@model IReadOnlyList<CRMManagement.Application.DTOs.ActivityListItemDto>
<div class="rounded-2xl border overflow-hidden"
     style="background-color:light-dark(#e8eef5, rgba(255,255,255,.03));border-color:light-dark(#adb8c4, rgba(255,255,255,.06))">
    <div class="flex flex-wrap items-center gap-3 px-5 py-4"
         style="border-bottom:1px solid light-dark(#d5dbdb, rgba(255,255,255,.08))">
        <div>
            <h3 class="text-sm font-semibold uppercase tracking-[0.18em]" style="color:light-dark(#545b64, #cbd5e1)">Recent Activities</h3>
            <div class="mt-1 text-xs" style="color:light-dark(#687078, #94a3b8)">Latest tasks, calls, meetings, and emails across the CRM.</div>
        </div>
        <i class="ml-auto fa-solid fa-clock-rotate-left text-brand text-sm"></i>
    </div>

    @if (Model.Count == 0)
    {
        <div class="p-5 text-sm" style="color:light-dark(#687078, #94a3b8)">No recent activities.</div>
    }
    else
    {
        <div class="overflow-x-auto">
            <table data-cm-table="home-recent-activities" class="crm-dash-table min-w-full divide-y text-sm" style="--tw-divide-opacity:.12; border-color:light-dark(#d5dbdb, rgba(255,255,255,.08))">
                <thead style="background-color:light-dark(#dde3ea, rgba(0,0,0,.15))">
                    <tr style="color:light-dark(#545b64, #94a3b8)">
                        <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wider" data-col-idx="0">Subject</th>
                        <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wider" data-col-idx="1">Type</th>
                        <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wider" data-col-idx="2">Status</th>
                        <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wider" data-col-idx="3">Due Date</th>
                        @* Extra Zoho fields — default-hidden, surfaced via the "Columns" picker *@
                        <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wider" data-col-idx="4"  data-cm-default-hide="1">Priority</th>
                        <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wider" data-col-idx="5"  data-cm-default-hide="1">Owner</th>
                        <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wider" data-col-idx="6"  data-cm-default-hide="1">Related To</th>
                        <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wider" data-col-idx="7"  data-cm-default-hide="1">Description</th>
                        <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wider" data-col-idx="8"  data-cm-default-hide="1">Activity Type</th>
                        <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wider" data-col-idx="9"  data-cm-default-hide="1">Call Type</th>
                        <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wider" data-col-idx="10" data-cm-default-hide="1">Start</th>
                        <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wider" data-col-idx="11" data-cm-default-hide="1">End</th>
                        <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wider" data-col-idx="12" data-cm-default-hide="1">Location</th>
                        <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wider" data-col-idx="13" data-cm-default-hide="1">Completed</th>
                        <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wider" data-col-idx="14" data-cm-default-hide="1">Created (Zoho)</th>
                        <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wider" data-col-idx="15" data-cm-default-hide="1">Modified (Zoho)</th>
                    </tr>
                </thead>
                <tbody class="divide-y" style="border-color:light-dark(#d5dbdb, rgba(255,255,255,.06))">
                    @foreach (var a in Model)
                    {
                        var actStart    = a.StartAt?.ToString("yyyy-MM-dd HH:mm") ?? "-";
                        var actEnd      = a.EndAt?.ToString("yyyy-MM-dd HH:mm") ?? "-";
                        var actComp     = a.CompletedAt?.ToString("yyyy-MM-dd HH:mm") ?? "-";
                        var actZCreated = a.ZohoCreatedTime?.ToString("yyyy-MM-dd HH:mm") ?? "-";
                        var actZMod     = a.ZohoModifiedTime?.ToString("yyyy-MM-dd HH:mm") ?? "-";
                        var actDesc     = string.IsNullOrWhiteSpace(a.Description) ? "-" : (a.Description!.Length > 80 ? a.Description.Substring(0, 80) + "…" : a.Description);
                        var actRel      = string.IsNullOrWhiteSpace(a.RelatedType) ? "-" : a.RelatedType;
                        <tr>
                            <td data-label="Subject" class="px-4 py-3" style="color:light-dark(#16191f, #f1f5f9)">@a.Subject</td>
                            <td data-label="Type" class="px-4 py-3" style="color:light-dark(#545b64, #cbd5e1)">@a.Type</td>
                            <td data-label="Status" class="px-4 py-3" style="color:light-dark(#545b64, #cbd5e1)">@a.Status</td>
                            <td data-label="Due Date" class="px-4 py-3" style="color:light-dark(#687078, #94a3b8)">@(a.DueDate?.ToString("yyyy-MM-dd") ?? "-")</td>
                            <td data-label="Priority" class="px-4 py-3" style="color:light-dark(#545b64, #cbd5e1)">@(a.Priority ?? "-")</td>
                            <td data-label="Owner" class="px-4 py-3" style="color:light-dark(#545b64, #cbd5e1)">@(a.OwnerName ?? "-")</td>
                            <td data-label="Related To" class="px-4 py-3" style="color:light-dark(#545b64, #cbd5e1)">@actRel</td>
                            <td data-label="Description" class="px-4 py-3" style="color:light-dark(#545b64, #cbd5e1)" title="@(a.Description ?? "")">@actDesc</td>
                            <td data-label="Activity Type" class="px-4 py-3" style="color:light-dark(#545b64, #cbd5e1)">@(a.ActivityType ?? "-")</td>
                            <td data-label="Call Type" class="px-4 py-3" style="color:light-dark(#545b64, #cbd5e1)">@(a.CallType ?? "-")</td>
                            <td data-label="Start" class="px-4 py-3 whitespace-nowrap" style="color:light-dark(#545b64, #cbd5e1)">@actStart</td>
                            <td data-label="End" class="px-4 py-3 whitespace-nowrap" style="color:light-dark(#545b64, #cbd5e1)">@actEnd</td>
                            <td data-label="Location" class="px-4 py-3" style="color:light-dark(#545b64, #cbd5e1)">@(a.Location ?? "-")</td>
                            <td data-label="Completed" class="px-4 py-3 whitespace-nowrap" style="color:light-dark(#545b64, #cbd5e1)">@actComp</td>
                            <td data-label="Created (Zoho)" class="px-4 py-3 whitespace-nowrap" style="color:light-dark(#545b64, #cbd5e1)">@actZCreated</td>
                            <td data-label="Modified (Zoho)" class="px-4 py-3 whitespace-nowrap" style="color:light-dark(#545b64, #cbd5e1)">@actZMod</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
