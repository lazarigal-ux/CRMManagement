@model IReadOnlyList<CRMManagement.Application.DTOs.OpportunityListItemDto>
<div class="crm-dash-panel space-y-3">
    <div class="flex items-center justify-between gap-3">
        <div>
            <h3>Top Opportunities</h3>
            <div class="mt-1 text-xs" style="color:light-dark(#687078, #94a3b8)">Top 5 ranked by deal amount.</div>
        </div>
        <i class="fa-solid fa-trophy text-brand text-sm"></i>
    </div>
    @if (Model.Count == 0)
    {
        <div class="text-sm" style="color:light-dark(#687078, #94a3b8)">No opportunities yet.</div>
    }
    else
    {
        <div class="crm-dash-opp-cards">
            @foreach (var o in Model)
            {
                <div class="rounded-xl border p-3"
                     style="background-color:light-dark(#ffffff, rgba(255,255,255,.04));border-color:light-dark(#dde3ea, rgba(255,255,255,.06))">
                    <div class="flex items-start justify-between gap-3">
                        <div class="min-w-0">
                            <a asp-page="/Opportunities/Details" asp-route-id="@o.Id"
                               class="text-sm font-semibold hover:underline truncate block"
                               style="color:light-dark(#0073bb, #7dd3fc)">@o.Name</a>
                            <div class="mt-1 text-xs" style="color:light-dark(#687078, #94a3b8)">@o.Status · @(o.CloseDate?.ToString("yyyy-MM-dd") ?? "No close date")</div>
                        </div>
                        <div class="text-base font-semibold whitespace-nowrap" style="color:light-dark(#16191f, #f1f5f9)">@o.Amount.ToString("N2") @o.Currency</div>
                    </div>
                </div>
            }
        </div>
    }
</div>
