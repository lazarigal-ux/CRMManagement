@model IReadOnlyList<CRMManagement.Application.DTOs.DashboardLeadDto>
<div class="crm-dash-panel space-y-3">
    <div class="flex items-center justify-between gap-3">
        <div>
            <h3>Today's Leads</h3>
            <div class="mt-1 text-xs" style="color:light-dark(#687078, #94a3b8)">New leads from today (or the last week if today is empty).</div>
        </div>
        <i class="fa-solid fa-user-plus text-sm" style="color:light-dark(#0073bb, #60a5fa)"></i>
    </div>
    @if (Model.Count == 0)
    {
        <div class="text-sm" style="color:light-dark(#687078, #94a3b8)">No new leads today.</div>
    }
    else
    {
        <div class="overflow-x-auto">
            <table data-cm-table="home-todays-leads" class="crm-dash-table min-w-full text-sm">
                <thead style="background-color:light-dark(#dde3ea, rgba(0,0,0,.15))">
                    <tr style="color:light-dark(#545b64, #94a3b8)">
                        <th class="px-3 py-2 text-left text-xs font-semibold uppercase tracking-wider" data-col-idx="0">Name</th>
                        <th class="px-3 py-2 text-left text-xs font-semibold uppercase tracking-wider" data-col-idx="1">Company</th>
                        <th class="px-3 py-2 text-left text-xs font-semibold uppercase tracking-wider" data-col-idx="2">Email</th>
                        <th class="px-3 py-2 text-left text-xs font-semibold uppercase tracking-wider" data-col-idx="3">Phone</th>
                        <th class="px-3 py-2 text-left text-xs font-semibold uppercase tracking-wider" data-col-idx="4">Source</th>
                        <th class="px-3 py-2 text-left text-xs font-semibold uppercase tracking-wider" data-col-idx="5">Status</th>
                        @* Extra Zoho fields — default-hidden, surfaced via the "Columns" picker *@
                        <th class="px-3 py-2 text-left text-xs font-semibold uppercase tracking-wider" data-col-idx="6"  data-cm-default-hide="1">Title</th>
                        <th class="px-3 py-2 text-left text-xs font-semibold uppercase tracking-wider" data-col-idx="7"  data-cm-default-hide="1">Mobile</th>
                        <th class="px-3 py-2 text-left text-xs font-semibold uppercase tracking-wider" data-col-idx="8"  data-cm-default-hide="1">Industry</th>
                        <th class="px-3 py-2 text-left text-xs font-semibold uppercase tracking-wider" data-col-idx="9"  data-cm-default-hide="1">Website</th>
                        <th class="px-3 py-2 text-left text-xs font-semibold uppercase tracking-wider" data-col-idx="10" data-cm-default-hide="1">Owner</th>
                        <th class="px-3 py-2 text-left text-xs font-semibold uppercase tracking-wider" data-col-idx="11" data-cm-default-hide="1">Created (Zoho)</th>
                    </tr>
                </thead>
                <tbody class="divide-y" style="border-color:light-dark(#d5dbdb, rgba(255,255,255,.06))">
                    @foreach (var l in Model)
                    {
                        var leadZCreated = l.ZohoCreatedTime?.ToString("yyyy-MM-dd HH:mm") ?? "-";
                        <tr>
                            <td data-label="Name" class="px-3 py-2"><a class="hover:underline" style="color:light-dark(#0073bb, #7dd3fc)" asp-page="/Leads/Details" asp-route-id="@l.Id">@l.FirstName @l.LastName</a></td>
                            <td data-label="Company" class="px-3 py-2" style="color:light-dark(#545b64, #cbd5e1)">@(l.Company ?? "-")</td>
                            <td data-label="Email" class="px-3 py-2" style="color:light-dark(#545b64, #cbd5e1)">@(l.Email ?? "-")</td>
                            <td data-label="Phone" class="px-3 py-2" style="color:light-dark(#545b64, #cbd5e1)">@(l.Phone ?? "-")</td>
                            <td data-label="Source" class="px-3 py-2" style="color:light-dark(#545b64, #cbd5e1)">@(l.Source ?? "-")</td>
                            <td data-label="Status" class="px-3 py-2" style="color:light-dark(#545b64, #cbd5e1)">@l.Status</td>
                            <td data-label="Title" class="px-3 py-2" style="color:light-dark(#545b64, #cbd5e1)">@(l.Title ?? "-")</td>
                            <td data-label="Mobile" class="px-3 py-2 whitespace-nowrap" style="color:light-dark(#545b64, #cbd5e1)">@(l.Mobile ?? "-")</td>
                            <td data-label="Industry" class="px-3 py-2" style="color:light-dark(#545b64, #cbd5e1)">@(l.Industry ?? "-")</td>
                            <td data-label="Website" class="px-3 py-2" style="color:light-dark(#545b64, #cbd5e1)">@(l.Website ?? "-")</td>
                            <td data-label="Owner" class="px-3 py-2" style="color:light-dark(#545b64, #cbd5e1)">@(l.OwnerName ?? "-")</td>
                            <td data-label="Created (Zoho)" class="px-3 py-2 whitespace-nowrap" style="color:light-dark(#545b64, #cbd5e1)">@leadZCreated</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
