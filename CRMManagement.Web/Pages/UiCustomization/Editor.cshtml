            function normalizeFieldKey(s) {
                const raw = String(s || "").trim();
                if (!raw) return "";
                // Keep it HTML-id + name friendly.
                return raw.toLowerCase().replace(/[^a-z0-9_-]+/g, "_").replace(/^_+|_+$/g, "");
            }

            function escapeHtmlAttr(s) {
                return String(s ?? "")
                    .replace(/&/g, "&amp;")
                    .replace(/\"/g, "&quot;")
                    .replace(/</g, "&lt;")
                    .replace(/>/g, "&gt;");
            }

            function normalizeSizeCss(raw, fallback) {
                const v = String(raw || "").trim();
                if (!v) return String(fallback || "");
                if (/^\d+(?:\.\d+)?(px|em|rem|%)$/.test(v)) return v;
                if (/^\d+(?:\.\d+)?$/.test(v)) return v + "px";
                return String(fallback || "");
            }

            function buildImageHtml(src, alt, widthPxOrCss, heightPxOrCss, classAdd, align) {
                const safeSrc = escapeHtmlAttr(src || "");
                if (!safeSrc) return "";

                const safeAlt = escapeHtmlAttr(alt || "");
                const safeCls = String(classAdd || "").replace(/\"/g, "").trim();
                const widthCss = normalizeSizeCss(widthPxOrCss, "");
                const heightCss = normalizeSizeCss(heightPxOrCss, "");

                const a = String(align || "inline").toLowerCase().trim();
                let placementStyle = "display:inline-block;vertical-align:middle;";
                if (a === "left") placementStyle = "display:block;margin-left:0;margin-right:auto;";
                if (a === "center") placementStyle = "display:block;margin-left:auto;margin-right:auto;";
                if (a === "right") placementStyle = "display:block;margin-left:auto;margin-right:0;";

                let sizeStyle = "max-width:100%;";
                if (widthCss) sizeStyle += `width:${widthCss};`;
                if (heightCss) sizeStyle += `height:${heightCss};`;
                if (!heightCss) sizeStyle += "height:auto;";

                const style = ` style=\"${placementStyle}${sizeStyle}\"`;
                const clsAttr = safeCls ? ` class=\"${escapeHtmlAttr(safeCls)}\"` : "";
                const altAttr = ` alt=\"${safeAlt}\"`;

                return `<img src=\"${safeSrc}\"${altAttr}${clsAttr}${style} />`;
            }

            function updateImgWidthCustomVisibility() {
                try {
                    if (!selImgWidthCustom) return;
                    const show = String(selImgWidth?.value || "") === "custom";
                    selImgWidthCustom.classList.toggle("hidden", !show);
                } catch { }
            }

            function updateImgHeightCustomVisibility() {
                try {
                    if (!selImgHeightCustom) return;
                    const show = String(selImgHeight?.value || "") === "custom";
                    selImgHeightCustom.classList.toggle("hidden", !show);
                } catch { }
            }

            function updateAddImagePreview() {
                try {
                    if (!addImgPreviewImg) return;

                    const src = String(selAddImgSrc?.value || "").trim();
                    if (!src) {
                        addImgPreviewImg.removeAttribute("src");
                        addImgPreviewImg.style.cssText = "";
                        return;
                    }

                    const align = String(selAddImgAlign?.value || "inline").toLowerCase().trim();
                    const sizeRaw = String(selAddImgSize?.value || "").trim();
                    const widthCss = sizeRaw ? (String(sizeRaw).trim() + "px") : "";
                    const heightRaw = String(selAddImgHeight?.value || "").trim();
                    const heightCss = heightRaw ? (String(heightRaw).trim() + "px") : "";

                    addImgPreviewImg.setAttribute("src", src);

                    let placementStyle = "display:inline-block;vertical-align:middle;";
                    if (align === "left") placementStyle = "display:block;margin-left:0;margin-right:auto;";
                    if (align === "center") placementStyle = "display:block;margin-left:auto;margin-right:auto;";
                    if (align === "right") placementStyle = "display:block;margin-left:auto;margin-right:0;";

                    let sizeStyle = "max-width:100%;";
                    if (widthCss) sizeStyle += `width:${widthCss};`;
                    if (heightCss) sizeStyle += `height:${heightCss};`;
                    if (!heightCss) sizeStyle += "height:auto;";
                    addImgPreviewImg.style.cssText = placementStyle + sizeStyle;
                } catch { }
            }

            function buildDefaultFieldHtml() {
                const key = normalizeFieldKey(selNewFieldKey?.value);
                if (!key) return "";

                const label = String(selNewFieldLabel?.value || key).trim();
                const type = String(selNewFieldType?.value || "text").trim();
                const required = !!chkNewFieldRequired?.checked;
                const ph = String(selNewFieldPlaceholder?.value || "");

                const id = "dyn_" + key;
                const reqAttr = required ? " required" : "";
                const phAttr = ph ? ` placeholder=\"${escapeHtmlAttr(ph)}\"` : "";
                const star = required ? "<span class=\"text-red-500\">*</span>" : "";

                // Match Create/Edit User styling.
                return (
                    `<div class=\"space-y-1\">` +
                    `<label for=\"${id}\" class=\"block text-sm font-medium text-slate-200\">` +
                    `<span class=\"inline-flex items-center gap-2\">` +
                    `<i class=\"fa-solid fa-pen\"></i>` +
                    `<span>${escapeHtmlAttr(label)}</span>${star}` +
                    `</span></label>` +
                    `<input id=\"${id}\" name=\"dyn.${key}\" type=\"${escapeHtmlAttr(type)}\"${reqAttr}${phAttr} ` +
                    `class=\"w-full rounded-lg border border-slate-500/50 bg-slate-800/40 px-3 py-2 text-slate-100 placeholder-slate-400 focus:border-brand focus:ring-brand focus:ring-1\" />` +
                    `</div>`
                );
            }

            function postToFrame(msg) {
                try {
                    if (!frame || !frame.contentWindow) return false;
                    frame.contentWindow.postMessage(msg, "*");
                    return true;
                } catch {
                    return false;
                }
            }

            function requestMoveStep(direction) {
                if (!currentSelector) { setStatus("No element selected."); return; }
                if (currentMode !== "move") setMode("move");

                const ok = postToFrame({ type: "uiedit:moveStep", direction: String(direction || "").toLowerCase() });
                if (!ok) setStatus("Failed to send to preview (blocked)." );
            }

            function cssRgbToHex(s) {
                const v = String(s || "").trim().toLowerCase();
                if (!v) return "";
                if (v === "transparent") return "";

                // already hex
                if (v[0] === "#") {
                    if (v.length === 4) {
                        return "#" + v[1] + v[1] + v[2] + v[2] + v[3] + v[3];
                    }
                    if (v.length === 7) return v;
                }

                const m = v.match(/^rgba?\((\d+)\s*,\s*(\d+)\s*,\s*(\d+)(?:\s*,\s*([0-9.]+))?\)$/);
                if (!m) return "";

                const r = Math.max(0, Math.min(255, parseInt(m[1], 10)));
                const g = Math.max(0, Math.min(255, parseInt(m[2], 10)));
                const b = Math.max(0, Math.min(255, parseInt(m[3], 10)));

                const toHex = (n) => n.toString(16).padStart(2, "0");
                return "#" + toHex(r) + toHex(g) + toHex(b);
            }

            function formatSelectOptions(opts) {
                try {
                    const rows = Array.isArray(opts) ? opts : [];
                    return rows.map(o => {
                        const v = (o && o.value !== undefined) ? String(o.value) : "";
                        const t = (o && o.text !== undefined) ? String(o.text) : "";
                        return t && t !== v ? (v + "|" + t) : v;
                    }).join("\n");
                } catch {
                    return "";
                }
            }

            window.addEventListener("message", (ev) => {
                const msg = ev && ev.data;
                if (!msg || !msg.type) return;

                if (msg.type === "uiedit:iconCatalog") {
                    try {
                        const rows = Array.isArray(msg.classes) ? msg.classes : [];
                        if (iconClassList) {
                            iconClassList.innerHTML = "";
                            rows.slice(0, 250).forEach(v => {
                                const s = String(v || "").trim();
                                if (!s) return;
                                const opt = document.createElement("option");
                                opt.value = s;
                                iconClassList.appendChild(opt);
                            });
                        }
                    } catch { }
                    return;
                }

                if (msg.type === "uiedit:imageCatalog") {
                    try {
                        const rows = Array.isArray(msg.srcs) ? msg.srcs : [];
                        if (iconImageList) {
                            iconImageList.innerHTML = "";
                            rows.slice(0, 250).forEach(v => {
                                const s = String(v || "").trim();
                                if (!s) return;
                                const opt = document.createElement("option");
                                opt.value = s;
                                iconImageList.appendChild(opt);
                            });
                        }
                    } catch { }
                    return;
                }

                if (msg.type === "uiedit:movedAbs") {
                    const sourceSelector = String(msg.sourceSelector || "").trim();
                    const containerSelector = String(msg.containerSelector || "").trim();
                    const left = Number(msg.left);
                    const top = Number(msg.top);

                    if (sourceSelector && containerSelector && Number.isFinite(left) && Number.isFinite(top)) {
                        upsertMoveOverride(sourceSelector, {
                            type: "moveAbs",
                            containerSelector,
                            left,
                            top
                        });

                        currentSelector = sourceSelector;
                        if (selSelector) selSelector.value = sourceSelector;
                        setStatus("Moved locally (not saved yet)." );
                    }
                    return;
                }

                if (msg.type === "uiedit:moved") {
                    const sourceSelector = String(msg.sourceSelector || "").trim();
                    const containerSelector = String(msg.containerSelector || "").trim();
                    const referenceSelector = String(msg.referenceSelector || "").trim();
                    const position = String(msg.position || "after").trim();

                    if (sourceSelector && containerSelector && referenceSelector) {
                        upsertMoveOverride(sourceSelector, {
                            type: "move",
                            containerSelector,
                            referenceSelector,
                            position
                        });

                        // Keep inspector pointing to the moved element.
                        currentSelector = sourceSelector;
                        if (selSelector) selSelector.value = sourceSelector;
                        setStatus("Moved locally (not saved yet)." );
                    }
                    return;
                }

                if (msg.type === "uiedit:imageTransformed") {
                    const selector = String(msg.selector || "").trim();
                    const styles = (msg.styles && typeof msg.styles === "object") ? msg.styles : null;

                    if (selector && styles) {
                        const map = {};
                        try {
                            Object.keys(styles).forEach(k => {
                                const key = String(k || "").trim();
                                if (!key) return;
                                map[key] = String(styles[k] ?? "");
                            });
                        } catch { }

                        upsertStyleActions(selector, map);

                        currentSelector = selector;
                        if (selSelector) selSelector.value = selector;
                        setStatus("Image moved/resized locally (not saved yet)." );
                    }
                    return;
                }

                if (msg.type !== "uiedit:selected") return;

                currentSelector = msg.selector || null;
                currentKind = msg.kind || null;
                currentInsertContainerSelector = msg.insertContainerSelector || null;
                currentIconSelector = msg.iconTargetSelector || null;
                updateModeButtonsVisibility(!!currentSelector, currentKind);

                if (normalizeMode(currentKind)) {
                    setMode(normalizeMode(currentKind));
                }

                // Keep current mode on selection (do not auto-switch).

                if (selSelector) selSelector.value = msg.selector || "";
                if (selText) selText.value = msg.text || "";

                if (selClasses) selClasses.value = msg.className || "";
                if (selIconClass) selIconClass.value = msg.className || "";

                const bgEff = msg.bgEffective || msg.bg || "";
                const fg = msg.color || "";

                if (selBgRaw) selBgRaw.value = bgEff;
                if (selTextColorRaw) selTextColorRaw.value = fg;

                // Update color inputs if we can convert.
                const bgHex = cssRgbToHex(bgEff);
                if (bgHex && selBg) selBg.value = bgHex;

                const fgHex = cssRgbToHex(fg);
                if (fgHex && selTextColor) selTextColor.value = fgHex;

                if (selTable) selTable.value = msg.tableSelector || "";
                if (selCol) selCol.value = (typeof msg.colIndex === "number") ? String(msg.colIndex) : "";

                if (selImgSrc) selImgSrc.value = msg.src || "";
                if (selImgAlt) selImgAlt.value = msg.alt || "";

                // INPUT details
                if (selInputType && msg.inputType) {
                    const v = String(msg.inputType || "").toLowerCase().trim();
                    // Only set if this option exists, otherwise keep current.
                    if ([...selInputType.options].some(o => o.value === v)) selInputType.value = v;
                }
                if (chkInputRequired) chkInputRequired.checked = !!msg.required;
                if (selInputPlaceholder) selInputPlaceholder.value = msg.placeholder || "";
                if (selInputValue) selInputValue.value = (msg.value === undefined || msg.value === null) ? "" : String(msg.value);

                if (selSelectOptions) selSelectOptions.value = formatSelectOptions(msg.selectOptions);
                if (selSelectValue) selSelectValue.value = String(msg.selectValue || "");

                setStatus("Selected.");

                updateResetSelectedButton();
                updateImgWidthCustomVisibility();
                updateImgHeightCustomVisibility();
            });

            function readFileAsDataUrl(file) {
                return new Promise((resolve) => {
                    try {
                        if (!file) return resolve("");
                        const r = new FileReader();
                        r.onload = () => resolve(String(r.result || ""));
                        r.onerror = () => resolve("");
                        r.readAsDataURL(file);
                    } catch {
                        resolve("");
                    }
                });
            }

            async function hydrateAddImageSrcFromUpload() {
                try {
                    const file = (fileAddImgUpload && fileAddImgUpload.files && fileAddImgUpload.files.length)
                        ? fileAddImgUpload.files[0]
                        : null;
                    if (!file) return "";
                    const dataUrl = await readFileAsDataUrl(file);
                    if (dataUrl && selAddImgSrc) selAddImgSrc.value = dataUrl;
                    return dataUrl;
                } catch {
                    return "";
                }
            }

            if (fileAddImgUpload) {
                fileAddImgUpload.addEventListener("change", async () => {
                    const dataUrl = await hydrateAddImageSrcFromUpload();
                    if (dataUrl) setStatus("Picture loaded (not inserted yet)." );
                    updateAddImagePreview();
                });
            }

            if (selAddImgSrc) selAddImgSrc.addEventListener("input", () => updateAddImagePreview());
            if (selAddImgSize) selAddImgSize.addEventListener("change", () => updateAddImagePreview());
            if (selAddImgHeight) selAddImgHeight.addEventListener("change", () => updateAddImagePreview());
            if (selAddImgAlign) selAddImgAlign.addEventListener("change", () => updateAddImagePreview());

            if (btnAddImage) {
                btnAddImage.addEventListener("click", async () => {
                    if (!currentSelector) {
                        setStatus("Select an element first (to choose where to insert)." );
                        return;
                    }

                    // Prefer uploaded file if present, else use typed/pasted src.
                    let src = String(selAddImgSrc?.value || "").trim();
                    const file = (fileAddImgUpload && fileAddImgUpload.files && fileAddImgUpload.files.length)
                        ? fileAddImgUpload.files[0]
                        : null;
                    if (file) {
                        const dataUrl = await readFileAsDataUrl(file);
                        if (dataUrl) src = dataUrl;
                    }

                    const alt = String(selAddImgAlt?.value || "").trim();
                    const size = String(selAddImgSize?.value || "").trim();
                    const height = String(selAddImgHeight?.value || "").trim();
                    const cls = String(selAddImgClassAdd?.value || "").trim();

                    const align = String(selAddImgAlign?.value || "inline").trim();

                    const html = buildImageHtml(src, alt, size, height, cls, align);
                    if (!html) {
                        setStatus("ADD picture: provide a src or upload an image." );
                        return;
                    }

                    // Route through existing ADD apply logic.
                    if (selInsertHtml) selInsertHtml.value = html;
                    setStep("edit");
                    setMode("add");
                    if (btnApply) btnApply.click();
                });
            }

            if (btnApply) {
                btnApply.addEventListener("click", async () => {
                    if (!currentSelector) { setStatus("No element selected."); return; }

                    if (currentMode === "move") {
                        setStatus("MOVE: drag & drop inside the preview (then Save).");
                        return;
                    }

                    const actions = [];

                    // For ADD mode we may need to target a container instead of a void element (e.g. input/img).
                    // This enables "append" (move to end) to work even if the selected element can't contain children.
                    let effectiveSelector = currentSelector;

                    if (currentMode === "table") {
                        setStatus("Use Table tools for table changes.");
                        return;
                    }

                    if (currentMode === "icon") {
                        const iconSel = String(currentIconSelector || currentSelector || "").trim();
                        if (!iconSel) {
                            setStatus("ICON: select an element.");
                            return;
                        }

                        // 1) Upload icon image
                        const file = (fileIconUpload && fileIconUpload.files && fileIconUpload.files.length)
                            ? fileIconUpload.files[0]
                            : null;
                        if (file) {
                            const dataUrl = await readFileAsDataUrl(file);
                            if (!dataUrl) {
                                setStatus("ICON: upload failed.");
                                return;
                            }

                            const sizeCss = normalizeSizeCss(selIconImgSize?.value, "1em");

                            actions.push({ type: "attr", name: "src", value: dataUrl });
                            actions.push({ type: "style", name: "backgroundImage", value: `url(\"${dataUrl}\")` });
                            actions.push({ type: "style", name: "backgroundRepeat", value: "no-repeat" });
                            actions.push({ type: "style", name: "backgroundSize", value: "contain" });
                            actions.push({ type: "style", name: "backgroundPosition", value: "center" });
                            actions.push({ type: "style", name: "display", value: "inline-block" });
                            actions.push({ type: "style", name: "width", value: sizeCss });
                            actions.push({ type: "style", name: "height", value: sizeCss });
                            actions.push({ type: "style", name: "lineHeight", value: sizeCss });
                            actions.push({ type: "style", name: "color", value: "transparent" });

                            upsertOverride(iconSel, actions);
                            const ok = postToFrame({ type: "uiedit:apply", selector: iconSel, actions });
                            setStatus(ok ? "ICON image applied (not saved yet)." : "Iframe not ready. Try again.");
                            return;
                        }

                        // 2) Pick an existing image URL
                        const pickedSrc = String(selIconImageSrc?.value || "").trim();
                        if (pickedSrc) {
                            const sizeCss = normalizeSizeCss(selIconImgSize?.value, "1em");
                            actions.push({ type: "attr", name: "src", value: pickedSrc });
                            actions.push({ type: "style", name: "backgroundImage", value: `url(\"${pickedSrc}\")` });
                            actions.push({ type: "style", name: "backgroundRepeat", value: "no-repeat" });
                            actions.push({ type: "style", name: "backgroundSize", value: "contain" });
                            actions.push({ type: "style", name: "backgroundPosition", value: "center" });
                            actions.push({ type: "style", name: "display", value: "inline-block" });
                            actions.push({ type: "style", name: "width", value: sizeCss });
                            actions.push({ type: "style", name: "height", value: sizeCss });
                            actions.push({ type: "style", name: "lineHeight", value: sizeCss });
                            actions.push({ type: "style", name: "color", value: "transparent" });

                            upsertOverride(iconSel, actions);
                            const ok = postToFrame({ type: "uiedit:apply", selector: iconSel, actions });
                            setStatus(ok ? "ICON image applied (not saved yet)." : "Iframe not ready. Try again.");
                            return;
                        }

                        // 3) Class-based icons
                        const cls = String(selIconClass?.value || "").trim();
                        if (!cls) {
                            setStatus("ICON: pick an image or provide class names.");
                            return;
                        }

                        actions.push({ type: "classSet", value: cls });
                        upsertOverride(iconSel, actions);
                        const ok = postToFrame({ type: "uiedit:apply", selector: iconSel, actions });
                        setStatus(ok ? "ICON updated (not saved yet)." : "Iframe not ready. Try again.");
                        return;
                    }

                    if (currentMode === "select") {
                        const raw = String(selSelectOptions?.value || "");
                        const lines = raw.split(/\r?\n/).map(l => l.trim()).filter(Boolean);
                        const options = lines.map(line => {
                            const parts = line.split("|");
                            const value = (parts[0] || "").trim();
                            const text = (parts[1] || "").trim();
                            return { value, text: text || value };
                        });

                        const selectedRaw = String(selSelectValue?.value || "").trim();

                        if (!options.length && !selectedRaw) {
                            setStatus("SELECT: provide options or selected value.");
                            return;
                        }

                        if (options.length) actions.push({ type: "selectOptions", options });
                        if (selectedRaw) actions.push({ type: "selectValue", value: selectedRaw });

                        upsertOverride(currentSelector, actions);
                        const ok = postToFrame({ type: "uiedit:apply", selector: currentSelector, actions });
                        if (!ok) setStatus("Failed to send to preview (blocked)." );
                        else setStatus("SELECT updated (not saved yet).");
                        return;
                    }

                    if (currentMode === "add") {
                        const pos = (selInsertPos?.value || "after").trim();
                        const custom = String(selInsertHtml?.value || "");
                        const html = custom.trim() ? custom : buildDefaultFieldHtml();

                        if (!String(html || "").trim()) {
                            setStatus("ADD: provide Field key or Custom HTML.");
                            return;
                        }

                        const posNorm = String(pos || "").toLowerCase();
                        if (posNorm === "append" || posNorm === "prepend") {
                            effectiveSelector = (currentInsertContainerSelector || currentSelector);
                        }

                        actions.push({ type: "insertHtml", position: pos, html: String(html) });
                    } else if (currentMode === "image") {
                        const src = (selImgSrc?.value || "").trim();
                        const alt = (selImgAlt?.value || "").trim();
                        const cls = (selImgClassAdd?.value || "").trim();

                        if (src) actions.push({ type: "attr", name: "src", value: src });
                        if (alt) actions.push({ type: "attr", name: "alt", value: alt });
                        if (cls) actions.push({ type: "classAdd", value: cls });

                        // Optional placement controls
                        const wSel = String(selImgWidth?.value || "").trim();
                        let widthCss = "";
                        if (wSel && wSel !== "custom") widthCss = wSel;
                        if (wSel === "custom") {
                            const n = String(selImgWidthCustom?.value || "").trim();
                            widthCss = normalizeSizeCss(n, "");
                        }

                        const hSel = String(selImgHeight?.value || "").trim();
                        let heightCss = "";
                        if (hSel && hSel !== "custom") heightCss = hSel;
                        if (hSel === "custom") {
                            const n = String(selImgHeightCustom?.value || "").trim();
                            heightCss = normalizeSizeCss(n, "");
                        }

                        if (widthCss) {
                            actions.push({ type: "style", name: "width", value: widthCss });
                            actions.push({ type: "style", name: "maxWidth", value: "100%" });
                        }

                        if (heightCss) {
                            actions.push({ type: "style", name: "height", value: heightCss });
                        } else if (widthCss) {
                            // If only width is set, keep aspect ratio.
                            actions.push({ type: "style", name: "height", value: "auto" });
                        }

                        const align = String(selImgAlign?.value || "").trim().toLowerCase();
                        if (align) {
                            if (align === "inline") {
                                actions.push({ type: "style", name: "display", value: "inline-block" });
                                actions.push({ type: "style", name: "verticalAlign", value: "middle" });
                                actions.push({ type: "style", name: "marginLeft", value: "" });
                                actions.push({ type: "style", name: "marginRight", value: "" });
                            } else if (align === "left") {
                                actions.push({ type: "style", name: "display", value: "block" });
                                actions.push({ type: "style", name: "marginLeft", value: "0" });
                                actions.push({ type: "style", name: "marginRight", value: "auto" });
                            } else if (align === "center") {
                                actions.push({ type: "style", name: "display", value: "block" });
                                actions.push({ type: "style", name: "marginLeft", value: "auto" });
                                actions.push({ type: "style", name: "marginRight", value: "auto" });
                            } else if (align === "right") {
                                actions.push({ type: "style", name: "display", value: "block" });
                                actions.push({ type: "style", name: "marginLeft", value: "auto" });
                                actions.push({ type: "style", name: "marginRight", value: "0" });
                            }
                        }
                    } else if (currentMode === "input") {
                        const t = (selInputType?.value || "").trim();
                        if (t) actions.push({ type: "attr", name: "type", value: t });

                        // placeholder: empty string removes attribute
                        const ph = (selInputPlaceholder?.value || "");
                        actions.push({ type: "attr", name: "placeholder", value: String(ph) });

                        // value: use a dedicated action to set element.value
                        const v = (selInputValue?.value || "");
                        actions.push({ type: "value", value: String(v) });

                        // required: only apply when explicitly requested
                        if (chkInputRequired?.checked) {
                            actions.push({ type: "attr", name: "required", value: "required" });
                        } else {
                            // Remove required if unchecked (explicit)
                            actions.push({ type: "attr", name: "required", value: "" });
                        }
                    } else {
                        // text/tab
                        actions.push({ type: "text", value: selText?.value ?? "" });

                        // IMPORTANT: color pickers always have a value, so only apply when explicitly requested.
                        if (chkSetBg?.checked) {
                            const bg = selBg?.value;
                            if (bg) actions.push({ type: "style", name: "backgroundColor", value: bg });
                        }

                        if (chkSetTextColor?.checked) {
                            const c = selTextColor?.value;
                            if (c) actions.push({ type: "style", name: "color", value: c });
                        }

                        const cls = (selClassAdd?.value || "").trim();
                        if (cls) actions.push({ type: "classAdd", value: cls });
                    }

                    upsertOverride(effectiveSelector, actions);

                    const ok = postToFrame({ type: "uiedit:apply", selector: effectiveSelector, actions });
                    setStatus(ok ? "Applied locally (not saved yet)." : "Iframe not ready. Try again.");
                });
            }

            if (selImgWidth) {
                selImgWidth.addEventListener("change", () => updateImgWidthCustomVisibility());
            }

            if (selImgHeight) {
                selImgHeight.addEventListener("change", () => updateImgHeightCustomVisibility());
            }

            if (btnHideCol) {
                btnHideCol.addEventListener("click", () => {
                    const tableSel = (selTable?.value || "").trim();
                    const colIndex = Number(selCol?.value);

                    if (!tableSel || !Number.isFinite(colIndex)) {
                        setStatus("Select a table header/cell first (so table + column are known).");
                        return;
                    }

                    const actions = [{ type: "tableColHide", colIndex }];
                    upsertOverride(tableSel, actions);

                    const ok = postToFrame({ type: "uiedit:apply", selector: tableSel, actions });
                    setStatus(ok ? "Column hidden locally (not saved yet)." : "Iframe not ready. Try again.");
                });
            }

            if (btnResetSelected) {
                btnResetSelected.addEventListener("click", () => {
                    const sel = getResetTargetSelector();
                    if (!sel) { setStatus("No element selected."); return; }

                    const idx = overrides.findIndex(o => o && o.selector === sel);
                    if (idx < 0) { setStatus("No saved changes for selected."); return; }

                    if (!confirmResetSelected()) {
                        setStatus("Reset canceled.");
                        return;
                    }

                    (async () => {
                        setStatus("Resetting selected...");

                        const url = "@Url.Page("/UiCustomization/Editor", "ResetSelected")";
                        const token = getAntiForgeryToken();
                        const payload = {
                            pageKey: effectivePageKey,
                            featureKey,
                            returnPath,
                            selector: sel
                        };

                        try {
                            const resp = await fetch(url, {
                                method: "POST",
                                credentials: "same-origin",
                                headers: {
                                    "Content-Type": "application/json",
                                    "RequestVerificationToken": token,
                                    "X-UIEditor-Debug": "1"
                                },
                                body: JSON.stringify(payload)
                            });

                            const data = await resp.json().catch(async () => {
                                const t = await resp.text();
                                const shortText = (t || "").replace(/\s+/g, " ").slice(0, 220);
                                return { ok: false, error: shortText ? (shortText + "…") : "Non-JSON response." };
                            });

                            if (!resp.ok || !data || data.ok !== true) {
                                setStatus("Reset selected failed: HTTP " + resp.status + " :: " + (data?.error ?? "unknown"));
                                return;
                            }

                            overrides.splice(idx, 1);
                            updateResetSelectedButton();

                            // We can't reliably undo arbitrary DOM mutations, so reload the iframe and reapply remaining overrides.
                            setStatus("Reset selected. Reloading preview...");
                            reloadFrameAndReapply();
                        } catch {
                            setStatus("Reset selected failed: network error.");
                        }
                    })();
                });
            }

            if (btnSave) {
                btnSave.addEventListener("click", async () => {
                    setStatus("Saving...");

                    const saveUrl = "@Url.Page("/UiCustomization/Editor", "Save")";
                    const token = getAntiForgeryToken();
                    dbg("Save click", {
                        href: String(location.href || ""),
                        origin: String(location.origin || ""),
                        protocol: String(location.protocol || ""),
                        saveUrl,
                        online: navigator.onLine,
                        tokenPresent: !!token,
                        tokenLen: token ? token.length : 0,
                        mode: (typeof currentMode !== 'undefined') ? currentMode : null,
                        selector: currentSelector
                    });

                    const payload = {
                        pageKey: effectivePageKey,
                        featureKey,
                        returnPath,
                        dom: { overrides }
                    };

                    let bodyJson = "";
                    try {
                        bodyJson = JSON.stringify(payload);
                        dbg("Payload size", { bytes: bodyJson.length });
                    } catch (e) {
                        dbg("Payload stringify failed", e);
                        setStatus("Save failed: payload serialize error.");
                        return;
                    }

                    try {
                        // Add a timeout so we can distinguish hang vs immediate failure.
                        const ac = new AbortController();
                        const t = setTimeout(() => ac.abort(), 12000);

                        const resp = await fetch(saveUrl, {
                            method: "POST",
                            credentials: "same-origin",
                            headers: {
                                "Content-Type": "application/json",
                                "RequestVerificationToken": token,
                                "X-UIEditor-Debug": "1"
                            },
                            body: bodyJson,
                            signal: ac.signal
                        });

                        clearTimeout(t);
                        dbg("Save response", {
                            ok: resp.ok,
                            status: resp.status,
                            url: resp.url,
                            redirected: resp.redirected,
                            type: resp.type
                        });

                        const data = await resp.json().catch(async () => {
                            const t = await resp.text();
                            dbg("Save non-JSON response", { status: resp.status, text: (t || "").slice(0, 1000) });
                            return { ok: false, error: t };
                        });

                        if (!resp.ok || !data || data.ok !== true) {
                            dbg("Save failed payload", data);
                            try { console.error("[UIEditor] Save failed", { status: resp.status, data }); } catch { }
                            setStatus("Save failed: HTTP " + resp.status + " :: " + (data?.error ?? "unknown"));
                            return;
                        }

                        setStatus("Saved. Redirecting...");

                        const target = (data && data.returnPath) ? String(data.returnPath) : String(returnPath);
                        const sep = target.includes("?") ? "&" : "?";
                        // Force a full reload so the user immediately sees server-applied overrides.
                        window.location.replace(target + sep + "__uireload=" + Date.now());
                    } catch (e) {
                        const err = e || {};
                        dbg("Save fetch threw", {
                            name: err.name,
                            message: err.message,
                            stack: err.stack
                        });

                        // Quick reachability check
                        try {
                            const h = await fetch("/healthz", { cache: "no-store" });
                            dbg("healthz", { ok: h.ok, status: h.status, url: h.url });
                        } catch (e2) {
                            const er2 = e2 || {};
                            dbg("healthz fetch threw", { name: er2.name, message: er2.message });
                        }

                        setStatus("Save failed: network error.");
                    }
                });
            }

            if (btnReset) {
                btnReset.addEventListener("click", async () => {
                    if (!confirmResetAll()) {
                        setStatus("Reset canceled.");
                        return;
                    }

                    setStatus("Resetting...");

                    const url = "@Url.Page("/UiCustomization/Editor", "Reset")";
                    const token = getAntiForgeryToken();
                    const payload = {
                        pageKey: effectivePageKey,
                        returnPath
                    };

                    try {
                        const resp = await fetch(url, {
                            method: "POST",
                            credentials: "same-origin",
                            headers: {
                                "Content-Type": "application/json",
                                "RequestVerificationToken": token,
                                "X-UIEditor-Debug": "1"
                            },
                            body: JSON.stringify(payload)
                        });

                        const data = await resp.json().catch(async () => {
                            const t = await resp.text();
                            const shortText = (t || "").replace(/\s+/g, " ").slice(0, 220);
                            return { ok: false, error: shortText ? (shortText + "…") : "Non-JSON response." };
                        });

                        if (!resp.ok || !data || data.ok !== true) {
                            setStatus("Reset failed: HTTP " + resp.status + " :: " + (data?.error ?? "unknown"));
                            return;
                        }

                        // Clear local state, then hard-refresh the target page without changes.
                        overrides.length = 0;
                        currentSelector = null;
                        currentKind = null;
                        currentInsertContainerSelector = null;
                        clearInspectorUi();
                        updateResetSelectedButton();
                        updateModeButtonsVisibility(false, null);

                        const target = (data && data.returnPath) ? String(data.returnPath) : returnPath;
                        const sep = target.includes("?") ? "&" : "?";
                        window.location.replace(target + sep + "__uireload=" + Date.now());
                    } catch {
                        setStatus("Reset failed: network error.");
                    }
                });
            }

            if (frame) {
                frame.addEventListener("load", () => {
                    if (pendingReapplyAfterReload) {
                        pendingReapplyAfterReload = false;
                        // Let the iframe initialize its message listener first.
                        setTimeout(() => {
                            reapplyAllOverridesToFrame();
                            postToFrame({ type: "uiedit:setMode", mode: currentMode });
                            setStatus("Preview reloaded. Click an element to select.");
                        }, 50);
                        return;
                    }
                    postToFrame({ type: "uiedit:setMode", mode: currentMode });
                    setStatus("Preview loaded. Click an element to select.");
                });
            }

            // Initial button state
            updateResetSelectedButton();
            updateUndoButton();
            updateRedoButton();
        })();
    </script>
}
