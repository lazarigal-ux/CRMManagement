                    if (selInsertHtml) selInsertHtml.value = "";

                    if (selAddImgSrc) selAddImgSrc.value = "";
                    if (selAddImgAlt) selAddImgAlt.value = "";
                    if (selAddImgSize) selAddImgSize.value = "";
