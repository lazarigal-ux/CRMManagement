@section Scripts {
    <script>
        // English comments only inside code.
        (function () {
            "use strict";

            const frame = document.getElementById("uiFrame");
            const status = document.getElementById("status");

            const selSelector = document.getElementById("selSelector");
            const selClasses = document.getElementById("selClasses");
            const selBgRaw = document.getElementById("selBgRaw");
            const selTextColor = document.getElementById("selTextColor");
            const selTextColorRaw = document.getElementById("selTextColorRaw");
            const chkSetBg = document.getElementById("chkSetBg");
            const chkSetTextColor = document.getElementById("chkSetTextColor");

            const selText = document.getElementById("selText");
            const selBg = document.getElementById("selBg");
            const selClassAdd = document.getElementById("selClassAdd");

            const selImgSrc = document.getElementById("selImgSrc");
            const selImgAlt = document.getElementById("selImgAlt");
            const selImgClassAdd = document.getElementById("selImgClassAdd");
            const selImgWidth = document.getElementById("selImgWidth");
            const selImgWidthCustom = document.getElementById("selImgWidthCustom");
            const selImgHeight = document.getElementById("selImgHeight");
            const selImgHeightCustom = document.getElementById("selImgHeightCustom");
            const selImgAlign = document.getElementById("selImgAlign");

            const selIconClass = document.getElementById("selIconClass");
            const btnIconDelete = document.getElementById("btnIconDelete");
            const iconClassList = document.getElementById("iconClassList");
            const selIconImageSrc = document.getElementById("selIconImageSrc");
            const iconImageList = document.getElementById("iconImageList");
            const selIconImgSize = document.getElementById("selIconImgSize");
            const fileIconUpload = document.getElementById("fileIconUpload");
            const btnIconAddPrepend = document.getElementById("btnIconAddPrepend");
            const btnIconAddAppend = document.getElementById("btnIconAddAppend");

            const selInputType = document.getElementById("selInputType");
            const chkInputRequired = document.getElementById("chkInputRequired");
            const selInputPlaceholder = document.getElementById("selInputPlaceholder");
            const selInputValue = document.getElementById("selInputValue");
            const selSelectOptions = document.getElementById("selSelectOptions");
            const selSelectValue = document.getElementById("selSelectValue");

            const selInsertPos = document.getElementById("selInsertPos");
            const selNewFieldKey = document.getElementById("selNewFieldKey");
            const selNewFieldLabel = document.getElementById("selNewFieldLabel");
            const selNewFieldType = document.getElementById("selNewFieldType");
            const chkNewFieldRequired = document.getElementById("chkNewFieldRequired");
            const selNewFieldPlaceholder = document.getElementById("selNewFieldPlaceholder");
            const selInsertHtml = document.getElementById("selInsertHtml");

            const selAddImgSrc = document.getElementById("selAddImgSrc");
            const fileAddImgUpload = document.getElementById("fileAddImgUpload");
            const selAddImgAlt = document.getElementById("selAddImgAlt");
            const selAddImgSize = document.getElementById("selAddImgSize");
            const selAddImgHeight = document.getElementById("selAddImgHeight");
            const selAddImgAlign = document.getElementById("selAddImgAlign");
            const selAddImgClassAdd = document.getElementById("selAddImgClassAdd");
            const btnAddImage = document.getElementById("btnAddImage");
            const addImgPreviewImg = document.getElementById("addImgPreviewImg");

            const selTable = document.getElementById("selTable");
            const selCol = document.getElementById("selCol");

            const btnHideCol = document.getElementById("btnHideCol");
            const btnApply = document.getElementById("btnApply");
            const btnUndo = document.getElementById("btnUndo");
            const btnRedo = document.getElementById("btnRedo");
            const btnResetSelected = document.getElementById("btnResetSelected");
            const btnSave = document.getElementById("btnSave");
            const btnReset = document.getElementById("btnReset");
            const btnMoveUp = document.getElementById("btnMoveUp");
            const btnMoveDown = document.getElementById("btnMoveDown");

            const selMoveContainer = document.getElementById("selMoveContainer");
            const selMoveReference = document.getElementById("selMoveReference");
            const selMovePos = document.getElementById("selMovePos");
            const btnMoveTo = document.getElementById("btnMoveTo");

            const btnCopySelector = document.getElementById("btnCopySelector");
            const selFindSelector = document.getElementById("selFindSelector");
            const btnFindSelector = document.getElementById("btnFindSelector");

            const btnQuickAdd = document.getElementById("btnQuickAdd");
            const btnQuickRemove = document.getElementById("btnQuickRemove");

            // Wizard step controls
            const stepButtons = Array.from(document.querySelectorAll("[data-uiedit-step-btn]"));
            const stepPanels = Array.from(document.querySelectorAll("[data-uiedit-step]"));
            const btnStepNextToEdit = document.getElementById("btnStepNextToEdit");
            const btnStepBackToSelect = document.getElementById("btnStepBackToSelect");
            const btnStepNextToSave = document.getElementById("btnStepNextToSave");
            const btnStepBackToEdit = document.getElementById("btnStepBackToEdit");

            const dbgLog = document.getElementById("dbgLog");

            const pageKey = @Html.Raw(pageKeyJs);
            const featureKey = @Html.Raw(featureKeyJs);
            const returnPath = @Html.Raw(returnPathJs);

            // Hydrate with already-saved overrides so Reset selected can work across sessions.
            const initialOverrides = @Html.Raw(Model.InitialOverridesJson);

            function derivePageKeyFromReturnPath(p) {
                // Match UiLayoutMiddleware normalization: trim '/', default 'root'.
                const raw = String(p || "");
                const pathOnly = raw.split("?")[0];
                const trimmed = pathOnly.replace(/^\/+|\/+$/g, "");
                return trimmed || "root";
            }

            // If the editor is opened without an explicit pageKey, fall back to the returnPath.
            const effectivePageKey = (String(pageKey || "").trim()) ? String(pageKey).trim() : derivePageKeyFromReturnPath(returnPath);

            const overrides = Array.isArray(initialOverrides) ? initialOverrides.slice() : [];
            const undoStack = [];
            const redoStack = [];
            let currentSelector = null;
            let currentKind = null;
            let currentInsertContainerSelector = null;
            let currentIconSelector = null;

            const initialFrameUrl = frame ? (frame.getAttribute("src") || "") : "";
            let pendingReapplyAfterReload = false;

            let currentMode = "text";
            const modeButtons = Array.from(document.querySelectorAll("[data-uiedit-mode]"));
            const groupMeta = document.querySelector('[data-uiedit-group="meta"]');
            const groupText = document.querySelector('[data-uiedit-group="text"]');
            const groupTable = document.querySelector('[data-uiedit-group="table"]');
            const groupImage = document.querySelector('[data-uiedit-group="image"]');
            const groupIcon = document.querySelector('[data-uiedit-group="icon"]');
            const groupInput = document.querySelector('[data-uiedit-group="input"]');
            const groupSelect = document.querySelector('[data-uiedit-group="select"]');
            const groupAdd = document.querySelector('[data-uiedit-group="add"]');
            const groupMove = document.querySelector('[data-uiedit-group="move"]');

            let currentStep = "select";

            function normalizeStep(s) {
                const v = String(s || "").toLowerCase().trim();
                if (v === "select" || v === "edit" || v === "save") return v;
                return "select";
            }

            function setStep(step) {
                currentStep = normalizeStep(step);
                stepButtons.forEach(b => {
                    const isActive = normalizeStep(b.getAttribute("data-uiedit-step-btn")) === currentStep;
                    b.classList.toggle("is-active", isActive);
                });
                stepPanels.forEach(p => {
                    const isActive = normalizeStep(p.getAttribute("data-uiedit-step")) === currentStep;
                    p.classList.toggle("hidden", !isActive);
                });
            }

            stepButtons.forEach(b => {
                b.addEventListener("click", () => setStep(b.getAttribute("data-uiedit-step-btn")));
            });

            if (btnStepNextToEdit) btnStepNextToEdit.addEventListener("click", () => setStep("edit"));
            if (btnStepBackToSelect) btnStepBackToSelect.addEventListener("click", () => setStep("select"));
            if (btnStepNextToSave) btnStepNextToSave.addEventListener("click", () => setStep("save"));
            if (btnStepBackToEdit) btnStepBackToEdit.addEventListener("click", () => setStep("edit"));

            function normalizeMode(m) {
                const v = String(m || "").toLowerCase().trim();
                if (v === "label") return "text";
                if (v === "input") return "input";
                if (v === "select") return "select";
                if (v === "add") return "add";
                if (v === "move") return "move";
                if (v === "table") return "table";
                if (v === "image") return "image";
                if (v === "icon") return "icon";
                if (v === "tab") return "tab";
                return "text";
            }

            function setMode(mode) {
                currentMode = normalizeMode(mode);
                modeButtons.forEach(b => {
                    const isActive = normalizeMode(b.getAttribute("data-uiedit-mode")) === currentMode;
                    b.classList.toggle("is-active", isActive);
                });

                // TEXT/TAB share the same fields group.
                const showText = (currentMode === "text" || currentMode === "tab");
                if (groupMeta) groupMeta.classList.toggle("hidden", currentMode === "add" || currentMode === "move");
                if (groupText) groupText.classList.toggle("hidden", !showText);
                if (groupTable) groupTable.classList.toggle("hidden", currentMode !== "table");
                if (groupImage) groupImage.classList.toggle("hidden", currentMode !== "image");
                if (groupIcon) groupIcon.classList.toggle("hidden", currentMode !== "icon");
                if (groupInput) groupInput.classList.toggle("hidden", currentMode !== "input");
                if (groupAdd) groupAdd.classList.toggle("hidden", currentMode !== "add");
                if (groupMove) groupMove.classList.toggle("hidden", currentMode !== "move");
                if (groupSelect) groupSelect.classList.toggle("hidden", currentMode !== "select");

                // Inform iframe so it can enable/disable drag & drop behavior.
                postToFrame({ type: "uiedit:setMode", mode: currentMode });
            }

            function updateModeButtonsVisibility(hasSelection, kind) {
                const normalizedKind = normalizeMode(kind);
                const allow = new Set(["move", "add"]);
                if (hasSelection && normalizedKind && !allow.has(normalizedKind)) {
                    allow.add(normalizedKind);
                }

                modeButtons.forEach(b => {
                    const mode = normalizeMode(b.getAttribute("data-uiedit-mode"));
                    const shouldShow = allow.has(mode);
                    b.classList.toggle("hidden", !shouldShow);
                });

                // If current mode is hidden, switch to a safe default.
                if (!allow.has(currentMode)) {
                    setMode("move");
                }
            }

            modeButtons.forEach(b => {
                b.addEventListener("click", () => setMode(b.getAttribute("data-uiedit-mode")));
            });

            // Initial state
            setMode("move");
            updateModeButtonsVisibility(false, null);
            setStep("select");

            function setStatus(t) { if (status) status.textContent = t || ""; }

            function updateUndoButton() {
                try {
                    if (!btnUndo) return;
                    const has = undoStack.length > 0;
                    btnUndo.disabled = !has;
                    btnUndo.title = has ? ("Undo last change (" + undoStack.length + " step(s) available)") : "Nothing to undo";
                } catch { }
            }

            function updateQuickRemoveButton() {
                try {
                    if (!btnQuickRemove) return;
                    const hasSelection = !!(currentSelector && String(currentSelector).trim());
                    btnQuickRemove.disabled = !hasSelection;
                    btnQuickRemove.title = hasSelection ? "Remove the selected element" : "Select an element first";
                } catch { }
            }

            function updateRedoButton() {
                try {
                    if (!btnRedo) return;
                    const has = redoStack.length > 0;
                    btnRedo.disabled = !has;
                    btnRedo.title = has ? ("Redo last undone change (" + redoStack.length + " step(s) available)") : "Nothing to redo";
                } catch { }
            }

            function cloneJsonSafe(x) {
                try {
                    if (typeof structuredClone === "function") return structuredClone(x);
                } catch { }
                try {
                    return JSON.parse(JSON.stringify(x));
                } catch {
                    return null;
                }
            }

            function pushUndo(reason) {
                try {
                    const snap = cloneJsonSafe(overrides);
                    if (!snap) return;

                    // Any new change invalidates redo history.
                    redoStack.length = 0;
                    updateRedoButton();

                    undoStack.push({ at: Date.now(), reason: String(reason || "") , overrides: snap });
                    // Avoid unbounded growth.
                    if (undoStack.length > 50) undoStack.shift();
                    updateUndoButton();
                } catch { }
            }

            function isTypingTarget(el) {
                try {
                    const t = el;
                    if (!t) return false;
                    const tag = String(t.tagName || "").toLowerCase();
                    if (tag === "input" || tag === "textarea" || tag === "select") return true;
                    if (t.isContentEditable) return true;
                } catch { }
                return false;
            }

            function doUndo() {
                if (!undoStack.length) {
                    setStatus("Nothing to undo.");
                    return;
                }

                // Save current state for redo.
                const cur = cloneJsonSafe(overrides);
                if (cur) {
                    redoStack.push({ at: Date.now(), reason: "undo", overrides: cur });
                    if (redoStack.length > 50) redoStack.shift();
                }

                const last = undoStack.pop();
                const prev = last && Array.isArray(last.overrides) ? last.overrides : null;
                if (!prev) {
                    setStatus("Undo failed: invalid snapshot.");
                    updateUndoButton();
                    updateRedoButton();
                    return;
                }

                // Restore overrides array in-place.
                overrides.length = 0;
                prev.forEach(x => overrides.push(x));

                updateUndoButton();
                updateRedoButton();
                updateResetSelectedButton();

                // Reload preview and re-apply all overrides to match restored state.
                setStatus("Undone. Reloading preview...");
                reloadFrameAndReapply();
            }

            function doRedo() {
                if (!redoStack.length) {
                    setStatus("Nothing to redo.");
                    return;
                }

                // Save current state for undo.
                const cur = cloneJsonSafe(overrides);
                if (cur) {
                    undoStack.push({ at: Date.now(), reason: "redo", overrides: cur });
                    if (undoStack.length > 50) undoStack.shift();
                }

                const last = redoStack.pop();
                const next = last && Array.isArray(last.overrides) ? last.overrides : null;
                if (!next) {
                    setStatus("Redo failed: invalid snapshot.");
                    updateUndoButton();
                    updateRedoButton();
                    return;
                }

                // Restore overrides array in-place.
                overrides.length = 0;
                next.forEach(x => overrides.push(x));

                updateUndoButton();
                updateRedoButton();
                updateResetSelectedButton();

                // Reload preview and re-apply all overrides to match restored state.
                setStatus("Redone. Reloading preview...");
                reloadFrameAndReapply();
            }

            function dbg(line, obj) {
                try {
                    const ts = new Date().toISOString().replace('T', ' ').replace('Z', '');
                    const msg = "[" + ts + "] " + String(line ?? "");
                    if (obj !== undefined) {
                        console.log("[UIEditor]", line, obj);
                    } else {
                        console.log("[UIEditor]", line);
                    }
                    if (dbgLog) {
                        dbgLog.textContent = (dbgLog.textContent ? (dbgLog.textContent + "\n") : "") + msg;
                        // keep latest lines visible
                        dbgLog.scrollTop = dbgLog.scrollHeight;
                    }
                } catch { }
            }

            function getAntiForgeryToken() {
                const el = document.querySelector('input[name="__RequestVerificationToken"]');
                return el ? el.value : "";
            }

            function upsertOverride(selector, actions) {
                pushUndo("upsertOverride");
                const idx = overrides.findIndex(x => x && x.selector === selector);
                if (idx >= 0) overrides[idx].actions = actions;
                else overrides.push({ selector, actions });

                updateResetSelectedButton();
                updateQuickRemoveButton();
            }

            function appendOverrideActions(selector, extraActions) {
                if (!selector || !Array.isArray(extraActions) || !extraActions.length) return;
                pushUndo("appendOverride");
                const idx = overrides.findIndex(x => x && x.selector === selector);
                if (idx < 0) {
                    overrides.push({ selector, actions: extraActions });
                    updateResetSelectedButton();
                    updateQuickRemoveButton();
                    return;
                }

                const existing = Array.isArray(overrides[idx].actions) ? overrides[idx].actions : [];
                overrides[idx].actions = existing.concat(extraActions);
                updateResetSelectedButton();
                updateQuickRemoveButton();
            }

            function upsertStyleActions(selector, styleMap) {
                try {
                    if (!selector) return;
                    const keys = (styleMap && typeof styleMap === "object")
                        ? Object.keys(styleMap).map(k => String(k || "").trim()).filter(Boolean)
                        : [];
                    if (!keys.length) return;

                    pushUndo("style");

                    const idx = overrides.findIndex(x => x && x.selector === selector);
                    const styleActions = keys.map(k => ({ type: "style", name: k, value: String(styleMap[k] ?? "") }));

                    if (idx < 0) {
                        overrides.push({ selector, actions: styleActions });
                        updateResetSelectedButton();
                        updateQuickRemoveButton();
                        return;
                    }

                    const existing = Array.isArray(overrides[idx].actions) ? overrides[idx].actions : [];
                    const rest = existing.filter(a => !(a && a.type === "style" && keys.includes(String(a.name || "").trim())));
                    overrides[idx].actions = rest.concat(styleActions);
                    updateResetSelectedButton();
                    updateQuickRemoveButton();
                } catch { }
            }

            function upsertMoveOverride(selector, moveAction) {
                if (!selector || !moveAction) return;
                pushUndo("move");
                const idx = overrides.findIndex(x => x && x.selector === selector);
                if (idx < 0) {
                    overrides.push({ selector, actions: [moveAction] });
                    updateResetSelectedButton();
                    updateQuickRemoveButton();
                    return;
                }

                const existing = overrides[idx].actions;
                const rest = Array.isArray(existing) ? existing.filter(a => a && a.type !== "move" && a.type !== "moveAbs") : [];
                rest.push(moveAction);
                overrides[idx].actions = rest;
                updateResetSelectedButton();
                updateQuickRemoveButton();
            }

            if (btnQuickAdd) {
                btnQuickAdd.addEventListener("click", () => {
                    // Add is relative to selection (after/before/append/prepend), but we can still take the user to Add mode.
                    setStep("edit");
                    setMode("add");
                    if (!currentSelector) {
                        setStatus("Tip: select an element first to choose where to insert.");
                    }
                });
            }

            if (btnQuickRemove) {
                btnQuickRemove.addEventListener("click", () => {
                    if (!currentSelector) {
                        setStatus("Select an element first.");
                        return;
                    }

                    const ok = confirm("Remove selected element? This will be saved as an override.");
                    if (!ok) return;

                    appendOverrideActions(currentSelector, [{ type: "remove" }]);
                    updateQuickRemoveButton();
                    updateModeButtonsVisibility(!!currentSelector, currentKind);

                    setStatus("Removed. Reloading preview...");
                    reloadFrameAndReapply();
                    setStep("save");
                });
            }

            if (btnUndo) {
                btnUndo.addEventListener("click", () => {
                    doUndo();
                });
            }

            if (btnRedo) {
                btnRedo.addEventListener("click", () => {
                    doRedo();
                });
            }

            if (btnIconDelete) {
                btnIconDelete.addEventListener("click", () => {
                    const iconSel = String(currentIconSelector || currentSelector || "").trim();
                    if (!iconSel) {
                        setStatus("No element selected.");
                        return;
                    }

                    const actions = [{ type: "remove" }];
                    upsertOverride(iconSel, actions);
                    const ok = postToFrame({ type: "uiedit:apply", selector: iconSel, actions });
                    setStatus(ok ? "Icon deleted (not saved yet)." : "Iframe not ready. Try again.");
                });
            }

            function buildIconHtmlFromInputs(dataUrlOverride) {
                const pickedSrc = String(selIconImageSrc?.value || "").trim();
                const cls = String(selIconClass?.value || "").trim();
                const src = String(dataUrlOverride || pickedSrc || "").trim();

                if (src) {
                    const safe = src.replace(/"/g, "&quot;");
                    const sizeCss = normalizeSizeCss(selIconImgSize?.value, "1em");
                    return `<img src="${safe}" alt="" style="width:${sizeCss};height:${sizeCss};display:inline-block;vertical-align:middle;object-fit:contain;" />`;
                }

                if (cls) {
                    const safeCls = cls.replace(/"/g, "").trim();
                    return `<i class="${safeCls}"></i>`;
                }

                return "";
            }

            async function addIconAt(position) {
                if (!currentSelector) {
                    setStatus("No element selected.");
                    return;
                }

                const containerSel = String(currentInsertContainerSelector || currentSelector || "").trim();
                if (!containerSel) {
                    setStatus("ICON: no container to insert into.");
                    return;
                }

                let dataUrl = "";
                const file = (fileIconUpload && fileIconUpload.files && fileIconUpload.files.length)
                    ? fileIconUpload.files[0]
                    : null;
                if (file) dataUrl = await readFileAsDataUrl(file);

                const html = buildIconHtmlFromInputs(dataUrl);
                if (!html) {
                    setStatus("ICON: pick an image, upload, or enter classes.");
                    return;
                }

                const action = { type: "insertHtml", html, position };
                appendOverrideActions(containerSel, [action]);
                const ok = postToFrame({ type: "uiedit:apply", selector: containerSel, actions: [action] });
                setStatus(ok ? "Icon added (not saved yet)." : "Iframe not ready. Try again.");
            }

            if (btnIconAddPrepend) btnIconAddPrepend.addEventListener("click", () => addIconAt("prepend"));
            if (btnIconAddAppend) btnIconAddAppend.addEventListener("click", () => addIconAt("append"));

            if (btnMoveUp) {
                btnMoveUp.addEventListener("click", () => requestMoveStep("up"));
            }

            if (btnMoveDown) {
                btnMoveDown.addEventListener("click", () => requestMoveStep("down"));
            }

            if (btnMoveTo) {
                btnMoveTo.addEventListener("click", () => {
                    if (!currentSelector) {
                        setStatus("No element selected.");
                        return;
                    }

                    const pos = String(selMovePos?.value || "after").toLowerCase().trim();
                    const containerSelector = String(selMoveContainer?.value || "").trim();
                    const referenceSelector = String(selMoveReference?.value || "").trim();

                    if ((pos === "append" || pos === "prepend") && !containerSelector) {
                        setStatus("MOVE: provide a container selector for append/prepend.");
                        return;
                    }

                    if ((pos === "before" || pos === "after") && !referenceSelector) {
                        setStatus("MOVE: provide a reference selector for before/after.");
                        return;
                    }

                    const moveAction = {
                        type: "move",
                        containerSelector,
                        referenceSelector,
                        position: pos
                    };

                    upsertMoveOverride(currentSelector, moveAction);
                    const ok = postToFrame({ type: "uiedit:apply", selector: currentSelector, actions: [moveAction] });
                    setStatus(ok ? "Moved locally (not saved yet)." : "Preview not ready. Try again.");
                });
            }

            if (btnCopySelector) {
                btnCopySelector.addEventListener("click", async () => {
                    const s = (selSelector?.value || "").trim();
                    if (!s) {
                        setStatus("Nothing to copy.");
                        return;
                    }
                    const ok = await copyTextToClipboard(s);
                    setStatus(ok ? "Selector copied." : "Copy failed (clipboard blocked).");
                });
            }

            if (btnFindSelector) {
                btnFindSelector.addEventListener("click", () => findAndSelectInPreview(selFindSelector?.value));
            }

            if (selFindSelector) {
                selFindSelector.addEventListener("keydown", (e) => {
                    if (e && e.key === "Enter") {
                        e.preventDefault();
                        findAndSelectInPreview(selFindSelector.value);
                    }
                });
            }

            // Ctrl+Z / Ctrl+Shift+Z / Ctrl+Y shortcuts (avoid hijacking normal typing in inputs)
            window.addEventListener("keydown", (e) => {
                try {
                    if (!e) return;
                    if (!(e.ctrlKey || e.metaKey)) return;
                    const k = String(e.key || "").toLowerCase();
                    if (isTypingTarget(e.target)) return;

                    if (k === "z") {
                        e.preventDefault();
                        if (e.shiftKey) doRedo();
                        else doUndo();
                        return;
                    }

                    if (k === "y") {
                        e.preventDefault();
                        doRedo();
                        return;
                    }

                    if (k === "s") {
                        e.preventDefault();
                        if (btnSave && !btnSave.disabled) btnSave.click();
                        return;
                    }
                } catch { }
            });

            // Arrow keys for MOVE mode
            window.addEventListener("keydown", (e) => {
                try {
                    if (!e) return;
                    if (isTypingTarget(e.target)) return;
                    if (currentMode !== "move") return;

                    if (e.key === "ArrowUp") {
                        e.preventDefault();
                        requestMoveStep("up");
                        return;
                    }
                    if (e.key === "ArrowDown") {
                        e.preventDefault();
                        requestMoveStep("down");
                        return;
                    }
                } catch { }
            });

            function getResetTargetSelector() {
                // For TABLE mode, the effective selector is the table selector, not the clicked cell.
                const tableSel = (selTable?.value || "").trim();
                if (currentMode === "table" && tableSel) return tableSel;
                return currentSelector;
            }

            function updateResetSelectedButton() {
                try {
                    if (!btnResetSelected) return;
                    const sel = getResetTargetSelector();
                    const has = !!sel && overrides.some(o => o && o.selector === sel);
                    btnResetSelected.disabled = !has;
                    btnResetSelected.title = has
                        ? "Delete saved overrides for the selected element"
                        : "Select an element with saved changes to enable";
                } catch { }

                // Also keep quick remove enabled/disabled in sync.
                updateQuickRemoveButton();
            }

            function reapplyAllOverridesToFrame() {
                // Apply overrides in a single message to reduce postMessage overhead.
                try {
                    const items = overrides
                        .filter(o => o && o.selector)
                        .map(o => ({ selector: o.selector, actions: o.actions || [] }));

                    if (!items.length) return;

                    const ok = postToFrame({ type: "uiedit:applyBatch", items });
                    if (!ok) {
                        // Fallback (older preview script)
                        items.forEach(it => postToFrame({ type: "uiedit:apply", selector: it.selector, actions: it.actions }));
                    }
                } catch {
                    // Fallback (best effort)
                    overrides.forEach(o => {
                        if (!o || !o.selector) return;
                        postToFrame({ type: "uiedit:apply", selector: o.selector, actions: o.actions || [] });
                    });
                }
            }

            function reloadFrameAndReapply() {
                if (!frame) return;
                pendingReapplyAfterReload = true;
                const base = initialFrameUrl || (frame.getAttribute("src") || "");
                if (!base) return;
                const sep = base.includes("?") ? "&" : "?";
                frame.src = base + sep + "__uireload=" + Date.now();
            }

            async function copyTextToClipboard(text) {
                const t = String(text || "");
                if (!t) return false;
                try {
                    if (navigator.clipboard && typeof navigator.clipboard.writeText === "function") {
                        await navigator.clipboard.writeText(t);
                        return true;
                    }
                } catch { }

                // Fallback for older browsers / blocked clipboard API
                try {
                    const ta = document.createElement("textarea");
                    ta.value = t;
                    ta.style.position = "fixed";
                    ta.style.left = "-9999px";
                    ta.style.top = "-9999px";
                    document.body.appendChild(ta);
                    ta.focus();
                    ta.select();
                    const ok = document.execCommand("copy");
                    document.body.removeChild(ta);
                    return !!ok;
                } catch {
                    return false;
                }
            }

            function findAndSelectInPreview(sel) {
