                    if (selInsertPos) selInsertPos.value = "after";
                    if (selNewFieldKey) selNewFieldKey.value = "";
                    if (selNewFieldLabel) selNewFieldLabel.value = "";
                    if (selNewFieldType) selNewFieldType.value = "text";
                    if (chkNewFieldRequired) chkNewFieldRequired.checked = false;
