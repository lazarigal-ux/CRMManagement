@page "/UiCustomization/Editor"
@using System.Text.Json
@model CRMManagement.Web.Pages.UiCustomization.EditorModel

@{
    // English comments only inside code.
    ViewData["Title"] = "UI Editor";
    Layout = "_Layout";

    var returnPath = string.IsNullOrWhiteSpace(Model.ReturnPath) ? "/" : Model.ReturnPath;
    if (!returnPath.StartsWith("/")) returnPath = "/" + returnPath;
    if (returnPath.StartsWith("/UiCustomization/Editor", StringComparison.OrdinalIgnoreCase)) returnPath = "/";

    var targetUrl = returnPath + (returnPath.Contains("?") ? "&" : "?") + "__uiedit=1";

    var pageKeyJs = JsonSerializer.Serialize(Model.PageKey ?? "");
    var featureKeyJs = JsonSerializer.Serialize(Model.FeatureKey ?? "");
    var returnPathJs = JsonSerializer.Serialize(returnPath);
}

<!-- Page Header -->
<div class="rounded-2xl border border-slate-600/50 bg-slate-700/80 text-slate-100 shadow-[0_6px_24px_-10px_rgba(2,6,23,.25)] mb-4">
    <div class="flex items-center px-4 py-2 min-h-[2.5rem]">
        <div class="flex-1 text-center">
            <h2 class="m-0 text-2xl font-semibold truncate">
                <span class="inline-flex items-center gap-2 leading-none">
                    <i class="fa-solid fa-pen-to-square"></i>
                    <span>UI Editor</span>
                </span>
            </h2>
        </div>
    </div>
</div>

<!-- English comments only inside code. -->
@Html.AntiForgeryToken()

<style>
    /* Page-scoped styling to match the Create/Edit User vibe */
    .ui-editor-page input[type="text"],
    .ui-editor-page input[type="number"],
    .ui-editor-page textarea {
        background: rgba(30, 41, 59, .40) !important; /* slate-800/40 like the site */
        color: #f1f5f9 !important;
        border: 1px solid rgba(100, 116, 139, .50) !important;
    }

    .ui-editor-page input[type="text"]::placeholder,
    .ui-editor-page textarea::placeholder {
        color: rgba(148, 163, 184, .85) !important;
    }

    .ui-editor-page input[type="text"]:focus,
    .ui-editor-page input[type="number"]:focus,
    .ui-editor-page textarea:focus {
        outline: none !important;
        border-color: var(--tw-ring-color) !important;
        box-shadow: 0 0 0 1px var(--tw-ring-color) !important;
    }

    .ui-editor-page input[type="color"] {
        background: rgba(30, 41, 59, .40) !important;
        border: 1px solid rgba(100, 116, 139, .50) !important;
        padding: 4px !important;
        height: 42px;
    }

    .ui-mode-btn {
        border: 1px solid rgba(100, 116, 139, .55);
        background: rgba(15, 23, 42, .35);
        color: #e2e8f0;
    }

    .ui-mode-btn:hover {
        background: rgba(51, 65, 85, .55);
    }

    .ui-mode-btn.is-active {
        border-color: rgba(56, 189, 248, .65);
        background: rgba(2, 132, 199, .35);
        color: #ffffff;
    }
</style>

<section class="ui-editor-page flex justify-center">
    <div class="w-full max-w-5xl rounded-2xl border border-slate-600/50 bg-slate-700/80 p-6 sm:p-8 shadow-soft text-slate-100">

        <!-- Top line (lighter: keep navigation, move editing actions into the wizard) -->
        <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-3 mb-5">
            <div class="text-sm text-slate-300">
                <div class="text-xs text-slate-300">
                    PageKey: <span class="text-slate-100 font-medium">@Model.PageKey</span>
                    <span class="mx-2 text-slate-500">•</span>
                    FeatureKey: <span class="text-slate-100 font-medium">@Model.FeatureKey</span>
                </div>
                <div class="text-xs text-slate-400 mt-1">
                    Tip: click an element in the preview to select it.
                </div>
            </div>

            <div class="flex flex-wrap items-center gap-2">
                <a href="@returnPath"
                   class="inline-flex items-center gap-2 rounded-full border border-slate-500/60 px-4 py-2 text-slate-100 hover:bg-slate-600 transition">
                    <i class="fa-solid fa-arrow-left text-sm"></i>
                    <span>Back</span>
                </a>
            </div>
        </div>

        <!-- Main area: Preview + Inspector inside same card -->
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">

            <!-- Preview -->
            <div class="lg:col-span-2">
                <div class="rounded-2xl border border-slate-600/50 bg-slate-800/40 overflow-hidden">
                    <div class="flex items-center justify-between px-4 py-3 border-b border-slate-600/50">
                        <div class="text-sm font-semibold text-slate-100">
                            <i class="fa-regular fa-eye mr-2"></i>Preview
                        </div>
                        <div id="status" class="text-xs text-slate-300"></div>
                    </div>

                    <iframe id="uiFrame"
                            src="@targetUrl"
                            class="w-full"
                            style="height: 62vh; min-height: 520px; border: 0; background: transparent;"
                            sandbox="allow-same-origin allow-scripts allow-forms allow-popups allow-modals">
                    </iframe>
                </div>
            </div>

            <!-- Inspector (site form style) -->
            <div class="lg:col-span-1">
                <div class="rounded-2xl border border-slate-600/50 bg-slate-800/40 p-4">
                    <div class="text-sm text-slate-100 font-semibold mb-3">
                        <i class="fa-solid fa-bullseye mr-2"></i>Inspector
                    </div>

                    <!-- Wizard steps: Select → Edit → Save -->
                    <div class="flex items-center justify-between gap-2 mb-4">
                        <div class="flex items-center gap-2" role="group" aria-label="Editor step">
                            <button id="btnStepSelect" type="button"
                                    class="ui-mode-btn rounded-full px-3 py-1 text-xs is-active"
                                    data-uiedit-step-btn="select">
                                1) Select
                            </button>
                            <button id="btnStepEdit" type="button"
                                    class="ui-mode-btn rounded-full px-3 py-1 text-xs"
                                    data-uiedit-step-btn="edit">
                                2) Edit
                            </button>
                            <button id="btnStepSave" type="button"
                                    class="ui-mode-btn rounded-full px-3 py-1 text-xs"
                                    data-uiedit-step-btn="save">
                                3) Save
                            </button>
                        </div>

                        <div class="flex items-center gap-2" role="group" aria-label="Quick actions">
                            <button id="btnQuickAdd" type="button"
                                    class="inline-flex items-center gap-2 rounded-full bg-brand px-3 py-1.5 text-xs text-white hover:bg-brand-600 transition">
                                <i class="fa-solid fa-plus"></i>
                                <span>Add</span>
                            </button>
                            <button id="btnQuickRemove" type="button" disabled
                                    class="inline-flex items-center gap-2 rounded-full bg-red-600 px-3 py-1.5 text-xs text-white hover:bg-red-700 transition disabled:opacity-40 disabled:cursor-not-allowed">
                                <i class="fa-solid fa-trash"></i>
                                <span>Remove</span>
                            </button>
                        </div>
                    </div>

                    <!-- STEP 1: Select -->
                    <div data-uiedit-step="select" class="space-y-4">
                        <div class="space-y-4">
                            <div class="space-y-1">
                                <label class="block text-xs font-medium text-slate-300">Selector</label>
                                <div class="flex items-stretch gap-2">
                                    <input id="selSelector"
                                           class="w-full rounded-lg border border-slate-500/50 bg-slate-800/40 px-3 py-2 text-slate-100 text-sm"
                                           readonly />
                                    <button id="btnCopySelector" type="button"
                                            class="inline-flex items-center gap-2 rounded-lg border border-slate-500/50 bg-slate-800/40 px-3 py-2 text-slate-100 text-xs hover:bg-slate-600/40 transition"
                                            title="Copy selector to clipboard">
                                        <i class="fa-regular fa-copy"></i>
                                        <span>Copy</span>
                                    </button>
                                </div>
                            </div>

                            <div class="space-y-1">
                                <label class="block text-xs font-medium text-slate-300">Find (CSS selector)</label>
                                <div class="flex items-stretch gap-2">
                                    <input id="selFindSelector"
                                           class="w-full rounded-lg border border-slate-500/50 bg-slate-800/40 px-3 py-2 text-slate-100 text-sm"
                                           placeholder='e.g. a[aria-label="Home"] or [data-uiedit-key="12"]' />
                                    <button id="btnFindSelector" type="button"
                                            class="inline-flex items-center gap-2 rounded-lg border border-slate-500/50 bg-slate-800/40 px-3 py-2 text-slate-100 text-xs hover:bg-slate-600/40 transition"
                                            title="Select and scroll to this element in the preview">
                                        <i class="fa-solid fa-location-crosshairs"></i>
                                        <span>Go</span>
                                    </button>
                                </div>
                                <div class="text-[11px] text-slate-400">Tip: you can paste a selector and press Enter.</div>
                            </div>
                        </div>

                        <button id="btnStepNextToEdit" type="button"
                                class="w-full inline-flex items-center justify-center gap-2 rounded-full border border-slate-500/60 bg-slate-800/40 px-4 py-2 text-slate-100 hover:bg-slate-600 transition">
                            <i class="fa-solid fa-arrow-right text-sm"></i>
                            <span>Next: Edit</span>
                        </button>
                    </div>

                    <!-- STEP 2: Edit -->
                    <div data-uiedit-step="edit" class="space-y-4 hidden">
                        <!-- Mode switch (shows only relevant fields) -->
                        <div class="flex flex-wrap gap-2" role="group" aria-label="Edit mode">
                            <button type="button" class="ui-mode-btn ui-mode-btn-text is-active rounded-full px-3 py-1 text-xs" data-uiedit-mode="text">TEXT</button>
                            <button type="button" class="ui-mode-btn ui-mode-btn-input rounded-full px-3 py-1 text-xs" data-uiedit-mode="input">INPUT</button>
                            <button type="button" class="ui-mode-btn ui-mode-btn-select rounded-full px-3 py-1 text-xs" data-uiedit-mode="select">SELECT</button>
                            <button type="button" class="ui-mode-btn ui-mode-btn-table rounded-full px-3 py-1 text-xs" data-uiedit-mode="table">TABLE</button>
                            <button type="button" class="ui-mode-btn ui-mode-btn-image rounded-full px-3 py-1 text-xs" data-uiedit-mode="image">IMAGE</button>
                            <button type="button" class="ui-mode-btn ui-mode-btn-icon rounded-full px-3 py-1 text-xs" data-uiedit-mode="icon">ICON</button>
                            <button type="button" class="ui-mode-btn ui-mode-btn-tab rounded-full px-3 py-1 text-xs" data-uiedit-mode="tab">TAB</button>
                            <button type="button" class="ui-mode-btn ui-mode-btn-move rounded-full px-3 py-1 text-xs" data-uiedit-mode="move">MOVE</button>
                            <button type="button" class="ui-mode-btn ui-mode-btn-add rounded-full px-3 py-1 text-xs" data-uiedit-mode="add">ADD</button>
                        </div>

                        <div class="space-y-4">
                        <div data-uiedit-group="meta" class="space-y-4">
                            <div class="space-y-1">
                                <label class="block text-xs font-medium text-slate-300">Classes (selected)</label>
                                <input id="selClasses"
                                       class="w-full rounded-lg border border-slate-500/50 bg-slate-800/40 px-3 py-2 text-slate-100 text-sm"
                                       readonly />
                            </div>

                            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                                <div class="space-y-1">
                                    <label class="block text-xs font-medium text-slate-300">Background (computed)</label>
                                    <div class="flex items-center gap-3">
                                        <input id="selBg" type="color"
                                               class="w-16 rounded-lg border border-slate-500/50 bg-slate-800/40" />
                                        <label class="inline-flex items-center gap-2 text-xs text-slate-300 select-none">
                                            <input id="chkSetBg" type="checkbox" class="h-4 w-4" />
                                            Apply
                                        </label>
                                    </div>
                                    <input id="selBgRaw"
                                           class="w-full rounded-lg border border-slate-500/50 bg-slate-800/40 px-3 py-2 text-slate-100 text-xs"
                                           readonly />
                                </div>

                                <div class="space-y-1">
                                    <label class="block text-xs font-medium text-slate-300">Text color (computed)</label>
                                    <div class="flex items-center gap-3">
                                        <input id="selTextColor" type="color"
                                               class="w-16 rounded-lg border border-slate-500/50 bg-slate-800/40" />
                                        <label class="inline-flex items-center gap-2 text-xs text-slate-300 select-none">
                                            <input id="chkSetTextColor" type="checkbox" class="h-4 w-4" />
                                            Apply
                                        </label>
                                    </div>
                                    <input id="selTextColorRaw"
                                           class="w-full rounded-lg border border-slate-500/50 bg-slate-800/40 px-3 py-2 text-slate-100 text-xs"
                                           readonly />
                                </div>
                            </div>
                        </div>
                        </div>

                        <!-- TEXT/TAB fields -->
                        <div data-uiedit-group="text" class="space-y-4">
                            <div class="space-y-1">
                                <label class="block text-xs font-medium text-slate-300">Text</label>
                                <textarea id="selText" rows="3"
                                          class="w-full rounded-lg border border-slate-500/50 bg-slate-800/40 px-3 py-2 text-slate-100 text-sm"></textarea>
                            </div>

                            <div class="space-y-1">
                                <label class="block text-xs font-medium text-slate-300">Add class</label>
                                <input id="selClassAdd"
                                       placeholder="e.g. border border-amber-400/40"
                                       class="w-full rounded-lg border border-slate-500/50 bg-slate-800/40 px-3 py-2 text-slate-100 text-sm" />
                            </div>
                        </div>

                        <!-- TABLE fields -->
                        <div data-uiedit-group="table" class="pt-3 border-t border-slate-600/50 hidden">
                            <div class="text-sm text-slate-100 font-semibold mb-2">
                                <i class="fa-solid fa-table-columns mr-2"></i>Table tools
                            </div>

                            <div class="space-y-3">
                                <div class="space-y-1">
                                    <label class="block text-xs font-medium text-slate-300">Table selector</label>
                                    <input id="selTable"
                                           class="w-full rounded-lg border border-slate-500/50 bg-slate-800/40 px-3 py-2 text-slate-100 text-sm"
                                           readonly />
                                </div>

                                <div class="space-y-1">
                                    <label class="block text-xs font-medium text-slate-300">Column index</label>
                                    <input id="selCol"
                                           class="w-full rounded-lg border border-slate-500/50 bg-slate-800/40 px-3 py-2 text-slate-100 text-sm"
                                           readonly />
                                </div>

                                <button id="btnHideCol" type="button"
                                        class="w-full inline-flex items-center justify-center gap-2 rounded-full border border-slate-500/60 bg-slate-800/40 px-4 py-2 text-slate-100 hover:bg-slate-600 transition">
                                    <i class="fa-solid fa-eye-slash text-sm"></i>
                                    <span>Hide column</span>
                                </button>
                            </div>
                        </div>

                        <!-- IMAGE fields -->
                        <div data-uiedit-group="image" class="pt-3 border-t border-slate-600/50 hidden">
                            <div class="text-sm text-slate-100 font-semibold mb-2">
                                <i class="fa-regular fa-image mr-2"></i>Image
                            </div>
                            <div class="space-y-3">
                                <div class="space-y-1">
                                    <label class="block text-xs font-medium text-slate-300">Src</label>
                                    <input id="selImgSrc" type="text"
                                           placeholder="/images/... or https://..."
                                           class="w-full rounded-lg border border-slate-500/50 bg-slate-800/40 px-3 py-2 text-slate-100 text-sm" />
                                </div>
                                <div class="space-y-1">
                                    <label class="block text-xs font-medium text-slate-300">Alt</label>
                                    <input id="selImgAlt" type="text"
                                           placeholder="Alt text"
                                           class="w-full rounded-lg border border-slate-500/50 bg-slate-800/40 px-3 py-2 text-slate-100 text-sm" />
                                </div>
                                <div class="space-y-1">
                                    <label class="block text-xs font-medium text-slate-300">Add class</label>
                                    <input id="selImgClassAdd" type="text"
                                           placeholder="e.g. rounded-xl shadow"
                                           class="w-full rounded-lg border border-slate-500/50 bg-slate-800/40 px-3 py-2 text-slate-100 text-sm" />
                                </div>

                                <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
                                    <div class="space-y-1">
                                        <label class="block text-xs font-medium text-slate-300">Width</label>
                                        <select id="selImgWidth"
                                                class="w-full rounded-lg border border-slate-500/50 bg-slate-800/40 px-3 py-2 text-slate-100 text-sm">
                                            <option value="">(keep)</option>
                                            <option value="auto">Auto</option>
                                            <option value="16px">16px</option>
                                            <option value="24px">24px</option>
                                            <option value="32px">32px</option>
                                            <option value="48px">48px</option>
                                            <option value="64px">64px</option>
                                            <option value="96px">96px</option>
                                            <option value="128px">128px</option>
                                            <option value="100%">100%</option>
                                            <option value="custom">Custom (px)</option>
                                        </select>
                                        <input id="selImgWidthCustom" type="number" min="1" step="1"
                                               placeholder="e.g. 120"
                                               class="hidden mt-2 w-full rounded-lg border border-slate-500/50 bg-slate-800/40 px-3 py-2 text-slate-100 text-sm" />
                                    </div>

                                    <div class="space-y-1">
                                        <label class="block text-xs font-medium text-slate-300">Height</label>
                                        <select id="selImgHeight"
                                                class="w-full rounded-lg border border-slate-500/50 bg-slate-800/40 px-3 py-2 text-slate-100 text-sm">
                                            <option value="">(keep)</option>
                                            <option value="auto">Auto</option>
                                            <option value="16px">16px</option>
                                            <option value="24px">24px</option>
                                            <option value="32px">32px</option>
                                            <option value="48px">48px</option>
                                            <option value="64px">64px</option>
                                            <option value="96px">96px</option>
                                            <option value="128px">128px</option>
                                            <option value="custom">Custom (px)</option>
                                        </select>
                                        <input id="selImgHeightCustom" type="number" min="1" step="1"
                                               placeholder="e.g. 80"
                                               class="hidden mt-2 w-full rounded-lg border border-slate-500/50 bg-slate-800/40 px-3 py-2 text-slate-100 text-sm" />
                                    </div>
                                </div>

                                <div class="space-y-1">
                                    <label class="block text-xs font-medium text-slate-300">Align</label>
                                    <select id="selImgAlign"
                                            class="w-full rounded-lg border border-slate-500/50 bg-slate-800/40 px-3 py-2 text-slate-100 text-sm">
                                        <option value="">(keep)</option>
                                        <option value="inline">Inline</option>
                                        <option value="left">Left</option>
                                        <option value="center">Center</option>
                                        <option value="right">Right</option>
                                    </select>
                                </div>
                            </div>
                        </div>

                        <!-- ICON fields -->
                        <div data-uiedit-group="icon" class="pt-3 border-t border-slate-600/50 hidden">
                            <div class="text-sm text-slate-100 font-semibold mb-2">
                                <i class="fa-solid fa-icons mr-2"></i>Icon
                            </div>
                            <div class="space-y-3">
                                <div class="space-y-1">
                                    <label class="block text-xs font-medium text-slate-300">Classes (replace)</label>
                                    <input id="selIconClass" type="text"
                                           placeholder="e.g. fa-solid fa-user"
                                           list="iconClassList"
                                           class="w-full rounded-lg border border-slate-500/50 bg-slate-800/40 px-3 py-2 text-slate-100 text-sm" />
                                    <datalist id="iconClassList"></datalist>
                                    <div class="text-[11px] text-slate-400">Tip: select the inner <span class="text-slate-200">&lt;i&gt;</span> element when possible.</div>
                                </div>

                                <div class="space-y-1">
                                    <label class="block text-xs font-medium text-slate-300">Icon image (pick or upload)</label>
                                    <input id="selIconImageSrc" type="text"
                                           placeholder="Pick an image (or upload below)"
                                           list="iconImageList"
                                           class="w-full rounded-lg border border-slate-500/50 bg-slate-800/40 px-3 py-2 text-slate-100 text-sm" />
                                    <datalist id="iconImageList"></datalist>

                                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-2 mt-2">
                                        <div class="space-y-1">
                                            <label class="block text-[11px] font-medium text-slate-300">Image size</label>
                                            <select id="selIconImgSize"
                                                    class="w-full rounded-lg border border-slate-500/50 bg-slate-800/40 px-3 py-2 text-slate-100 text-sm">
                                                <option value="1em">Auto (1em)</option>
                                                <option value="16px">16px</option>
                                                <option value="24px">24px</option>
                                                <option value="32px">32px</option>
                                                <option value="48px">48px</option>
                                                <option value="64px">64px</option>
                                            </select>
                                        </div>
                                        <div class="space-y-1">
                                            <label class="block text-[11px] font-medium text-slate-300">Upload</label>
                                            <input id="fileIconUpload" type="file" accept="image/*"
                                                   class="block w-full text-xs text-slate-200" />
                                        </div>
                                    </div>
                                    <div class="text-[11px] text-slate-400">Upload stores the image inside the override (can be large).</div>
                                </div>

                                <div class="grid grid-cols-1 sm:grid-cols-2 gap-2">
                                    <button id="btnIconAddPrepend" type="button"
                                            class="w-full inline-flex items-center justify-center gap-2 rounded-full bg-brand px-4 py-2 text-white hover:bg-brand-600 transition">
                                        <i class="fa-solid fa-plus text-sm"></i>
                                        <span>Add (before)</span>
                                    </button>
                                    <button id="btnIconAddAppend" type="button"
                                            class="w-full inline-flex items-center justify-center gap-2 rounded-full bg-brand px-4 py-2 text-white hover:bg-brand-600 transition">
                                        <i class="fa-solid fa-plus text-sm"></i>
                                        <span>Add (after)</span>
                                    </button>
                                </div>

                                <button id="btnIconDelete" type="button"
                                        class="w-full inline-flex items-center justify-center gap-2 rounded-full bg-red-600 px-4 py-2 text-white hover:bg-red-700 transition">
                                    <i class="fa-solid fa-trash text-sm"></i>
                                    <span>Remove icon</span>
                                </button>
                            </div>
                        </div>

                        <!-- INPUT fields -->
                        <div data-uiedit-group="input" class="pt-3 border-t border-slate-600/50 hidden">
                            <div class="text-sm text-slate-100 font-semibold mb-2">
                                <i class="fa-solid fa-i-cursor mr-2"></i>Input
                            </div>
                            <div class="space-y-3">
                                <div class="space-y-1">
                                    <label class="block text-xs font-medium text-slate-300">Type</label>
                                    <select id="selInputType"
                                            class="w-full rounded-lg border border-slate-500/50 bg-slate-800/40 px-3 py-2 text-slate-100 text-sm">
                                        <option value="text">text</option>
                                        <option value="number">number</option>
                                        <option value="date">date</option>
                                        <option value="datetime-local">datetime-local</option>
                                        <option value="time">time</option>
                                        <option value="email">email</option>
                                        <option value="password">password</option>
                                        <option value="tel">tel</option>
                                        <option value="url">url</option>
                                        <option value="search">search</option>
                                    </select>
                                </div>

                                <div class="flex items-center justify-between">
