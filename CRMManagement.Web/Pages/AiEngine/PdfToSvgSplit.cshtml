        const maxMarked = 6000;
        const cropHitPad = _getSvgAiCandidateHitPad(crop);
        const minThinObjectThickness = Math.max(2, Math.min(8, Math.min(Number(crop.w) || 0, Number(crop.h) || 0) * 0.08));
        const debugInfo = {
            cropViewBox: svgPreviewFixedCropViewBoxStr || '',
            totalNodes: 0,
            skippedDefs: 0,
            bboxMisses: 0,
            nonIntersecting: 0,
            marked: 0,
            limitHit: false,
            samples: []
        };

