    // Drawing on PDF mark canvases
    (function bindPdfMarkDraw() {
        let drawState = null;

        document.addEventListener('pointerdown', (e) => {
            if (!e.target || !e.target.classList) return;
            if (!e.target.classList.contains('pdf-mark-canvas')) return;
            if (!_pdfMarkMode) return;
            const mc = e.target;
            const pi = parseInt(mc.dataset.pageIndex || '0', 10);
            e.preventDefault();
            e.stopPropagation();
            const rect = mc.getBoundingClientRect();
            const sx = mc.width / rect.width;
            const sy = mc.height / rect.height;
            drawState = { pi, mc, x0: (e.clientX - rect.left) * sx, y0: (e.clientY - rect.top) * sy, rect, sx, sy };
        });

        document.addEventListener('pointermove', (e) => {
            if (!drawState) return;
            const { mc, x0, y0, rect, sx, sy } = drawState;
            const x1 = (e.clientX - rect.left) * sx;
            const y1 = (e.clientY - rect.top) * sy;
            const ctx = mc.getContext('2d');
            if (!ctx) return;
            ctx.clearRect(0, 0, mc.width, mc.height);
            const rx = Math.min(x0, x1), ry = Math.min(y0, y1);
            const rw = Math.abs(x1 - x0), rh = Math.abs(y1 - y0);
            ctx.strokeStyle = '#f59e0b'; ctx.lineWidth = 3; ctx.setLineDash([8, 4]);
            ctx.strokeRect(rx, ry, rw, rh);
            ctx.fillStyle = 'rgba(245,158,11,0.12)';
            ctx.fillRect(rx, ry, rw, rh);
            ctx.setLineDash([]);
        });

        document.addEventListener('pointerup', (e) => {
            if (!drawState) return;
            const { pi, mc, x0, y0, rect, sx, sy } = drawState;
            const x1 = (e.clientX - rect.left) * sx;
            const y1 = (e.clientY - rect.top) * sy;
            drawState = null;
            const rw = Math.abs(x1 - x0), rh = Math.abs(y1 - y0);
            if (rw < 8 || rh < 8) return;
            const fx = Math.min(x0, x1) / mc.width;
            const fy = Math.min(y0, y1) / mc.height;
            const fw = rw / mc.width;
            const fh = rh / mc.height;
            _showPdfMarkPreview(pi, fx, fy, fw, fh);
        });
    })();

    async function _showPdfMarkPreview(pi, fx, fy, fw, fh) {
