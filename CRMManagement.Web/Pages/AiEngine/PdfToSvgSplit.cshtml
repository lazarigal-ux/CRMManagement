                            <div class="flex items-center gap-2 flex-wrap">${yoloStatusHtml}</div>
                            <div class="ms-auto text-[11px] text-slate-500">${pagesToShow.length} page(s) • scroll-wheel to zoom</div>
                        </div>
                        ${pagesToShow.some(p => p && p.detectionCount > 0)
                            ? ''
                            : `<div class="px-3 py-2 border-b border-red-500/20 text-[11px] text-slate-400">No detections were found. Use Mark Missing or Add to YOLO on the page image to add training objects manually.</div>`}
                        <div class="p-3 space-y-4">${cards}</div>
                    </div>`;
        } catch {
            return '';
        }
    }

    /* ── Annotated page inline zoom helpers ── */
    const _annotatedPageZooms = {};

    function _getAnnotatedPageDisplayMetrics(pi) {
        try {
            const scaleEl = document.getElementById(`annotatedPageScale_${pi}`);
            const img = scaleEl ? scaleEl.querySelector('img') : null;
            if (!scaleEl || !img) return null;

            const bw = img.naturalWidth || 0;
            const bh = img.naturalHeight || 0;
            if (bw <= 0 || bh <= 0) return null;

            const cropX = Math.max(0, Math.min(1, Number(scaleEl.dataset.cropX || '0')));
            const cropY = Math.max(0, Math.min(1, Number(scaleEl.dataset.cropY || '0')));
            const cropW = Math.max(0.0005, Math.min(1 - cropX, Number(scaleEl.dataset.cropW || '1')));
            const cropH = Math.max(0.0005, Math.min(1 - cropY, Number(scaleEl.dataset.cropH || '1')));
            const displayW = Math.max(1, Math.round(bw * cropW));
            const displayH = Math.max(1, Math.round(bh * cropH));

            return { scaleEl, img, bw, bh, cropX, cropY, cropW, cropH, displayW, displayH };
        } catch {
            return null;
        }
    }

    function _drawAnnotatedDetectionOverlays(pi) {
        try {
            const canvas = document.getElementById(`annotatedDetectionsCanvas_${pi}`);
            if (!canvas) return;

            const boxes = _getAnnotatedDetectionBoxes(pi);
            const metrics = _getAnnotatedPageDisplayMetrics(pi);
            if (!metrics) return;
            const { displayW, displayH } = metrics;
            canvas.width = displayW;
            canvas.height = displayH;
            const z = _annotatedPageZooms[pi] || 1;
            canvas.style.width = (displayW * z) + 'px';
            canvas.style.height = (displayH * z) + 'px';

            const ctx = canvas.getContext('2d');
            if (!ctx) return;
            ctx.clearRect(0, 0, canvas.width, canvas.height);

            for (const box of boxes) {
                const state = box.state;
                const stroke = state === 'manual' || state === 'approved'
                    ? '#22c55e'
                    : (state === 'rejected' ? '#facc15' : '#ef4444');
                const fill = state === 'manual' || state === 'approved'
                    ? 'rgba(34,197,94,0.14)'
                    : (state === 'rejected' ? 'rgba(250,204,21,0.16)' : 'rgba(239,68,68,0.14)');
                const memoryInfo = _getDetectionMemoryLinkInfo(box.row);
                const baseLabel = state === 'manual'
                    ? 'Manual'
                    : (state === 'approved' ? 'Correct' : (state === 'rejected' ? 'Rejected' : _getDetectionSourceLabel(box.row)));
                const label = `${baseLabel} #${box.idx + 1}${memoryInfo ? (' • ' + memoryInfo.shortLabel) : ''}`;

                ctx.save();
                ctx.lineWidth = state === 'manual' ? 4 : 3;
                ctx.strokeStyle = stroke;
                ctx.fillStyle = fill;
                ctx.setLineDash(state === 'rejected' ? [10, 6] : []);
                ctx.fillRect(box.dx, box.dy, box.dw, box.dh);
                ctx.strokeRect(box.dx, box.dy, box.dw, box.dh);
                ctx.setLineDash([]);
                ctx.font = 'bold 12px sans-serif';
                const textW = Math.ceil(ctx.measureText(label).width) + 12;
                const textH = 18;
                const ty = Math.max(0, box.dy - textH);
                ctx.fillStyle = stroke;
                ctx.fillRect(box.dx, ty, textW, textH);
                ctx.fillStyle = '#08111f';
                ctx.fillText(label, box.dx + 6, ty + 13);
                ctx.restore();
            }
            try { _renderAnnotatedDetectionHotspots(pi, boxes, displayW, displayH); } catch { /* ignore */ }
        } catch { /* ignore */ }
    }

    function _renderAnnotatedDetectionHotspots(pi, boxes, displayW, displayH) {
        const layer = document.getElementById(`annotatedDetectionsHotspots_${pi}`);
        if (!layer) return;
        layer.style.width = `${displayW}px`;
        layer.style.height = `${displayH}px`;
        const safeBoxes = Array.isArray(boxes) ? boxes : _getAnnotatedDetectionBoxes(pi);
        layer.innerHTML = safeBoxes.map(box => {
            const state = _getDetectionVisualState(box.row, box.idx, true);
            const title = state === 'approved'
                ? 'Green add — click for actions'
                : (state === 'rejected' ? 'Yellow cancel — click for actions' : 'Neutral — click for actions');
            const ring = state === 'manual' || state === 'approved'
                ? 'rgba(34,197,94,0.18)'
                : (state === 'rejected' ? 'rgba(250,204,21,0.18)' : 'rgba(239,68,68,0.10)');
            return `<button type="button"
                        class="annotated-detection-hotspot"
                        data-annotated-detection-hotspot="1"
                        data-page-index="${pi}"
                        data-detection-idx="${box.idx}"
                        title="${escapeHtml(title)}"
                        ondblclick="toggleAnnotatedDetectionFromMap(${box.idx}); event.preventDefault(); event.stopPropagation();"
                        onclick="scheduleAnnotatedDetectionActionMenuFromHotspot(${pi}, ${box.idx}, this); event.preventDefault(); event.stopPropagation();"
                        style="position:absolute; left:${box.dx}px; top:${box.dy}px; width:${box.dw}px; height:${box.dh}px; border:none; padding:0; margin:0; background:${ring}; cursor:pointer;"></button>`;
        }).join('');
    }

    function _getAnnotatedDetectionBoxes(pi) {
        try {
            const metrics = _getAnnotatedPageDisplayMetrics(pi);
            if (!metrics) return [];
            const { displayW, displayH, cropX, cropY, cropW, cropH } = metrics;
            const rows = Array.isArray(_familyScanDetections) ? _familyScanDetections : [];
            const pageMeta = (Array.isArray(_familyScanAnnotatedPages) ? _familyScanAnnotatedPages : []).find(p => p && ((p.pageIndex | 0) === pi));
            const drawDetected = !!(pageMeta && pageMeta.renderClientOverlays);
            const boxes = [];

            rows.forEach((r, idx) => {
                if (!r) return;
                const pageIndex = (r.pageIndex != null && isFinite(r.pageIndex)) ? (r.pageIndex | 0) : -1;
                if (pageIndex !== pi) return;

                const rx = Number(r.x);
                const ry = Number(r.y);
                const rw = Number(r.w);
                const rh = Number(r.h);
                if (!Number.isFinite(rx) || !Number.isFinite(ry) || !Number.isFinite(rw) || !Number.isFinite(rh)) return;

                const ix0 = Math.max(rx, cropX);
                const iy0 = Math.max(ry, cropY);
                const ix1 = Math.min(rx + rw, cropX + cropW);
                const iy1 = Math.min(ry + rh, cropY + cropH);
                if (ix1 <= ix0 || iy1 <= iy0) return;

                const dx = ((ix0 - cropX) / cropW) * displayW;
                const dy = ((iy0 - cropY) / cropH) * displayH;
                const dw = ((ix1 - ix0) / cropW) * displayW;
                const dh = ((iy1 - iy0) / cropH) * displayH;
                if (!(dw > 1 && dh > 1)) return;

                const state = _getDetectionVisualState(r, idx, true);
                if (state === 'detected' && !drawDetected) return;
                boxes.push({ idx, row: r, state, dx, dy, dw, dh });
            });

            return boxes;
        } catch {
            return [];
        }
    }

