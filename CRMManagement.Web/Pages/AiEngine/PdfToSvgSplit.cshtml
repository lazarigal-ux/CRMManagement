            }).filter(Boolean).join('');

            const yoloStatusHtml = _getFamilyYoloStatusSummaryHtml();

            return `<div class="mt-3 rounded-xl border border-red-500/40 bg-slate-950/30">
                        <div class="px-3 py-2 border-b border-red-500/30 flex items-center gap-2 flex-wrap">
