                        <span class="shrink-0 text-slate-400">Confidence</span>
                        <input type="number" min="0.01" max="0.95" step="0.01" value="${escapeHtml(detectSettings.conf.toFixed(2))}" class="min-w-0 flex-1 rounded-md border border-slate-500/50 bg-slate-900/40 px-2 py-1 text-xs text-slate-100 outline-none focus:border-sky-400 focus:ring-2 focus:ring-sky-400/40" onchange="setFamilyYoloDetectField('conf', this.value)" />
