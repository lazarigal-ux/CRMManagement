    function _familyEditPushUndo() {
        try {
            const scale = document.getElementById('svgPreviewScale');
            if (!scale) return;
            const svg = scale.querySelector('svg');
            if (!svg) return;
            const snap = new XMLSerializer().serializeToString(svg);
            _familyEditUndoStack.push(snap);
            if (_familyEditUndoStack.length > _FAMILY_EDIT_MAX_UNDO) _familyEditUndoStack.shift();
            _familyEditRedoStack.length = 0;
            _familyEditUpdateUndoRedoButtons();
        } catch { /* ignore */ }
    }

    function _familyEditRestoreSvg(svgText, opts) {
        try {
            const scale = document.getElementById('svgPreviewScale');
            if (!scale) return;

            const preserveViewport = !!(opts && opts.preserveViewport);
            const body = preserveViewport ? document.getElementById('svgPreviewBody') : null;
            const prevZoom = preserveViewport ? svgPreviewZoom : null;
            const prevScrollLeft = (preserveViewport && body) ? body.scrollLeft : 0;
            const prevScrollTop = (preserveViewport && body) ? body.scrollTop : 0;

            // Restore via XML parsing (more reliable than innerHTML for SVG).
            scale.innerHTML = '';
            let svg = null;
            try {
                const doc = new DOMParser().parseFromString(String(svgText || ''), 'image/svg+xml');
                const svgNode = doc ? doc.querySelector('svg') : null;
                if (svgNode) {
                    svg = document.importNode(svgNode, true);
                    scale.appendChild(svg);
                }
            } catch { /* ignore */ }
            if (!svg) svg = scale.querySelector('svg');
            if (svg) {
                svg.removeAttribute('width');
                svg.removeAttribute('height');
                svg.style.width = 'auto';
                svg.style.height = 'auto';
                svg.style.display = 'block';
                if (!svg.getAttribute('preserveAspectRatio')) svg.setAttribute('preserveAspectRatio', 'xMidYMid meet');
                for (const el of svg.querySelectorAll('image, use, path, rect, circle, ellipse, polygon, polyline')) {
                    el.style.pointerEvents = 'visible';
                    el.style.cursor = 'pointer';
                }
                svg.addEventListener('click', _familyEditSvgClickHandler, { capture: true });

                if (preserveViewport) {
                    // Keep the user's current zoom & pan; do NOT auto-fit on undo/redo.
                    try {
                        if (prevZoom && isFinite(prevZoom)) setSvgPreviewZoom(prevZoom);
                        else setSvgPreviewZoom(svgPreviewZoom);
                    } catch { /* ignore */ }
                    try {
                        if (body) {
                            requestAnimationFrame(() => {
                                try { body.scrollLeft = prevScrollLeft; body.scrollTop = prevScrollTop; } catch { /* ignore */ }
                            });
                        }
                    } catch { /* ignore */ }
                } else {
                    // For non-undo restores, keep the previous behavior (fit/crop to show content).
                    try { autoFitSvgPreviewViewBoxToContent(svg, { force: true }); } catch { /* ignore */ }
                    try { fitSvgPreviewToViewport(); } catch { /* ignore */ }
                }
            }
            _familyEditState.selectedEl = null;
            const lbl = document.getElementById('familyEditSelected');
            if (lbl) lbl.textContent = 'Selected: — (click an object)';
            _familyEditUpdateUndoRedoButtons();
        } catch { /* ignore */ }
    }

    function _familyEditUndo() {
        if (!_familyEditUndoStack.length) return;
        try {
            const scale = document.getElementById('svgPreviewScale');
            const svg = scale ? scale.querySelector('svg') : null;
            if (svg) {
                const current = new XMLSerializer().serializeToString(svg);
                _familyEditRedoStack.push(current);
            }
        } catch { /* ignore */ }
        const prev = _familyEditUndoStack.pop();
        _familyEditRestoreSvg(prev, { preserveViewport: true });
    }

    function _familyEditRedo() {
        if (!_familyEditRedoStack.length) return;
        try {
            const scale = document.getElementById('svgPreviewScale');
            const svg = scale ? scale.querySelector('svg') : null;
            if (svg) {
                const current = new XMLSerializer().serializeToString(svg);
                _familyEditUndoStack.push(current);
            }
        } catch { /* ignore */ }
        const next = _familyEditRedoStack.pop();
        _familyEditRestoreSvg(next, { preserveViewport: true });
    }

    function _familyEditUpdateUndoRedoButtons() {
        try {
            const btnUndo = document.getElementById('btnFamilyEditUndo');
            const btnRedo = document.getElementById('btnFamilyEditRedo');
            if (btnUndo) { btnUndo.disabled = _familyEditUndoStack.length === 0; btnUndo.classList.toggle('opacity-40', _familyEditUndoStack.length === 0); }
            if (btnRedo) { btnRedo.disabled = _familyEditRedoStack.length === 0; btnRedo.classList.toggle('opacity-40', _familyEditRedoStack.length === 0); }
        } catch { /* ignore */ }
    }

    function _familyEditSvgClickHandler(e) {
        try {
            if (!e || !e.target) return;
            let t = e.target;
            if (!t || !t.tagName) return;
            let tag = String(t.tagName).toLowerCase();
            const scale = document.getElementById('svgPreviewScale');
            const svg = scale ? scale.querySelector('svg') : null;
            if (tag === 'use' && svg) {
                const href = t.getAttribute('href') || t.getAttribute('xlink:href') || '';
                if (href.startsWith('#')) {
                    const ref = svg.querySelector(href);
                    if (ref && ref.tagName && ref.tagName.toLowerCase() === 'symbol' && ref.children.length === 1) {
                        t = ref.children[0]; tag = String(t.tagName).toLowerCase();
                    } else if (ref) { t = ref; tag = String(t.tagName).toLowerCase(); }
                }
                if (tag === 'use') { _familyEditSelectElement(t); return; }
            }
            if (tag === 'svg' || tag === 'defs' || tag === 'style' || tag === 'title' || tag === 'desc' || tag === 'symbol') return;
            _familyEditSelectElement(t);
        } catch { /* ignore */ }
    }

    // Keyboard shortcuts: Ctrl+Z = Undo, Ctrl+Y / Ctrl+Shift+Z = Redo
    document.addEventListener('keydown', (e) => {
        try {
            const modal = document.getElementById('svgPreviewModal');
            if (!modal || modal.classList.contains('hidden')) return;
            if (!_familyEditState || !_familyEditState.sampleId) return;
            // Escape cancels region mode
            if (e.key === 'Escape' && _familyEditRegionMode) { e.preventDefault(); _familyEditCancelRegionMode(); return; }
            if (e.key === 'Escape' && _familyEditBrushMode) { e.preventDefault(); _familyEditCancelBrushEraseMode(); return; }
            if ((e.ctrlKey || e.metaKey) && !e.altKey) {
                if (e.key === 'z' && !e.shiftKey) { e.preventDefault(); _familyEditUndo(); }
                else if (e.key === 'z' && e.shiftKey) { e.preventDefault(); _familyEditRedo(); }
                else if (e.key === 'y') { e.preventDefault(); _familyEditRedo(); }
            }
        } catch { /* ignore */ }
    });

