            _svgAiCleanBusy = true;
            _updateSvgAiCleanUi();
            if (sourceBtn) {
                sourceBtn.disabled = true;
                sourceBtn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> AI…';
            }

            errorCard.classList.add('hidden');

            if (!svgPreviewFixedCropEnabled || !svgPreviewFixedCropViewBoxStr) {
                throw new Error('For AI CLEAN, first use SELECT AREA in SVG Preview and mark a smaller area to send.');
            }

            const selectedProvider = _getSvgAiProviderValue();
            let selectedModel = (_getAiTextOnlyModelValue() || '').toString().trim();
            if (/^gpt-image-1$/i.test(selectedModel)) selectedModel = 'gpt-4.1';

            const tPrepare0 = performance.now();
            const imageDataUrls = await _buildAiCleanImageDataUrls(r.svgContent, svgPreviewFixedCropViewBoxStr);
            const prepareImageMs = Math.round(performance.now() - tPrepare0);
            if (!imageDataUrls.length) throw new Error('Failed to prepare the cropped preview image for AI CLEAN.');

            const payload = {
                clientId: getSelectedClientId(),
                provider: selectedProvider,
                model: selectedModel,
                svgContent: String(r.svgContent || ''),
                layerName: r.isLayer ? String(r.layerName || 'Layer') : `Page ${r.pageNumber || 1}`,
                pageNumber: Math.max(1, Number(r.pageNumber || 1) | 0),
                cropViewBox: String(svgPreviewFixedCropViewBoxStr || ''),
                imageDataUrls
            };

            try {
                console.groupCollapsed('[AI CLEAN] request');
                console.log('endpoint', SVG_AI_CLEAN_OTHER_ELEMENTS_ENDPOINT);
                console.log('payloadMeta', {
                    idx,
                    provider: payload.provider,
                    model: payload.model,
                    layerName: payload.layerName,
                    pageNumber: payload.pageNumber,
                    cropViewBox: payload.cropViewBox,
                    prepareImageMs,
                    svgChars: payload.svgContent.length,
                    imageCount: Array.isArray(payload.imageDataUrls) ? payload.imageDataUrls.length : 0,
                    imageSizes: Array.isArray(payload.imageDataUrls) ? payload.imageDataUrls.map(x => (x || '').length) : []
                });
                console.log('payloadPreview', {
                    cropViewBox: payload.cropViewBox,
                    svgHead: payload.svgContent.slice(0, 1200)
                });
                console.groupEnd();
            } catch { /* ignore */ }

            const tFetch0 = performance.now();
            const resp = await fetch(SVG_AI_CLEAN_OTHER_ELEMENTS_ENDPOINT, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json', 'X-Client-Id': 'admin' },
                body: JSON.stringify(payload)
            });
            const fetchMs = Math.round(performance.now() - tFetch0);

            const tRead0 = performance.now();
            const raw = await resp.text();
            const readBodyMs = Math.round(performance.now() - tRead0);
            let obj = null;
            const tParse0 = performance.now();
            try { obj = raw ? JSON.parse(raw) : null; } catch { obj = null; }
            const parseBodyMs = Math.round(performance.now() - tParse0);

            try {
                console.groupCollapsed('[AI CLEAN] response');
                console.log('status', resp.status);
                console.log('timings', {
                    prepareImageMs,
                    fetchMs,
                    readBodyMs,
                    parseBodyMs,
                    serverTimings: obj && obj.timings ? obj.timings : (obj && obj.diagnostics && obj.diagnostics.timings ? obj.diagnostics.timings : null)
                });
                console.log('body', obj || raw);
                console.groupEnd();
            } catch { /* ignore */ }

            if (!resp.ok) {
                const diagnostics = obj && obj.diagnostics ? obj.diagnostics : null;
                let msg = (obj && (obj.detail || obj.error || obj.title))
                    ? String(obj.detail || obj.error || obj.title)
                    : (raw || `HTTP ${resp.status}`);
                if (diagnostics) {
                    const tagSummary = diagnostics.tagCounts && typeof diagnostics.tagCounts === 'object'
                        ? Object.entries(diagnostics.tagCounts).slice(0, 8).map(([k, v]) => `${k}:${v}`).join(', ')
                        : '';
                    const diagSummary = [
                        diagnostics.cropViewBox ? `crop=${diagnostics.cropViewBox}` : '',
                        Number.isFinite(Number(diagnostics.totalCandidates)) ? `candidates=${diagnostics.totalCandidates}` : '',
                        Number.isFinite(Number(diagnostics.intersectingCandidates)) ? `intersecting=${diagnostics.intersectingCandidates}` : '',
                        Number.isFinite(Number(diagnostics.uniqueSampleElements)) ? `sampled=${diagnostics.uniqueSampleElements}` : '',
                        tagSummary ? `tags=${tagSummary}` : ''
                    ].filter(Boolean).join(' | ');
                    if (diagSummary) msg += `\n${diagSummary}`;
                }
                throw new Error(msg);
            }

            const aiSvg = (obj && obj.svgContent) ? String(obj.svgContent) : '';
            if (!aiSvg || !aiSvg.includes('<svg')) throw new Error('AI did not return a valid SVG document.');

            /* ── AI CLEAN log ── */
            const _logSentCount   = countSvgObjects(payload.svgContent);
            const _logResultCount = countSvgObjects(aiSvg);
            const _logDeletedCount = Math.max(0, _logSentCount - _logResultCount);
            const _logProvider = selectedProvider || 'unknown';
            const _logModel    = (obj && obj.model) ? String(obj.model) : (selectedModel || '');
            console.log(
                `%c[AI CLEAN]%c sent=${_logSentCount}  deleted=${_logDeletedCount}  remaining=${_logResultCount}  provider=${_logProvider}  model=${_logModel}`,
                'background:#0284c7;color:#fff;padding:2px 6px;border-radius:3px;font-weight:bold',
                'color:#0284c7;font-weight:bold'
            );
            /* ── end log ── */

            const resultNameBase = r.isLayer
                ? String(r.layerName || 'Layer')
                : `Page ${Math.max(1, Number(r.pageNumber || 1) | 0)}`;

            const aiResult = {
                pageNumber: Math.max(1, Number(r.pageNumber || 1) | 0),
                isLayer: true,
                layerName: `${resultNameBase} — AI clean`,
                layerColor: '#0284c7',
                layerIcon: 'fa-sparkles',
                svgContent: aiSvg,
                svgSizeBytes: new Blob([aiSvg]).size,
                objectCount: _logResultCount,
                aiProvider: obj && obj.provider ? String(obj.provider) : payload.provider,
                aiModel: _logModel,
                sourceResultIndex: idx,
                aiCleanSource: 'other-elements'
            };

            pageResults.push(aiResult);
            addResultCard(pageResults.length - 1);
            resultsSection.classList.remove('hidden');
            setSplitMainTab('svgSplit');

            if (options && options.openPreview) {
                requestAnimationFrame(() => {
                    try {
                        const previewBtn = resultsGrid
                            ? resultsGrid.querySelector(`.page-card[data-idx="${pageResults.length - 1}"] .btn-preview`)
                            : null;
                        previewBtn?.click();
                    } catch { /* ignore */ }
                });
            }
        } catch (ex) {
            const msg = ex && ex.message ? ex.message : String(ex || 'AI clean failed.');
            showError(msg);
            cgAlert(msg);
        } finally {
            _svgAiCleanBusy = false;
            _updateSvgAiCleanUi();
            if (sourceBtn) {
                sourceBtn.disabled = originalBtnDisabled;
                sourceBtn.innerHTML = originalBtnHtml;
            }
        }
    }

