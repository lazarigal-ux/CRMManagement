                console.log('[EDITOR-DBG] viewBox baseVal:', vb0 ? { x: vb0.x, y: vb0.y, w: vb0.width, h: vb0.height } : 'null');
                if (vb0 && vb0.width > 0 && vb0.height > 0) {
                    svg._origPageRect = { x: vb0.x || 0, y: vb0.y || 0, w: vb0.width, h: vb0.height };
                } else {
                    const bb0 = svg.getBBox();
                    console.log('[EDITOR-DBG] fallback getBBox:', bb0 ? { x: bb0.x, y: bb0.y, w: bb0.width, h: bb0.height } : 'null');
                    if (bb0 && bb0.width > 0 && bb0.height > 0) {
                        svg.setAttribute('viewBox', `${bb0.x} ${bb0.y} ${bb0.width} ${bb0.height}`);
                        svg._origPageRect = { x: bb0.x || 0, y: bb0.y || 0, w: bb0.width, h: bb0.height };
                    }
                }
                console.log('[EDITOR-DBG] _origPageRect:', svg._origPageRect);
            } catch (e) { console.warn('[EDITOR-DBG] viewBox setup error:', e); }

            svg.removeAttribute('width');
            svg.removeAttribute('height');
            svg.style.width = 'auto';
            svg.style.height = 'auto';
            svg.style.display = 'block';
            if (!svg.getAttribute('preserveAspectRatio')) svg.setAttribute('preserveAspectRatio', 'xMidYMid meet');

            // Ensure all visual elements are clickable
            try {
                for (const el of svg.querySelectorAll('image, use, path, rect, circle, ellipse, polygon, polyline')) {
                    el.style.pointerEvents = 'visible';
                    el.style.cursor = 'pointer';
                }
            } catch {}

            // Aggressively crop to content for small symbols so it is visible.
            try {
                console.log('[EDITOR-DBG] calling autoFitSvgPreviewViewBoxToContent (force=true)');
                autoFitSvgPreviewViewBoxToContent(svg, { force: true });
                console.log('[EDITOR-DBG] after autoFit, viewBox=', svg.getAttribute('viewBox'));
            } catch (e) { console.warn('[EDITOR-DBG] autoFit error:', e); }

            svg.addEventListener('click', _familyEditSvgClickHandler, { capture: true });

            // Auto-select the first meaningful element so user sees something is active
            try {
                const firstEl = svg.querySelector('use, image, path, rect, circle, ellipse');
                if (firstEl) {
                    // For <use> referencing a symbol with a single child, select the child
                    if (firstEl.tagName.toLowerCase() === 'use') {
                        const href = firstEl.getAttribute('href') || firstEl.getAttribute('xlink:href') || '';
                        if (href.startsWith('#')) {
                            const ref = svg.querySelector(href);
                            if (ref && ref.tagName && ref.tagName.toLowerCase() === 'symbol' && ref.children.length === 1) {
                                _familyEditSelectElement(ref.children[0]);
                            } else {
                                _familyEditSelectElement(firstEl);
                            }
                        } else {
                            _familyEditSelectElement(firstEl);
                        }
                    } else {
                        _familyEditSelectElement(firstEl);
                    }
                }
            } catch { /* ignore */ }
        }

        const colorInput = document.getElementById('familyEditColor');
        const btnColor = document.getElementById('btnFamilyEditApplyColor');
        const btnBig = document.getElementById('btnFamilyEditBigger');
        const btnDel = document.getElementById('btnFamilyEditDelete');
        const btnSave = document.getElementById('btnFamilyEditSave');

