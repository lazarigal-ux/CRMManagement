        const hasOutputCrop = !!(ctx && ctx.hasOutputCrop);
        if (hasOutputCrop && hasRegions) return 'Global output crop + region selections';
        if (hasOutputCrop) return 'Global output crop';
        if (hasRegions) return 'Region crop';
