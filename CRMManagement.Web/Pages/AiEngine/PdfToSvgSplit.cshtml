@section Scripts {
<script>
(function () {
    // ── Endpoints ──
    const PREVIEW_ENDPOINT  = '@Url.Content("~/fire/pdf/preview/render")';
    const LAYERS_ENDPOINT   = '@Url.Content("~/fire/pdf/layers/detect")';
