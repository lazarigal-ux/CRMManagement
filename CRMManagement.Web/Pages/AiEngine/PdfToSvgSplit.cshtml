    let _pdfTextSelectedLanguages = (() => {
        try {
            const raw = localStorage.getItem(_pdfTextLanguageStorageKey);
            const parsed = raw ? JSON.parse(raw) : null;
            const list = Array.isArray(parsed) ? parsed.map(x => String(x || '').trim().toLowerCase()).filter(x => _pdfTextLanguageOrder.includes(x)) : [];
            return list.length > 0 ? Array.from(new Set(list)) : [..._pdfTextLanguageOrder];
        } catch {
            return [..._pdfTextLanguageOrder];
        }
    })();

    function _normalizeHiddenTextLabel(s) {
        return String(s || '').replace(/\s+/g, ' ').trim().toUpperCase();
    }

    function _compactHiddenTextLabel(s) {
        return _normalizeHiddenTextLabel(s).replace(/\s+/g, '');
    }

    function _reverseHiddenTextLabel(s) {
        return Array.from(String(s || '')).reverse().join('');
    }

    function _getSelectedPdfTextLanguages() {
        return new Set((_pdfTextSelectedLanguages || []).map(x => String(x || '').trim().toLowerCase()).filter(x => _pdfTextLanguageOrder.includes(x)));
    }

    function _analyzePdfTextLanguages(text) {
        const s = String(text || '');
        const counts = { english: 0, hebrew: 0, arabic: 0 };
        const found = new Set();

        for (const ch of s) {
            if (/[A-Za-z]/.test(ch)) {
                counts.english++;
                found.add('english');
                continue;
            }
            if (/[\u0590-\u05FF]/.test(ch)) {
                counts.hebrew++;
                found.add('hebrew');
                continue;
            }
            if (/[\u0600-\u06FF\u0750-\u077F\u08A0-\u08FF\uFB50-\uFDFF\uFE70-\uFEFF]/.test(ch)) {
                counts.arabic++;
                found.add('arabic');
                continue;
            }
        }

        const tokens = s.match(/[A-Za-z]+|[\u0590-\u05FF]+|[\u0600-\u06FF\u0750-\u077F\u08A0-\u08FF\uFB50-\uFDFF\uFE70-\uFEFF]+/g) || [];
        for (const tok of tokens) {
            if (/^[A-Za-z]+$/.test(tok)) found.add('english');
            else if (/^[\u0590-\u05FF]+$/.test(tok)) found.add('hebrew');
            else if (/^[\u0600-\u06FF\u0750-\u077F\u08A0-\u08FF\uFB50-\uFDFF\uFE70-\uFEFF]+$/.test(tok)) found.add('arabic');
        }

        let dominant = null;
        let dominantScore = 0;
        for (const lang of _pdfTextLanguageOrder) {
            const score = counts[lang] || 0;
            if (score > dominantScore) {
                dominant = lang;
                dominantScore = score;
            }
        }

        return {
            languages: _pdfTextLanguageOrder.filter(lang => found.has(lang)),
            dominantLanguage: dominant,
            counts
        };
    }

    function _detectPdfTextLanguages(text) {
        return _analyzePdfTextLanguages(text).languages;
    }

    function _getPdfTextLayerGroupKey(text) {
        const info = _analyzePdfTextLanguages(text);
        if (info && info.dominantLanguage && _pdfTextLanguageOrder.includes(info.dominantLanguage)) {
            return info.dominantLanguage;
        }
        const langs = Array.isArray(info && info.languages)
            ? info.languages.filter(lang => _pdfTextLanguageOrder.includes(lang))
            : [];
        if (langs.length === 1) return langs[0];
        if (langs.length > 1) return langs[0];
        return 'other';
    }

    function _getPdfTextLayerDisplayLabel(groupKey) {
        if (groupKey === 'english') return 'English';
        if (groupKey === 'hebrew') return 'עברית';
        if (groupKey === 'arabic') return 'العربية';
        return 'Text / Labels';
    }

    function _groupPdfTextItemsByLanguage(items, getText) {
        const order = [..._pdfTextLanguageOrder, 'other'];
        const buckets = new Map(order.map(key => [key, []]));
        for (const item of (Array.isArray(items) ? items : [])) {
            if (!item) continue;
            const text = typeof getText === 'function' ? getText(item) : '';
            const key = _getPdfTextLayerGroupKey(text);
            if (!buckets.has(key)) buckets.set(key, []);
            buckets.get(key).push(item);
        }
        return order
            .map(key => ({ key, label: _getPdfTextLayerDisplayLabel(key), items: buckets.get(key) || [] }))
            .filter(group => group.items.length > 0);
    }

    function _isAllowedByPdfTextLanguage(text) {
        const info = _analyzePdfTextLanguages(text);
        const langs = Array.isArray(info.languages) ? info.languages : [];
        const selected = _getSelectedPdfTextLanguages();
        if (selected.size === 0) return false;
        if (langs.length === 0) return true;
        if (info.dominantLanguage && selected.has(info.dominantLanguage)) return true;
        return langs.some(lang => selected.has(lang));
    }

    function _getHiddenTextLabelTokens(s) {
        const base = _normalizeHiddenTextLabel(s);
        if (!base) return [];
        return base.split(/[^0-9A-Z\u0590-\u05FF]+/).map(x => x.trim()).filter(Boolean);
    }

    function _matchesIgnoredLabelCandidate(candidate, hidden) {
        const norm = _normalizeHiddenTextLabel(candidate);
        if (!norm) return false;
        if (hidden.has(norm)) return true;

        const compact = _compactHiddenTextLabel(norm);
        if (compact && hidden.has(compact)) return true;

        const reversed = _normalizeHiddenTextLabel(_reverseHiddenTextLabel(norm));
        if (reversed && hidden.has(reversed)) return true;

        const reversedCompact = _compactHiddenTextLabel(reversed);
        if (reversedCompact && hidden.has(reversedCompact)) return true;

        return false;
    }

    function _getHiddenTextLabelSet() {
        const set = new Set();
        const parts = String(_pdfTextHiddenLabelsRaw || '').split(/[\n,;]+/);
        for (const part of parts) {
            const norm = _normalizeHiddenTextLabel(part);
            if (norm) set.add(norm);
        }
        return set;
    }

    function _isIgnoredTextLabel(text) {
        const hidden = _getHiddenTextLabelSet();
        if (hidden.size === 0) return false;

        if (_matchesIgnoredLabelCandidate(text, hidden)) return true;

        const tokens = _getHiddenTextLabelTokens(text);
        for (const token of tokens) {
            if (_matchesIgnoredLabelCandidate(token, hidden)) return true;
        }

        return false;
    }

    function _isVisiblePdfTextLabel(text) {
        // When merge-before-split is enabled, all text is visible (no filtering)
        if (_pdfPreSplitMergeEnabled) return true;
        return _isAllowedByPdfTextLanguage(text) && !_isIgnoredTextLabel(text);
    }

    function _getVisiblePdfExtractWords(words) {
        const arr = Array.isArray(words) ? words : [];
        // When merge-before-split is enabled, all words are visible
        if (_pdfPreSplitMergeEnabled) return [...arr];
        return arr.filter(it => _isVisiblePdfTextLabel(it && it.text));
    }

    function _getIgnoredPdfExtractWords(words) {
        // When merge-before-split is enabled, no words are ignored
        if (_pdfPreSplitMergeEnabled) return [];
        const arr = Array.isArray(words) ? words : [];
        return arr.filter(it => !_isVisiblePdfTextLabel(it && it.text));
    }

    function _extractSvgLayerBodyElements(svgText) {
        try {
            const src = (svgText || '').toString();
            if (!src) return [];
            const parser = new DOMParser();
            const doc = parser.parseFromString(src, 'image/svg+xml');
            const svg = doc.querySelector('svg');
            if (!svg) return [];
            return [...svg.children]
                .filter(el => String(el.tagName || '').toLowerCase() !== 'defs')
                .map(el => el.outerHTML)
                .filter(Boolean);
        } catch {
            return [];
        }
    }

    function _appendElementsToOtherLayer(layers, extraElements, vb, w, h, defsHtml) {
        const items = (Array.isArray(extraElements) ? extraElements : []).filter(Boolean);
        if (!items.length) return;

        const otherIdx = layers.findIndex(l => (l && l.layerName && String(l.layerName).toLowerCase().includes('other elements')));
        if (otherIdx >= 0) {
            const existing = layers[otherIdx] || {};
            let targetVb = vb;
            let targetW = w;
            let targetH = h;
            let targetDefs = defsHtml || '';
            try {
                const parser = new DOMParser();
                const doc = parser.parseFromString(String(existing.svgContent || ''), 'image/svg+xml');
                const svg = doc.querySelector('svg');
                if (svg) {
                    targetVb = svg.getAttribute('viewBox') || targetVb;
                    targetW = svg.getAttribute('width') || targetW;
                    targetH = svg.getAttribute('height') || targetH;
                    const defs = svg.querySelector('defs');
                    if (defs) targetDefs = defs.outerHTML;
                }
            } catch { /* ignore */ }
            const merged = [
                ..._extractSvgLayerBodyElements(existing.svgContent),
                ...items
            ];
            existing.svgContent = wrapPaths(merged, targetVb, targetW, targetH, targetDefs);
            existing.objectCount = merged.length;
            existing.layerName = `⬜ Other elements (${merged.length})`;
            layers[otherIdx] = existing;
            return;
        }

        layers.push({
            layerName: `⬜ Other elements (${items.length})`,
            color: '#64748b',
            svgContent: wrapPaths(items, vb, w, h, defsHtml),
            icon: 'fa-shapes',
            objectCount: items.length
        });
    }

    /**
     * Deduplication: merge existing body elements with incoming items,
     * removing positional duplicates both within existing items and between existing/incoming.
     * Uses position-based proximity matching to prevent duplicates on repeated "Add to SVG Split".
     */
    function _deduplicateFamilyItems(existingHtmlArr, newHtmlArr) {
        const existing = Array.isArray(existingHtmlArr) ? existingHtmlArr.filter(Boolean) : [];
        const incoming = Array.isArray(newHtmlArr) ? newHtmlArr.filter(Boolean) : [];
        if (!incoming.length && !existing.length) return [];

        // Combine everything, then deduplicate by position
        const all = [...existing, ...incoming];

        // Extract center positions
        const items = all.map(html => {
            const pos = _extractElementCenterFromHtml(html);
            return { html, cx: pos ? pos.cx : null, cy: pos ? pos.cy : null };
        });

        // Items without extractable position – keep all of them
        const noPos = items.filter(it => it.cx === null);
        const withPos = items.filter(it => it.cx !== null);

        if (withPos.length === 0) return all;

        // Compute tolerance from nearest-neighbor distance
        let minDim = Infinity;
        for (let i = 0; i < Math.min(withPos.length, 200); i++) {
            for (let j = i + 1; j < Math.min(i + 15, withPos.length); j++) {
                const d = Math.hypot(withPos[i].cx - withPos[j].cx, withPos[i].cy - withPos[j].cy);
                if (d > 0.01) minDim = Math.min(minDim, d);
            }
        }
        const tolerance = Math.min(isFinite(minDim) ? minDim * 0.25 : 5, 20);

        // Keep first occurrence at each position, skip duplicates
        const kept = [];
        const keptPositions = [];
        for (const it of withPos) {
            const isDup = keptPositions.some(kp =>
                Math.abs(kp.cx - it.cx) < tolerance && Math.abs(kp.cy - it.cy) < tolerance
            );
            if (!isDup) {
                kept.push(it.html);
                keptPositions.push({ cx: it.cx, cy: it.cy });
            }
        }

        const dupCount = all.length - kept.length - noPos.length;
        _debugPdfSplitLog('[FamilyDetector][Dedup]', {
            existingCount: existing.length,
            incomingCount: incoming.length,
            totalBeforeDedup: all.length,
            duplicatesRemoved: dupCount,
            uniqueWithPos: kept.length,
            noPos: noPos.length,
            tolerance: tolerance.toFixed(3)
        });

        return [...noPos.map(it => it.html), ...kept];
    }

    function _convertItemsToFamilyMarkers(items, vbStr, familyTypeKey, familySymbolKey) {
        const markerColor = _getFamilyTypeMarkerColor(familyTypeKey);
        const symbolShapes = _getFamilyTypeSymbolShapesMarkup(familySymbolKey);
        const markerSize = _computeFamilyMarkerSize(vbStr);
        const markers = [];
        _debugPdfSplitLog('[FamilyDetector][Markers:start]', {
            itemCount: Array.isArray(items) ? items.length : 0,
            vbStr,
            familyTypeKey,
            familySymbolKey,
            markerSize
        });
        for (let itemIndex = 0; itemIndex < items.length; itemIndex++) {
            const html = items[itemIndex];
            // Guard against the old format spreading
            if (html.includes('data-family-marker="true"') || (html.includes('fill-opacity="0.15"') && html.includes('stroke-opacity="0.55"'))) {
                markers.push(html);
                continue;
            }
            const pos = _extractElementCenterFromHtml(html);
            if (pos) {
                // Fixed small icon centered on the detection center
                const markerX = pos.cx - markerSize / 2;
                const markerY = pos.cy - markerSize / 2;
                _debugPdfSplitLog('[FamilyDetector][Markers:item]', {
                    itemIndex,
                    extractedPosition: pos,
                    markerPosition: { x: markerX, y: markerY, size: markerSize }
                });
                markers.push(_buildFamilySymbolMarkerSvg(markerX, markerY, markerSize, markerSize, symbolShapes, markerColor));
            } else {
                _debugPdfSplitLog('[FamilyDetector][Markers:item-no-pos]', { itemIndex, htmlSnippet: String(html || '').slice(0, 220) });
                markers.push(html);
            }
        }
        return markers;
    }

    function _computeFamilyLayerViewport(baseVb, baseW, baseH, contentBounds) {
        const baseView = _parseViewBoxStr(baseVb);
        const b = contentBounds
            && Number.isFinite(Number(contentBounds.x))
            && Number.isFinite(Number(contentBounds.y))
            && Number.isFinite(Number(contentBounds.w))
            && Number.isFinite(Number(contentBounds.h))
            && Number(contentBounds.w) > 0
            && Number(contentBounds.h) > 0
            ? {
                x: Number(contentBounds.x),
                y: Number(contentBounds.y),
                w: Number(contentBounds.w),
                h: Number(contentBounds.h)
            }
            : null;
        if (!b) {
            return {
                vb: baseVb,
                w: baseW,
                h: baseH,
                bounds: null
            };
        }

        const maxDim = Math.max(b.w, b.h);
        const pad = Math.max(10, Math.min(48, maxDim * 0.08));
        let x = b.x - pad;
        let y = b.y - pad;
        let w = b.w + (pad * 2);
        let h = b.h + (pad * 2);

        if (baseView) {
            const minX = Math.max(baseView.x, x);
            const minY = Math.max(baseView.y, y);
            const maxX = Math.min(baseView.x + baseView.w, x + w);
            const maxY = Math.min(baseView.y + baseView.h, y + h);
            if (maxX > minX && maxY > minY) {
                x = minX;
                y = minY;
                w = maxX - minX;
                h = maxY - minY;
            }
        }

        return {
            vb: `${x} ${y} ${w} ${h}`,
            w: String(w),
            h: String(h),
            bounds: { x, y, w, h }
        };
    }

    function _appendElementsToFamilyLayer(layers, extraElements, vb, w, h, defsHtml, familyId, familyName, contentBounds, sourcePageIndex) {
        const items = (Array.isArray(extraElements) ? extraElements : []).filter(Boolean);
        if (!items.length || !Array.isArray(layers)) return;

        const famId = Number.isFinite(Number(familyId)) && Number(familyId) > 0 ? (Number(familyId) | 0) : null;
        const safeFamilyName = String(familyName || '').trim() || (famId ? `Family #${famId}` : 'Selected family');
        const familyRecord = _findFamilyRecordByIdOrName(famId, safeFamilyName);
        const familyTypeKey = familyRecord ? _getFamilyTypeMeta(familyRecord.typeKey, familyRecord.name).key : _inferFamilyTypeKeyByName(safeFamilyName);
        const familySymbolKey = familyRecord ? _getFamilySymbolKey(familyTypeKey, familyRecord.name, familyRecord.symbolKey) : _getFamilySymbolKey(familyTypeKey, safeFamilyName, '');
        const layerTitle = `${safeFamilyName} (${items.length})`;
        const sourcePi = Number.isFinite(Number(sourcePageIndex)) ? (Number(sourcePageIndex) | 0) : null;
        _debugPdfSplitLog('[FamilyDetector][Layer:start]', {
            familyId: famId,
            familyName: safeFamilyName,
            itemCount: items.length,
            viewBox: vb,
            width: w,
            height: h,
            contentBounds,
            sourcePageIndex: sourcePi
        });
        const familyIdx = layers.findIndex(l => {
            if (!l || !l.isFamilyDetectorLayer) return false;
            if (famId && Number(l.familyId) === famId) return true;
            return String(l.familyName || '').trim().toLowerCase() === safeFamilyName.toLowerCase();
        });

        if (familyIdx >= 0) {
            const existing = layers[familyIdx] || {};
            const existingBounds = existing && existing.familyContentBounds
                && Number.isFinite(Number(existing.familyContentBounds.x))
                && Number.isFinite(Number(existing.familyContentBounds.y))
                && Number.isFinite(Number(existing.familyContentBounds.w))
                && Number.isFinite(Number(existing.familyContentBounds.h))
                && Number(existing.familyContentBounds.w) > 0
                && Number(existing.familyContentBounds.h) > 0
                ? {
                    x: Number(existing.familyContentBounds.x),
                    y: Number(existing.familyContentBounds.y),
                    w: Number(existing.familyContentBounds.w),
                    h: Number(existing.familyContentBounds.h)
                }
                : null;
            const mergedContentBounds = existingBounds && contentBounds
                ? {
                    x: Math.min(existingBounds.x, contentBounds.x),
                    y: Math.min(existingBounds.y, contentBounds.y),
                    w: Math.max(existingBounds.x + existingBounds.w, contentBounds.x + contentBounds.w) - Math.min(existingBounds.x, contentBounds.x),
                    h: Math.max(existingBounds.y + existingBounds.h, contentBounds.y + contentBounds.h) - Math.min(existingBounds.y, contentBounds.y)
                }
                : (contentBounds || existingBounds || null);
            const sourceMetrics = _getFamilyDetectorSourceMetrics(existing) || { vb, w, h };
            const viewport = _computeFamilyLayerViewport(sourceMetrics.vb || vb, sourceMetrics.w || w, sourceMetrics.h || h, mergedContentBounds);
            const previewViewportVb = viewport.vb || sourceMetrics.vb || vb;
            const targetVb = sourceMetrics.vb || vb;
            const targetW = sourceMetrics.w || w;
            const targetH = sourceMetrics.h || h;

            const mergedRaw = _deduplicateFamilyItems(
                _extractSvgLayerBodyElements(existing.svgContent),
                items
            );
            const merged = _convertItemsToFamilyMarkers(mergedRaw, targetVb, familyTypeKey, familySymbolKey);
            _debugPdfSplitLog('[FamilyDetector][Layer:merge]', {
                familyId: famId,
                familyName: safeFamilyName,
                existingCount: _extractSvgLayerBodyElements(existing.svgContent).length,
                incomingCount: items.length,
                mergedCount: mergedRaw.length,
                targetViewBox: targetVb,
                markerViewBox: targetVb,
                previewViewportVb,
                targetWidth: targetW,
                targetHeight: targetH
            });
            existing.svgContent = _injectFamilyMapBadgeSvg(wrapPaths(merged, targetVb, targetW, targetH, ''), familyTypeKey, safeFamilyName, familySymbolKey);
            existing.objectCount = mergedRaw.length;
            existing.layerName = `${safeFamilyName} (${mergedRaw.length})`;
            existing.layerIcon = existing.layerIcon || existing.icon || 'fa-tag';
            existing.layerColor = existing.layerColor || existing.color || '';
            existing.svgSizeBytes = new Blob([existing.svgContent]).size;
            existing.isLayer = true;
            existing.isFamilyLayer = true;
            existing.isFamilyDetectorLayer = true;
            existing.familyId = famId;
            existing.familyName = safeFamilyName;
            existing.familyContentBounds = mergedContentBounds;
            existing.sourceSvgMetrics = {
                vb: String(targetVb || ''),
                w: String(targetW || ''),
                h: String(targetH || ''),
                defsHtml: String(defsHtml || '')
            };
            existing.sourcePageIndexes = Array.from(new Set([
                ...((Array.isArray(existing.sourcePageIndexes) ? existing.sourcePageIndexes : []).map(v => Number(v) | 0)),
                ...(sourcePi != null ? [sourcePi] : [])
            ])).filter(v => Number.isFinite(v) && v >= 0);
            if (existing.sourcePageIndexes.length === 1) existing.pageNumber = existing.sourcePageIndexes[0] + 1;
            layers[familyIdx] = existing;
            return;
        }

        const viewport = _computeFamilyLayerViewport(vb, w, h, contentBounds);
        const previewViewportVb = viewport.vb || vb;
        const targetVb = vb;
        const targetW = w;
        const targetH = h;
        const markerItems = _convertItemsToFamilyMarkers(items, targetVb, familyTypeKey, familySymbolKey);

        // Diagnostic: parse first few markers to log their actual positions
        try {
            const diagParser = new DOMParser();
            const parsedTargetVb = _parseViewBoxStr(targetVb);
            const samplePositions = markerItems.slice(0, 5).map((mkr, idx) => {
                try {
                    const d = diagParser.parseFromString(`<svg xmlns="http://www.w3.org/2000/svg">${mkr}</svg>`, 'image/svg+xml');
                    const c = d.querySelector('circle');
                    if (!c) return { idx, cx: '?', cy: '?' };
                    return { idx, cx: c.getAttribute('cx'), cy: c.getAttribute('cy') };
                } catch { return { idx, error: true }; }
            });
            _debugPdfSplitLog('[FamilyDetector][Layer:create-positions]', {
                targetVb,
                parsedTargetVb,
                markerVb: targetVb,
                previewViewportVb,
                contentBounds,
                samplePositions,
                positionCheck: parsedTargetVb && samplePositions.length > 0 ? {
                    msg: 'Marker fraction within targetVb',
                    first: samplePositions[0] && samplePositions[0].cx !== '?' ? {
                        fracX: ((parseFloat(samplePositions[0].cx) - parsedTargetVb.x) / parsedTargetVb.w).toFixed(4),
                        fracY: ((parseFloat(samplePositions[0].cy) - parsedTargetVb.y) / parsedTargetVb.h).toFixed(4)
                    } : null
                } : null
            });
        } catch { /* ignore */ }

        const svgContent = _injectFamilyMapBadgeSvg(wrapPaths(markerItems, targetVb, targetW, targetH, ''), familyTypeKey, safeFamilyName, familySymbolKey);
        _debugPdfSplitLog('[FamilyDetector][Layer:create]', {
            familyId: famId,
            familyName: safeFamilyName,
            markerCount: markerItems.length,
            viewBox: targetVb,
            width: targetW,
            height: targetH,
            markerViewBox: targetVb,
            previewViewportVb,
            contentBounds,
            sourcePageIndex: sourcePi
        });
        const familyLayer = {
            pageNumber: sourcePi != null ? (sourcePi + 1) : 1,
            isLayer: true,
            layerName: layerTitle,
            layerColor: '',
            layerIcon: 'fa-tag',
            color: '',
            svgContent,
            icon: 'fa-tag',
            objectCount: items.length,
            svgSizeBytes: new Blob([svgContent]).size,
            isFamilyLayer: true,
            isFamilyDetectorLayer: true,
            familyId: famId,
            familyName: safeFamilyName,
            familyTypeKey,
            familySymbolKey,
            familyContentBounds: contentBounds || null,
            sourceSvgMetrics: {
                vb: String(targetVb || ''),
                w: String(targetW || ''),
                h: String(targetH || ''),
                defsHtml: String(defsHtml || '')
            },
            sourcePageIndexes: sourcePi != null ? [sourcePi] : []
        };

        const fullIdx = layers.findIndex(l => l && l.layerName && String(l.layerName).includes('Full SVG (all layers)'));
        const insertAt = fullIdx >= 0 ? (fullIdx + 1) : layers.length;
        layers.splice(insertAt, 0, familyLayer);
    }

    function _appendElementsToFamilyDebugLayer(layers, extraElements, vb, w, h, defsHtml, familyId, familyName, sourcePageIndex) {
        const items = (Array.isArray(extraElements) ? extraElements : []).filter(Boolean);
        if (!items.length || !Array.isArray(layers)) return;

        const famId = Number.isFinite(Number(familyId)) && Number(familyId) > 0 ? (Number(familyId) | 0) : null;
        const safeFamilyName = String(familyName || '').trim() || (famId ? `Family #${famId}` : 'Selected family');
        const layerTitle = `🔎 ${safeFamilyName} YOLO boxes (${items.length})`;
        const sourcePi = Number.isFinite(Number(sourcePageIndex)) ? (Number(sourcePageIndex) | 0) : null;
        const existingIdx = layers.findIndex(l => {
            if (!l || !l.isFamilyDetectorDebugLayer) return false;
            if (famId && Number(l.familyId) === famId) return true;
            return String(l.familyName || '').trim().toLowerCase() === safeFamilyName.toLowerCase();
        });

        if (existingIdx >= 0) {
            const existing = layers[existingIdx] || {};
            let targetVb = vb;
            let targetW = w;
            let targetH = h;
            let targetDefs = defsHtml || '';
            try {
                const parser = new DOMParser();
                const doc = parser.parseFromString(String(existing.svgContent || ''), 'image/svg+xml');
                const svg = doc.querySelector('svg');
                if (svg) {
                    targetVb = svg.getAttribute('viewBox') || targetVb;
                    targetW = svg.getAttribute('width') || targetW;
                    targetH = svg.getAttribute('height') || targetH;
                    const defs = svg.querySelector('defs');
                    if (defs) targetDefs = defs.outerHTML;
                }
            } catch { /* ignore */ }

            const merged = [
                ..._extractSvgLayerBodyElements(existing.svgContent),
                ...items
            ];
            existing.svgContent = wrapPaths(merged, targetVb, targetW, targetH, targetDefs);
            existing.objectCount = merged.length;
            existing.layerName = `🔎 ${safeFamilyName} YOLO boxes (${merged.length})`;
            existing.layerIcon = existing.layerIcon || existing.icon || 'fa-vector-square';
            existing.layerColor = existing.layerColor || existing.color || '#f59e0b';
            existing.color = existing.color || '#f59e0b';
            existing.svgSizeBytes = new Blob([existing.svgContent]).size;
            existing.isLayer = true;
            existing.isFamilyDetectorDebugLayer = true;
            existing.familyId = famId;
            existing.familyName = safeFamilyName;
            existing.sourcePageIndexes = Array.from(new Set([
                ...((Array.isArray(existing.sourcePageIndexes) ? existing.sourcePageIndexes : []).map(v => Number(v) | 0)),
                ...(sourcePi != null ? [sourcePi] : [])
            ])).filter(v => Number.isFinite(v) && v >= 0);
            if (existing.sourcePageIndexes.length === 1) existing.pageNumber = existing.sourcePageIndexes[0] + 1;
            layers[existingIdx] = existing;
            _debugPdfSplitLog('[FamilyDetector][DebugLayer:merge]', {
                familyId: famId,
                familyName: safeFamilyName,
                mergedCount: merged.length,
                viewBox: targetVb,
                width: targetW,
                height: targetH,
                sourcePageIndex: sourcePi
            });
            return;
        }

        const svgContent = wrapPaths(items, vb, w, h, defsHtml || '');
