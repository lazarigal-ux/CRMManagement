            const chunkStart = performance.now();
            let chunkProcessed = 0;
            while (i < nodes.length && chunkProcessed < 300 && (performance.now() - chunkStart) < 10) {
                const el = nodes[i++];
                chunkProcessed++;
                if (!el) continue;
                debugInfo.totalNodes++;
                if (marked.length >= maxMarked) {
                    debugInfo.limitHit = true;
                    i = nodes.length;
                    break;
                }
                try {
                    if (el.closest && el.closest('defs')) {
                        debugInfo.skippedDefs++;
                        continue;
                    }
                } catch { /* ignore */ }

                const bb = _getSvgPreviewAiCandidateBBox(el, svg, idMap);
