        // ── DELETE FROM DB: two-step (highlight → confirm) ──
        let _dbDeletePreviewRuleSet = null;     // Set of element-line strings from DB
        let _dbDeletePreviewSignatures = null;  // parsed signatures (for map highlights)
        let _dbDeletePreviewCount = 0;          // match count in full SVG
        const _dbOrigLabel = '<i class="fa-solid fa-database"></i> Delete from DB';

        function _clearDbDeletePreview() {
            _dbDeletePreviewRuleSet = null;
            _dbDeletePreviewSignatures = null;
