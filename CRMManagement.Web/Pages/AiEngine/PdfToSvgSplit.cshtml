    let _detectionsPage = 0;
    const _detectionsPerPage = 10;

    function _getPendingDetectionApprovalCount() {
        try {
            return Object.keys(_pendingDetectionApprovalChanges || {}).length;
        } catch {
            return 0;
        }
    }

    function _setDetectionsPage(p) {
        const rows = Array.isArray(_familyScanDetections) ? _familyScanDetections : [];
        const maxPage = Math.max(0, Math.ceil(rows.length / _detectionsPerPage) - 1);
        _detectionsPage = Math.max(0, Math.min(maxPage, p | 0));
        // Re-render just the table body + pagination controls.
        const tbody = document.getElementById('detectionsTableBody');
        const pager = document.getElementById('detectionsPager');
        const info = document.getElementById('detectionsPageInfo');
        if (tbody) tbody.innerHTML = _buildDetectionRows();
        if (pager) pager.innerHTML = _buildDetectionsPager();
        if (info) info.textContent = _buildDetectionsPageInfo();
    }

    function _refreshFamilyDetectionsUi() {
        try {
            const host = document.getElementById('familyDetectionsSection');
            if (host) host.innerHTML = _getFamilyDetectionsTableHtml();
            _setDetectionsPage(_detectionsPage | 0);
        } catch { /* ignore */ }
        try { _refreshAnnotatedDetectionsOverlay(); } catch { /* ignore */ }
    }

    function _buildDetectionsPageInfo() {
        const rows = Array.isArray(_familyScanDetections) ? _familyScanDetections : [];
        const total = rows.length;
        const approved = rows.filter((r, idx) => r && _getDetectionApprovalValue(r, idx, true) === true).length;
        const rejected = rows.filter((r, idx) => r && _getDetectionApprovalValue(r, idx, true) === false).length;
        const neutral = rows.filter((r, idx) => r && _getDetectionApprovalValue(r, idx, true) == null).length;
        const pending = _getPendingDetectionApprovalCount();
        if (!total) return '0';
        const from = _detectionsPage * _detectionsPerPage + 1;
        const to = Math.min(from + _detectionsPerPage - 1, total);
        return `${from}–${to} of ${total} • correct ${approved} • incorrect ${rejected} • neutral ${neutral}` + (pending ? ` • pending ${pending}` : '');
    }

    function _getApprovedFamilyScanDetections(includePending = true) {
        const rows = Array.isArray(_familyScanDetections) ? _familyScanDetections : [];
        return rows.filter((r, idx) => r && _getDetectionApprovalValue(r, idx, includePending) === true);
    }

    function _getRejectedFamilyScanDetections(includePending = true) {
        const rows = Array.isArray(_familyScanDetections) ? _familyScanDetections : [];
        return rows.filter((r, idx) => r && _getDetectionApprovalValue(r, idx, includePending) === false);
    }

    function _getNeutralFamilyScanDetections(includePending = true) {
        const rows = Array.isArray(_familyScanDetections) ? _familyScanDetections : [];
        return rows.filter((r, idx) => r && _getDetectionApprovalValue(r, idx, includePending) == null);
    }

    function _getSelectedFamilyScanDetectionsForSvgSplit(includePending = true) {
        const rows = Array.isArray(_familyScanDetections) ? _familyScanDetections : [];
        return rows.filter((r, idx) => {
            if (!r) return false;
            if (r.isManualAdd) return true;
            return _getDetectionApprovalValue(r, idx, includePending) !== false;
        });
    }

    function _getSvgSplitSourceResultForDetection(pageIndex) {
        const pi = Number.isFinite(pageIndex) ? (pageIndex | 0) : 0;
        // IMPORTANT: never return a family detector layer — it has cropped metrics
        const isSource = r => r && r.svgContent && !r.isFamilyDetectorLayer && !r.isFamilyDetectorDebugLayer;
        const preferred = pageResults.find(r => isSource(r) && String(r.layerName || '').toLowerCase().includes('full svg') && (((Number(r.pageNumber) || 1) - 1) === pi));
        if (preferred) return preferred;
        const fallbackFull = pageResults.find(r => isSource(r) && String(r.layerName || '').toLowerCase().includes('full svg'));
        if (fallbackFull) return fallbackFull;
        const pageMatch = pageResults.find(r => isSource(r) && (((Number(r.pageNumber) || 1) - 1) === pi));
        if (pageMatch) return pageMatch;
        return pageResults.find(r => isSource(r)) || null;
    }

    function _getSvgRootMetrics(svgText) {
        try {
            const parser = new DOMParser();
            const doc = parser.parseFromString(String(svgText || ''), 'image/svg+xml');
            const svg = doc.querySelector('svg');
            if (!svg) return null;
            return {
                vb: svg.getAttribute('viewBox') || '',
                w: svg.getAttribute('width') || '',
                h: svg.getAttribute('height') || '',
                defsHtml: (() => {
                    try {
                        const defs = svg.querySelector('defs');
                        return defs ? defs.outerHTML : '';
                    } catch {
                        return '';
                    }
                })()
            };
        } catch {
            return null;
        }
    }

    function _mapDetectionRectToSvgUnits(row, metrics, cropFrac) {
        let rawX = Math.max(0, Number(row && row.x) || 0);
        let rawY = Math.max(0, Number(row && row.y) || 0);
        let rawW = Math.max(0, Number(row && row.w) || 0);
        let rawH = Math.max(0, Number(row && row.h) || 0);
        if (!(rawW > 0) || !(rawH > 0)) return null;

        // If a crop was used for detection, the coordinates are relative to the crop.
        // Convert them to full-page normalized coordinates first.
        const cf = cropFrac;
        const hasCrop = cf && Number.isFinite(cf.x) && Number.isFinite(cf.y)
            && Number.isFinite(cf.w) && Number.isFinite(cf.h) && cf.w > 0 && cf.h > 0;
        const coordSpaceRaw = String((row && (row.coordSpace ?? row.coordsSpace ?? row.normalizedTo)) || '').trim().toLowerCase();
        const isCropRelative = coordSpaceRaw === 'crop'
            || coordSpaceRaw === 'crop-relative'
            || coordSpaceRaw === 'crop_relative'
            || coordSpaceRaw === 'roi'
            || coordSpaceRaw === 'roi-relative'
            || coordSpaceRaw === 'roi_relative';
        if (hasCrop && rawX <= 1.000001 && rawY <= 1.000001 && isCropRelative) {
            const origX = rawX, origY = rawY, origW = rawW, origH = rawH;
            rawX = cf.x + (rawX * cf.w);
            rawY = cf.y + (rawY * cf.h);
            rawW = rawW * cf.w;
            rawH = rawH * cf.h;
            _debugPdfSplitLog('[FamilyDetector][MapRect:crop-adjust]', {
                cropFrac: { x: cf.x, y: cf.y, w: cf.w, h: cf.h },
                cropRelative: { x: origX, y: origY, w: origW, h: origH },
                fullPageNormalized: { x: rawX, y: rawY, w: rawW, h: rawH }
            });
        } else if (hasCrop && rawX <= 1.000001 && rawY <= 1.000001) {
            _debugPdfSplitLog('[FamilyDetector][MapRect:crop-skip]', {
                reason: 'row coordinates treated as full-page normalized',
                coordSpace: coordSpaceRaw || '(default-full-page)',
                cropFrac: { x: cf.x, y: cf.y, w: cf.w, h: cf.h },
                raw: { x: rawX, y: rawY, w: rawW, h: rawH }
            });
        }

        let view = _parseViewBoxStr(metrics && metrics.vb);
        if (!view) {
            const mw = parseFloat(String(metrics && metrics.w || '0'));
            const mh = parseFloat(String(metrics && metrics.h || '0'));
            if (Number.isFinite(mw) && Number.isFinite(mh) && mw > 0 && mh > 0) {
                view = { x: 0, y: 0, w: mw, h: mh };
            }
        }

        const looksNormalized = rawX <= 1.000001 && rawY <= 1.000001 && rawW <= 1.000001 && rawH <= 1.000001;
        if (view && looksNormalized && !isCropRelative) {
            const detW = Math.max(0, Number(row && (row.pageRawWidth || row.rawWidth || row.pagePixelWidth || row.pixelWidth)) || 0);
            const detH = Math.max(0, Number(row && (row.pageRawHeight || row.rawHeight || row.pagePixelHeight || row.pixelHeight)) || 0);
            if (detW > 0 && detH > 0 && view.w > 0 && view.h > 0) {
                const scale = Math.min(detW / view.w, detH / view.h);
                const fitW = view.w * scale;
                const fitH = view.h * scale;
                const offX = (detW - fitW) * 0.5;
                const offY = (detH - fitH) * 0.5;
                if ((offX > 0.5 || offY > 0.5) && fitW > 0 && fitH > 0) {
                    const xPx1 = (rawX * detW);
                    const yPx1 = (rawY * detH);
                    const xPx2 = ((rawX + rawW) * detW);
                    const yPx2 = ((rawY + rawH) * detH);

                    const nx1 = (xPx1 - offX) / fitW;
                    const ny1 = (yPx1 - offY) / fitH;
                    const nx2 = (xPx2 - offX) / fitW;
                    const ny2 = (yPx2 - offY) / fitH;

                    const clampedX1 = Math.max(0, Math.min(1, nx1));
                    const clampedY1 = Math.max(0, Math.min(1, ny1));
                    const clampedX2 = Math.max(clampedX1, Math.max(0, Math.min(1, nx2)));
                    const clampedY2 = Math.max(clampedY1, Math.max(0, Math.min(1, ny2)));
                    const adjW = clampedX2 - clampedX1;
                    const adjH = clampedY2 - clampedY1;
                    if (adjW > 0 && adjH > 0) {
                        _debugPdfSplitLog('[FamilyDetector][MapRect:unletterbox]', {
                            coordSpace: coordSpaceRaw || '(default-full-page)',
                            detSize: { w: detW, h: detH },
                            viewSize: { w: view.w, h: view.h },
                            fit: { w: fitW, h: fitH, offX, offY, scale },
                            before: { x: rawX, y: rawY, w: rawW, h: rawH },
                            after: { x: clampedX1, y: clampedY1, w: adjW, h: adjH }
                        });
                        rawX = clampedX1;
                        rawY = clampedY1;
                        rawW = adjW;
                        rawH = adjH;
                    }
                }
            }
        }
        if (view && looksNormalized) {
            const mapped = {
                x: view.x + (rawX * view.w),
                y: view.y + (rawY * view.h),
                w: rawW * view.w,
                h: rawH * view.h
            };
            _debugPdfSplitLog('[FamilyDetector][MapRect:normalized]', {
                raw: { x: rawX, y: rawY, w: rawW, h: rawH },
                view,
                mapped,
                hasCrop
            });
            return mapped;
        }

        const mapped = { x: rawX, y: rawY, w: rawW, h: rawH };
        _debugPdfSplitLog('[FamilyDetector][MapRect:absolute]', { mapped, view });
        return mapped;
    }

    function _expandDetectionFracForSvgSplit(frac, padFrac) {
        const p = Number.isFinite(padFrac) ? Math.max(0, padFrac) : 0.004;
        const x1 = _clamp01(((frac && frac.x) || 0) - p);
        const y1 = _clamp01(((frac && frac.y) || 0) - p);
        const x2 = _clamp01(((frac && frac.x) || 0) + ((frac && frac.w) || 0) + p);
        const y2 = _clamp01(((frac && frac.y) || 0) + ((frac && frac.h) || 0) + p);
        return {
            x: x1,
            y: y1,
            w: Math.max(0, x2 - x1),
            h: Math.max(0, y2 - y1)
        };
    }

    function _buildYoloTrainingPayload() {
        const rows = Array.isArray(_familyScanDetections) ? _familyScanDetections : [];
        return {
            detections: rows.flatMap((r, idx) => {
                const approval = _getDetectionApprovalValue(r, idx, true);
                if (!r || approval == null) return [];
                return [{
                    pageIndex: r.pageIndex,
                    x: r.x,
                    y: r.y,
                    w: r.w,
                    h: r.h,
                    sampleId: r.sampleId || 0,
                    symbolHref: r.detectTemplateSymbolHref || r.symbolHref || '',
                    approved: approval === true
                }];
            })
        };
    }

    function _getFamilyYoloDatasetSummary() {
        const approvedDetections = _getApprovedFamilyScanDetections(true);
        const rejectedDetections = _getRejectedFamilyScanDetections(true);
        const neutralDetections = _getNeutralFamilyScanDetections(true);
        return {
            approvedDetectionCount: approvedDetections.length,
            rejectedDetectionCount: rejectedDetections.length,
            neutralDetectionCount: neutralDetections.length,
            totalSourceCount: approvedDetections.length + rejectedDetections.length
        };
    }

    function _getFamilyYoloTrainingReadiness() {
        const datasetSummary = _getFamilyYoloDatasetSummary();
        const model = _lastFamilyLearnModel || {};
        const memoryPositiveCount = (model && isFinite(model.yoloMemoryPositiveCount)) ? Math.max(0, Number(model.yoloMemoryPositiveCount) | 0) : 0;
        const memoryNegativeCount = (model && isFinite(model.yoloMemoryNegativeCount)) ? Math.max(0, Number(model.yoloMemoryNegativeCount) | 0) : 0;
        const hasCurrentDetections = datasetSummary.totalSourceCount > 0;
        const hasPersistedPositives = memoryPositiveCount > 0;
        return {
            datasetSummary,
            memoryPositiveCount,
            memoryNegativeCount,
            hasCurrentDetections,
            hasPersistedPositives,
            canTrain: hasCurrentDetections || hasPersistedPositives
        };
    }

    function _parseDetectionApprovalInput(value) {
        if (value === true || value === 'true' || value === 'approved' || value === 'correct') return true;
        if (value === false || value === 'false' || value === 'rejected' || value === 'incorrect') return false;
        return null;
    }

    function setDetectionApprovalState(idx, stateValue) {
        const i = parseInt(String(idx != null ? idx : ''), 10);
        if (!Number.isFinite(i) || i < 0) return;
        const rows = Array.isArray(_familyScanDetections) ? _familyScanDetections : [];
        if (i >= rows.length || !rows[i]) return;
        const nextValue = _parseDetectionApprovalInput(stateValue);
        const committed = _getDetectionApprovalValue(rows[i], i, false);
        if (committed === nextValue) delete _pendingDetectionApprovalChanges[String(i)];
        else _pendingDetectionApprovalChanges[String(i)] = nextValue;
        _refreshFamilyDetectionsUi();
    }

    function toggleDetectionApproval(idx, approved) {
        setDetectionApprovalState(idx, approved ? true : null);
    }

    function setAllDetectionApprovals(stateValue) {
        const rows = Array.isArray(_familyScanDetections) ? _familyScanDetections : [];
        const nextValue = _parseDetectionApprovalInput(stateValue);
        for (let i = 0; i < rows.length; i++) {
            const r = rows[i];
            if (!r) continue;
            const committed = _getDetectionApprovalValue(r, i, false);
            if (committed === nextValue) delete _pendingDetectionApprovalChanges[String(i)];
            else _pendingDetectionApprovalChanges[String(i)] = nextValue;
        }
        _refreshFamilyDetectionsUi();
    }

    function discardPendingDetectionApprovals() {
        _pendingDetectionApprovalChanges = {};
        _refreshFamilyDetectionsUi();
    }

    function applyPendingDetectionApprovals() {
        const rows = Array.isArray(_familyScanDetections) ? _familyScanDetections : [];
        const pending = _pendingDetectionApprovalChanges || {};
        for (const [k, v] of Object.entries(pending)) {
            const i = parseInt(k, 10);
            if (!Number.isFinite(i) || i < 0 || i >= rows.length || !rows[i]) continue;
            if (v === true) rows[i].approved = true;
            else if (v === false) rows[i].approved = false;
            else delete rows[i].approved;
        }
        _pendingDetectionApprovalChanges = {};
        _refreshFamilyDetectionsUi();
    }

    async function exportApprovedDetectionsYolo() {
        const famId = _getSelectedFamilyId();
        if (!famId) { cgAlert('Pick a family first.'); return; }
        const file = (pdfFileInput && pdfFileInput.files && pdfFileInput.files.length) ? pdfFileInput.files[0] : null;
        if (!file) { cgAlert('Pick a PDF first.'); return; }
        const approvedRows = _getApprovedFamilyScanDetections();
        const rejectedRows = _getRejectedFamilyScanDetections();
        const datasetSummary = _getFamilyYoloDatasetSummary();
        if (!datasetSummary.totalSourceCount) { cgAlert('No green/yellow detection changes to export. Leave unchanged detections in Neutral.'); return; }

        try {
            _yoloExportBusy = true;
            if (_lastFamilyLearnModel) _renderFamilyLearnPanel(_lastFamilyLearnModel);
            const famName = _getSelectedFamilyName();
            const payload = _buildYoloTrainingPayload();

            const fd = new FormData();
            fd.append('pdf', file, file.name || 'document.pdf');
            fd.append('detectionsJson', JSON.stringify(payload));
            fd.append('familyName', famName);
            fd.append('dpi', String(getSelectedProcessingDpi()));
            _appendLocateCropToFormData(fd, { includeCrop: true });

            _appendFamilyScanLog(`Export YOLO dataset: ${approvedRows.length} green addition(s), ${rejectedRows.length} yellow cancellation(s)`);
            const resp = await fetch(`${OBJECT_FAMILIES_ENDPOINT}/${famId}/export-yolo`, {
                method: 'POST',
                headers: { 'X-Client-Id': 'admin' },
                body: fd
            });
            if (!resp.ok) {
                const t = await resp.text();
                throw new Error(`HTTP ${resp.status}: ${t.substring(0, 500)}`);
            }

            const blob = await resp.blob();
            const cd = resp.headers.get('content-disposition') || '';
            let name = 'yolo-dataset.zip';
            const m = /filename\*=UTF-8''([^;]+)|filename="?([^";]+)"?/i.exec(cd);
            if (m) name = decodeURIComponent(m[1] || m[2] || name);
            const url = URL.createObjectURL(blob);
            const a = document.createElement('a');
            a.href = url;
            a.download = name;
            document.body.appendChild(a);
            a.click();
            a.remove();
            setTimeout(() => URL.revokeObjectURL(url), 1500);
            _appendFamilyScanLog(`YOLO export ready: ${name}`);
        } catch (e) {
            _appendFamilyScanLog(`YOLO export failed: ${String(e)}`);
            cgAlert(`YOLO export failed: ${String(e)}`);
        } finally {
            _yoloExportBusy = false;
            if (_lastFamilyLearnModel) _renderFamilyLearnPanel(_lastFamilyLearnModel);
        }
    }

    async function addSelectedDetectionsToSvgSplit() {
        const selectedRows = _getSelectedFamilyScanDetectionsForSvgSplit(true);
        const famId = _getSelectedFamilyId();
        const famName = _getSelectedFamilyName() || (famId ? `Family #${famId}` : 'Selected family');
        if (!selectedRows.length) {
            cgAlert('Mark detections green/red first, or add manual detections, before saving to SVG Split.');
            return;
        }
        if (!Array.isArray(pageResults) || !pageResults.some(r => r && r.svgContent)) {
            cgAlert(`Run SVG Split first so there is an SVG result to add into the ${famName} family tab.`);
            return;
        }

        try {
            const grouped = new Map();
            for (const row of selectedRows) {
                const pi = Number.isFinite(row && row.pageIndex) ? (row.pageIndex | 0) : 0;
                if (!grouped.has(pi)) grouped.set(pi, []);
                grouped.get(pi).push(row);
            }

            let savedDetections = 0;
            let savedSvgObjects = 0;
            let skippedDetections = 0;

            for (const [pageIndex, rows] of grouped.entries()) {
                _debugPdfSplitLog('[FamilyDetector][Save:start-page]', {
                    familyId: famId,
                    familyName: famName,
                    pageIndex,
                    rowCount: rows.length
                });
                const src = _getSvgSplitSourceResultForDetection(pageIndex);
                if (!src || !src.svgContent) {
                    skippedDetections += rows.length;
                    _debugPdfSplitLog('[FamilyDetector][Save:skip-page-no-src]', { pageIndex, skipped: rows.length });
                    continue;
                }
                // Resolve the crop fraction that was used for detection
                const _locateCropFrac = (outputCrop && outputCrop.frac && typeof outputCrop.frac === 'object'
                    && Number.isFinite(outputCrop.frac.x) && Number.isFinite(outputCrop.frac.y)
                    && Number.isFinite(outputCrop.frac.w) && Number.isFinite(outputCrop.frac.h)
                    && outputCrop.frac.w > 0.0005 && outputCrop.frac.h > 0.0005)
                    ? { x: outputCrop.frac.x, y: outputCrop.frac.y, w: outputCrop.frac.w, h: outputCrop.frac.h }
                    : null;
                _debugPdfSplitLog('[FamilyDetector][Save:src-info]', {
                    pageIndex,
                    srcLayerName: src.layerName || '(unnamed)',
                    srcIsFamilyLayer: !!src.isFamilyDetectorLayer,
                    srcHasSourceSvgMetrics: !!(src.sourceSvgMetrics && typeof src.sourceSvgMetrics === 'object'),
                    srcSourceSvgMetricsVb: src.sourceSvgMetrics ? String(src.sourceSvgMetrics.vb || '') : '(none)',
                    srcSvgViewBox: (() => { try { return _getSvgRootMetrics(src.svgContent)?.vb || '(none)'; } catch { return '(error)'; } })(),
                    cropFrac: _locateCropFrac
                });
                const metrics = _resolveFamilyDetectorMapMetrics(src, _locateCropFrac);
                if (!metrics) {
                    skippedDetections += rows.length;
                    _debugPdfSplitLog('[FamilyDetector][Save:skip-page-no-metrics]', { pageIndex, skipped: rows.length });
                    continue;
                }

                // Diagnostic log: viewBox and sample detection mapping
                try {
                    const sampleRow = rows[0];
                    const sampleRect = _mapDetectionRectToSvgUnits(sampleRow, metrics, _locateCropFrac);
                    _debugPdfSplitLog('[FamilyDetector] Source viewBox:', metrics.vb, 'w:', metrics.w, 'h:', metrics.h,
                        '| Sample detection normalized:', { x: sampleRow.x, y: sampleRow.y, w: sampleRow.w, h: sampleRow.h },
                        '→ SVG mapped:', sampleRect,
                        '| Detections:', rows.length, 'pageIndex:', pageIndex);
                } catch { /* ignore */ }

                const extraElements = [];
                const debugElements = [];
                let bounds = null;
                for (let rowIndex = 0; rowIndex < rows.length; rowIndex++) {
                    const row = rows[rowIndex];
                    const rect = _mapDetectionRectToSvgUnits(row, metrics, _locateCropFrac);
                    const x = Math.max(0, Number(rect && rect.x) || 0);
                    const y = Math.max(0, Number(rect && rect.y) || 0);
                    const w = Math.max(0, Number(rect && rect.w) || 0);
                    const h = Math.max(0, Number(rect && rect.h) || 0);
                    const thumb = (row && row.thumbDataUrl) ? String(row.thumbDataUrl).trim() : '';
                    if (!(w > 0) || !(h > 0) || !thumb) {
                        skippedDetections++;
                        _debugPdfSplitLog('[FamilyDetector][Save:skip-row]', {
                            pageIndex,
                            rowIndex,
                            rect,
                            hasThumb: !!thumb
                        });
                        continue;
                    }

                    const trimmedThumb = await _trimDetectionThumbDataUrl(thumb, { pad: 4, threshold: 248, step: 2 });
                    const centerThumb = trimmedThumb || thumb;
                    const centerFracX = 0.5;
                    const centerFracY = 0.5;
                    const centerX = x + (w * centerFracX);
                    const centerY = y + (h * centerFracY);
                    _debugPdfSplitLog('[FamilyDetector][Save:row]', {
                        pageIndex,
                        rowIndex,
                        rawRow: {
                            x: row && row.x,
                            y: row && row.y,
                            w: row && row.w,
                            h: row && row.h,
                            approved: row ? _getDetectionApprovalValue(row, -1, true) : null,
                            isManualAdd: !!(row && row.isManualAdd)
                        },
                        mappedRect: { x, y, w, h },
                        thumbLength: thumb.length,
                        trimmedThumbLength: (trimmedThumb || '').length,
                        centerThumbLength: centerThumb.length,
                        anchorSource: 'table-bbox-center',
                        centerFrac: { x: centerFracX, y: centerFracY },
                        centerAbs: { x: centerX, y: centerY }
                    });
                    const escapedHref = escapeXml(trimmedThumb || thumb);
                    const detectorLabel = row && row.isManualAdd
                        ? 'manual-detector'
                        : (_getDetectionApprovalValue(row, -1, true) === false ? 'detector-rejected' : 'detector-approved');
                    extraElements.push(
                        `<g data-detector-choice="${detectorLabel}" data-page-index="${pageIndex}">` +
                        `<image href="${escapedHref}" x="${x.toFixed(6)}" y="${y.toFixed(6)}" width="${w.toFixed(6)}" height="${h.toFixed(6)}" data-center-x="${centerX.toFixed(6)}" data-center-y="${centerY.toFixed(6)}" preserveAspectRatio="xMidYMid meet" />` +
                        `</g>`
                    );
                    if (!bounds) {
                        bounds = { x, y, w, h };
                    } else {
                        const minX = Math.min(bounds.x, x);
                        const minY = Math.min(bounds.y, y);
                        const maxX = Math.max(bounds.x + bounds.w, x + w);
                        const maxY = Math.max(bounds.y + bounds.h, y + h);
                        bounds = { x: minX, y: minY, w: maxX - minX, h: maxY - minY };
                    }
                    savedDetections++;
                    savedSvgObjects += 1;
                }

                if (extraElements.length) {
                    _purgeFamilyDebugLayers(pageResults);
                    _debugPdfSplitLog('[FamilyDetector][Save:append-layer]', {
                        pageIndex,
                        familyId: famId,
                        familyName: famName,
                        extraElements: extraElements.length,
                        bounds,
                        metrics: { vb: metrics.vb, w: metrics.w, h: metrics.h }
                    });
                    _appendElementsToFamilyLayer(pageResults, extraElements, metrics.vb, metrics.w, metrics.h, metrics.defsHtml, famId, famName, bounds, pageIndex);
                }
            }

            _debugPdfSplitLog('[FamilyDetector][Save:done]', {
                familyId: famId,
                familyName: famName,
                savedDetections,
                savedSvgObjects,
                skippedDetections
            });

            if (!savedDetections) {
                cgAlert('No SVG objects could be extracted from the selected detections.');
                return;
            }

            try { recomputeFullLayerFromSum(pageResults); } catch { /* ignore */ }
            try { _rerenderAllResultCards(); } catch { /* ignore */ }
            try { resultsSection.classList.remove('hidden'); } catch { /* ignore */ }
            try { setSplitMainTab('svgSplit'); } catch { /* ignore */ }

            // Auto-select base + family + debug layers for Combined Layout
            try {
                for (let li = 0; li < pageResults.length; li++) {
                    const lr = pageResults[li];
                    if (!lr) continue;
                    const isBase = lr.layerName && String(lr.layerName).includes('Full SVG (all layers)');
                    const isFam = lr.isFamilyDetectorLayer && ((famId && Number(lr.familyId) === famId) || String(lr.familyName || '').trim().toLowerCase() === famName.toLowerCase());
                    if (isBase || isFam) _setLayoutPreviewSelected(li, true);
                }
            } catch { /* ignore */ }
            try { if (resultsSummary) resultsSummary.textContent = `${pageResults.length} layer(s) available • detector selections added to family tab ${famName}`; } catch { /* ignore */ }
            try { _appendFamilyScanLog(`Saved ${savedDetections} detector selection(s) into SVG Split / ${famName} as ${savedSvgObjects} SVG object(s)${skippedDetections ? ` • skipped ${skippedDetections}` : ''}`); } catch { /* ignore */ }
            cgAlert(`Saved ${savedDetections} detector selection(s) into the ${famName} family tab as SVG.${skippedDetections ? ` Skipped: ${skippedDetections}.` : ''}`);
        } catch (e) {
            cgAlert(`Saving detector selections to SVG Split failed: ${String(e)}`);
        }
    }

    function _buildDetectionsPager() {
        const rows = Array.isArray(_familyScanDetections) ? _familyScanDetections : [];
        const totalPages = Math.ceil(rows.length / _detectionsPerPage);
        if (totalPages <= 1) return '';

        const btnCls = 'px-2 py-1 text-[11px] rounded border';
        const activeCls = 'text-sky-200 border-sky-500/50 bg-sky-900/30';
        const inactiveCls = 'text-slate-400 border-slate-600/40 hover:text-white hover:bg-slate-800/40 cursor-pointer';
        const disabledCls = 'text-slate-600 border-slate-700/30 cursor-default opacity-40';

        let html = '';
        // Prev
        html += _detectionsPage > 0
            ? `<button type="button" class="${btnCls} ${inactiveCls}" onclick="setDetectionsPage(${_detectionsPage - 1})"><i class="fa-solid fa-chevron-left"></i></button>`
            : `<span class="${btnCls} ${disabledCls}"><i class="fa-solid fa-chevron-left"></i></span>`;

        // Page numbers (show max 7 around current)
        const maxShow = 7;
        let start = Math.max(0, _detectionsPage - Math.floor(maxShow / 2));
        let end = Math.min(totalPages, start + maxShow);
        if (end - start < maxShow) start = Math.max(0, end - maxShow);

        if (start > 0) html += `<button type="button" class="${btnCls} ${inactiveCls}" onclick="setDetectionsPage(0)">1</button><span class="text-slate-500 text-[10px] px-1">…</span>`;
        for (let i = start; i < end; i++) {
            html += i === _detectionsPage
                ? `<span class="${btnCls} ${activeCls} font-semibold">${i + 1}</span>`
                : `<button type="button" class="${btnCls} ${inactiveCls}" onclick="setDetectionsPage(${i})">${i + 1}</button>`;
        }
        if (end < totalPages) html += `<span class="text-slate-500 text-[10px] px-1">…</span><button type="button" class="${btnCls} ${inactiveCls}" onclick="setDetectionsPage(${totalPages - 1})">${totalPages}</button>`;

        // Next
        html += _detectionsPage < totalPages - 1
            ? `<button type="button" class="${btnCls} ${inactiveCls}" onclick="setDetectionsPage(${_detectionsPage + 1})"><i class="fa-solid fa-chevron-right"></i></button>`
            : `<span class="${btnCls} ${disabledCls}"><i class="fa-solid fa-chevron-right"></i></span>`;

        return html;
    }

    function _hasAnyDetectionTemplateData() {
        const rows = Array.isArray(_familyScanDetections) ? _familyScanDetections : [];
        return rows.some(r => {
            const tplSid = (r && isFinite(r.detectTemplateSampleId)) ? (r.detectTemplateSampleId | 0) : 0;
            const tplHref = (r && r.detectTemplateSymbolHref != null) ? String(r.detectTemplateSymbolHref).trim() : '';
            return tplSid > 0 || tplHref.length > 0;
        });
    }
    function _hasAnyDetectionSampleIdData() {
        const rows = Array.isArray(_familyScanDetections) ? _familyScanDetections : [];
        return rows.some(r => {
            const samp = (r && r.sampleIds && Array.isArray(r.sampleIds)) ? r.sampleIds.join(',') : ((r && isFinite(r.sampleId)) ? String(r.sampleId | 0) : '');
            return samp.length > 0;
        });
    }

    function _buildDetectionRows() {
        const rows = Array.isArray(_familyScanDetections) ? _familyScanDetections : [];
        const from = _detectionsPage * _detectionsPerPage;
        const to = Math.min(from + _detectionsPerPage, rows.length);
        const slice = rows.slice(from, to);
        const showTpl = _hasAnyDetectionTemplateData();
        const showSid = _hasAnyDetectionSampleIdData();

        return slice.map((r, localIdx) => {
            const idx = from + localIdx;
            const num = idx + 1;
            const img = r && r.thumbDataUrl ? String(r.thumbDataUrl) : '';
            const page = (r && isFinite(r.pageIndex)) ? ((r.pageIndex | 0) + 1) : 0;
            const x = (r && isFinite(r.x)) ? r.x : 0;
            const y = (r && isFinite(r.y)) ? r.y : 0;
            const w = (r && isFinite(r.w)) ? r.w : 0;
            const h = (r && isFinite(r.h)) ? r.h : 0;
            const conf = (r && isFinite(r.confidence)) ? Math.max(0, Math.min(1, r.confidence)) : 0;
            const confPct = Math.round(conf * 100);
            const samp = (r && r.sampleIds && Array.isArray(r.sampleIds)) ? r.sampleIds.join(',') : ((r && isFinite(r.sampleId)) ? String(r.sampleId | 0) : '');
            const memoryInfo = _getDetectionMemoryLinkInfo(r);

            const tplSid = (r && isFinite(r.detectTemplateSampleId)) ? (r.detectTemplateSampleId | 0) : 0;
            const tplHref = (r && r.detectTemplateSymbolHref != null) ? String(r.detectTemplateSymbolHref).trim() : '';
            const tplTxt = tplSid > 0
                ? (`#${tplSid}` + (tplHref ? (' ' + tplHref) : ''))
                : (tplHref || '');
            const visualState = _getDetectionVisualState(r, idx, true);
            const thumbBorder = (visualState === 'manual' || visualState === 'approved')
                ? 'border-emerald-500/70'
                : (visualState === 'rejected' ? 'border-yellow-400/70' : 'border-slate-700/40');
            const rowTone = (visualState === 'manual' || visualState === 'approved')
                ? 'bg-emerald-950/20'
                : (visualState === 'rejected' ? 'bg-yellow-950/10' : 'bg-rose-950/10');
            const detectedBadge = escapeHtml(_getDetectionSourceLabel(r));
            const statusBadge = visualState === 'manual'
                ? '<span class="inline-flex items-center rounded border border-emerald-500/50 bg-emerald-900/20 px-1.5 py-0.5 text-[10px] font-semibold text-emerald-200">Manual</span>'
                : (visualState === 'approved'
                    ? '<span class="inline-flex items-center rounded border border-emerald-500/50 bg-emerald-900/20 px-1.5 py-0.5 text-[10px] font-semibold text-emerald-200">Green add</span>'
                : (visualState === 'rejected'
                    ? '<span class="inline-flex items-center rounded border border-yellow-500/50 bg-yellow-900/20 px-1.5 py-0.5 text-[10px] font-semibold text-yellow-200">Yellow cancel</span>'
                    : `<span class="inline-flex items-center rounded border border-rose-500/40 bg-rose-900/20 px-1.5 py-0.5 text-[10px] font-semibold text-rose-200">Neutral</span>`));

            const pos = `p${page} • x=${x.toFixed(3)} y=${y.toFixed(3)} w=${w.toFixed(3)} h=${h.toFixed(3)}`;
            const thumbInner = img
                ? `<img src="${img}" class="w-16 h-16 rounded-lg border ${thumbBorder} bg-white object-contain" alt="Detection preview" loading="lazy" />`
                : `<div class="w-16 h-16 rounded-lg border ${thumbBorder} bg-slate-900/20"></div>`;
            const thumbHtml = img
                ? `<button type="button" class="rounded-lg focus:outline-none focus:ring-2 focus:ring-sky-400/30" title="Open preview" onclick="openFamilyDetectionPreview(${idx})">${thumbInner}</button>`
                : thumbInner;

            const confColor = confPct >= 80 ? 'text-emerald-300' : (confPct >= 60 ? 'text-yellow-300' : 'text-rose-300');
            const approvalValue = _getDetectionApprovalValue(r, idx, true);
            const neutralButtonClass = approvalValue == null
                ? 'border-rose-400 bg-rose-600/25 text-rose-100 shadow-[0_0_0_1px_rgba(251,113,133,0.25)]'
                : 'border-rose-500/30 bg-slate-900/40 text-rose-300 hover:bg-rose-950/20';
            const correctButtonClass = approvalValue === true
                ? 'border-emerald-300 bg-emerald-600/25 text-emerald-50 shadow-[0_0_0_1px_rgba(52,211,153,0.25)]'
                : 'border-emerald-500/30 bg-slate-900/40 text-emerald-300 hover:bg-emerald-950/20';
            const incorrectButtonClass = approvalValue === false
                ? 'border-yellow-300 bg-yellow-500/25 text-yellow-50 shadow-[0_0_0_1px_rgba(253,224,71,0.22)]'
                : 'border-yellow-500/30 bg-slate-900/40 text-yellow-300 hover:bg-yellow-950/20';

            return `<tr class="border-t border-slate-800 ${rowTone}">
                        <td class="px-2 py-2 text-center">
                            <div class="inline-flex min-w-[116px] flex-col gap-1 text-[10px] font-semibold">
                                <button type="button" class="rounded-md border px-2 py-1 transition-colors ${neutralButtonClass}" onclick="setDetectionApprovalState(${idx}, 'neutral')">Neutral</button>
                                <button type="button" class="rounded-md border px-2 py-1 transition-colors ${correctButtonClass}" onclick="setDetectionApprovalState(${idx}, 'approved')">Correct</button>
                                <button type="button" class="rounded-md border px-2 py-1 transition-colors ${incorrectButtonClass}" onclick="setDetectionApprovalState(${idx}, 'rejected')">Incorrect</button>
                            </div>
                        </td>
                        <td class="px-2 py-2 text-center text-xs text-slate-500 font-semibold">${num}</td>
                        <td class="px-2 py-2">${thumbHtml}</td>
                        <td class="px-2 py-2 text-[11px] text-slate-200 font-mono"><div>${escapeHtml(pos)}</div><div class="mt-1">${statusBadge}</div></td>
                        <td class="px-2 py-2 text-xs ${confColor} text-center font-semibold">${confPct}%</td>
                        <td class="px-2 py-2 text-[11px] font-mono ${memoryInfo ? 'text-sky-300' : 'text-slate-500'}" title="${escapeHtml(memoryInfo ? memoryInfo.title : 'No linked YOLO memory match')}">${memoryInfo ? escapeHtml(memoryInfo.label + (memoryInfo.trainingRunNumber > 0 ? ` • T${memoryInfo.trainingRunNumber}` : '')) : '—'}</td>
                        ${showTpl ? `<td class="px-2 py-2 text-[11px] text-slate-300 font-mono">${escapeHtml(tplTxt)}</td>` : ''}
                        ${showSid ? `<td class="px-2 py-2 text-[11px] text-slate-300 font-mono">${escapeHtml(samp)}</td>` : ''}
                    </tr>`;
        }).join('');
    }

