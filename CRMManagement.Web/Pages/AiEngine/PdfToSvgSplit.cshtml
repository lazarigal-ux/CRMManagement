    /* Use SVG-native stroke for highlight (CSS outline does NOT render on SVG children) */
    .merged-svg-el-highlight {
        stroke: #3b82f6 !important;
        stroke-width: 3px !important;
        stroke-opacity: 1 !important;
        filter: drop-shadow(0 0 4px rgba(59,130,246,.8)) drop-shadow(0 0 2px rgba(59,130,246,1));
        transition: filter .15s;
    }
    .merged-svg-el-cluster-highlight {
        stroke: #3b82f6 !important;
