                <div id="familyScanLogSection">${_getFamilyScanLogHtml() || '<div class="mt-2 rounded-xl border border-slate-700/40 bg-slate-950/40 px-3 py-3 text-xs text-slate-500">No scan log yet.</div>'}</div>
                <div id="familyAnnotatedTabSection">
                    <div id="annotatedPagesSection">${_getAnnotatedPagesHtml()}</div>
                    <div id="familyDetectionsSection">${_getFamilyDetectionsTableHtml()}</div>
                </div>
            </div>`;

        const itemsHtml = objects.length
            ? `<div class="px-3 pb-3">
