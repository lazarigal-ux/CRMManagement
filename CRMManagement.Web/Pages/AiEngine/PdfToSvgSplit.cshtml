            const resp = await fetch(SVG_AI_TEXT_ONLY_ENDPOINT, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'X-AI-Trace-Id': requestTraceId
                },
                body: JSON.stringify(payload)
            });

            let raw = await resp.text();
            let finalResp = resp;
            if (!finalResp.ok && [404, 500, 502, 503, 504].includes(Number(finalResp.status || 0))) {
                try {
                    console.warn(`[AI ACTION REQUEST ${requestTraceId}] first attempt failed`, {
                        status: finalResp.status,
                        endpoint: SVG_AI_TEXT_ONLY_ENDPOINT,
                        bodyPreview: raw ? String(raw).slice(0, 1200) : ''
                    });
                } catch { /* ignore */ }

                await new Promise(resolve => setTimeout(resolve, 900));
                finalResp = await fetch(SVG_AI_TEXT_ONLY_ENDPOINT, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'X-AI-Trace-Id': `${requestTraceId}-retry1`
                    },
                    body: JSON.stringify(payload)
                });
                raw = await finalResp.text();

                try {
                    console.warn(`[AI ACTION REQUEST ${requestTraceId}] retry result`, {
                        status: finalResp.status,
                        endpoint: SVG_AI_TEXT_ONLY_ENDPOINT,
                        bodyPreview: raw ? String(raw).slice(0, 1200) : ''
                    });
                } catch { /* ignore */ }
            }

            let obj = null;
            try { obj = raw ? JSON.parse(raw) : null; } catch { obj = null; }

            try {
                console.groupCollapsed(`[AI ACTION RESPONSE ${requestTraceId}]`);
                console.log('status', finalResp.status);
                console.log('traceId', (obj && obj.traceId) ? obj.traceId : (finalResp.headers ? finalResp.headers.get('X-AI-Trace-Id') : null));
                console.log('headers', {
                    contentType: finalResp.headers ? finalResp.headers.get('content-type') : null,
                    traceId: finalResp.headers ? finalResp.headers.get('X-AI-Trace-Id') : null
                });
                console.log('rawBody', raw);
                console.log('parsedBody', obj);
                if (obj && obj.diagnostics) console.log('diagnostics', obj.diagnostics);
                console.groupEnd();
            } catch { /* ignore */ }

            if (!finalResp.ok) {
                const msg = (obj && (obj.detail || obj.error || obj.title))
                    ? String(obj.detail || obj.error || obj.title)
                    : (raw || `HTTP ${finalResp.status}`);
                throw new Error(msg);
            }

            const aiSvg = (obj && obj.svgContent) ? String(obj.svgContent) : '';
            if (!aiSvg || !aiSvg.includes('<svg')) throw new Error('AI did not return a valid SVG document.');

            let finalSvg = aiSvg;
            let finalProvider = obj && obj.provider ? String(obj.provider) : payload.provider;
            let finalModel = (obj && obj.model) ? String(obj.model) : (payload.model || '');
            let finalDiagnostics = obj && obj.diagnostics ? obj.diagnostics : null;
            let finalWarning = '';

            if (payload.action === 'remove-small') {
                const aiGuardrails = evaluateCleanupGuardrails(String(r.svgContent || ''), aiSvg, {
                    cropViewBox: payload.cropViewBox,
                    aggressiveRemoveThreshold: 0.70
                });
                try {
                    console.groupCollapsed(`[AI ACTION GUARDRAILS ${requestTraceId}]`);
                    console.log('guardrails', aiGuardrails);
                    console.groupEnd();
                } catch { /* ignore */ }

                if (aiGuardrails.tooAggressive) {
                    const cleanupDoc = new DOMParser().parseFromString(String(r.svgContent || ''), 'image/svg+xml');
                    const cleanupSvgRoot = cleanupDoc.querySelector('svg');
                    if (!cleanupSvgRoot) throw new Error('Failed to parse SVG for conservative fallback cleanup.');
                    const cleanupResult = applyConservativeCleanup(cleanupSvgRoot, {
                        cropViewBox: payload.cropViewBox,
                        debugMode: !!_svgAiCandidateDebugEnabled,
                        enableUnsureBucket: true,
                        deleteSmallWhiteFills: true,
                        detectHatches: true,
                        keepStructuralStrokes: true
                    });
                    finalSvg = new XMLSerializer().serializeToString(cleanupSvgRoot);
                    finalProvider = 'ai+local-fallback';
                    finalModel = `fallback:${finalModel || 'ai'}`;
                    finalWarning = `AI remove-small was too aggressive; used local conservative fallback. ${aiGuardrails.warnings.join(' | ')}`;
                    finalDiagnostics = {
                        ai: obj && obj.diagnostics ? obj.diagnostics : null,
                        aiGuardrails,
                        localFallback: cleanupResult.diagnostics
                    };
                    try {
                        console.warn(`[AI ACTION GUARDRAILS ${requestTraceId}] AI result rejected, local fallback applied`, {
                            aiGuardrails,
                            localFallback: cleanupResult.diagnostics
                        });
                    } catch { /* ignore */ }
                } else {
                    finalDiagnostics = {
                        ai: obj && obj.diagnostics ? obj.diagnostics : null,
                        aiGuardrails
                    };
                    if (aiGuardrails.warnings && aiGuardrails.warnings.length) finalWarning = aiGuardrails.warnings.join(' | ');
                }
            }

            /* ── AI ACTION log ── */
            const _logSentCount   = countSvgObjects(svgForAi);
            const _logResultCount = countSvgObjects(finalSvg);
            const _logDeletedCount = Math.max(0, _logSentCount - _logResultCount);
            const _logProvider = finalProvider || selectedProvider || 'unknown';
            const _logModel    = finalModel;
            const _logAction   = _getSvgAiAction ? _getSvgAiAction() : 'unknown';
            console.log(
                `%c[AI ACTION]%c sent=${_logSentCount}  deleted=${_logDeletedCount}  remaining=${_logResultCount}  provider=${_logProvider}  model=${_logModel}  action=${_logAction}`,
                'background:#7c3aed;color:#fff;padding:2px 6px;border-radius:3px;font-weight:bold',
                'color:#7c3aed;font-weight:bold'
            );
            /* ── end log ── */

            const resultNameBase = r.isLayer
                ? String(r.layerName || 'Layer')
                : `Page ${Math.max(1, Number(r.pageNumber || 1) | 0)}`;

            const _actionLabel = _getAiActionButtonLabel ? _getAiActionButtonLabel() : 'AI';
            const aiResult = {
                pageNumber: Math.max(1, Number(r.pageNumber || 1) | 0),
                isLayer: true,
                layerName: `${resultNameBase} — ${_actionLabel}`,
