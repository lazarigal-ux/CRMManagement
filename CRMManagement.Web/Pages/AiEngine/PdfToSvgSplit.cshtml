    @@keyframes color-scan-pulse {
        0%   { stroke-opacity: 0; filter: drop-shadow(0 0 0 transparent); }
        50%  { stroke-opacity: 1; filter: drop-shadow(0 0 10px rgba(34,197,94,1)); }
        100% { stroke-opacity: 1; filter: drop-shadow(0 0 5px rgba(34,197,94,.85)) drop-shadow(0 0 2px rgba(34,197,94,1)); }
