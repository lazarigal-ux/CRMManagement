                method: 'POST',
                headers: { 'Content-Type': 'application/json', 'X-Client-Id': 'admin' },
                signal: controller ? controller.signal : undefined,
                body: JSON.stringify({
                    svgContent: r.svgContent,
                    cropViewBox,
                    layerName: r.layerName || null,
                    pageNumber: Number.isFinite(r.pageNumber) ? r.pageNumber : null,
                    clientId: 'admin'
