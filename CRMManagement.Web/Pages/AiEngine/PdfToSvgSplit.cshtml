    function formatBytes(n) {
        if (!isFinite(n) || n <= 0) return '0 B';
        const units = ['B','KB','MB','GB'];
        let u = 0;
        while (n >= 1024 && u < units.length - 1) { n /= 1024; u++; }
        return `${n.toFixed(u === 0 ? 0 : 1)} ${units[u]}`;
    }

    function formatInt(n) {
        if (!isFinite(n)) return '';
        try { return new Intl.NumberFormat().format(Math.trunc(n)); } catch { return String(Math.trunc(n)); }
    }

    // Count only actual graphical shape elements (not structural <g>, <defs>, <clipPath> etc.)
    const _SHAPE_SELECTOR = 'path, rect, circle, ellipse, line, polyline, polygon, text, image, use';
    function _analyzeSvgUseDiagnostics(svgText) {
        try {
            if (!svgText || typeof svgText !== 'string') return null;
            const doc = new DOMParser().parseFromString(svgText, 'image/svg+xml');
            const svg = doc.querySelector('svg');
            if (!svg) return null;

            const defsIds = new Set([...svg.querySelectorAll('[id]')].map(el => String(el.getAttribute('id') || '').trim()).filter(Boolean));
            const uses = [...svg.querySelectorAll('use')].filter(el => { try { return !(el.closest && el.closest('defs')); } catch { return true; } });
            const textNodes = [...svg.querySelectorAll('text')].filter(el => { try { return !(el.closest && el.closest('defs')); } catch { return true; } });
            const images = [...svg.querySelectorAll('image')].filter(el => { try { return !(el.closest && el.closest('defs')); } catch { return true; } });
            const shapes = [...svg.querySelectorAll(_SHAPE_SELECTOR)].filter(el => { try { return !(el.closest && el.closest('defs')); } catch { return true; } });

            const hrefTargets = [];
            let useWithHref = 0;
            let useMissingTarget = 0;
            let useWithoutHref = 0;
            for (const el of uses) {
                const href = String(el.getAttribute('href') || el.getAttribute('xlink:href') || '').trim();
                if (!href) {
                    useWithoutHref++;
                    continue;
                }
                useWithHref++;
                if (href.startsWith('#')) {
                    const target = href.slice(1);
                    hrefTargets.push(target);
                    if (!defsIds.has(target)) useMissingTarget++;
                }
            }

            const styles = [...svg.querySelectorAll('style')].map(el => String(el.textContent || '')).filter(Boolean);
            const styleUrlRefs = [];
            for (const css of styles) {
                for (const m of css.matchAll(/url\(\s*#([^\)\s]+)\s*\)/g)) {
                    const target = String(m[1] || '').trim();
                    if (target) styleUrlRefs.push(target);
                }
            }

            const hrefCounts = new Map();
            for (const target of hrefTargets) hrefCounts.set(target, (hrefCounts.get(target) || 0) + 1);
            const topHrefTargets = [...hrefCounts.entries()].sort((a, b) => (b[1] - a[1]) || a[0].localeCompare(b[0])).slice(0, 12);
            const missingTargets = [...new Set(hrefTargets.filter(id => !defsIds.has(id)))].slice(0, 12);

            return {
                objectCount: shapes.length,
                defsIdCount: defsIds.size,
                useCount: uses.length,
                textCount: textNodes.length,
                imageCount: images.length,
                xlinkHrefCount: (svgText.match(/xlink:href=/g) || []).length,
                hrefCount: (svgText.match(/\shref=/g) || []).length,
                nsHrefCount: (svgText.match(/\sns\d+:href=/g) || []).length,
                xmlnsXlinkCount: (svgText.match(/xmlns:xlink=/g) || []).length,
                useWithHref,
                useWithoutHref,
                useMissingTarget,
                topHrefTargets,
                missingTargets,
                styleUrlRefCount: styleUrlRefs.length,
                svgInfo: analyzeSvg(svgText)
            };
        } catch {
            return null;
        }
    }

    function _renderMergedSvgDebugReport() {
        const report = _mergedSvgDebugReport;
        if (!mergedSvgDebugText || !mergedSvgDebugSummary) return;
        if (!report || !Array.isArray(report.entries) || !report.entries.length) {
            mergedSvgDebugSummary.textContent = 'Run Merge Before Split to collect diagnostics.';
            mergedSvgDebugText.textContent = 'No diagnostics yet.';
            if (btnCopyMergedSvgDebug) btnCopyMergedSvgDebug.disabled = true;
            return;
        }

        const lines = [];
        lines.push('=== Merge SVG Diagnostics ===');
        lines.push(`Time: ${new Date(report.createdAt || Date.now()).toLocaleString()}`);
        if (report.cropText) lines.push(`Crop: ${report.cropText}`);
        lines.push('');

        for (const entry of report.entries) {
            if (!entry) continue;
            lines.push(`--- ${entry.label || 'SVG'} ---`);
            if (typeof entry.byteLength === 'number') lines.push(`bytes=${entry.byteLength}`);
            const diag = entry.diag || null;
            if (!diag) {
                lines.push('diag=(unavailable)');
                lines.push('');
                continue;
            }
            lines.push(`objects=${diag.objectCount} use=${diag.useCount} text=${diag.textCount} image=${diag.imageCount} defsIds=${diag.defsIdCount}`);
            lines.push(`href: xlink=${diag.xlinkHrefCount} href=${diag.hrefCount} nsHref=${diag.nsHrefCount} xmlns:xlink=${diag.xmlnsXlinkCount}`);
            lines.push(`useRefs: withHref=${diag.useWithHref} withoutHref=${diag.useWithoutHref} missingTargets=${diag.useMissingTarget}`);
            if (diag.svgInfo) {
                lines.push(`svg: viewBox=${diag.svgInfo.viewBox || '-'} width=${diag.svgInfo.width || '-'} height=${diag.svgInfo.height || '-'} els=${diag.svgInfo.elementCount || 0}`);
            }
            if (diag.topHrefTargets && diag.topHrefTargets.length) {
                lines.push(`topHrefTargets=${diag.topHrefTargets.map(([id, count]) => `${id}:${count}`).join(', ')}`);
            }
            if (diag.missingTargets && diag.missingTargets.length) {
                lines.push(`missingTargets=${diag.missingTargets.join(', ')}`);
            }
            lines.push('');
        }

        mergedSvgDebugSummary.textContent = `Stages logged: ${report.entries.length}`;
        mergedSvgDebugText.textContent = lines.join('\n').trim();
        if (btnCopyMergedSvgDebug) btnCopyMergedSvgDebug.disabled = false;
    }

    function _setMergedSvgDebugReport(report) {
        _mergedSvgDebugReport = report || null;
        _renderMergedSvgDebugReport();
    }
    function countSvgObjects(svgText) {
        try {
            if (!svgText || typeof svgText !== 'string') return 0;
            const doc = new DOMParser().parseFromString(svgText, 'image/svg+xml');
            const svg = doc.querySelector('svg');
            if (!svg) return 0;
            const els = [...svg.querySelectorAll(_SHAPE_SELECTOR)];
            let c = 0;
            for (const el of els) {
                try {
                    if (el.closest && el.closest('defs')) continue;
                } catch {
                    // ignore
                }
                c++;
            }
            return c;
        } catch {
            return 0;
        }
    }

    const _CONSERVATIVE_CLEANUP_SELECTOR = 'path, line, polyline, polygon, rect, ellipse, circle';

    function _cleanupNumber(v, fallback = 0) {
        const n = Number(v);
        return Number.isFinite(n) ? n : fallback;
    }

    function _cleanupRectArea(r) {
        return r && Number.isFinite(r.w) && Number.isFinite(r.h) ? Math.max(0, r.w) * Math.max(0, r.h) : 0;
    }

    function _cleanupDistance(a, b) {
        if (!a || !b) return Infinity;
        return Math.hypot(_cleanupNumber(a.x) - _cleanupNumber(b.x), _cleanupNumber(a.y) - _cleanupNumber(b.y));
    }

    function _cleanupRectIntersects(a, b) {
        if (!a || !b) return false;
        return !(a.x + a.w < b.x || b.x + b.w < a.x || a.y + a.h < b.y || b.y + b.h < a.y);
    }

    function _cleanupRectDistance(a, b) {
        if (!a || !b) return Infinity;
        const dx = Math.max(0, b.x - (a.x + a.w), a.x - (b.x + b.w));
        const dy = Math.max(0, b.y - (a.y + a.h), a.y - (b.y + b.h));
        return Math.hypot(dx, dy);
    }

    function _cleanupUnionRect(rects) {
        const list = (Array.isArray(rects) ? rects : []).filter(Boolean);
        if (!list.length) return null;
        let minX = Infinity, minY = Infinity, maxX = -Infinity, maxY = -Infinity;
        for (const r of list) {
            minX = Math.min(minX, _cleanupNumber(r.x));
            minY = Math.min(minY, _cleanupNumber(r.y));
            maxX = Math.max(maxX, _cleanupNumber(r.x) + _cleanupNumber(r.w));
            maxY = Math.max(maxY, _cleanupNumber(r.y) + _cleanupNumber(r.h));
        }
        if (!Number.isFinite(minX) || !Number.isFinite(minY) || !Number.isFinite(maxX) || !Number.isFinite(maxY)) return null;
        return { x: minX, y: minY, w: Math.max(0, maxX - minX), h: Math.max(0, maxY - minY) };
    }

    function _cleanupClamp(v, min, max) {
        if (!Number.isFinite(v)) return min;
        return Math.max(min, Math.min(max, v));
    }

    function _cleanupAngleDiff(a, b) {
        if (!Number.isFinite(a) || !Number.isFinite(b)) return Math.PI;
        let d = Math.abs(a - b) % Math.PI;
        if (d > Math.PI / 2) d = Math.PI - d;
        return d;
    }

    function _cleanupNormalizeColor(value) {
        const raw = String(value || '').trim().toLowerCase();
        if (!raw || raw === 'none' || raw === 'transparent') return null;
        if (raw === 'white') return { r: 255, g: 255, b: 255, a: 1, raw };
        if (raw === 'black') return { r: 0, g: 0, b: 0, a: 1, raw };
        if (raw[0] === '#') {
            let hex = raw.slice(1);
            if (hex.length === 3) hex = hex.split('').map(ch => ch + ch).join('');
            if (hex.length === 6 || hex.length === 8) {
                const r = parseInt(hex.slice(0, 2), 16);
                const g = parseInt(hex.slice(2, 4), 16);
                const b = parseInt(hex.slice(4, 6), 16);
                const a = hex.length === 8 ? (parseInt(hex.slice(6, 8), 16) / 255) : 1;
                if ([r, g, b, a].every(Number.isFinite)) return { r, g, b, a, raw };
            }
        }
        const rgb = raw.match(/^rgba?\(([^)]+)\)$/);
        if (rgb) {
            const parts = rgb[1].split(',').map(s => s.trim());
            if (parts.length >= 3) {
                const r = parseFloat(parts[0]);
                const g = parseFloat(parts[1]);
                const b = parseFloat(parts[2]);
                const a = parts.length > 3 ? parseFloat(parts[3]) : 1;
                if ([r, g, b, a].every(Number.isFinite)) return { r, g, b, a, raw };
            }
        }
        return { r: NaN, g: NaN, b: NaN, a: 1, raw };
    }

    function _cleanupIsWhiteLike(color, threshold = 246) {
        if (!color || !Number.isFinite(color.r) || !Number.isFinite(color.g) || !Number.isFinite(color.b)) return false;
        return color.r >= threshold && color.g >= threshold && color.b >= threshold;
    }

    function _cleanupParseStyleString(styleText) {
        const map = new Map();
        String(styleText || '').split(';').forEach(part => {
            const idx = part.indexOf(':');
            if (idx <= 0) return;
            const k = part.slice(0, idx).trim().toLowerCase();
            const v = part.slice(idx + 1).trim();
            if (k) map.set(k, v);
        });
        return map;
    }

    function _cleanupReadPresentation(el, name) {
        const key = String(name || '').toLowerCase();
        let cur = el;
        while (cur && cur.nodeType === 1) {
            try {
                const attr = cur.getAttribute(key);
                if (attr != null && String(attr).trim() !== '') return String(attr).trim();
            } catch { /* ignore */ }
            try {
                const styles = _cleanupParseStyleString(cur.getAttribute('style') || '');
                if (styles.has(key)) return styles.get(key) || '';
            } catch { /* ignore */ }
            cur = cur.parentElement;
        }
        return '';
    }

    function _cleanupOpacityValue(el, name, fallback = 1) {
        const raw = _cleanupReadPresentation(el, name);
        if (!raw) return fallback;
        const n = parseFloat(raw);
        return Number.isFinite(n) ? _cleanupClamp(n, 0, 1) : fallback;
    }

    function _cleanupStrokeWidth(el) {
        const raw = _cleanupReadPresentation(el, 'stroke-width');
        if (!raw) return 0;
        const n = parseFloat(String(raw).replace(/[a-z%]+$/i, ''));
        return Number.isFinite(n) ? Math.max(0, n) : 0;
    }

    function _cleanupIdentityMatrix() {
        return { a: 1, b: 0, c: 0, d: 1, e: 0, f: 0 };
    }

    function _cleanupMultiplyMatrix(m1, m2) {
        return {
            a: m1.a * m2.a + m1.c * m2.b,
            b: m1.b * m2.a + m1.d * m2.b,
            c: m1.a * m2.c + m1.c * m2.d,
            d: m1.b * m2.c + m1.d * m2.d,
            e: m1.a * m2.e + m1.c * m2.f + m1.e,
            f: m1.b * m2.e + m1.d * m2.f + m1.f
        };
    }

    function _cleanupApplyMatrix(m, x, y) {
        return { x: m.a * x + m.c * y + m.e, y: m.b * x + m.d * y + m.f };
    }

    function _cleanupParseTransform(transformText) {
        const text = String(transformText || '').trim();
        if (!text) return _cleanupIdentityMatrix();
        let result = _cleanupIdentityMatrix();
        const re = /([a-zA-Z]+)\(([^)]*)\)/g;
        let m;
        while ((m = re.exec(text))) {
            const kind = String(m[1] || '').toLowerCase();
            const vals = String(m[2] || '').split(/[\s,]+/).filter(Boolean).map(Number);
            let next = _cleanupIdentityMatrix();
            if (kind === 'matrix' && vals.length >= 6) next = { a: vals[0], b: vals[1], c: vals[2], d: vals[3], e: vals[4], f: vals[5] };
            else if (kind === 'translate') next = { a: 1, b: 0, c: 0, d: 1, e: vals[0] || 0, f: vals.length > 1 ? vals[1] : 0 };
            else if (kind === 'scale') next = { a: vals[0] || 1, b: 0, c: 0, d: vals.length > 1 ? vals[1] : (vals[0] || 1), e: 0, f: 0 };
            else if (kind === 'rotate') {
                const angle = ((vals[0] || 0) * Math.PI) / 180;
                const cos = Math.cos(angle), sin = Math.sin(angle);
                next = { a: cos, b: sin, c: -sin, d: cos, e: 0, f: 0 };
                if (vals.length >= 3) {
                    const cx = vals[1] || 0;
                    const cy = vals[2] || 0;
                    next = _cleanupMultiplyMatrix(_cleanupMultiplyMatrix({ a: 1, b: 0, c: 0, d: 1, e: cx, f: cy }, next), { a: 1, b: 0, c: 0, d: 1, e: -cx, f: -cy });
