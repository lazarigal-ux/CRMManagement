    async function _moveSmallSignsFromActiveOtherElements() {
        const idx = Number(_svgPreviewActiveResultIdx);
        const r = Number.isFinite(idx) ? pageResults[idx] : null;
        if (!Number.isFinite(idx) || idx < 0 || idx >= pageResults.length || !r || !r.svgContent || !_isOtherElementsLayerResult(r)) return;
        if (_svgMoveSmallSignsBusy) return;
        if (!svgPreviewFixedCropEnabled || !svgPreviewFixedCropViewBoxStr) {
            cgAlert('First mark the exact area with SELECT AREA inside SVG Preview.');
            return;
        }

        try {
            _svgMoveSmallSignsBusy = true;
            _updateSvgMoveSmallSignsUi();

            const resp = await fetch(SVG_OTHER_ELEMENTS_CLEAN_SIGNS_ENDPOINT, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json', 'X-Client-Id': 'admin' },
                body: JSON.stringify({
                    svgContent: r.svgContent,
                    layerName: r.layerName || '',
                    pageNumber: r.pageNumber || null,
                    cropViewBox: String(svgPreviewFixedCropViewBoxStr || '')
                })
            });

            if (!resp.ok) {
                const txt = await resp.text();
                throw new Error(`HTTP ${resp.status}: ${String(txt || '').slice(0, 500)}`);
            }

            const split = await resp.json();
            if (!split || !(Number(split.movedCount || 0) > 0) || !split.cleanedSvg || !split.movedSvg) {
                cgAlert('No small signs were found in OTHER ELEMENTS.');
                return;
            }

            r.svgContent = String(split.cleanedSvg || '');
            r.objectCount = Number(split.keptCount || 0);
            r.layerName = `⬜ Other elements (${r.objectCount})`;

            const existingIdx = pageResults.findIndex((x, xi) => xi !== idx && x && x.movedFromOtherElements && x.sourceOtherLayerIdx === idx);
            const movedCount = Number(split.movedCount || 0);
            const movedLayerName = `🧹 Moved small signs (${movedCount})`;
            let movedResultIdx = existingIdx;
            if (existingIdx >= 0) {
                const movedResult = pageResults[existingIdx];
                movedResult.svgContent = String(split.movedSvg || '');
                movedResult.objectCount = movedCount;
                movedResult.layerName = movedLayerName;
                movedResult.svgSizeBytes = new Blob([movedResult.svgContent]).size;
            } else {
                pageResults.push({
                    pageNumber: r.pageNumber,
                    regionIndex: r.regionIndex,
                    isLayer: true,
                    movedFromOtherElements: true,
                    sourceOtherLayerIdx: idx,
                    layerName: movedLayerName,
                    layerColor: '#f59e0b',
                    layerIcon: 'fa-broom',
                    svgContent: String(split.movedSvg || ''),
                    svgSizeBytes: new Blob([String(split.movedSvg || '')]).size,
                    objectCount: movedCount
                });
                movedResultIdx = pageResults.length - 1;
            }

            r.svgSizeBytes = new Blob([r.svgContent]).size;
            _upsertResultCard(idx);
            if (Number.isFinite(movedResultIdx) && movedResultIdx >= 0) _upsertResultCard(movedResultIdx);
            try { await _openSvgPreviewForResult(idx, { preserveView: true }); } catch { /* ignore */ }
            try { resultsSection?.scrollIntoView({ behavior: 'smooth', block: 'start' }); } catch { /* ignore */ }
        } catch (e) {
            cgAlert(`Failed to clean small signs: ${String(e)}`);
        } finally {
            _svgMoveSmallSignsBusy = false;
            _updateSvgMoveSmallSignsUi();
        }
    }

    async function _buildAiTextOnlyImageDataUrls(r, preparedSvgText, preparedPreviewImageDataUrl) {
        const urls = [];
        const seen = new Set();

        function add(url) {
            const s = (url || '').toString().trim();
            if (!s || !s.startsWith('data:image/')) return;
            if (seen.has(s)) return;
            seen.add(s);
            urls.push(s);
        }

        add(preparedPreviewImageDataUrl);

        try {
            const svgForAi = (preparedSvgText || '').toString().trim();
            if (svgForAi && !preparedPreviewImageDataUrl) {
                const layerPreview = await _buildTemplateImageDataUrl(svgForAi, 1200);
                add(layerPreview);
            }
        } catch { /* ignore */ }

        return urls.slice(0, 2);
    }

    async function _buildAiCleanImageDataUrls(svgText, cropViewBoxStr) {
        const prepared = await _buildAiTextOnlyCroppedPayload(svgText, cropViewBoxStr);
        const urls = [];
        const primary = (prepared && prepared.previewImageDataUrl) ? String(prepared.previewImageDataUrl) : '';
        if (primary && primary.startsWith('data:image/')) urls.push(primary);
        else {
            const fallback = await _buildTemplateImageDataUrl(String(svgText || ''), 1400);
            if (fallback && fallback.startsWith('data:image/')) urls.push(fallback);
        }
        return urls.slice(0, 1);
    }

