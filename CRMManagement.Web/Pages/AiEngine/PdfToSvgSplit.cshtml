        const fh = Number(frac.h);
        if (!(Number.isFinite(fx) && Number.isFinite(fy) && Number.isFinite(fw) && Number.isFinite(fh))) return '';
        const prefix = Number.isFinite(pageIndex) && pageIndex >= 0 ? `page=${pageIndex + 1} ` : '';
        return `${prefix}frac{x=${fx.toFixed(4)},y=${fy.toFixed(4)},w=${fw.toFixed(4)},h=${fh.toFixed(4)}}`;
    }

    function _describeProcessCropMode(ctx) {
