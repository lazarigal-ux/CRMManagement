                layerIcon: 'fa-wand-magic-sparkles',
                svgContent: finalSvg,
                svgSizeBytes: new Blob([finalSvg]).size,
                objectCount: _logResultCount,
                aiProvider: _logProvider,
                aiModel: _logModel,
                aiDiagnostics: finalDiagnostics,
                aiWarning: finalWarning,
                sourceResultIndex: idx
            };

            pageResults.push(aiResult);
            addResultCard(pageResults.length - 1);
            resultsSection.classList.remove('hidden');
            setSplitMainTab('svgSplit');

            if (finalWarning) {
                try { console.warn(`[AI ACTION RESPONSE ${requestTraceId}] warning`, finalWarning, finalDiagnostics); } catch { /* ignore */ }
            }

            if (options && options.openPreview) {
                requestAnimationFrame(() => {
                    try {
                        const previewBtn = resultsGrid
                            ? resultsGrid.querySelector(`.page-card[data-idx="${pageResults.length - 1}"] .btn-preview`)
                            : null;
                        previewBtn?.click();
                    } catch { /* ignore */ }
                });
            }
        } catch (ex) {
            const msg = ex && ex.message ? ex.message : String(ex || 'AI text-only failed.');
            showError(msg);
            cgAlert(msg);
        } finally {
            _svgAiTextOnlyBusy = false;
            _updateSvgAiTextOnlyUi();
            if (sourceBtn) {
                sourceBtn.disabled = originalBtnDisabled;
                sourceBtn.innerHTML = originalBtnHtml;
            }
