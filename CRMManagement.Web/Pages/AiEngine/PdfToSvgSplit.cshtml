                                : `<button type="button" class="text-[10px] text-amber-200 hover:text-amber-50 bg-amber-800/40 hover:bg-amber-800/60 border border-amber-500/40 rounded px-2 py-1 font-semibold" onclick="confirmMarkMissingTableOnly(${pi}, ${fx.toFixed(6)}, ${fy.toFixed(6)}, ${fw.toFixed(6)}, ${fh.toFixed(6)})"><i class="fa-solid fa-table-list me-1"></i>Add to Table</button>`}
