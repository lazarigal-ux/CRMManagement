                    addSample(el, 'bbox-miss');
                    continue;
                }
                const rect = _inflateSvgCandidateRectForHitTest({ x: bb.x1, y: bb.y1, width: Math.max(0, bb.x2 - bb.x1), height: Math.max(0, bb.y2 - bb.y1) }, minThinObjectThickness);
