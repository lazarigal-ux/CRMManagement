    function _renderSvgAiModelMenu() {
        if (!svgAiModelMenu) return;
        const current = ((svgAiModelInput && svgAiModelInput.value) ? String(svgAiModelInput.value) : '').trim();
        const options = Array.from(svgAiModelInput?.options || []).map(opt => ({
            value: String(opt.value || ''),
            label: String(opt.textContent || opt.value || 'Auto')
        }));
        svgAiModelMenu.innerHTML = options.map(opt => `
            <button type="button" class="svg-ai-picker-option ${opt.value === current ? 'is-active' : ''}" data-model-option="${escapeHtml(opt.value)}">
                <span>${escapeHtml(opt.label || 'Auto')}</span>
            </button>`).join('');
    }

    function _syncSvgAiModelPicker() {
        try {
            const p = _getSvgAiProviderValue();
            if (svgAiProviderSelect) svgAiProviderSelect.value = p;
            if (svgCodeAiProviderSelect) svgCodeAiProviderSelect.value = p;

            // Auto-select the best model for the current provider
            const bestModel = _getFamilyScanModelHintForProvider(p);
            setFamilyScanAiModel(bestModel);

            const opts = _getFamilyScanModelOptionsForProvider(p);
            if (svgAiModelOptions) {
                const uniq = [];
                const seen = new Set();
                for (const o of opts) {
                    const s = (o || '').toString().trim();
                    if (!s) continue;
                    const k = s.toLowerCase();
                    if (seen.has(k)) continue;
                    seen.add(k);
                    uniq.push(s);
                }
                const selected = (_familyScanAiModel || '').toString().trim();
                if (selected) {
                    const k = selected.toLowerCase();
                    if (!seen.has(k)) uniq.unshift(selected);
                }
                svgAiModelOptions.innerHTML = uniq.map(s => `<option value="${escapeHtml(s)}"></option>`).join('');
                if (svgAiModelInput) {
                    const modelOptions = ['<option value="">Auto</option>']
                        .concat(uniq.map(s => `<option value="${escapeHtml(s)}">${escapeHtml(s)}</option>`));
                    svgAiModelInput.innerHTML = modelOptions.join('');
                }
            }
            if (svgAiModelInput) {
                svgAiModelInput.value = bestModel || '';
                if (svgAiModelInput.value !== (bestModel || '')) svgAiModelInput.value = '';
            }
            if (svgCodeAiModelInput) svgCodeAiModelInput.value = bestModel || '';
            if (svgAiProviderButtonText) svgAiProviderButtonText.textContent = p === 'gemini' ? 'Gemini' : (p === 'ollama' ? 'Ollama' : 'OpenAI');
            _renderSvgAiProviderMenu();
            _updateSvgAiPickerTheme();
        } catch { /* ignore */ }
    }

    function _applyAiProviderToModel(provider) {
        try {
            const nextModel = _getFamilyScanModelHintForProvider(provider);
            setFamilyScanAiModel(nextModel);
            if (_lastFamilyLearnModel && familyLearnPanel && !familyLearnPanel.classList.contains('hidden')) {
