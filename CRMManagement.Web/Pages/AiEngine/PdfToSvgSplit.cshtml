    function reportStart(ctx) {
        _processReport = {
            startedAt: new Date(),
            endedAt: null,
            ctx,
            steps: [],
            cropDiagnostics: [],
            vectorizeCalls: [],
            lastError: null,
            notes: []
        };
        if (_processReport.ctx && !_processReport.ctx.regions) _processReport.ctx.regions = [];
        if (_processReport.ctx) {
            reportCropDiagnostic('Crop mode', {
                mode: _describeProcessCropMode(_processReport.ctx),
                outputCrop: _processReport.ctx.outputCrop || null,
                outputCropText: _formatCropFractionForReport(_processReport.ctx.outputCrop, _processReport.ctx.outputCrop && Number.isFinite(_processReport.ctx.outputCrop.pageIndex) ? Number(_processReport.ctx.outputCrop.pageIndex) : -1)
            });
        }
        reportStep('Start', ctx);
    }
    function reportStep(title, data) {
        if (!_processReport) return;
        _processReport.steps.push({
            at: new Date(),
            title,
            data: data || null
        });
    }
    function reportVectorizeCall(entry) {
        if (!_processReport) return;
        if (entry && entry.meta && !entry.metaObj) entry.metaObj = parseJsonSafe(entry.meta);
        _processReport.vectorizeCalls.push(entry);
    }
    function reportSetError(msg) {
        if (!_processReport) return;
        _processReport.lastError = msg;
    }
    function reportRenderFinal() {
        if (!_processReport || !processReportText || !processReportCard) return;
        _processReport.endedAt = new Date();

        const lines = [];
        const started = _processReport.startedAt;
        const ended = _processReport.endedAt;
        const msTotal = ended - started;
        lines.push('=== Process Report — PDF to SVG Split ===');
        lines.push(`Start time: ${started.toLocaleString()}`);
        lines.push(`End time:   ${ended.toLocaleString()}`);
        lines.push(`Total time: ${(msTotal/1000).toFixed(1)} seconds`);
        lines.push('');

        const ctx = _processReport.ctx || {};
        if (ctx.fileName) lines.push(`File: ${ctx.fileName}`);
        if (typeof ctx.fileSizeBytes === 'number') lines.push(`Size (File.size): ${formatBytes(ctx.fileSizeBytes)} (${ctx.fileSizeBytes} bytes)`);
        if (typeof ctx.fileArrayBufferBytes === 'number') {
            const match = (typeof ctx.fileSizeBytes === 'number') ? (ctx.fileArrayBufferBytes === ctx.fileSizeBytes) : null;
            const matchTxt = (match === null) ? '' : ` | match=${match ? 'yes' : 'no'}`;
            lines.push(`Size (arrayBuffer): ${formatBytes(ctx.fileArrayBufferBytes)} (${ctx.fileArrayBufferBytes} bytes)${matchTxt}`);
        }
        if (ctx.provider) lines.push(`Provider: ${ctx.provider}`);
        if (isFinite(ctx.dpi)) lines.push(`DPI: ${ctx.dpi}`);
        lines.push(`Mode: ${ctx.hasCrop ? 'Region (Crop)' : 'Full pages'}`);
        lines.push(`Crop mode: ${_describeProcessCropMode(ctx)}`);
        if (ctx.outputCrop) {
            const cropText = _formatCropFractionForReport(ctx.outputCrop, Number.isFinite(Number(ctx.outputCrop.pageIndex)) ? Number(ctx.outputCrop.pageIndex) : -1);
            if (cropText) lines.push(`Output crop: ${cropText}`);
        }
        if (isFinite(ctx.previewDpi)) lines.push(`Preview DPI (render): ${ctx.previewDpi}`);
        if (isFinite(ctx.pageCount)) lines.push(`Pages: ${ctx.pageCount}`);
        if (isFinite(ctx.totalRegions)) lines.push(`Selected regions: ${ctx.totalRegions}`);
        if (ctx.activeLayersSummary) lines.push(`Active color layers: ${ctx.activeLayersSummary}`);
        if (ctx.previewRasterFirstPage) lines.push(`Raster resolution (page 1): ${ctx.previewRasterFirstPage}`);
        lines.push('');

        lines.push('--- Steps ---');
        for (let i = 0; i < _processReport.steps.length; i++) {
            const s = _processReport.steps[i];
            const t = s.at.toLocaleTimeString();
            const suffix = s.data ? ` | ${JSON.stringify(s.data)}` : '';
            lines.push(`${String(i+1).padStart(2,'0')}. [${t}] ${s.title}${suffix}`);
        }

        if (_processReport.vectorizeCalls.length > 0) {
            lines.push('');
            lines.push('--- Vectorize Calls (Server) ---');
            for (const c of _processReport.vectorizeCalls) {
                const metaObj = c.metaObj || parseJsonSafe(c.meta);
                const metaShort = (c.meta || '').toString().slice(0, 180).replace(/\s+/g, ' ').trim();
                const svgBytes = (typeof c.svgBytes === 'number') ? ` svgBytes=${formatBytes(c.svgBytes)}` : '';
                const svgShort = c.svgInfo
                    ? ` svg{vb=${c.svgInfo.viewBox || '-'} w=${c.svgInfo.width || '-'} h=${c.svgInfo.height || '-'} els=${c.svgInfo.elementCount}}`
                    : '';
                lines.push(`- ${c.label}: HTTP ${c.status} (${(c.ms/1000).toFixed(2)}s) reqProv=${c.requestedProvider || '-'}${svgBytes}${svgShort} meta=${metaShort || '-'}`);

                if (c.svgInfo && c.svgInfo.topTags && Array.isArray(c.svgInfo.topTags) && c.svgInfo.topTags.length > 0) {
                    const tagsLine = c.svgInfo.topTags.map(([t, n]) => `${t}=${n}`).join(', ');
                    lines.push(`  svgTags: ${tagsLine}`);
                }

                // If the server provided AI prompt info, print it (once).
                if (!lines._aiPrinted && metaObj && (metaObj.ai_prompt_system || metaObj.ai_prompt_instruction)) {
                    lines._aiPrinted = true;
                    lines.push('');
                    lines.push('--- AI Prompt (Server → OpenAI/Gemini) ---');
                    if (metaObj.ai_provider) lines.push(`Provider: ${metaObj.ai_provider}`);
                    if (metaObj.ai_model) lines.push(`Model: ${metaObj.ai_model}`);
                    if (typeof metaObj.ai_prompt_included_image !== 'undefined') lines.push(`Image included: ${metaObj.ai_prompt_included_image ? 'yes' : 'no'}`);
                    if (typeof metaObj.ai_prompt_source_svg_chars_sent !== 'undefined') lines.push(`SVG chars sent: ${metaObj.ai_prompt_source_svg_chars_sent}`);
                    if (typeof metaObj.ai_prompt_source_svg_truncated !== 'undefined') lines.push(`SVG truncated: ${metaObj.ai_prompt_source_svg_truncated ? 'yes' : 'no'}`);
                    if (metaObj.ai_prompt_system) {
                        lines.push('System:');
                        lines.push(String(metaObj.ai_prompt_system));
                    }
                    if (metaObj.ai_prompt_instruction) {
                        lines.push('Instruction:');
                        lines.push(String(metaObj.ai_prompt_instruction));
                    }
                    lines.push('');
                }
            }
        }

        // PDF regions detail
        if (ctx.hasCrop && ctx.regions && Array.isArray(ctx.regions) && ctx.regions.length > 0) {
            lines.push('');
            lines.push('--- Regions ---');
            for (const r of ctx.regions) {
                const frac = r.frac ? `frac{x=${r.frac.x.toFixed(4)},y=${r.frac.y.toFixed(4)},w=${r.frac.w.toFixed(4)},h=${r.frac.h.toFixed(4)}}` : '';
                const src = (r.srcW && r.srcH) ? `src=${r.srcW}x${r.srcH}` : '';
                const crop = (r.cropW && r.cropH) ? `crop=${r.cropW}x${r.cropH} (sx=${r.sx},sy=${r.sy})` : '';
                const scaled = (r.scaledW && r.scaledH) ? `scaled=${r.scaledW}x${r.scaledH}` : '';
                lines.push(`- ${r.label || 'Region'}: ${src} ${crop} ${scaled} ${frac}`.trim());
            }
        }

        if (_processReport.cropDiagnostics && Array.isArray(_processReport.cropDiagnostics) && _processReport.cropDiagnostics.length > 0) {
            lines.push('');
            lines.push('--- Crop Diagnostics ---');
            for (let i = 0; i < _processReport.cropDiagnostics.length; i++) {
                const entry = _processReport.cropDiagnostics[i];
                const t = entry && entry.at ? entry.at.toLocaleTimeString() : '';
                const suffix = entry && entry.data ? ` | ${JSON.stringify(entry.data)}` : '';
                lines.push(`${String(i + 1).padStart(2, '0')}. [${t}] ${entry && entry.title ? entry.title : 'Crop'}${suffix}`);
            }
        }

        lines.push('');
        lines.push('--- Results ---');
        const okCount = pageResults.filter(r => r && !r.error).length;
        const errCount = pageResults.filter(r => r && r.error).length;
        lines.push(`Cards: ${pageResults.length} (OK: ${okCount}, ERR: ${errCount})`);
        const byName = {};
        for (const r of pageResults) {
            const name = (r && (r.layerName || (r.isLayer ? 'Layer' : `Page ${r.pageNumber}`))) || 'Unknown';
            byName[name] = (byName[name] || 0) + 1;
        }
        const topNames = Object.entries(byName).sort((a,b)=>b[1]-a[1]).slice(0, 25);
        for (const [name, cnt] of topNames) lines.push(`- ${name}: ${cnt}`);
        const totalBytes = pageResults.reduce((s, r) => s + (r && r.svgSizeBytes ? r.svgSizeBytes : 0), 0);
        lines.push(`Total SVG size: ${formatBytes(totalBytes)}`);

        if (_processReport.lastError) {
            lines.push('');
            lines.push('--- Errors ---');
            lines.push(_processReport.lastError.toString());
        }

        lines.push('');
        lines.push('--- Layer Algorithm (Region Decompose) ---');
        lines.push('- "Unmatched colors" is disabled.');
        lines.push('- A colored element that does not match within tolerance is assigned to the nearest color (RGB).');
        lines.push('- Large-fill guard: fill matching is allowed only if element area ≤ 2% of the region.');
        lines.push('- "Other elements" contains only items not assigned to an active color layer.');

        // Summary cards
        const summaryItems = [];
        if (ctx.fileName) summaryItems.push({ label: 'File', value: String(ctx.fileName), sub: (typeof ctx.fileSizeBytes === 'number') ? formatBytes(ctx.fileSizeBytes) : '' });
        if (ctx.provider) summaryItems.push({ label: 'Provider', value: String(ctx.provider) });
        if (typeof ctx.pdfTextWordsCount === 'number' && ctx.pdfTextWordsCount > 0) {
            const sz = (ctx.pdfTextPageWidthPt && ctx.pdfTextPageHeightPt) ? `${ctx.pdfTextPageWidthPt}×${ctx.pdfTextPageHeightPt} pt` : '';
            summaryItems.push({ label: 'PDF TEXT', value: `${ctx.pdfTextWordsCount} word(s)`, sub: `page=${ctx.pdfTextPage || 1}${sz ? `, ${sz}` : ''}` });
        }
        summaryItems.push({ label: 'Mode', value: ctx.hasCrop ? 'Region (Crop)' : 'Full pages', sub: _describeProcessCropMode(ctx) });
        summaryItems.push({ label: 'Total Time', value: `${(msTotal/1000).toFixed(1)} seconds`, sub: `steps: ${_processReport.steps.length}, Vectorize: ${_processReport.vectorizeCalls.length}` });
        summaryItems.push({ label: 'Results', value: `OK: ${okCount} | ERR: ${errCount}`, sub: `SVG size: ${formatBytes(totalBytes)}` });
        if (typeof ctx.fileArrayBufferBytes === 'number' && typeof ctx.fileSizeBytes === 'number' && ctx.fileArrayBufferBytes !== ctx.fileSizeBytes) {
            summaryItems.push({ label: 'Warning', value: 'File size mismatch', sub: `size=${ctx.fileSizeBytes}, arrayBuffer=${ctx.fileArrayBufferBytes}` });
        }
        setSummaryItems(summaryItems);

        processReportText.textContent = lines.join('\n');
        processReportCard.classList.remove('hidden');
        resultsSection.classList.remove('hidden');
    }

