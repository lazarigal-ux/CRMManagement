                const cleanupSvgRoot = cleanupDoc.querySelector('svg');
                if (!cleanupSvgRoot) throw new Error('Failed to parse SVG for conservative cleanup.');
                const cleanupResult = applyConservativeCleanup(cleanupSvgRoot, {
                    cropViewBox: payload.cropViewBox,
                    debugMode: !!_svgAiCandidateDebugEnabled,
                    enableUnsureBucket: true,
                    deleteSmallWhiteFills: true,
                    detectHatches: true,
                    keepStructuralStrokes: true
                });
                const aiSvg = new XMLSerializer().serializeToString(cleanupSvgRoot);
                const localObj = {
                    ok: true,
                    traceId: requestTraceId,
                    provider: 'local-conservative',
                    model: 'conservative-js-cleanup',
                    svgContent: aiSvg,
                    diagnostics: cleanupResult.diagnostics,
                    removedCount: cleanupResult.removedCount,
                    keptCount: cleanupResult.keptCount,
                    unsureCount: cleanupResult.unsureCount,
                    warning: cleanupResult.warning || ''
                };
                try {
                    console.groupCollapsed(`[AI ACTION RESPONSE ${requestTraceId}]`);
                    console.log('status', 'local-cleanup');
                    console.log('traceId', requestTraceId);
                    console.log('parsedBody', localObj);
                    console.log('diagnostics', cleanupResult.diagnostics);
                    console.log('summary', serializeCleanupDiagnostics(cleanupResult.diagnostics));
                    console.groupEnd();
                } catch { /* ignore */ }
                if (!aiSvg || !aiSvg.includes('<svg')) throw new Error('Conservative cleanup did not produce a valid SVG document.');
                const _logSentCount = countSvgObjects(String(r.svgContent || ''));
                const _logResultCount = countSvgObjects(aiSvg);
                const _logDeletedCount = Math.max(0, _logSentCount - _logResultCount);
                console.log(
                    `%c[AI ACTION]%c sent=${_logSentCount}  deleted=${_logDeletedCount}  remaining=${_logResultCount}  provider=local-conservative  model=conservative-js-cleanup  action=${payload.action}`,
                    'background:#7c3aed;color:#fff;padding:2px 6px;border-radius:3px;font-weight:bold',
                    'color:#7c3aed;font-weight:bold'
                );
                const resultNameBase = r.isLayer ? String(r.layerName || 'Layer') : `Page ${Math.max(1, Number(r.pageNumber || 1) | 0)}`;
                const _actionLabel = _getAiActionButtonLabel ? _getAiActionButtonLabel() : 'AI';
                const aiResult = {
                    pageNumber: Math.max(1, Number(r.pageNumber || 1) | 0),
                    isLayer: true,
                    layerName: `${resultNameBase} — ${_actionLabel}`,
                    layerColor: '#111111',
                    layerIcon: 'fa-wand-magic-sparkles',
                    svgContent: aiSvg,
                    svgSizeBytes: new Blob([aiSvg]).size,
                    objectCount: _logResultCount,
                    aiProvider: 'local-conservative',
                    aiModel: 'conservative-js-cleanup',
                    aiDiagnostics: cleanupResult.diagnostics,
                    aiWarning: cleanupResult.warning || '',
                    sourceResultIndex: idx
                };
                pageResults.push(aiResult);
                addResultCard(pageResults.length - 1);
                resultsSection.classList.remove('hidden');
                setSplitMainTab('svgSplit');
                if (cleanupResult.warning) {
                    try { console.warn(`[AI ACTION RESPONSE ${requestTraceId}] warning`, cleanupResult.warning, cleanupResult.diagnostics); } catch { /* ignore */ }
                }
                if (options && options.openPreview) {
                    requestAnimationFrame(() => {
                        try {
                            const previewBtn = resultsGrid ? resultsGrid.querySelector(`.page-card[data-idx="${pageResults.length - 1}"] .btn-preview`) : null;
                            previewBtn?.click();
                        } catch { /* ignore */ }
                    });
