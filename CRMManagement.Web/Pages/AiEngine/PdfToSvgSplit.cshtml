    }

    function _cleanupExtractPathPoints(d) {
        const tokens = String(d || '').match(/[AaCcHhLlMmQqSsTtVvZz]|[-+]?(?:\d*\.\d+|\d+)(?:[eE][-+]?\d+)?/g) || [];
        const pts = [];
