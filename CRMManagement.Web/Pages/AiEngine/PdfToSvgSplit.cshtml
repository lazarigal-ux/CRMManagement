            for (const cb of cancelBtns) {
                cb.addEventListener('click', () => { if (_similarPreviewSignatures) _clearSimilarPreview(); }, true);
            }
            // Also cancel on Escape
            document.addEventListener('keydown', (e) => {
                if (e.key === 'Escape' && _similarPreviewSignatures) _clearSimilarPreview();
            });
