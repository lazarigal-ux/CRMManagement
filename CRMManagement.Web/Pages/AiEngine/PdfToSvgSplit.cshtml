    function _applyMergedSvgTransform() {
        if (!mergedSvgPreviewScale) return;
        // Native SVG sizing for crisp vector zoom (no CSS scale blur)
        const svg = mergedSvgPreviewScale.querySelector('svg');
        if (svg && _mergedSvgBaseSize) {
            svg.setAttribute('width',  _mergedSvgBaseSize.width  * _mergedSvgZoom);
            svg.setAttribute('height', _mergedSvgBaseSize.height * _mergedSvgZoom);
        }
        mergedSvgPreviewScale.style.transform = `translate(${_mergedSvgPanX}px, ${_mergedSvgPanY}px)`;
        if (mergedSvgZoomLabel) mergedSvgZoomLabel.textContent = `${Math.round(_mergedSvgZoom * 100)}%`;
    }

    function _getMergedSvgTypeLabel(tagName) {
        const tag = String(tagName || '').toLowerCase();
        if (tag.startsWith('group:')) {
            const familyKey = tag.substring('group:'.length);
            const meta = _getFamilyTypeMeta(familyKey, familyKey);
            return `GROUP · ${(meta.optionLabel || meta.label || familyKey).toUpperCase()}`;
        }
        switch (tag) {
            case 'path': return 'PATH';
            case 'line': return 'LINE';
            case 'polyline': return 'POLYLINE';
            case 'polygon': return 'POLYGON';
            case 'rect': return 'RECT';
            case 'circle': return 'CIRCLE';
            case 'ellipse': return 'ELLIPSE';
            case 'text': return 'TEXT';
            case 'image': return 'IMAGE';
            case 'use': return 'USE';
            default: return tag ? tag.toUpperCase() : 'OTHER';
        }
    }

    function _collectMergedSvgLegendCounts(svg) {
        const counts = new Map();
        if (!svg) return counts;

        const groupedRoots = [...svg.querySelectorAll('g[data-family]')].filter(el => {
            try { return !(el.closest && el.closest('defs')); } catch { return true; }
        });
        for (const groupEl of groupedRoots) {
            const familyKey = String(groupEl.getAttribute('data-family') || 'other').trim().toLowerCase() || 'other';
            const groupTag = `group:${familyKey}`;
            counts.set(groupTag, (counts.get(groupTag) || 0) + 1);
        }

        for (const el of svg.querySelectorAll(_SHAPE_SELECTOR)) {
            try {
                if (el.closest && el.closest('defs')) continue;
                if (el.closest && el.closest('g[data-family]')) continue;
            } catch { /* ignore */ }
            const tag = String(el.localName || el.tagName || '').toLowerCase();
            if (!tag) continue;
            counts.set(tag, (counts.get(tag) || 0) + 1);
        }

        return counts;
    }

    async function _ensureFamilySelectionForType(typeKey) {
        const meta = _getFamilyTypeMeta(typeKey, typeKey);
        const targetType = meta.key;
        console.log('[EnsureFamily] START typeKey=%s → targetType=%s, familySelect=%s', typeKey, targetType, !!familySelect);
        if (!targetType || !familySelect) return false;
        const currentType = _getSelectedFamilyTypeKey();
        const curId = _getSelectedFamilyId();
        console.log('[EnsureFamily] currentType=%s, currentId=%s', currentType, curId);
        if (curId && currentType === targetType) { console.log('[EnsureFamily] already selected'); return true; }

        // Step 1: load families (use cache if fresh)
        let fams = await loadObjectFamilies(false);
        console.log('[EnsureFamily] loaded %d families (cached). Types: %s', Array.isArray(fams) ? fams.length : -1,
            Array.isArray(fams) ? fams.map(f => `${f.id}:${f.name}:${f.typeKey}`).join(', ') : 'N/A');

        // Step 2: try to find by typeKey match
        let match = Array.isArray(fams) ? fams.find(f => _getFamilyTypeMeta(f && f.typeKey, f && f.name).key === targetType) : null;
        // Also try matching by name (fallback for DB families whose stored typeKey differs)
        if (!match) {
            const targetLabel = (meta.label || '').toLowerCase();
            match = Array.isArray(fams) ? fams.find(f => {
                const n = String(f && f.name || '').trim().toLowerCase();
                return n === targetType || n === targetLabel;
            }) : null;
            if (match) console.log('[EnsureFamily] matched by name fallback: id=%s name=%s typeKey=%s', match.id, match.name, match.typeKey);
        }
        console.log('[EnsureFamily] initial match=%s', match ? `id=${match.id} name=${match.name} typeKey=${match.typeKey}` : 'null');

        // Step 3: auto-create if not found
        if (!match || !match.id) {
            try {
                const familyName = meta.label || (targetType.charAt(0).toUpperCase() + targetType.slice(1));
                console.log('[EnsureFamily] POST create name=%s typeKey=%s', familyName, targetType);
                const resp = await fetch(OBJECT_FAMILIES_ENDPOINT, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json', 'X-Client-Id': 'admin' },
                    body: JSON.stringify({ name: familyName, typeKey: targetType, symbolKey: meta.primarySymbol || 'generic' })
                });
                console.log('[EnsureFamily] POST status=%d ok=%s', resp.status, resp.ok);
                if (resp.ok) {
                    const obj = await resp.json().catch(() => null);
                    const newId = obj && Number.isFinite(Number(obj.id)) ? (Number(obj.id) | 0) : 0;
                    console.log('[EnsureFamily] created newId=%d', newId);
                    fams = await loadObjectFamilies(true);
                    match = newId > 0
                        ? (Array.isArray(fams) ? fams.find(f => Number(f && f.id) === newId) : null)
                        : (Array.isArray(fams) ? fams.find(f => _getFamilyTypeMeta(f && f.typeKey, f && f.name).key === targetType) : null);
                } else {
                    // Family exists on server — force-reload and find it
                    const errText = await resp.text().catch(() => '');
                    console.warn('[EnsureFamily] POST failed: %s — force-reloading families', errText);
                    fams = await loadObjectFamilies(true);
                    console.log('[EnsureFamily] reloaded %d families. Types: %s', Array.isArray(fams) ? fams.length : -1,
                        Array.isArray(fams) ? fams.map(f => `${f.id}:${f.name}:${f.typeKey}`).join(', ') : 'N/A');
                    // Match by typeKey
                    match = Array.isArray(fams) ? fams.find(f => _getFamilyTypeMeta(f && f.typeKey, f && f.name).key === targetType) : null;
                    // Fallback: match by name
                    if (!match) {
                        const targetLabel = (meta.label || '').toLowerCase();
                        match = Array.isArray(fams) ? fams.find(f => {
                            const n = String(f && f.name || '').trim().toLowerCase();
                            return n === targetType || n === targetLabel;
                        }) : null;
                        if (match) console.log('[EnsureFamily] fallback name-match after POST fail: id=%s', match.id);
                    }
                    console.log('[EnsureFamily] after reload match=%s', match ? `id=${match.id} name=${match.name} typeKey=${match.typeKey}` : 'null');
                }
            } catch (ex) {
                console.error('[EnsureFamily] exception during auto-create:', ex);
                // Last resort: force-reload
                try {
                    fams = await loadObjectFamilies(true);
                    match = Array.isArray(fams) ? fams.find(f => _getFamilyTypeMeta(f && f.typeKey, f && f.name).key === targetType) : null;
                    if (!match) {
                        const targetLabel = (meta.label || '').toLowerCase();
                        match = Array.isArray(fams) ? fams.find(f => {
                            const n = String(f && f.name || '').trim().toLowerCase();
                            return n === targetType || n === targetLabel;
                        }) : null;
                    }
                } catch { /* truly nothing we can do */ }
            }
        }

        // Step 4: final fallback — unconditional reload
        if (!match || !match.id) {
            console.warn('[EnsureFamily] still no match, final unconditional reload');
            try {
                fams = await loadObjectFamilies(true);
                match = Array.isArray(fams) ? fams.find(f => _getFamilyTypeMeta(f && f.typeKey, f && f.name).key === targetType) : null;
                if (!match) {
                    const targetLabel = (meta.label || '').toLowerCase();
                    match = Array.isArray(fams) ? fams.find(f => {
                        const n = String(f && f.name || '').trim().toLowerCase();
                        return n === targetType || n === targetLabel;
                    }) : null;
                }
            } catch { /* ignore */ }
        }

        console.log('[EnsureFamily] FINAL match=%s', match ? `id=${match.id} name=${match.name} typeKey=${match.typeKey}` : 'null');
        if (!match || !match.id) return false;
        familySelect.value = String(match.id);
        _rememberSelectedFamilyId(familySelect.value || '');
        _syncFamilyTypeBadge();
        familySelect.dispatchEvent(new Event('change'));
        return true;
    }

    function _analyzeMergedSvgLegend(svgText) {
        try {
            if (!svgText || typeof svgText !== 'string') return [];
            const doc = new DOMParser().parseFromString(svgText, 'image/svg+xml');
            const svg = doc.querySelector('svg');
            if (!svg) return [];
            const counts = _collectMergedSvgLegendCounts(svg);
            const order = ['path', 'line', 'polyline', 'polygon', 'rect', 'circle', 'ellipse', 'text', 'image', 'use', 'group:lighting', 'group:emergency-lighting', 'group:camera', 'group:suppression', 'group:access-control', 'group:intrusion', 'group:communication', 'group:automation', 'group:other'];
            return [...counts.entries()]
                .map(([tag, count]) => ({ tag, label: _getMergedSvgTypeLabel(tag), count: Number(count) || 0 }))
                .sort((a, b) => {
                    const ai = order.indexOf(a.tag);
                    const bi = order.indexOf(b.tag);
                    if (ai >= 0 || bi >= 0) {
                        if (ai < 0) return 1;
                        if (bi < 0) return -1;
                        if (ai !== bi) return ai - bi;
                    }
                    return b.count - a.count || a.label.localeCompare(b.label);
                });
        } catch {
            return [];
        }
    }

    function _getMergedSvgActiveTagSet() {
        return new Set((_pdfPreSplitMergedFilterTags || []).map(x => String(x || '').toLowerCase()).filter(Boolean));
    }

    function _getDefaultMergedSvgFilterTags(items) {
        const rows = Array.isArray(items) ? items : [];
        const allTags = rows.map(item => String(item && item.tag || '').toLowerCase()).filter(Boolean);
        const vectorTags = allTags.filter(tag => tag !== 'image');
        return vectorTags.length ? vectorTags : allTags;
    }

    function _makeSvgInstancePrefix(label) {
        const base = String(label || 'svg').replace(/[^a-z0-9_-]+/gi, '_') || 'svg';
        return `${base}_${Date.now().toString(36)}_${Math.random().toString(36).slice(2, 8)}`;
    }

    function _prefixSvgIds(svgText, prefix) {
        try {
            if (!svgText || typeof svgText !== 'string') return svgText;
            const idPrefix = String(prefix || '').trim();
            if (!idPrefix) return svgText;

            const doc = new DOMParser().parseFromString(svgText, 'image/svg+xml');
            const svg = doc.querySelector('svg');
            if (!svg) return svgText;

            const idMap = new Map();
            for (const el of svg.querySelectorAll('[id]')) {
                const rawId = String(el.getAttribute('id') || '').trim();
                if (!rawId || idMap.has(rawId)) continue;
                idMap.set(rawId, `${idPrefix}_${rawId.replace(/[^a-z0-9_:-]+/gi, '_')}`);
            }
            if (!idMap.size) return svgText;

            for (const el of svg.querySelectorAll('[id]')) {
                const rawId = String(el.getAttribute('id') || '').trim();
                const nextId = rawId ? idMap.get(rawId) : '';
                if (nextId) el.setAttribute('id', nextId);
            }

            const rewriteUrlRefs = (value) => String(value || '').replace(/url\(\s*#([^)\s]+)\s*\)/g, (m, id) => {
                const nextId = idMap.get(String(id || '').trim());
                return nextId ? `url(#${nextId})` : m;
            });

            const rewriteHref = (value) => {
                const raw = String(value || '').trim();
                if (!raw.startsWith('#')) return raw;
                const nextId = idMap.get(raw.slice(1));
                return nextId ? `#${nextId}` : raw;
            };

            const refAttrs = ['href', 'xlink:href', 'fill', 'stroke', 'filter', 'mask', 'clip-path', 'marker-start', 'marker-mid', 'marker-end'];
            for (const el of svg.querySelectorAll('*')) {
                for (const attr of refAttrs) {
                    const raw = el.getAttribute(attr);
                    if (!raw) continue;
                    const next = (attr === 'href' || attr === 'xlink:href') ? rewriteHref(raw) : rewriteUrlRefs(raw);
                    if (next !== raw) el.setAttribute(attr, next);
                }

                const style = el.getAttribute('style');
                if (style) {
                    const nextStyle = rewriteUrlRefs(style);
                    if (nextStyle !== style) el.setAttribute('style', nextStyle);
                }
            }

            for (const styleEl of svg.querySelectorAll('style')) {
                const rawCss = String(styleEl.textContent || '');
                if (!rawCss) continue;
                let nextCss = rawCss;
                for (const [oldId, newId] of idMap.entries()) {
                    nextCss = nextCss.replace(new RegExp(`([#.])${oldId}(?=[^a-zA-Z0-9_:-]|$)`, 'g'), `$1${newId}`);
                }
                nextCss = rewriteUrlRefs(nextCss);
                if (nextCss !== rawCss) styleEl.textContent = nextCss;
            }

            return new XMLSerializer().serializeToString(svg);
        } catch {
            return svgText;
        }
    }

    function _renderMergedSvgLegend() {
        const items = Array.isArray(_pdfPreSplitMergedLegend) ? _pdfPreSplitMergedLegend : [];
        const active = _getMergedSvgActiveTagSet();
        const total = items.reduce((sum, item) => sum + (Number(item && item.count) || 0), 0);
        const visible = items.reduce((sum, item) => sum + (active.has(item.tag) ? (Number(item && item.count) || 0) : 0), 0);
        const hiddenCount = total - visible;
        const hasHiddenRasterImages = items.some(item => item && item.tag === 'image') && !active.has('image');
        if (mergedSvgLegendSummary) {
            mergedSvgLegendSummary.textContent = items.length
                ? `Visible ${formatInt(visible)} / ${formatInt(total)} object(s) across ${items.length} type(s)${hasHiddenRasterImages ? ' · IMAGE hidden for sharp zoom' : ''}`
                : 'No SVG stats yet.';
        }
        if (btnMergedSvgFilterAll) btnMergedSvgFilterAll.disabled = !items.length;
        if (btnMergedSvgFilterNone) btnMergedSvgFilterNone.disabled = !items.length;
        const btnDel = document.getElementById('btnMergedSvgDeleteHidden');
        if (btnDel) btnDel.disabled = !(hiddenCount > 0);
        if (!mergedSvgLegendChips) return;
        if (!items.length) {
            mergedSvgLegendChips.innerHTML = '<div class="text-[11px] text-slate-500">No element types detected yet.</div>';
            return;
        }
        mergedSvgLegendChips.innerHTML = items.map(item => {
            const isActive = active.has(item.tag);
            const deleteIcon = isActive ? '' : `<i class="fa-solid fa-trash-can chip-delete-icon" data-svg-delete-tag="${escapeHtml(item.tag)}" title="Delete all ${escapeHtml(item.label)} elements permanently"></i>`;
            return `<button type="button" class="merged-svg-legend-chip ${isActive ? 'is-active' : 'is-inactive'}" data-svg-tag="${escapeHtml(item.tag)}" aria-pressed="${isActive ? 'true' : 'false'}"><span>${escapeHtml(item.label)}</span><span class="merged-svg-legend-count">${escapeHtml(formatInt(item.count))}</span>${deleteIcon}</button>`;
        }).join('');
    }

    function _deleteMergedSvgElementsByTags(tagsToDelete) {
        try {
            if (!_pdfPreSplitMergedSvg || !tagsToDelete || !tagsToDelete.length) return;
            const delSet = new Set(tagsToDelete.map(t => String(t || '').toLowerCase()).filter(Boolean));
            if (!delSet.size) return;
            const doc = new DOMParser().parseFromString(_pdfPreSplitMergedSvg, 'image/svg+xml');
            const svg = doc.querySelector('svg');
            if (!svg) return;
            let removed = 0;
            const toRemove = [];
            for (const el of svg.querySelectorAll('g[data-family], ' + _SHAPE_SELECTOR)) {
                try { if (el.closest && el.closest('defs')) continue; } catch { /* ignore */ }
                let tag = String(el.localName || el.tagName || '').toLowerCase();
                if (tag === 'g' && el.hasAttribute('data-family')) {
                    tag = `group:${String(el.getAttribute('data-family') || 'other').trim().toLowerCase() || 'other'}`;
                } else if (el.closest && el.closest('g[data-family]')) {
                    continue;
                }
                if (delSet.has(tag)) toRemove.push(el);
            }
            for (const el of toRemove) {
                el.parentNode.removeChild(el);
                removed++;
            }
            if (!removed) return;
            _pdfPreSplitMergedSvg = new XMLSerializer().serializeToString(doc);
            // Re-analyze legend & rebuild filter tags (remove deleted types)
            _pdfPreSplitMergedLegend = _analyzeMergedSvgLegend(_pdfPreSplitMergedSvg);
            _pdfPreSplitMergedFilterTags = _pdfPreSplitMergedLegend.map(item => item.tag);
            _renderPreSplitMergedPreview();
            console.log(`[PdfToSvgSplit] Deleted ${removed} elements of type(s): ${[...delSet].join(', ')}`);
        } catch (err) {
            console.error('[PdfToSvgSplit] Delete elements error:', err);
        }
    }

    function _buildFilteredMergedSvg(svgText) {
        try {
            if (!svgText || typeof svgText !== 'string') return '';
            const items = Array.isArray(_pdfPreSplitMergedLegend) ? _pdfPreSplitMergedLegend : [];
            const active = _getMergedSvgActiveTagSet();
            if (!items.length) return svgText;
            if (active.size === items.length) return svgText;
            const doc = new DOMParser().parseFromString(svgText, 'image/svg+xml');
            const svg = doc.querySelector('svg');
            if (!svg) return svgText;
            for (const groupEl of svg.querySelectorAll('g[data-family]')) {
                try { if (groupEl.closest && groupEl.closest('defs')) continue; } catch { /* ignore */ }
                const groupTag = `group:${String(groupEl.getAttribute('data-family') || 'other').trim().toLowerCase() || 'other'}`;
                if (!active.has(groupTag)) groupEl.setAttribute('display', 'none');
                else groupEl.removeAttribute('display');
            }
            for (const el of svg.querySelectorAll(_SHAPE_SELECTOR)) {
                try {
                    if (el.closest && el.closest('defs')) continue;
                    if (el.closest && el.closest('g[data-family]')) continue;
                } catch { /* ignore */ }
                const tag = String(el.localName || el.tagName || '').toLowerCase();
                if (!tag) continue;
                if (!active.has(tag)) el.setAttribute('display', 'none');
                else el.removeAttribute('display');
            }
            return new XMLSerializer().serializeToString(doc);
        } catch {
            return svgText;
        }
    }

    function _computeMergedSvgBaseSize() {
        if (!mergedSvgPreviewScale) return null;
        const svg = mergedSvgPreviewScale.querySelector('svg');
        if (svg) {
            const vb = svg.viewBox && svg.viewBox.baseVal ? svg.viewBox.baseVal : null;
            if (vb && isFinite(vb.width) && vb.width > 0 && isFinite(vb.height) && vb.height > 0) {
                return { width: vb.width, height: vb.height };
            }
            const w = svg.width && svg.width.baseVal ? svg.width.baseVal.value : NaN;
            const h = svg.height && svg.height.baseVal ? svg.height.baseVal.value : NaN;
            if (isFinite(w) && w > 0 && isFinite(h) && h > 0) {
                return { width: w, height: h };
            }
        }
        return null;
    }

    function _getMergedSvgPreviewContentSize() {
        if (_mergedSvgBaseSize) return _mergedSvgBaseSize;
        return _computeMergedSvgBaseSize();
    }

    function _setMergedSvgZoom(nextZoom, anchorX, anchorY) {
        if (!mergedSvgPreviewViewport || !mergedSvgPreviewScale || !_pdfPreSplitMergedSvg) return;
        const prevZoom = Math.max(_mergedSvgZoom || 1, 0.05);
        const newZoom = Math.min(50, Math.max(0.1, Number(nextZoom) || 1));
        const ax = isFinite(anchorX) ? anchorX : (mergedSvgPreviewViewport.clientWidth / 2);
        const ay = isFinite(anchorY) ? anchorY : (mergedSvgPreviewViewport.clientHeight / 2);
        const worldX = (ax - _mergedSvgPanX) / prevZoom;
        const worldY = (ay - _mergedSvgPanY) / prevZoom;
        _mergedSvgZoom = newZoom;
        _mergedSvgPanX = ax - (worldX * newZoom);
        _mergedSvgPanY = ay - (worldY * newZoom);
        _applyMergedSvgTransform();
    }

    function _fitMergedSvgPreview() {
        if (!mergedSvgPreviewViewport || !mergedSvgPreviewScale) return;
        const size = _getMergedSvgPreviewContentSize();
        if (!size || !(size.width > 0) || !(size.height > 0)) {
            _mergedSvgZoom = 1;
            _mergedSvgPanX = 0;
            _mergedSvgPanY = 0;
            _applyMergedSvgTransform();
            return;
        }
        const vw = Math.max(mergedSvgPreviewViewport.clientWidth - 24, 80);
        const vh = Math.max(mergedSvgPreviewViewport.clientHeight - 24, 80);
        _mergedSvgZoom = Math.min(vw / size.width, vh / size.height, 1);
        _mergedSvgPanX = Math.max(0, (mergedSvgPreviewViewport.clientWidth - (size.width * _mergedSvgZoom)) / 2);
        _mergedSvgPanY = Math.max(0, (mergedSvgPreviewViewport.clientHeight - (size.height * _mergedSvgZoom)) / 2);
        _applyMergedSvgTransform();
    }

    function _stopMergedSvgPan() {
        _mergedSvgPanning = false;
        if (mergedSvgPreviewViewport) mergedSvgPreviewViewport.classList.remove('is-panning');
    }

    function _beginMergedSvgPan(e) {
        if (!mergedSvgPreviewViewport || !mergedSvgPreviewScale || !_pdfPreSplitMergedSvg) return;
        if (e.button !== 0) return;
        const tag = (e.target && e.target.tagName ? e.target.tagName : '').toLowerCase();
        if (tag === 'button' || tag === 'select' || tag === 'input' || tag === 'option') return;
        // When Select Mode is active, don't start panning – let click handler work
        if (mergedSvgPreviewViewport.classList.contains('select-mode')) return;
        _mergedSvgPanning = true;
        _mergedSvgPanDragStartX = e.clientX;
        _mergedSvgPanDragStartY = e.clientY;
        _mergedSvgPanStartX = _mergedSvgPanX;
        _mergedSvgPanStartY = _mergedSvgPanY;
        mergedSvgPreviewViewport.classList.add('is-panning');
        e.preventDefault();
    }

    function _moveMergedSvgPan(e) {
        if (!_mergedSvgPanning) return;
        _mergedSvgPanX = _mergedSvgPanStartX + (e.clientX - _mergedSvgPanDragStartX);
        _mergedSvgPanY = _mergedSvgPanStartY + (e.clientY - _mergedSvgPanDragStartY);
        _applyMergedSvgTransform();
        e.preventDefault();
    }

    function _clearPreSplitMergedPreview() {
        _pdfPreSplitMergedSvg = '';
        _pdfPreSplitMergedLabel = '';
        _pdfPreSplitMergedStats = null;
        _pdfPreSplitMergedLegend = [];
        _pdfPreSplitMergedFilterTags = [];
        _setMergedSvgDebugReport(null);
        _mergedSvgZoom = 1;
        _mergedSvgPanX = 0;
        _mergedSvgPanY = 0;
        _mergedSvgBaseSize = null;
        if (btnMergedSvgTab) btnMergedSvgTab.classList.add('hidden');
        if (mergedSvgPreviewSummary) mergedSvgPreviewSummary.textContent = 'Run Merge Before Split to generate a merged SVG preview.';
        if (mergedSvgLegendSummary) mergedSvgLegendSummary.textContent = 'No SVG stats yet.';
        if (mergedSvgLegendChips) mergedSvgLegendChips.innerHTML = '<div class="text-[11px] text-slate-500">No element types detected yet.</div>';
        if (mergedSvgPreviewScale) mergedSvgPreviewScale.innerHTML = '<div class="text-sm text-slate-500">No merged SVG generated yet.</div>';
        _applyMergedSvgTransform();
        if (btnDownloadMergedSvg) btnDownloadMergedSvg.disabled = true;
        if (btnMergedSvgZoomOut) btnMergedSvgZoomOut.disabled = true;
        if (btnMergedSvgZoomFit) btnMergedSvgZoomFit.disabled = true;
        if (btnMergedSvgZoomIn) btnMergedSvgZoomIn.disabled = true;
        if (btnMergedSvgFilterAll) btnMergedSvgFilterAll.disabled = true;
        if (btnMergedSvgFilterNone) btnMergedSvgFilterNone.disabled = true;
        { const _bd = document.getElementById('btnMergedSvgDeleteHidden'); if (_bd) _bd.disabled = true; }
        if (_splitMainTab === 'mergedSvg') {
            _splitMainTab = 'pdfPreview';
            _applySplitMainTab();
        }
    }

    function _renderPreSplitMergedPreview() {
        if (!mergedSvgPreviewScale) return;
        if (!_pdfPreSplitMergedSvg) {
            mergedSvgPreviewScale.innerHTML = '<div class="text-sm text-slate-500">No merged SVG generated yet.</div>';
            if (btnMergedSvgTab) btnMergedSvgTab.classList.add('hidden');
            if (btnDownloadMergedSvg) btnDownloadMergedSvg.disabled = true;
            if (btnMergedSvgZoomOut) btnMergedSvgZoomOut.disabled = true;
            if (btnMergedSvgZoomFit) btnMergedSvgZoomFit.disabled = true;
            if (btnMergedSvgZoomIn) btnMergedSvgZoomIn.disabled = true;
            if (btnMergedSvgFilterAll) btnMergedSvgFilterAll.disabled = true;
            if (btnMergedSvgFilterNone) btnMergedSvgFilterNone.disabled = true;
            { const _bd = document.getElementById('btnMergedSvgDeleteHidden'); if (_bd) _bd.disabled = true; }
            // Disable Group Objects toolbar buttons
            document.dispatchEvent(new CustomEvent('mergedSvgReady', { detail: { hasSvg: false } }));
            _mergedSvgZoom = 1;
            _mergedSvgPanX = 0;
            _mergedSvgPanY = 0;
            _renderMergedSvgLegend();
            _applyMergedSvgTransform();
            return;
        }
        if (btnMergedSvgTab) btnMergedSvgTab.classList.remove('hidden');
        if (btnDownloadMergedSvg) btnDownloadMergedSvg.disabled = false;
        if (btnMergedSvgZoomOut) btnMergedSvgZoomOut.disabled = false;
        if (btnMergedSvgZoomFit) btnMergedSvgZoomFit.disabled = false;
        if (btnMergedSvgZoomIn) btnMergedSvgZoomIn.disabled = false;
        // Enable Group Objects toolbar buttons
        document.dispatchEvent(new CustomEvent('mergedSvgReady', { detail: { hasSvg: true } }));
        _renderMergedSvgLegend();
        if (mergedSvgPreviewSummary) {
            const st = _pdfPreSplitMergedStats || {};
            mergedSvgPreviewSummary.textContent = `${_pdfPreSplitMergedLabel || 'Merged SVG'} · groups=${st.mergedGroups ?? '?'} · paths ${st.pathCountBefore ?? '?'} → ${st.pathCountAfter ?? '?'} · ${formatBytes(new Blob([_pdfPreSplitMergedSvg]).size)}`;
        }
        const filteredSvg = _buildFilteredMergedSvg(_pdfPreSplitMergedSvg) || _pdfPreSplitMergedSvg;
        mergedSvgPreviewScale.innerHTML = filteredSvg;
        _mergedSvgBaseSize = _computeMergedSvgBaseSize();
        _mergedSvgZoom = 1;
        _mergedSvgPanX = 0;
        _mergedSvgPanY = 0;
        _applyMergedSvgTransform();
        requestAnimationFrame(() => {
            try { _fitMergedSvgPreview(); } catch { /* ignore */ }
        });
    }

    async function _generatePreSplitMergedPreview() {
        const file = pdfFileInput.files && pdfFileInput.files[0];
        if (!file) { showError('Please select a PDF file first.'); return; }

        _syncOutputCropFromSelections();
        const hasOutputCrop = !!(outputCrop && outputCrop.frac && isFinite(outputCrop.frac.w) && outputCrop.frac.w > 0 && isFinite(outputCrop.frac.h) && outputCrop.frac.h > 0);
        const outputCropFrac = hasOutputCrop ? outputCrop.frac : null;

        const prevHtml = btnPreSplitMerge ? btnPreSplitMerge.innerHTML : '';
        if (btnPreSplitMerge) {
            btnPreSplitMerge.disabled = true;
            btnPreSplitMerge.classList.add('premerge-btn-busy');
            btnPreSplitMerge.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Merging...';
        }

        try {
            _setPreSplitMergeEnabled(true);
            const fd = new FormData();
            fd.append('pdf', file, file.name);
            const resp = await fetch(VECTOR_PDF_SVG_ENDPOINT, {
                method: 'POST',
                body: fd,
                headers: { 'X-Client-Id': 'admin' }
            });
            if (!resp.ok) {
                const errText = await resp.text();
                throw new Error(`Vector SVG failed: HTTP ${resp.status} ${String(errText || '').slice(0, 300)}`);
            }

            let svgContent = await resp.text();
            const svgContentFull = svgContent;
            const debugEntries = [];
            const addDebugEntry = (label, svg) => {
                const text = String(svg || '');
                debugEntries.push({
                    label,
                    byteLength: text ? new Blob([text]).size : 0,
                    diag: _analyzeSvgUseDiagnostics(text)
                });
            };
            addDebugEntry('vector-source', svgContent);
            if (hasOutputCrop && outputCropFrac) {
                try { svgContent = cropSvgByFraction(svgContent, outputCropFrac); } catch { }
                addDebugEntry('vector-cropped', svgContent);
            }

            const mergeResp = await fetch(SHAPELY_MERGE_ENDPOINT, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ svgContent })
            });
            if (!mergeResp.ok) {
                const errText = await mergeResp.text();
                throw new Error(`Merge failed: HTTP ${mergeResp.status} ${String(errText || '').slice(0, 300)}`);
            }
            const data = await mergeResp.json();
            let mergedSvgRaw = String(data?.svgContent || svgContent || '');
            addDebugEntry('merged-server', mergedSvgRaw);

            try {
                const pageNumber = Math.max(1, Number(outputCrop && Number.isFinite(outputCrop.pageIndex) ? (Number(outputCrop.pageIndex) + 1) : 1) || 1);
                const originalSvgMetrics = _getSvgRootMetrics(svgContentFull);
                const textData = await _fetchPdfTextWordsForPage(file, pageNumber);
                const textWords = Array.isArray(textData && textData.words) ? textData.words : [];
                const textMeta = textData && textData.meta ? textData.meta : {};
                if (textWords.length > 0 && originalSvgMetrics) {
                    let textOverlaySvg = await buildPdfBboxTextLayerSvg(textWords, textMeta, originalSvgMetrics.vb, originalSvgMetrics.w, originalSvgMetrics.h, { useProvidedWords: true, preferVectorText: true });
                    if (hasOutputCrop && outputCropFrac && textOverlaySvg) {
                        try { textOverlaySvg = cropSvgByFraction(textOverlaySvg, outputCropFrac); } catch { /* ignore */ }
                    }
                    if (textOverlaySvg) {
                        mergedSvgRaw = _appendSvgOverlay(mergedSvgRaw, textOverlaySvg);
                        addDebugEntry('merged-with-pdf-text-overlay', mergedSvgRaw);
                    }
                }
            } catch (overlayErr) {
                reportStep('Merge SVG text overlay fallback failed', { detail: String(overlayErr || '') });
            }

            _pdfPreSplitMergedSvg = _prefixSvgIds(mergedSvgRaw, _makeSvgInstancePrefix('mergedsvg'));
            addDebugEntry('merged-prefixed', _pdfPreSplitMergedSvg);
            _setMergedSvgDebugReport({
                createdAt: Date.now(),
                cropText: hasOutputCrop && outputCropFrac ? _formatCropFractionForReport(outputCropFrac, Number.isFinite(outputCrop?.pageIndex) ? Number(outputCrop.pageIndex) : -1) : '',
                entries: debugEntries
            });
            _pdfPreSplitMergedLabel = hasOutputCrop ? 'Merged SVG (cropped)' : 'Merged SVG';
            _pdfPreSplitMergedStats = {
                mergedGroups: data?.mergedGroups ?? 0,
                pathCountBefore: data?.pathCountBefore ?? 0,
                pathCountAfter: data?.pathCountAfter ?? 0
            };
            reportStep('Merge SVG diagnostics', {
                stages: debugEntries.map(x => ({
                    label: x.label,
                    use: x.diag && Number.isFinite(x.diag.useCount) ? x.diag.useCount : 0,
                    text: x.diag && Number.isFinite(x.diag.textCount) ? x.diag.textCount : 0,
                    missingTargets: x.diag && Number.isFinite(x.diag.useMissingTarget) ? x.diag.useMissingTarget : 0,
                    nsHref: x.diag && Number.isFinite(x.diag.nsHrefCount) ? x.diag.nsHrefCount : 0
                }))
            });
            _pdfPreSplitMergedLegend = _analyzeMergedSvgLegend(_pdfPreSplitMergedSvg);
            _pdfPreSplitMergedFilterTags = _getDefaultMergedSvgFilterTags(_pdfPreSplitMergedLegend);
            _renderPreSplitMergedPreview();
            _splitMainTab = 'mergedSvg';
            _applySplitMainTab();
            requestAnimationFrame(() => {
                try { _fitMergedSvgPreview(); } catch { /* ignore */ }
            });
        } catch (ex) {
            _setMergedSvgDebugReport({
                createdAt: Date.now(),
                cropText: hasOutputCrop && outputCropFrac ? _formatCropFractionForReport(outputCropFrac, Number.isFinite(outputCrop?.pageIndex) ? Number(outputCrop.pageIndex) : -1) : '',
                entries: [{ label: 'merge-error', byteLength: 0, diag: null }]
            });
            showError(ex?.message || String(ex));
        } finally {
            if (btnPreSplitMerge) {
                btnPreSplitMerge.disabled = false;
                btnPreSplitMerge.classList.remove('premerge-btn-busy');
                btnPreSplitMerge.innerHTML = prevHtml || '<i class="fa-solid fa-object-group"></i> Merge Before Split';
                _applyPreSplitMergeButtonUi();
            }
        }
    }

    function _applyPreSplitMergeButtonUi() {
        if (!btnPreSplitMerge) return;
        btnPreSplitMerge.classList.toggle('bg-fuchsia-700/80', _pdfPreSplitMergeEnabled);
        btnPreSplitMerge.classList.toggle('text-white', _pdfPreSplitMergeEnabled);
        btnPreSplitMerge.classList.toggle('border-fuchsia-400/80', _pdfPreSplitMergeEnabled);
        btnPreSplitMerge.classList.toggle('bg-fuchsia-900/25', !_pdfPreSplitMergeEnabled);
        btnPreSplitMerge.classList.toggle('text-fuchsia-200', !_pdfPreSplitMergeEnabled);
        btnPreSplitMerge.innerHTML = _pdfPreSplitMergeEnabled
            ? '<i class="fa-solid fa-check"></i> Merge Before Split: ON'
            : '<i class="fa-solid fa-object-group"></i> Merge Before Split';
    }

    function _setPreSplitMergeEnabled(enabled) {
        _pdfPreSplitMergeEnabled = !!enabled;
        try { localStorage.setItem(PDF_SPLIT_PREMERGE_STORAGE_KEY, _pdfPreSplitMergeEnabled ? '1' : '0'); } catch { }
        _applyPreSplitMergeButtonUi();
    }

    async function _mergeSvgBeforeSplit(svgContent, label) {
        if (!_pdfPreSplitMergeEnabled || !svgContent) return svgContent;
        console.log('[PdfToSvgSplit][PreMerge] start', { label, svgLen: svgContent.length });
        reportStep('Pre-merge SVG (Shapely)', { label, svgLen: svgContent.length });
        const resp = await fetch(SHAPELY_MERGE_ENDPOINT, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ svgContent })
        });
        if (!resp.ok) {
            const errText = await resp.text();
            throw new Error(`Pre-split merge failed for ${label}: HTTP ${resp.status} ${String(errText || '').slice(0, 300)}`);
        }
        const data = await resp.json();
        const mergedSvg = String(data?.svgContent || '');
        const mergedGroups = Number(data?.mergedGroups || 0);
        const beforeCount = Number(data?.pathCountBefore || 0);
        const afterCount = Number(data?.pathCountAfter || 0);
        console.log('[PdfToSvgSplit][PreMerge] done', { label, mergedGroups, beforeCount, afterCount, mergedSvgLen: mergedSvg.length || svgContent.length });
        reportStep('Pre-merge SVG result', { label, mergedGroups, beforeCount, afterCount, changed: !!mergedSvg && mergedSvg !== svgContent });
        return mergedSvg || svgContent;
    }

    try {
        _pdfPreSplitMergeEnabled = localStorage.getItem(PDF_SPLIT_PREMERGE_STORAGE_KEY) === '1';
    } catch { }
    _applyPreSplitMergeButtonUi();
    btnPreSplitMerge?.addEventListener('click', _generatePreSplitMergedPreview);
    btnMergedSvgZoomOut?.addEventListener('click', () => _setMergedSvgZoom(_mergedSvgZoom / 1.2));
    btnMergedSvgZoomFit?.addEventListener('click', () => _fitMergedSvgPreview());
    btnMergedSvgZoomIn?.addEventListener('click', () => _setMergedSvgZoom(_mergedSvgZoom * 1.2));
    btnMergedSvgFilterAll?.addEventListener('click', () => {
        _pdfPreSplitMergedFilterTags = (_pdfPreSplitMergedLegend || []).map(item => item.tag);
        _renderPreSplitMergedPreview();
    });
    btnMergedSvgFilterNone?.addEventListener('click', () => {
        _pdfPreSplitMergedFilterTags = [];
        _renderPreSplitMergedPreview();
    });
    document.getElementById('btnMergedSvgDeleteHidden')?.addEventListener('click', () => {
        const active = _getMergedSvgActiveTagSet();
        const items = Array.isArray(_pdfPreSplitMergedLegend) ? _pdfPreSplitMergedLegend : [];
        const toDelete = items.map(item => item.tag).filter(tag => !active.has(tag));
        if (!toDelete.length) return;
        const labels = toDelete.map(t => _getMergedSvgTypeLabel(t));
        if (!confirm(`Permanently delete ${labels.join(', ')} elements from the SVG?\nThis cannot be undone.`)) return;
        _deleteMergedSvgElementsByTags(toDelete);
    });
    mergedSvgLegendChips?.addEventListener('click', (e) => {
        // Handle per-chip delete icon click
        const delIcon = e.target && e.target.closest ? e.target.closest('[data-svg-delete-tag]') : null;
        if (delIcon) {
            e.stopPropagation();
            const tag = String(delIcon.getAttribute('data-svg-delete-tag') || '').toLowerCase();
            if (!tag) return;
            const label = _getMergedSvgTypeLabel(tag);
            if (!confirm(`Permanently delete all ${label} elements from the SVG?\nThis cannot be undone.`)) return;
            _deleteMergedSvgElementsByTags([tag]);
            return;
        }
        const btn = e.target && e.target.closest ? e.target.closest('[data-svg-tag]') : null;
        if (!btn) return;
        const tag = String(btn.getAttribute('data-svg-tag') || '').toLowerCase();
        if (!tag) return;
        const set = _getMergedSvgActiveTagSet();
        if (set.has(tag)) set.delete(tag); else set.add(tag);
        _pdfPreSplitMergedFilterTags = (_pdfPreSplitMergedLegend || []).map(item => item.tag).filter(tagName => set.has(tagName));
        _renderPreSplitMergedPreview();
    });
    btnDownloadMergedSvg?.addEventListener('click', () => {
        if (!_pdfPreSplitMergedSvg) return;
        downloadFile('merged_before_split.svg', _pdfPreSplitMergedSvg, 'image/svg+xml');
    });

    if (mergedSvgPreviewViewport) {
        mergedSvgPreviewViewport.addEventListener('wheel', (e) => {
            if (!_pdfPreSplitMergedSvg) return;
            e.preventDefault();
            const rect = mergedSvgPreviewViewport.getBoundingClientRect();
            const px = e.clientX - rect.left;
            const py = e.clientY - rect.top;
            const factor = e.deltaY < 0 ? 1.15 : (1 / 1.15);
            _setMergedSvgZoom(_mergedSvgZoom * factor, px, py);
        }, { passive: false });
        mergedSvgPreviewViewport.addEventListener('mousedown', _beginMergedSvgPan);
    }
    window.addEventListener('mousemove', _moveMergedSvgPan);
    window.addEventListener('mouseup', _stopMergedSvgPan);
    window.addEventListener('blur', _stopMergedSvgPan);

    // ═══════════════════════════════════════════════════════════════════════
    // ── Group Objects (Lamps) ─ click-to-select, merge-and-group, auto-detect
    // ═══════════════════════════════════════════════════════════════════════
    (function _initGroupObjects() {
        const GROUP_OBJ_ENDPOINT = SHAPELY_GROUP_OBJECTS_ENDPOINT;
        const btnSelectMode = document.getElementById('btnMergedSvgSelectMode');
        const btnSelectFull = document.getElementById('btnSelectFull');
        const btnSelectPartial = document.getElementById('btnSelectPartial');
        const btnMergeSelected = document.getElementById('btnMergedSvgMergeSelected');
        const btnSaveGroup = document.getElementById('btnMergedSvgSaveGroup');
        const btnSelectByColor = document.getElementById('btnSelectByColor');
        const btnAutoDetect = document.getElementById('btnMergedSvgAutoDetectLamps');
        const groupNameSelect = document.getElementById('mergedSvgGroupNameSelect');
        const groupStatus = document.getElementById('mergedSvgGroupStatus');
        const groupResult = document.getElementById('mergedSvgGroupResult');
        const proximityInput = document.getElementById('mergedSvgProximityRadius');
        const maxDiagInput = document.getElementById('mergedSvgMaxClusterDiag');
        const minElsInput = document.getElementById('mergedSvgMinClusterEls');

        let _selectMode = false;
        let _selectStrict = true; // true = only fully-inside, false = also partial/intersecting
        let _selectedSeedBbox = null; // { x, y, w, h } in SVG coordinates
        let _selectedSeedMode = '';
        let _lastGroupClusters = [];
        let _groupBusy = false;
        let _selectDragActive = false;
        let _selectDragStartPt = null;
        let _selectDragCurrentPt = null;
        let _suppressNextSelectClick = false;
        let _svgScreenCTMInv = null; // cached svg.getScreenCTM().inverse() for coordinate mapping
        let _currentSelectedItems = []; // live array of {el, bb, enabled} for table toggle
        let _selectedColorSourceIdx = -1; // index of row selected as color source
        let _colorMatchItems = []; // items in the second (color match) table
        let _lastCreatedGroupInfo = null; // { id, groupName, elementCount }
        // _suppressFamilySelectNav is declared in the outer scope (shared with family-select change handler)

        function _updateSelectedPreviewActions() {
            const actionsEl = document.getElementById('selectedObjectPreviewActions');
            const activeCount = (_currentSelectedItems || []).filter(i => i && i.enabled).length;
            const hasSelection = activeCount > 0;
            const hasSavedGroupTarget = !!(_lastCreatedGroupInfo && _lastCreatedGroupInfo.id);
            if (actionsEl) actionsEl.classList.toggle('hidden', !hasSelection && !hasSavedGroupTarget);
            if (btnSaveGroup) btnSaveGroup.disabled = !(hasSavedGroupTarget || hasSelection) || _groupBusy;
        }

        function _getGroupParams() {
            return {
                groupName: groupNameSelect ? groupNameSelect.value : 'lighting',
                proximityRadius: parseFloat(proximityInput ? proximityInput.value : '15') || 15,
                maxClusterDiagonal: parseFloat(maxDiagInput ? maxDiagInput.value : '120') || 120,
                minClusterElements: parseInt(minElsInput ? minElsInput.value : '2', 10) || 2,
                similarityThreshold: 0.7
            };
        }

        function _saveSelectionStroke(el) {
            if (!el || !el.dataset) return;
            if (el.dataset.origStroke === undefined) {
                el.dataset.origStroke = el.getAttribute('stroke') || '';
                el.dataset.origStrokeWidth = el.getAttribute('stroke-width') || '';
            }
        }

        function _normalizeSvgBbox(a, b) {
            if (!a || !b) return null;
            const minX = Math.min(a.x, b.x);
            const minY = Math.min(a.y, b.y);
            return {
                x: minX,
                y: minY,
                w: Math.abs(a.x - b.x),
                h: Math.abs(a.y - b.y)
            };
        }

        function _bboxContainsPoint(bb, x, y) {
            return !!bb && x >= bb.x && x <= (bb.x + bb.w) && y >= bb.y && y <= (bb.y + bb.h);
        }

        function _bboxContainsBox(outer, inner) {
            return !!outer && !!inner
                && inner.x >= outer.x
                && inner.y >= outer.y
                && (inner.x + inner.w) <= (outer.x + outer.w)
                && (inner.y + inner.h) <= (outer.y + outer.h);
        }

        function _bboxIntersectsBox(a, b) {
            return !!a && !!b
                && (a.x + a.w) >= b.x
                && (b.x + b.w) >= a.x
                && (a.y + a.h) >= b.y
                && (b.y + b.h) >= a.y;
        }

        function _removeSelectionRect() {
            if (!mergedSvgPreviewScale) return;
            mergedSvgPreviewScale.querySelectorAll('.merged-svg-selection-drag-rect').forEach(el => el.remove());
        }

        function _removeSelectedObjectRect() {
            if (!mergedSvgPreviewScale) return;
            mergedSvgPreviewScale.querySelectorAll('.merged-svg-selected-object-rect').forEach(el => el.remove());
        }

        function _updateSelectionRect(bb) {
            if (!mergedSvgPreviewScale || !bb) return;
            const svg = mergedSvgPreviewScale.querySelector('svg');
            if (!svg) return;
            _removeSelectionRect();
            const rectEl = document.createElementNS('http://www.w3.org/2000/svg', 'rect');
            rectEl.setAttribute('x', String(bb.x));
            rectEl.setAttribute('y', String(bb.y));
            rectEl.setAttribute('width', String(Math.max(bb.w, 0.01)));
            rectEl.setAttribute('height', String(Math.max(bb.h, 0.01)));
            rectEl.classList.add('merged-svg-selection-drag-rect');
            svg.appendChild(rectEl);
        }

        function _drawSelectedObjectRect(bb) {
            console.log('[GroupObjects] _drawSelectedObjectRect: bb=%o', bb);
            if (!mergedSvgPreviewScale || !bb) { console.warn('[GroupObjects] _drawSelectedObjectRect: scale=%o, bb=%o — aborting', !!mergedSvgPreviewScale, bb); return; }
            const svg = mergedSvgPreviewScale.querySelector('svg');
            if (!svg) { console.warn('[GroupObjects] _drawSelectedObjectRect: no <svg> found'); return; }
            _removeSelectedObjectRect();
            const pad = 3;
            const rectEl = document.createElementNS('http://www.w3.org/2000/svg', 'rect');
            rectEl.setAttribute('x', String(bb.x - pad));
            rectEl.setAttribute('y', String(bb.y - pad));
            rectEl.setAttribute('width', String(Math.max(bb.w + (pad * 2), 1)));
            rectEl.setAttribute('height', String(Math.max(bb.h + (pad * 2), 1)));
            rectEl.classList.add('merged-svg-selected-object-rect');
            svg.appendChild(rectEl);
            console.log('[GroupObjects] _drawSelectedObjectRect: ADDED rect at (%f,%f) size (%f,%f)', bb.x - pad, bb.y - pad, bb.w + (pad * 2), bb.h + (pad * 2));
        }

        function _enableGroupButtons(enabled) {
            if (btnSelectFull) btnSelectFull.disabled = !enabled;
            if (btnSelectPartial) btnSelectPartial.disabled = !enabled;
            if (btnAutoDetect) btnAutoDetect.disabled = !enabled;
            if (btnMergeSelected) btnMergeSelected.disabled = !enabled || !_selectedSeedBbox;
            if (btnSelectByColor) btnSelectByColor.disabled = !enabled || _selectedColorSourceIdx < 0;
            _updateSelectedPreviewActions();
        }

        function _setGroupStatus(msg) {
            if (groupStatus) groupStatus.textContent = msg;
        }

        function _showGroupResult(msg) {
            if (groupResult) {
                groupResult.textContent = msg;
                groupResult.classList.remove('hidden');
                setTimeout(() => groupResult.classList.add('hidden'), 5000);
            }
        }

        function _toggleSelectMode(strict) {
            // If clicking the same mode that's already active → turn off
            if (_selectMode && _selectStrict === strict) {
                _selectMode = false;
            } else {
                _selectMode = true;
                _selectStrict = strict;
            }
            console.log('[GroupObjects] _toggleSelectMode: selectMode=%s, strict=%s', _selectMode, _selectStrict);
            if (btnSelectFull) btnSelectFull.classList.toggle('active-select-mode', _selectMode && _selectStrict);
            if (btnSelectPartial) btnSelectPartial.classList.toggle('active-select-mode', _selectMode && !_selectStrict);
            if (mergedSvgPreviewViewport) mergedSvgPreviewViewport.classList.toggle('select-mode', _selectMode);
            _setGroupStatus(_selectMode
                ? (_selectStrict ? 'Select Full: drag a box — only objects fully inside will be selected.' : 'Select Partial: drag a box — all overlapping objects will be selected.')
                : 'Drag an area around one lamp, then merge it or auto-detect similar lamps.');
            if (!_selectMode) {
                _selectDragActive = false;
                _selectDragStartPt = null;
                _selectDragCurrentPt = null;
                _selectedSeedMode = '';
                _clearSelectionHighlights();
                _clearColorMatchHighlights();
                _selectedSeedBbox = null;
                _selectedColorSourceIdx = -1;
                if (btnMergeSelected) btnMergeSelected.disabled = true;
                if (btnSelectByColor) btnSelectByColor.disabled = true;
                _updateSelectedPreviewActions();
            }
        }

        function _clearSelectionHighlights() {
            if (!mergedSvgPreviewScale) return;
            mergedSvgPreviewScale.querySelectorAll('.merged-svg-el-highlight, .merged-svg-el-cluster-highlight, .merged-svg-el-color-highlight').forEach(el => {
                el.classList.remove('merged-svg-el-highlight', 'merged-svg-el-cluster-highlight', 'merged-svg-el-color-highlight');
                // Restore original stroke attributes that were saved before highlighting
                if (el.dataset.origStroke !== undefined) {
                    if (el.dataset.origStroke) el.setAttribute('stroke', el.dataset.origStroke);
                    else el.removeAttribute('stroke');
                    delete el.dataset.origStroke;
                }
                if (el.dataset.origStrokeWidth !== undefined) {
                    if (el.dataset.origStrokeWidth) el.setAttribute('stroke-width', el.dataset.origStrokeWidth);
                    else el.removeAttribute('stroke-width');
                    delete el.dataset.origStrokeWidth;
                }
            });
            _removeSelectionRect();
            _removeSelectedObjectRect();
            mergedSvgPreviewScale.querySelectorAll('.merged-svg-cluster-rect, .merged-svg-group-rect').forEach(el => el.remove());
            _clearSelectedObjectsTable();
        }

        function _clearObjectSelectionState(message) {
            _clearSelectionHighlights();
            _clearColorMatchHighlights();
            _currentSelectedItems = [];
            _colorMatchItems = [];
            _selectedSeedBbox = null;
            _selectedSeedMode = '';
            _selectedColorSourceIdx = -1;
            _selectDragActive = false;
            _selectDragStartPt = null;
            _selectDragCurrentPt = null;
            if (btnMergeSelected) btnMergeSelected.disabled = true;
            if (btnSelectByColor) btnSelectByColor.disabled = true;
            const checkAll = document.getElementById('selObjCheckAll');
            if (checkAll) checkAll.checked = true;
            const colorCheckAll = document.getElementById('colorMatchCheckAll');
            if (colorCheckAll) colorCheckAll.checked = true;
            _renderSelectedObjectsHeaderSummary();
            _updateSelectedPreviewActions();
            if (message) _setGroupStatus(message);
        }

        function _getSvgCoords(clientX, clientY) {
            if (!mergedSvgPreviewViewport || !mergedSvgPreviewScale) {
                console.warn('[GroupObjects] _getSvgCoords: viewport or scale missing', { viewport: !!mergedSvgPreviewViewport, scale: !!mergedSvgPreviewScale });
                return null;
            }
            const svg = mergedSvgPreviewScale.querySelector('svg');
            if (!svg) { console.warn('[GroupObjects] _getSvgCoords: no <svg> found'); return null; }
            const rect = svg.getBoundingClientRect ? svg.getBoundingClientRect() : null;
            const vb = svg.viewBox && svg.viewBox.baseVal ? svg.viewBox.baseVal : null;
            if (rect && vb && rect.width > 0 && rect.height > 0 && vb.width > 0 && vb.height > 0) {
                const x = vb.x + ((clientX - rect.left) / rect.width) * vb.width;
                const y = vb.y + ((clientY - rect.top) / rect.height) * vb.height;
                console.log('[GroupObjects] _getSvgCoords: client(%f,%f) rect(%f,%f,%f,%f) vb(%f,%f,%f,%f) → svg(%f,%f)', clientX, clientY, rect.left, rect.top, rect.width, rect.height, vb.x, vb.y, vb.width, vb.height, x, y);
                return { x, y };
            }
            const pt = svg.createSVGPoint();
            const ctm = svg.getScreenCTM();
            if (!ctm) { console.warn('[GroupObjects] _getSvgCoords: no rect/viewBox and getScreenCTM() returned null'); return null; }
            pt.x = clientX;
            pt.y = clientY;
            const svgPt = pt.matrixTransform(ctm.inverse());
            console.log('[GroupObjects] _getSvgCoords: fallback client(%f,%f) → svg(%f,%f)', clientX, clientY, svgPt.x, svgPt.y);
            return { x: svgPt.x, y: svgPt.y };
        }

        function _getElementBbox(el, svgRoot) {
            try {
                const bb = el.getBBox();
                if (!bb || bb.width <= 0 || bb.height <= 0) return null;
                if (!svgRoot) return { x: bb.x, y: bb.y, w: bb.width, h: bb.height };
                // Transform bbox from element's local space → screen → SVG viewBox space
                // This guarantees the same coordinate system as _getSvgCoords (which uses svg.getScreenCTM().inverse())
                const elScreenCTM = el.getScreenCTM();
                if (!elScreenCTM) return { x: bb.x, y: bb.y, w: bb.width, h: bb.height };
                // Use cached svgScreenCTMInv if available (set by _selectElementsInArea before the loop)
                let inv = _svgScreenCTMInv;
                if (!inv) {
                    const svgScreenCTM = svgRoot.getScreenCTM();
                    inv = svgScreenCTM ? svgScreenCTM.inverse() : null;
                }
                if (!inv) return { x: bb.x, y: bb.y, w: bb.width, h: bb.height };
                // Composite: element local → screen → SVG viewBox (user) space
                const toViewBox = inv.multiply(elScreenCTM);
                const pt = svgRoot.createSVGPoint();
                let minX = Infinity, minY = Infinity, maxX = -Infinity, maxY = -Infinity;
                const corners = [[bb.x, bb.y], [bb.x + bb.width, bb.y], [bb.x, bb.y + bb.height], [bb.x + bb.width, bb.y + bb.height]];
                for (const [cx, cy] of corners) {
                    pt.x = cx; pt.y = cy;
                    const t = pt.matrixTransform(toViewBox);
                    if (t.x < minX) minX = t.x;
                    if (t.y < minY) minY = t.y;
                    if (t.x > maxX) maxX = t.x;
                    if (t.y > maxY) maxY = t.y;
                }
                return { x: minX, y: minY, w: maxX - minX, h: maxY - minY };
            } catch { /* ignore */ }
            return null;
        }

        function _selectElementsInArea(selectionBbox) {
            console.log('[GroupObjects] _selectElementsInArea START', JSON.stringify(selectionBbox));
            console.time('[GroupObjects] _selectElementsInArea');
            if (!mergedSvgPreviewScale || !selectionBbox) {
                console.warn('[GroupObjects] _selectElementsInArea: early exit - scale=%o, bbox=%o', !!mergedSvgPreviewScale, selectionBbox);
                return;
            }
            const svg = mergedSvgPreviewScale.querySelector('svg');
            if (!svg) { console.warn('[GroupObjects] _selectElementsInArea: no <svg> found'); return; }

            // Cache svg.getScreenCTM().inverse() for the entire loop (342K+ elements)
            const _svgScreenCTM = svg.getScreenCTM();
            _svgScreenCTMInv = _svgScreenCTM ? _svgScreenCTM.inverse() : null;
            console.log('[GroupObjects] _selectElementsInArea: svgScreenCTM cached, inverse=%o', !!_svgScreenCTMInv);

            const areaCenterX = selectionBbox.x + (selectionBbox.w / 2);
            const areaCenterY = selectionBbox.y + (selectionBbox.h / 2);
            const selectionDiag = Math.hypot(selectionBbox.w, selectionBbox.h);
            const shapes = svg.querySelectorAll(_SHAPE_SELECTOR);
            console.log('[GroupObjects] _selectElementsInArea: areaCenter=(%f,%f), diag=%f, totalShapes=%d', areaCenterX, areaCenterY, selectionDiag, shapes.length);
            // Diagnostic: sample a few element bboxes to verify coordinate space
            let _diagSampled = 0;
            const candidates = [];
            const intersecting = [];

            for (const el of shapes) {
                try { if (el.closest && el.closest('defs')) continue; } catch { /* ignore */ }
                const bb = _getElementBbox(el, svg);
                if (!bb) continue;
                if (_diagSampled < 5) {
                    _diagSampled++;
                    console.log('[GroupObjects] _selectElementsInArea sample#%d: tag=%s bbox=(%f,%f,%f,%f)', _diagSampled, el.tagName, bb.x, bb.y, bb.w, bb.h);
                }
                const cx = bb.x + (bb.w / 2);
                const cy = bb.y + (bb.h / 2);
                const diag = Math.hypot(bb.w, bb.h);
                const fullyInside = _bboxContainsBox(selectionBbox, bb);
                const centerInside = _bboxContainsPoint(selectionBbox, cx, cy);
                const intersects = _bboxIntersectsBox(selectionBbox, bb);
                if (!fullyInside && !centerInside && !intersects) continue;
                const item = {
                    el,
                    bb,
                    diag,
                    fullyInside,
                    centerInside,
                    intersects,
                    dist: Math.hypot(cx - areaCenterX, cy - areaCenterY)
                };
                intersecting.push(item);

                // In strict mode: only accept elements fully inside the selection
                if (_selectStrict) {
                    if (fullyInside) candidates.push({ ...item });
                    continue;
                }

                // In partial mode: accept all intersecting, but filter oversized
                const isReasonablySized = diag <= Math.max(selectionDiag * 2.5, 90);
                if (!fullyInside && !centerInside && !isReasonablySized) continue;
                candidates.push({
                    ...item
                });
            }

            console.log('[GroupObjects] _selectElementsInArea: intersecting=%d, candidates=%d', intersecting.length, candidates.length);

            if (!candidates.length) {
                let fallback = null;
                for (const item of intersecting) {
                    if (!fallback || item.dist < fallback.dist || item.diag < fallback.diag) fallback = item;
                }
                if (fallback) {
                    candidates.push(fallback);
                    console.log('[GroupObjects] _selectElementsInArea: used fallback element, tag=%s, dist=%f', fallback.el.tagName, fallback.dist);
                }
            }

            if (!candidates.length) {
                _selectedSeedBbox = null;
                _selectedSeedMode = '';
                if (btnMergeSelected) btnMergeSelected.disabled = true;
                _setGroupStatus('No lamp/object found in the selected area. Drag a tighter box around one lamp.');
                console.warn('[GroupObjects] _selectElementsInArea: NO candidates found at all');
                console.timeEnd('[GroupObjects] _selectElementsInArea');
                return;
            }

            candidates.sort((a, b) => {
                const aScore = (a.centerInside ? 0 : 1) + (a.fullyInside ? -0.25 : 0) + (a.intersects ? 0 : 1);
                const bScore = (b.centerInside ? 0 : 1) + (b.fullyInside ? -0.25 : 0) + (b.intersects ? 0 : 1);
                return aScore - bScore || a.dist - b.dist || a.diag - b.diag;
            });

            const seed = candidates[0];
            const seedEl = seed.el;
            const seedDiag = seed.diag || 0;
            const selectedItems = candidates.filter(item => {
                if (item.el === seedEl) return true;
                const nearSeed = _bboxIntersectsBox(
                    { x: seed.bb.x - 6, y: seed.bb.y - 6, w: seed.bb.w + 12, h: seed.bb.h + 12 },
                    item.bb
                );
                const similarScale = item.diag <= Math.max(seedDiag * 1.8, selectionDiag * 1.4, 30);
                return nearSeed && similarScale;
            });

            let minX = Infinity, minY = Infinity, maxX = -Infinity, maxY = -Infinity;

            _clearSelectionHighlights();
            for (const item of selectedItems) {
                minX = Math.min(minX, item.bb.x);
                minY = Math.min(minY, item.bb.y);
                maxX = Math.max(maxX, item.bb.x + item.bb.w);
                maxY = Math.max(maxY, item.bb.y + item.bb.h);
            }

            // Use the full selected cluster bbox for backend merge/group so all
            // highlighted elements are treated as one logical object.
            _selectedSeedBbox = isFinite(minX)
                ? { x: minX, y: minY, w: Math.max(maxX - minX, 0.01), h: Math.max(maxY - minY, 0.01) }
                : { x: selectionBbox.x, y: selectionBbox.y, w: selectionBbox.w, h: selectionBbox.h };
            _selectedSeedMode = 'manual-area';
            if (btnMergeSelected) btnMergeSelected.disabled = false;

            _saveSelectionStroke(seedEl);
            seedEl.classList.add('merged-svg-el-highlight');
            for (const item of selectedItems) {
                if (item.el === seedEl) continue;
                _saveSelectionStroke(item.el);
                item.el.classList.add('merged-svg-el-cluster-highlight');
            }

            // Draw the final selected object/cluster bbox, not the raw mouse box.
            // This keeps the marker aligned with the actual elements that will be previewed/saved.
            _drawSelectedObjectRect(_selectedSeedBbox || selectionBbox);
            console.log('[GroupObjects] _selectElementsInArea: DONE → seedBbox=%o, selectedItems=%d, seedMode=%s', _selectedSeedBbox, selectedItems.length, _selectedSeedMode);
            console.timeEnd('[GroupObjects] _selectElementsInArea');

            _setGroupStatus(`Selected 1 object made of ${selectedItems.length} element(s). Merge & Group will merge all selected elements as one object.`);
            _populateSelectedObjectsTable(selectedItems);
        }

        /* ── Populate Selected-Objects Table ── */
        function _populateSelectedObjectsTable(items) {
            const panel = document.getElementById('selectedObjectsPanel');
            const tbody = document.querySelector('#selectedObjectsTable tbody');
            const checkAll = document.getElementById('selObjCheckAll');
            if (!panel || !tbody) return;
            tbody.innerHTML = '';
            if (!items || !items.length) {
                panel.classList.add('hidden');
                _currentSelectedItems = [];
                _renderSelectedObjectsHeaderSummary();
                return;
            }
            panel.classList.remove('hidden');
            _currentSelectedItems = items.map(item => ({ ...item, enabled: true }));
            _updateSelectedCount();

            const _esc = s => { const d = document.createElement('span'); d.textContent = s; return d.innerHTML; };
            const _trunc = (s, max) => s && s.length > max ? s.substring(0, max) + '…' : (s || '');

            items.forEach((item, idx) => {
                const el = item.el;
                const tag = el.tagName.toLowerCase();
                const transform = el.getAttribute('transform') || '';
                const fill = el.getAttribute('fill') || '';
                const stroke = el.getAttribute('stroke') || '';
                let geom = '';
                if (tag === 'path') {
                    geom = el.getAttribute('d') || '';
                } else if (tag === 'circle') {
                    geom = `cx=${el.getAttribute('cx')} cy=${el.getAttribute('cy')} r=${el.getAttribute('r')}`;
                } else if (tag === 'rect') {
                    geom = `x=${el.getAttribute('x')} y=${el.getAttribute('y')} w=${el.getAttribute('width')} h=${el.getAttribute('height')}`;
                } else if (tag === 'line') {
                    geom = `x1=${el.getAttribute('x1')} y1=${el.getAttribute('y1')} x2=${el.getAttribute('x2')} y2=${el.getAttribute('y2')}`;
                } else if (tag === 'ellipse') {
                    geom = `cx=${el.getAttribute('cx')} cy=${el.getAttribute('cy')} rx=${el.getAttribute('rx')} ry=${el.getAttribute('ry')}`;
                } else if (tag === 'polygon' || tag === 'polyline') {
                    geom = el.getAttribute('points') || '';
                }
                const bb = item.bb;
                const bboxStr = bb ? `${bb.x.toFixed(1)}, ${bb.y.toFixed(1)}, ${bb.w.toFixed(1)}, ${bb.h.toFixed(1)}` : '';

                const tr = document.createElement('tr');
                tr.dataset.idx = idx;
                const cb = document.createElement('input');
                cb.type = 'checkbox';
                cb.checked = true;
                cb.title = 'Include/exclude this element';
                const cbTd = document.createElement('td');
                cbTd.appendChild(cb);

                tr.innerHTML =
                    `<td class="sel-idx">${idx + 1}</td>` +
                    `<td class="sel-tag">&lt;${_esc(tag)}&gt;</td>` +
                    `<td class="sel-attr" title="${_esc(transform)}">${_esc(_trunc(transform, 50))}</td>` +
                    `<td class="sel-val"  title="${_esc(geom)}">${_esc(_trunc(geom, 60))}</td>` +
                    `<td><span class="sel-color-swatch" style="background:${_esc(fill || 'transparent')}"></span>${_esc(fill || '—')}</td>` +
                    `<td><span class="sel-color-swatch" style="background:${_esc(stroke || 'transparent')}"></span>${_esc(stroke || '—')}</td>` +
                    `<td class="sel-dim">${_esc(bboxStr)}</td>` +
                    `<td></td>`;
                tr.insertBefore(cbTd, tr.firstChild);

                // Delete button for this row
                const delBtn = document.createElement('button');
                delBtn.className = 'sel-del-btn';
                delBtn.title = 'Delete this element from SVG';
                delBtn.innerHTML = '<i class="fa-solid fa-trash-can"></i>';
                delBtn.addEventListener('click', (e) => {
                    e.stopPropagation();
                    _deleteItemFromSvg(idx);
                });
                tr.lastElementChild.appendChild(delBtn);

                // Checkbox toggle → enable/disable element in selection
                cb.addEventListener('change', () => {
                    const enabled = cb.checked;
                    _currentSelectedItems[idx].enabled = enabled;
                    tr.classList.toggle('sel-obj-disabled', !enabled);
                    _syncElementHighlight(el, enabled, idx === 0);
                    _updateSelectedCount();
                    console.log('[GroupObjects] table toggle #%d enabled=%s, activeCount=%d', idx + 1, enabled, _currentSelectedItems.filter(i => i.enabled).length);
                });

                // Hover row → highlight element in SVG
                tr.addEventListener('mouseenter', () => {
                    tr.classList.add('sel-obj-highlight');
                    try { el.style.outline = '2px solid #3b82f6'; el.style.outlineOffset = '1px'; } catch {}
                });
                tr.addEventListener('mouseleave', () => {
                    tr.classList.remove('sel-obj-highlight');
                    try { el.style.outline = ''; el.style.outlineOffset = ''; } catch {}
                });
                // Click row → select as color source for Select All Colors
                tr.addEventListener('click', (e) => {
                    if (e.target.closest('input,button,.sel-del-btn')) return; // ignore checkbox/delete clicks
                    tbody.querySelectorAll('tr.sel-row-selected').forEach(r => r.classList.remove('sel-row-selected'));
                    tr.classList.add('sel-row-selected');
                    _selectedColorSourceIdx = idx;
                    console.log('[GroupObjects] row click → selected color source idx=%d, fill=%s', idx, fill);
                    if (btnSelectByColor) btnSelectByColor.disabled = false;
                });
                tbody.appendChild(tr);
            });

            // Master checkbox – toggle all
            if (checkAll) {
                checkAll.checked = true;
                checkAll.onchange = () => {
                    const checked = checkAll.checked;
                    tbody.querySelectorAll('input[type="checkbox"]').forEach(cb => {
                        if (cb.checked !== checked) { cb.checked = checked; cb.dispatchEvent(new Event('change')); }
                    });
                };
            }

            console.log('[GroupObjects] _populateSelectedObjectsTable: %d rows', items.length);
        }

        function _getSelectedObjectGeometry(el) {
            if (!el) return '';
            const tag = String(el.tagName || '').toLowerCase();
            if (tag === 'path') return el.getAttribute('d') || '';
            if (tag === 'circle') return `cx=${el.getAttribute('cx')} cy=${el.getAttribute('cy')} r=${el.getAttribute('r')}`;
            if (tag === 'rect') return `x=${el.getAttribute('x')} y=${el.getAttribute('y')} w=${el.getAttribute('width')} h=${el.getAttribute('height')}`;
            if (tag === 'line') return `x1=${el.getAttribute('x1')} y1=${el.getAttribute('y1')} x2=${el.getAttribute('x2')} y2=${el.getAttribute('y2')}`;
            if (tag === 'ellipse') return `cx=${el.getAttribute('cx')} cy=${el.getAttribute('cy')} rx=${el.getAttribute('rx')} ry=${el.getAttribute('ry')}`;
            if (tag === 'polygon' || tag === 'polyline') return el.getAttribute('points') || '';
            if (tag === 'text') return (el.textContent || '').trim();
            if (tag === 'use') return el.getAttribute('href') || el.getAttribute('xlink:href') || '';
            return '';
        }

        function _getSelectedObjectHeaderLabel(item, idx) {
            if (!item?.el) return `#${idx + 1}`;
            const tag = String(item.el.tagName || '').toLowerCase();
            const geom = _getSelectedObjectGeometry(item.el).replace(/\s+/g, ' ').trim();
            const bb = item.bb ? `${item.bb.x.toFixed(0)},${item.bb.y.toFixed(0)},${item.bb.w.toFixed(0)},${item.bb.h.toFixed(0)}` : '';
            const detail = geom || (bb ? `bbox ${bb}` : '');
            const shortDetail = detail && detail.length > 34 ? `${detail.substring(0, 34)}…` : detail;
            return shortDetail ? `#${idx + 1} <${tag}> ${shortDetail}` : `#${idx + 1} <${tag}>`;
        }

        function _findSvgElementById(svgRoot, id) {
            if (!svgRoot || !id) return null;
            try {
                if (window.CSS && typeof window.CSS.escape === 'function') {
                    return svgRoot.querySelector(`#${window.CSS.escape(id)}`);
                }
            } catch {}
            try {
                return svgRoot.querySelector(`[id="${String(id).replace(/"/g, '\\"')}"]`);
            } catch {
                return null;
            }
        }

        function _collectSelectedObjectPreviewRefIds(node, refIds) {
            if (!node || !refIds) return;
            if (node.attributes) {
                [...node.attributes].forEach(attr => {
                    const value = String(attr.value || '');
                    if (!value) return;
                    if ((attr.name === 'href' || attr.name.endsWith(':href')) && value.startsWith('#')) {
                        refIds.add(value.substring(1));
                    }
                    for (const match of value.matchAll(/url\(#([^\)]+)\)/g)) {
                        if (match[1]) refIds.add(match[1]);
                    }
                });
            }
            [...(node.children || [])].forEach(child => _collectSelectedObjectPreviewRefIds(child, refIds));
        }

        function _appendSelectedObjectPreviewDefs(sourceSvg, previewSvg, sourceEl, appendedIds) {
            if (!sourceSvg || !previewSvg || !sourceEl) return;
            const pendingIds = new Set();
            const seenIds = appendedIds || new Set();
            _collectSelectedObjectPreviewRefIds(sourceEl, pendingIds);
            if (!pendingIds.size) return;
            let defs = previewSvg.querySelector('defs');
            if (!defs) {
                defs = document.createElementNS('http://www.w3.org/2000/svg', 'defs');
                previewSvg.appendChild(defs);
            }
            while (pendingIds.size) {
                const id = pendingIds.values().next().value;
                pendingIds.delete(id);
                if (!id || seenIds.has(id)) continue;
                const refNode = _findSvgElementById(sourceSvg, id);
                if (!refNode) continue;
                seenIds.add(id);
                defs.appendChild(refNode.cloneNode(true));
                _collectSelectedObjectPreviewRefIds(refNode, pendingIds);
            }
        }

        function _isIdentitySvgMatrix(m) {
            if (!m) return true;
            const eps = 0.000001;
            return Math.abs((m.a ?? 1) - 1) < eps
                && Math.abs(m.b ?? 0) < eps
                && Math.abs(m.c ?? 0) < eps
                && Math.abs((m.d ?? 1) - 1) < eps
                && Math.abs(m.e ?? 0) < eps
                && Math.abs(m.f ?? 0) < eps;
        }

        function _svgMatrixToTransform(m) {
            if (!m) return '';
            const n = v => {
                const num = Number(v);
                return Number.isFinite(num) ? Number(num.toFixed(6)).toString() : '0';
            };
            return `matrix(${n(m.a)} ${n(m.b)} ${n(m.c)} ${n(m.d)} ${n(m.e)} ${n(m.f)})`;
        }

        function _getSelectedObjectAncestorMatrix(sourceSvg, sourceEl) {
            try {
                if (!sourceSvg || !sourceEl) return null;
                const parent = sourceEl.parentNode;
                if (!parent || parent === sourceSvg || typeof parent.getScreenCTM !== 'function') return null;
                const rootCtm = sourceSvg.getScreenCTM ? sourceSvg.getScreenCTM() : null;
                const parentCtm = parent.getScreenCTM ? parent.getScreenCTM() : null;
                if (!rootCtm || !parentCtm) return null;
                const matrix = rootCtm.inverse().multiply(parentCtm);
                return _isIdentitySvgMatrix(matrix) ? null : matrix;
            } catch { /* ignore */ }
            return null;
        }

        function _copySelectedObjectComputedPresentation(sourceNode, cloneNode) {
            if (!sourceNode || !cloneNode || !window.getComputedStyle) return;
            const props = [
                'fill', 'fill-opacity', 'fill-rule',
                'stroke', 'stroke-opacity', 'stroke-width', 'stroke-linecap', 'stroke-linejoin', 'stroke-miterlimit', 'stroke-dasharray',
                'opacity', 'paint-order', 'vector-effect',
                'font-family', 'font-size', 'font-weight', 'font-style', 'font-stretch',
                'letter-spacing', 'word-spacing', 'text-anchor', 'dominant-baseline', 'alignment-baseline', 'baseline-shift',
                'direction', 'unicode-bidi', 'white-space'
            ];
            const skip = new Set(['', 'auto', 'none', 'normal', 'initial', 'inherit', 'unset']);

            const applyOne = (src, dst) => {
                if (!src || !dst || !src.ownerSVGElement) return;
                const highlightClasses = ['merged-svg-el-highlight', 'merged-svg-el-cluster-highlight', 'merged-svg-el-color-highlight'];
                const removedHighlight = [];
                const values = new Map();
                try {
                    if (src.classList) {
                        for (const cls of highlightClasses) {
                            if (src.classList.contains(cls)) {
                                src.classList.remove(cls);
                                removedHighlight.push(cls);
                            }
                        }
                    }
                    const cs = window.getComputedStyle(src);
                    for (const prop of props) values.set(prop, String(cs.getPropertyValue(prop) || '').trim());
                } catch { /* ignore */ }
                finally {
                    try { removedHighlight.forEach(cls => src.classList.add(cls)); } catch { /* ignore */ }
                }
                if (!values.size) return;
                for (const prop of props) {
                    const value = String(values.get(prop) || '').trim();
                    if (!value || skip.has(value.toLowerCase())) continue;

                    // Do not invent paint for elements that explicitly opted out.
                    const attrValue = (dst.getAttribute && dst.getAttribute(prop)) || '';
                    if ((prop === 'fill' || prop === 'stroke') && String(attrValue).trim().toLowerCase() === 'none') continue;

                    try { dst.style.setProperty(prop, value); } catch { /* ignore */ }
                }

                // Attributes are more portable once the standalone SVG is serialized/saved.
                const textAttrs = ['direction', 'unicode-bidi', 'text-anchor', 'dominant-baseline', 'alignment-baseline', 'font-family', 'font-size', 'font-weight', 'font-style'];
                for (const attr of textAttrs) {
                    if (dst.hasAttribute && dst.hasAttribute(attr)) continue;
                    const value = String(values.get(attr) || '').trim();
                    if (!value || skip.has(value.toLowerCase())) continue;
                    try { dst.setAttribute(attr, value); } catch { /* ignore */ }
                }
            };

            applyOne(sourceNode, cloneNode);
            try {
                const srcDesc = sourceNode.querySelectorAll ? [...sourceNode.querySelectorAll('*')] : [];
                const dstDesc = cloneNode.querySelectorAll ? [...cloneNode.querySelectorAll('*')] : [];
                for (let i = 0; i < Math.min(srcDesc.length, dstDesc.length); i++) applyOne(srcDesc[i], dstDesc[i]);
            } catch { /* ignore */ }
        }

        function _appendSelectedObjectCloneInRootSpace(targetSvg, sourceSvg, sourceEl) {
            if (!targetSvg || !sourceSvg || !sourceEl) return null;
            const doc = targetSvg.ownerDocument || document;
            const clone = doc.importNode ? doc.importNode(sourceEl.cloneNode(true), true) : sourceEl.cloneNode(true);
            try {
                clone.classList.remove('merged-svg-el-highlight', 'merged-svg-el-cluster-highlight', 'merged-svg-el-color-highlight');
            } catch {}
            try {
                clone.style.outline = '';
                clone.style.outlineOffset = '';
            } catch {}
            _copySelectedObjectComputedPresentation(sourceEl, clone);

            const ancestorMatrix = _getSelectedObjectAncestorMatrix(sourceSvg, sourceEl);
            if (ancestorMatrix) {
                const wrapper = doc.createElementNS('http://www.w3.org/2000/svg', 'g');
                wrapper.setAttribute('transform', _svgMatrixToTransform(ancestorMatrix));
                wrapper.appendChild(clone);
                targetSvg.appendChild(wrapper);
                return wrapper;
            }

            targetSvg.appendChild(clone);
            return clone;
        }

        function _buildElementPreviewSvg(sourceEl, options) {
            const sourceSvg = mergedSvgPreviewScale ? mergedSvgPreviewScale.querySelector('svg') : null;
            if (!sourceSvg || !sourceEl) return null;
            const bb = _getElementBbox(sourceEl, sourceSvg);
            if (!bb || !isFinite(bb.x) || !isFinite(bb.y) || !isFinite(bb.w) || !isFinite(bb.h)) return null;

            const opts = options || {};
            const padFactor = Number.isFinite(Number(opts.padFactor)) ? Number(opts.padFactor) : 0.2;
            const minPad = Number.isFinite(Number(opts.minPad)) ? Number(opts.minPad) : 4;
            const maxPad = Number.isFinite(Number(opts.maxPad)) ? Number(opts.maxPad) : 12;
            const pad = Math.max(minPad, Math.min(maxPad, Math.max(bb.w, bb.h) * padFactor || minPad));
            const viewBox = [bb.x - pad, bb.y - pad, Math.max(bb.w + pad * 2, 1), Math.max(bb.h + pad * 2, 1)].join(' ');
            const previewSvg = document.createElementNS('http://www.w3.org/2000/svg', 'svg');
            previewSvg.setAttribute('viewBox', viewBox);
            previewSvg.setAttribute('preserveAspectRatio', 'xMidYMid meet');
            previewSvg.setAttribute('aria-hidden', 'true');

            const bg = document.createElementNS('http://www.w3.org/2000/svg', 'rect');
            bg.setAttribute('x', String(bb.x - pad));
            bg.setAttribute('y', String(bb.y - pad));
            bg.setAttribute('width', String(Math.max(bb.w + pad * 2, 1)));
            bg.setAttribute('height', String(Math.max(bb.h + pad * 2, 1)));
            bg.setAttribute('fill', '#ffffff');
            previewSvg.appendChild(bg);

            _appendSelectedObjectPreviewDefs(sourceSvg, previewSvg, sourceEl);
            _appendSelectedObjectCloneInRootSpace(previewSvg, sourceSvg, sourceEl);
            return previewSvg;
        }

        function _buildSelectedObjectPreviewSvg(item) {
            return item?.el ? _buildElementPreviewSvg(item.el) : null;
        }

        function _isColorGroupType(type) {
            return String(type || '').trim().toLowerCase() === 'color';
        }

        function _isUsableColorPaint(value, { allowWhite = false } = {}) {
            const v = String(value || '').trim();
            if (!v) return false;
            const low = v.toLowerCase();
            if (!allowWhite && _svgIsWhiteish(v)) return false;
            return !(low === 'none' || low === 'transparent' || low === 'currentcolor' || low.startsWith('url('));
        }

        function _pickRepresentativeColorFromElements(elements) {
            const scores = new Map();
            const add = (paint, weight) => {
                const key = String(paint || '').trim();
                if (!key) return;
                scores.set(key, (scores.get(key) || 0) + weight);
            };

            for (const el of (elements || [])) {
                if (!el) continue;
                const fill = _svgGetPaint(el, 'fill');
                const stroke = _svgGetPaint(el, 'stroke');
                if (_isUsableColorPaint(fill)) add(fill, 3);
                if (_isUsableColorPaint(stroke, { allowWhite: true })) add(stroke, 2);
                if (_isUsableColorPaint(fill, { allowWhite: true })) add(fill, 1);
            }

            let best = '';
            let bestScore = -1;
            for (const [paint, score] of scores.entries()) {
                if (score > bestScore) {
                    best = paint;
                    bestScore = score;
                }
            }
            return best || '#94a3b8';
        }

        function _buildColorSwatchPreviewSvg(color, label) {
            const previewSvg = document.createElementNS('http://www.w3.org/2000/svg', 'svg');
            previewSvg.setAttribute('viewBox', '0 0 64 64');
            previewSvg.setAttribute('preserveAspectRatio', 'xMidYMid meet');
            previewSvg.setAttribute('aria-hidden', 'true');

            const bg = document.createElementNS('http://www.w3.org/2000/svg', 'rect');
            bg.setAttribute('x', '0');
            bg.setAttribute('y', '0');
            bg.setAttribute('width', '64');
            bg.setAttribute('height', '64');
            bg.setAttribute('rx', '10');
            bg.setAttribute('fill', '#ffffff');
            previewSvg.appendChild(bg);

            const swatch = document.createElementNS('http://www.w3.org/2000/svg', 'rect');
            swatch.setAttribute('x', '10');
            swatch.setAttribute('y', '10');
            swatch.setAttribute('width', '44');
            swatch.setAttribute('height', '44');
            swatch.setAttribute('rx', '8');
            swatch.setAttribute('fill', String(color || '#94a3b8'));
            swatch.setAttribute('stroke', '#0f172a');
            swatch.setAttribute('stroke-width', '2');
            previewSvg.appendChild(swatch);

            if (label) {
                const text = document.createElementNS('http://www.w3.org/2000/svg', 'text');
                text.setAttribute('x', '32');
                text.setAttribute('y', '59');
                text.setAttribute('text-anchor', 'middle');
                text.setAttribute('font-size', '6');
                text.setAttribute('font-family', 'Arial, sans-serif');
                text.setAttribute('fill', '#334155');
                text.textContent = String(label);
                previewSvg.appendChild(text);
            }

            return previewSvg;
        }

        function _buildColorSwatchStandaloneSvg(color) {
            const doc = document.implementation.createDocument('http://www.w3.org/2000/svg', 'svg', null);
            const outSvg = doc.documentElement;
            outSvg.setAttribute('xmlns', 'http://www.w3.org/2000/svg');
            outSvg.setAttribute('viewBox', '0 0 64 64');
            outSvg.setAttribute('data-color-swatch', 'true');

            const bg = doc.createElementNS('http://www.w3.org/2000/svg', 'rect');
            bg.setAttribute('x', '0');
            bg.setAttribute('y', '0');
            bg.setAttribute('width', '64');
            bg.setAttribute('height', '64');
            bg.setAttribute('fill', '#ffffff');
            outSvg.appendChild(bg);

            const swatch = doc.createElementNS('http://www.w3.org/2000/svg', 'rect');
            swatch.setAttribute('x', '8');
            swatch.setAttribute('y', '8');
            swatch.setAttribute('width', '48');
            swatch.setAttribute('height', '48');
            swatch.setAttribute('rx', '8');
            swatch.setAttribute('fill', String(color || '#94a3b8'));
            swatch.setAttribute('stroke', '#0f172a');
            swatch.setAttribute('stroke-width', '2');
            outSvg.appendChild(swatch);

            return new XMLSerializer().serializeToString(outSvg);
        }

        function _buildSelectedObjectsCombinedPreviewSvg(activeItems) {
            const sourceSvg = mergedSvgPreviewScale ? mergedSvgPreviewScale.querySelector('svg') : null;
            if (!sourceSvg || !activeItems?.length) return null;

            const groupType = groupNameSelect ? groupNameSelect.value : '';
            if (_isColorGroupType(groupType)) {
                const color = _pickRepresentativeColorFromElements(activeItems.map(x => x && x.item ? x.item.el : null));
                return _buildColorSwatchPreviewSvg(color, color);
            }

            const validItems = activeItems
                .map(({ item, idx }) => {
                    const bb = item?.bb || _getElementBbox(item?.el, sourceSvg);
                    return item?.el && bb && isFinite(bb.x) && isFinite(bb.y) && isFinite(bb.w) && isFinite(bb.h)
                        ? { item, idx, bb }
                        : null;
                })
                .filter(Boolean);
            if (!validItems.length) return null;

            let minX = Infinity, minY = Infinity, maxX = -Infinity, maxY = -Infinity;
            validItems.forEach(({ bb }) => {
                minX = Math.min(minX, bb.x);
                minY = Math.min(minY, bb.y);
                maxX = Math.max(maxX, bb.x + bb.w);
                maxY = Math.max(maxY, bb.y + bb.h);
            });

            const width = Math.max(maxX - minX, 1);
            const height = Math.max(maxY - minY, 1);
            const pad = Math.max(8, Math.min(24, Math.max(width, height) * 0.08 || 8));
            const previewSvg = document.createElementNS('http://www.w3.org/2000/svg', 'svg');
            previewSvg.setAttribute('viewBox', `${minX - pad} ${minY - pad} ${width + pad * 2} ${height + pad * 2}`);
            previewSvg.setAttribute('preserveAspectRatio', 'xMidYMid meet');
            previewSvg.setAttribute('aria-hidden', 'true');

            const bg = document.createElementNS('http://www.w3.org/2000/svg', 'rect');
            bg.setAttribute('x', String(minX - pad));
            bg.setAttribute('y', String(minY - pad));
            bg.setAttribute('width', String(width + pad * 2));
            bg.setAttribute('height', String(height + pad * 2));
            bg.setAttribute('fill', '#ffffff');
            previewSvg.appendChild(bg);

            const appendedIds = new Set();
            validItems.forEach(({ item }) => _appendSelectedObjectPreviewDefs(sourceSvg, previewSvg, item.el, appendedIds));
            validItems.forEach(({ item }) => _appendSelectedObjectCloneInRootSpace(previewSvg, sourceSvg, item.el));
            return previewSvg;
        }

        function _renderSelectedObjectsHeaderSummary() {
            const summaryEl = document.getElementById('selectedObjectsHeaderSummary');
            const lastCreatedWrap = document.getElementById('mergedSvgLastCreatedGroupPreview');
            if (!summaryEl) return;
