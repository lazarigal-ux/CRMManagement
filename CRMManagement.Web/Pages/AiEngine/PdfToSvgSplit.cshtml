    /* ── Parse SVG elements into a table-friendly array ── */
    function _parseSvgElements(svgText) {
        const rows = [];
        if (!svgText) return rows;
        try {
            const doc = new DOMParser().parseFromString(svgText, 'image/svg+xml');
            if (doc.querySelector('parsererror')) return rows;
            const svg = doc.querySelector('svg');
            if (!svg) return rows;
            const els = svg.querySelectorAll('path, line, polyline, polygon, rect, circle, ellipse, text, image, use, g');
            els.forEach((el, i) => {
                const tag = el.tagName.toLowerCase();
                const transform = el.getAttribute('transform') || '';
                const fill = el.getAttribute('fill') || el.style.fill || '';
                const stroke = el.getAttribute('stroke') || el.style.stroke || '';
                let geometry = '';
                if (tag === 'path') geometry = (el.getAttribute('d') || '').substring(0, 80);
                else if (tag === 'rect') geometry = `x=${el.getAttribute('x')||0} y=${el.getAttribute('y')||0} w=${el.getAttribute('width')||0} h=${el.getAttribute('height')||0}`;
                else if (tag === 'circle') geometry = `cx=${el.getAttribute('cx')||0} cy=${el.getAttribute('cy')||0} r=${el.getAttribute('r')||0}`;
                else if (tag === 'ellipse') geometry = `cx=${el.getAttribute('cx')||0} cy=${el.getAttribute('cy')||0} rx=${el.getAttribute('rx')||0} ry=${el.getAttribute('ry')||0}`;
                else if (tag === 'line') geometry = `x1=${el.getAttribute('x1')||0} y1=${el.getAttribute('y1')||0} x2=${el.getAttribute('x2')||0} y2=${el.getAttribute('y2')||0}`;
                else if (tag === 'polyline' || tag === 'polygon') geometry = (el.getAttribute('points') || '').substring(0, 80);
                else if (tag === 'use') geometry = el.getAttribute('href') || el.getAttribute('xlink:href') || '';
                else if (tag === 'image') geometry = (el.getAttribute('href') || el.getAttribute('xlink:href') || '').substring(0, 60);
                else if (tag === 'text') geometry = (el.textContent || '').substring(0, 60);
                else if (tag === 'g') geometry = `${el.children.length} child element${el.children.length !== 1 ? 's' : ''}`;
                rows.push({ idx: i + 1, tag, transform: transform.substring(0, 60), geometry, fill, stroke });
            });
        } catch { /* ignore */ }
        return rows;
    }

    /* ── Render the tab content panel for a specific sample ── */
    function _renderSavedSampleTabContent(idx) {
        if (!_savedSamplesBrowserBody) return;
        const samples = _savedSamplesBrowserSamples;
        if (idx < 0 || idx >= samples.length) {
            _savedSamplesBrowserBody.innerHTML = '<div class="text-center text-slate-500 py-12">No object selected.</div>';
            return;
        }
        const s = samples[idx];
        const sid = (s && isFinite(s.id)) ? (s.id | 0) : 0;
        const href = (s && s.symbolHref != null) ? String(s.symbolHref).trim() : '';
        const svgText = (s && s.sampleSvg != null) ? String(s.sampleSvg) : '';
        const pageIdx = (s && isFinite(s.pageIndex)) ? (s.pageIndex | 0) : 0;
        let thumbUrl = '';
        try { if (svgText) thumbUrl = _createSvgObjectUrl(_normalizeMapIconSampleSvg(svgText) || svgText) || ''; } catch { /* */ }

        // Parse SVG for elements table
        const elements = _parseSvgElements(svgText);

        // Build content
        let html = '';

        // ── Top section: Preview + Info side by side ──
        html += '<div style="display:flex;flex-direction:row;gap:16px;margin-bottom:16px;align-items:stretch;">';

        // Left: SVG preview (compact, dark-themed with checkerboard)
        html += '<div style="flex-shrink:0;width:180px;">';
        html += '<div class="rounded-xl border border-slate-600/40 p-2 flex items-center justify-center overflow-hidden" style="min-height:100px;max-height:150px;background:#fff;">';
        if (thumbUrl) {
            html += `<img src="${thumbUrl}" class="w-full h-full object-contain" style="max-height:140px;filter:drop-shadow(0 4px 12px rgba(0,0,0,.35));" />`;
        } else {
            html += '<div class="text-center text-slate-500"><i class="fa-regular fa-image text-3xl mb-2 block"></i><span class="text-[11px]">No preview</span></div>';
        }
        html += '</div>';
        html += '</div>';

        // Right: Metadata card
        html += '<div class="flex-1 min-w-0">';
        html += '<div class="rounded-xl border border-slate-600/40 bg-slate-800/50 p-3">';

        // Object name
        html += `<div class="text-sm font-semibold text-slate-100 mb-3 truncate" title="${escapeHtml(href)}">`
              + `<i class="fa-solid fa-cube text-sky-400 text-[11px] mr-2"></i>`
              + escapeHtml(href || ('Object #' + sid))
              + '</div>';

        // Info grid
        html += '<div class="grid grid-cols-2 gap-x-6 gap-y-2 text-[11px] mb-4">';
        html += `<div><span class="text-slate-500 uppercase tracking-wider font-semibold text-[9px]">ID</span><div class="text-slate-200 font-mono">${sid}</div></div>`;
        html += `<div><span class="text-slate-500 uppercase tracking-wider font-semibold text-[9px]">Page</span><div class="text-slate-200">${Number.isFinite(pageIdx) ? (pageIdx + 1) : '—'}</div></div>`;
