        const btnRedo = document.getElementById('btnFamilyEditRedo');
        const btnBrushErase = document.getElementById('btnFamilyEditBrushErase');
        const btnEraseRegion = document.getElementById('btnFamilyEditEraseRegion');
        const btnKeepRegion = document.getElementById('btnFamilyEditKeepRegion');

        if (colorInput) colorInput.addEventListener('input', () => { try { _familyEditState.color = String(colorInput.value || '#000000'); } catch { } });
        if (btnColor) btnColor.addEventListener('click', () => _familyEditApplyColor());
        if (btnBig) btnBig.addEventListener('click', () => _familyEditScaleSelected(2.0));
        if (btnDel) btnDel.addEventListener('click', () => _familyEditDeleteSelected());
        if (btnUndo) btnUndo.addEventListener('click', () => _familyEditUndo());
        if (btnRedo) btnRedo.addEventListener('click', () => _familyEditRedo());
        if (btnBrushErase) btnBrushErase.addEventListener('click', () => _familyEditToggleBrushEraseMode());
        if (btnEraseRegion) btnEraseRegion.addEventListener('click', () => _familyEditStartRegionMode('erase'));
        if (btnKeepRegion) btnKeepRegion.addEventListener('click', () => _familyEditStartRegionMode('keep'));
        if (btnSave) btnSave.addEventListener('click', () => saveEditedFamilySample());

        // Reset undo/redo stacks for new editing session
        _familyEditUndoStack.length = 0;
        _familyEditRedoStack.length = 0;
        _familyEditUpdateUndoRedoButtons();

        body.scrollLeft = 0;
        body.scrollTop = 0;
        try { _setSvgPreviewToolbarMode('family'); } catch { /* ignore */ }
        _applySvgPreviewModalSidebarOffset();
        modal.classList.remove('hidden');
        try {
            // Fit first to guarantee something is visible, then go to 400% and center.
            // Delay one frame so layout settles before computing getBBox/viewBox.
            requestAnimationFrame(() => {
                try {
                    const svgAfter = body.querySelector('#svgPreviewScale svg');
                    if (svgAfter) {
                        console.log('[EDITOR-DBG] rAF: viewBox before fit=', svgAfter.getAttribute('viewBox'));
                        try {
                            const bb1 = svgAfter.getBBox();
                            console.log('[EDITOR-DBG] rAF: getBBox=', bb1 ? { x: bb1.x, y: bb1.y, w: bb1.width, h: bb1.height } : 'null');
                        } catch (e2) { console.warn('[EDITOR-DBG] rAF getBBox error:', e2); }
                    }
                    fitSvgPreviewToViewport();
                    if (svgAfter) console.log('[EDITOR-DBG] rAF: viewBox after fit=', svgAfter.getAttribute('viewBox'));
                    setSvgPreviewZoom(4.0);
                    _centerSvgPreviewScroll();
                } catch { /* ignore */ }
            });
        } catch { /* ignore */ }
    }

    function _familyEditSelectElement(el) {
        try {
            // Ignore clicks while region-draw mode is active
            if (_familyEditRegionMode || _familyEditBrushMode) return;
            // Remove highlight from previous selection
            if (_familyEditState.selectedEl && _familyEditState.selectedEl !== el) {
                try { _familyEditState.selectedEl.style.outline = ''; } catch {}
            }
            _familyEditState.selectedEl = el;
            _familyEditState.baseTransform = (el.getAttribute('transform') || '').toString();
            _familyEditState.scale = 1.0;
            const tag = el && el.tagName ? String(el.tagName).toLowerCase() : '';
            let href = (el.getAttribute && (el.getAttribute('href') || el.getAttribute('xlink:href'))) ? (el.getAttribute('href') || el.getAttribute('xlink:href')) : '';
            // Truncate long data URIs
            if (href.startsWith('data:')) href = href.substring(0, 30) + '…[data]';
            const id = (el.getAttribute && el.getAttribute('id')) ? el.getAttribute('id') : '';
            const lbl = document.getElementById('familyEditSelected');
            if (lbl) lbl.textContent = `Selected: <${tag || '?'}>${id ? (' #' + id) : ''}${href ? (' ' + href) : ''}`;
            // Visual highlight
            try { el.style.outline = '2px solid #3b82f6'; } catch {}
        } catch { /* ignore */ }
    }

    function _familyEditDeleteSelected() {
        const el = _familyEditState.selectedEl;
        if (!el) { cgAlert('Click an object first.'); return; }
        try {
            _familyEditPushUndo();
            el.remove();
            _familyEditState.selectedEl = null;
            const lbl = document.getElementById('familyEditSelected');
            if (lbl) lbl.textContent = 'Selected: — (click an object)';
        } catch (e) {
            cgAlert(`Delete failed: ${String(e)}`);
        }
    }

    function _familyEditApplyColor() {
        const el = _familyEditState.selectedEl;
        if (!el) { cgAlert('Click an object first.'); return; }
        const c = (_familyEditState.color || '#000000').toString();
        try {
            _familyEditPushUndo();
            const fill = (el.getAttribute('fill') || '').toString();
            const stroke = (el.getAttribute('stroke') || '').toString();
            const hasStroke = stroke && stroke.toLowerCase() !== 'none';
            const hasFill = fill && fill.toLowerCase() !== 'none';
            if (hasStroke || (!hasFill && !hasStroke)) el.setAttribute('stroke', c);
            if (hasFill || (!hasFill && !hasStroke)) el.setAttribute('fill', c);
        } catch (e) {
            cgAlert(`Color change failed: ${String(e)}`);
        }
    }

    function _familyEditScaleSelected(factor) {
        const el = _familyEditState.selectedEl;
        if (!el) { cgAlert('Click an object first.'); return; }
        const f = isFinite(factor) ? Number(factor) : 1.0;
        if (!f || f <= 0) return;
        try {
            _familyEditPushUndo();
            const bb = (typeof el.getBBox === 'function') ? el.getBBox() : null;
            if (!bb || !isFinite(bb.x) || !isFinite(bb.y) || !isFinite(bb.width) || !isFinite(bb.height)) {
                cgAlert('Cannot scale this object (no bbox).');
                return;
            }
            const cx = bb.x + bb.width / 2;
            const cy = bb.y + bb.height / 2;
            _familyEditState.scale = (_familyEditState.scale || 1.0) * f;
            const base = (_familyEditState.baseTransform || '').toString();
            const s = _familyEditState.scale;
            const t = `translate(${cx} ${cy}) scale(${s}) translate(${-cx} ${-cy})`;
            el.setAttribute('transform', base ? (t + ' ' + base) : t);
        } catch (e) {
            cgAlert(`Scale failed: ${String(e)}`);
        }
    }

    async function saveEditedFamilySample() {
        const famId = _familyEditState.familyId;
        const sampleId = _familyEditState.sampleId;
        if (!famId || !sampleId) return;
        try {
            const body = document.getElementById('svgPreviewBody');
            const svg = body ? body.querySelector('#svgPreviewScale svg') : null;
            if (!svg) { cgAlert('No SVG found to save.'); return; }
            const xmlRaw = new XMLSerializer().serializeToString(svg);
            const xml = _normalizeMapIconSampleSvg(xmlRaw) || xmlRaw;
            const resp = await fetch(`${OBJECT_FAMILIES_ENDPOINT}/${famId}/samples/${sampleId}`, {
                method: 'PUT',
                headers: { 'Content-Type': 'application/json', 'X-Client-Id': 'admin' },
                body: JSON.stringify({ sampleSvg: xml })
            });
            if (!resp.ok) {
                const t = await resp.text();
                cgAlert(`Save failed: HTTP ${resp.status}: ${t.substring(0, 600)}`);
                return;
            }

            // Close editor immediately on success (no popup), then refresh lists in background.
            try { closeSvgPreview(); } catch { /* ignore */ }
            try {
                Promise.resolve()
                    .then(() => loadObjectFamilies(true))
                    .then(() => viewSelectedFamily())
                    .catch((e) => { try { console.warn('[FAMILY] refresh after save failed:', e); } catch { } });
            } catch { /* ignore */ }
        } catch (e) {
            cgAlert(`Save failed: ${String(e)}`);
        }
    }

    function _getSelectedFamilyId() {
        const v = familySelect ? (familySelect.value || '') : '';
        const id = parseInt(v, 10);
        return Number.isFinite(id) && id > 0 ? id : null;
    }

    function _pickDefaultRegionForFamilyLearning() {
        _syncOutputCropFromSelections();
        if (outputCrop && outputCrop.frac) return { pageIndex: outputCrop.pageIndex || 0, frac: outputCrop.frac };
        const picked = _pickDefaultRegionForOutputCrop();
        if (picked && picked.frac) return { pageIndex: picked.pageIndex || 0, frac: picked.frac };
        return null;
    }

    function _extractUseHrefs(svgText) {
        try {
            const doc = new DOMParser().parseFromString(svgText, 'image/svg+xml');
            const svgRoot = doc.querySelector('svg');
            if (!svgRoot) return { hrefs: [], ignoredGlyphs: 0 };
            const uses = [...svgRoot.querySelectorAll('use')].filter(u => { try { return !u.closest('defs'); } catch { return true; } });
            const hrefs = [];
            let ignoredGlyphs = 0;
            for (const u of uses) {
                const href = (u.getAttribute('href') || u.getAttribute('xlink:href') || '').trim();
                if (!href) continue;
                if (_isLikelyTextGlyphHref(href)) { ignoredGlyphs++; continue; }
                hrefs.push(href);
            }
            return { hrefs, ignoredGlyphs };
        } catch {
            return { hrefs: [], ignoredGlyphs: 0 };
        }
    }

    /**
     * Expand <use> + <symbol> pairs so each tile becomes a direct element
     * (e.g. <image>) that is individually selectable in the editor.
     * Each <use xlink:href="#im1234" x="100" y="200" width="10" height="10">
     * becomes <image x="100" y="200" width="10" height="10" href="data:...">
     */
    function _expandUseSymbolsForEditing(svgText) {
        const parser = new DOMParser();
        const doc = parser.parseFromString(svgText, 'image/svg+xml');
        const svgRoot = doc.querySelector('svg');
        if (!svgRoot) return svgText;

        // Build a map of symbol id → child elements
        const symbolMap = new Map();
        for (const sym of svgRoot.querySelectorAll('defs symbol')) {
            const id = sym.getAttribute('id');
            if (!id) continue;
            symbolMap.set(id, sym);
        }
        if (symbolMap.size === 0) return svgText;

        // Find all <use> that reference symbols and expand them
        const uses = [...svgRoot.querySelectorAll('use')];
        let expanded = 0;
        for (const use of uses) {
            try {
                const href = use.getAttribute('href') || use.getAttribute('xlink:href') || '';
                const id = href.startsWith('#') ? href.substring(1) : '';
                if (!id) continue;
                const sym = symbolMap.get(id);
                if (!sym) continue;

                // Get position/size from <use>
                const ux = use.getAttribute('x') || '0';
                const uy = use.getAttribute('y') || '0';
                const uw = use.getAttribute('width');
                const uh = use.getAttribute('height');

                // Symbol's viewBox (for mapping)
                const svb = sym.getAttribute('viewBox');
                const svbParts = svb ? svb.trim().split(/[\s,]+/).map(Number) : [];
                const hasSymVB = svbParts.length === 4 && svbParts.every(n => isFinite(n));

                // Clone each child of the symbol
                for (const child of sym.children) {
                    const clone = child.cloneNode(true);
                    const tag = clone.tagName ? clone.tagName.toLowerCase() : '';

                    if (tag === 'image' && uw && uh) {
                        // Position the image at the <use> coordinates with <use> dimensions
                        clone.setAttribute('x', ux);
                        clone.setAttribute('y', uy);
                        clone.setAttribute('width', uw);
                        clone.setAttribute('height', uh);
                    } else if (ux !== '0' || uy !== '0') {
                        // Add a translate transform
                        const existing = clone.getAttribute('transform') || '';
                        clone.setAttribute('transform', `translate(${ux},${uy}) ${existing}`.trim());
                    }

                    // Insert before the <use>
                    use.parentNode.insertBefore(clone, use);
                    expanded++;
                }

                // Remove the <use>
                use.remove();
            } catch { /* skip this use */ }
        }

        if (expanded > 0) {
            console.log('[EDITOR-DBG] expanded', expanded, 'elements from', uses.length, 'use tags');
            return new XMLSerializer().serializeToString(svgRoot);
        }
        return svgText;
    }

    function _pickMostCommon(arr) {
        const m = new Map();
        for (const x of arr || []) {
            const k = String(x || '').trim();
            if (!k) continue;
            m.set(k, (m.get(k) || 0) + 1);
        }
        let best = null;
        let bestC = 0;
        m.forEach((c, k) => { if (c > bestC) { bestC = c; best = k; } });
        return { value: best, count: bestC, map: m };
    }

    /**
     * Render an SVG string to a canvas, then produce a compact SVG
     * with a single <image> containing the rasterized data URL.
     * This turns thousands of base64 image-tile fragments into one image.
     */
    async function _renderSvgToCompactImageSvg(svgText) {
        return new Promise((resolve, reject) => {
            try {
                const parser = new DOMParser();
                const doc = parser.parseFromString(svgText, 'image/svg+xml');
                const svgEl = doc.querySelector('svg');
                if (!svgEl) { reject(new Error('No <svg> found')); return; }

                // Use the viewBox or width/height to determine render size
                let vbW = 0, vbH = 0, vbX = 0, vbY = 0;
                const vbAttr = svgEl.getAttribute('viewBox');
                if (vbAttr) {
                    const parts = vbAttr.trim().split(/[\s,]+/).map(Number);
                    if (parts.length === 4 && parts.every(n => isFinite(n))) {
                        vbX = parts[0]; vbY = parts[1]; vbW = parts[2]; vbH = parts[3];
                    }
                }
                if (!(vbW > 0) || !(vbH > 0)) {
                    vbW = parseFloat(svgEl.getAttribute('width')) || 800;
                    vbH = parseFloat(svgEl.getAttribute('height')) || 600;
                }

                // Render at up to 1200px on the long side
                const maxDim = 1200;
                const scale = Math.min(1, maxDim / Math.max(vbW, vbH));
                const canvasW = Math.max(1, Math.round(vbW * scale));
                const canvasH = Math.max(1, Math.round(vbH * scale));

                // Prepare a self-contained SVG blob for the Image
                svgEl.setAttribute('width', String(canvasW));
                svgEl.setAttribute('height', String(canvasH));
                if (!svgEl.getAttribute('viewBox')) {
                    svgEl.setAttribute('viewBox', `${vbX} ${vbY} ${vbW} ${vbH}`);
                }
                const svgStr = new XMLSerializer().serializeToString(svgEl);
                const blob = new Blob([svgStr], { type: 'image/svg+xml;charset=utf-8' });
                const url = URL.createObjectURL(blob);

                const img = new Image();
                img.onload = () => {
                    try {
                        const canvas = document.createElement('canvas');
                        canvas.width = canvasW;
                        canvas.height = canvasH;
                        const ctx = canvas.getContext('2d');
                        ctx.drawImage(img, 0, 0, canvasW, canvasH);
                        URL.revokeObjectURL(url);

                        const dataUrl = canvas.toDataURL('image/png');
                        // Build a simple SVG that just embeds this raster image
                        const compactSvg = `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 ${canvasW} ${canvasH}"><image width="${canvasW}" height="${canvasH}" href="${dataUrl}"/></svg>`;
                        console.log('[LEARN-DBG] compact image SVG size:', compactSvg.length, 'canvas:', canvasW, 'x', canvasH);
                        resolve(compactSvg);
                    } catch (e) {
                        URL.revokeObjectURL(url);
                        reject(e);
                    }
                };
                img.onerror = (e) => {
                    URL.revokeObjectURL(url);
                    reject(new Error('Image render failed: ' + String(e)));
                };
                img.src = url;
            } catch (e) {
                reject(e);
            }
        });
    }

    function _makeCompactSampleSvg(svgText, symbolHref) {
        try {
            const href = (symbolHref || '').toString().trim();
            if (!svgText || !href) return '';

            let id = '';
            if (href.startsWith('#')) id = href.substring(1);
            if (!id) {
                const i = href.indexOf('#');
                if (i >= 0) id = href.substring(i + 1);
            }
            if (!id) return '';

            const doc = new DOMParser().parseFromString(svgText, 'image/svg+xml');
            const root = doc.querySelector('svg');
            if (!root) return '';

            const ref = root.querySelector(`#${CSS.escape(id)}`);
            if (!ref) return '';

            // Estimate bbox for a tight viewBox
            const bb = _estimateSubtreeBBox(ref, ref);
            let vb;
            if (bb && isFinite(bb.x1) && isFinite(bb.y1) && isFinite(bb.x2) && isFinite(bb.y2)) {
                const w = Math.max(1, bb.x2 - bb.x1);
                const h = Math.max(1, bb.y2 - bb.y1);
                const pad = 0.12;
                vb = {
                    x: bb.x1 - w * pad,
                    y: bb.y1 - h * pad,
                    w: w * (1 + 2 * pad),
                    h: h * (1 + 2 * pad)
                };
            } else {
                vb = _parseViewBox(root.getAttribute('viewBox') || '') || { x: 0, y: 0, w: 100, h: 100 };
            }

            const viewBox = `${vb.x} ${vb.y} ${vb.w} ${vb.h}`;

            // For <image> elements, <use> doesn't render the image visually.
            // Place the element directly in the SVG instead of in defs+use.
            const tagName = (ref.tagName || '').toLowerCase();
            if (tagName === 'image') {
                const clone = ref.cloneNode(true);
                clone.removeAttribute('id');
                const raw = `<svg xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink" viewBox="${escapeHtml(viewBox)}">${clone.outerHTML}</svg>`;
                return _normalizeMapIconSampleSvg(raw) || raw;
            }

            // For <symbol>, <g>, <path>, etc. — use defs+use as before.
            const defs = `<defs>${ref.outerHTML}</defs>`;
            const raw = `<svg xmlns="http://www.w3.org/2000/svg" viewBox="${escapeHtml(viewBox)}">${defs}<use href="#${escapeHtml(id)}" /></svg>`;
            return _normalizeMapIconSampleSvg(raw) || raw;
        } catch {
            return '';
        }
    }

    function _parseSvgInlineStyle(styleText) {
        const map = {};
        String(styleText || '').split(';').forEach(part => {
            const i = part.indexOf(':');
            if (i <= 0) return;
            const key = part.substring(0, i).trim().toLowerCase();
            const value = part.substring(i + 1).trim();
            if (!key) return;
            map[key] = value;
        });
        return map;
    }

    function _stringifySvgInlineStyle(styleMap) {
        return Object.entries(styleMap || {})
            .filter(([k, v]) => k && v != null && String(v).trim())
            .map(([k, v]) => `${k}:${String(v).trim()}`)
            .join('; ');
    }

    function _svgPaintIsNone(value) {
        const s = String(value || '').trim().toLowerCase();
        return !s || s === 'none' || s === 'transparent' || s === 'rgba(0,0,0,0)' || s === 'rgba(0, 0, 0, 0)';
    }

    function _svgPaintIsNearWhite(value) {
        const s = String(value || '').trim().toLowerCase();
        if (!s) return false;
        if (s === '#fff' || s === '#ffffff' || s === 'white') return true;
        const rgb = s.match(/^rgba?\(([^)]+)\)$/);
        if (!rgb) return false;
        const parts = rgb[1].split(',').map(x => Number.parseFloat(String(x).trim()));
        if (parts.length < 3 || parts.slice(0, 3).some(n => !Number.isFinite(n))) return false;
        const alpha = parts.length > 3 ? parts[3] : 1;
        return alpha > 0.2 && parts[0] >= 240 && parts[1] >= 240 && parts[2] >= 240;
    }

    function _normalizeMapIconSampleSvg(svgText) {
        try {
            const raw = String(svgText || '').trim();
            if (!raw || raw.indexOf('<svg') < 0) return raw;

            // Preserve color swatches — skip normalization entirely
            if (raw.indexOf('data-color-swatch') >= 0) return raw;

            const doc = new DOMParser().parseFromString(raw, 'image/svg+xml');
            const root = doc.querySelector('svg');
            if (!root) return raw;

            const vb = _parseViewBox(root.getAttribute('viewBox') || '');
            const fillColor = '#374151';
            const strokeColor = '#111827';
            const skipParents = new Set(['clipPath', 'mask', 'pattern', 'marker', 'linearGradient', 'radialGradient', 'filter']);

            root.querySelectorAll('rect, path, circle, ellipse, polygon, polyline, line, text, tspan, use, g, symbol').forEach(el => {
                try {
                    const tag = (el.tagName || '').toLowerCase();
                    const parentTag = (el.parentNode && el.parentNode.tagName) ? String(el.parentNode.tagName).toLowerCase() : '';
                    if (skipParents.has(parentTag)) return;

                    const styleMap = _parseSvgInlineStyle(el.getAttribute('style') || '');
                    const fillValue = el.getAttribute('fill') ?? styleMap.fill ?? '';
                    const strokeValue = el.getAttribute('stroke') ?? styleMap.stroke ?? '';

                    if (tag === 'rect' && vb && _svgPaintIsNearWhite(fillValue) && _svgPaintIsNone(strokeValue)) {
                        const w = Number.parseFloat(el.getAttribute('width') || '0');
                        const h = Number.parseFloat(el.getAttribute('height') || '0');
                        if (Number.isFinite(w) && Number.isFinite(h) && vb.w > 0 && vb.h > 0 && w >= vb.w * 0.8 && h >= vb.h * 0.8) {
                            el.remove();
                            return;
                        }
                    }

                    delete styleMap.filter;
                    delete styleMap['drop-shadow'];
                    delete styleMap.color;

                    const isLineLike = tag === 'line' || tag === 'polyline' || (tag === 'path' && _svgPaintIsNone(fillValue));
                    const isText = tag === 'text' || tag === 'tspan';

                    if (isText) {
                        el.setAttribute('fill', strokeColor);
                        styleMap.fill = strokeColor;
                        el.removeAttribute('stroke');
                        delete styleMap.stroke;
                    } else {
                        if (!_svgPaintIsNone(fillValue) && !_svgPaintIsNearWhite(fillValue)) {
                            el.setAttribute('fill', fillColor);
                            styleMap.fill = fillColor;
                        } else if (_svgPaintIsNearWhite(fillValue)) {
                            el.setAttribute('fill', 'none');
                            styleMap.fill = 'none';
                        }

                        if (!_svgPaintIsNone(strokeValue) || isLineLike) {
                            el.setAttribute('stroke', strokeColor);
                            styleMap.stroke = strokeColor;
                        }

                        if (tag === 'g' || tag === 'symbol') {
                            el.removeAttribute('fill');
                            el.removeAttribute('stroke');
                            delete styleMap.fill;
                            delete styleMap.stroke;
                        }
                    }

                    const styleText = _stringifySvgInlineStyle(styleMap);
                    if (styleText) el.setAttribute('style', styleText);
                    else el.removeAttribute('style');
                } catch { /* ignore per-element normalization failures */ }
            });

            root.style.background = 'transparent';
            root.removeAttribute('width');
            root.removeAttribute('height');
            return new XMLSerializer().serializeToString(root);
        } catch {
            return String(svgText || '');
        }
    }

    function _clamp01(x) { return Math.max(0, Math.min(1, x)); }

    function _getPdfPageImgEl(pageIndex) {
        try {
            if (!pdfPages) return null;
            const wrap = pdfPages.querySelector(`.pdf-page-wrap[data-page-index="${pageIndex}"]`);
            if (!wrap) return null;
            return wrap.querySelector('img');
        } catch {
            return null;
        }
    }

    function _makePdfThumbFromFrac(pageIndex, frac, padFrac) {
        return _makePdfThumbFromFracEx(pageIndex, frac, padFrac, 96);
    }

    function _makePdfThumbFromFracEx(pageIndex, frac, padFrac, maxSidePx) {
        try {
            const img = _getPdfPageImgEl(pageIndex);
            if (!img || !img.naturalWidth || !img.naturalHeight) return null;

            const p = isFinite(padFrac) ? padFrac : 0.01;
            const fx1 = _clamp01((frac.x || 0) - p);
            const fy1 = _clamp01((frac.y || 0) - p);
            const fx2 = _clamp01((frac.x || 0) + (frac.w || 0) + p);
            const fy2 = _clamp01((frac.y || 0) + (frac.h || 0) + p);

            const sx = Math.round(fx1 * img.naturalWidth);
            const sy = Math.round(fy1 * img.naturalHeight);
            const sw = Math.max(1, Math.round((fx2 - fx1) * img.naturalWidth));
            const sh = Math.max(1, Math.round((fy2 - fy1) * img.naturalHeight));

            const maxSide = Math.max(32, parseInt(String(maxSidePx || 96), 10) || 96);
            const scale = Math.min(1, maxSide / Math.max(sw, sh));
            const tw = Math.max(1, Math.round(sw * scale));
            const th = Math.max(1, Math.round(sh * scale));

            const c = document.createElement('canvas');
            c.width = tw;
            c.height = th;
            const ctx = c.getContext('2d');
            ctx.imageSmoothingEnabled = true;
            ctx.drawImage(img, sx, sy, sw, sh, 0, 0, tw, th);
            return c.toDataURL('image/png');
        } catch {
            return null;
        }
    }

    function _parseViewBox(vb) {
        const parts = (vb || '').trim().split(/\s+/).map(Number).filter(n => isFinite(n));
        if (parts.length >= 4) return { x: parts[0], y: parts[1], w: parts[2], h: parts[3] };
        return null;
    }

    function _unionBBox(a, b) {
        if (!a) return b;
        if (!b) return a;
        return { x1: Math.min(a.x1, b.x1), y1: Math.min(a.y1, b.y1), x2: Math.max(a.x2, b.x2), y2: Math.max(a.y2, b.y2) };
    }

    function _estimateSubtreeBBox(rootEl, subtreeRoot) {
        try {
            if (!rootEl) return null;
            const SEL = 'path, rect, circle, ellipse, line, polyline, polygon, text, image';
            let bb = null;

            // Include root element itself if it's a primitive shape
            const direct = _estimateElBBox(rootEl);
            if (direct) {
                const md = _getCumulativeTransform(rootEl, subtreeRoot);
                bb = _unionBBox(bb, _transformBBox(direct, md));
            }

            const shapes = [...rootEl.querySelectorAll(SEL)];
            for (const el of shapes) {
                const local = _estimateElBBox(el);
                if (!local) continue;
                const m = _getCumulativeTransform(el, subtreeRoot);
                bb = _unionBBox(bb, _transformBBox(local, m));
            }
            return bb;
        } catch {
            return null;
        }
    }

    function _getParentCumulativeTransform(el, svgRoot) {
        let m = [1, 0, 0, 1, 0, 0];
        let cur = el ? el.parentElement : null;
        while (cur && cur !== svgRoot) {
            const tr = cur.getAttribute && cur.getAttribute('transform');
            if (tr) {
                const parsed = _parseTransform(tr);
                if (parsed) m = _matrixMul(parsed, m);
            }
            cur = cur.parentElement;
        }
        return m;
    }

    function _estimateUseBBox(useEl, svgRoot, idMap) {
        try {
            if (!useEl || !svgRoot) return null;
            const hrefRaw = (useEl.getAttribute('href') || useEl.getAttribute('xlink:href') || '').trim();
            if (!hrefRaw) return null;

            let id = '';
            if (hrefRaw.startsWith('#')) id = hrefRaw.substring(1);
            if (!id) {
                const i = hrefRaw.indexOf('#');
                if (i >= 0) id = hrefRaw.substring(i + 1);
            }
            const ref = id ? (idMap && idMap.get(id)) : null;
            if (!ref) return null;

            const refBB = _estimateSubtreeBBox(ref, ref);
            if (!refBB) return null;

            const ux = parseFloat(useEl.getAttribute('x')) || 0;
            const uy = parseFloat(useEl.getAttribute('y')) || 0;
            const tTranslate = _matrixTranslate(ux, uy);
            const tUse = _parseTransform(useEl.getAttribute('transform')) || [1, 0, 0, 1, 0, 0];

            // Approx order: parent transforms * use.transform * translate(x,y)
            const parentM = _getParentCumulativeTransform(useEl, svgRoot);
            const inst = _matrixMul(tUse, tTranslate);
            const totalM = _matrixMul(parentM, inst);
            return _transformBBox(refBB, totalM);
        } catch {
            return null;
        }
    }

    async function _buildFamilyLearnModel({ pageIndex, regionFrac, familyId, learnedHref, croppedSvgText }) {
        const fams = await loadObjectFamilies(false);
        const fam = (fams || []).find(x => x && x.id === familyId) || null;
        const famName = fam ? (fam.name || '') : '';
        const sampleHrefs = fam && Array.isArray(fam.sampleHrefs) ? fam.sampleHrefs : [];
        const sampleSet = new Set(sampleHrefs.map(s => (s || '').toString().trim()).filter(Boolean));

        let totalObjects = 0;
        let ignoredGlyphs = 0;
        let grouped = [];

        try {
            const doc = new DOMParser().parseFromString(croppedSvgText, 'image/svg+xml');
            const svgRoot = doc.querySelector('svg');
            if (svgRoot) {
                const vb = _parseViewBox(svgRoot.getAttribute('viewBox') || '');
                const idMap = new Map();
                [...svgRoot.querySelectorAll('[id]')].forEach(el => {
                    const id = (el.getAttribute('id') || '').trim();
                    if (id) idMap.set(id, el);
                });

                const uses = [...svgRoot.querySelectorAll('use')].filter(u => { try { return !u.closest('defs'); } catch { return true; } });
                const byHref = new Map();
                for (const u of uses) {
                    const href = (u.getAttribute('href') || u.getAttribute('xlink:href') || '').trim();
                    if (!href) continue;
                    if (_isLikelyTextGlyphHref(href)) { ignoredGlyphs++; continue; }
                    const key = _normalizeSymbolHref(href) || href;

                    const bb = _estimateUseBBox(u, svgRoot, idMap);

                    const cur = byHref.get(key) || { href, key, count: 0, bb: null };
                    cur.count++;
                    if (!cur.bb && bb) cur.bb = bb;
                    byHref.set(key, cur);
                    totalObjects++;
                }

                grouped = [...byHref.values()].sort((a, b) => (b.count || 0) - (a.count || 0));

                // Heuristic: some PDFs produce many per-instance image fragments (#im####),
                // which are not meaningful as separate objects for the user.
                // In that case, show a single composite item for the entire selected region.
                try {
                    const uniq = grouped.length;
                    const allSingle = uniq > 0 && grouped.every(x => (x && (x.count || 0) === 1));
                    const imLike = grouped.filter(x => {
                        const h = (x && x.href) ? String(x.href).trim() : '';
                        const n = _normalizeSymbolHref(h).toLowerCase();
                        return /^#im\d+$/.test(n);
                    }).length;
                    const mostlyIm = uniq > 0 && (imLike / uniq) >= 0.8;
                    if (uniq >= 6 && allSingle && mostlyIm) {
                        const regionThumb = (regionFrac && typeof regionFrac === 'object')
                            ? _makePdfThumbFromFrac(pageIndex || 0, regionFrac, 0.01)
                            : null;
                        const composite = {
                            href: '__composite__',
                            label: 'Selected region (composite)',
                            count: uniq,
                            inFamily: false,
                            thumbDataUrl: regionThumb
                        };
                        return {
                            familyId,
                            familyName: famName || `Family #${familyId}`,
                            learnedHref: learnedHref || '',
                            familySampleHrefs: sampleHrefs,
                            objects: [composite],
                            shownObjects: 1,
                            uniqueObjects: 1,
                            totalObjects: 1,
                            ignoredGlyphs
                        };
                    }
                } catch { /* ignore */ }

                // Build thumbnails (cap for UI safety)
                const MAX_SHOW = 200;
                const shown = grouped.slice(0, MAX_SHOW);
                const objects = shown.map(o => {
                    let thumb = null;
                    try {
                        if (vb && o.bb) {
                            // object bbox → frac within cropped viewBox
                            const fx = (o.bb.x1 - vb.x) / vb.w;
                            const fy = (o.bb.y1 - vb.y) / vb.h;
                            const fw = (o.bb.x2 - o.bb.x1) / vb.w;
                            const fh = (o.bb.y2 - o.bb.y1) / vb.h;

                            // region frac → page frac
                            const pageFrac = {
                                x: (regionFrac.x || 0) + _clamp01(fx) * (regionFrac.w || 0),
                                y: (regionFrac.y || 0) + _clamp01(fy) * (regionFrac.h || 0),
                                w: _clamp01(fw) * (regionFrac.w || 0),
                                h: _clamp01(fh) * (regionFrac.h || 0)
                            };
                            thumb = _makePdfThumbFromFrac(pageIndex || 0, pageFrac, 0.01);
                        }
                    } catch { /* ignore */ }

                    const hrefNorm = _normalizeSymbolHref(o.href);
                    const inFamily = sampleSet.has(o.href) || (hrefNorm && sampleSet.has(hrefNorm));
                    return { href: o.href, count: o.count || 0, inFamily, thumbDataUrl: thumb };
                });

                return {
                    familyId,
                    familyName: famName || `Family #${familyId}`,
                    learnedHref: learnedHref || '',
                    familySampleHrefs: sampleHrefs,
                    objects,
                    shownObjects: objects.length,
                    uniqueObjects: grouped.length,
                    totalObjects,
                    ignoredGlyphs
                };
            }
        } catch {
            // ignore
        }

        return {
            familyId,
            familyName: famName || `Family #${familyId}`,
            learnedHref: learnedHref || '',
            familySampleHrefs: sampleHrefs,
            objects: [],
            shownObjects: 0,
            uniqueObjects: 0,
            totalObjects,
            ignoredGlyphs
        };
    }

    async function learnFamilyFromSelectedRegion() {
        const famId = _getSelectedFamilyId();
        if (!famId) { cgAlert('Pick a family first.'); return; }
        const file = (pdfFileInput && pdfFileInput.files) ? pdfFileInput.files[0] : null;
        if (!file) { cgAlert('Select a PDF file first.'); return; }
        const picked = _pickDefaultRegionForFamilyLearning();
        if (!picked) { cgAlert('Draw a region first (Select Regions).'); return; }

        try {
            if (btnFamilyLearn) btnFamilyLearn.disabled = true;

            if (familyLearnPanelBody) familyLearnPanelBody.innerHTML = '<div class="p-3 text-xs text-slate-300">Loading…</div>';
            if (familyLearnPanelSummary) familyLearnPanelSummary.textContent = 'Loading…';
            openFamilyLearnPanel();

            const fd = new FormData();
            fd.append('pdf', file, file.name);
            const resp = await fetch(VECTOR_PDF_SVG_ENDPOINT, {
                method: 'POST',
                body: fd,
                headers: { 'X-Client-Id': 'admin' }
            });
            if (!resp.ok) {
                const t = await resp.text();
                cgAlert(`Vector SVG failed: HTTP ${resp.status}: ${t.substring(0, 600)}`);
                return;
            }
            let svgText = await resp.text();

            // Mirror pipeline: apply global output crop first (if any)
            _syncOutputCropFromSelections();
            let regionFracForPage = picked.frac;
            if (outputCrop && outputCrop.frac) {
                try { svgText = cropSvgByFraction(svgText, outputCrop.frac); } catch { }
                const a = outputCrop.frac;
                const b = picked.frac;
                const eps = 1e-6;
                const same = a && b
                    && Math.abs((a.x||0) - (b.x||0)) < eps
                    && Math.abs((a.y||0) - (b.y||0)) < eps
                    && Math.abs((a.w||0) - (b.w||0)) < eps
                    && Math.abs((a.h||0) - (b.h||0)) < eps;
                if (same) {
                    // already cropped to the learn region
                    regionFracForPage = outputCrop.frac;
                } else {
                    // crop within the globally-cropped SVG using relative fractions
                    const rel = {
                        x: (b.x - a.x) / (a.w || 1),
                        y: (b.y - a.y) / (a.h || 1),
                        w: (b.w) / (a.w || 1),
                        h: (b.h) / (a.h || 1)
                    };
                    try { svgText = cropSvgByFraction(svgText, rel); } catch { }
                }
            } else {
                try { svgText = cropSvgByFraction(svgText, picked.frac); } catch { }
            }

            const cropped = svgText;
            // Debug: show the cropped SVG viewBox and first few elements
            try {
                const _dbgParser = new DOMParser();
                const _dbgDoc = _dbgParser.parseFromString(cropped, 'image/svg+xml');
                const _dbgSvg = _dbgDoc.querySelector('svg');
                if (_dbgSvg) {
                    console.log('[LEARN-DBG] cropped SVG viewBox:', _dbgSvg.getAttribute('viewBox'), 'width:', _dbgSvg.getAttribute('width'), 'height:', _dbgSvg.getAttribute('height'));
                    const _dbgUses = [..._dbgSvg.querySelectorAll('use')].slice(0, 3);
                    for (const u of _dbgUses) console.log('[LEARN-DBG] <use>', { href: u.getAttribute('href') || u.getAttribute('xlink:href'), x: u.getAttribute('x'), y: u.getAttribute('y') });
                    const _dbgImgs = [..._dbgSvg.querySelectorAll('image')].slice(0, 3);
                    for (const im of _dbgImgs) console.log('[LEARN-DBG] <image>', { id: im.id, x: im.getAttribute('x'), y: im.getAttribute('y'), w: im.getAttribute('width'), h: im.getAttribute('height') });
                }
            } catch {}
            const hrefStats = _extractUseHrefs(cropped);
            const hrefs = (hrefStats && Array.isArray(hrefStats.hrefs)) ? hrefStats.hrefs : [];
            const ignoredGlyphs = (hrefStats && typeof hrefStats.ignoredGlyphs === 'number') ? hrefStats.ignoredGlyphs : 0;
            const pickedHref = _pickMostCommon(hrefs);
            if (!pickedHref.value) {
                await loadObjectFamilies(true);
                const emptyModel = await _buildFamilyLearnModel({
                    pageIndex: picked.pageIndex || 0,
                    regionFrac: regionFracForPage,
                    familyId: famId,
                    learnedHref: '',
                    croppedSvgText: cropped
                });
                emptyModel.ignoredGlyphs = Math.max(emptyModel.ignoredGlyphs || 0, ignoredGlyphs || 0);
                if ((ignoredGlyphs || 0) > 0) {
                    emptyModel.warning = 'Only text glyphs were detected in this region (e.g. #font_*). Select a region around the symbol/shape (not text) and try again.';
                }
                _renderFamilyLearnPanel(emptyModel);
                return;
            }

            const postUrl = `${OBJECT_FAMILIES_ENDPOINT}/${famId}/samples`;

            // For composite image-fragment regions (#im####), the compact single-symbol
            // SVG would just be one invisible tile. Save the entire cropped region instead.
            let compactSample = '';
            let isComposite = false;
            try {
                isComposite = !!(hrefStats && Array.isArray(hrefStats.hrefs)) && (() => {
                    const unique = new Set(hrefStats.hrefs);
                    if (unique.size < 6) return false;
                    let imCount = 0;
                    for (const h of unique) {
                        const n = _normalizeSymbolHref(h).toLowerCase();
                        if (/^#im\d+$/.test(n)) imCount++;
                    }
                    return (imCount / unique.size) >= 0.8;
                })();
                if (isComposite) {
                    // Composite: render to canvas and create a single-image SVG (much smaller than 2308 tiles)
                    console.log('[LEARN-DBG] composite detected, cropped SVG length=', cropped.length, '— rendering to raster');
                    try {
                        compactSample = await _renderSvgToCompactImageSvg(cropped);
                        console.log('[LEARN-DBG] rasterized compact SVG length=', compactSample.length);
                    } catch (rasterErr) {
                        console.warn('[LEARN-DBG] rasterization failed:', rasterErr);
                        compactSample = '';
                    }
                } else {
                    compactSample = _makeCompactSampleSvg(cropped, pickedHref.value);
                }
            } catch {
                compactSample = _makeCompactSampleSvg(cropped, pickedHref.value);
            }
            const sampleSvgRaw = compactSample || ((cropped.length <= 2_000_000) ? cropped : '');
            const payload = {
                symbolHref: pickedHref.value,
                sampleSvg: _normalizeMapIconSampleSvg(sampleSvgRaw) || sampleSvgRaw,
                pageIndex: picked.pageIndex || 0,
                cropFracJson: JSON.stringify(picked.frac)
            };
            console.log('[LEARN-DBG] payload sampleSvg length=', payload.sampleSvg.length, 'symbolHref=', payload.symbolHref);

            // De-duplicate: if this family already has a sample for this symbolHref, update instead of creating a new one.
            // Skip dedup for composite image-tile regions — different selected regions share the same
            // tile IDs (#im####) so dedup would wrongly overwrite previous samples.
            let existingId = 0;
            if (isComposite) {
                console.log('[LEARN-DBG] dedup SKIPPED — composite image-tile region (always create new sample)');
            } else {
            try {
                const viewForDedup = await _fetchFamilySamplesForPanel(famId);
                console.log('[LEARN-DBG] dedup: loaded', viewForDedup?.samples?.length || 0, 'samples for family', famId);
                if (viewForDedup && Array.isArray(viewForDedup.samples)) {
                    const target = _normalizeSymbolHref(payload.symbolHref);
                    console.log('[LEARN-DBG] dedup: looking for target=', target);
                    for (const s of viewForDedup.samples) {
                        if (!s || !s.symbolHref) continue;
                        const sn = _normalizeSymbolHref(s.symbolHref);
                        console.log('[LEARN-DBG] dedup: comparing', sn, 'vs', target, 'id=', s.id);
                        if (sn === target) { existingId = s.id || 0; break; }
                    }
                }
                console.log('[LEARN-DBG] dedup result: existingId=', existingId);
            } catch (dedupErr) { console.warn('[LEARN-DBG] dedup error:', dedupErr); }
            }

            let resp2;
            if (existingId > 0) {
                // Update existing sample
                const putUrl = `${OBJECT_FAMILIES_ENDPOINT}/${famId}/samples/${existingId}`;
                resp2 = await fetch(putUrl, {
                    method: 'PUT',
                    headers: { 'Content-Type': 'application/json', 'X-Client-Id': 'admin' },
                    body: JSON.stringify({ sampleSvg: payload.sampleSvg })
                });
            } else {
                resp2 = await fetch(postUrl, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json', 'X-Client-Id': 'admin' },
                    body: JSON.stringify(payload)
                });
            }
            if (!resp2.ok) {
                const t2 = await resp2.text();
                await loadObjectFamilies(true);
                const failModel = await _buildFamilyLearnModel({
                    pageIndex: picked.pageIndex || 0,
                    regionFrac: regionFracForPage,
                    familyId: famId,
                    learnedHref: pickedHref.value,
                    croppedSvgText: cropped
                });
                _renderFamilyLearnPanel(failModel);
                return;
            }

            let createdSampleId = existingId > 0 ? existingId : 0;
            if (!existingId) {
                try {
                    const created = await resp2.json();
                    createdSampleId = (created && isFinite(created.sampleId)) ? (created.sampleId | 0) : 0;
                } catch { /* ignore */ }
            }

            await loadObjectFamilies(true);
            try { if (familySelect) familySelect.value = String(famId); } catch { /* ignore */ }
            const model = await _buildFamilyLearnModel({
                pageIndex: picked.pageIndex || 0,
                regionFrac: regionFracForPage,
                familyId: famId,
                learnedHref: pickedHref.value,
                croppedSvgText: cropped
            });

            // Also load family samples so the user can immediately open the editor.
            try {
                const view = await _fetchFamilySamplesForPanel(famId);
                if (view && Array.isArray(view.samples)) {
                    model.familySamples = view.samples;
                    model.familySampleHrefs = [...new Set(view.samples.map(s => (s && s.symbolHref) ? String(s.symbolHref).trim() : '').filter(Boolean))];
                    if (view.familyName) model.familyName = view.familyName;

                    // Fallback: if POST didn't return a usable sampleId, infer the latest sample for this symbol.
                    if (!(createdSampleId > 0)) {
                        try {
                            const target = String(pickedHref.value || '').trim();
                            const tn = _normalizeSymbolHref(target);
                            for (const s of view.samples) {
                                const sid = (s && isFinite(s.id)) ? (s.id | 0) : 0;
                                if (sid <= 0) continue;
                                const sh = (s && s.symbolHref != null) ? String(s.symbolHref).trim() : '';
                                if (!sh) continue;
                                const sn = _normalizeSymbolHref(sh);
                                if (sh === target || (tn && sn && sn === tn)) { createdSampleId = sid; break; }
                            }
                        } catch { /* ignore */ }
                    }
                }
            } catch { /* ignore */ }
            model.learnedSampleId = createdSampleId;
            _renderFamilyLearnPanel(model);

            // Auto-open the editor so the user sees the learned sample immediately.
            if (createdSampleId > 0 && _familyViewSamplesById && _familyViewSamplesById.has(createdSampleId)) {
                try { openFamilySampleEditor(createdSampleId); } catch { /* ignore */ }
            }
        } catch (e) {
            cgAlert(`Learn failed: ${String(e)}`);
        } finally {
            if (btnFamilyLearn) btnFamilyLearn.disabled = false;
            updateCropClearBtn();
        }
    }

    if (familySelect) familySelect.addEventListener('change', async () => {
        _rememberSelectedFamilyId(familySelect.value || '');
