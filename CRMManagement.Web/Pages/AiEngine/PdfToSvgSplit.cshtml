                            <i class="fa-solid ${_familyYoloDbTransferState.busy && _familyYoloDbTransferState.mode === 'importJson' ? 'fa-spinner fa-spin' : 'fa-upload'}"></i> ${_familyYoloDbTransferState.busy && _familyYoloDbTransferState.mode === 'importJson' ? 'Importing…' : 'Import from export file'}
