                    async function scanSelectedFamilyInPdfLocateParallel() {
                        const famId = _getSelectedFamilyId();
                        if (!famId) { cgAlert('Pick a family first.'); return; }
                        const file = (pdfFileInput && pdfFileInput.files && pdfFileInput.files.length) ? pdfFileInput.files[0] : null;
                        if (!file) { cgAlert('Pick a PDF first.'); return; }
                        try {
                            _familyScanBusy = true;
                            _resetFamilyLocateUi('Parallel (CV + YOLO)');
                            _appendFamilyScanLog(`Locate start (Parallel CV + YOLO) fam=${famId} pdf=${file.name || 'document.pdf'} (${file.size || 0} bytes)`);
                            if (_lastFamilyLearnModel) _renderFamilyLearnPanel(_lastFamilyLearnModel);

                            const [cvRes, yoloRes] = await Promise.allSettled([
                                _requestCvLocate(famId, file, { allowEmpty: true }),
                                _requestYoloLocate(famId, file, { allowEmpty: true })
                            ]);

                            const cv = cvRes.status === 'fulfilled' ? cvRes.value : null;
                            const yolo = yoloRes.status === 'fulfilled' ? yoloRes.value : null;
                            if (cvRes.status !== 'fulfilled') _appendFamilyScanLog(`Parallel CV failed: ${String(cvRes.reason)}`);
                            if (yoloRes.status !== 'fulfilled') _appendFamilyScanLog(`Parallel YOLO failed: ${String(yoloRes.reason)}`);
                            if (!cv && !yolo) throw new Error('Both CV and YOLO locate failed.');

                            const mergedRows = _mergeParallelDetections(cv ? cv.rows : [], yolo ? yolo.rows : []);
                            if (!mergedRows.length) throw new Error('No detections found by CV or YOLO.');
                            const mergedPages = _buildParallelAnnotatedPages(cv ? cv.annotatedPages : [], yolo ? yolo.annotatedPages : [], mergedRows);
                            _setFamilyLocateResults('Parallel (CV + YOLO)', mergedRows, mergedPages);
                            _appendFamilyScanLog(`Parallel locate complete: ${mergedRows.length} merged detection(s)`);
                            await refreshSelectedFamilyYoloStatus(true);
                        } catch (e) {
                            try { _appendFamilyScanLog(`Parallel locate error: ${String(e)}`); } catch { /* ignore */ }
                            cgAlert(`Parallel locate failed: ${String(e)}`);
                        } finally {
                            try {
                                _familyScanBusy = false;
                                if (_lastFamilyLearnModel) _renderFamilyLearnPanel(_lastFamilyLearnModel);
                            } catch { /* ignore */ }
                        }
                    }
