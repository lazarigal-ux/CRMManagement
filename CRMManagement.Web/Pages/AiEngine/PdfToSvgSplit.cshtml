                // Show status
                _hideDeleteOverlay();
                if (deleteStatus) {
                    const extra = removedFromFull !== removeSet.size ? ` (${removedFromFull} removed from full SVG)` : '';
                    deleteStatus.textContent = `Deleted ${elementLineIndexes.length} element(s) from ${areaLabel}${extra}`;
                    deleteStatus.classList.remove('hidden');
                    setTimeout(() => deleteStatus.classList.add('hidden'), 3500);
                }

                // Animate the button
                _flashDeleteBtn(btnDeleteAll);

                // DELETE ALL never saves to DB
                // (removed _saveDeletedLinesToDb call)
            });
