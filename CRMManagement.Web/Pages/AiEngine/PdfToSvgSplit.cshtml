    async function _persistSelectedFamilyYoloDetectSettings() {
        const famId = _getSelectedFamilyId();
        if (!famId) return;
        const settings = _getFamilyYoloDetectSettings();
        try {
            const resp = await fetch(`${OBJECT_FAMILIES_ENDPOINT}/${famId}/yolo-detect-settings`, {
                method: 'PUT',
                headers: { 'Content-Type': 'application/json', 'X-Client-Id': 'admin' },
                body: JSON.stringify({ conf: settings.conf, iou: settings.iou, imgsz: settings.imgsz })
            });
            if (!resp.ok) throw new Error(await resp.text());
            const obj = await resp.json();
            if (obj && obj.yoloDetectSettings) {
                _familyYoloDetectSettings = _normalizeFamilyYoloDetectSettings(obj.yoloDetectSettings);
                _updateSelectedFamilyRecordDetectSettings(obj.yoloDetectSettings);
                _saveFamilyYoloDetectSettings();
