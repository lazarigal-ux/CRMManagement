                    createdIndex.className = 'merged-svg-last-created-group__title';
                    createdIndex.textContent = 'Created group';
                    const createdTag = document.createElement('span');
                    createdTag.className = 'merged-svg-last-created-group__name';
                    createdTag.textContent = String((_lastCreatedGroupInfo && _lastCreatedGroupInfo.groupName) || 'SVG group').replace(/-/g, ' ');
                    const createdNote = document.createElement('span');
                    createdNote.className = 'merged-svg-last-created-group__note';
                    createdNote.textContent = 'נשאר למעלה בתצוגה מוקטנת';
                    createdMeta.appendChild(createdIndex);
                    createdMeta.appendChild(createdTag);
