    async function _autoTrimImageElementToInk(imgEl, opts) {
        const pad = (opts && isFinite(opts.pad)) ? (opts.pad | 0) : 6;
        const threshold = (opts && isFinite(opts.threshold)) ? (opts.threshold | 0) : 248;
        const step = (opts && isFinite(opts.step)) ? Math.max(1, (opts.step | 0)) : 2;
        if (!imgEl) return;
        const nw = imgEl.naturalWidth || 0;
        const nh = imgEl.naturalHeight || 0;
        if (!nw || !nh) return;

        const c = document.createElement('canvas');
        c.width = nw;
        c.height = nh;
        const ctx = c.getContext('2d');
        if (!ctx) return;
        ctx.drawImage(imgEl, 0, 0);
        const id = ctx.getImageData(0, 0, nw, nh);
        const data = id.data;

        let minX = nw, minY = nh, maxX = -1, maxY = -1;
        for (let y = 0; y < nh; y += step) {
            const row = y * nw * 4;
            for (let x = 0; x < nw; x += step) {
                const i = row + x * 4;
                const a = data[i + 3];
                if (a < 12) continue;
                const r = data[i];
                const g = data[i + 1];
                const b = data[i + 2];
                if (r >= threshold && g >= threshold && b >= threshold) continue; // near-white
                if (x < minX) minX = x;
                if (y < minY) minY = y;
                if (x > maxX) maxX = x;
                if (y > maxY) maxY = y;
            }
        }

        if (maxX < 0 || maxY < 0 || minX >= nw || minY >= nh) {
            // No ink found; keep original
            imgEl.dataset.baseW = String(nw);
            imgEl.dataset.baseH = String(nh);
            return;
        }

        minX = Math.max(0, minX - pad);
        minY = Math.max(0, minY - pad);
        maxX = Math.min(nw - 1, maxX + pad);
        maxY = Math.min(nh - 1, maxY + pad);

        const tw = Math.max(1, maxX - minX + 1);
        const th = Math.max(1, maxY - minY + 1);

        const c2 = document.createElement('canvas');
        c2.width = tw;
        c2.height = th;
        const ctx2 = c2.getContext('2d');
        if (!ctx2) return;
        ctx2.drawImage(c, minX, minY, tw, th, 0, 0, tw, th);

        // Replace image source with trimmed version. Also record base dims for zoom.
        imgEl.src = c2.toDataURL('image/png');
        imgEl.dataset.baseW = String(tw);
        imgEl.dataset.baseH = String(th);
    }

    async function _trimDetectionThumbDataUrl(dataUrl, opts) {
        const src = String(dataUrl || '').trim();
        if (!src.startsWith('data:image/')) return src;
        const pad = (opts && isFinite(opts.pad)) ? (opts.pad | 0) : 4;
        const threshold = (opts && isFinite(opts.threshold)) ? (opts.threshold | 0) : 248;
        const step = (opts && isFinite(opts.step)) ? Math.max(1, (opts.step | 0)) : 2;
        try {
            const img = new Image();
            img.src = src;
            const ok = await _ensureImageLoaded(img);
            if (!ok) return src;

            const nw = img.naturalWidth || 0;
            const nh = img.naturalHeight || 0;
            if (!nw || !nh) return src;

            _debugPdfSplitLog('[FamilyDetector][Trim:start]', {
                naturalWidth: nw,
                naturalHeight: nh,
                pad,
                threshold,
                step,
                srcLength: src.length
            });

            const c = document.createElement('canvas');
            c.width = nw;
            c.height = nh;
            const ctx = c.getContext('2d');
            if (!ctx) return src;
            ctx.drawImage(img, 0, 0);
            const id = ctx.getImageData(0, 0, nw, nh);
            const data = id.data;

            let minX = nw, minY = nh, maxX = -1, maxY = -1;
            for (let y = 0; y < nh; y += step) {
                const row = y * nw * 4;
                for (let x = 0; x < nw; x += step) {
                    const i = row + x * 4;
                    const a = data[i + 3];
                    if (a < 12) continue;
                    const r = data[i];
                    const g = data[i + 1];
                    const b = data[i + 2];
                    if (r >= threshold && g >= threshold && b >= threshold) continue;
                    if (x < minX) minX = x;
                    if (y < minY) minY = y;
                    if (x > maxX) maxX = x;
                    if (y > maxY) maxY = y;
                }
            }

            if (maxX < 0 || maxY < 0 || minX >= nw || minY >= nh) {
                _debugPdfSplitLog('[FamilyDetector][Trim:no-ink]', {
                    naturalWidth: nw,
                    naturalHeight: nh,
                    threshold,
                    step
                });
                return src;
            }

            const rawBounds = {
                minX,
                minY,
                maxX,
                maxY,
                width: Math.max(1, maxX - minX + 1),
                height: Math.max(1, maxY - minY + 1)
            };

            minX = Math.max(0, minX - pad);
            minY = Math.max(0, minY - pad);
            maxX = Math.min(nw - 1, maxX + pad);
            maxY = Math.min(nh - 1, maxY + pad);

            const tw = Math.max(1, maxX - minX + 1);
            const th = Math.max(1, maxY - minY + 1);
            const c2 = document.createElement('canvas');
            c2.width = tw;
            c2.height = th;
            const ctx2 = c2.getContext('2d');
            if (!ctx2) return src;
            ctx2.drawImage(c, minX, minY, tw, th, 0, 0, tw, th);
            _debugPdfSplitLog('[FamilyDetector][Trim:done]', {
                naturalWidth: nw,
                naturalHeight: nh,
                rawBounds,
                paddedBounds: { minX, minY, maxX, maxY, width: tw, height: th },
                trimmedRatioW: Number((tw / Math.max(1, nw)).toFixed(4)),
                trimmedRatioH: Number((th / Math.max(1, nh)).toFixed(4))
            });
            return c2.toDataURL('image/png');
        } catch {
            return src;
        }
    }

    const _detectionThumbInkCenterCache = new Map();

    async function _estimateDetectionThumbInkCenter(dataUrl, opts) {
        const src = String(dataUrl || '').trim();
        if (!src.startsWith('data:image/')) return null;

        const cacheKey = src;
        if (_detectionThumbInkCenterCache.has(cacheKey)) {
            _debugPdfSplitLog('[FamilyDetector][InkCenter:cache-hit]', _detectionThumbInkCenterCache.get(cacheKey));
            return _detectionThumbInkCenterCache.get(cacheKey);
        }

        const threshold = (opts && isFinite(opts.threshold)) ? (opts.threshold | 0) : 248;
        const step = (opts && isFinite(opts.step)) ? Math.max(1, (opts.step | 0)) : 2;

        try {
            const img = new Image();
            img.src = src;
            const ok = await _ensureImageLoaded(img);
            if (!ok) return null;

            const nw = img.naturalWidth || 0;
            const nh = img.naturalHeight || 0;
            if (!nw || !nh) return null;

            _debugPdfSplitLog('[FamilyDetector][InkCenter:start]', {
                naturalWidth: nw,
                naturalHeight: nh,
                threshold,
                step,
                srcLength: src.length
            });

            const c = document.createElement('canvas');
            c.width = nw;
            c.height = nh;
            const ctx = c.getContext('2d');
            if (!ctx) return null;
            ctx.drawImage(img, 0, 0);
            const id = ctx.getImageData(0, 0, nw, nh);
            const data = id.data;

            const gridW = Math.max(1, Math.ceil(nw / step));
            const gridH = Math.max(1, Math.ceil(nh / step));
            const mask = new Uint8Array(gridW * gridH);
            const sampleXByIdx = new Int16Array(gridW * gridH);
            const sampleYByIdx = new Int16Array(gridW * gridH);
            let minX = nw, minY = nh, maxX = -1, maxY = -1;
            let sumX = 0, sumY = 0, count = 0;

            for (let y = 0; y < nh; y += step) {
                const row = y * nw * 4;
                for (let x = 0; x < nw; x += step) {
                    const i = row + x * 4;
                    const a = data[i + 3];
                    if (a < 12) continue;
                    const r = data[i];
                    const g = data[i + 1];
                    const b = data[i + 2];
                    if (r >= threshold && g >= threshold && b >= threshold) continue;

                    if (x < minX) minX = x;
                    if (y < minY) minY = y;
                    if (x > maxX) maxX = x;
                    if (y > maxY) maxY = y;
                    sumX += x;
                    sumY += y;
                    count++;

                    const gx = Math.min(gridW - 1, Math.max(0, Math.floor(x / step)));
                    const gy = Math.min(gridH - 1, Math.max(0, Math.floor(y / step)));
                    const gi = gy * gridW + gx;
                    mask[gi] = 1;
                    sampleXByIdx[gi] = x;
                    sampleYByIdx[gi] = y;
                }
            }

            let result = null;
            let chosenComponentSummary = null;
            if (count > 0) {
                const visited = new Uint8Array(gridW * gridH);
                const queue = new Int32Array(gridW * gridH);
                const centerX = (nw - 1) / 2;
                const centerY = (nh - 1) / 2;
                const maxCenterDist = Math.max(1, Math.hypot(centerX, centerY));
                let bestComp = null;

                for (let gy = 0; gy < gridH; gy++) {
                    for (let gx = 0; gx < gridW; gx++) {
                        const startIdx = gy * gridW + gx;
                        if (!mask[startIdx] || visited[startIdx]) continue;

                        let qh = 0, qt = 0;
                        queue[qt++] = startIdx;
                        visited[startIdx] = 1;

                        let compCount = 0;
                        let compSumX = 0, compSumY = 0;
                        let compMinX = Infinity, compMinY = Infinity, compMaxX = -Infinity, compMaxY = -Infinity;
                        let minGX = Infinity, minGY = Infinity, maxGX = -Infinity, maxGY = -Infinity;

                        while (qh < qt) {
                            const cur = queue[qh++];
                            const cgx = cur % gridW;
                            const cgy = Math.floor(cur / gridW);
                            const px = sampleXByIdx[cur];
                            const py = sampleYByIdx[cur];

                            compCount++;
                            compSumX += px;
                            compSumY += py;
                            if (px < compMinX) compMinX = px;
                            if (py < compMinY) compMinY = py;
                            if (px > compMaxX) compMaxX = px;
                            if (py > compMaxY) compMaxY = py;
                            if (cgx < minGX) minGX = cgx;
                            if (cgy < minGY) minGY = cgy;
                            if (cgx > maxGX) maxGX = cgx;
                            if (cgy > maxGY) maxGY = cgy;

                            const neighbors = [
                                [cgx - 1, cgy],
                                [cgx + 1, cgy],
                                [cgx, cgy - 1],
                                [cgx, cgy + 1]
                            ];
                            for (const [ngx, ngy] of neighbors) {
                                if (ngx < 0 || ngy < 0 || ngx >= gridW || ngy >= gridH) continue;
                                const ni = ngy * gridW + ngx;
                                if (!mask[ni] || visited[ni]) continue;
                                visited[ni] = 1;
                                queue[qt++] = ni;
                            }
                        }

                        const spanX = Math.max(1, compMaxX - compMinX + 1);
                        const spanY = Math.max(1, compMaxY - compMinY + 1);
                        const compactness = Math.max(0.05, Math.min(spanX, spanY) / Math.max(spanX, spanY));
                        const gridArea = Math.max(1, (maxGX - minGX + 1) * (maxGY - minGY + 1));
                        const density = compCount / gridArea;
                        const compCx = compSumX / Math.max(1, compCount);
                        const compCy = compSumY / Math.max(1, compCount);
                        const centerDistFrac = Math.min(1, Math.hypot(compCx - centerX, compCy - centerY) / maxCenterDist);
                        const score = compCount * (0.35 + density) * (0.2 + compactness) * (1.35 - centerDistFrac);

                        const candidate = {
                            count: compCount,
                            sumX: compSumX,
                            sumY: compSumY,
                            minX: compMinX,
                            minY: compMinY,
                            maxX: compMaxX,
                            maxY: compMaxY,
                            compactness,
                            density,
                            centerDistFrac,
                            score
                        };

                        if (!bestComp || candidate.score > bestComp.score) {
                            bestComp = candidate;
                        }
                    }
                }

                const focus = bestComp || {
                    count,
                    sumX,
                    sumY,
                    minX,
                    minY,
                    maxX,
                    maxY
                };

                result = {
                    fracX: _clamp01((focus.sumX / Math.max(1, focus.count)) / Math.max(1, nw - 1)),
                    fracY: _clamp01((focus.sumY / Math.max(1, focus.count)) / Math.max(1, nh - 1)),
                    bboxFracX: _clamp01(((focus.minX + focus.maxX) / 2) / Math.max(1, nw - 1)),
                    bboxFracY: _clamp01(((focus.minY + focus.maxY) / 2) / Math.max(1, nh - 1))
                };

                if (bestComp) {
                    chosenComponentSummary = {
                        count: bestComp.count,
                        bounds: {
                            minX: bestComp.minX,
                            minY: bestComp.minY,
                            maxX: bestComp.maxX,
                            maxY: bestComp.maxY
                        },
                        compactness: Number(bestComp.compactness.toFixed(4)),
                        density: Number(bestComp.density.toFixed(4)),
                        centerDistFrac: Number(bestComp.centerDistFrac.toFixed(4)),
                        score: Number(bestComp.score.toFixed(4))
                    };
                }
            }

            _debugPdfSplitLog('[FamilyDetector][InkCenter:done]', {
                naturalWidth: nw,
                naturalHeight: nh,
                sampleCount: count,
                inkBounds: count > 0 ? { minX, minY, maxX, maxY } : null,
                chosenComponent: chosenComponentSummary,
                result
            });

            _detectionThumbInkCenterCache.set(cacheKey, result);
            return result;
        } catch {
            _detectionThumbInkCenterCache.set(cacheKey, null);
            return null;
        }
    }

    function _centerSvgPreviewScroll() {
        const body = document.getElementById('svgPreviewBody');
        if (!body) return;
        const dx = Math.max(0, body.scrollWidth - body.clientWidth);
        const dy = Math.max(0, body.scrollHeight - body.clientHeight);
        body.scrollLeft = Math.floor(dx / 2);
        body.scrollTop = Math.floor(dy / 2);
    }

    async function generateEditableSvgForSample(sampleId) {
        // Optional UI integration: keep all progress inside the modal.
        const opts = (arguments && arguments.length > 1) ? arguments[1] : null;
        const statusEl = (opts && opts.showInlineStatus) ? document.getElementById('familyEditStatus') : null;
        const sid = parseInt(String(sampleId || ''), 10);
        if (!Number.isFinite(sid) || sid <= 0) return;
        const famId = _getSelectedFamilyId();
        if (!famId) { cgAlert('Pick a family first.'); return; }
        const file = (pdfFileInput && pdfFileInput.files) ? pdfFileInput.files[0] : null;
        if (!file) {
            if (statusEl) statusEl.textContent = 'State: cannot edit — no PDF selected at the top.';
            cgAlert('Select a PDF file first (same PDF).');
            return;
        }

        const s = _familyViewSamplesById && _familyViewSamplesById.get ? _familyViewSamplesById.get(sid) : null;
        if (!s) {
            if (statusEl) statusEl.textContent = 'State: sample not found (click VIEW again).';
            cgAlert('Sample not found in view. Click View again.');
            return;
        }

        let frac = null;
        try {
            const cf = (s && s.cropFracJson != null) ? String(s.cropFracJson) : '';
            frac = cf ? JSON.parse(cf) : null;
        } catch { /* ignore */ }
        if (!frac) {
            if (statusEl) statusEl.textContent = 'State: cannot edit — no crop region saved for this sample.';
            cgAlert('This sample has no crop region saved.');
            return;
        }

        try {
            if (statusEl) statusEl.textContent = 'State: converting PDF to SVG…';
            const fd = new FormData();
            fd.append('pdf', file, file.name);
            const resp = await fetch(VECTOR_PDF_SVG_ENDPOINT, {
                method: 'POST',
                body: fd,
                headers: { 'X-Client-Id': 'admin' }
            });
            if (!resp.ok) {
                const t = await resp.text();
                if (statusEl) statusEl.textContent = 'State: convert-to-SVG failed.';
                cgAlert(`Vector SVG failed: HTTP ${resp.status}: ${t.substring(0, 600)}`);
                return;
            }
            let svgText = await resp.text();
            try { svgText = cropSvgByFraction(svgText, frac); } catch { /* ignore */ }

            const symbolHref = (s && s.symbolHref != null) ? String(s.symbolHref) : '';
            const compact = _makeCompactSampleSvg(svgText, symbolHref);
            const toSaveRaw = compact || ((svgText && svgText.length <= 250_000) ? svgText : '');
            const toSave = _normalizeMapIconSampleSvg(toSaveRaw) || toSaveRaw;
            if (!toSave) {
                if (statusEl) statusEl.textContent = 'State: could not generate an editable SVG for this sample.';
                cgAlert('Could not generate a compact editable SVG for this sample. Try LEARN again on a tighter region.');
                return;
            }

            if (statusEl) statusEl.textContent = 'State: saving editable SVG…';
            const put = await fetch(`${OBJECT_FAMILIES_ENDPOINT}/${famId}/samples/${sid}`, {
                method: 'PUT',
                headers: { 'Content-Type': 'application/json', 'X-Client-Id': 'admin' },
                body: JSON.stringify({ sampleSvg: toSave })
            });
            if (!put.ok) {
                const t2 = await put.text();
                if (statusEl) statusEl.textContent = 'State: save failed.';
                cgAlert(`Save failed: HTTP ${put.status}: ${t2.substring(0, 600)}`);
                return;
            }

            if (statusEl) statusEl.textContent = 'State: opening editor…';
            await viewSelectedFamily();
            openFamilySampleEditor(sid);
        } catch (e) {
            if (statusEl) statusEl.textContent = 'State: error.';
            cgAlert(`Generate failed: ${String(e)}`);
        }
    }

    function openFamilySampleEditor(sampleId) {
        const sid = parseInt(String(sampleId || ''), 10);
        if (!Number.isFinite(sid) || sid <= 0) return;
        const famId = _getSelectedFamilyId();
        if (!famId) { cgAlert('Pick a family first.'); return; }

        const s = _familyViewSamplesById && _familyViewSamplesById.get ? _familyViewSamplesById.get(sid) : null;
        let svgText = (s && s.sampleSvg != null) ? String(s.sampleSvg) : '';
        try { svgText = _normalizeMapIconSampleSvg(svgText) || svgText; } catch { /* ignore */ }
        console.log('[EDITOR-DBG] openFamilySampleEditor sampleId=', sid, 'svgText length=', svgText.length, 'first 500 chars=', svgText.substring(0, 500));

        // For editing, always prefer the full tile-based SVG from the page crop
        // so individual tiles are selectable. The stored raster compact SVG is just for thumbnails.
        let usedPageCrop = false;
        try {
            const cropJson = (s && s.cropFracJson) ? s.cropFracJson : '';
            const pageIdx = (s && isFinite(s.pageIndex)) ? s.pageIndex : 0;
            console.log('[EDITOR-DBG] page crop regen: cropJson length=', cropJson.length,
                'pageIdx=', pageIdx,
                'pageResults=', pageResults ? pageResults.length : 'null/undefined');
            if (cropJson && pageResults && pageResults.length > 0) {
                const frac = JSON.parse(cropJson);
                console.log('[EDITOR-DBG] page crop regen: frac=', JSON.stringify(frac));
                const pr = pageResults.find(r => r && r.svgContent && ((r.pageNumber || 1) - 1) === pageIdx);
                console.log('[EDITOR-DBG] page crop regen: found pageResult=', !!pr,
                    pr ? ('svgContent length=' + pr.svgContent.length) : '');
                if (pr && pr.svgContent) {
                    const regen = cropSvgByFraction(pr.svgContent, frac);
                    console.log('[EDITOR-DBG] page crop regen: regen length=', regen ? regen.length : 'null');
                    if (regen && regen.length > 100) {
                        svgText = regen;
                        usedPageCrop = true;
                        console.log('[EDITOR-DBG] using page crop SVG for editing, length=', svgText.length);
                    }
                }
            } else {
                console.log('[EDITOR-DBG] page crop regen SKIPPED: cropJson=', !!cropJson, 'pageResults=', !!pageResults, 'length=', pageResults ? pageResults.length : 0);
            }
        } catch (e) { console.warn('[EDITOR-DBG] page crop regen failed:', e); }

        // Fallback: if no page crop available, use stored SVG as-is
        if (!svgText) {
            console.warn('[EDITOR-DBG] No SVG available for sample', sid);
            return;
        }

        // Expand <use>+<symbol> pairs into direct elements so each tile is individually selectable
        if (usedPageCrop) {
