    function _loadFamilyYoloDetectSettings() {
        try {
            const raw = localStorage.getItem(_familyYoloDetectSettingsStorageKey);
            if (!raw) return { preset: 'balanced', ..._familyYoloDetectPresets.balanced };
            return _normalizeFamilyYoloDetectSettings(JSON.parse(raw));
        } catch {
            return { preset: 'balanced', ..._familyYoloDetectPresets.balanced };
        }
    }

    function _normalizeFamilyYoloDetectSettings(input) {
        const src = (input && typeof input === 'object') ? input : {};
        const presetRaw = (src.preset == null) ? 'balanced' : String(src.preset).trim().toLowerCase();
        const preset = Object.prototype.hasOwnProperty.call(_familyYoloDetectPresets, presetRaw) ? presetRaw : 'custom';
        const base = preset !== 'custom' ? _familyYoloDetectPresets[preset] : _familyYoloDetectPresets.balanced;
        const conf = Number(src.conf);
        const iou = Number(src.iou);
        const imgsz = Number(src.imgsz);
        const normalized = {
            preset,
            conf: Number.isFinite(conf) ? Math.max(0.01, Math.min(0.95, conf)) : base.conf,
            iou: Number.isFinite(iou) ? Math.max(0.05, Math.min(0.95, iou)) : base.iou,
            imgsz: Number.isFinite(imgsz) ? Math.max(640, Math.min(3072, Math.round(imgsz))) : base.imgsz
        };
        const matchingPreset = Object.entries(_familyYoloDetectPresets).find(([_, value]) =>
            Math.abs(normalized.conf - value.conf) < 0.0001
            && Math.abs(normalized.iou - value.iou) < 0.0001
            && normalized.imgsz === value.imgsz);
        if (matchingPreset) normalized.preset = matchingPreset[0];
        return normalized;
    }

