            { label: 'First page (pt)', value: (ptW != null && ptH != null) ? `${fmtNum(ptW)} × ${fmtNum(ptH)}` : '—', sub: 'PDF points' },
            { label: 'First page (mm)', value: (mmW != null && mmH != null) ? `${fmtNum(mmW)} × ${fmtNum(mmH)}` : '—', sub: 'millimeters' },
            { label: 'Preview render', value: (pxW != null && pxH != null) ? `${fmtNum(pxW)} × ${fmtNum(pxH)} px` : '—', sub: capped && maxDimUsed ? `capped at ${fmtNum(maxDimUsed)} px` : ((dpi && isFinite(dpi)) ? `${fmtNum(dpi)} DPI` : 'render size') },
            { label: 'First page (inch)', value: (inW != null && inH != null) ? `${fmtNum(inW)} × ${fmtNum(inH)}` : '—', sub: 'inches' }
        ];

        pdfSizeInfoBody.innerHTML = cards.map(c => `
            <div class="min-w-[220px] flex-1 rounded-lg border border-slate-700/50 bg-slate-950/30 p-3">
                <div class="text-[11px] uppercase tracking-wider text-slate-400">${escapeHtml(c.label)}</div>
                <div class="mt-1 text-lg font-bold text-slate-100">${escapeHtml(c.value)}</div>
