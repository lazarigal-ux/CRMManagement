                                if (pdfExtractWords && Array.isArray(pdfExtractWords) && pdfExtractWords.length > 0) {
                                    const baseVb = (_vectorBaseSvgMetrics && _vectorBaseSvgMetrics.vb) ? _vectorBaseSvgMetrics.vb : '';
                                    const baseW  = (_vectorBaseSvgMetrics && _vectorBaseSvgMetrics.w) ? _vectorBaseSvgMetrics.w : '';
                                    const baseH  = (_vectorBaseSvgMetrics && _vectorBaseSvgMetrics.h) ? _vectorBaseSvgMetrics.h : '';
                                    // When merge-before-split is enabled, skip the HIDE EXACT LABELS / LANGUAGES filter — keep all text
                                    const _skipTF = !!_pdfPreSplitMergeEnabled;
                                    const visiblePdfWords = _skipTF ? [...pdfExtractWords] : _getVisiblePdfExtractWords(pdfExtractWords);
                                    const ignoredPdfWords = _skipTF ? [] : _getIgnoredPdfExtractWords(pdfExtractWords);
                                    const visibleWordGroups = _groupPdfTextItemsByLanguage(visiblePdfWords, word => word && word.text != null ? String(word.text) : '');
                                    let addedPdfTextLayerCount = 0;
                                    for (const group of visibleWordGroups) {
                                        let textSvg = await buildPdfBboxTextLayerSvg(group.items, pdfExtractWordsMeta || {}, baseVb, baseW, baseH, { useProvidedWords: true });
                                        if (hasOutputCrop && outputCropFrac && textSvg) textSvg = cropSvgByFraction(textSvg, outputCropFrac);
                                        if (!textSvg) continue;
                                        const shown = Math.min(20000, group.items.length);
                                        const textLayer = {
                                            layerName: `🔤 ${group.label} (PDF bbox) (${shown})`,
                                            color: '#4A5568',
                                            svgContent: textSvg,
                                            icon: 'fa-font',
                                            objectCount: shown
                                        };
                                        const otherIdx = layers.findIndex(l => (l && l.layerName && String(l.layerName).toLowerCase().includes('other elements')));
                                        if (otherIdx >= 0) layers.splice(otherIdx, 0, textLayer);
                                        else layers.push(textLayer);
                                        addedPdfTextLayerCount++;
                                    }

                                    if (addedPdfTextLayerCount > 0) {
                                        reportStep('Add text layer (PDF bbox)', {
                                            words: pdfExtractWords.length,
                                            groups: addedPdfTextLayerCount,
                                            shown: visiblePdfWords.length,
                                            hidden: Math.max(0, pdfExtractWords.length - visiblePdfWords.length)
                                        });
                                    }

                                    if (ignoredPdfWords.length > 0) {
                                        let ignoredTextSvg = await buildPdfBboxTextLayerSvg(ignoredPdfWords, pdfExtractWordsMeta || {}, baseVb, baseW, baseH, { useProvidedWords: true });
                                        if (hasOutputCrop && outputCropFrac && ignoredTextSvg) ignoredTextSvg = cropSvgByFraction(ignoredTextSvg, outputCropFrac);
                                        if (ignoredTextSvg) {
                                            _appendElementsToOtherLayer(
                                                layers,
                                                _extractSvgLayerBodyElements(ignoredTextSvg),
                                                baseVb,
                                                baseW,
                                                baseH,
                                                ''
                                            );
                                        }
                                    }
                                }
                            } catch {
                                // ignore
                            }
                        }

                        // Ensure Full SVG count matches the sum of the other layer cards
                        recomputeFullLayerFromSum(layers);

                        if (!layers || layers.length === 0) {
                            showError('Vector conversion succeeded but produced no layers.');
                            return;
                        }

                        reportStep('Build result cards', { layers: layers.length, mode: 'vector' });
                        for (let li = 0; li < layers.length; li++) {
                            const layer = layers[li];
                            const layerSvgSize = new Blob([layer.svgContent]).size;
                            pageResults.push({
                                pageNumber: 1,
                                isLayer: true,
                                layerName: layer.layerName,
                                layerColor: layer.color,
                                layerIcon: layer.icon,
                                svgContent: layer.svgContent,
                                sourceSvgMetrics: _vectorBaseSvgMetrics && (_vectorBaseSvgMetrics.vb || _vectorBaseSvgMetrics.w || _vectorBaseSvgMetrics.h)
                                    ? { ..._vectorBaseSvgMetrics }
                                    : null,
                                svgSizeBytes: layerSvgSize,
                                objectCount: (typeof layer.objectCount === 'number') ? layer.objectCount : countSvgObjects(layer.svgContent)
                            });
                            addResultCard(pageResults.length - 1);
                        }

                        resultsSummary.textContent = `${layers.length} layer(s) produced (vector)`;
                        reportStep('Done', { mode: 'vector', layers: layers.length });
                        return;
                    }
                } catch (e) {
                    reportStep('[PIPE] FALLBACK raster', { reason: 'vector exception', detail: String(e) });
                    if (_processReport && _processReport.ctx) {
                        _processReport.ctx.vectorAttemptFailed = true;
                    }
                }
            }

            // Pure VECTOR PDF → SVG (no raster preview / no crop)
            if (hasCrop) {
                // If crop regions are selected, we need the preview-based region pipeline.
                // (If vector-first succeeded, we'd have returned already above.)
                reportStep('[PIPE] VECTOR PDF engine skipped', { reason: 'crop regions selected' });
            } else {

                    reportStep('[PIPE] Using VECTOR pipeline', { mode: 'pdf->svg', tools: 'mutool -> pdf2svg (fallback)' });
                    resultsSection.classList.remove('hidden');
                    resultsSummary.textContent = 'Converting PDF → SVG layers (vector)...';

                async function fetchLayer(layerKey) {
                    const fd = new FormData();
                    fd.append('pdf', file, file.name);
                    const qs = new URLSearchParams({ layer: layerKey });
                    const t0 = performance.now();
                    const resp = await fetch(`${VECTOR_PDF_LAYER_ENDPOINT}?${qs}`, {
                        method: 'POST',
                        body: fd,
                        headers: { 'X-Client-Id': 'admin' }
                    });

                    const vecCallBase = {
                        label: `Layer ${layerKey}`,
                        status: resp.status,
                        ms: Math.round(performance.now() - t0),
                        engineMode: 'vectorpdf',
                        requestedProvider: providerSelect.value,
                        meta: null,
                        pipe: resp.headers.get('x-pipe') || resp.headers.get('X-Pipe') || '',
                        pipeCmd: resp.headers.get('x-pipe-cmd') || resp.headers.get('X-Pipe-Cmd') || '',
                        cacheHit: resp.headers.get('x-cache-hit') || resp.headers.get('X-Cache-Hit') || '',
                        svgBytesHeader: resp.headers.get('x-svg-bytes') || resp.headers.get('X-Svg-Bytes') || '',
                        baseSvgBytesHeader: resp.headers.get('x-base-svg-bytes') || resp.headers.get('X-Base-Svg-Bytes') || ''
                    };

                    const text = await resp.text();
                    if (!resp.ok) {
                        reportVectorizeCall({
                            ...vecCallBase,
                            error: `HTTP ${resp.status}: ${text.substring(0, 500)}`
                        });
                        throw new Error(`Layer ${layerKey}: HTTP ${resp.status} — ${text.substring(0, 800)}`);
                    }

                    const svgInfo = analyzeSvg(text);
                    reportVectorizeCall({
                        ...vecCallBase,
                        svgBytes: new Blob([text]).size,
                        svgInfo
                    });
                    return text;
                }

                    const layers = [
                        { key: 'walls', name: '🧱 Walls', icon: 'fa-building' },
                        { key: 'routes', name: '🧭 Routes', icon: 'fa-route' },
                        { key: 'other', name: '⬜ Other', icon: 'fa-layer-group' }
                    ];

                pageResults = [];
                resultsGrid.innerHTML = '';
                revokeThumbObjectUrls();

                    for (const l of layers) {
                        btnSplitConvert.querySelector('span').textContent = `Vector ${l.key}...`;
                        const svgContent = await fetchLayer(l.key);
                        const svgSize = new Blob([svgContent]).size;
                        pageResults.push({
                            pageNumber: 1,
                            isLayer: true,
                            layerName: l.name,
                            layerIcon: l.icon,
                            svgContent,
                            svgSizeBytes: svgSize,
                            objectCount: countSvgObjects(svgContent)
                        });
                        addResultCard(pageResults.length - 1);
                    }

                resultsSummary.textContent = `${layers.length} layer(s) produced (vector PDF)`;
                reportStep('Done', { mode: 'vectorpdf', layers: layers.length });
                return;
            }

            // Optional: verify the selected file size from actual bytes read.
            // This helps explain cases where OS/UI shows a different size (e.g. size-on-disk).
            try {
                const maxVerifyBytes = 80 * 1024 * 1024; // 80 MiB safety guard
                if (typeof file.size === 'number' && file.size > maxVerifyBytes) {
                    reportStep('File size verification (File.arrayBuffer)', { skipped: true, reason: `file too large (> ${formatBytes(maxVerifyBytes)})`, fileSizeBytes: file.size });
                } else {
                    const t0 = performance.now();
                    const ab = await file.arrayBuffer();
                    const bytes = ab ? ab.byteLength : 0;
                    const match = (typeof file.size === 'number') ? (bytes === file.size) : null;
                    if (_processReport && _processReport.ctx) {
                        _processReport.ctx.fileArrayBufferBytes = bytes;
                        _processReport.ctx.fileBytesMatch = match;
                    }
                    reportStep('File size verification (File.arrayBuffer)', { bytes, match, ms: Math.round(performance.now() - t0) });
                }
            } catch (e) {
                reportStep('File size verification (File.arrayBuffer)', { error: String(e) });
            }

            // Step 1: render PDF to page images via the preview endpoint to count pages
            const previewFd = new FormData();
            previewFd.append('pdf', file, file.name);
            // For region mode, use higher DPI for better quality
            const previewDpi = hasCrop
                ? Math.max(getSelectedPdfPreviewDpi(), 600)
                : getSelectedPdfPreviewDpi();
            reportStep('Render preview (PDF → images)', { previewDpi });
            const tPreview0 = performance.now();
            const previewResp = await fetch(`${PREVIEW_ENDPOINT}?dpi=${previewDpi}`, {
                method: 'POST', body: previewFd,
                headers: { 'X-Client-Id': 'admin' }
            });
            if (!previewResp.ok) throw new Error('Failed to render PDF preview: ' + previewResp.statusText);
            const previewPayload = await previewResp.json();
            const pageCount = previewPayload.pageCount || 0;
            const pageThumbs = previewPayload.pages || [];
            reportStep('Preview ready', { pageCount, ms: Math.round(performance.now() - tPreview0) });
            if (_processReport && _processReport.ctx) {
                _processReport.ctx.pageCount = pageCount;
                _processReport.ctx.previewDpi = previewDpi;
                _processReport.ctx.previewThumbCount = Array.isArray(pageThumbs) ? pageThumbs.length : 0;
                if (Array.isArray(pageThumbs) && pageThumbs[0]) {
                    const sz = await getImageSize(pageThumbs[0]);
                    if (sz) _processReport.ctx.previewRasterFirstPage = `${sz.w}x${sz.h}`;
                }
            }

            if (pageCount === 0) { showError('PDF has no pages.'); return; }

            // ═══════ REGION MODE: vectorize cropped area → decompose into layers ═══════
            // NOTE: If a GLOBAL Output CROP is set, we treat it as normal page-mode (single crop for all pages)
            // to avoid producing multiple results per page.
            if (hasCrop && !hasOutputCrop) {
                btnSplitConvert.querySelector('span').textContent = 'Vectorizing region...';
                resultsSummary.textContent = 'Vectorizing selected region...';
                resultsSection.classList.remove('hidden');

                const errors = [];
                let allLayers = [];

                for (let i = 0; i < pageCount; i++) {
                    const regions = cropSelections[i];
                    if (!regions || regions.length === 0) continue;
                    const pageDataUrl = pageThumbs[i];
                    if (!pageDataUrl) continue;

                    for (let ri = 0; ri < regions.length; ri++) {
                        const sel = regions[ri];
                        const regionLabel = regions.length > 1 ? `P${i+1} R${ri+1}` : `Page ${i+1}`;
                        try {
                            btnSplitConvert.querySelector('span').textContent = `Cropping ${regionLabel}...`;
                            const tCrop0 = performance.now();
                            const crop = await cropDataUrl(pageDataUrl, sel);
                            let dataUrl = crop.dataUrl;
                            // Avoid aggressive downscale; keep more detail for thin lines.
                            const maxPx = Math.min(12000, Math.max(4000, Math.round(previewDpi * 20)));
                            const down = await scaleDownDataUrl(dataUrl, maxPx);
                            dataUrl = down.dataUrl;
                            reportStep('Crop region', { region: regionLabel, ms: Math.round(performance.now() - tCrop0), src: `${crop.imgW}x${crop.imgH}`, crop: `${crop.cropW}x${crop.cropH}`, scaled: `${down.scaledW}x${down.scaledH}`, maxPx });
                            if (_processReport && _processReport.ctx && Array.isArray(_processReport.ctx.regions)) {
                                _processReport.ctx.regions.push({
                                    label: regionLabel,
                                    pageNumber: i + 1,
                                    regionIndex: ri + 1,
                                    frac: { x: sel.x, y: sel.y, w: sel.w, h: sel.h },
                                    srcW: crop.imgW,
                                    srcH: crop.imgH,
                                    sx: crop.sx,
                                    sy: crop.sy,
                                    cropW: crop.cropW,
                                    cropH: crop.cropH,
                                    scaledW: down.scaledW,
                                    scaledH: down.scaledH,
                                    maxPx
                                });
                            }

                            btnSplitConvert.querySelector('span').textContent = `Vectorizing ${regionLabel}...`;
                            const blob = await dataUrlToBlob(dataUrl);
                            const fd = new FormData();
                            fd.append('file', blob, `region_p${i+1}_r${ri+1}.png`);

                            const qs = new URLSearchParams({ provider: providerSelect.value, upscale: '1' });
                            const tVec0 = performance.now();
                            const resp = await fetch(`${VECTORIZE_ENDPOINT}?${qs}`, {
                                method: 'POST', body: fd,
                                headers: { 'X-Client-Id': 'admin' }
                            });

                            const vecCallBase = {
                                label: regionLabel,
                                status: resp.status,
                                ms: Math.round(performance.now() - tVec0),
                                engineMode: resp.headers.get('x-engine-mode') || resp.headers.get('X-Engine-Mode'),
                                requestedProvider: resp.headers.get('x-requested-provider') || resp.headers.get('X-Requested-Provider'),
                                meta: resp.headers.get('x-meta') || resp.headers.get('X-Meta')
                            };

                            if (!resp.ok) {
                                const errText = await resp.text();
                                reportVectorizeCall({
                                    ...vecCallBase,
                                    error: `HTTP ${resp.status}: ${errText.substring(0, 500)}`
                                });
                                errors.push(`${regionLabel}: HTTP ${resp.status} — ${errText.substring(0, 2000)}`);
                                continue;
                            }

                            const svgContent = await resp.text();
                            if (!svgContent || svgContent.length < 20) {
                                reportVectorizeCall({
                                    ...vecCallBase,
                                    error: 'Empty SVG response'
                                });
                                errors.push(`${regionLabel}: Empty SVG response`);
                                continue;
                            }

                            let mergedRegionSvg = await _mergeSvgBeforeSplit(svgContent, `${regionLabel} (raster region)`);
                            const svgInfo = analyzeSvg(mergedRegionSvg);
                            reportVectorizeCall({
                                ...vecCallBase,
                                svgBytes: new Blob([mergedRegionSvg]).size,
                                svgInfo
                            });

                            btnSplitConvert.querySelector('span').textContent = `Decomposing ${regionLabel}...`;
                            const tDec0 = performance.now();
                            let layers = decomposeSvgIntoLayers(mergedRegionSvg);
                            reportStep('Decompose SVG → layers', { region: regionLabel, layers: layers.length, ms: Math.round(performance.now() - tDec0) });

                            const tFam0 = performance.now();
                            layers = await injectFamilyLayers(mergedRegionSvg, layers);
                            const famCount = (layers || []).filter(l => l && l.isFamilyLayer).length;
                            if (famCount > 0) reportStep('Inject family layers', { region: regionLabel, families: famCount, ms: Math.round(performance.now() - tFam0) });

                            allLayers.push(...layers.map(l => ({ ...l, pageNumber: i + 1, regionIndex: ri + 1, thumbnailDataUrl: dataUrl })));

                        } catch (ex) {
                            errors.push(`${regionLabel}: ${ex.message}`);
                        }
                    }
                }

                if (allLayers.length === 0) {
                    const detail = errors.length > 0 ? '\n\n' + errors.join('\n') : '';
                    showError('No layers produced.' + detail);
                    return;
                }

                if (errors.length > 0) {
                    showError('Some pages had errors:\n' + errors.join('\n'));
                }

                resultsSummary.textContent = `${allLayers.length} layer(s) from ${totalRegions} region(s)`;
                reportStep('Build result cards', { layers: allLayers.length, totalRegions });
                for (let li = 0; li < allLayers.length; li++) {
                    const layer = allLayers[li];
                    const svgSize = new Blob([layer.svgContent]).size;
                    pageResults.push({
                        pageNumber: layer.pageNumber,
                        regionIndex: layer.regionIndex,
                        layerName: layer.layerName,
                        layerColor: layer.color,
                        layerIcon: layer.icon,
                        svgContent: layer.svgContent,
                        thumbnailDataUrl: layer.thumbnailDataUrl,
                        svgSizeBytes: svgSize,
                        isLayer: true
                    });
                    addResultCard(pageResults.length - 1);
                }

                reportStep('Done', { mode: 'region', layers: allLayers.length });

            } else {
                // ═══════ NORMAL MODE: page-by-page vectorize ═══════
                resultsSummary.textContent = `0 of ${pageCount} page(s) converted...`;
                resultsSection.classList.remove('hidden');
                if (movedOtherElementsGrid) movedOtherElementsGrid.innerHTML = '';
                if (movedOtherElementsSection) movedOtherElementsSection.classList.add('hidden');

                let successCount = 0;
                for (let i = 0; i < pageCount; i++) {
                    btnSplitConvert.querySelector('span').textContent = `Page ${i + 1} / ${pageCount}...`;

                    let dataUrl = pageThumbs[i];
                    let outputCropPixels = null;
                    if (!dataUrl) {
                        pageResults.push({ pageNumber: i + 1, error: 'No image for this page' });
                        addResultCard(pageResults.length - 1);
                        continue;
                    }

                    // Apply GLOBAL Output CROP to each page thumbnail BEFORE vectorization
                    if (hasOutputCrop && outputCropFrac) {
                        try {
                            const tOC0 = performance.now();
                            const crop = await cropDataUrl(dataUrl, outputCropFrac);
                            dataUrl = crop.dataUrl;
                            outputCropPixels = {
                                pageW: crop.imgW,
                                pageH: crop.imgH,
                                cropW: crop.cropW,
                                cropH: crop.cropH,
                                offsetX: crop.sx,
                                offsetY: crop.sy
                            };
                            reportCropDiagnostic('Raster crop applied', {
                                pipeline: 'raster-vectorize',
                                page: i + 1,
                                cropFraction: outputCropFrac,
                                sourceRaster: { w: crop.imgW, h: crop.imgH },
                                cropRaster: { w: crop.cropW, h: crop.cropH },
                                cropOffsetPx: { x: crop.sx, y: crop.sy }
                            });
                            reportStep('Output crop (preview image)', { page: i + 1, ms: Math.round(performance.now() - tOC0), crop: `${crop.cropW}x${crop.cropH}` });
                        } catch {
                            outputCropPixels = null;
                            // If crop fails, keep original page image
                        }
                    } else {
                        reportCropDiagnostic('Raster no crop', {
                            pipeline: 'raster-vectorize',
                            page: i + 1,
                            cropFraction: null,
                            input: 'full preview page'
                        });
                    }

                    try {
                        const blob = await dataUrlToBlob(dataUrl);
                        const fd = new FormData();
                        fd.append('file', blob, `page_${i + 1}.png`);

                        const qs = new URLSearchParams({ provider: providerSelect.value, upscale: '1' });
                        const tVec0 = performance.now();
                        const resp = await fetch(`${VECTORIZE_ENDPOINT}?${qs}`, {
                            method: 'POST', body: fd,
                            headers: { 'X-Client-Id': 'admin' }
                        });

                        const vecCallBase = {
                            label: `Page ${i + 1}`,
                            status: resp.status,
                            ms: Math.round(performance.now() - tVec0),
                            engineMode: resp.headers.get('x-engine-mode') || resp.headers.get('X-Engine-Mode'),
                            requestedProvider: resp.headers.get('x-requested-provider') || resp.headers.get('X-Requested-Provider'),
                            meta: resp.headers.get('x-meta') || resp.headers.get('X-Meta')
                        };

                        if (!resp.ok) {
                            const errText = await resp.text();
                            reportVectorizeCall({
                                ...vecCallBase,
                                error: `HTTP ${resp.status}: ${errText.substring(0, 200)}`
                            });
                            pageResults.push({ pageNumber: i + 1, error: `HTTP ${resp.status}: ${errText.substring(0, 200)}` });
                        } else {
                            let svgContent = await resp.text();
                            const vectorizedSvgInfo = _summarizeSvgInfoForReport(analyzeSvg(svgContent));
                            if (hasOutputCrop && outputCropPixels) {
                                reportCropDiagnostic('Raster vectorize raw SVG', {
                                    pipeline: 'raster-vectorize',
                                    page: i + 1,
                                    cropFraction: outputCropFrac,
                                    cropPixels: outputCropPixels,
                                    svg: vectorizedSvgInfo
                                });
                                svgContent = restoreCroppedSvgToPageSpace(svgContent, outputCropPixels);
                                reportCropDiagnostic('Raster vectorize restored SVG', {
                                    pipeline: 'raster-vectorize',
                                    page: i + 1,
                                    cropFraction: outputCropFrac,
                                    cropPixels: outputCropPixels,
                                    svg: _summarizeSvgInfoForReport(analyzeSvg(svgContent))
                                });
                            } else {
                                reportCropDiagnostic('Raster vectorize full-page SVG', {
                                    pipeline: 'raster-vectorize',
                                    page: i + 1,
                                    cropFraction: null,
                                    svg: vectorizedSvgInfo
                                });
                            }
                            reportVectorizeCall({
                                ...vecCallBase,
                                svgBytes: new Blob([svgContent]).size,
                                svgInfo: analyzeSvg(svgContent)
                            });
                            const svgSize = new Blob([svgContent]).size;
                            pageResults.push({
                                pageNumber: i + 1,
                                svgContent,
                                thumbnailDataUrl: dataUrl,
                                svgSizeBytes: svgSize
                            });
                            successCount++;
                        }
                    } catch (ex) {
                        pageResults.push({ pageNumber: i + 1, error: ex.message });
                    }

                    addResultCard(pageResults.length - 1);
                    resultsSummary.textContent = `${successCount} of ${pageCount} page(s) converted`;
                }

                resultsSummary.textContent = `${successCount} of ${pageCount} page(s) converted`;
                reportStep('Done', { mode: 'pages', pageCount, successCount });
            }
        } catch (ex) {
            showError(ex.message);
        } finally {
            reportRenderFinal();
            try {
                if (_processReport || pageResults.length > 0) setSplitMainTab('svgSplit');
            } catch { /* ignore */ }
            btnSplitConvert.disabled = false;
            btnSplitConvert.innerHTML = origHtml;
        }
    });

    // ── Global per-layer SVG Undo / Redo system ──
    const _svgUndoStacks = {};  // idx => [svgContent, ...]
    const _svgRedoStacks = {};  // idx => [svgContent, ...]
    const _SVG_UNDO_MAX = 10;

    function _pushSvgUndo(idx) {
        const r = (idx >= 0 && pageResults[idx]) ? pageResults[idx] : null;
        if (!r || !r.svgContent) return;
        if (!_svgUndoStacks[idx]) _svgUndoStacks[idx] = [];
        _svgUndoStacks[idx].push(String(r.svgContent));
        if (_svgUndoStacks[idx].length > _SVG_UNDO_MAX) _svgUndoStacks[idx].shift();
        _svgRedoStacks[idx] = [];  // new action clears redo
        _updateCardUndoRedoButtons(idx);
    }

    async function _doSvgUndo(idx) {
        if (!_svgUndoStacks[idx] || _svgUndoStacks[idx].length === 0) return false;
        const r = (idx >= 0 && pageResults[idx]) ? pageResults[idx] : null;
        if (!r) return false;
        // Save current to redo
        if (!_svgRedoStacks[idx]) _svgRedoStacks[idx] = [];
        _svgRedoStacks[idx].push(String(r.svgContent || ''));
        // Restore previous
        r.svgContent = _svgUndoStacks[idx].pop();
        _syncResultMetadataAfterSvgChange(idx);
        // Refresh preview if this layer is currently open
        if (Number(_svgPreviewActiveResultIdx) === idx) {
            try { await _openSvgPreviewForResult(idx, { preserveView: true }); } catch { }
        }
        _updateCardUndoRedoButtons(idx);
        return true;
    }

    async function _doSvgRedo(idx) {
        if (!_svgRedoStacks[idx] || _svgRedoStacks[idx].length === 0) return false;
        const r = (idx >= 0 && pageResults[idx]) ? pageResults[idx] : null;
        if (!r) return false;
        // Save current to undo
        if (!_svgUndoStacks[idx]) _svgUndoStacks[idx] = [];
        _svgUndoStacks[idx].push(String(r.svgContent || ''));
        // Restore next
        r.svgContent = _svgRedoStacks[idx].pop();
        _syncResultMetadataAfterSvgChange(idx);
        if (Number(_svgPreviewActiveResultIdx) === idx) {
            try { await _openSvgPreviewForResult(idx, { preserveView: true }); } catch { }
        }
        _updateCardUndoRedoButtons(idx);
        return true;
    }

    function _hasSvgUndo(idx) { return !!(_svgUndoStacks[idx] && _svgUndoStacks[idx].length > 0); }
    function _hasSvgRedo(idx) { return !!(_svgRedoStacks[idx] && _svgRedoStacks[idx].length > 0); }

    function _updateCardUndoRedoButtons(idx) {
        const card = document.querySelector(`.page-card[data-idx="${idx}"]`);
        if (!card) return;
        const undoBtn = card.querySelector('.btn-svg-undo');
        const redoBtn = card.querySelector('.btn-svg-redo');
        if (undoBtn) undoBtn.disabled = !_hasSvgUndo(idx);
        if (redoBtn) redoBtn.disabled = !_hasSvgRedo(idx);
    }

    // ── Build a result card (supports both page-level and layer-level) ──
    function _buildResultCardElement(idx) {
        const r = pageResults[idx];
        const card = document.createElement('div');
        card.className = 'page-card rounded-2xl border border-slate-600/50 bg-slate-700/80 text-slate-100 shadow-soft';
        card.dataset.idx = String(idx);
        card.classList.toggle('ring-2', _isLayoutPreviewSelected(idx));
        card.classList.toggle('ring-sky-400/50', _isLayoutPreviewSelected(idx));

        if (r && r.svgContent && (!isFinite(r.objectCount) || r.objectCount <= 0)) {
            r.objectCount = countSvgObjects(r.svgContent);
        }

        const titleAlreadyHasCount = (() => {
            try {
                const name = String((r && r.isLayer) ? (r.layerName || '') : ('Page ' + (r ? r.pageNumber : '')));
                // e.g. "Other elements (267168)" or "Full SVG (all layers) (352806)"
                return /\(\s*\d[\d,\.]*\s*\)\s*$/.test(name);
            } catch {
                return false;
            }
        })();

        const meta = (() => {
            const parts = [];
            if (r && isFinite(r.svgSizeBytes) && r.svgSizeBytes > 0) parts.push(formatBytes(r.svgSizeBytes));
            // Avoid duplicating the object count when it is already in the title ("(...)")
            if (!titleAlreadyHasCount && r && isFinite(r.objectCount) && r.objectCount > 0) parts.push(`${formatInt(r.objectCount)} objects`);
            return parts.join(' • ');
        })();

        let header;
        if (r.isLayer) {
            // Layer card header with colour swatch + optional region badge
            const swatch = r.layerColor
                ? `<span class="inline-block w-4 h-4 rounded-sm border border-white/20" style="background:${r.layerColor}"></span>`
                : `<i class="fa-solid ${r.layerIcon || 'fa-layer-group'} text-brand text-sm"></i>`;
            const regionBadge = r.regionIndex
                ? `<span class="text-[10px] px-1.5 py-0.5 rounded bg-sky-800/60 text-sky-300 font-bold">R${r.regionIndex}</span>`
                : '';
            header = `
                <div class="flex items-center gap-2 px-4 py-2.5 border-b border-slate-600/40">
                    <label class="inline-flex items-center gap-1 text-slate-300" title="Select this layout for combined preview">
                        <input type="checkbox" class="result-preview-select h-4 w-4 rounded border-slate-400/60 bg-slate-950 text-sky-400 focus:ring-sky-400/50" data-idx="${idx}" ${_isLayoutPreviewSelected(idx) ? 'checked' : ''}>
                    </label>
                    ${swatch} ${regionBadge}
                    <span class="text-sm font-semibold text-slate-200">${escHtml(r.layerName)}</span>
                    ${r.svgContent ? `<span class="ml-auto text-[11px] text-slate-400">${escHtml(meta)}</span>` : ''}
                </div>`;
        } else {
            header = `
                <div class="flex items-center gap-2 px-4 py-2.5 border-b border-slate-600/40">
                    <label class="inline-flex items-center gap-1 text-slate-300" title="Select this layout for combined preview">
                        <input type="checkbox" class="result-preview-select h-4 w-4 rounded border-slate-400/60 bg-slate-950 text-sky-400 focus:ring-sky-400/50" data-idx="${idx}" ${_isLayoutPreviewSelected(idx) ? 'checked' : ''}>
                    </label>
                    <span class="inline-flex items-center justify-center w-6 h-6 rounded-full bg-brand/20 text-brand text-xs font-bold">${r.pageNumber}</span>
                    <span class="text-sm font-semibold text-slate-200">Page ${r.pageNumber}</span>
                    ${r.svgContent ? `<span class="ml-auto text-[11px] text-slate-400">${escHtml(meta)}</span>` : ''}
                </div>`;
        }

        let body;
        if (r.error) {
            body = `<div class="px-4 py-3"><div class="text-rose-300 text-sm">${escHtml(r.error)}</div></div>`;
        } else {
            // SVG thumbnail rendered inline — full-width preview
            const thumbAlt = r.isLayer
                ? ((r.layerName && String(r.layerName).trim())
                    ? String(r.layerName).trim()
                    : (r.pageNumber ? `Page ${r.pageNumber}` : 'SVG layer'))
                : `Page ${r.pageNumber}`;

            // Layer/region mode: ALWAYS render a vector thumbnail for each layer.
            // Use a Blob objectURL (not data URL) so huge SVGs still preview correctly.
            // For "Small signs" layer: auto-crop to content so tiny elements are visible.
            const isSmallSignsLayer = r.isLayer && /small signs|moved small signs/i.test(r.layerName || '');
            const isFamilyDetectorLayer = !!(r && r.isFamilyDetectorLayer);
            const thumbSvg = (r.isLayer && r.svgContent)
                ? (isFamilyDetectorLayer
                    ? _fitFamilyDetectorSvgToImages(r.svgContent, _getFamilyDetectorSourceMetrics(r), r.familyContentBounds || null)
                    : (isSmallSignsLayer ? _autoCropSvgForThumbnail(r.svgContent) : r.svgContent))
                : null;
            const thumbHtml = thumbSvg
                ? `<img src="${svgToObjectUrl(thumbSvg)}" class="svg-thumb" alt="${escHtml(thumbAlt)}" loading="lazy" />`
                : (r.thumbnailDataUrl
                    ? `<img src="${r.thumbnailDataUrl}" class="svg-thumb" alt="${escHtml(thumbAlt)}" loading="lazy" />`
                    : (r.svgContent ? `<div class="svg-thumb">${r.svgContent}</div>` : ''));

            const dlName = r.isLayer
                ? `layer_${idx + 1}_${(r.layerName || 'layer').replace(/[^a-zA-Z0-9]/g, '_').substring(0, 30)}.svg`
                : `page_${r.pageNumber}.svg`;

            body = `<div class="px-4 py-3 space-y-3">
                ${thumbHtml}
                <div class="flex flex-wrap items-center gap-2">
                    <button type="button" class="btn-preview inline-flex items-center gap-1 rounded-lg border border-slate-500/60 bg-slate-800/40 hover:bg-slate-800/60 text-slate-100 px-3 py-1.5 text-xs transition" data-idx="${idx}">
                        <i class="fa-solid fa-eye"></i> Preview
                    </button>
                    <button type="button" class="btn-download-svg inline-flex items-center gap-1 rounded-lg border border-emerald-500/60 bg-emerald-900/30 hover:bg-emerald-900/50 text-emerald-300 px-3 py-1.5 text-xs transition" data-idx="${idx}" data-filename="${escHtml(dlName)}">
                        <i class="fa-solid fa-download"></i> SVG
                    </button>
                </div>
            </div>`;
        }

        card.innerHTML = header + body;

        // Wire up buttons
        const title = r.isLayer ? r.layerName : ('Page ' + r.pageNumber);
        card.querySelector('.btn-preview')?.addEventListener('click', async () => {
            if (!r.svgContent) return;
            try {
                await _openSvgPreviewForResult(idx);
            } catch (e) {
                const msg = e && e.message ? e.message : String(e || 'Failed to open SVG Preview.');
                try { showError(msg); } catch { /* ignore */ }
                cgAlert(msg);
            }
        });
        card.querySelector('.btn-download-svg')?.addEventListener('click', () => {
            if (!r.svgContent) return;
            const fname = card.querySelector('.btn-download-svg').dataset.filename || 'output.svg';
            downloadFile(fname, _getSvgContentForExport(r.svgContent), 'image/svg+xml');
        });
        /* Align / Undo / Redo buttons removed from cards */
        card.querySelector('.result-preview-select')?.addEventListener('change', (ev) => {
            _setLayoutPreviewSelected(idx, !!(ev && ev.target && ev.target.checked));
            card.classList.toggle('ring-2', _isLayoutPreviewSelected(idx));
            card.classList.toggle('ring-sky-400/50', _isLayoutPreviewSelected(idx));
        });
        return card;
    }

    async function _openSvgPreviewMarkup(title, previewMarkup, opts) {
        const preserveView = !!(opts && opts.preserveView);
        const preservedZoom = preserveView ? svgPreviewZoom : 1;
        const preservedCropEnabled = preserveView ? !!svgPreviewFixedCropEnabled : !!svgPreviewFixedCropEnabled;
        const preservedCropViewBox = preserveView ? String(svgPreviewFixedCropViewBoxStr || '') : String(svgPreviewFixedCropViewBoxStr || '');
        const modal = document.getElementById('svgPreviewModal');
        const body = document.getElementById('svgPreviewBody');
        const titleEl = document.getElementById('previewTitle');
        if (!modal || !body || !titleEl) throw new Error('SVG Preview UI is not available.');
        const prevScrollLeft = preserveView && body ? body.scrollLeft : 0;
        const prevScrollTop = preserveView && body ? body.scrollTop : 0;

        _svgPreviewActiveResultIdx = Number.isFinite(Number(opts && opts.activeResultIdx)) ? (Number(opts.activeResultIdx) | 0) : -1;
        _clearSvgPreviewAiCandidateHighlight();
        try { _syncSvgAiModelPicker(); } catch { /* ignore */ }
        _updateSvgAiTextOnlyUi();

        // Hide editing-only toolbar items for Combined Layout
        const _isCombined = !!(opts && opts.isCombinedLayout);
        const _editOnlyIds = ['btnSvgCropAll', 'btnSvgViewCode', 'btnSvgAiClean', 'btnSvgMoveSmallSigns', 'svgAiCandidateCount', 'btnSvgAiCandidateDebug'];
        for (const eid of _editOnlyIds) {
            const el = document.getElementById(eid);
            if (el) el.style.display = _isCombined ? 'none' : '';
        }

        titleEl.textContent = title || 'SVG Preview';
        body.innerHTML = `<div class="flex min-h-[240px] items-center justify-center rounded-xl border border-slate-200 bg-slate-50 text-sm text-slate-500">Loading preview…</div>`;
        _applySvgPreviewModalSidebarOffset();
        modal.classList.remove('hidden');

        await new Promise(resolve => requestAnimationFrame(() => resolve()));

        body.innerHTML = `<div id="svgPreviewScale" style="display:inline-block;">${previewMarkup}</div>`;

        svgPreviewUseAutoCrop = !!(opts && opts.useAutoCrop);
        svgPreviewAutoCropForce = !!(opts && opts.autoCropForce);
        svgPreviewAutoCropPreservePageAspect = !!(opts && opts.preservePageAspect);

        body.scrollLeft = preserveView ? prevScrollLeft : 0;
        body.scrollTop = preserveView ? prevScrollTop : 0;

        const svg = body.querySelector('#svgPreviewScale svg');
        if (svg) {
            svg._origViewBoxStr = svg.getAttribute('viewBox');

            const origVB = svg.viewBox && svg.viewBox.baseVal
                ? { x: svg.viewBox.baseVal.x, y: svg.viewBox.baseVal.y, w: svg.viewBox.baseVal.width, h: svg.viewBox.baseVal.height }
                : null;
            const origW = parseFloat(svg.getAttribute('width')) || (origVB ? origVB.w : 0);
            const origH = parseFloat(svg.getAttribute('height')) || (origVB ? origVB.h : 0);
            svg._origPageRect = {
                x: origVB ? origVB.x : 0,
                y: origVB ? origVB.y : 0,
                w: origW,
                h: origH
            };

            const vb = svg.viewBox && svg.viewBox.baseVal ? svg.viewBox.baseVal : null;
            if ((!vb || !vb.width || !vb.height) && svg._origPageRect.w > 0 && svg._origPageRect.h > 0) {
                svg.setAttribute('viewBox', `${svg._origPageRect.x} ${svg._origPageRect.y} ${svg._origPageRect.w} ${svg._origPageRect.h}`);
            }

            svg.removeAttribute('width');
            svg.removeAttribute('height');
            svg.style.width = 'auto';
            svg.style.height = 'auto';
            svg.style.display = 'block';
            if (!svg.getAttribute('preserveAspectRatio')) svg.setAttribute('preserveAspectRatio', 'xMidYMid meet');

            if (svgPreviewUseAutoCrop) {
                try { autoFitSvgPreviewViewBoxToContent(svg, { force: true, preservePageAspect: svgPreviewAutoCropPreservePageAspect }); } catch { /* ignore */ }
            }
        }

        if (preserveView) {
            svgPreviewFixedCropEnabled = preservedCropEnabled;
            svgPreviewFixedCropViewBoxStr = preservedCropViewBox || null;
            setSvgPreviewZoom(preservedZoom > 0 ? preservedZoom : 1.0);
        } else {
            setSvgPreviewZoom(1.0);
        }
        _applySvgPreviewModalSidebarOffset();
        _updateSvgCropUi();

        if (svg) {
            requestAnimationFrame(() => {
                _renderSvgPreviewCropOverlay();
                if (preserveView) {
                    body.scrollLeft = prevScrollLeft;
                    body.scrollTop = prevScrollTop;
                } else {
                    fitSvgPreviewToViewport();
                }
            });
        }

        // Show/hide drag-move toolbar if SVG contains family markers
        try {
            const hasFamilyMarkers = !!(svg && svg.querySelector('g[data-family-marker]'));
            if (typeof window._initDragMoveBar === 'function') window._initDragMoveBar(hasFamilyMarkers);
        } catch { /* ignore */ }
    }

    async function _openSvgPreviewForResult(idx, opts) {
        const r = pageResults[idx];
        if (!r || !r.svgContent) return;
        const title = r.isLayer ? r.layerName : ('Page ' + r.pageNumber);
        const previewMarkup = await _getSvgContentForPreviewDisplayAsync(r);
        await _openSvgPreviewMarkup('SVG Preview — ' + title, previewMarkup, {
            preserveView: !!(opts && opts.preserveView),
            useAutoCrop: !!r.isLayer,
            autoCropForce: !!r.isLayer,
            preservePageAspect: !!r.isFamilyDetectorLayer,
            activeResultIdx: idx
        });
    }

    document.getElementById('btnLayerAlignClose')?.addEventListener('click', () => {
        _closeLayerAlignmentModal();
    });
    document.getElementById('btnLayerAlignTabSource')?.addEventListener('click', () => {
        _setLayerAlignActiveTab('source');
    });
    document.getElementById('btnLayerAlignTabTarget')?.addEventListener('click', () => {
        _setLayerAlignActiveTab('target');
    });
    document.getElementById('btnLayerAlignFitSource')?.addEventListener('click', () => {
        try {
            if (_layerAlignState) _layerAlignState.sourceViewBox = null;
            const host = document.getElementById('layerAlignSourceHost');
            const svg = host ? host.querySelector('svg') : null;
            if (svg) _fitAlignmentSvgToContent('source', svg, true);
        } catch { /* ignore */ }
    });
    document.getElementById('btnLayerAlignFitTarget')?.addEventListener('click', () => {
        try {
            if (_layerAlignState) _layerAlignState.targetViewBox = null;
            const host = document.getElementById('layerAlignTargetHost');
            const svg = host ? host.querySelector('svg') : null;
            if (svg) _fitAlignmentSvgToContent('target', svg, true);
