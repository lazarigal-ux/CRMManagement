        const title = names.length <= 3 ? names.join(' + ') : `${names.slice(0, 3).join(' + ')} + ${names.length - 3} more`;
        await _openSvgPreviewMarkup(`Combined Layout — ${title}`, markup, {
            useAutoCrop: true,
            autoCropForce: true,
            preservePageAspect: false,
            activeResultIdx: valid[0],
            isCombinedLayout: true
        });
