    @@keyframes preSplitMergePulse {
        0%, 100% {
            transform: translateY(0);
            box-shadow: 0 0 0 rgba(192, 38, 211, 0), 0 0 0 rgba(168, 85, 247, 0);
        }
        50% {
            transform: translateY(-1px);
            box-shadow: 0 0 0 4px rgba(217, 70, 239, 0.16), 0 10px 22px rgba(168, 85, 247, 0.22);
        }
    }
    @@keyframes preSplitMergeShimmer {
        0% {
            transform: translateX(-135%) skewX(-18deg);
            opacity: 0;
        }
        18% {
            opacity: .0;
        }
        45% {
            opacity: .42;
        }
        100% {
            transform: translateX(170%) skewX(-18deg);
            opacity: 0;
        }
    }
    #btnPreSplitMerge.premerge-btn-anim {
        position: relative;
        will-change: transform, box-shadow;
        overflow: hidden;
        isolation: isolate;
        transition: transform .18s ease, box-shadow .18s ease, border-color .18s ease, background .18s ease;
    }
    #btnPreSplitMerge.premerge-btn-anim::after {
        content: '';
        position: absolute;
        inset: -35% auto -35% -30%;
        width: 44%;
        background: linear-gradient(90deg, rgba(255,255,255,0) 0%, rgba(255,255,255,.08) 35%, rgba(255,255,255,.55) 50%, rgba(255,255,255,.08) 65%, rgba(255,255,255,0) 100%);
        transform: translateX(-135%) skewX(-18deg);
        pointer-events: none;
        opacity: 0;
        z-index: 0;
    }
    #btnPreSplitMerge.premerge-btn-anim > * {
        position: relative;
        z-index: 1;
    }
    #btnPreSplitMerge.premerge-btn-anim i {
        transition: transform .2s ease;
    }
    #btnPreSplitMerge.premerge-btn-anim:hover {
        transform: translateY(-1px);
        box-shadow: 0 10px 24px rgba(168, 85, 247, 0.18);
    }
    #btnPreSplitMerge.premerge-btn-anim:hover i {
        transform: scale(1.08);
    }
    #btnPreSplitMerge.premerge-btn-busy {
        animation: preSplitMergePulse 1.8s ease-in-out infinite;
    }
    #btnPreSplitMerge.premerge-btn-busy::after {
        animation: preSplitMergeShimmer 2.2s ease-in-out infinite;
    }
