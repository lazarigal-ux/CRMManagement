                simpleLine = pointCount === 2 && segCount <= 3 && pathLength > 0;
            } else if (tag === 'polygon' || tag === 'polyline') {
                bounds = _estimateSvgPointsBounds(points);
                pointCount = distinctPointCount(points, 10);
                pathLength = estimatePolyLength(points);
                segCount = pointCount;
                simpleLine = pointCount === 2 && pathLength > 0;
            } else if (tag === 'line') {
                const x1 = _parseSvgNumberAttr(attr('x1'));
                const y1 = _parseSvgNumberAttr(attr('y1'));
                const x2 = _parseSvgNumberAttr(attr('x2'));
                const y2 = _parseSvgNumberAttr(attr('y2'));
                if (x1 != null && y1 != null && x2 != null && y2 != null) {
                    bounds = {
                        x: Math.min(x1, x2),
                        y: Math.min(y1, y2),
                        width: Math.abs(x2 - x1),
                        height: Math.abs(y2 - y1)
                    };
                    pointCount = 2;
                    pathLength = Math.sqrt((x2 - x1) ** 2 + (y2 - y1) ** 2);
                    segCount = 2;
                    simpleLine = true;
                }
            } else if (tag === 'rect' || tag === 'image' || tag === 'use') {
                const x = _parseSvgNumberAttr(attr('x')) || 0;
                const y = _parseSvgNumberAttr(attr('y')) || 0;
                const width = _parseSvgNumberAttr(attr('width'));
                const height = _parseSvgNumberAttr(attr('height'));
                if (width > 0 && height > 0) bounds = { x, y, width, height };
                pointCount = 4;
            }

            if (bounds && transform) {
                bounds = _svgTransformRect(bounds, _svgParseTransformMatrix(transform));
            }

            const geomWidth = Math.max(0, Number(bounds && bounds.width) || 0);
            const geomHeight = Math.max(0, Number(bounds && bounds.height) || 0);
            const geomArea = geomWidth > 0 && geomHeight > 0 ? (geomWidth * geomHeight) : 0;
            const aspectRatio = (geomWidth > 0 && geomHeight > 0)
                ? (Math.max(geomWidth, geomHeight) / Math.max(0.0001, Math.min(geomWidth, geomHeight)))
                : 0;
            const shapeKind = ((tag === 'path' || tag === 'polygon') && pointCount === 3) ? 'triangle' : tag;

            return {
                tag,
                shapeKind,
                stroke: normAttr('stroke'),
                fill: normAttr('fill'),
                strokeWidth,
                strokeWidthNum: Number.isFinite(strokeWidthNum) ? strokeWidthNum : null,
                transform,
                strokeLinecap: normAttr('stroke-linecap'),
                strokeLinejoin: normAttr('stroke-linejoin'),
                pointCount,
                pathLength,
                segCount,
                simpleLine,
                geomWidth,
                geomHeight,
                geomArea,
                aspectRatio,
                _ratioWithin: ratioWithin,
                _closeEnough: closeEnough
            };
        }

        function _signaturesMatch(a, b) {
            if (!a || !b) return false;
            if (a.tag !== b.tag) return false;
            if (a.shapeKind && b.shapeKind && a.shapeKind !== b.shapeKind) return false;
            if (a.stroke !== b.stroke) return false;
            if (a.fill !== b.fill) return false;
            if (a.strokeLinecap !== b.strokeLinecap) return false;
            if (a.strokeLinejoin !== b.strokeLinejoin) return false;

            if ((a.pointCount > 0) && (b.pointCount > 0) && a.pointCount !== b.pointCount) return false;

            const closeEnough = a._closeEnough || b._closeEnough || ((x, y) => x === y);
            const ratioWithin = a._ratioWithin || b._ratioWithin || ((x, y) => x === y);
            const diagA = Math.sqrt((a.geomWidth || 0) * (a.geomWidth || 0) + (a.geomHeight || 0) * (a.geomHeight || 0));
            const diagB = Math.sqrt((b.geomWidth || 0) * (b.geomWidth || 0) + (b.geomHeight || 0) * (b.geomHeight || 0));
            const majorA = Math.max(a.geomWidth || 0, a.geomHeight || 0);
            const majorB = Math.max(b.geomWidth || 0, b.geomHeight || 0);
            const minorA = Math.min(a.geomWidth || 0, a.geomHeight || 0);
            const minorB = Math.min(b.geomWidth || 0, b.geomHeight || 0);

            if (!closeEnough(a.strokeWidthNum, b.strokeWidthNum, 0.22, 0.25)) return false;

            if (a.simpleLine || b.simpleLine) {
                if (!(a.simpleLine && b.simpleLine)) return false;
                if (a.pathLength > 1 && b.pathLength > 1 && !ratioWithin(a.pathLength, b.pathLength, 1.85)) return false;
                if (diagA > 1 && diagB > 1 && !ratioWithin(diagA, diagB, 1.85)) return false;
                if (majorA > 1 && majorB > 1 && !ratioWithin(majorA, majorB, 1.9)) return false;
                if (!closeEnough(minorA, minorB, 0.75, 8)) return false;
                return true;
            }

            // Path length – strongest discriminator for non-line-work
            if (a.pathLength > 1 && b.pathLength > 1) {
                if (!ratioWithin(a.pathLength, b.pathLength, 1.45)) return false;
            } else if ((a.pathLength > 1) !== (b.pathLength > 1)) {
                return false;
            }

            if (a.segCount > 0 && b.segCount > 0) {
                const minSeg = Math.min(a.segCount, b.segCount);
                const maxSeg = Math.max(a.segCount, b.segCount);
                if (maxSeg > minSeg + Math.max(1, Math.floor(minSeg * 0.3))) return false;
            }

            if (diagA > 1 && diagB > 1) {
                if (!ratioWithin(diagA, diagB, 1.45)) return false;
            } else if ((diagA > 3) !== (diagB > 3)) {
                return false;
            }

            if (!ratioWithin(a.geomWidth, b.geomWidth, 1.45)) return false;
            if (!ratioWithin(a.geomHeight, b.geomHeight, 1.45)) return false;
            if (!ratioWithin(a.geomArea, b.geomArea, 1.9)) return false;
            if (!ratioWithin(a.aspectRatio, b.aspectRatio, 1.4)) return false;
            return true;
        }

        function _countMatchingSignatureLines(lines, signatures) {
            const indexes = [];
            const sigs = Array.isArray(signatures) ? signatures.filter(Boolean) : [];
            if (!sigs.length) return indexes;
            for (let i = 0; i < lines.length; i++) {
                const lineSig = _parseSvgElementSignature(lines[i]);
                if (!lineSig) continue;
                for (const sig of sigs) {
                    if (_signaturesMatch(sig, lineSig)) {
                        indexes.push(i);
                        break;
                    }
                }
            }
            return indexes;
        }

        function _describeSignatureKind(signatures) {
            const list = Array.isArray(signatures) ? signatures.filter(Boolean) : [];
            if (!list.length) return 'element';
            const first = list[0];
            const kind = String(first.shapeKind || first.tag || 'element').trim().toLowerCase();
            for (let i = 1; i < list.length; i++) {
                const nextKind = String(list[i].shapeKind || list[i].tag || 'element').trim().toLowerCase();
                if (nextKind !== kind) return 'element';
            }
            return kind || 'element';
        }

        function _buildSvgPseudoLine(el) {
            const tag = (el && (el.tagName || el.nodeName) || '').toLowerCase();
            if (!tag) return '';
            const sigAttrs = ['d', 'points', 'x', 'y', 'x1', 'y1', 'x2', 'y2', 'width', 'height', 'cx', 'cy', 'r', 'rx', 'ry', 'stroke', 'fill', 'stroke-width', 'stroke-linecap', 'stroke-linejoin', 'transform'];
            let pseudo = `<${tag}`;
            for (const an of sigAttrs) {
                const av = el.getAttribute(an);
                if (av != null && av !== '') pseudo += ` ${an}="${av}"`;
            }
            pseudo += '/>';
            return pseudo;
        }

        function _setSvgElementDarkGray(el) {
            if (!el || !el.setAttribute) return false;
            const darkGray = '#4b5563';
            let changed = false;
            const tag = String(el.tagName || '').toLowerCase();
            const stroke = String(_getSvgInheritedStyleValue(el, 'stroke') || '').trim().toLowerCase();
            const fill = String(_getSvgInheritedStyleValue(el, 'fill') || '').trim().toLowerCase();

            if (stroke && stroke !== 'none') {
                el.setAttribute('stroke', darkGray);
                changed = true;
            }
            if (fill && fill !== 'none') {
                el.setAttribute('fill', darkGray);
                changed = true;
            }
            if (!changed && (tag === 'path' || tag === 'line' || tag === 'polyline' || tag === 'polygon')) {
                el.setAttribute('stroke', darkGray);
                changed = true;
            }
            return changed;
        }

        async function _paintSelectedObjectsDarkGray() {
            const idx = Number(_svgPreviewActiveResultIdx);
            const r = (idx >= 0 && pageResults[idx]) ? pageResults[idx] : null;
            if (!r || !r.svgContent) return 0;

            const exactKeys = _collectSelectedSvgExactKeys();
            if (!exactKeys.size) return 0;

            const parser = new DOMParser();
            const doc = parser.parseFromString(String(r.svgContent || ''), 'image/svg+xml');
            const svgRoot = doc.querySelector('svg');
            if (!svgRoot) return 0;

            let changedCount = 0;
            const allEls = svgRoot.querySelectorAll('path, line, rect, circle, ellipse, polygon, polyline, text, image, use');
            for (const el of allEls) {
                const key = _buildSvgExactKeyFromLine(_buildSvgPseudoLine(el));
                if (!key) continue;
                const remaining = exactKeys.get(key) || 0;
                if (remaining <= 0) continue;
                if (_setSvgElementDarkGray(el)) changedCount++;
                exactKeys.set(key, remaining - 1);
            }

            if (!(changedCount > 0)) return 0;
            r.svgContent = new XMLSerializer().serializeToString(svgRoot);
            try { _syncResultMetadataAfterSvgChange(idx); } catch { /* ignore */ }
            try { await _openSvgPreviewForResult(idx, { preserveView: true }); } catch { /* ignore */ }
            refreshCodePanel({ silent: true });
            try { _updateCodeSelectionPreview(); } catch { /* ignore */ }
            return changedCount;
        }

        function _updateCodeSelectionPreview() {
            _clearCodeSelectionPreview();
            if (panel.classList.contains('hidden')) return 0;
            const previewSvg = document.querySelector('#svgPreviewScale svg');
            if (!previewSvg) return 0;
            const exactKeys = _collectSelectedSvgExactKeys();
            if (!exactKeys.size) return 0;
            let count = 0;
            const highlighted = [];
            const allEls = previewSvg.querySelectorAll('path, line, rect, circle, ellipse, polygon, polyline, text, image, use');
            for (const el of allEls) {
                const key = _buildSvgExactKeyFromLine(_buildSvgPseudoLine(el));
                if (!key) continue;
                const remaining = exactKeys.get(key) || 0;
                if (remaining <= 0) continue;
                el.classList.add('svg-code-selection-highlight');
                exactKeys.set(key, remaining - 1);
                highlighted.push(el);
                count++;
            }

            // Zoom to show highlighted elements
            if (highlighted.length > 0) {
                try { _zoomToSelectedElements(previewSvg, highlighted); } catch { /* ignore */ }
            }

            return count;
        }

        function _zoomToSelectedElements(svgEl, elements) {
            const body = document.getElementById('svgPreviewBody');
            if (!body || !svgEl) return;

            const vb = svgEl.viewBox && svgEl.viewBox.baseVal;
            if (!vb || !(vb.width > 0) || !(vb.height > 0)) {
                console.warn('[zoom-sel] No valid viewBox on SVG');
                return;
            }

            // Get the SVG's rendered rect to compute screen→viewBox mapping
            const svgRect = svgEl.getBoundingClientRect();
            if (!(svgRect.width > 0) || !(svgRect.height > 0)) {
                console.warn('[zoom-sel] SVG has zero rendered size');
                return;
            }
            const scaleX = svgRect.width / vb.width;
            const scaleY = svgRect.height / vb.height;

            console.log('[zoom-sel] viewBox:', vb.x, vb.y, vb.width, vb.height,
                        'rendered:', svgRect.width.toFixed(1), svgRect.height.toFixed(1),
                        'scale:', scaleX.toFixed(4), scaleY.toFixed(4));

            // Convert each element's screen bbox → viewBox coordinates
            let minX = Infinity, minY = Infinity, maxX = -Infinity, maxY = -Infinity;
            for (const el of elements) {
                try {
                    const r = el.getBoundingClientRect();
                    if (!(r.width > 0) && !(r.height > 0)) continue;
                    const vx1 = vb.x + (r.left - svgRect.left) / scaleX;
                    const vy1 = vb.y + (r.top - svgRect.top) / scaleY;
                    const vx2 = vb.x + (r.right - svgRect.left) / scaleX;
                    const vy2 = vb.y + (r.bottom - svgRect.top) / scaleY;
                    console.log('[zoom-sel] element rect→viewBox:', vx1.toFixed(2), vy1.toFixed(2), vx2.toFixed(2), vy2.toFixed(2));
                    minX = Math.min(minX, vx1);
                    minY = Math.min(minY, vy1);
                    maxX = Math.max(maxX, vx2);
                    maxY = Math.max(maxY, vy2);
                } catch { continue; }
            }
            if (!isFinite(minX) || !isFinite(minY) || !isFinite(maxX) || !isFinite(maxY)) {
                console.warn('[zoom-sel] No valid bounding boxes found');
                return;
            }

            const selW = maxX - minX;
            const selH = maxY - minY;
            console.log('[zoom-sel] combined viewBox bbox:', minX.toFixed(2), minY.toFixed(2),
                        'size:', selW.toFixed(2), selH.toFixed(2));
            if (!(selW > 0) && !(selH > 0)) return;

            // Add padding (20% around the selection, minimum 5 viewBox units)
            const padX = Math.max(selW * 0.2, 5);
            const padY = Math.max(selH * 0.2, 5);
            const viewW = selW + padX * 2;
            const viewH = selH + padY * 2;

            // Compute zoom to fit selection in viewport
            const bodyRect = body.getBoundingClientRect();
            const viewportW = bodyRect.width;
            const viewportH = bodyRect.height;
            if (!(viewportW > 0) || !(viewportH > 0)) return;

            const zoomX = viewportW / viewW;
            const zoomY = viewportH / viewH;
            const newZoom = Math.max(0.1, Math.min(20, Math.min(zoomX, zoomY)));

            console.log('[zoom-sel] viewport:', viewportW.toFixed(0), viewportH.toFixed(0),
                        'padded view:', viewW.toFixed(2), viewH.toFixed(2),
                        'newZoom:', newZoom.toFixed(3));

            // Center of the selection in viewBox coordinates
            const selCenterX = (minX + maxX) / 2;
            const selCenterY = (minY + maxY) / 2;

            setSvgPreviewZoom(newZoom);

            // Scroll to center the selection (defer to next frame so layout reflows first)
            requestAnimationFrame(() => {
                // After zoom, pixel position = (viewBoxCoord - viewBox.origin) * zoom
                const pixelX = (selCenterX - vb.x) * newZoom;
                const pixelY = (selCenterY - vb.y) * newZoom;
                const scrollL = pixelX - viewportW / 2;
                const scrollT = pixelY - viewportH / 2;
                console.log('[zoom-sel] scroll: selCenter=', selCenterX.toFixed(2), selCenterY.toFixed(2),
                            'pixel=', pixelX.toFixed(0), pixelY.toFixed(0),
                            'scroll=', scrollL.toFixed(0), scrollT.toFixed(0),
                            'scrollMax=', body.scrollWidth, body.scrollHeight);
                body.scrollLeft = scrollL;
                body.scrollTop = scrollT;
            });
        }

        // ── Helper: persist deleted element lines to DB ──
        async function _saveDeletedLinesToDb(deletedLines, source) {
            try {
                const idx = Number(_svgPreviewActiveResultIdx);
                const layer = (idx >= 0 && pageResults[idx]) ? (pageResults[idx].layerName || '') : '';
                if (!layer) { console.warn('[delete-db] no active layer name'); return; }
                const elements = (Array.isArray(deletedLines) ? deletedLines : [deletedLines])
                    .map(l => String(l || '').trim()).filter(Boolean);
                if (!elements.length) return;
                const resp = await fetch(SVG_DELETE_RULES_ENDPOINT, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ layerName: layer, source: source || 'manual', elements })
                });
                const data = await resp.json();
                console.log('[delete-db] saved', data.added, 'rules for layer', layer, '(sent:', elements.length, ')');
            } catch (e) {
                console.warn('[delete-db] save failed:', e);
            }
        }

        function _isSaveDeleteToDbEnabled() {
            const chk = document.getElementById('chkSvgSaveDeleteToDb');
            return chk && chk.checked;
        }

        // ── DELETE selected lines from SVG ──
        const btnDelete = document.getElementById('btnSvgCodeDelete');
        const deleteStatus = document.getElementById('svgCodeDeleteStatus');
        if (btnDelete) {
            btnDelete.addEventListener('click', async () => {
                const selStart = textarea.selectionStart;
                const selEnd = textarea.selectionEnd;
                const code = textarea.value;
                if (!code) return;

                // Expand selection to full lines
                let lineStart = code.lastIndexOf('\n', selStart - 1) + 1;
                let lineEnd = code.indexOf('\n', selEnd);
                if (lineEnd === -1) lineEnd = code.length;

                const selectedText = code.substring(lineStart, lineEnd).trim();
                if (!selectedText) {
                    if (deleteStatus) { deleteStatus.textContent = 'Select lines to delete first'; deleteStatus.classList.remove('hidden'); setTimeout(() => deleteStatus.classList.add('hidden'), 2000); }
                    return;
                }

                const selectedLines = selectedText.split('\n').filter(l => l.trim());
                const lineCount = selectedLines.length;
                const selectedSignatures = selectedLines.map(_parseSvgElementSignature).filter(Boolean);
                const similarKind = _describeSignatureKind(selectedSignatures);

                const idx = Number(_svgPreviewActiveResultIdx);
                const r = (idx >= 0 && pageResults[idx]) ? pageResults[idx] : null;
                const fullSourceLines = (r && r.svgContent) ? String(r.svgContent).replace(/>\s*</g, '>\n<').split('\n') : [];
                const similarMatchesBeforeDelete = _countMatchingSignatureLines(fullSourceLines, selectedSignatures).length;

                // Save state for undo
                _pushUndoState();

                // Show deletion animation
                btnDelete.classList.add('deleting');
                _showDeleteOverlay(lineCount, 'Deleting');
                await new Promise(r => setTimeout(r, 350));

                // Remove selected lines from the textarea code
                const newCode = code.substring(0, lineStart) + code.substring(lineEnd + 1);
                textarea.value = newCode;

                // Update meta
                if (metaEl) {
                    const lines = newCode.split('\n').length;
                    const size = newCode.length;
                    metaEl.textContent = `${lines.toLocaleString()} lines \u2022 ${(size / 1024).toFixed(1)} KB`;
                }

                // Now remove the same lines from the actual SVG content in pageResults
                if (r && r.svgContent) {
                    // Build a Set for O(1) lookups instead of O(n) indexOf per line
                    const removeSet = new Set(selectedLines.map(l => l.trim()).filter(Boolean));
                    const srcLines = String(r.svgContent).replace(/>\s*</g, '>\n<').split('\n');
                    const keepLines = [];
                    for (const sl of srcLines) {
                        if (!removeSet.has(sl.trim())) keepLines.push(sl);
                    }
                    r.svgContent = keepLines.join('\n');
                    try { _syncResultMetadataAfterSvgChange(idx); } catch { /* ignore */ }
                    _clearSelectedAreaAfterDelete();

                    // Refresh the SVG preview
                    try {
                        await _openSvgPreviewForResult(idx, { preserveView: true });
                    } catch { /* ignore */ }
                }

                // Show status
                _hideDeleteOverlay();
                if (deleteStatus) {
                    const extra = (similarMatchesBeforeDelete > lineCount && selectedSignatures.length)
                        ? ` • ~${similarMatchesBeforeDelete} similar ${similarKind}(s) on page with same color / stroke / size`
                        : '';
                    deleteStatus.textContent = `Deleted ${lineCount} element(s)${extra}`;
                    deleteStatus.classList.remove('hidden');
                    setTimeout(() => deleteStatus.classList.add('hidden'), 4200);
                }

                // Animate the button
                _flashDeleteBtn(btnDelete);

                // Save deleted lines to DB (only if toggle is on)
                if (_isSaveDeleteToDbEnabled()) _saveDeletedLinesToDb(selectedLines, 'delete-selected');
            });
        }

        // ── DELETE SIMILAR elements (two-step: highlight → confirm) ──
        let _similarPreviewSignatures = null;   // signatures being previewed
        let _similarPreviewFullCount = 0;       // total matches in full SVG
        let _similarPreviewDescs = [];           // human-readable descriptions
        const _similarOrigLabel = '<i class="fa-solid fa-broom"></i> Delete Similar';

        function _clearSimilarPreview() {
            _similarPreviewSignatures = null;
            _similarPreviewFullCount = 0;
            _similarPreviewDescs = [];
            // Remove red highlights from preview SVG
            const previewSvg = document.querySelector('#svgPreviewScale svg');
            if (previewSvg) {
                previewSvg.querySelectorAll('.svg-similar-highlight').forEach(el => {
                    el.classList.remove('svg-similar-highlight');
                });
            }
            // Reset button appearance
            const btn = document.getElementById('btnSvgCodeDeleteSimilar');
            if (btn) {
                btn.classList.remove('similar-preview-active');
                btn.innerHTML = _similarOrigLabel;
            }
            if (deleteStatus) deleteStatus.classList.add('hidden');
        }

        function _highlightSimilarInPreview(signatures) {
            const previewSvg = document.querySelector('#svgPreviewScale svg');
            if (!previewSvg) return 0;
            let count = 0;
            const allEls = previewSvg.querySelectorAll('path, line, rect, circle, ellipse, polygon, polyline, text, image, use');
            for (const el of allEls) {
                const elSig = _parseSvgElementSignature(_buildSvgPseudoLine(el));
                if (!elSig) continue;
                let matched = false;
                for (const sig of signatures) {
                    if (_signaturesMatch(sig, elSig)) { matched = true; break; }
                }
                if (matched) {
                    el.classList.add('svg-similar-highlight');
                    count++;
                }
            }
            return count;
        }

        const btnDeleteSimilar = document.getElementById('btnSvgCodeDeleteSimilar');
        if (btnDeleteSimilar) {
            btnDeleteSimilar.addEventListener('click', async () => {

                // ── STEP 2: Confirm deletion ──
                if (_similarPreviewSignatures) {
                    const signatures = _similarPreviewSignatures;
                    _clearSimilarPreview();

                    // Save state for undo
                    _pushUndoState();

                    // Show deletion animation
                    btnDeleteSimilar.classList.add('deleting');
                    const code = textarea.value;
                    const allLines = code.split('\n');
                    const matchingLineIndexes = _countMatchingSignatureLines(allLines, signatures);
                    _showDeleteOverlay(matchingLineIndexes.length, 'Deleting similar');
                    await new Promise(r => setTimeout(r, 400));

                    // Remove matching lines from the textarea
                    const matchingLineSet = new Set(matchingLineIndexes);
                    const newLines = allLines.filter((_, i) => !matchingLineSet.has(i));
                    const newCode = newLines.join('\n');
                    textarea.value = newCode;

                    // Update meta
                    if (metaEl) {
                        const lines = newCode.split('\n').length;
                        const size = newCode.length;
                        metaEl.textContent = `${lines.toLocaleString()} lines \u2022 ${(size / 1024).toFixed(1)} KB`;
                    }

                    // Remove from the actual SVG content in pageResults
                    const idx = Number(_svgPreviewActiveResultIdx);
                    const r = (idx >= 0 && pageResults[idx]) ? pageResults[idx] : null;
                    if (r && r.svgContent) {
                        let src = String(r.svgContent).replace(/>\s*</g, '>\n<');
                        const srcLines = src.split('\n');
                        const keepLines = [];
                        let removedFromFull = 0;
                        for (const sl of srcLines) {
                            const slSig = _parseSvgElementSignature(sl);
                            if (slSig && signatures.some(sig => _signaturesMatch(sig, slSig))) {
                                removedFromFull++;
                            } else {
                                keepLines.push(sl);
                            }
                        }
                        r.svgContent = keepLines.join('\n');
                        try { _syncResultMetadataAfterSvgChange(idx); } catch { /* ignore */ }
                        _clearSelectedAreaAfterDelete();

                        // Refresh the SVG preview
                        try {
                            await _openSvgPreviewForResult(idx, { preserveView: true });
                        } catch { /* ignore */ }

                        _hideDeleteOverlay();
                        if (deleteStatus) {
                            const extra = removedFromFull > matchingLineIndexes.length ? ` (${removedFromFull} total in full SVG)` : '';
                            deleteStatus.textContent = `Deleted ${matchingLineIndexes.length} similar element(s) [${signatures.length} signature(s)]${extra}`;
                            deleteStatus.classList.remove('hidden');
                            setTimeout(() => deleteStatus.classList.add('hidden'), 3500);
                        }
                    } else {
                        _hideDeleteOverlay();
                        if (deleteStatus) {
                            deleteStatus.textContent = `Deleted ${matchingLineIndexes.length} similar element(s) [${signatures.length} signature(s)]`;
                            deleteStatus.classList.remove('hidden');
                            setTimeout(() => deleteStatus.classList.add('hidden'), 3000);
                        }
                    }

                    _flashDeleteBtn(btnDeleteSimilar);

                    // Save deleted lines to DB (only if toggle is on)
                    if (_isSaveDeleteToDbEnabled()) {
                        const deletedLines = matchingLineIndexes.map(i => allLines[i]).filter(l => l && l.trim());
                        _saveDeletedLinesToDb(deletedLines, 'delete-similar');
                    }
                    return;
                }

                // ── STEP 1: Parse selection, highlight in red, show count ──
                const selStart = textarea.selectionStart;
                const selEnd = textarea.selectionEnd;
                const code = textarea.value;
                if (!code) return;

                const allLines = code.split('\n');
                let charPos = 0;
                let selFirstLine = -1, selLastLine = -1;
                for (let i = 0; i < allLines.length; i++) {
                    const lineLen = allLines[i].length + 1;
                    if (selFirstLine === -1 && charPos + lineLen > selStart) selFirstLine = i;
                    if (charPos < selEnd) selLastLine = i;
                    charPos += lineLen;
                }
                if (selFirstLine === -1) selFirstLine = 0;
                if (selLastLine === -1) selLastLine = allLines.length - 1;

                // Parse signatures from every selected line, dedup
                const signatures = [];
                const sigKeys = new Set();
                for (let i = selFirstLine; i <= selLastLine; i++) {
                    const sig = _parseSvgElementSignature(allLines[i]);
                    if (!sig) continue;
                    const key = [
                        sig.tag, sig.shapeKind, sig.stroke, sig.fill,
                        sig.strokeLinecap, sig.strokeLinejoin,
                        Number.isFinite(sig.strokeWidthNum) ? sig.strokeWidthNum.toFixed(1) : sig.strokeWidth,
                        sig.geomWidth > 0 ? Math.round(sig.geomWidth * 4) / 4 : '',
                        sig.geomHeight > 0 ? Math.round(sig.geomHeight * 4) / 4 : '',
                        sig.pathLength > 0 ? Math.round(sig.pathLength) : '',
                        sig.segCount || ''
                    ].join('|');
                    if (!sigKeys.has(key)) { sigKeys.add(key); signatures.push(sig); }
                }

                if (signatures.length === 0) {
                    if (deleteStatus) { deleteStatus.textContent = 'Select one or more SVG element lines first'; deleteStatus.classList.remove('hidden'); setTimeout(() => deleteStatus.classList.add('hidden'), 2500); }
                    return;
                }

                // Count matches in the FULL SVG (not just visible/cropped area)
                const idx = Number(_svgPreviewActiveResultIdx);
                const r = (idx >= 0 && pageResults[idx]) ? pageResults[idx] : null;
                let fullCount = 0;
                if (r && r.svgContent) {
                    const src = String(r.svgContent).replace(/>\s*</g, '>\n<');
                    const srcLines = src.split('\n');
                    for (const sl of srcLines) {
                        const slSig = _parseSvgElementSignature(sl);
                        if (slSig && signatures.some(sig => _signaturesMatch(sig, slSig))) fullCount++;
                    }
                } else {
                    // Fall back to visible code
                    fullCount = _countMatchingSignatureLines(allLines, signatures).length;
                }

                if (fullCount === 0) {
                    if (deleteStatus) { deleteStatus.textContent = 'No similar elements found'; deleteStatus.classList.remove('hidden'); setTimeout(() => deleteStatus.classList.add('hidden'), 2500); }
                    return;
                }

                // Build human-readable descriptions
                const descs = signatures.map(sig => [
                    `<${sig.shapeKind || sig.tag}>`,
                    sig.stroke ? `stroke=${sig.stroke}` : '',
                    sig.fill ? `fill=${sig.fill}` : '',
                    sig.strokeWidth ? `stroke-width≈${sig.strokeWidth}` : '',
                    (sig.geomWidth > 0 && sig.geomHeight > 0) ? `size≈${sig.geomWidth.toFixed(1)}×${sig.geomHeight.toFixed(1)}` : '',
                    sig.pathLength > 0 ? `len≈${Math.round(sig.pathLength)}` : '',
                ].filter(Boolean).join(', '));

                // Highlight matching elements in the SVG preview in RED
                const highlightedCount = _highlightSimilarInPreview(signatures);

                // Store state for step 2
                _similarPreviewSignatures = signatures;
                _similarPreviewFullCount = fullCount;
                _similarPreviewDescs = descs;

                // Update button to confirm state
                btnDeleteSimilar.classList.add('similar-preview-active');
                btnDeleteSimilar.innerHTML = `<i class="fa-solid fa-check-double"></i> Confirm Delete (${fullCount})`;

                // Show status
                const kind = _describeSignatureKind(signatures);
                if (deleteStatus) {
                    deleteStatus.textContent = `\u{1F534} ${fullCount} similar ${kind}(s) highlighted in red – click "Confirm Delete" to remove`;
                    deleteStatus.classList.remove('hidden');
                }
            });

            // Cancel preview when clicking other action buttons
            const cancelBtns = [
                document.getElementById('btnSvgCodeClose'),
                document.getElementById('btnSvgCodeDelete'),
                document.getElementById('btnSvgCodeDeleteAll'),
                document.getElementById('btnSvgCodeDeleteFromDb'),
                document.getElementById('btnSvgCodeRefresh'),
