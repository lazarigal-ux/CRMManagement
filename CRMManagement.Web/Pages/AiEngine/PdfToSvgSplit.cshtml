            cur = cur.parentElement;
        }
        return matrix;
    }

    function _cleanupParsePoints(pointsText) {
        const nums = String(pointsText || '').trim().split(/[\s,]+/).filter(Boolean).map(Number);
        const pts = [];
        for (let i = 0; i + 1 < nums.length; i += 2) if (Number.isFinite(nums[i]) && Number.isFinite(nums[i + 1])) pts.push({ x: nums[i], y: nums[i + 1] });
