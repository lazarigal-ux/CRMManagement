        if (splitMainTabBar) splitMainTabBar.classList.toggle('hidden', _mergedSvgOnlyMode);
        try {
            const buttons = splitMainTabBar ? Array.from(splitMainTabBar.querySelectorAll('[data-split-tab]')) : [];
            for (const btn of buttons) {
