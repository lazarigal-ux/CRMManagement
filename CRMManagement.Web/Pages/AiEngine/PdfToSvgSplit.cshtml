        function _highlightDbDeleteInPreview(signatures) {
            const previewSvg = document.querySelector('#svgPreviewScale svg');
            if (!previewSvg) return 0;
            let count = 0;
            const allEls = previewSvg.querySelectorAll('path, line, rect, circle, ellipse, polygon, polyline, text, image, use');
            for (const el of allEls) {
                const elSig = _parseSvgElementSignature(_buildSvgPseudoLine(el));
                if (!elSig) continue;
                let matched = false;
                for (const sig of signatures) {
                    if (_signaturesMatch(sig, elSig)) { matched = true; break; }
                }
                if (matched) {
                    el.classList.add('svg-dbdelete-highlight');
                    count++;
                }
            }
            return count;
        }

        const btnDeleteFromDb = document.getElementById('btnSvgCodeDeleteFromDb');
        if (btnDeleteFromDb) {
            btnDeleteFromDb.addEventListener('click', async () => {

                // ── STEP 2: Confirm deletion (signature-based matching) ──
                if (_dbDeletePreviewRuleSet) {
                    const signatures2 = _dbDeletePreviewSignatures;
                    const totalCount = _dbDeletePreviewCount;
                    _clearDbDeletePreview();

                    // Also clear Delete Similar preview if active
                    if (_similarPreviewSignatures) _clearSimilarPreview();

                    _pushUndoState();

                    // Match via signatures (same as Delete Similar)
                    const code = textarea.value || '';
                    const allLines = code.split('\n');
                    const matchIndexes = _countMatchingSignatureLines(allLines, signatures2);

                    btnDeleteFromDb.classList.add('deleting');
                    _showDeleteOverlay(matchIndexes.length, 'Deleting from DB rules');
                    await new Promise(r => setTimeout(r, 400));

                    const matchSet = new Set(matchIndexes);
                    const newLines = allLines.filter((_, i) => !matchSet.has(i));
                    const newCode = newLines.join('\n');
                    textarea.value = newCode;

                    if (metaEl) {
                        const lines = newCode.split('\n').length;
                        const size = newCode.length;
                        metaEl.textContent = `${lines.toLocaleString()} lines \u2022 ${(size / 1024).toFixed(1)} KB`;
                    }

                    const idx = Number(_svgPreviewActiveResultIdx);
                    const rr = (idx >= 0 && pageResults[idx]) ? pageResults[idx] : null;
                    let removedFromFull = 0;
                    if (rr && rr.svgContent) {
                        const srcLines = String(rr.svgContent).replace(/>\s*</g, '>\n<').split('\n');
                        const keepLines = [];
                        for (const sl of srcLines) {
                            const slSig = _parseSvgElementSignature(sl);
                            if (slSig && signatures2.some(sig => _signaturesMatch(sig, slSig))) {
                                removedFromFull++;
                            } else {
                                keepLines.push(sl);
                            }
                        }
                        rr.svgContent = keepLines.join('\n');
                        try { _syncResultMetadataAfterSvgChange(idx); } catch { /* ignore */ }
                        _clearSelectedAreaAfterDelete();
                        try { await _openSvgPreviewForResult(idx, { preserveView: true }); } catch { /* ignore */ }
                    }

                    _hideDeleteOverlay();
                    _flashDeleteBtn(btnDeleteFromDb);
                    if (deleteStatus) {
                        const extra = removedFromFull > 0 ? ` (${removedFromFull} from full SVG)` : '';
                        deleteStatus.textContent = `DB rules: deleted ${matchIndexes.length} element(s)${extra}`;
                        deleteStatus.classList.remove('hidden');
                        setTimeout(() => deleteStatus.classList.add('hidden'), 4000);
                    }
                    return;
                }

                // ── STEP 1: Fetch rules, highlight matches, show count ──
                // Clear Delete Similar preview if active
                if (_similarPreviewSignatures) _clearSimilarPreview();

                const idx = Number(_svgPreviewActiveResultIdx);
                const layer = (idx >= 0 && pageResults[idx]) ? (pageResults[idx].layerName || '') : '';
                if (!layer) {
                    if (deleteStatus) { deleteStatus.textContent = 'No active layer'; deleteStatus.classList.remove('hidden'); setTimeout(() => deleteStatus.classList.add('hidden'), 2000); }
                    return;
                }

                // Fetch saved delete rules for this layer
                btnDeleteFromDb.disabled = true;
                btnDeleteFromDb.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Loading...';
                let rules;
                try {
                    const url = `${SVG_DELETE_RULES_ENDPOINT}?layerName=${encodeURIComponent(layer)}`;
                    const resp = await fetch(url);
                    if (!resp.ok) throw new Error(`HTTP ${resp.status}`);
                    rules = await resp.json();
                } catch (e) {
                    console.error('[delete-from-db] fetch failed:', e);
                    if (deleteStatus) { deleteStatus.textContent = 'Failed to load rules from DB'; deleteStatus.classList.remove('hidden'); setTimeout(() => deleteStatus.classList.add('hidden'), 3000); }
                    btnDeleteFromDb.disabled = false;
                    btnDeleteFromDb.innerHTML = _dbOrigLabel;
                    return;
                }
                btnDeleteFromDb.disabled = false;

                if (!rules.rules || rules.count === 0) {
                    btnDeleteFromDb.innerHTML = _dbOrigLabel;
                    if (deleteStatus) { deleteStatus.textContent = `No saved delete rules for "${layer}"`; deleteStatus.classList.remove('hidden'); setTimeout(() => deleteStatus.classList.add('hidden'), 3000); }
                    return;
                }

                // Build ruleSet + parse signatures for highlighting
                const ruleSet = new Set();
                const signatures = [];
                const sigKeys = new Set();
                for (const r of rules.rules) {
                    const line = String(r.elementLine || '').trim();
                    if (!line) continue;
                    ruleSet.add(line);
                    const sig = _parseSvgElementSignature(line);
                    if (sig) {
                        const key = [
                            sig.tag, sig.shapeKind, sig.stroke, sig.fill,
                            sig.strokeLinecap, sig.strokeLinejoin,
                            Number.isFinite(sig.strokeWidthNum) ? sig.strokeWidthNum.toFixed(1) : sig.strokeWidth,
                            sig.geomWidth > 0 ? Math.round(sig.geomWidth * 4) / 4 : '',
                            sig.geomHeight > 0 ? Math.round(sig.geomHeight * 4) / 4 : '',
                            sig.pathLength > 0 ? Math.round(sig.pathLength) : '',
                            sig.segCount || ''
                        ].join('|');
                        if (!sigKeys.has(key)) { sigKeys.add(key); signatures.push(sig); }
                    }
                }

                // Count matches in full SVG using signature-based matching
                // (same approach as Delete Similar – finds ALL elements with the
                //  same shape/color/stroke, not just exact coordinate duplicates)
                const r = (idx >= 0 && pageResults[idx]) ? pageResults[idx] : null;
                let fullCount = 0;
                if (r && r.svgContent) {
                    const src = String(r.svgContent).replace(/>\s*</g, '>\n<');
                    const srcLines = src.split('\n');
                    for (const sl of srcLines) {
                        const slSig = _parseSvgElementSignature(sl);
                        if (slSig && signatures.some(sig => _signaturesMatch(sig, slSig))) fullCount++;
                    }
                } else {
                    fullCount = _countMatchingSignatureLines((textarea.value || '').split('\n'), signatures).length;
                }

                if (fullCount === 0) {
                    btnDeleteFromDb.innerHTML = _dbOrigLabel;
                    if (deleteStatus) { deleteStatus.textContent = `${rules.count} rules loaded, but 0 matches in current SVG`; deleteStatus.classList.remove('hidden'); setTimeout(() => deleteStatus.classList.add('hidden'), 3500); }
                    return;
                }

                // Highlight matching elements in the SVG preview
                const highlightedCount = _highlightDbDeleteInPreview(signatures);

                // Store state for step 2
                _dbDeletePreviewRuleSet = ruleSet;
                _dbDeletePreviewSignatures = signatures;
                _dbDeletePreviewCount = fullCount;

                // Update button to confirm state
                btnDeleteFromDb.classList.add('similar-preview-active');
                btnDeleteFromDb.innerHTML = `<i class="fa-solid fa-check-double"></i> Confirm Delete (${fullCount})`;

                // Show status
                if (deleteStatus) {
                    deleteStatus.textContent = `\u{1F534} ${fullCount} DB-rule match(es) highlighted in red \u2013 click "Confirm Delete" to remove`;
                    deleteStatus.classList.remove('hidden');
                }
            });

            // Cancel DB-delete preview when clicking other action buttons
            const dbCancelBtns = [
                document.getElementById('btnSvgCodeClose'),
                document.getElementById('btnSvgCodeDelete'),
                document.getElementById('btnSvgCodeDeleteAll'),
                document.getElementById('btnSvgCodeDeleteSimilar'),
                document.getElementById('btnSvgCodeRefresh'),
            ].filter(Boolean);
            for (const cb of dbCancelBtns) {
                cb.addEventListener('click', () => { if (_dbDeletePreviewRuleSet) _clearDbDeletePreview(); }, true);
            }
            document.addEventListener('keydown', (e) => {
                if (e.key === 'Escape' && _dbDeletePreviewRuleSet) _clearDbDeletePreview();
            });
        }
    })();

    // ── Draggable SVG Preview window (drag the header) ──
    (function setupPreviewDrag() {
        const win = document.getElementById('svgPreviewWindow');
        const header = document.getElementById('svgPreviewHeader');
        if (!win || !header) return;

        let drag = null;
        let offsetX = 0;
        let offsetY = 0;

        const apply = () => {
            win.style.transform = `translate(${offsetX}px, ${offsetY}px)`;
        };

        header.addEventListener('pointerdown', (e) => {
            // Don't drag when interacting with controls
            if (e.target && (e.target.closest('button') || e.target.closest('a') || e.target.closest('input') || e.target.closest('select') || e.target.closest('.svg-ai-picker'))) return;
            drag = { startX: e.clientX, startY: e.clientY, origX: offsetX, origY: offsetY, pointerId: e.pointerId };
            try { header.setPointerCapture(e.pointerId); } catch { /* ignore */ }
            e.preventDefault();
        });

        header.addEventListener('pointermove', (e) => {
            if (!drag || e.pointerId !== drag.pointerId) return;
            offsetX = drag.origX + (e.clientX - drag.startX);
            offsetY = drag.origY + (e.clientY - drag.startY);
            apply();
        });

        const end = (e) => {
            if (!drag || e.pointerId !== drag.pointerId) return;
            drag = null;
            try { header.releasePointerCapture(e.pointerId); } catch { /* ignore */ }
        };
        header.addEventListener('pointerup', end);
        header.addEventListener('pointercancel', end);

        // Reset position when closing
        const oldClose = window.closeSvgPreview;
        window.closeSvgPreview = function () {
            offsetX = 0; offsetY = 0;
            win.style.transform = '';
            return oldClose();
        };
    })();

    // ── Helpers ──
    const _thumbObjectUrls = new Set();

    function svgToDataUrl(svgText) {
        return 'data:image/svg+xml;charset=utf-8,' + encodeURIComponent(svgText);
    }

    function svgToObjectUrl(svgText) {
        const blob = new Blob([svgText], { type: 'image/svg+xml' });
        const url = URL.createObjectURL(blob);
        _thumbObjectUrls.add(url);
        return url;
    }

    /**
     * Auto-crop an SVG to a tight bounding box around its visible content.
     * Useful for layers with many tiny scattered elements (e.g. "Small signs")
     * that are invisible at full-page viewBox scale.
     * Adds a dark background rect so light/gray strokes become visible.
     */
    function _autoCropSvgForThumbnail(svgText) {
        try {
            const src = (svgText || '').toString();
            if (!src) return src;
            const parser = new DOMParser();
            const doc = parser.parseFromString(src, 'image/svg+xml');
            const svgRoot = doc.querySelector('svg');
            if (!svgRoot) return src;

            const shapeEls = svgRoot.querySelectorAll('path, rect, circle, ellipse, line, polyline, polygon');
            if (shapeEls.length === 0) return src;

            let minX = Infinity, minY = Infinity, maxX = -Infinity, maxY = -Infinity;
            let validCount = 0;
            for (const el of shapeEls) {
                const bb = _estimateSvgElementBoundsFast(el, { skipPaths: shapeEls.length > 20000 });
                if (!bb || !isFinite(bb.x) || !isFinite(bb.y) || !isFinite(bb.width) || !isFinite(bb.height)) continue;
                if (bb.width <= 0 && bb.height <= 0) continue;
                minX = Math.min(minX, bb.x);
                minY = Math.min(minY, bb.y);
                maxX = Math.max(maxX, bb.x + bb.width);
                maxY = Math.max(maxY, bb.y + bb.height);
                validCount++;
            }
            if (validCount === 0 || !isFinite(minX) || !isFinite(minY)) return src;

            const contentW = maxX - minX;
            const contentH = maxY - minY;
            if (contentW <= 0 && contentH <= 0) return src;

            // Add 8% padding around the content
            const padX = Math.max(contentW * 0.08, 2);
            const padY = Math.max(contentH * 0.08, 2);
            const vbX = minX - padX;
            const vbY = minY - padY;
            const vbW = contentW + padX * 2;
            const vbH = contentH + padY * 2;

            svgRoot.setAttribute('viewBox', `${vbX} ${vbY} ${vbW} ${vbH}`);
            svgRoot.removeAttribute('width');
            svgRoot.removeAttribute('height');

            // Add a white background so elements are visible on the card
            const bgRect = doc.createElementNS('http://www.w3.org/2000/svg', 'rect');
            bgRect.setAttribute('x', String(vbX));
            bgRect.setAttribute('y', String(vbY));
            bgRect.setAttribute('width', String(vbW));
            bgRect.setAttribute('height', String(vbH));
            bgRect.setAttribute('fill', '#ffffff');
            svgRoot.insertBefore(bgRect, svgRoot.firstChild);

            // Boost visibility: thicken strokes and make them dark/bold for thumbnail
            for (const el of shapeEls) {
                const sw = _getSvgCleanupStrokeWidth(el);
                const minSw = Math.max(vbW, vbH) * 0.005;
                if (sw < minSw) {
                    el.setAttribute('stroke-width', String(minSw));
                }
                // Force all strokes to a visible dark color
                const strokeRaw = _getSvgInheritedStyleValue(el, 'stroke');
                if (strokeRaw) {
                    el.setAttribute('stroke', '#f59e0b');
                }
                const fillRaw = _getSvgInheritedStyleValue(el, 'fill');
                if (fillRaw && fillRaw !== 'none') {
                    el.setAttribute('fill', '#f59e0b');
                }
            }

            return new XMLSerializer().serializeToString(svgRoot);
        } catch {
            return svgText;
        }
    }

    function revokeThumbObjectUrls() {
        for (const u of _thumbObjectUrls) {
            try { URL.revokeObjectURL(u); } catch { /* ignore */ }
        }
        _thumbObjectUrls.clear();
    }

    function downloadFile(name, content, mime) {
        const blob = new Blob([content], { type: mime });
        const url = URL.createObjectURL(blob);
        const a = document.createElement('a');
        a.href = url; a.download = name; a.click();
        URL.revokeObjectURL(url);
    }

    function downloadContent(content, name, mime) {
        const blob = content instanceof Blob ? content : new Blob([content], { type: mime || 'application/octet-stream' });
        const url = URL.createObjectURL(blob);
        const a = document.createElement('a');
        a.href = url;
        a.download = name || 'download';
        a.click();
        URL.revokeObjectURL(url);
    }

    async function dataUrlToBlob(dataUrl) {
        const resp = await fetch(dataUrl);
        return resp.blob();
    }

    function formatBytes(bytes) {
        if (bytes < 1024) return bytes + ' B';
        if (bytes < 1024 * 1024) return (bytes / 1024).toFixed(1) + ' KB';
        return (bytes / (1024 * 1024)).toFixed(1) + ' MB';
    }

    function escHtml(s) {
        const d = document.createElement('div');
        d.textContent = s;
        return d.innerHTML;
    }

    document.addEventListener('visibilitychange', () => {
        if (!document.hidden) refreshResourceUsage();
    });

    // ── SESSION SAVE / LOAD ──
    (function setupSessionSaveLoad() {
        const btnSave   = document.getElementById('btnSessionSave');
        const btnSaveAs = document.getElementById('btnSessionSaveAs');
        const btnLoad   = document.getElementById('btnSessionLoad');
        const sessionNameBadge = document.getElementById('sessionNameBadge');
        const sessionNameLabel = document.getElementById('sessionNameLabel');
        if (!btnSaveAs && !btnLoad) return;

        // ── Active-session state ──
        let _currentSessionId   = null;
        let _currentSessionName = '';

        function _updateSessionUI() {
            const hasSession = !!_currentSessionId;
            if (sessionNameBadge) sessionNameBadge.classList.toggle('hidden', !hasSession);
            if (sessionNameLabel) sessionNameLabel.textContent = _currentSessionName || '—';
            if (btnSave) btnSave.classList.toggle('hidden', !hasSession);
        }

        function _setActiveSession(id, name) {
            _currentSessionId   = id   || null;
            _currentSessionName = name || '';
            _updateSessionUI();
        }

        function _clearActiveSession() {
            _currentSessionId   = null;
            _currentSessionName = '';
            _updateSessionUI();
        }

        // ── Build payload helper ──
        function _buildPayload(customerId, pdfFileName, dpi, provider, sessionName) {
            return {
                customerId,
                pdfFileName,
                dpi,
                provider,
                sessionName: sessionName || pdfFileName.replace(/\.pdf$/i, ''),
                splitMainTab: _splitMainTab || 'svgSplit',
                pageResults: pageResults.map(r => ({
                    pageNumber: r.pageNumber,
                    isLayer: r.isLayer,
                    layerName: r.layerName,
                    layerColor: r.layerColor,
                    layerIcon: r.layerIcon,
                    svgContent: r.svgContent,
                    svgSizeBytes: r.svgSizeBytes,
                    objectCount: r.objectCount,
                    sourceSvgMetrics: r.sourceSvgMetrics || null,
                    movedFromOtherElements: r.movedFromOtherElements || false,
                    sourceOtherLayerIdx: r.sourceOtherLayerIdx,
                    regionIndex: r.regionIndex,
                    isFamilyLayer: r.isFamilyLayer || false,
                    familyId: r.familyId,
                    familyName: r.familyName
                })),
                lastPdfPages: Array.isArray(lastPdfPages) ? lastPdfPages : [],
                lastPdfPageDims: Array.isArray(lastPdfPageDims) ? lastPdfPageDims : [],
                lastPdfPreviewMeta: lastPdfPreviewMeta || null,
                cropSelections: JSON.parse(JSON.stringify(cropSelections || {})),
                outputCrop: outputCrop ? JSON.parse(JSON.stringify(outputCrop)) : null,
                familyScanLogLines: Array.isArray(_familyScanLogLines) ? _familyScanLogLines : [],
                familyScanDetections: Array.isArray(_familyScanDetections) ? _familyScanDetections : [],
                familyScanAnnotatedPages: (Array.isArray(_familyScanAnnotatedPages) ? _familyScanAnnotatedPages : []).map(p => ({
                    pageIndex: p.pageIndex,
                    imageDataUrl: p.imageDataUrl || '',
                    originalImageDataUrl: p.originalImageDataUrl || '',
                    detectionCount: p.detectionCount || 0,
                    renderClientOverlays: p.renderClientOverlays || false
                })),
                familyScanModeLabel: _familyScanModeLabel || '',
                pendingDetectionApprovalChanges: _pendingDetectionApprovalChanges || {},
                lastFamilyLearnModel: _lastFamilyLearnModel || null,
                // ── UI Settings ──
                colorLayerDefs: colorLayerDefs.map(d => ({ label: d.label, enabled: d.enabled, colors: d.colors.map(c => ({ color: c.color, tolerance: c.tolerance })) })),
                hiddenTextLabels: pdfTextHiddenLabelsInput ? pdfTextHiddenLabelsInput.value : (_pdfTextHiddenLabelsRaw || ''),
                textLanguages: _pdfTextSelectedLanguages ? [..._pdfTextSelectedLanguages] : ['english', 'hebrew', 'arabic'],
                smallSignsSizePercent: window._smallSignsSizePercent || 100,
                familyYoloDetectSettings: (typeof _getFamilyYoloDetectSettings === 'function') ? _getFamilyYoloDetectSettings() : null
            };
        }

        // ── Shared form values ──
        function _formValues() {
            const customerId  = clientIdSelect ? clientIdSelect.value : 'admin';
            const pdfFileName = _currentPdfPreviewFile
                ? (_currentPdfPreviewFile.name || 'document.pdf')
                : 'document.pdf';
            const dpi      = dpiInput ? parseInt(dpiInput.value, 10) || 0 : 0;
            const provider = providerSelect ? providerSelect.value : '';
            return { customerId, pdfFileName, dpi, provider };
        }

        // ── SAVE (overwrite current session) ──
        if (btnSave) {
            btnSave.addEventListener('click', async () => {
                if (!_currentSessionId) return;
                if (!pageResults || pageResults.length === 0) {
                    cgAlert('No results to save. Run a PDF conversion first.');
                    return;
                }

                const ok = await cgConfirm(
                    `Overwrite session "${_currentSessionName}"?\nThis will replace the previously saved data.`,
                    'Save Session'
                );
                if (!ok) return;

                const { customerId, pdfFileName, dpi, provider } = _formValues();
                const payload = _buildPayload(customerId, pdfFileName, dpi, provider, _currentSessionName);

                btnSave.disabled = true;
                const origHtml = btnSave.innerHTML;
                btnSave.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Saving...';

                try {
                    const resp = await fetch(PAGE_SESSIONS_ENDPOINT, {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify(payload)
                    });
                    if (!resp.ok) throw new Error(`HTTP ${resp.status}`);
                    const data = await resp.json();
                    const sizeStr = formatBytes(data.compressedSize || 0);
                    cgAlert(`Session saved!\n\nLayers: ${data.layerCount}\nCompressed: ${sizeStr}`, 'Save Complete');
                } catch (e) {
                    console.error('[session-save]', e);
                    cgAlert(`Failed to save session: ${e.message}`, 'Error');
                } finally {
                    btnSave.disabled = false;
                    btnSave.innerHTML = origHtml;
                }
            });
        }

        // ── SAVE AS (new session — shows modal with existing sessions) ──
        if (btnSaveAs) {
            btnSaveAs.addEventListener('click', async () => {
                if (!pageResults || pageResults.length === 0) {
                    cgAlert('No results to save. Run a PDF conversion first.');
                    return;
                }

                const { customerId, pdfFileName, dpi, provider } = _formValues();
                const defaultName = pdfFileName.replace(/\.pdf$/i, '');

                // Fetch existing sessions to show in the save-as picker
                let sessions = [];
                try {
                    const resp = await fetch(`${PAGE_SESSIONS_ENDPOINT}?customerId=${encodeURIComponent(customerId)}`);
                    if (resp.ok) { const d = await resp.json(); sessions = d.sessions || []; }
                } catch { /* proceed without list */ }

                _showSaveAsModal(sessions, defaultName, customerId, pdfFileName, dpi, provider);
            });
        }

        // ── Save-As Modal (new name + existing session list) ──
        async function _showSaveAsModal(sessions, defaultName, customerId, pdfFileName, dpi, provider) {
            document.getElementById('saveAsPickerOverlay')?.remove();

            const overlay = document.createElement('div');
            overlay.id = 'saveAsPickerOverlay';
            overlay.className = 'fixed inset-0 z-[200] flex items-center justify-center bg-black/60 backdrop-blur-sm';

            const card = document.createElement('div');
            card.className = 'bg-slate-900 border border-slate-600/50 rounded-2xl shadow-2xl max-w-xl w-full mx-4 max-h-[80vh] flex flex-col';

            card.innerHTML = `
                <div class="flex items-center justify-between px-5 py-3 border-b border-slate-700/50">
                    <h3 class="text-sm font-semibold text-slate-100 uppercase tracking-wider">
                        <i class="fa-solid fa-file-export text-amber-400 me-2"></i>Save As
                    </h3>
                    <button id="saveAsPickerClose" class="text-slate-400 hover:text-white transition text-lg px-2">
                        <i class="fa-solid fa-xmark"></i>
                    </button>
                </div>
                <!-- New session row -->
                <div class="px-4 pt-3 pb-2 border-b border-slate-700/30">
                    <div class="text-[11px] text-slate-400 mb-1.5 font-semibold uppercase tracking-wider">New session</div>
                    <div class="flex items-center gap-2">
                        <input id="saveAsNewName" type="text" value="${escHtml(defaultName)}"
                               class="flex-1 h-9 rounded-lg border border-slate-500/60 bg-slate-800/40 px-3 text-sm text-slate-100 focus:border-amber-400 focus:ring-amber-400 focus:ring-1 outline-none"
                               placeholder="Session name…" />
                        <button id="saveAsNewBtn"
                                class="inline-flex items-center gap-1 h-9 rounded-lg border border-emerald-500/50 bg-emerald-900/30 hover:bg-emerald-900/50 text-emerald-300 px-3 text-xs font-semibold transition whitespace-nowrap">
                            <i class="fa-solid fa-plus"></i> Save New
                        </button>
                    </div>
                </div>
                <!-- Existing sessions list -->
                <div class="overflow-y-auto flex-1 px-2 py-2" id="saveAsSessionList">
                    ${sessions.length === 0 ? '<div class="text-xs text-slate-500 text-center py-4">No existing sessions</div>' : ''}
                </div>
            `;
            overlay.appendChild(card);
            document.body.appendChild(overlay);

            const close = () => overlay.remove();
            overlay.querySelector('#saveAsPickerClose').addEventListener('click', close);
            overlay.addEventListener('click', (e) => { if (e.target === overlay) close(); });
            document.addEventListener('keydown', function escH(e) {
                if (e.key === 'Escape') { close(); document.removeEventListener('keydown', escH); }
            });

            const nameInput = card.querySelector('#saveAsNewName');
            nameInput.select();

            // Helper: perform the actual save
            async function _doSave(sessionName, triggerBtn, origHtml) {
                const payload = _buildPayload(customerId, pdfFileName, dpi, provider, sessionName);
                triggerBtn.disabled = true;
                triggerBtn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i>';
                try {
                    const resp = await fetch(PAGE_SESSIONS_ENDPOINT, {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify(payload)
                    });
                    if (!resp.ok) throw new Error(`HTTP ${resp.status}`);
                    const data = await resp.json();
                    _setActiveSession(data.id, sessionName);
                    close();
                    const sizeStr = formatBytes(data.compressedSize || 0);
                    cgAlert(`Session saved!\n\nLayers: ${data.layerCount}\nCompressed: ${sizeStr}\n${data.updated ? '(Updated existing)' : '(New session)'}`, 'Save Complete');
                } catch (e) {
                    console.error('[save-as]', e);
                    cgAlert(`Failed to save: ${e.message}`, 'Error');
                    triggerBtn.disabled = false;
                    triggerBtn.innerHTML = origHtml;
                }
            }

            // ── Save New button ──
            const saveNewBtn = card.querySelector('#saveAsNewBtn');
            const saveNewOrigHtml = saveNewBtn.innerHTML;
            saveNewBtn.addEventListener('click', () => {
                const name = nameInput.value.trim() || defaultName;
                _doSave(name, saveNewBtn, saveNewOrigHtml);
            });
            nameInput.addEventListener('keydown', (e) => {
                if (e.key === 'Enter') saveNewBtn.click();
            });

            // ── Existing sessions list ──
            const listEl = card.querySelector('#saveAsSessionList');
            for (const s of sessions) {
                const row = document.createElement('div');
                row.className = 'flex items-center gap-3 px-3 py-2 rounded-xl hover:bg-slate-700/50 transition';
                const dateStr = new Date(s.updatedAtUtc || s.createdAtUtc).toLocaleString();
                const sizeStr = formatBytes(s.compressedSize || 0);
                row.innerHTML = `
                    <div class="flex-1 min-w-0">
                        <div class="text-sm font-semibold text-slate-100 truncate">${escHtml(s.sessionName || s.pdfFileName || 'Untitled')}</div>
                        <div class="text-[11px] text-slate-400 mt-0.5">
                            <span class="me-3"><i class="fa-solid fa-layer-group me-1"></i>${s.layerCount} layers</span>
                            <span class="me-3"><i class="fa-solid fa-hard-drive me-1"></i>${sizeStr}</span>
                            <span class="me-3"><i class="fa-solid fa-expand me-1"></i>${s.dpi || '?'} DPI</span>
                        </div>
                        <div class="text-[10px] text-slate-500 mt-0.5">${dateStr}</div>
                    </div>
                    <button class="saveas-overwrite-btn inline-flex items-center gap-1 rounded-lg border border-orange-500/50 bg-orange-900/30 hover:bg-orange-900/50 text-orange-300 px-3 py-1.5 text-xs font-semibold transition whitespace-nowrap"
                            data-id="${s.id}" data-name="${escHtml(s.sessionName || s.pdfFileName || 'Untitled')}" title="Overwrite this session">
                        <i class="fa-solid fa-rotate"></i> Overwrite
                    </button>
                `;
                listEl.appendChild(row);
            }

            // Overwrite handlers
            listEl.querySelectorAll('.saveas-overwrite-btn').forEach(btn => {
                const origH = btn.innerHTML;
                btn.addEventListener('click', async (e) => {
                    e.stopPropagation();
                    const name = btn.dataset.name;
                    const ok = await cgConfirm(`Overwrite session "${name}"?\nThis will replace the previously saved data.`, 'Overwrite Session');
                    if (!ok) return;
                    _doSave(name, btn, origH);
                });
            });
        }

        // ── LOAD ──
        if (btnLoad) {
            btnLoad.addEventListener('click', async () => {
                const customerId = clientIdSelect ? clientIdSelect.value : 'admin';

                btnLoad.disabled = true;
                const origHtml = btnLoad.innerHTML;
                btnLoad.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Loading...';

                let sessions;
                try {
                    const resp = await fetch(`${PAGE_SESSIONS_ENDPOINT}?customerId=${encodeURIComponent(customerId)}`);
                    if (!resp.ok) throw new Error(`HTTP ${resp.status}`);
                    const data = await resp.json();
                    sessions = data.sessions || [];
                } catch (e) {
                    console.error('[session-load]', e);
                    cgAlert(`Failed to load sessions: ${e.message}`, 'Error');
                    btnLoad.disabled = false;
                    btnLoad.innerHTML = origHtml;
                    return;
                }

                btnLoad.disabled = false;
                btnLoad.innerHTML = origHtml;

                if (sessions.length === 0) {
                    cgAlert('No saved sessions found for this customer.', 'Load Session');
                    return;
                }

                // Build a modal to pick a session
                _showSessionPickerModal(sessions);
            });
        }

        function _showSessionPickerModal(sessions) {
            // Remove any existing picker
            document.getElementById('sessionPickerOverlay')?.remove();

            const overlay = document.createElement('div');
            overlay.id = 'sessionPickerOverlay';
            overlay.className = 'fixed inset-0 z-[200] flex items-center justify-center bg-black/60 backdrop-blur-sm';

            const card = document.createElement('div');
            card.className = 'bg-slate-900 border border-slate-600/50 rounded-2xl shadow-2xl max-w-xl w-full mx-4 max-h-[80vh] flex flex-col';

            // Header
            card.innerHTML = `
                <div class="flex items-center justify-between px-5 py-3 border-b border-slate-700/50">
                    <h3 class="text-sm font-semibold text-slate-100 uppercase tracking-wider">
                        <i class="fa-solid fa-folder-open text-sky-400 me-2"></i>Load Session
                    </h3>
                    <button id="sessionPickerClose" class="text-slate-400 hover:text-white transition text-lg px-2">
                        <i class="fa-solid fa-xmark"></i>
                    </button>
                </div>
                <div class="overflow-y-auto flex-1 px-2 py-2" id="sessionPickerList"></div>
            `;
            overlay.appendChild(card);
            document.body.appendChild(overlay);

            const listEl = card.querySelector('#sessionPickerList');

            for (const s of sessions) {
                const row = document.createElement('div');
                row.className = 'flex items-center gap-3 px-3 py-2.5 rounded-xl hover:bg-slate-700/50 cursor-pointer transition group';
                const dateStr = new Date(s.updatedAtUtc || s.createdAtUtc).toLocaleString();
                const sizeStr = formatBytes(s.compressedSize || 0);
                const uncompStr = formatBytes(s.uncompressedSize || 0);
                row.innerHTML = `
                    <div class="flex-1 min-w-0">
                        <div class="session-name-label text-sm font-semibold text-slate-100 truncate">${escHtml(s.sessionName || s.pdfFileName || 'Untitled')}</div>
                        <div class="text-[11px] text-slate-400 mt-0.5">
                            <span class="me-3"><i class="fa-solid fa-layer-group me-1"></i>${s.layerCount} layers</span>
                            <span class="me-3"><i class="fa-solid fa-hard-drive me-1"></i>${sizeStr} (${uncompStr})</span>
                            <span class="me-3"><i class="fa-solid fa-expand me-1"></i>${s.dpi || '?'} DPI</span>
                        </div>
                        <div class="text-[10px] text-slate-500 mt-0.5">${escHtml(s.pdfFileName || '')} — ${dateStr}</div>
                    </div>
                    <button class="session-edit-btn inline-flex items-center gap-1 rounded-lg border border-amber-500/50 bg-amber-900/30 hover:bg-amber-900/50 text-amber-300 px-2 py-1 text-[10px] transition"
                            data-id="${s.id}" data-name="${escHtml(s.sessionName || s.pdfFileName || 'Untitled')}" title="Rename this session">
                        <i class="fa-solid fa-pen"></i>
                    </button>
                    <button class="session-delete-btn inline-flex items-center gap-1 rounded-lg border border-rose-500/50 bg-rose-900/30 hover:bg-rose-900/50 text-rose-300 px-2 py-1 text-[10px] transition"
                            data-id="${s.id}" title="Delete this session">
                        <i class="fa-solid fa-trash-can"></i>
                    </button>
                    <button class="session-load-btn inline-flex items-center gap-1 rounded-lg border border-sky-500/50 bg-sky-900/30 hover:bg-sky-900/50 text-sky-300 px-3 py-1.5 text-xs font-semibold transition"
                            data-id="${s.id}" data-name="${escHtml(s.sessionName || s.pdfFileName || 'Untitled')}" title="Load this session">
                        <i class="fa-solid fa-download"></i> Load
                    </button>
                    </div>
                `;
                listEl.appendChild(row);
            }

            // Close handlers
            const close = () => overlay.remove();
            overlay.querySelector('#sessionPickerClose').addEventListener('click', close);
            overlay.addEventListener('click', (e) => { if (e.target === overlay) close(); });
            document.addEventListener('keydown', function escHandler(e) {
                if (e.key === 'Escape') { close(); document.removeEventListener('keydown', escHandler); }
            });

            // Delete handlers
            listEl.querySelectorAll('.session-delete-btn').forEach(btn => {
                btn.addEventListener('click', async (e) => {
                    e.stopPropagation();
                    const id = btn.dataset.id;
                    const ok = await cgConfirm('Delete this saved session?', 'Delete Session');
                    if (!ok) return;
                    try {
                        const resp = await fetch(`${PAGE_SESSIONS_ENDPOINT}/${id}`, { method: 'DELETE' });
                        if (!resp.ok) throw new Error(`HTTP ${resp.status}`);
                        btn.closest('[class*="flex items-center gap-3"]')?.remove();
                        // If the deleted session was the active one, clear it
                        if (String(_currentSessionId) === String(id)) _clearActiveSession();
                        if (!listEl.children.length) { close(); cgAlert('No more sessions.', 'Load Session'); }
                    } catch (ex) {
                        cgAlert(`Failed to delete: ${ex.message}`, 'Error');
                    }
                });
            });

            // Edit (rename) handlers
            listEl.querySelectorAll('.session-edit-btn').forEach(btn => {
                btn.addEventListener('click', async (e) => {
                    e.stopPropagation();
                    const id = btn.dataset.id;
                    const currentName = btn.dataset.name || '';
                    const newName = await cgPrompt('Session name:', currentName, 'Rename Session');
                    if (newName === null || newName.trim() === currentName.trim()) return;
                    try {
                        const resp = await fetch(`${PAGE_SESSIONS_ENDPOINT}/${id}`, {
                            method: 'PATCH',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({ sessionName: newName.trim() })
                        });
                        if (!resp.ok) throw new Error(`HTTP ${resp.status}`);
                        // Update the label in-place
                        btn.dataset.name = newName.trim();
                        const row = btn.closest('[class*="flex items-center gap-3"]');
                        if (row) {
                            const label = row.querySelector('.session-name-label');
                            if (label) label.textContent = newName.trim() || 'Untitled';
                        }
                    } catch (ex) {
                        cgAlert(`Failed to rename: ${ex.message}`, 'Error');
                    }
                });
            });

            // Load handlers
            listEl.querySelectorAll('.session-load-btn').forEach(btn => {
                btn.addEventListener('click', async (e) => {
                    e.stopPropagation();
                    const id = btn.dataset.id;
                    const name = btn.dataset.name || '';
                    btn.disabled = true;
                    btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i>';

                    try {
                        const resp = await fetch(`${PAGE_SESSIONS_ENDPOINT}/${id}`);
                        if (!resp.ok) throw new Error(`HTTP ${resp.status}`);
                        const data = await resp.json();
                        close();
                        await _restoreSession(data);

                        // Mark this as the active session
                        _setActiveSession(data.id || id, data.sessionName || name);
                    } catch (ex) {
                        console.error('[session-load]', ex);
                        cgAlert(`Failed to load session: ${ex.message}`, 'Error');
                        btn.disabled = false;
                        btn.innerHTML = '<i class="fa-solid fa-download"></i> Load';
                    }
                });
            });
        }

        async function _restoreSession(data) {
            // Set form fields
            if (dpiInput && data.dpi) dpiInput.value = data.dpi;
            if (providerSelect && data.provider) {
                for (let i = 0; i < providerSelect.options.length; i++) {
                    if (providerSelect.options[i].value === data.provider) {
                        providerSelect.selectedIndex = i;
                        break;
                    }
                }
            }

            // Clear existing results
            pageResults.length = 0;
            if (resultsGrid) resultsGrid.innerHTML = '';
            if (movedOtherElementsGrid) movedOtherElementsGrid.innerHTML = '';
            if (resultsSummary) resultsSummary.textContent = '';

            // ═══════════════════════════════════════════════
            // 1. Restore pageResults (SVG Split tab)
            // ═══════════════════════════════════════════════
            const results = Array.isArray(data.pageResults) ? data.pageResults : [];
            for (const r of results) {
                pageResults.push({
                    pageNumber: r.pageNumber || 1,
                    isLayer: r.isLayer !== false,
                    layerName: r.layerName || '',
                    layerColor: r.layerColor || '',
                    layerIcon: r.layerIcon || '',
                    svgContent: r.svgContent || '',
                    svgSizeBytes: r.svgSizeBytes || 0,
                    objectCount: r.objectCount || 0,
                    sourceSvgMetrics: r.sourceSvgMetrics || null,
                    movedFromOtherElements: r.movedFromOtherElements || false,
                    sourceOtherLayerIdx: r.sourceOtherLayerIdx,
                    regionIndex: r.regionIndex,
                    isFamilyLayer: r.isFamilyLayer || false,
                    familyId: r.familyId,
                    familyName: r.familyName
                });
            }

            // Rebuild result cards
            if (resultsSection) resultsSection.classList.remove('hidden');
            for (let i = 0; i < pageResults.length; i++) {
                addResultCard(i);
            }

            try { _renderWallResultsTab(); } catch { /* ignore */ }
            try { _renderMovedOtherElementsSection(); } catch { /* ignore */ }

            // ═══════════════════════════════════════════════
            // 2. Restore PDF Preview tab
            // ═══════════════════════════════════════════════
            try {
                const savedPages = Array.isArray(data.lastPdfPages) ? data.lastPdfPages : [];
                if (savedPages.length) {
                    lastPdfPages = savedPages;
                    lastPdfPageDims = Array.isArray(data.lastPdfPageDims) ? data.lastPdfPageDims : [];
                    lastPdfPreviewMeta = data.lastPdfPreviewMeta || null;
                    if (btnOpenPdfSizeDrawer) btnOpenPdfSizeDrawer.disabled = lastPdfPageDims.length === 0;
                    try { renderPdfSizePanel(); } catch { /* ignore */ }
                    try { renderPdfSizeInfoCard(); } catch { /* ignore */ }
                    if (pdfPages) {
                        pdfPages.innerHTML = '';
                        try { updateCropClearBtn(); } catch { /* ignore */ }
                        const totalPages = lastPdfPages.length;
                        let loadedCount = 0;
                        // Restore crop state BEFORE building DOM so drawAllRegions can see it
                        if (data.cropSelections && typeof data.cropSelections === 'object') {
                            cropSelections = JSON.parse(JSON.stringify(data.cropSelections));
                            // Restore _regionIdSeq to be above any existing region id
                            for (const key of Object.keys(cropSelections)) {
                                const arr = cropSelections[key];
                                if (Array.isArray(arr)) {
                                    for (const r of arr) {
                                        if (r && r.id && r.id >= _regionIdSeq) _regionIdSeq = r.id + 1;
                                    }
                                }
                            }
                        }
                        if (data.outputCrop) {
                            outputCrop = JSON.parse(JSON.stringify(data.outputCrop));
                        }

                        const _onAllPagesLoaded = () => {
                            try {
                                const canMeasure = _canMeasurePdfViewport();
                                const fitZ = canMeasure ? Math.max(0.0001, _fitZoomWidth()) : 1;
                                _setPdfBaseViewZoom(fitZ);
                                if (canMeasure) {
                                    setPdfZoom(fitZ, { resetScroll: true });
                                    _pendingPdfInitialFit = false;
                                } else {
                                    setPdfZoom(1, { resetScroll: true });
                                    _pendingPdfInitialFit = true;
                                }
                            } catch { /* ignore */ }
                            // Redraw crop regions on all page canvases
                            try {
                                if (pdfPages) {
                                    for (const wrap of pdfPages.querySelectorAll('.pdf-page-wrap')) {
                                        const pi = parseInt(wrap.dataset.pageIndex, 10);
                                        const cvs = wrap.querySelector('.crop-overlay');
                                        if (cvs && !isNaN(pi)) drawAllRegions(cvs, pi);
                                    }
                                }
                                updateCropClearBtn();
                            } catch { /* ignore */ }
                        };

                        for (let pi = 0; pi < lastPdfPages.length; pi++) {
                            const src = lastPdfPages[pi];
                            const wrap = document.createElement('div');
                            wrap.className = 'pdf-page-wrap';
                            wrap.dataset.pageIndex = pi;

                            const shell = document.createElement('div');
                            shell.className = 'pdf-page-shell';

                            const world = document.createElement('div');
                            world.className = 'pdf-page-world';

                            const img = document.createElement('img');
                            img.alt = 'PDF page ' + (pi + 1);
                            img.className = 'block max-w-none';
                            img.draggable = false;
                            img._baseW = 0;
                            img._baseH = 0;
                            img._viewW = 0;
                            img._viewH = 0;

                            const cvs = document.createElement('canvas');
                            cvs.className = 'crop-overlay';
                            cvs.dataset.pageIndex = pi;

                            const markCvs = document.createElement('canvas');
                            markCvs.className = 'pdf-mark-canvas';
                            markCvs.dataset.pageIndex = pi;
                            markCvs.style.cssText = 'position:absolute;top:0;left:0;pointer-events:none;z-index:20;';

                            const onImgLoad = () => {
                                img._baseW = img.naturalWidth;
                                img._baseH = img.naturalHeight;
                                cvs.width  = img.naturalWidth;
                                cvs.height = img.naturalHeight;
                                markCvs.width  = img.naturalWidth;
                                markCvs.height = img.naturalHeight;
                                loadedCount++;
                                if (loadedCount === totalPages) _onAllPagesLoaded();
                            };
                            img.addEventListener('load', onImgLoad, { once: true });
                            img.addEventListener('error', () => { loadedCount++; if (loadedCount === totalPages) _onAllPagesLoaded(); }, { once: true });

                            img.src = src;

                            world.appendChild(img);
                            world.appendChild(cvs);
                            world.appendChild(markCvs);
                            shell.appendChild(world);
                            wrap.appendChild(shell);
                            pdfPages.appendChild(wrap);
                            try { setupCropHandlers(cvs, pi); } catch { /* ignore */ }
                        }
                        if (totalPages === 0) _onAllPagesLoaded();
                    }
                    if (pdfPreviewCard) {
                        pdfPreviewCard.classList.remove('hidden');
                        pdfPreviewCard.hidden = false;
                    }
                }
            } catch (e) {
                console.warn('[session-restore] PDF preview:', e);
            }

            // ═══════════════════════════════════════════════
            // 3. Restore Scan log
            // ═══════════════════════════════════════════════
            try {
                if (Array.isArray(data.familyScanLogLines) && data.familyScanLogLines.length) {
                    _familyScanLogLines = data.familyScanLogLines.slice();
                }
            } catch { /* ignore */ }

            // ═══════════════════════════════════════════════
            // 4. Restore Family detections & annotated pages
            // ═══════════════════════════════════════════════
            try {
                if (Array.isArray(data.familyScanDetections) && data.familyScanDetections.length) {
                    _familyScanDetections = data.familyScanDetections.slice();
                }
                if (Array.isArray(data.familyScanAnnotatedPages) && data.familyScanAnnotatedPages.length) {
                    _familyScanAnnotatedPages = data.familyScanAnnotatedPages.slice();
                }
                if (data.familyScanModeLabel) {
                    _familyScanModeLabel = String(data.familyScanModeLabel);
                }
                if (data.pendingDetectionApprovalChanges && typeof data.pendingDetectionApprovalChanges === 'object') {
                    _pendingDetectionApprovalChanges = { ...data.pendingDetectionApprovalChanges };
                }
            } catch { /* ignore */ }

            // ═══════════════════════════════════════════════
            // 5. Re-render Family learn panel (covers Family Samples,
            //    YOLO memory, Scan log, Annotated Pages sub-tabs)
            // ═══════════════════════════════════════════════
            try {
                const model = data.lastFamilyLearnModel || _lastFamilyLearnModel;
                if (model) {
                    _renderFamilyLearnPanel(model);
                    openFamilyLearnPanel();
                }
            } catch { /* ignore */ }

            // ═══════════════════════════════════════════════
            // 6. Restore UI Settings
            // ═══════════════════════════════════════════════
            try {
                // Color layer definitions
                if (Array.isArray(data.colorLayerDefs) && data.colorLayerDefs.length > 0) {
                    colorLayerDefs = [];
                    _colorIdSeq = 0;
                    for (const d of data.colorLayerDefs) {
                        const id = ++_colorIdSeq;
                        colorLayerDefs.push({
                            id,
                            label: d.label || '',
                            enabled: d.enabled !== false,
                            colors: Array.isArray(d.colors) ? d.colors.map(c => ({ color: c.color || '#ff0000', tolerance: c.tolerance ?? 60 })) : [{ color: '#ff0000', tolerance: 60 }]
                        });
                    }
                    try { renderLayerCards(); } catch { /* ignore */ }
                }
            } catch { /* ignore */ }
            try {
                // Hidden text labels
                if (typeof data.hiddenTextLabels === 'string') {
                    _pdfTextHiddenLabelsRaw = data.hiddenTextLabels;
                    if (pdfTextHiddenLabelsInput) pdfTextHiddenLabelsInput.value = data.hiddenTextLabels;
                    try { localStorage.setItem(_pdfTextHiddenLabelsStorageKey, data.hiddenTextLabels); } catch { /* ignore */ }
                    try { _renderPdfTextHiddenLabelsUi(); } catch { /* ignore */ }
                }
            } catch { /* ignore */ }
            try {
                // Language selection
                if (Array.isArray(data.textLanguages)) {
                    _pdfTextSelectedLanguages = data.textLanguages.slice();
                    try { localStorage.setItem(_pdfTextLanguageStorageKey, JSON.stringify(_pdfTextSelectedLanguages)); } catch { /* ignore */ }
                    // Update checkboxes
                    const langMap = { english: 'pdfTextLangEnglish', hebrew: 'pdfTextLangHebrew', arabic: 'pdfTextLangArabic' };
                    for (const [lang, elId] of Object.entries(langMap)) {
                        const cb = document.getElementById(elId);
                        if (cb) cb.checked = _pdfTextSelectedLanguages.includes(lang);
                    }
                    try { _renderPdfTextHiddenLabelsUi(); } catch { /* ignore */ }
                }
            } catch { /* ignore */ }
            try {
                // Small signs size
                if (typeof data.smallSignsSizePercent === 'number') {
                    window._smallSignsSizePercent = data.smallSignsSizePercent;
                    _smallSignsSizePercent = data.smallSignsSizePercent;
                    const sl = document.getElementById('smallSignsSizeSlider');
                    if (sl) sl.value = String(data.smallSignsSizePercent);
                    const lbl = document.getElementById('smallSignsSizeLabel');
                    if (lbl) lbl.textContent = data.smallSignsSizePercent + '%';
                    try { localStorage.setItem('pdfToSvgSplit.smallSignsSize.v1', String(data.smallSignsSizePercent)); } catch { /* ignore */ }
                }
            } catch { /* ignore */ }
            try {
                // YOLO detect settings
                if (data.familyYoloDetectSettings && typeof data.familyYoloDetectSettings === 'object') {
                    _familyYoloDetectSettings = data.familyYoloDetectSettings;
                    try { localStorage.setItem(_familyYoloDetectSettingsStorageKey, JSON.stringify(data.familyYoloDetectSettings)); } catch { /* ignore */ }
                }
            } catch { /* ignore */ }

            // ═══════════════════════════════════════════════
            // 7. Switch to the saved tab
            // ═══════════════════════════════════════════════
            try {
                const tab = _requestedSplitMainTab || data.splitMainTab || 'svgSplit';
                setSplitMainTab(tab);
            } catch { /* ignore */ }
        }
    })();

    _applySplitMainTab();
    startResourceUsagePolling();
})();
</script>
}

@functions {
    static string FormatBytes(int bytes)
    {
        if (bytes < 1024) return $"{bytes} B";
        if (bytes < 1024 * 1024) return $"{bytes / 1024.0:F1} KB";
        return $"{bytes / (1024.0 * 1024.0):F1} MB";
    }
}
