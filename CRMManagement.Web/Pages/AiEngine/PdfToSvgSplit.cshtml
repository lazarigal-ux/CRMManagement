    function _debugAnnotatedDetectionMenu(eventName, details, writeToScanLog) {
        try {
            const payload = details && typeof details === 'object' ? details : {};
            const text = `[YOLO menu] ${eventName}`;
            try { console.log(text, payload); } catch { /* ignore */ }
            if (writeToScanLog) {
                const suffix = Object.keys(payload).length ? ` ${JSON.stringify(payload)}` : '';
                try { _appendFamilyScanLog(`${text}${suffix}`); } catch { /* ignore */ }
            }
        } catch { /* ignore */ }
    }

    function _findAnnotatedDetectionHit(pi, clientX, clientY) {
        try {
            const container = document.getElementById(`annotatedPageContainer_${pi}`);
            if (!container) return null;
            const rect = container.getBoundingClientRect();
            const scaleX = rect.width > 0 ? (container.clientWidth / rect.width) : 1;
            const scaleY = rect.height > 0 ? (container.clientHeight / rect.height) : 1;
            const localX = (clientX - rect.left) * scaleX + container.scrollLeft;
            const localY = (clientY - rect.top) * scaleY + container.scrollTop;
            const hits = _getAnnotatedDetectionBoxes(pi).filter(box => localX >= box.dx && localX <= (box.dx + box.dw) && localY >= box.dy && localY <= (box.dy + box.dh));
            if (!hits.length) return null;
            hits.sort((a, b) => (a.dw * a.dh) - (b.dw * b.dh));
            return hits[0];
        } catch {
            return null;
        }
    }

