    function _buildFamilyTypeSymbolSvg(symbolKey, size = 18, extraClasses = '') {
        const px = Number.isFinite(Number(size)) ? Math.max(12, Number(size)) : 18;
        const shapes = _getFamilyTypeSymbolShapesMarkup(symbolKey);
        return `<svg viewBox="0 0 24 24" width="${px}" height="${px}" class="family-type-icon-svg ${extraClasses}" aria-hidden="true">${shapes}</svg>`;
    }

    function _injectFamilyMapBadgeSvg(svgText, familyTypeKey, familyName, symbolKey) {
        // Badge removed – no icon / family-name overlay needed
        return String(svgText || '');
        const src = String(svgText || '');
        if (!src || !src.includes('<svg')) return src;
        try {
            const parser = new DOMParser();
            const doc = parser.parseFromString(src, 'image/svg+xml');
            const svg = doc.querySelector('svg');
            if (!svg) return src;

            const meta = _getFamilyTypeMeta(familyTypeKey, familyName);
            const activeSymbolKey = _getFamilySymbolKey(meta.key, familyName, symbolKey);
            const vb = _parseViewBoxStr(svg.getAttribute('viewBox') || '') || (() => {
                const w = parseFloat(svg.getAttribute('width') || '0');
                const h = parseFloat(svg.getAttribute('height') || '0');
                return (Number.isFinite(w) && Number.isFinite(h) && w > 0 && h > 0) ? { x: 0, y: 0, w, h } : null;
            })();
            if (!vb) return src;

            try { svg.querySelectorAll('[data-family-map-badge="1"]').forEach(el => el.remove()); } catch { }

            const badgeSize = Math.max(Math.min(vb.w, vb.h) * 0.11, 34);
            const padding = Math.max(badgeSize * 0.22, 10);
            const symbolSize = badgeSize * 0.62;
            const label = String(familyName || meta.label || 'Family').trim();
            const fontSize = Math.max(badgeSize * 0.17, 7.5);
            const labelWidth = Math.max(Math.min(label.length * fontSize * 0.56, vb.w * 0.28), badgeSize * 1.2);
            const totalWidth = badgeSize + 8 + labelWidth;
            const symbolShapes = _getFamilyTypeSymbolShapesMarkup(activeSymbolKey);

            const group = doc.createElementNS('http://www.w3.org/2000/svg', 'g');
            group.setAttribute('data-family-map-badge', '1');
            group.setAttribute('transform', `translate(${(vb.x + padding).toFixed(3)} ${(vb.y + padding).toFixed(3)})`);
            group.setAttribute('pointer-events', 'none');
            group.innerHTML = `
                <rect x="0" y="0" width="${totalWidth.toFixed(3)}" height="${badgeSize.toFixed(3)}" rx="${(badgeSize * 0.24).toFixed(3)}" fill="rgba(255,255,255,0.92)" stroke="#475569" stroke-width="${Math.max(badgeSize * 0.02, 1).toFixed(3)}"/>
                <rect x="0" y="0" width="${badgeSize.toFixed(3)}" height="${badgeSize.toFixed(3)}" rx="${(badgeSize * 0.24).toFixed(3)}" fill="rgba(226,232,240,0.96)" stroke="#334155" stroke-width="${Math.max(badgeSize * 0.022, 1).toFixed(3)}"/>
                <g transform="translate(${(badgeSize / 2 - symbolSize / 2).toFixed(3)} ${(badgeSize / 2 - symbolSize / 2).toFixed(3)}) scale(${(symbolSize / 24).toFixed(5)})" style="color:#111827">${symbolShapes}</g>
                <text x="${(badgeSize + 6).toFixed(3)}" y="${(badgeSize / 2 + fontSize * 0.18).toFixed(3)}" fill="#111827" font-size="${fontSize.toFixed(3)}" font-weight="700" font-family="Inter, Arial, sans-serif">${escapeHtml(label)}</text>`;
            svg.appendChild(group);
            return new XMLSerializer().serializeToString(svg);
        } catch {
            return src;
        }
    }

    function _buildFamilyTypeSymbolStripHtml(typeKey, familyName, symbolKey = '') {
        const meta = _getFamilyTypeMeta(typeKey, familyName);
        const items = Array.isArray(meta.familySymbols) && meta.familySymbols.length ? meta.familySymbols : [meta.primarySymbol || 'generic'];
        const active = _normalizeFamilySymbolKeyForMeta(meta, symbolKey);
        return `<div class="family-type-symbol-strip">${items.map(symbol => `<span class="family-type-symbol-mini ${symbol === active ? 'ring-1 ring-sky-400/40' : ''}">${_buildFamilyTypeSymbolSvg(symbol, 17)}</span>`).join('')}</div>`;
    }

    function _buildFamilyTypeBadgeHtml(typeKey, familyName, extraClasses = '', symbolKey = '') {
        const meta = _getFamilyTypeMeta(typeKey, familyName);
        const selectedSymbolKey = _normalizeFamilySymbolKeyForMeta(meta, symbolKey);
        return `<span class="family-type-badge inline-flex items-center rounded-full border px-2.5 py-1 text-[11px] font-semibold ${meta.badgeClass} ${extraClasses}"><span class="family-type-icon-chip">${_buildFamilyTypeSymbolSvg(selectedSymbolKey, 14)}</span><span>${escapeHtml(meta.label)}</span></span>`;
    }

    function _syncFamilyTypeBadge() {
        if (!familyTypeBadge) return;
        const fam = _getSelectedFamilyRecord();
        if (!fam) {
            familyTypeBadge.innerHTML = '';
            familyTypeBadge.className = 'hidden';
            return;
        }
        const meta = _getFamilyTypeMeta(fam.typeKey, fam.name);
        const symbolKey = _getFamilySymbolKey(fam.typeKey, fam.name, fam.symbolKey);
        familyTypeBadge.className = `family-type-badge inline-flex items-center rounded-full border px-2.5 py-1 text-[11px] font-semibold ${meta.badgeClass}`;
        familyTypeBadge.innerHTML = `<span class="family-type-icon-chip">${_buildFamilyTypeSymbolSvg(symbolKey, 14)}</span><span>${escapeHtml(meta.label)}</span>`;
    }

    function _renderFamilyEditorSymbolPicker(selectedSymbolKey = '') {
        if (!familyEditorSymbolPicker || !familyEditorTypeSelect) return;
        const name = (familyEditorNameInput && familyEditorNameInput.value) ? familyEditorNameInput.value.trim() : '';
        const meta = _getFamilyTypeMeta(familyEditorTypeSelect.value, name);
        const choices = Array.isArray(meta.familySymbols) && meta.familySymbols.length ? meta.familySymbols : [meta.primarySymbol || 'generic'];
        const active = _normalizeFamilySymbolKeyForMeta(meta, selectedSymbolKey || _familyEditorState.symbolKey);
        _familyEditorState.symbolKey = active;
        familyEditorSymbolPicker.innerHTML = choices.map(symbol => `
            <button type="button" class="family-type-symbol-choice ${symbol === active ? 'is-selected' : ''}" data-family-symbol-key="${escapeHtml(symbol)}" title="${escapeHtml(symbol)}">
                ${_buildFamilyTypeSymbolSvg(symbol, 18)}
            </button>
        `).join('');
        familyEditorSymbolPicker.querySelectorAll('[data-family-symbol-key]').forEach(btn => {
            btn.addEventListener('click', () => {
                _familyEditorState.symbolKey = String(btn.getAttribute('data-family-symbol-key') || '').trim();
                _renderFamilyEditorSymbolPicker(_familyEditorState.symbolKey);
                _renderFamilyEditorTypePreview();
            });
        });
    }

    function _renderFamilyEditorTypeOptions(selectedTypeKey, familyName) {
        if (!familyEditorTypeSelect) return;
        const active = _getFamilyTypeMeta(selectedTypeKey, familyName).key;
        familyEditorTypeSelect.innerHTML = Object.values(FAMILY_TYPE_META).map(meta =>
            `<option value="${escapeHtml(meta.key)}" ${meta.key === active ? 'selected' : ''}>${escapeHtml(meta.optionLabel || meta.label)}</option>`
        ).join('');
    }

    function _renderFamilyEditorTypePreview() {
        if (!familyEditorTypePreview) return;
        const name = (familyEditorNameInput && familyEditorNameInput.value) ? familyEditorNameInput.value.trim() : '';
        const meta = _getFamilyTypeMeta(familyEditorTypeSelect ? familyEditorTypeSelect.value : '', name);
        const selectedSymbolKey = _getFamilySymbolKey(meta.key, name, _familyEditorState.symbolKey);
        const previewName = escapeHtml(name || 'Family group');
        familyEditorTypePreview.innerHTML = `
            <div class="family-type-preview-card p-4">
                <div class="flex flex-wrap items-start gap-3">
                    <div class="family-type-icon-chip-lg">
                        ${_buildFamilyTypeSymbolSvg(selectedSymbolKey, 22)}
                    </div>
                    <div class="min-w-0 flex-1">
                        <div class="text-sm font-semibold text-slate-100">${previewName}</div>
                        <div class="mt-1">${_buildFamilyTypeBadgeHtml(meta.key, name, '', selectedSymbolKey)}</div>
                        <div class="family-type-preview-label mt-3">Family symbols</div>
                        ${_buildFamilyTypeSymbolStripHtml(meta.key, name, selectedSymbolKey)}
                    </div>
                </div>
            </div>`;
    }

    // ── User-defined color layers ──
    const colorLayerList = document.getElementById('colorLayerList');
    const btnAddColor    = document.getElementById('btnAddColor');
    // colorLayerDefs: [ { id, label, enabled, colors: [ { color, tolerance } ] } ]
    let colorLayerDefs = [];
    let _colorIdSeq = 0;

    // Defaults – replaced by auto-detection after PDF import
    addLayerDef('Red', [{ color: '#ff0000', tolerance: 80 }]);
    addLayerDef('Magenta', [{ color: '#cc00cc', tolerance: 80 }]);

    function addLayerDef(label, colors, enabled) {
        const id = ++_colorIdSeq;
        colorLayerDefs.push({ id, label: label || '', enabled: enabled !== false, colors: colors || [{ color: '#ff0000', tolerance: 60 }] });
        renderLayerCards();
        return id;
    }

    function removeLayerDef(id) {
        colorLayerDefs = colorLayerDefs.filter(c => c.id !== id);
        renderLayerCards();
    }

    function renderLayerCards() {
        colorLayerList.innerHTML = '';
        for (const def of colorLayerDefs) {
            const card = document.createElement('div');
            card.className = 'layer-card';
            card.style.opacity = def.enabled ? '1' : '0.45';
            card.draggable = true;
            card.setAttribute('data-layer-id', def.id);

            // Drag handle
            const handle = document.createElement('span');
            handle.className = 'drag-handle';
            handle.title = 'Drag onto another layer to merge';
            handle.innerHTML = '<i class="fa-solid fa-grip-vertical"></i>';
            card.appendChild(handle);

            // Header: checkbox + layer name
            const header = document.createElement('div');
            header.className = 'layer-header';
            header.innerHTML = `
                <input type="checkbox" ${def.enabled ? 'checked' : ''} title="Enable/disable this layer" style="width:16px;height:16px;cursor:pointer;accent-color:#10b981" />
                <input type="text" class="layer-name" value="${escHtml(def.label)}" placeholder="Layer name" title="Layer name" />
            `;
            const cbInput = header.querySelector('input[type="checkbox"]');
            const nameInput = header.querySelector('.layer-name');
            cbInput.addEventListener('change', () => { def.enabled = cbInput.checked; card.style.opacity = def.enabled ? '1' : '0.45'; });
            nameInput.addEventListener('input', () => { def.label = nameInput.value; });
            card.appendChild(header);

            // Color entries container
            const entriesDiv = document.createElement('div');
            entriesDiv.className = 'color-entries';

            function renderEntries() {
                entriesDiv.innerHTML = '';
                def.colors.forEach((ce, ci) => {
                    const entry = document.createElement('span');
                    entry.className = 'color-entry';
                    entry.innerHTML = `
                        <input type="color" value="${ce.color}" title="Pick color" />
                        <label class="text-[10px] text-slate-500" title="Tolerance">±</label>
                        <input type="number" min="10" max="255" step="5" value="${ce.tolerance}" title="Tolerance (0-255)" />
                        ${def.colors.length > 1 ? '<span class="ce-remove" title="Remove this color"><i class="fa-solid fa-xmark"></i></span>' : ''}
                    `;
                    const cInput = entry.querySelector('input[type="color"]');
                    const tInput = entry.querySelector('input[type="number"]');
                    const rmBtn  = entry.querySelector('.ce-remove');
                    cInput.addEventListener('input', () => { ce.color = cInput.value; });
                    tInput.addEventListener('input', () => { ce.tolerance = parseInt(tInput.value) || 60; });
                    if (rmBtn) rmBtn.addEventListener('click', () => { def.colors.splice(ci, 1); renderEntries(); });
                    entriesDiv.appendChild(entry);
                });
            }
            renderEntries();
            card.appendChild(entriesDiv);

            // Remove layer button
            const removeBtn = document.createElement('span');
            removeBtn.className = 'layer-remove';
            removeBtn.title = 'Remove layer';
            removeBtn.innerHTML = '<i class="fa-solid fa-trash-can"></i>';
            removeBtn.addEventListener('click', () => removeLayerDef(def.id));
            card.appendChild(removeBtn);

            // ── Drag & Drop events for merging layers ──
            card.addEventListener('dragstart', (e) => {
                e.dataTransfer.setData('text/plain', String(def.id));
                e.dataTransfer.effectAllowed = 'move';
                card.classList.add('dragging');
            });
            card.addEventListener('dragend', () => { card.classList.remove('dragging'); });
            card.addEventListener('dragover', (e) => {
                e.preventDefault();
                e.dataTransfer.dropEffect = 'move';
                card.classList.add('drag-over');
            });
            card.addEventListener('dragleave', () => { card.classList.remove('drag-over'); });
            card.addEventListener('drop', (e) => {
                e.preventDefault();
                card.classList.remove('drag-over');
                const srcId = parseInt(e.dataTransfer.getData('text/plain'));
                if (!srcId || srcId === def.id) return;
                mergeLayers(srcId, def.id);
            });

            colorLayerList.appendChild(card);
        }
    }

    // Merge source layer into target layer (combine colors, remove source)
    function mergeLayers(srcId, targetId) {
        const src = colorLayerDefs.find(d => d.id === srcId);
        const tgt = colorLayerDefs.find(d => d.id === targetId);
        if (!src || !tgt) return;
        // Add all source colors to target (skip exact duplicates)
        for (const sc of src.colors) {
            const dup = tgt.colors.some(tc => tc.color === sc.color);
            if (!dup) tgt.colors.push({ ...sc });
        }
        // Update label if target has no label
        if (!tgt.label && src.label) tgt.label = tgt.label || src.label;
        else if (src.label && tgt.label) tgt.label = tgt.label + '+' + src.label;
        // Remove source
        colorLayerDefs = colorLayerDefs.filter(d => d.id !== srcId);
        renderLayerCards();
    }

    btnAddColor.addEventListener('click', () => addLayerDef('', [{ color: '#0000ff', tolerance: 60 }]));

    // ── Zoom controls ──
    // pdfZoom is an absolute scale: 1.0 = 1 image-pixel → 1 CSS-pixel.
    // Images are resized via explicit style.width/height so the scroll area expands.
    function _applyZoomToImages(z) {
        if (!pdfPages) return;
        const baseZoom = Math.max(0.0001, pdfBaseViewZoom || 1);
        const rel = Math.max(0.02, z / baseZoom);
        for (const wrap of pdfPages.querySelectorAll('.pdf-page-wrap')) {
            const shell = wrap.querySelector('.pdf-page-shell');
            const world = wrap.querySelector('.pdf-page-world');
            const img = wrap.querySelector('img');
            if (!img) continue;
            const vw = img._viewW || 0;
            const vh = img._viewH || 0;
            if (!(vw > 0 && vh > 0)) continue;

            if (shell) {
                shell.style.width = (vw * rel) + 'px';
                shell.style.height = (vh * rel) + 'px';
            }
            if (world) {
                world.style.width = (vw * rel) + 'px';
                world.style.height = (vh * rel) + 'px';
            }

            const applyScaledStyle = (el) => {
                if (!el) return;
                el.style.width = vw + 'px';
                el.style.height = vh + 'px';
                el.style.transform = `scale(${rel})`;
                el.style.transformOrigin = 'top left';
                el.style.position = 'absolute';
                el.style.top = '0';
                el.style.left = '0';
            };

            applyScaledStyle(img);
            applyScaledStyle(wrap.querySelector('canvas.crop-overlay'));
            applyScaledStyle(wrap.querySelector('.pdf-mark-canvas'));
            wrap.style.width = (vw * rel) + 'px';
            wrap.style.height = (vh * rel) + 'px';
        }
    }

    // Returns the widest base image width across all loaded page images.
    function _maxBaseImageWidth() {
        let mx = 0;
        if (pdfPages) {
            for (const img of pdfPages.querySelectorAll('.pdf-page-wrap img')) {
                if (img._baseW > mx) mx = img._baseW;
            }
        }
        return mx;
    }

    function _maxBaseImageHeight() {
        let mx = 0;
        if (pdfPages) {
            for (const img of pdfPages.querySelectorAll('.pdf-page-wrap img')) {
                if (img._baseH > mx) mx = img._baseH;
            }
        }
        return mx;
    }

    function _canMeasurePdfViewport() {
        return !!(pdfViewport && pdfViewport.clientWidth > 120 && pdfViewport.clientHeight > 120);
    }

    function _setPdfBaseViewZoom(z) {
        pdfBaseViewZoom = Math.max(0.0001, Number(z) || 1);
        if (!pdfPages) return;
        for (const wrap of pdfPages.querySelectorAll('.pdf-page-wrap')) {
            const img = wrap.querySelector('img');
            if (!img || !(img._baseW > 0) || !(img._baseH > 0)) continue;
            img._viewW = img._baseW * pdfBaseViewZoom;
            img._viewH = img._baseH * pdfBaseViewZoom;
        }
    }

    function _applyPendingPdfInitialFit() {
        if (!_pendingPdfInitialFit) return false;
        if (!_canMeasurePdfViewport()) return false;
        const nextZoom = Math.max(0.0001, _fitZoomWidth());
        _setPdfBaseViewZoom(nextZoom);
        setPdfZoom(nextZoom, { resetScroll: true });
        _pendingPdfInitialFit = false;
        return true;
    }

    // Compute zoom so the widest page fits the viewport width.
    function _fitZoomWidth() {
        if (!pdfViewport) return 1;
        const vw = Math.max(1, pdfViewport.clientWidth - 32);
        const bw = _maxBaseImageWidth();
        if (bw <= 0) return 1;
        return Math.min(vw / bw, 1);
    }

    // Compute zoom so a full page fits inside the viewport.
    function _fitZoom() {
        if (!pdfViewport) return 1;
        const vw = Math.max(1, pdfViewport.clientWidth - 32);
        const vh = Math.max(1, pdfViewport.clientHeight - 32);
        const bw = _maxBaseImageWidth();
        const bh = _maxBaseImageHeight();
        if (bw <= 0 || bh <= 0) return 1;
        return Math.min(vw / bw, vh / bh, 1);
    }

    function setPdfZoom(z, opts) {
        const prevZoom = pdfZoom;
        pdfZoom = Math.max(0.02, Math.min(50, z));
        if (pdfInner) pdfInner.style.transform = ''; // clear any legacy transform
        _applyZoomToImages(pdfZoom);

        const label = document.getElementById('pdfZoomLabel');
        if (label) label.textContent = Math.round(pdfZoom * 100) + '%';

        if (opts && opts.anchor && pdfViewport) {
            const rect = pdfViewport.getBoundingClientRect();
            const x = opts.anchor.x - rect.left;
            const y = opts.anchor.y - rect.top;
            const contentX = (pdfViewport.scrollLeft + x) / prevZoom;
            const contentY = (pdfViewport.scrollTop + y) / prevZoom;
            pdfViewport.scrollLeft = contentX * pdfZoom - x;
            pdfViewport.scrollTop  = contentY * pdfZoom - y;
        } else if (opts && opts.resetScroll && pdfViewport) {
            pdfViewport.scrollLeft = 0;
            pdfViewport.scrollTop = 0;
        }
    }
    document.getElementById('btnPdfZoomIn')?.addEventListener('click',  () => setPdfZoom(pdfZoom * 1.25));
    document.getElementById('btnPdfZoomOut')?.addEventListener('click', () => setPdfZoom(pdfZoom / 1.25));
    document.getElementById('btnPdfZoomFit')?.addEventListener('click', () => setPdfZoom(_fitZoom()));

    function _updatePdfViewportCursor(isPanning) {
        if (!pdfViewport) return;
        const cursor = cropMode || _pdfMarkMode || _pdfDirectCropMode ? 'default' : (isPanning ? 'grabbing' : 'grab');
        pdfViewport.style.cursor = cursor;
        if (pdfPages) {
            for (const shell of pdfPages.querySelectorAll('.pdf-page-shell')) {
                shell.style.cursor = cursor;
            }
        }
    }

    function _getPdfPanTarget(startEl) {
        if (!pdfViewport) return null;
        return pdfViewport;
    }

    // Wheel zoom for PDF preview (no Ctrl)
    // Keeps zoom anchored under the cursor.
    pdfViewport?.addEventListener('wheel', (e) => {
        // Avoid breaking page scroll outside of the viewport.
        if (!pdfViewport) return;
        e.preventDefault();
        const factor = e.deltaY < 0 ? 1.12 : 1 / 1.12;
        setPdfZoom(pdfZoom * factor, { anchor: { x: e.clientX, y: e.clientY } });
    }, { passive: false });

    // Drag-to-pan PDF preview (left button when NOT cropping; middle button always)
    let _pdfPan = null;
    pdfViewport?.addEventListener('mousedown', (e) => {
        if (!pdfViewport) return;
        // Left button is reserved for region drawing while crop/mark mode is active.
        if (e.button === 0 && (cropMode || _pdfMarkMode || _pdfDirectCropMode)) return;
        if (!(e.button === 0 || e.button === 1)) return;

        const panEl = _getPdfPanTarget(e.target);
        if (!panEl) return;

        // Prevent middle-button auto-scroll and text selection while panning.
        e.preventDefault();
        _pdfPan = {
            el: panEl,
            x: e.clientX,
            y: e.clientY,
            sl: panEl.scrollLeft,
            st: panEl.scrollTop
        };
        _updatePdfViewportCursor(true);
        panEl.style.userSelect = 'none';
    });

    window.addEventListener('mousemove', (e) => {
        if (!_pdfPan || !_pdfPan.el) return;
        const dx = e.clientX - _pdfPan.x;
        const dy = e.clientY - _pdfPan.y;
        _pdfPan.el.scrollLeft = _pdfPan.sl - dx;
        _pdfPan.el.scrollTop = _pdfPan.st - dy;
    });

    window.addEventListener('mouseup', () => {
        if (!_pdfPan) return;
        const panEl = _pdfPan.el;
        _pdfPan = null;
        if (panEl) panEl.style.userSelect = '';
        _updatePdfViewportCursor(false);
    });

    // ── Crop toggle / clear buttons ──
    btnCropToggle.addEventListener('click', () => {
        if (_pdfDirectCropMode) _cancelPdfDirectCrop();
        cropMode = !cropMode;
        btnCropToggle.classList.toggle('active', cropMode);
        pdfPages.classList.toggle('crop-active', cropMode);

        _updatePdfViewportCursor(false);

        // Show overlays only while editing regions
        pdfPages.querySelectorAll('canvas.crop-overlay').forEach(cvs => {
            const pageIndex = parseInt(cvs.getAttribute('data-page-index') || '0', 10);
            const ctx = cvs.getContext('2d');
            if (!cropMode) {
                ctx.clearRect(0, 0, cvs.width, cvs.height);
                if (outputCrop && outputCrop.pageIndex === pageIndex) drawAllRegions(cvs, pageIndex);
            } else {
                drawAllRegions(cvs, pageIndex);
            }
        });
    });
    btnCropClear.addEventListener('click', () => {
        _keepOnlyOutputCropSelection();
        updateCropClearBtn();
        // Redraw all canvases
        pdfPages.querySelectorAll('canvas.crop-overlay').forEach(cvs => {
            const ctx = cvs.getContext('2d');
            ctx.clearRect(0, 0, cvs.width, cvs.height);
            const pageIndex = parseInt(cvs.getAttribute('data-page-index') || '0', 10);
            if (outputCrop && outputCrop.pageIndex === pageIndex) drawAllRegions(cvs, pageIndex);
        });
    });

    function _findRegionById(pageIndex, regionId) {
        const regions = cropSelections[pageIndex] || [];
        for (const r of regions) {
            if (r && r.id === regionId) return r;
        }
        return null;
    }

    function _removeOutputCropSelectionIfPresent() {
        if (!outputCrop) return;
        const pi = outputCrop.pageIndex;
        const arr = cropSelections[pi] || [];
        const idx = arr.findIndex(r => r && r.id === outputCrop.regionId);
        if (idx >= 0) {
            arr.splice(idx, 1);
            if (arr.length === 0) delete cropSelections[pi];
        }
    }

    function _applyOutputCropSelection(pageIndex, sel) {
        if (!sel) return;
        const prev = outputCrop ? { pageIndex: outputCrop.pageIndex, regionId: outputCrop.regionId } : null;
        if (prev && (prev.pageIndex !== pageIndex || prev.regionId !== sel.id)) {
            const prevArr = cropSelections[prev.pageIndex] || [];
            const prevIdx = prevArr.findIndex(r => r && r.id === prev.regionId);
            if (prevIdx >= 0) {
                prevArr.splice(prevIdx, 1);
                if (prevArr.length === 0) delete cropSelections[prev.pageIndex];
            }
        }
        if (!cropSelections[pageIndex]) cropSelections[pageIndex] = [];
        const arr = cropSelections[pageIndex];
        const idx = arr.findIndex(r => r && r.id === sel.id);
        if (idx >= 0) arr[idx] = sel;
        else arr.push(sel);
        outputCrop = { pageIndex, regionId: sel.id, frac: { x: sel.x, y: sel.y, w: sel.w, h: sel.h } };
    }
    function _countGenericCropSelections() {
        let total = 0;
        for (const [k, arrRaw] of Object.entries(cropSelections || {})) {
            const pi = parseInt(k, 10);
            const arr = Array.isArray(arrRaw) ? arrRaw : [];
            for (const r of arr) {
                if (!r) continue;
                if (outputCrop && outputCrop.pageIndex === pi && outputCrop.regionId === r.id) continue;
                total++;
            }
        }
        return total;
    }

    function _keepOnlyOutputCropSelection() {
        if (!outputCrop) {
            cropSelections = {};
            return;
        }
        const live = _findRegionById(outputCrop.pageIndex, outputCrop.regionId)
            || (outputCrop.frac ? {
                id: outputCrop.regionId,
                x: outputCrop.frac.x,
                y: outputCrop.frac.y,
                w: outputCrop.frac.w,
                h: outputCrop.frac.h
            } : null);
        cropSelections = live ? { [outputCrop.pageIndex]: [live] } : {};
    }

    function _syncOutputCropFromSelections() {
        if (!outputCrop) return;
        const live = _findRegionById(outputCrop.pageIndex, outputCrop.regionId);
        if (!live) {
            outputCrop = null;
            updateCropClearBtn();
            return;
        }
        outputCrop.frac = { x: live.x, y: live.y, w: live.w, h: live.h };
    }

    function _pickDefaultRegionForOutputCrop() {
        const keys = Object.keys(cropSelections || {}).map(k => parseInt(k, 10)).filter(n => isFinite(n)).sort((a,b)=>a-b);
        for (const pi of keys) {
            const arr = cropSelections[pi] || [];
            if (!arr.length) continue;
            const sel = arr[arr.length - 1];
            if (sel) return { pageIndex: pi, regionId: sel.id, frac: { x: sel.x, y: sel.y, w: sel.w, h: sel.h } };
        }
        return null;
    }

    if (btnOutputCropSet) {
        btnOutputCropSet.addEventListener('click', () => {
            const picked = _pickDefaultRegionForOutputCrop();
            if (!picked) return;
            outputCrop = picked;
            updateCropClearBtn();
            redrawAllCropOverlays();
        });
    }
    if (btnOutputCropClear) {
        btnOutputCropClear.addEventListener('click', () => {
            if (_pdfDirectCropMode) _cancelPdfDirectCrop();
            _removeOutputCropSelectionIfPresent();
            outputCrop = null;
            updateCropClearBtn();
            redrawAllCropOverlays();
        });
    }

    // Redraw crop overlays on every page canvas
    function redrawAllCropOverlays() {
        _syncOutputCropFromSelections();
        pdfPages.querySelectorAll('canvas.crop-overlay').forEach(cvs => {
            const pi = parseInt(cvs.dataset.pageIndex);
            if (!isNaN(pi) && typeof drawAllRegions === 'function') drawAllRegions(cvs, pi);
            else { const ctx = cvs.getContext('2d'); ctx.clearRect(0, 0, cvs.width, cvs.height); }
        });
    }

    // The page always uses the fixed vector-first pipeline.
    if (colorLayerSection) colorLayerSection.classList.remove('hidden');
    if (btnCropToggle) btnCropToggle.disabled = false;
    if (btnCropToggle) btnCropToggle.classList.remove('opacity-50');
    if (btnCropToggle) btnCropToggle.title = 'Select crop regions (applied to the vector SVG; no quality loss)';

    // regionTextSection is informational only (text layers are auto-generated)
    if (regionTextSection) {
        const total = Object.values(cropSelections).reduce((s, arr) => s + (arr ? arr.length : 0), 0);
        regionTextSection.classList.toggle('opacity-60', total === 0);
    }

    function updateCropClearBtn() {
        const total = _countGenericCropSelections();
        if (total > 0) {
            btnCropClear.classList.remove('hidden');
            btnCropClear.querySelector('span') && (btnCropClear.innerHTML = '<i class="fa-solid fa-xmark"></i> Clear (' + total + ')');
        } else {
            btnCropClear.classList.add('hidden');
        }
        if (regionTextSection) regionTextSection.classList.toggle('opacity-60', total === 0);

        // Output crop UI
        if (btnOutputCropSet) btnOutputCropSet.classList.toggle('hidden', total === 0 || !!outputCrop || _pdfDirectCropMode);
        if (btnOutputCropClear) btnOutputCropClear.classList.toggle('hidden', !outputCrop);
        if (outputCropInfo) {
            if (outputCrop) {
                outputCropInfo.classList.remove('hidden');
                outputCropInfo.textContent = `CROP: P${(outputCrop.pageIndex || 0) + 1}`;
            } else {
                outputCropInfo.classList.add('hidden');
            }
        }

        // Family learning UI
        if (familySelect) familySelect.disabled = false;
        if (btnFamilyView) btnFamilyView.disabled = false;
        if (btnFamilyNew) btnFamilyNew.disabled = false;
        const famId = familySelect ? parseInt(familySelect.value || '', 10) : NaN;
        const famOk = Number.isFinite(famId) && famId > 0;
        if (btnFamilyView) btnFamilyView.disabled = !famOk;
        if (btnFamilyRename) btnFamilyRename.disabled = !famOk;
        if (btnFamilyDelete) btnFamilyDelete.disabled = !famOk;
        // Mark button: enabled if a family is selected and pages are loaded
        const btnPdfMark = document.getElementById('btnPdfMark');
        if (btnPdfMark) btnPdfMark.disabled = !(famOk && lastPdfPages.length > 0);
        const btnPdfCrop = document.getElementById('btnPdfCrop');
        if (btnPdfCrop) {
            btnPdfCrop.disabled = !(lastPdfPages.length > 0);
            if (!_pdfDirectCropMode) {
                btnPdfCrop.innerHTML = outputCrop
                    ? '<i class="fa-solid fa-crop-simple"></i> Edit CROP'
                    : '<i class="fa-solid fa-crop-simple"></i> CROP';
            }
        }
    }

    function _renderFamiliesSelect(families) {
        if (!familySelect) return;
        const cur = familySelect.value || '';
        familySelect.innerHTML = '';
        const opt0 = document.createElement('option');
        opt0.value = '';
        opt0.textContent = '—';
        familySelect.appendChild(opt0);

        (families || []).forEach(f => {
            const opt = document.createElement('option');
            const name = `${String(f && f.name || '').trim() || '(unnamed)'}`;
            const meta = _getFamilyTypeMeta(f && f.typeKey, name);
            opt.value = String(f.id || '');
            opt.textContent = `${meta.optionLabel || meta.label} · ${name}`;
            opt.dataset.familyName = name;
            opt.dataset.familyTypeKey = meta.key;
            familySelect.appendChild(opt);
        });

        const values = [...familySelect.options].map(o => o.value);
        const preferred = (cur && values.includes(cur)) ? cur : '';

        familySelect.value = preferred || '';
        _rememberSelectedFamilyId(familySelect.value || '');
        _syncFamilyTypeBadge();
    }

    async function loadObjectFamilies(force) {
        const now = Date.now();
        if (!force && _objectFamiliesLoadedAt && (now - _objectFamiliesLoadedAt) < 15_000) return _objectFamilies;
        try {
            const resp = await fetch(OBJECT_FAMILIES_ENDPOINT, { headers: { 'X-Client-Id': 'admin' } });
            if (!resp.ok) throw new Error(await resp.text());
            const obj = await resp.json();
            const fams = (obj && obj.families && Array.isArray(obj.families))
                ? obj.families.map(f => {
                    const typeKey = _getFamilyTypeMeta(f && f.typeKey, f && f.name).key;
                    return { ...f, typeKey, symbolKey: _getFamilySymbolKey(typeKey, f && f.name, f && f.symbolKey) };
                })
                : [];
            _objectFamilies = fams;
            _objectFamiliesLoadedAt = now;
            _renderFamiliesSelect(_objectFamilies);
            _applySelectedFamilyYoloDetectSettings();
            updateCropClearBtn();
            return _objectFamilies;
        } catch {
            _objectFamilies = [];
            _objectFamiliesLoadedAt = now;
            _renderFamiliesSelect([]);
            _applySelectedFamilyYoloDetectSettings();
            updateCropClearBtn();
            return [];
        }
    }

    function _openFamilyEditorDialog(mode, fam) {
        if (!familyEditorModal || !familyEditorNameInput || !familyEditorTypeSelect || !familyEditorTitle) return;
        const current = fam || null;
        const currentName = current && current.name != null ? String(current.name).trim() : '';
        const currentTypeKey = current ? _getFamilyTypeMeta(current.typeKey, current.name).key : 'fire-detection';
        const currentSymbolKey = current ? _getFamilySymbolKey(currentTypeKey, current.name, current.symbolKey) : _getFamilySymbolKey(currentTypeKey, currentName, '');
        _familyEditorState = {
            mode: mode === 'edit' ? 'edit' : 'create',
            familyId: current && Number.isFinite(Number(current.id)) ? (Number(current.id) | 0) : 0,
            busy: false,
            symbolKey: currentSymbolKey
        };
        familyEditorTitle.textContent = _familyEditorState.mode === 'edit' ? 'Edit family group' : 'Create family group';
        familyEditorNameInput.value = currentName;
        _renderFamilyEditorTypeOptions(currentTypeKey, currentName);
        familyEditorTypeSelect.value = currentTypeKey;
        _renderFamilyEditorSymbolPicker(currentSymbolKey);
        _renderFamilyEditorTypePreview();
        familyEditorModal.classList.remove('hidden');
        familyEditorModal.classList.add('flex');
        try { familyEditorNameInput.focus(); familyEditorNameInput.select(); } catch { /* ignore */ }
    }

    function _closeFamilyEditorDialog() {
        if (!familyEditorModal) return;
        familyEditorModal.classList.add('hidden');
        familyEditorModal.classList.remove('flex');
        _familyEditorState = { mode: 'create', familyId: 0, busy: false, symbolKey: '' };
    }

    async function _saveFamilyEditorDialog() {
        if (!familyEditorNameInput || !familyEditorTypeSelect || _familyEditorState.busy) return;
        const name = String(familyEditorNameInput.value || '').trim();
        const typeKey = _getFamilyTypeMeta(familyEditorTypeSelect.value, name).key;
        const symbolKey = _getFamilySymbolKey(typeKey, name, _familyEditorState.symbolKey);
        if (!name) {
            cgAlert('Family name is required.');
            try { familyEditorNameInput.focus(); } catch { /* ignore */ }
            return;
        }

        const isEdit = _familyEditorState.mode === 'edit' && _familyEditorState.familyId > 0;
        const famId = _familyEditorState.familyId;
        const panelOpen = !!(familyLearnPanel && !familyLearnPanel.classList.contains('hidden'));
        try {
            _familyEditorState.busy = true;
            if (btnFamilyEditorSave) {
                btnFamilyEditorSave.disabled = true;
                btnFamilyEditorSave.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Saving…';
            }

            const resp = await fetch(isEdit ? `${OBJECT_FAMILIES_ENDPOINT}/${famId}` : OBJECT_FAMILIES_ENDPOINT, {
                method: isEdit ? 'PUT' : 'POST',
