                    createdChip.title = 'Last created group';

                    const createdFrame = document.createElement('div');
                    createdFrame.className = 'merged-svg-last-created-group__frame';
                    const createdPreviewSvg = _buildElementPreviewSvg(lastCreatedEl, { padFactor: 0.08, minPad: 2, maxPad: 6 });
                    if (createdPreviewSvg) {
                        createdFrame.appendChild(createdPreviewSvg);
                    } else {
                        const fallback = document.createElement('span');
                        fallback.className = 'selected-object-preview-fallback';
                        fallback.innerHTML = '<i class="fa-solid fa-layer-group"></i>';
                        createdFrame.appendChild(fallback);
                    }

                    const createdMeta = document.createElement('div');
                    createdMeta.className = 'merged-svg-last-created-group__meta';
