                            <i class="fa-solid fa-bezier-curve"></i> Add to SVG Split
                        </button>
                        <button type="button" ${(scanBusy || (_familyYoloStatus && _familyYoloStatus.isTraining)) ? 'disabled' : ''} class="yolo-btn-anim yolo-btn-anim--blue inline-flex items-center gap-2 rounded-lg border px-2.5 py-1 text-xs disabled:opacity-60 disabled:pointer-events-none disabled:transform-none" style="background:linear-gradient(135deg,#3b82f6 0%,#2563eb 100%); border-color:#93c5fd; color:#ffffff; box-shadow:0 10px 24px rgba(37,99,235,0.34);" onmouseenter="this.style.transform='translateY(-3px) scale(1.06)';this.style.filter='brightness(1.18)';this.style.boxShadow='0 10px 32px rgba(37,99,235,0.55), 0 0 0 3px rgba(59,130,246,0.25)'" onmouseleave="this.style.transform='';this.style.filter='';this.style.boxShadow='0 10px 24px rgba(37,99,235,0.34)'" onmousedown="this.style.transform='scale(0.94)';this.style.filter='brightness(0.90)'" onmouseup="this.style.transform='translateY(-3px) scale(1.06)';this.style.filter='brightness(1.18)'" title="Run YOLO locate. If the family is not trained yet, the annotated map opens so you can mark the first YOLO samples." onclick="scanSelectedFamilyInPdfLocateYolo()">
                            <i class="fa-solid fa-wand-magic-sparkles animate-pulse"></i> Locate (YOLO)
                        </button>
                        <button type="button" ${canTrainFamilyYolo ? '' : 'disabled'} ${(_yoloTrainBusy || (_familyYoloStatus && _familyYoloStatus.isTraining)) ? 'disabled' : ''} class="yolo-btn-anim yolo-btn-anim--amber inline-flex items-center gap-2 rounded-lg border px-2.5 py-1 text-xs font-semibold disabled:opacity-60 disabled:pointer-events-none disabled:transform-none" style="background:linear-gradient(135deg,#facc15 0%,#f59e0b 100%); border-color:#fde68a; color:#172033; box-shadow:0 10px 24px rgba(245,158,11,0.30);" onmouseenter="this.style.transform='translateY(-3px) scale(1.06)';this.style.filter='brightness(1.15)';this.style.boxShadow='0 10px 32px rgba(245,158,11,0.55), 0 0 0 3px rgba(245,158,11,0.25)'" onmouseleave="this.style.transform='';this.style.filter='';this.style.boxShadow='0 10px 24px rgba(245,158,11,0.30)'" onmousedown="this.style.transform='scale(0.94)';this.style.filter='brightness(0.90)'" onmouseup="this.style.transform='translateY(-3px) scale(1.06)';this.style.filter='brightness(1.15)'" title="Train the family YOLO model from current green/yellow changes and/or persisted memory crops" onclick="trainSelectedFamilyYolo()">
