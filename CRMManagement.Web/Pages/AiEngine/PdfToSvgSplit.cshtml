                const matrix = _getCumulativeTransform(el, svgRoot);
                return _transformBBox(local, matrix);
            }

            if (typeof el.getBBox === 'function') {
                const bb = el.getBBox();
                if (bb && Number.isFinite(bb.x) && Number.isFinite(bb.y) && Number.isFinite(bb.width) && Number.isFinite(bb.height)) {
                    const ctm = typeof el.getCTM === 'function' ? el.getCTM() : null;
                    if (ctm && Number.isFinite(ctm.a) && Number.isFinite(ctm.b) && Number.isFinite(ctm.c) && Number.isFinite(ctm.d) && Number.isFinite(ctm.e) && Number.isFinite(ctm.f)) {
                        return _transformBBox(
                            { x1: bb.x, y1: bb.y, x2: bb.x + bb.width, y2: bb.y + bb.height },
                            [ctm.a, ctm.b, ctm.c, ctm.d, ctm.e, ctm.f]
                        );
                    }
                    return { x1: bb.x, y1: bb.y, x2: bb.x + bb.width, y2: bb.y + bb.height };
                }
            }

            return null;
        } catch {
            return null;
        }
    }

    async function _applySvgPreviewAiCandidateHighlightNow() {
        const idx = Number(_svgPreviewActiveResultIdx);
        const r = Number.isFinite(idx) && idx >= 0 && idx < pageResults.length ? pageResults[idx] : null;
        const { svg } = _getSvgPreviewScaleAndSvg();
        const crop = svgPreviewFixedCropEnabled ? _parseViewBoxStr(svgPreviewFixedCropViewBoxStr) : null;
        const scanToken = ++_svgPreviewAiCandidateScanToken;

        if (!svg || !crop || !(crop.w > 0) || !(crop.h > 0) || !r || !_isOtherElementsLayerResult(r)) {
            _clearSvgPreviewAiCandidateHighlight();
            return;
        }

        if (!_isSvgAiCandidateAutoScanAllowed(r)) {
            _clearSvgPreviewAiCandidateHighlight();
            _svgAiCandidateDebugInfo = {
                cropViewBox: svgPreviewFixedCropViewBoxStr || '',
                totalNodes: 0,
                skippedDefs: 0,
                bboxMisses: 0,
                nonIntersecting: 0,
                marked: 0,
                limitHit: false,
                samples: [
                    {
                        tag: 'layer',
                        id: '',
                        reason: `auto-scan-disabled objectCount=${Math.max(0, Number(r.objectCount) || 0)} svgBytes=${Math.max(0, Number(r.svgSizeBytes) || 0)}`
                    }
                ]
            };
            _updateSvgAiCandidateCountUi(0);
            _updateSvgAiCandidateDebugUi();
            return;
        }

        const key = `${idx}|${svgPreviewFixedCropViewBoxStr || ''}`;
        if (_svgPreviewAiCandidateLastSvg === svg && _svgPreviewAiCandidateLastKey === key && _svgPreviewAiCandidateMarkedNodes.length > 0) {
            return;
        }

        _clearSvgPreviewAiCandidateHighlight();

        const idMap = new Map();
        try {
            for (const node of svg.querySelectorAll('[id]')) {
                const id = (node.getAttribute('id') || '').trim();
