    /* Make ALL svg elements clickable in select-mode (even fill:none strokes) */
    #mergedSvgPreviewViewport.select-mode svg path,
    #mergedSvgPreviewViewport.select-mode svg rect,
    #mergedSvgPreviewViewport.select-mode svg circle,
    #mergedSvgPreviewViewport.select-mode svg ellipse,
    #mergedSvgPreviewViewport.select-mode svg line,
    #mergedSvgPreviewViewport.select-mode svg polyline,
    #mergedSvgPreviewViewport.select-mode svg polygon,
