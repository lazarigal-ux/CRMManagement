    document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && familyEditorModal && !familyEditorModal.classList.contains('hidden')) {
            _closeFamilyEditorDialog();
            return;
        }
        if (e.key === 'Enter' && familyEditorModal && !familyEditorModal.classList.contains('hidden')) {
            const target = e.target;
            if (target instanceof HTMLInputElement || target instanceof HTMLSelectElement) {
                e.preventDefault();
                _saveFamilyEditorDialog().catch(() => { /* ignore */ });
            }
        }
    });

    // Load families ASAP (best-effort)
    try { loadObjectFamilies(false); } catch { }

    // ── Hit-test: which part of which region did we click? ──
    // Returns { regionIdx, zone } or null.  zone: 'move','nw','n','ne','e','se','s','sw','w'
    function hitTestSingleRegion(sel, fx, fy) {
        if (!sel) return null;
        const r = HANDLE_R;
        const x1 = sel.x, y1 = sel.y, x2 = sel.x + sel.w, y2 = sel.y + sel.h;
        const mx = (x1 + x2) / 2, my = (y1 + y2) / 2;
        if (Math.abs(fx - x1) < r && Math.abs(fy - y1) < r) return 'nw';
        if (Math.abs(fx - x2) < r && Math.abs(fy - y1) < r) return 'ne';
        if (Math.abs(fx - x1) < r && Math.abs(fy - y2) < r) return 'sw';
        if (Math.abs(fx - x2) < r && Math.abs(fy - y2) < r) return 'se';
        if (Math.abs(fx - mx) < r && Math.abs(fy - y1) < r) return 'n';
        if (Math.abs(fx - mx) < r && Math.abs(fy - y2) < r) return 's';
        if (Math.abs(fx - x1) < r && Math.abs(fy - my) < r) return 'w';
        if (Math.abs(fx - x2) < r && Math.abs(fy - my) < r) return 'e';
        if (fx >= x1 && fx <= x2 && fy >= y1 && fy <= y2) return 'move';
        return null;
    }

    function hitTestAllRegions(pageIndex, fx, fy) {
        const regions = cropSelections[pageIndex] || [];
        // Test last-drawn first (topmost)
        for (let ri = regions.length - 1; ri >= 0; ri--) {
            const zone = hitTestSingleRegion(regions[ri], fx, fy);
            if (zone) return { regionIdx: ri, zone };
        }
        return null;
    }

    // Map hit zone to CSS cursor
    function hitCursor(zone) {
        const map = { nw: 'nwse-resize', se: 'nwse-resize', ne: 'nesw-resize', sw: 'nesw-resize',
                      n: 'ns-resize', s: 'ns-resize', e: 'ew-resize', w: 'ew-resize', move: 'move' };
        return map[zone] || 'crosshair';
    }

    // ── Setup crop mouse handlers for a canvas (multi-region) ──
    let _cropRafId = 0;  // requestAnimationFrame ID for throttling crop redraws
    function setupCropHandlers(cvs, pageIndex) {
        function fracPos(e) {
            const rect = cvs.getBoundingClientRect();
            return {
                fx: Math.max(0, Math.min(1, (e.clientX - rect.left) / rect.width)),
                fy: Math.max(0, Math.min(1, (e.clientY - rect.top) / rect.height))
            };
        }

        cvs.addEventListener('mousedown', e => {
            if (!cropMode && !_pdfDirectCropMode) return;
            if (e.button !== 0) return; // only left-click draws/edits regions
            const { fx, fy } = fracPos(e);
            if (_pdfDirectCropMode) {
                const currentCrop = outputCrop && outputCrop.pageIndex === pageIndex
                    ? _findRegionById(pageIndex, outputCrop.regionId)
                    : null;
                const currentZone = currentCrop ? hitTestSingleRegion(currentCrop, fx, fy) : null;
                if (currentCrop && currentZone) {
                    const regionIdx = (cropSelections[pageIndex] || []).findIndex(r => r && r.id === outputCrop.regionId);
                    _cropDrag = {
                        pageIndex, mode: currentZone, regionIdx,
                        origSel: { ...currentCrop },
                        anchorX: fx, anchorY: fy,
                        directCrop: true
                    };
                } else {
                    _cropDrag = {
                        pageIndex, mode: 'new',
                        startX: fx, startY: fy, curX: fx, curY: fy,
                        directCrop: true
                    };
                }
                e.preventDefault();
                return;
            }
            const hit = hitTestAllRegions(pageIndex, fx, fy);

            if (hit) {
                // Edit existing region: move or resize
                const sel = cropSelections[pageIndex][hit.regionIdx];
                _cropDrag = {
                    pageIndex, mode: hit.zone, regionIdx: hit.regionIdx,
                    origSel: { ...sel },
                    anchorX: fx, anchorY: fy
                };
            } else {
                // New region
                _cropDrag = {
                    pageIndex, mode: 'new',
                    startX: fx, startY: fy, curX: fx, curY: fy
                };
            }
            e.preventDefault();
        });

        cvs.addEventListener('mousemove', e => {
            if (!cropMode && !_pdfDirectCropMode) { cvs.style.cursor = 'default'; return; }
            const { fx, fy } = fracPos(e);

            if (!_cropDrag) {
                if (_pdfDirectCropMode) {
                    const currentCrop = outputCrop && outputCrop.pageIndex === pageIndex
                        ? _findRegionById(pageIndex, outputCrop.regionId)
                        : null;
                    const currentZone = currentCrop ? hitTestSingleRegion(currentCrop, fx, fy) : null;
                    cvs.style.cursor = currentZone ? hitCursor(currentZone) : 'crosshair';
                    return;
                }
                const hit = hitTestAllRegions(pageIndex, fx, fy);
                cvs.style.cursor = hit ? hitCursor(hit.zone) : 'crosshair';
                return;
            }
            if (_cropDrag.pageIndex !== pageIndex) return;

            if (_cropDrag.mode === 'new') {
                _cropDrag.curX = fx;
                _cropDrag.curY = fy;
            } else {
                const dx = fx - _cropDrag.anchorX;
                const dy = fy - _cropDrag.anchorY;
                const o = _cropDrag.origSel;
                const s = { ...o };
                const mode = _cropDrag.mode;

                if (mode === 'move') {
                    s.x = clamp01(o.x + dx, 0, 1 - o.w);
                    s.y = clamp01(o.y + dy, 0, 1 - o.h);
                } else {
                    if (mode.includes('n')) { s.y = clamp01(o.y + dy, 0, o.y + o.h - 0.01); s.h = (o.y + o.h) - s.y; }
                    if (mode.includes('s')) { s.h = clamp01(o.h + dy, 0.01, 1 - o.y); }
                    if (mode.includes('w')) { s.x = clamp01(o.x + dx, 0, o.x + o.w - 0.01); s.w = (o.x + o.w) - s.x; }
                    if (mode.includes('e')) { s.w = clamp01(o.w + dx, 0.01, 1 - o.x); }
                }

                cropSelections[pageIndex][_cropDrag.regionIdx] = s;
            }
            // Throttle redraws to one per animation frame to prevent flickering
            if (!_cropRafId) {
                _cropRafId = requestAnimationFrame(() => {
                    _cropRafId = 0;
                    if (!_cropDrag || _cropDrag.pageIndex !== pageIndex) return;
                    if (_cropDrag.mode === 'new') {
                        drawDragPreview(cvs, pageIndex, _cropDrag);
                    } else {
                        drawAllRegions(cvs, pageIndex);
                    }
                });
            }
            e.preventDefault();
        });

        cvs.addEventListener('mouseup', e => {
            if (!_cropDrag || _cropDrag.pageIndex !== pageIndex) return;
            // Cancel any pending throttled rAF so it doesn't fire after finalization
            if (_cropRafId) { cancelAnimationFrame(_cropRafId); _cropRafId = 0; }
            const { fx, fy } = fracPos(e);

            if (_cropDrag.mode === 'new') {
                _cropDrag.curX = fx;
                _cropDrag.curY = fy;
                const x1 = Math.min(_cropDrag.startX, _cropDrag.curX);
                const y1 = Math.min(_cropDrag.startY, _cropDrag.curY);
                const x2 = Math.max(_cropDrag.startX, _cropDrag.curX);
                const y2 = Math.max(_cropDrag.startY, _cropDrag.curY);
                if (x2 - x1 > 0.01 && y2 - y1 > 0.01) {
                    const newSel = { id: ++_regionIdSeq, x: x1, y: y1, w: x2 - x1, h: y2 - y1 };
                    if (_cropDrag.directCrop) {
                        _applyOutputCropSelection(pageIndex, newSel);
                    } else {
                        if (!cropSelections[pageIndex]) cropSelections[pageIndex] = [];
                        cropSelections[pageIndex].push(newSel);
                    }
                    updateCropClearBtn();
                }
                if (_cropDrag.directCrop) {
                    redrawAllCropOverlays();
                } else {
                    drawAllRegions(cvs, pageIndex);
                }
            } else {
                if (_cropDrag.directCrop && outputCrop) {
                    const edited = cropSelections[pageIndex] && _cropDrag.regionIdx >= 0
                        ? cropSelections[pageIndex][_cropDrag.regionIdx]
                        : null;
                    if (edited) outputCrop = { pageIndex, regionId: edited.id, frac: { x: edited.x, y: edited.y, w: edited.w, h: edited.h } };
                }
                drawAllRegions(cvs, pageIndex);
            }
            _cropDrag = null;
            e.preventDefault();
        });

        // Double-click → delete region under cursor
        cvs.addEventListener('dblclick', e => {
            if (!cropMode) return;
            const { fx, fy } = fracPos(e);
            const hit = hitTestAllRegions(pageIndex, fx, fy);
            if (hit) {
                cropSelections[pageIndex].splice(hit.regionIdx, 1);
                if (cropSelections[pageIndex].length === 0) delete cropSelections[pageIndex];
                updateCropClearBtn();
                drawAllRegions(cvs, pageIndex);
            }
            e.preventDefault();
        });

        cvs.addEventListener('mouseleave', () => {
            if (_cropDrag && _cropDrag.pageIndex === pageIndex) {
                if (_cropRafId) { cancelAnimationFrame(_cropRafId); _cropRafId = 0; }
                drawAllRegions(cvs, pageIndex);
                _cropDrag = null;
            }
        });
    }

    function clamp01(v, min, max) { return Math.max(min, Math.min(max, v)); }

    // Region colours (cycle through for visual distinction)
    const REGION_COLORS = ['#0ea5e9','#f59e0b','#10b981','#f43f5e','#8b5cf6','#06b6d4','#ec4899','#84cc16'];

    // Draw ALL regions for a page (finalized state)
    function drawAllRegions(cvs, pageIndex) {
        const ctx = cvs.getContext('2d');
        const cw = cvs.width, ch = cvs.height;
        ctx.clearRect(0, 0, cw, ch);
        const regions = cropSelections[pageIndex] || [];
        if (regions.length === 0) return;

        const outputRegion = (outputCrop && outputCrop.pageIndex === pageIndex)
            ? _findRegionById(pageIndex, outputCrop.regionId)
            : null;

        if (outputRegion) {
            const ox = outputRegion.x * cw;
            const oy = outputRegion.y * ch;
            const ow = outputRegion.w * cw;
            const oh = outputRegion.h * ch;
            ctx.save();
            ctx.beginPath();
            ctx.rect(0, 0, cw, ch);
            ctx.rect(ox, oy, ow, oh);
            ctx.fillStyle = 'rgba(2, 6, 23, 0.42)';
            ctx.fill('evenodd');
            ctx.restore();

            // Add a subtle bright wash inside the crop so the selected area pops.
            ctx.save();
            ctx.fillStyle = 'rgba(16, 185, 129, 0.10)';
            ctx.fillRect(ox, oy, ow, oh);
            ctx.restore();
        }

        // Keep overlay subtle: no page-wide dimming (only draw within regions)

        // Border + handles + label for each region
        for (let ri = 0; ri < regions.length; ri++) {
            const r = regions[ri];
            const x = r.x * cw, y = r.y * ch, w = r.w * cw, h = r.h * ch;
            const color = REGION_COLORS[ri % REGION_COLORS.length];
            const isOutputCrop = !!(outputCrop && outputCrop.pageIndex === pageIndex && outputCrop.regionId === r.id);

            // Very light fill inside the region
            const cr = parseInt(color.slice(1,3),16), cg = parseInt(color.slice(3,5),16), cb = parseInt(color.slice(5,7),16);
            ctx.fillStyle = isOutputCrop ? 'rgba(16,185,129,0.18)' : `rgba(${cr},${cg},${cb},0.06)`;
            ctx.fillRect(x, y, w, h);

            ctx.strokeStyle = isOutputCrop ? '#10b981' : color;
            ctx.lineWidth = isOutputCrop ? 5 : 2;
            ctx.setLineDash([]);
            ctx.strokeRect(x, y, w, h);

            // Inner dashed line (white) for contrast on dark backgrounds
            ctx.strokeStyle = isOutputCrop ? 'rgba(255,255,255,0.9)' : 'rgba(255,255,255,0.5)';
            ctx.lineWidth = isOutputCrop ? 3 : 1;
            ctx.setLineDash(isOutputCrop ? [] : [4, 4]);
            ctx.strokeRect(x + 2.5, y + 2.5, w - 5, h - 5);
            ctx.setLineDash([]);

            // Output crop highlight
            if (isOutputCrop) {
                // Thick outer white ring.
                ctx.strokeStyle = 'rgba(255,255,255,0.95)';
                ctx.lineWidth = 7;
                ctx.setLineDash([]);
                ctx.strokeRect(x - 4, y - 4, w + 8, h + 8);

                // Thick green border on top.
                ctx.strokeStyle = '#10b981';
                ctx.lineWidth = 5;
                ctx.strokeRect(x - 2.5, y - 2.5, w + 5, h + 5);

                // Soft glow
                ctx.save();
                ctx.shadowColor = 'rgba(16,185,129,0.65)';
                ctx.shadowBlur = 28;
                ctx.strokeStyle = 'rgba(16,185,129,0.85)';
                ctx.lineWidth = 3;
                ctx.strokeRect(x - 1.5, y - 1.5, w + 3, h + 3);
                ctx.restore();

                // Corner markers.
                const cornerLen = Math.max(18, Math.min(42, Math.min(w, h) * 0.12));
                const corners = [
                    [x, y, 1, 1],
                    [x + w, y, -1, 1],
                    [x, y + h, 1, -1],
                    [x + w, y + h, -1, -1]
                ];
                ctx.save();
                ctx.strokeStyle = '#34d399';
                ctx.lineWidth = 6;
                for (const [cx, cy, sx, sy] of corners) {
                    ctx.beginPath();
                    ctx.moveTo(cx, cy + (cornerLen * sy));
                    ctx.lineTo(cx, cy);
                    ctx.lineTo(cx + (cornerLen * sx), cy);
                    ctx.stroke();
                }
                ctx.restore();

                // "CROP" badge
                const badge = `CROP • ${Math.round(r.w * 1000) / 10}% × ${Math.round(r.h * 1000) / 10}%`;
                const fs2 = Math.max(13, Math.min(24, cw * 0.022));
                ctx.font = `bold ${fs2}px sans-serif`;
                const tm2 = ctx.measureText(badge);
                const bw2 = tm2.width + 18, bh2 = fs2 + 12;
                ctx.fillStyle = 'rgba(16,185,129,0.96)';
                ctx.beginPath();
                ctx.roundRect(x + 6, y + 6, bw2, bh2, 5);
                ctx.fill();
                ctx.strokeStyle = 'rgba(255,255,255,0.95)';
                ctx.lineWidth = 2;
                ctx.stroke();
                ctx.fillStyle = '#fff';
                ctx.fillText(badge, x + 14, y + 6 + fs2 + 3);
            }

            drawHandles(ctx, x, y, w, h, cw, ch, isOutputCrop ? '#10b981' : color);

            // Number badge
            const badge = String(ri + 1);
            const fs = Math.max(14, Math.min(26, cw * 0.02));
            ctx.font = `bold ${fs}px sans-serif`;
            const tm = ctx.measureText(badge);
            const bw = tm.width + 10, bh = fs + 6;
            ctx.fillStyle = color;
            ctx.beginPath();
            ctx.roundRect(x + 4, y + 4, bw, bh, 4);
            ctx.fill();
            ctx.fillStyle = '#fff';
            ctx.fillText(badge, x + 9, y + 4 + fs);
        }
    }

    // Preview while dragging a NEW region (renders all existing + the being-drawn one)
    function drawDragPreview(cvs, pageIndex, drag) {
        const ctx = cvs.getContext('2d');
        const cw = cvs.width, ch = cvs.height;
        ctx.clearRect(0, 0, cw, ch);
        const regions = cropSelections[pageIndex] || [];
        const nx = Math.min(drag.startX, drag.curX) * cw;
        const ny = Math.min(drag.startY, drag.curY) * ch;
        const nw = Math.abs(drag.curX - drag.startX) * cw;
        const nh = Math.abs(drag.curY - drag.startY) * ch;

        // Keep overlay subtle: no page-wide dimming

        // Existing regions
        for (let ri = 0; ri < regions.length; ri++) {
            const r = regions[ri];
            const x = r.x * cw, y = r.y * ch, w = r.w * cw, h = r.h * ch;
            const color = REGION_COLORS[ri % REGION_COLORS.length];
            const isOutputCrop = !!(outputCrop && outputCrop.pageIndex === pageIndex && outputCrop.regionId === r.id);
            // Colored fill
            const cr2 = parseInt(color.slice(1,3),16), cg2 = parseInt(color.slice(3,5),16), cb2 = parseInt(color.slice(5,7),16);
            ctx.fillStyle = `rgba(${cr2},${cg2},${cb2},0.06)`;
            ctx.fillRect(x, y, w, h);
            ctx.strokeStyle = color; ctx.lineWidth = isOutputCrop ? 3 : 2; ctx.setLineDash([]); ctx.strokeRect(x,y,w,h);
            ctx.strokeStyle = 'rgba(255,255,255,0.5)'; ctx.lineWidth = 1; ctx.setLineDash([4,4]); ctx.strokeRect(x+1.5,y+1.5,w-3,h-3); ctx.setLineDash([]);

            if (isOutputCrop) {
                ctx.strokeStyle = '#10b981';
                ctx.lineWidth = 3;
                ctx.setLineDash([10, 6]);
                ctx.strokeRect(x - 2, y - 2, w + 4, h + 4);
                ctx.setLineDash([]);
            }
            drawHandles(ctx, x, y, w, h, cw, ch, color);
            const badge = String(ri + 1), fs = Math.max(14, Math.min(26, cw * 0.02));
            ctx.font = `bold ${fs}px sans-serif`;
            const tm = ctx.measureText(badge), bw = tm.width + 10, bh = fs + 6;
            ctx.fillStyle = color; ctx.beginPath(); ctx.roundRect(x+4,y+4,bw,bh,4); ctx.fill();
            ctx.fillStyle = '#fff'; ctx.fillText(badge, x+9, y+4+fs);
        }

        // New (being drawn) region
        const newColor = REGION_COLORS[regions.length % REGION_COLORS.length];
        const nr = parseInt(newColor.slice(1,3),16), ng = parseInt(newColor.slice(3,5),16), nb = parseInt(newColor.slice(5,7),16);
        ctx.fillStyle = `rgba(${nr},${ng},${nb},0.06)`;
        ctx.fillRect(nx, ny, nw, nh);
        ctx.strokeStyle = newColor; ctx.lineWidth = 2; ctx.setLineDash([]); ctx.strokeRect(nx,ny,nw,nh);
        ctx.strokeStyle = 'rgba(255,255,255,0.5)'; ctx.lineWidth = 1; ctx.setLineDash([4,4]); ctx.strokeRect(nx+1.5,ny+1.5,nw-3,nh-3); ctx.setLineDash([]);
        drawHandles(ctx, nx, ny, nw, nh, cw, ch, newColor);
    }

    // Draw 8 grab handles (corners + edge midpoints)
    function drawHandles(ctx, x, y, w, h, cw, ch, color) {
        const pts = [
            [x, y], [x + w, y], [x, y + h], [x + w, y + h],
            [x + w/2, y], [x + w/2, y + h], [x, y + h/2], [x + w, y + h/2]
        ];
        const isOutput = String(color || '').toLowerCase() === '#10b981';
        const hr = isOutput
            ? Math.max(7, Math.min(12, cw * 0.009))
            : Math.max(4, Math.min(8, cw * 0.006));
        ctx.fillStyle = color || '#0ea5e9';
        ctx.strokeStyle = '#ffffff';
        ctx.lineWidth = isOutput ? 2.5 : 1.5;
        ctx.setLineDash([]);
        for (const [px, py] of pts) {
            ctx.beginPath();
            ctx.arc(px, py, hr, 0, Math.PI * 2);
            ctx.fill();
            ctx.stroke();
        }
    }

    // Crop a data-URL image to a fractional region; returns a new data-URL (PNG)
    function cropDataUrl(dataUrl, sel) {
        return new Promise((resolve, reject) => {
            const img = new Image();
            img.onload = () => {
                const sx = Math.round(sel.x * img.width);
                const sy = Math.round(sel.y * img.height);
                const sw = Math.round(sel.w * img.width);
                const sh = Math.round(sel.h * img.height);
                const c = document.createElement('canvas');
                c.width = sw; c.height = sh;
                const ctx = c.getContext('2d');
                ctx.drawImage(img, sx, sy, sw, sh, 0, 0, sw, sh);
                resolve({
                    dataUrl: c.toDataURL('image/png'),
                    imgW: img.width,
                    imgH: img.height,
                    sx, sy,
                    cropW: sw,
                    cropH: sh
                });
            };
            img.onerror = reject;
            img.src = dataUrl;
        });
    }

    // Scale down a data-URL image so the longest side is at most maxPx pixels
    function scaleDownDataUrl(dataUrl, maxPx) {
        return new Promise((resolve, reject) => {
            const img = new Image();
            img.onload = () => {
                const longest = Math.max(img.width, img.height);
                if (longest <= maxPx) {
                    resolve({ dataUrl, scaledW: img.width, scaledH: img.height, didScale: false });
                    return;
                }
                const scale = maxPx / longest;
                const nw = Math.round(img.width * scale);
                const nh = Math.round(img.height * scale);
                const c = document.createElement('canvas');
                c.width = nw; c.height = nh;
                const ctx = c.getContext('2d');
                // Preserve crispness for line-art when downscaling.
                try { ctx.imageSmoothingEnabled = false; } catch { /* ignore */ }
                ctx.drawImage(img, 0, 0, nw, nh);
                resolve({ dataUrl: c.toDataURL('image/png'), scaledW: nw, scaledH: nh, didScale: true });
            };
            img.onerror = reject;
            img.src = dataUrl;
        });
    }

    function getSelectedPdfPreviewDpi() {
        // Preview uses the main PDF-tab DPI when there is no separate preview field.
        const raw = (pdfPreviewDpiEl && typeof pdfPreviewDpiEl.value !== 'undefined')
            ? String(pdfPreviewDpiEl.value || '').trim()
            : ((dpiInput && typeof dpiInput.value !== 'undefined') ? String(dpiInput.value || '').trim() : '');
        const n = parseInt(raw, 10);
        if (!Number.isFinite(n)) return 900;
        return Math.max(50, Math.min(1600, n));
    }

    function getSelectedProcessingDpi() {
        // Used for processing/locate calls. Keep in sync with UI constraints.
        const raw = (dpiInput && typeof dpiInput.value !== 'undefined') ? String(dpiInput.value || '').trim() : '';
        const n = parseInt(raw, 10);
        if (!Number.isFinite(n)) return 900;
        return Math.max(72, Math.min(1600, n));
    }

    async function _ensureHighResSamplePages(minDpi = 1200) {
        const file = _currentPdfPreviewFile;
        const fileKey = _getPdfFileKey(file);
        if (!file || !fileKey) return [];

        const dpi = Math.max(getSelectedPdfPreviewDpi(), getSelectedProcessingDpi(), Math.max(300, Math.min(1200, minDpi | 0)));
        if (_highResSamplePagesKey === fileKey && _highResSamplePagesDpi === dpi && Array.isArray(_highResSamplePages) && _highResSamplePages.length > 0)
            return _highResSamplePages;

        if (_highResSamplePagesPromise && _highResSamplePagesKey === fileKey && _highResSamplePagesDpi === dpi)
            return await _highResSamplePagesPromise;

        _highResSamplePagesKey = fileKey;
        _highResSamplePagesDpi = dpi;
        _highResSamplePagesPromise = (async () => {
            const fd = new FormData();
            fd.append('pdf', file, file.name);
            const qs = new URLSearchParams({ dpi: String(dpi) });

            const resp = await fetch(`${PREVIEW_ENDPOINT}?${qs}`, {
                method: 'POST',
                body: fd,
                headers: { 'X-Client-Id': 'admin' },
                cache: 'no-store'
            });
            const text = await resp.text();
            if (!resp.ok) throw new Error(text || 'Failed to render high-resolution PDF preview');

            const payload = JSON.parse(text);
            const pages = Array.isArray(payload && payload.pages) ? payload.pages : [];
            _highResSamplePages = pages;
            return pages;
        })();

        try {
            return await _highResSamplePagesPromise;
        } finally {
            _highResSamplePagesPromise = null;
        }
    }

    async function _getBestPdfPageSourceForSample(pi) {
        const previewDpi = getSelectedPdfPreviewDpi();
        if (previewDpi >= 1000 && Array.isArray(lastPdfPages) && lastPdfPages[pi])
            return String(lastPdfPages[pi] || '');

        try {
            const pages = await _ensureHighResSamplePages(1200);
            if (Array.isArray(pages) && pages[pi]) return String(pages[pi] || '');
        } catch {
            // Fallback to current preview image.
        }

        return (Array.isArray(lastPdfPages) && lastPdfPages[pi]) ? String(lastPdfPages[pi] || '') : '';
    }

    function _cropDataUrlFromPageSource(src, fx, fy, fw, fh) {
        return new Promise((resolve, reject) => {
            if (!src) { resolve(''); return; }
            const img = new Image();
            img.crossOrigin = 'anonymous';
            img.onload = () => {
                try {
                    const cw = Math.round(fw * img.naturalWidth);
                    const ch = Math.round(fh * img.naturalHeight);
                    const cx = Math.round(fx * img.naturalWidth);
                    const cy = Math.round(fy * img.naturalHeight);
                    if (cw < 4 || ch < 4) { resolve(''); return; }

                    const cv = document.createElement('canvas');
                    cv.width = cw;
                    cv.height = ch;
                    const ctx2 = cv.getContext('2d');
                    if (!ctx2) { resolve(''); return; }
                    ctx2.imageSmoothingEnabled = true;
                    ctx2.imageSmoothingQuality = 'high';
                    ctx2.drawImage(img, cx, cy, cw, ch, 0, 0, cw, ch);
                    resolve(cv.toDataURL('image/png'));
                } catch (err) {
                    reject(err);
                }
            };
            img.onerror = reject;
            img.src = src;
        });
    }

    function _getPdfFileKey(file) {
        if (!file) return null;
        const name = file.name || '';
        const size = (typeof file.size === 'number') ? file.size : 0;
        const lm = (typeof file.lastModified === 'number') ? file.lastModified : 0;
        return `${name}|${size}|${lm}`;
    }

    function _schedulePdfPreviewRerender() {
        if (!_currentPdfPreviewFile) return;
        if (_pdfPreviewDpiTimer) clearTimeout(_pdfPreviewDpiTimer);
        _pdfPreviewDpiTimer = setTimeout(() => {
            renderPdfPreview(_currentPdfPreviewFile, { preserveRegions: true, preserveZoom: true, autoDetectColors: false });
        }, 250);
    }

    if (pdfPreviewDpiEl) {
        pdfPreviewDpiEl.addEventListener('input', () => {
            const dpi = getSelectedPdfPreviewDpi();
            pdfPreviewDpiEl.value = String(dpi);
            if (dpiInput) {
                const proc = Math.max(72, Math.min(1600, dpi));
                dpiInput.value = String(proc);
            }
            _schedulePdfPreviewRerender();
        });
    }
    if (dpiInput) {
        dpiInput.addEventListener('input', () => {
            const proc = getSelectedProcessingDpi();
            dpiInput.value = String(proc);
            if (pdfPreviewDpiEl) {
                const prev = Math.max(50, Math.min(1600, proc));
                pdfPreviewDpiEl.value = String(prev);
            }
            _schedulePdfPreviewRerender();
        });
    }

    // Initial clamp for the main DPI field.
    try {
        const proc = Math.max(72, Math.min(1200, getSelectedProcessingDpi() || 600));
        if (dpiInput) dpiInput.value = String(proc);
        if (pdfPreviewDpiEl) pdfPreviewDpiEl.value = String(Math.max(50, Math.min(1200, proc)));
    } catch { /* ignore */ }

    // ── PDF Preview ──

    // ═══════ SVG Layer Decomposition ═══════
    // Split vectorised SVG into layers based on user-defined colors.
    // If the user defined color layers, use those. Otherwise, auto-detect.
    function decomposeSvgIntoLayers(svgText) {
        const parser  = new DOMParser();
        const doc     = parser.parseFromString(svgText, 'image/svg+xml');
        const svgRoot = doc.querySelector('svg');
        if (!svgRoot) return [{ layerName: 'Full SVG', color: null, svgContent: svgText }];

        const vb = svgRoot.getAttribute('viewBox') || '';
        const w  = svgRoot.getAttribute('width')   || '';
        const h  = svgRoot.getAttribute('height')  || '';

        const defsEl = svgRoot.querySelector('defs');
        const defsHtml = defsEl ? defsEl.outerHTML : '';

        const ELS_SELECTOR = 'path, rect, circle, ellipse, line, polyline, polygon';
        const allEls   = [...svgRoot.querySelectorAll(ELS_SELECTOR)].filter(el => { try { return !el.closest('defs'); } catch { return true; } });
        const allTextNodes = [...svgRoot.querySelectorAll('text')].filter(el => { try { return !el.closest('defs'); } catch { return true; } });
        const allUseNodes = [...svgRoot.querySelectorAll('use')].filter(el => { try { return !el.closest('defs'); } catch { return true; } });
        // When merge-before-split is enabled, skip the HIDE EXACT LABELS / LANGUAGES filter — keep all text
        const _skipDecomposeTextFilter = !!_pdfPreSplitMergeEnabled;
        const allTexts = _skipDecomposeTextFilter ? [...allTextNodes] : allTextNodes.filter(el => {
            const text = (el.textContent || '').replace(/\s+/g, ' ').trim();
            return _isVisiblePdfTextLabel(text);
        });
        const ignoredTexts = _skipDecomposeTextFilter ? [] : allTextNodes.filter(el => {
            const text = (el.textContent || '').replace(/\s+/g, ' ').trim();
            return !_isVisiblePdfTextLabel(text);
        });

        // Compute bounding-box area fraction for each element (to avoid large filled regions
        // being pulled into color layers and making them look like the original raster).
        const areaFracs = (() => {
            let vbW = 0, vbH = 0;
            if (vb) {
                const parts = vb.trim().split(/[\s,]+/).map(Number);
                if (parts.length === 4 && parts.every(n => isFinite(n))) {
                    vbW = Math.abs(parts[2]);
                    vbH = Math.abs(parts[3]);
                }
            }
            if (!vbW || !vbH) {
                const wNum = parseFloat(String(w).replace(/[a-z%]+/gi, ''));
                const hNum = parseFloat(String(h).replace(/[a-z%]+/gi, ''));
                if (isFinite(wNum) && isFinite(hNum) && wNum > 0 && hNum > 0) {
                    vbW = wNum; vbH = hNum;
                }
            }
            const totalArea = (vbW > 0 && vbH > 0) ? (vbW * vbH) : 0;
            if (!totalArea || allEls.length === 0) return new Array(allEls.length).fill(0);

            const host = document.createElement('div');
            host.style.position = 'absolute';
            host.style.left = '-10000px';
            host.style.top = '-10000px';
            host.style.width = '0';
            host.style.height = '0';
            host.style.overflow = 'hidden';
            host.style.visibility = 'hidden';

            const renderSvg = svgRoot.cloneNode(true);
            // Ensure it has a viewBox/size so getBBox works consistently
            if (vb) renderSvg.setAttribute('viewBox', vb);
            if (w) renderSvg.setAttribute('width', w);
            if (h) renderSvg.setAttribute('height', h);

            host.appendChild(renderSvg);
            document.body.appendChild(host);

            const renderEls = [...renderSvg.querySelectorAll(ELS_SELECTOR)];
            const fracs = new Array(allEls.length).fill(0);
            const n = Math.min(renderEls.length, allEls.length);

            for (let i = 0; i < n; i++) {
                try {
                    const bb = renderEls[i].getBBox();
                    if (bb && isFinite(bb.width) && isFinite(bb.height) && bb.width > 0 && bb.height > 0) {
                        fracs[i] = Math.min(1, (bb.width * bb.height) / totalArea);
                    }
                } catch {
                    // ignore
                }
            }

            try { host.remove(); } catch { try { document.body.removeChild(host); } catch { /* ignore */ } }
            return fracs;
        })();

        const layers = [];

        // Shape detection runs first and claims elements so they don't also land in colour/other buckets.
        const shapeTaken = new Set();
        const shapeLayers = [];

        // 1) Full composite always first
        layers.push({
            layerName: `🖼️ Full SVG (all layers) (0)`,
            color: null,
            svgContent: svgText,
            icon: 'fa-layer-group',
            objectCount: 0
        });

        // ── User-defined color layers (each layer may have multiple colors) ──
        const activeLayers = colorLayerDefs.filter(d => d.enabled !== false && d.colors && d.colors.length > 0);
        const matched = new Set();  // track which elements already matched a user-defined layer

        // ── Heuristic layers (circles/arrows/light hatch strokes) — claim elements early ──
        (function detectHeuristicShapeLayers() {
            const insertLayerObj = (layerObj) => {
                if (layerObj) shapeLayers.push(layerObj);
            };

            const circleIdx = [];
            const arrowIdx = [];
            const repeatedStrokeBuckets = new Map();

            const parseNum = (v) => {
                if (v == null) return NaN;
                const s = String(v).trim();
                if (!s) return NaN;
                const n = parseFloat(s.replace(',', '.'));
                return isFinite(n) ? n : NaN;
            };

            // Use both explicit attributes/inline style and computed style (handles class-based CSS in <style>)
            const getInheritedProp = (el, prop, renderEl, computedPropCamel) => {
                const direct = el.getAttribute(prop);
                if (direct && direct.trim() !== '') return direct.trim();
                const style = el.getAttribute('style') || '';
                if (style) {
                    const re = new RegExp(`${prop}\\s*:\\s*([^;]+)`, 'i');
                    const m = style.match(re);
                    if (m && (m[1] || '').trim()) return (m[1] || '').trim();
                }
                let parent = el.parentElement;
                while (parent && parent.tagName !== 'svg') {
                    const pd = parent.getAttribute(prop);
                    if (pd && pd.trim() !== '') return pd.trim();
                    const ps = parent.getAttribute('style') || '';
                    if (ps) {
                        const re2 = new RegExp(`${prop}\\s*:\\s*([^;]+)`, 'i');
                        const m2 = ps.match(re2);
                        if (m2 && (m2[1] || '').trim()) return (m2[1] || '').trim();
                    }
                    parent = parent.parentElement;
                }

                if (renderEl) {
                    try {
                        const cs = window.getComputedStyle(renderEl);
                        const v = computedPropCamel ? cs[computedPropCamel] : cs.getPropertyValue(prop);
                        const s = String(v || '').trim();
                        if (s && s !== 'initial' && s !== 'inherit' && s !== 'unset') return s;
                    } catch {
                        // ignore
                    }
                }
                return null;
            };

            const isTrianglePolygon = (el) => {
                if (!el || (el.tagName || '').toLowerCase() !== 'polygon') return false;
                const pts = String(el.getAttribute('points') || '').trim();
                if (!pts) return false;
                const nums = pts.split(/[^0-9eE+\-\.]+/).filter(Boolean).map(Number).filter(n => isFinite(n));
                const pairs = Math.floor(nums.length / 2);
                return pairs === 3;
            };

            const angleDeg = (dx, dy) => {
                const a = Math.atan2(dy, dx) * 180 / Math.PI;
                let deg = Math.abs(a);
                while (deg < 0) deg += 180;
                while (deg >= 180) deg -= 180;
                return deg;
            };

            // Render a hidden clone so computed styles are available (classes in <style> etc.)
            const renderHost = document.createElement('div');
            renderHost.style.position = 'absolute';
            renderHost.style.left = '-10000px';
            renderHost.style.top = '-10000px';
            renderHost.style.width = '0';
            renderHost.style.height = '0';
            renderHost.style.overflow = 'hidden';
            renderHost.style.visibility = 'hidden';

            const renderSvg = svgRoot.cloneNode(true);
            if (vb) renderSvg.setAttribute('viewBox', vb);
            if (w) renderSvg.setAttribute('width', w);
            if (h) renderSvg.setAttribute('height', h);
            renderHost.appendChild(renderSvg);
            document.body.appendChild(renderHost);
            const renderEls = [...renderSvg.querySelectorAll(ELS_SELECTOR)];

            const getProp = (i, el, prop, computedPropCamel) => {
                const re = (i >= 0 && i < renderEls.length) ? renderEls[i] : null;
                return getInheritedProp(el, prop, re, computedPropCamel);
            };

            const hasMarkerAt = (i, el) => {
                const me = getProp(i, el, 'marker-end', 'markerEnd');
                const ms = getProp(i, el, 'marker-start', 'markerStart');
                const mm = getProp(i, el, 'marker-mid', 'markerMid');
                return (me && me !== 'none') || (ms && ms !== 'none') || (mm && mm !== 'none');
            };

            const getBBoxMetrics = (i) => {
                const re = (i >= 0 && i < renderEls.length) ? renderEls[i] : null;
                if (!re) return null;
                try {
                    const bb = re.getBBox();
                    if (!bb || !isFinite(bb.width) || !isFinite(bb.height) || bb.width <= 0 || bb.height <= 0) return null;
                    const parts = vb ? vb.trim().split(/[\s,]+/).map(Number) : [];
                    const vbW = (parts.length === 4 && parts.every(n => isFinite(n))) ? Math.abs(parts[2]) : NaN;
                    const vbH = (parts.length === 4 && parts.every(n => isFinite(n))) ? Math.abs(parts[3]) : NaN;
                    return {
                        width: bb.width,
                        height: bb.height,
                        widthFrac: (isFinite(vbW) && vbW > 0) ? (bb.width / vbW) : 0,
                        heightFrac: (isFinite(vbH) && vbH > 0) ? (bb.height / vbH) : 0
                    };
                } catch {
                    return null;
                }
            };

            const isLikelyPatternNeutralStroke = (rgb) => {
                if (!rgb || !isNeutralRgb(rgb)) return false;
                const luma = _rgbLuma(rgb);
                // Include dark neutral strokes too: many CAD hatch/pattern regions are exported
                // as dense black/gray line-work rather than filled polygons.
                return luma >= 12 && luma <= 242;
            };

            const parsePointPairs = (raw) => {
                const nums = String(raw || '').trim().split(/[^0-9eE+\-\.]+/).filter(Boolean).map(Number).filter(n => isFinite(n));
                const pts = [];
                for (let pi = 0; pi + 1 < nums.length; pi += 2) pts.push({ x: nums[pi], y: nums[pi + 1] });
                return pts;
            };

            const normalizeDasharray = (raw) => {
                const s = String(raw || '').trim().toLowerCase();
                if (!s || s === 'none' || s === '0' || s === '0 0') return 'solid';
                const parts = s.split(/[\s,]+/).map(parseNum).filter(n => isFinite(n) && n > 0.01).map(n => String(Math.round(n * 10) / 10));
                return parts.length ? parts.join(' ') : 'solid';
            };

            const describeDasharray = (dasharray) => {
                if (!dasharray || dasharray === 'solid') return '';
                const nums = dasharray.split(/[\s,]+/).map(parseNum).filter(n => isFinite(n) && n > 0);
                if (!nums.length) return '';
                if (nums.length <= 2 && nums[0] <= 1.8) return ' dotted';
                return ' dashed';
            };

            const describeTone = (rgb) => {
                const luma = rgb ? _rgbLuma(rgb) : 0;
                if (luma >= 210) return 'very light gray';
                if (luma >= 175) return 'light gray';
                if (luma >= 135) return 'gray';
                return 'dark gray';
            };

            const angleBucketInfo = (angle) => {
                if (!isFinite(angle)) return { key: 'mixed', label: 'mixed angle' };
                const a = ((angle % 180) + 180) % 180;
                if (a <= 12 || a >= 168) return { key: 'horizontal', label: 'horizontal' };
                if (a >= 78 && a <= 102) return { key: 'vertical', label: 'vertical' };
                if (a >= 25 && a <= 65) return { key: 'diag45', label: '45° diagonal' };
                if (a >= 115 && a <= 155) return { key: 'diag135', label: '135° diagonal' };
                return { key: 'angled', label: `${Math.round(a)}° angled` };
            };

            const estimateStrokeMetrics = (i, el, bbox) => {
                const tag = String(el && el.tagName || '').toLowerCase();
                const metricsFromSegment = (dx, dy) => {
                    const length = Math.hypot(dx, dy);
                    const angle = length > 0.0001 ? angleDeg(dx, dy) : NaN;
                    return { length, angle };
                };

                if (tag === 'line') {
                    const x1 = parseNum(el.getAttribute('x1'));
                    const y1 = parseNum(el.getAttribute('y1'));
                    const x2 = parseNum(el.getAttribute('x2'));
                    const y2 = parseNum(el.getAttribute('y2'));
                    if ([x1, y1, x2, y2].every(n => isFinite(n))) {
                        const seg = metricsFromSegment(x2 - x1, y2 - y1);
                        const major = Math.max(bbox?.width || 0, bbox?.height || 0, seg.length || 0);
                        const minor = Math.min(Math.max(0.0001, bbox?.width || 0.0001), Math.max(0.0001, bbox?.height || 0.0001));
                        return { length: major, angle: seg.angle, aspect: major / Math.max(0.0001, minor) };
                    }
                }

                if (tag === 'polyline' || tag === 'polygon') {
                    const pts = parsePointPairs(el.getAttribute('points'));
                    let best = null;
                    for (let pi = 1; pi < pts.length; pi++) {
                        const seg = metricsFromSegment(pts[pi].x - pts[pi - 1].x, pts[pi].y - pts[pi - 1].y);
                        if (!best || seg.length > best.length) best = seg;
                    }
                    if (tag === 'polygon' && pts.length >= 3) {
                        const closing = metricsFromSegment(pts[0].x - pts[pts.length - 1].x, pts[0].y - pts[pts.length - 1].y);
                        if (!best || closing.length > best.length) best = closing;
                    }
                    if (best) {
                        const major = Math.max(bbox?.width || 0, bbox?.height || 0, best.length || 0);
                        const minor = Math.min(Math.max(0.0001, bbox?.width || 0.0001), Math.max(0.0001, bbox?.height || 0.0001));
                        return { length: major, angle: best.angle, aspect: major / Math.max(0.0001, minor) };
                    }
                }

                if (tag === 'path') {
                    const pts = parsePointPairs(el.getAttribute('d'));
                    let best = null;
                    for (let pi = 1; pi < pts.length; pi++) {
                        const seg = metricsFromSegment(pts[pi].x - pts[pi - 1].x, pts[pi].y - pts[pi - 1].y);
                        if (!best || seg.length > best.length) best = seg;
                    }
                    if (best && best.length > 0.0001) {
                        const major = Math.max(bbox?.width || 0, bbox?.height || 0, best.length || 0);
                        const minor = Math.min(Math.max(0.0001, bbox?.width || 0.0001), Math.max(0.0001, bbox?.height || 0.0001));
                        return { length: major, angle: best.angle, aspect: major / Math.max(0.0001, minor) };
                    }
                }

                if (bbox) {
                    const major = Math.max(bbox.width || 0, bbox.height || 0);
                    const minor = Math.min(Math.max(0.0001, bbox.width || 0.0001), Math.max(0.0001, bbox.height || 0.0001));
                    let angle = NaN;
                    if ((bbox.width || 0) >= (bbox.height || 0) * 2.5) angle = 0;
                    else if ((bbox.height || 0) >= (bbox.width || 0) * 2.5) angle = 90;
                    return { length: major, angle, aspect: major / Math.max(0.0001, minor) };
                }

                return null;
            };

            for (let i = 0; i < allEls.length; i++) {
                if (shapeTaken.has(i)) continue;
                const el = allEls[i];
                const tag = (el.tagName || '').toLowerCase();
                const aFrac = areaFracs[i] || 0;

                // Detectors / circles
                if (tag === 'circle' || tag === 'ellipse') {
                    bakeInheritedPaint(el);
                    circleIdx.push(i);
                    shapeTaken.add(i);
                    continue;
                }

                // Circle/ellipse drawn as a path with arc commands (common in PDF->SVG)
                if (tag === 'path') {
                    const d = String(el.getAttribute('d') || '').trim();
                    if (aFrac > 0 && aFrac <= 0.01 && /[Aa]/.test(d) && /[Zz]\s*$/.test(d)) {
                        const arcs = [];
                        const reArc = /[Aa]\s*([\-\d\.eE]+)[\s,]+([\-\d\.eE]+)/g;
                        let mArc;
                        while ((mArc = reArc.exec(d)) !== null) {
                            const rx = parseNum(mArc[1]);
                            const ry = parseNum(mArc[2]);
                            if (isFinite(rx) && isFinite(ry) && rx > 0 && ry > 0) arcs.push({ rx, ry });
                            if (arcs.length >= 6) break;
                        }
                        if (arcs.length >= 2) {
                            const r0 = arcs[0];
                            const ratio = r0.ry ? (r0.rx / r0.ry) : 0;
                            if (ratio > 0.85 && ratio < 1.15) {
                                bakeInheritedPaint(el);
                                circleIdx.push(i);
                                shapeTaken.add(i);
                                continue;
                            }
                        }
                    }
                }

                // Arrows
                if (hasMarkerAt(i, el) || isTrianglePolygon(el)) {
                    bakeInheritedPaint(el);
                    arrowIdx.push(i);
                    shapeTaken.add(i);
                    continue;
                }

                // Repeated neutral thin strokes often represent hatching/pattern fills
                // or compact disposable line-work clusters. Split them out early so they do
                // not get mixed into the generic Other bucket.
                const strokeRaw = getProp(i, el, 'stroke', 'stroke');
                const strokeRgb = resolveColor(strokeRaw || '');
                if (!isLikelyPatternNeutralStroke(strokeRgb)) continue;

                const fillRaw = getProp(i, el, 'fill', 'fill');
                const fillRgb = resolveColor(fillRaw || '');
                if (fillRgb && !isNeutralRgb(fillRgb) && _rgbLuma(fillRgb) < 235) continue;

                const strokeWidthRaw = getProp(i, el, 'stroke-width', 'strokeWidth');
                const strokeWidth = parseNum(strokeWidthRaw);
                const effectiveStrokeWidth = (isFinite(strokeWidth) && strokeWidth > 0) ? strokeWidth : 1;
                if (effectiveStrokeWidth > 1.6) continue;

                const bbox = getBBoxMetrics(i);
                if (!bbox) continue;
                const maxSideFrac = Math.max(bbox.widthFrac || 0, bbox.heightFrac || 0);
                if (aFrac > 0.0035 || maxSideFrac > 0.12) continue;

                const metrics = estimateStrokeMetrics(i, el, bbox);
                if (!metrics) continue;
                if (!isFinite(metrics.aspect) || metrics.aspect < 1.8) continue;
                const lengthFrac = Math.max(bbox.widthFrac || 0, bbox.heightFrac || 0);
                const angleInfo = angleBucketInfo(metrics.angle);
                const dasharray = normalizeDasharray(getProp(i, el, 'stroke-dasharray', 'strokeDasharray'));
                const toneLabel = describeTone(strokeRgb);

                let family = 'pattern';
                if ((angleInfo.key === 'diag45' || angleInfo.key === 'diag135') && metrics.aspect >= 2.2) {
                    family = 'hatch';
                } else if (lengthFrac <= 0.028 && metrics.aspect >= 2.4 && (angleInfo.key === 'horizontal' || angleInfo.key === 'vertical' || angleInfo.key === 'angled')) {
                    family = 'ticks';
                }

                const strokeHex = rgbToHex(strokeRgb);
                const bucketStrokeWidth = Math.max(0.25, Math.round(effectiveStrokeWidth * 4) / 4);
                const bucketKey = `${family}|${strokeHex}|${bucketStrokeWidth.toFixed(2)}|${dasharray}|${angleInfo.key}`;
                let bucket = repeatedStrokeBuckets.get(bucketKey);
                if (!bucket) {
                    bucket = {
                        idx: [],
                        family,
                        strokeHex,
                        strokeWidth: bucketStrokeWidth,
                        dasharray,
                        angleKey: angleInfo.key,
                        angleLabel: angleInfo.label,
                        toneLabel,
                        lengthFracSum: 0,
                        aspectSum: 0
                    };
                    repeatedStrokeBuckets.set(bucketKey, bucket);
                }
                bucket.idx.push(i);
                bucket.lengthFracSum += lengthFrac;
                bucket.aspectSum += metrics.aspect;
            }

            try { renderHost.remove(); } catch { try { document.body.removeChild(renderHost); } catch { /* ignore */ } }

            const pickOuter = (idxArr) => idxArr.map(i => allEls[i].outerHTML);

            if (circleIdx.length > 0) {
                insertLayerObj({
                    layerName: `⭕ Detectors / Circles (${circleIdx.length})`,
                    color: null,
                    svgContent: wrapPaths(pickOuter(circleIdx), vb, w, h, defsHtml),
                    icon: 'fa-circle-dot',
                    objectCount: circleIdx.length
                });
            }

            if (arrowIdx.length > 0) {
                insertLayerObj({
                    layerName: `➡️ Arrows (${arrowIdx.length})`,
                    color: null,
                    svgContent: wrapPaths(pickOuter(arrowIdx), vb, w, h, defsHtml),
                    icon: 'fa-arrow-right',
                    objectCount: arrowIdx.length
                });
            }

            const repeatedStrokeGroups = [...repeatedStrokeBuckets.values()]
                .filter(g => {
                    if (!Array.isArray(g.idx)) return false;
                    const minCount = g.family === 'ticks' ? 6 : (g.family === 'hatch' ? 8 : 10);
                    return g.idx.length >= minCount;
                })
                .sort((a, b) => b.idx.length - a.idx.length)
                .slice(0, 6);

            for (const group of repeatedStrokeGroups) {
                for (const idx of group.idx) {
                    bakeInheritedPaint(allEls[idx]);
                    shapeTaken.add(idx);
                }
                const dashLabel = describeDasharray(group.dasharray);
                const avgLengthFrac = group.idx.length ? (group.lengthFracSum / group.idx.length) : 0;
                const title = group.family === 'ticks'
                    ? `┆ Ticks · ${group.angleLabel}${dashLabel} (${group.idx.length})`
                    : (group.family === 'hatch'
                        ? `░ Diagonal hatch · ${group.angleLabel}${dashLabel} (${group.idx.length})`
                        : `≋ ${group.toneLabel} stroke pattern · ${group.angleLabel}${dashLabel} (${group.idx.length})`);
                insertLayerObj({
                    layerName: title,
                    color: group.strokeHex,
                    svgContent: wrapPaths(pickOuter(group.idx), vb, w, h, defsHtml),
                    icon: group.family === 'ticks' ? 'fa-grip-lines-vertical' : (group.family === 'hatch' ? 'fa-slash' : 'fa-grip-lines'),
                    objectCount: group.idx.length,
                    isHatchApproxLayer: true,
                    hatchFamily: group.family,
                    hatchAngle: group.angleLabel,
                    hatchDash: group.dasharray,
                    hatchAvgLengthFrac: avgLengthFrac
                });
            }
        })();

        // Helper: bake inherited paint onto an element so it survives extraction
        function bakeInheritedPaint(el) {
            for (const prop of ['fill', 'stroke']) {
                const own = el.getAttribute(prop);
                if (!own || own.trim() === '') {
                    const inherited = getRawPaint(el, prop);
                    if (inherited != null && String(inherited).trim() !== '') {
                        el.setAttribute(prop, inherited);
                    }
                }
            }
        }

        // Helpers: classify colors
        function isNeutral(rgb) {
            if (!rgb) return true;
            const hsl = rgbToHsl(rgb.r, rgb.g, rgb.b);
            const maxc = Math.max(rgb.r, rgb.g, rgb.b);
            const minc = Math.min(rgb.r, rgb.g, rgb.b);
            const range = maxc - minc;
            // Neutral if low saturation OR small channel range OR near-white/near-black
            if (hsl.l <= 0.06 || hsl.l >= 0.96) return true;
            if (hsl.s < 0.12) return true;
            if (range < 18) return true;
            return false;
        }

        // "Strong" color = visually chromatic enough that we should not silently hide it in Other.
        // Pastel / low-chroma background tints are treated as neutral-ish noise for the purposes of
        // the Unmatched bucket (they will go to Other).
        function isStrongColor(rgb) {
            if (!rgb) return false;
            const hsl = rgbToHsl(rgb.r, rgb.g, rgb.b);
            const maxc = Math.max(rgb.r, rgb.g, rgb.b);
            const minc = Math.min(rgb.r, rgb.g, rgb.b);
            const range = maxc - minc;
            if (hsl.l <= 0.08 || hsl.l >= 0.92) return false;
            if (hsl.s < 0.22) return false;
            if (range < 30) return false;
            return true;
        }

        function pickPaintRgb(fillRgb, strokeRgb) {
            // Prefer a non-neutral paint if present
            if (fillRgb && !isNeutral(fillRgb)) return fillRgb;
            if (strokeRgb && !isNeutral(strokeRgb)) return strokeRgb;
            return fillRgb || strokeRgb || null;
        }

        if (activeLayers.length > 0) {
            // Prepare layer work buckets so we can add "near misses" later.
            const layerWork = activeLayers.map(def => {
                const targets = (def.colors || []).map(c => ({ rgb: hexToRgb(c.color), tol: c.tolerance || 60 })).filter(t => t.rgb);
                const label = def.label || (def.colors || []).map(c => c.color).join('+');
                return { def, targets, label, hits: [] };
            }).filter(w => w.targets.length > 0);

            // Pass 1: strict matches (respect tolerance + large-fill guard).
            for (const w of layerWork) {
                for (let ei = 0; ei < allEls.length; ei++) {
                    if (shapeTaken.has(ei)) continue;
                    const el = allEls[ei];
                    const fill   = getPaint(el, 'fill');
                    const stroke = getPaint(el, 'stroke');

                    const aFrac = areaFracs[ei] || 0;
                    const strokeMatches = w.targets.some(t => colorMatchesTarget(stroke, t.rgb, t.tol));
                    // Prefer stroke; only allow fill matching when the element is "small".
                    // This prevents huge filled background regions from polluting the color layers.
                    const fillAllowed = aFrac <= 0.02;
                    const fillMatches = fillAllowed && w.targets.some(t => colorMatchesTarget(fill, t.rgb, t.tol));
                    const matchesAny = strokeMatches || fillMatches;
                    if (matchesAny) {
                        bakeInheritedPaint(el);
                        w.hits.push(el.outerHTML);
                        matched.add(ei);
                    }
                }
            }

            // Pass 2: route remaining strongly-colored elements to the nearest layer (no Unmatched bucket).
            for (let ei = 0; ei < allEls.length; ei++) {
                if (matched.has(ei)) continue;
                if (shapeTaken.has(ei)) continue;
                const el = allEls[ei];
                const fill   = getPaint(el, 'fill');
                const stroke = getPaint(el, 'stroke');
                const paint = pickPaintRgb(fill, stroke);
                if (!paint || !isStrongColor(paint)) continue;

                let bestIdx = -1;
                let bestDist = Infinity;
                for (let li = 0; li < layerWork.length; li++) {
                    const w = layerWork[li];
                    for (const t of w.targets) {
                        const d = colorDistance(paint, t.rgb);
                        if (d < bestDist) {
                            bestDist = d;
                            bestIdx = li;
                        }
                    }
                }

                if (bestIdx >= 0 && isFinite(bestDist)) {
                    bakeInheritedPaint(el);
                    layerWork[bestIdx].hits.push(el.outerHTML);
                    matched.add(ei);
                }
            }

            // Emit layer SVGs after both passes.
            for (const lw of layerWork) {
                if (lw.hits.length === 0) continue;
                layers.push({
                    layerName: `🎨 ${lw.label} (${lw.hits.length})`,
                    color: lw.def.colors[0].color,
                    svgContent: wrapPaths(lw.hits, vb, w, h, defsHtml),
                    icon: 'fa-palette',
                    objectCount: lw.hits.length
                });
            }

            // Remaining unmatched elements → Background / Neutral line-work / Small signs / Other
            const thresholds = _getSvgResidualThresholds(vb, w, h);
            const backgroundHits = [];
            const neutralDarkHits = [];   // black/near-black neutral strokes (base drawing)
            const neutralLightHits = [];  // gray/light neutral strokes (grid/dim lines)
            const smallSignHits = [];
            const otherHits = [];
            for (let i = 0; i < allEls.length; i++) {
                if (matched.has(i)) continue;
                if (shapeTaken.has(i)) continue;
                const el = allEls[i];
                bakeInheritedPaint(el);

                if (_isBackgroundLikeSvgElement(el, areaFracs[i] || 0)) {
                    backgroundHits.push(el.outerHTML);
                    continue;
                }
                if (_isSmallResidualSvgElement(el, thresholds)) {
                    smallSignHits.push(el.outerHTML);
                    continue;
                }

                // Separate neutral-colored elements (black/gray line-work of base drawing)
                // from truly "other" chromatic leftovers.
                const _fill = getPaint(el, 'fill');
                const _stroke = getPaint(el, 'stroke');
                const _paint = pickPaintRgb(_fill, _stroke);
                const _elIsNeutral = !_paint || isNeutral(_paint);
                if (_elIsNeutral) {
                    const _luma = _paint ? _rgbLuma(_paint) : 0;
                    if (_luma < 128) {
                        neutralDarkHits.push(el.outerHTML);
                    } else {
                        neutralLightHits.push(el.outerHTML);
                    }
                    continue;
                }

                otherHits.push(el.outerHTML);
            }

            if (backgroundHits.length > 0) {
                layers.push({
                    layerName: `⬜ Background / fills (${backgroundHits.length})`,
                    color: '#e5e7eb',
                    svgContent: wrapPaths(backgroundHits, vb, w, h, defsHtml),
                    icon: 'fa-layer-group',
                    objectCount: backgroundHits.length
                });
            }

            if (neutralDarkHits.length > 0) {
                layers.push({
                    layerName: `⬛ Base line-work / dark (${neutralDarkHits.length})`,
                    color: '#374151',
                    svgContent: wrapPaths(neutralDarkHits, vb, w, h, defsHtml),
                    icon: 'fa-pencil-ruler',
                    objectCount: neutralDarkHits.length,
                    isNeutralLineWork: true
                });
            }

            if (neutralLightHits.length > 0) {
                layers.push({
                    layerName: `⬜ Grid / light line-work (${neutralLightHits.length})`,
                    color: '#9ca3af',
                    svgContent: wrapPaths(neutralLightHits, vb, w, h, defsHtml),
                    icon: 'fa-border-all',
                    objectCount: neutralLightHits.length,
                    isNeutralLineWork: true
                });
            }

            if (smallSignHits.length > 0) {
                layers.push({
                    layerName: `🧹 Small signs / symbols (${smallSignHits.length})`,
                    color: '#f59e0b',
                    svgContent: wrapPaths(smallSignHits, vb, w, h, defsHtml),
                    icon: 'fa-broom',
                    objectCount: smallSignHits.length
                });
            }

            if (otherHits.length > 0) {
                layers.push({
                    layerName: `⬜ Other elements (${otherHits.length})`,
                    color: '#64748b',
                    svgContent: wrapPaths(otherHits, vb, w, h, defsHtml),
                    icon: 'fa-shapes',
                    objectCount: otherHits.length
                });
            }

            if (ignoredTexts.length > 0) {
                _appendElementsToOtherLayer(layers, ignoredTexts.map(t => t.outerHTML), vb, w, h, defsHtml);
            }
        } else {
            // ── Auto mode: group by color ──
            const thresholds = _getSvgResidualThresholds(vb, w, h);
            const backgroundHits = [];
            const smallSignHits = [];
            const colourBuckets = {};
            for (let ei = 0; ei < allEls.length; ei++) {
                if (shapeTaken.has(ei)) continue;
                const el = allEls[ei];
                bakeInheritedPaint(el);
                if (_isBackgroundLikeSvgElement(el, areaFracs[ei] || 0)) {
                    backgroundHits.push(el.outerHTML);
                    continue;
                }
                if (_isSmallResidualSvgElement(el, thresholds)) {
                    smallSignHits.push(el.outerHTML);
                    continue;
                }
                const fill   = normaliseColour(getRawPaint(el, 'fill') || '');
                const stroke = normaliseColour(getRawPaint(el, 'stroke') || '');
                const bucketKey = (fill && fill !== 'none') ? fill : (stroke || 'none');
                if (!colourBuckets[bucketKey]) colourBuckets[bucketKey] = [];
                colourBuckets[bucketKey].push(el.outerHTML);
            }
            const sortedKeys = Object.keys(colourBuckets).sort((a, b) => colourBuckets[b].length - colourBuckets[a].length);
            for (const key of sortedKeys) {
                if (key === 'none' || colourBuckets[key].length < 2) continue;
                layers.push({
                    layerName: `🎨 Color: ${key} (${colourBuckets[key].length})`,
                    color: key,
                    svgContent: wrapPaths(colourBuckets[key], vb, w, h, defsHtml),
                    icon: 'fa-palette',
                    objectCount: colourBuckets[key].length
                });
            }

            if (backgroundHits.length > 0) {
                layers.push({
                    layerName: `⬜ Background / fills (${backgroundHits.length})`,
                    color: '#e5e7eb',
                    svgContent: wrapPaths(backgroundHits, vb, w, h, defsHtml),
                    icon: 'fa-layer-group',
                    objectCount: backgroundHits.length
                });
            }

            if (smallSignHits.length > 0) {
                layers.push({
                    layerName: `🧹 Small signs / symbols (${smallSignHits.length})`,
                    color: '#f59e0b',
                    svgContent: wrapPaths(smallSignHits, vb, w, h, defsHtml),
                    icon: 'fa-broom',
                    objectCount: smallSignHits.length
                });
            }

            if (ignoredTexts.length > 0) {
                _appendElementsToOtherLayer(layers, ignoredTexts.map(t => t.outerHTML), vb, w, h, defsHtml);
            }
        }

        // Text layer (insert before "Other elements" when present)
        if (allTexts.length > 0) {
            const textGroups = _groupPdfTextItemsByLanguage(allTexts, el => (el && el.textContent) ? String(el.textContent).replace(/\s+/g, ' ').trim() : '');
            for (const group of textGroups) {
                const textHtml = group.items.map(t => t.outerHTML);
                const textLayer = {
                    layerName: `🔤 ${group.label} (${textHtml.length})`,
                    color: '#4A5568',
                    svgContent: wrapPaths(textHtml, vb, w, h, defsHtml),
                    icon: 'fa-font',
                    objectCount: textHtml.length
                };
                const otherIdx = layers.findIndex(l => (l && l.layerName && String(l.layerName).toLowerCase().includes('other elements')));
                if (otherIdx >= 0) layers.splice(otherIdx, 0, textLayer);
                else layers.push(textLayer);
            }
        }

        // PDF vector text often arrives as <use> glyph references instead of real <text> nodes.
        // Preserve those glyph uses as their own text layer so they do not get dropped during split.
        if (allUseNodes.length > 0) {
            const useHtml = allUseNodes.map(el => el.outerHTML);
            const useLayer = {
                layerName: `🔤 Text / labels (glyph uses) (${useHtml.length})`,
                color: '#4A5568',
                svgContent: wrapPaths(useHtml, vb, w, h, defsHtml),
                icon: 'fa-font',
                objectCount: useHtml.length,
                isGlyphUseTextLayer: true
            };
            const otherIdx = layers.findIndex(l => (l && l.layerName && String(l.layerName).toLowerCase().includes('other elements')));
            if (otherIdx >= 0) layers.splice(otherIdx, 0, useLayer);
            else layers.push(useLayer);
        }

        // Insert shape layers before "Other elements"
        if (shapeLayers.length > 0) {
            const insertBeforeOther = (layerObj) => {
                const otherIdx = layers.findIndex(l => (l && l.layerName && String(l.layerName).toLowerCase().includes('other elements')));
                if (otherIdx >= 0) layers.splice(otherIdx, 0, layerObj);
                else layers.push(layerObj);
            };
            for (const sl of shapeLayers) insertBeforeOther(sl);
        }

        // Full count = sum of non-full layers (keeps cards consistent and disjoint)
        recomputeFullLayerFromSum(layers);

        return layers;
    }

    // ── Estimate an element's bounding box from its attributes ──
    function _estimateElBBox(el) {
        const tag = (el.tagName || '').toLowerCase();
        try {
            if (tag === 'image') {
                const x = parseFloat(el.getAttribute('x')) || 0;
                const y = parseFloat(el.getAttribute('y')) || 0;
                const w = parseFloat(el.getAttribute('width')) || 0;
                const h = parseFloat(el.getAttribute('height')) || 0;
                if (w > 0 && h > 0) return { x1: x, y1: y, x2: x + w, y2: y + h };
                return null;
            }
            if (tag === 'rect') {
                const x = parseFloat(el.getAttribute('x')) || 0;
                const y = parseFloat(el.getAttribute('y')) || 0;
                const w = parseFloat(el.getAttribute('width')) || 0;
                const h = parseFloat(el.getAttribute('height')) || 0;
                if (w > 0 && h > 0) return { x1: x, y1: y, x2: x + w, y2: y + h };
                return null;
            }
            if (tag === 'circle') {
                const cx2 = parseFloat(el.getAttribute('cx')) || 0;
                const cy2 = parseFloat(el.getAttribute('cy')) || 0;
                const r  = parseFloat(el.getAttribute('r')) || 0;
                if (r > 0) return { x1: cx2 - r, y1: cy2 - r, x2: cx2 + r, y2: cy2 + r };
                return null;
            }
            if (tag === 'ellipse') {
                const cx2 = parseFloat(el.getAttribute('cx')) || 0;
                const cy2 = parseFloat(el.getAttribute('cy')) || 0;
                const rx = parseFloat(el.getAttribute('rx')) || 0;
                const ry = parseFloat(el.getAttribute('ry')) || 0;
                if (rx > 0 && ry > 0) return { x1: cx2 - rx, y1: cy2 - ry, x2: cx2 + rx, y2: cy2 + ry };
                return null;
            }
            if (tag === 'line') {
                const lx1 = parseFloat(el.getAttribute('x1')) || 0;
                const ly1 = parseFloat(el.getAttribute('y1')) || 0;
                const lx2 = parseFloat(el.getAttribute('x2')) || 0;
                const ly2 = parseFloat(el.getAttribute('y2')) || 0;
                return { x1: Math.min(lx1, lx2), y1: Math.min(ly1, ly2), x2: Math.max(lx1, lx2), y2: Math.max(ly1, ly2) };
            }
            if (tag === 'polyline' || tag === 'polygon') {
                const pts = (el.getAttribute('points') || '').trim();
                if (!pts) return null;
                const nums = pts.split(/[\s,]+/).map(Number).filter(n => isFinite(n));
                if (nums.length < 2) return null;
                let mnX = Infinity, mnY = Infinity, mxX = -Infinity, mxY = -Infinity;
                for (let i = 0; i < nums.length - 1; i += 2) {
                    mnX = Math.min(mnX, nums[i]);  mxX = Math.max(mxX, nums[i]);
                    mnY = Math.min(mnY, nums[i+1]); mxY = Math.max(mxY, nums[i+1]);
                }
                if (isFinite(mnX)) return { x1: mnX, y1: mnY, x2: mxX, y2: mxY };
                return null;
            }
            if (tag === 'path') {
                const d = el.getAttribute('d') || '';
                if (!d) return null;
                return _pathBBox(d);
            }
            if (tag === 'text' || tag === 'tspan') {
                const tx = parseFloat(el.getAttribute('x')) || 0;
                const ty = parseFloat(el.getAttribute('y')) || 0;
                const fs = parseFloat(el.getAttribute('font-size')) || 14;
                // Rough estimate: text extends rightward & above baseline
                return { x1: tx, y1: ty - fs * 1.2, x2: tx + fs * 20, y2: ty + fs * 0.3 };
            }
        } catch { return null; }
        return null;
    }

    // Parse SVG path d-attribute into a bounding box
    function _pathBBox(d) {
        try {
            const tokens = d.match(/[MmLlHhVvCcSsQqTtAaZz]|[-+]?(?:\d+\.?\d*|\.\d+)(?:[eE][-+]?\d+)?/g);
            if (!tokens || tokens.length < 2) return null;
            let curX = 0, curY = 0;
            let mnX = Infinity, mnY = Infinity, mxX = -Infinity, mxY = -Infinity;
            function add(x, y) {
                if (isFinite(x) && isFinite(y)) { mnX = Math.min(mnX, x); mxX = Math.max(mxX, x); mnY = Math.min(mnY, y); mxY = Math.max(mxY, y); }
            }
            let cmd = '', nums = [], idx = 0;
            while (idx < tokens.length) {
                const t = tokens[idx];
                if (/^[A-Za-z]$/.test(t)) {
                    cmd = t; nums = []; idx++;
                    while (idx < tokens.length && !/^[A-Za-z]$/.test(tokens[idx])) { nums.push(parseFloat(tokens[idx])); idx++; }
                } else { idx++; continue; }
                switch (cmd) {
                    case 'M': case 'L': case 'T':
                        for (let i = 0; i < nums.length - 1; i += 2) { curX = nums[i]; curY = nums[i+1]; add(curX, curY); } break;
                    case 'm': case 'l': case 't':
                        for (let i = 0; i < nums.length - 1; i += 2) { curX += nums[i]; curY += nums[i+1]; add(curX, curY); } break;
                    case 'H': for (const n of nums) { curX = n; add(curX, curY); } break;
                    case 'h': for (const n of nums) { curX += n; add(curX, curY); } break;
                    case 'V': for (const n of nums) { curY = n; add(curX, curY); } break;
                    case 'v': for (const n of nums) { curY += n; add(curX, curY); } break;
                    case 'C':
                        for (let i = 0; i < nums.length - 5; i += 6) { add(nums[i],nums[i+1]); add(nums[i+2],nums[i+3]); curX=nums[i+4]; curY=nums[i+5]; add(curX,curY); } break;
                    case 'c':
                        for (let i = 0; i < nums.length - 5; i += 6) { add(curX+nums[i],curY+nums[i+1]); add(curX+nums[i+2],curY+nums[i+3]); curX+=nums[i+4]; curY+=nums[i+5]; add(curX,curY); } break;
                    case 'S': case 'Q':
                        for (let i = 0; i < nums.length - 3; i += 4) { add(nums[i],nums[i+1]); curX=nums[i+2]; curY=nums[i+3]; add(curX,curY); } break;
                    case 's': case 'q':
                        for (let i = 0; i < nums.length - 3; i += 4) { add(curX+nums[i],curY+nums[i+1]); curX+=nums[i+2]; curY+=nums[i+3]; add(curX,curY); } break;
                    case 'A':
                        for (let i = 0; i < nums.length - 6; i += 7) { curX=nums[i+5]; curY=nums[i+6]; add(curX,curY); } break;
                    case 'a':
                        for (let i = 0; i < nums.length - 6; i += 7) { curX+=nums[i+5]; curY+=nums[i+6]; add(curX,curY); } break;
                }
            }
            if (isFinite(mnX) && isFinite(mnY)) return { x1: mnX, y1: mnY, x2: mxX, y2: mxY };
        } catch {}
        return null;
    }

    // ── 2D affine matrix multiply: returns a*b (apply b, then a) ──
    function _matrixMul(a, b) {
        return [
            a[0] * b[0] + a[2] * b[1], a[1] * b[0] + a[3] * b[1],
            a[0] * b[2] + a[2] * b[3], a[1] * b[2] + a[3] * b[3],
            a[0] * b[4] + a[2] * b[5] + a[4], a[1] * b[4] + a[3] * b[5] + a[5]
        ];
    }

    function _matrixTranslate(tx, ty) {
        return [1, 0, 0, 1, tx || 0, ty || 0];
    }

    // ── Parse a CSS/SVG transform string into a 2D affine matrix [a,b,c,d,e,f] ──
    // Supports: translate, scale, rotate, matrix, skewX, skewY
    function _parseTransform(str) {
        if (!str) return null;
        // identity
        let m = [1, 0, 0, 1, 0, 0]; // [a,b,c,d,e,f]
        const re = /(matrix|translate|scale|rotate|skewX|skewY)\s*\(([^)]*)\)/gi;
        let match;
        while ((match = re.exec(str)) !== null) {
            const fn = match[1].toLowerCase();
            const args = match[2].split(/[\s,]+/).map(Number).filter(n => isFinite(n));
            let t;
            switch (fn) {
                case 'matrix':
                    if (args.length >= 6) t = args.slice(0, 6); break;
                case 'translate':
                    t = _matrixTranslate(args[0] || 0, args[1] || 0); break;
                case 'scale': {
                    const sx = args[0]||1, sy = args.length > 1 ? args[1] : sx;
                    t = [sx,0,0,sy,0,0]; break;
                }
                case 'rotate': {
                    const deg = (args[0]||0)*Math.PI/180;
                    const cs = Math.cos(deg), sn = Math.sin(deg);
                    if (args.length >= 3) {
                        // rotate(angle, cx, cy)
                        const rcx = args[1], rcy = args[2];
                        t = _matrixMul(_matrixTranslate(rcx, rcy), _matrixMul([cs, sn, -sn, cs, 0, 0], _matrixTranslate(-rcx, -rcy)));
                    } else {
                        t = [cs,sn,-sn,cs,0,0];
                    }
                    break;
                }
                case 'skewx': { const a2 = Math.tan((args[0]||0)*Math.PI/180); t = [1,0,a2,1,0,0]; break; }
                case 'skewy': { const a2 = Math.tan((args[0]||0)*Math.PI/180); t = [1,a2,0,1,0,0]; break; }
            }
            // SVG applies transform list left→right: M = Tn * ... * T2 * T1
            if (t) m = _matrixMul(t, m);
        }
        return m;
    }

    // ── Get cumulative transform from element up to (but not including) svgRoot ──
    function _getCumulativeTransform(el, svgRoot) {
        let m = [1, 0, 0, 1, 0, 0];
        let cur = el;
        while (cur && cur !== svgRoot) {
            const tr = cur.getAttribute && cur.getAttribute('transform');
            if (tr) {
                const parsed = _parseTransform(tr);
                if (parsed) m = _matrixMul(parsed, m);
            }
            cur = cur.parentElement;
        }
        return m;
    }

    // ── Apply affine transform to a bbox → return axis-aligned bbox in parent space ──
    function _transformBBox(bb, m) {
        // Transform the 4 corners and take the AABB
        const corners = [
            [bb.x1, bb.y1], [bb.x2, bb.y1],
            [bb.x1, bb.y2], [bb.x2, bb.y2]
        ];
        let mnX = Infinity, mnY = Infinity, mxX = -Infinity, mxY = -Infinity;
        for (const [px, py] of corners) {
            const tx = m[0]*px + m[2]*py + m[4];
            const ty = m[1]*px + m[3]*py + m[5];
            mnX = Math.min(mnX, tx); mxX = Math.max(mxX, tx);
            mnY = Math.min(mnY, ty); mxY = Math.max(mxY, ty);
        }
        return { x1: mnX, y1: mnY, x2: mxX, y2: mxY };
    }

    // Remove graphical elements whose bbox is entirely outside the crop rectangle.
    // Accounts for parent <g transform="..."> chains so coordinates are in viewBox space.
    // Elements inside <defs> are kept. Elements with no determinable bbox are kept (conservative).
    function _pruneElementsOutsideCrop(svgRoot, cropX, cropY, cropW, cropH) {
        const SEL = 'path, rect, circle, ellipse, line, polyline, polygon, text';
        const allEls = [...svgRoot.querySelectorAll(SEL)];
        const cX2 = cropX + cropW, cY2 = cropY + cropH;
        let removed = 0;
        for (const el of allEls) {
            try { if (el.closest && el.closest('defs')) continue; } catch {}
            const localBB = _estimateElBBox(el);
            if (!localBB) continue; // unknown bbox → keep
            // Apply cumulative transform to get bbox in SVG root coordinate space
            const m = _getCumulativeTransform(el, svgRoot);
            const bb = _transformBBox(localBB, m);
            // Entirely outside?
            if (bb.x2 < cropX || bb.x1 > cX2 || bb.y2 < cropY || bb.y1 > cY2) {
                el.remove();
                removed++;
            }
        }
        // Clean up empty <g> containers
        if (removed > 0) {
            let changed = true;
            while (changed) {
                changed = false;
                for (const g of [...svgRoot.querySelectorAll('g')]) {
                    try { if (g.closest && g.closest('defs')) continue; } catch {}
                    if (g.children.length === 0 && !g.textContent.trim()) { g.remove(); changed = true; }
                }
            }
        }
    }

    // Crop a VECTOR SVG by a fractional region (x,y,w,h in 0..1 of the page)
    // without rasterizing.
    // IMPORTANT: Must not rely on a parent <g transform="translate(...)"> wrapper.
    // We later decompose SVG into layers by extracting element outerHTML, which would
    // lose any inherited transform and misalign layers. So we crop via viewBox only.
    // Also prunes elements entirely outside the crop to reduce object counts & file size.
    function cropSvgByFraction(svgText, frac) {
        if (!svgText || !frac) return svgText;

        const fx = Math.max(0, Math.min(1, Number(frac.x)));
        const fy = Math.max(0, Math.min(1, Number(frac.y)));
        const fw = Math.max(0, Math.min(1, Number(frac.w)));
        const fh = Math.max(0, Math.min(1, Number(frac.h)));
        if (!isFinite(fx) || !isFinite(fy) || !isFinite(fw) || !isFinite(fh) || fw <= 0 || fh <= 0) return svgText;

        try {
            const parser = new DOMParser();
            const doc = parser.parseFromString(svgText, 'image/svg+xml');
            const svgRoot = doc.querySelector('svg');
            if (!svgRoot) return svgText;

            function parseViewBox(vbStr) {
                const parts = String(vbStr || '').trim().split(/[\s,]+/).map(Number);
                if (parts.length === 4 && parts.every(n => isFinite(n))) {
                    return { x: parts[0], y: parts[1], w: parts[2], h: parts[3] };
                }
                return null;
            }

            let box = parseViewBox(svgRoot.getAttribute('viewBox'));
            if (!box) {
                const w = parseFloat(String(svgRoot.getAttribute('width') || '').replace(/[a-z%]+/gi, ''));
                const h = parseFloat(String(svgRoot.getAttribute('height') || '').replace(/[a-z%]+/gi, ''));
                if (isFinite(w) && isFinite(h) && w > 0 && h > 0) box = { x: 0, y: 0, w, h };
            }
            if (!box || !isFinite(box.w) || !isFinite(box.h) || box.w === 0 || box.h === 0) return svgText;

            const cx = box.x + fx * box.w;
            const cy = box.y + fy * box.h;
            const cw = fw * box.w;
            const ch = fh * box.h;

            // Prune elements entirely outside the crop rectangle
            _pruneElementsOutsideCrop(svgRoot, cx, cy, cw, ch);

            // ViewBox crop (no translation). Keeps original element coordinates intact.
            svgRoot.setAttribute('viewBox', `${cx} ${cy} ${cw} ${ch}`);
            // Keep width/height consistent (unitless is fine for our UI)
            svgRoot.setAttribute('width', String(cw));
            svgRoot.setAttribute('height', String(ch));

            return new XMLSerializer().serializeToString(svgRoot);
        } catch {
            return svgText;
        }
    }

    function restoreCroppedSvgToPageSpace(svgText, cropInfo) {
        if (!svgText || !cropInfo) return svgText;

        const pageW = Math.max(1, Number(cropInfo.pageW ?? cropInfo.imgW ?? 0) || 0);
        const pageH = Math.max(1, Number(cropInfo.pageH ?? cropInfo.imgH ?? 0) || 0);
        const cropW = Math.max(1, Number(cropInfo.cropW ?? 0) || 0);
        const cropH = Math.max(1, Number(cropInfo.cropH ?? 0) || 0);
        const offsetX = Number(cropInfo.offsetX ?? cropInfo.sx ?? 0) || 0;
        const offsetY = Number(cropInfo.offsetY ?? cropInfo.sy ?? 0) || 0;
        if (!(pageW > 0 && pageH > 0 && cropW > 0 && cropH > 0)) return svgText;

        try {
            const parser = new DOMParser();
            const doc = parser.parseFromString(svgText, 'image/svg+xml');
            const svgRoot = doc.querySelector('svg');
            if (!svgRoot) return svgText;

            const parseViewBox = (vbStr) => {
                const parts = String(vbStr || '').trim().split(/[\s,]+/).map(Number);
                if (parts.length === 4 && parts.every(n => isFinite(n))) {
                    return { x: parts[0], y: parts[1], w: parts[2], h: parts[3] };
                }
                return null;
            };

            let view = parseViewBox(svgRoot.getAttribute('viewBox'));
            if (!view) {
                const w = parseFloat(String(svgRoot.getAttribute('width') || '').replace(/[a-z%]+/gi, ''));
                const h = parseFloat(String(svgRoot.getAttribute('height') || '').replace(/[a-z%]+/gi, ''));
                if (isFinite(w) && isFinite(h) && w > 0 && h > 0) view = { x: 0, y: 0, w, h };
            }
            if (!view || !isFinite(view.w) || !isFinite(view.h) || view.w <= 0 || view.h <= 0) {
                view = { x: 0, y: 0, w: cropW, h: cropH };
            }

            const sx = cropW / view.w;
            const sy = cropH / view.h;
            const tx = offsetX - (view.x * sx);
            const ty = offsetY - (view.y * sy);

            const xmlNs = svgRoot.namespaceURI || 'http://www.w3.org/2000/svg';
            const replacement = doc.createElementNS(xmlNs, 'svg');
            for (const attr of Array.from(svgRoot.attributes || [])) {
                const name = attr.name;
                if (name === 'viewBox' || name === 'width' || name === 'height' || name === 'preserveAspectRatio') continue;
                replacement.setAttribute(name, attr.value);
            }
            if (!replacement.getAttribute('xmlns')) replacement.setAttribute('xmlns', 'http://www.w3.org/2000/svg');
            replacement.setAttribute('viewBox', `0 0 ${pageW} ${pageH}`);
            replacement.setAttribute('width', String(pageW));
            replacement.setAttribute('height', String(pageH));
            replacement.setAttribute('preserveAspectRatio', svgRoot.getAttribute('preserveAspectRatio') || 'none');

            const passthroughTags = new Set(['defs', 'style', 'metadata', 'title', 'desc']);
            const contentGroup = doc.createElementNS(xmlNs, 'g');
            contentGroup.setAttribute('transform', `matrix(${sx} 0 0 ${sy} ${tx} ${ty})`);

            for (const child of Array.from(svgRoot.childNodes || [])) {
                const clone = child.cloneNode(true);
                if (child.nodeType === Node.ELEMENT_NODE && passthroughTags.has((child.localName || '').toLowerCase())) {
                    replacement.appendChild(clone);
                } else {
                    contentGroup.appendChild(clone);
                }
            }

            replacement.appendChild(contentGroup);
            svgRoot.replaceWith(replacement);
            return new XMLSerializer().serializeToString(replacement);
        } catch {
            return svgText;
        }
    }

    function getSvgBox(svgText) {
        try {
            if (!svgText) return null;
            const parser = new DOMParser();
            const doc = parser.parseFromString(svgText, 'image/svg+xml');
            const svgRoot = doc.querySelector('svg');
            if (!svgRoot) return null;
            const vb = String(svgRoot.getAttribute('viewBox') || '').trim();
            if (vb) {
                const parts = vb.split(/[\s,]+/).map(Number);
                if (parts.length === 4 && parts.every(n => isFinite(n)) && parts[2] > 0 && parts[3] > 0) {
                    return { w: parts[2], h: parts[3] };
                }
            }
            const w = parseFloat(String(svgRoot.getAttribute('width') || '').replace(/[a-z%]+/gi, ''));
            const h = parseFloat(String(svgRoot.getAttribute('height') || '').replace(/[a-z%]+/gi, ''));
            if (isFinite(w) && isFinite(h) && w > 0 && h > 0) return { w, h };
            return null;
        } catch {
            return null;
        }
    }

    function wrapTextLines(text, maxWidth, fontSizePx) {
        const raw = String(text || '').replace(/\r\n/g, '\n');
        const paras = raw.split('\n');
        const lines = [];

        const canvas = document.createElement('canvas');
        const ctx = canvas.getContext('2d');
        if (!ctx) return raw.split('\n');
        ctx.font = `${fontSizePx}px sans-serif`;

        for (const p of paras) {
            const words = String(p).split(/\s+/).filter(Boolean);
            if (words.length === 0) { lines.push(''); continue; }
            let cur = '';
            for (const w of words) {
                const next = cur ? (cur + ' ' + w) : w;
                if (ctx.measureText(next).width <= maxWidth || !cur) {
                    cur = next;
                } else {
                    lines.push(cur);
                    cur = w;
                }
            }
            if (cur) lines.push(cur);
        }
        return lines;
    }

    function buildTextOverlaySvg(text, boxW, boxH, cfg) {
        const t = String(text || '').trim();
        if (!t) return '';
        const w = Number(boxW), h = Number(boxH);
        if (!isFinite(w) || !isFinite(h) || w <= 0 || h <= 0) return '';
        const fontSize = Math.max(6, Math.min(96, Number(cfg?.fontSize) || 14));
        const pos = String(cfg?.position || 'center');

        const pad = Math.max(5, Math.min(24, w * 0.05));
        const maxWidth = Math.max(10, w - pad * 2);
        const lines = wrapTextLines(t, maxWidth, fontSize);
        const lineH = fontSize * 1.25;
        const totalH = lines.length * lineH;

        let x = w / 2;
        let anchor = 'middle';
        let y0 = (h - totalH) / 2 + fontSize;

        if (pos.includes('left')) { x = pad; anchor = 'start'; }
        if (pos.includes('right')) { x = w - pad; anchor = 'end'; }

        if (pos.startsWith('top')) y0 = pad + fontSize;
        else if (pos.startsWith('bottom')) y0 = (h - pad - totalH) + fontSize;

        const svg = document.createElementNS('http://www.w3.org/2000/svg', 'svg');
        svg.setAttribute('xmlns', 'http://www.w3.org/2000/svg');
        svg.setAttribute('viewBox', `0 0 ${w} ${h}`);
        svg.setAttribute('width', String(w));
        svg.setAttribute('height', String(h));

        const textEl = document.createElementNS('http://www.w3.org/2000/svg', 'text');
        textEl.setAttribute('x', String(x));
        textEl.setAttribute('y', String(y0));
        textEl.setAttribute('fill', '#4A5568');
        textEl.setAttribute('font-size', String(fontSize));
        textEl.setAttribute('text-anchor', anchor);

        for (let i = 0; i < lines.length; i++) {
            const tspan = document.createElementNS('http://www.w3.org/2000/svg', 'tspan');
            tspan.setAttribute('x', String(x));
            tspan.setAttribute('dy', i === 0 ? '0' : String(lineH));
            tspan.textContent = lines[i];
            textEl.appendChild(tspan);
        }

        svg.appendChild(textEl);
        return new XMLSerializer().serializeToString(svg);
    }

    // Read SVG paint (fill/stroke) from attribute or inline style.
    // Walks UP parent <g> elements to find inherited paint (SVG cascade).
    function getRawPaint(el, prop) {
        if (!el) return null;
        // Check the element's own attribute first
        const direct = el.getAttribute(prop);
        if (direct && direct.trim() !== '') return direct.trim();
        // Check inline style
        const style = el.getAttribute('style') || '';
        if (style) {
            const re = new RegExp(`${prop}\\s*:\\s*([^;]+)`, 'i');
            const m = style.match(re);
            if (m && (m[1] || '').trim()) return (m[1] || '').trim();
        }
        // Walk up parent chain (SVG inheritance from <g> etc.)
        let parent = el.parentElement;
        while (parent && parent.tagName !== 'svg') {
            const pd = parent.getAttribute(prop);
            if (pd && pd.trim() !== '') return pd.trim();
            const ps = parent.getAttribute('style') || '';
            if (ps) {
                const re2 = new RegExp(`${prop}\\s*:\\s*([^;]+)`, 'i');
                const m2 = ps.match(re2);
                if (m2 && (m2[1] || '').trim()) return (m2[1] || '').trim();
            }
            parent = parent.parentElement;
        }
        return null;
    }

    function getPaint(el, prop) {
        const raw = getRawPaint(el, prop);
        return raw ? resolveColor(raw) : null;
    }

    // Wrap inner SVG element strings into a full SVG document
    function wrapPaths(innerHtmlArr, viewBox, w, h, defsHtml) {
        const attrs = ['xmlns="http://www.w3.org/2000/svg"'];
        if (viewBox) attrs.push(`viewBox="${viewBox}"`);
        if (w) attrs.push(`width="${w}"`);
        if (h) attrs.push(`height="${h}"`);
        const defs = defsHtml ? String(defsHtml) : '';
        const defsBlock = defs ? (defs + "\n") : '';
        return `<svg ${attrs.join(' ')}>\n${defsBlock}${innerHtmlArr.join('\n')}\n</svg>`;
    }

    function _normalizeSymbolHref(href) {
        const s = (href || '').toString().trim();
        if (!s) return '';
        // If the SVG uses absolute/relative URLs with fragment, keep only the fragment
        const i = s.indexOf('#');
        if (i >= 0) return s.substring(i);
        return s;
    }

    function _isLikelyTextGlyphHref(href) {
        try {
            const norm = _normalizeSymbolHref(href).toLowerCase();
            if (!norm) return false;
            // Common patterns from PDF-to-SVG text as glyph <use> references.
            if (norm.startsWith('#font_')) return true;
            if (norm.startsWith('#glyph')) return true;
            if (norm.startsWith('#gid')) return true;
            if (norm.includes('font_')) return true;
            return false;
        } catch {
            return false;
        }
    }

    /* ── Family marker helpers ── */
    function _getFamilyTypeMarkerColor(typeKey) {
        const colors = {
            'fire-detection': '#dc2626',
            'camera': '#2563eb',
            'lighting': '#d97706',
            'emergency-lighting': '#16a34a',
            'suppression': '#0891b2',
            'access-control': '#7c3aed',
            'intrusion': '#be185d',
            'communication': '#0d9488',
            'automation': '#4f46e5',
            'other': '#475569'
        };
        return colors[typeKey] || colors.other;
    }

    function _extractUseElementCenter(useEl) {
        let x = parseFloat(useEl.getAttribute('x') || '0') || 0;
        let y = parseFloat(useEl.getAttribute('y') || '0') || 0;
        let w = parseFloat(useEl.getAttribute('width') || '0') || 0;
        let h = parseFloat(useEl.getAttribute('height') || '0') || 0;
        const transform = useEl.getAttribute('transform') || '';
        if (transform) {
            const matrixMatch = transform.match(/matrix\(\s*([\-\d.e]+)[\s,]+([\-\d.e]+)[\s,]+([\-\d.e]+)[\s,]+([\-\d.e]+)[\s,]+([\-\d.e]+)[\s,]+([\-\d.e]+)\s*\)/i);
            if (matrixMatch) {
                x += parseFloat(matrixMatch[5]) || 0;
                y += parseFloat(matrixMatch[6]) || 0;
            } else {
                const translateMatch = transform.match(/translate\(\s*([\-\d.e]+)[\s,]+([\-\d.e]+)?\s*\)/i);
                if (translateMatch) {
                    x += parseFloat(translateMatch[1]) || 0;
                    y += parseFloat(translateMatch[2] || '0') || 0;
                }
            }
        }
        return { x, y, w, h };
    }

    function _buildFamilySymbolMarkerSvg(x, y, w, h, symbolShapes, strokeColor) {
        const boxW = Math.max(4, Number(w) || 0);
        const boxH = Math.max(4, Number(h) || 0);
        const iconSize = Math.min(boxW, boxH);
        const iconScale = iconSize / 24;
        const iconX = x + ((boxW - iconSize) / 2);
        const iconY = y + ((boxH - iconSize) / 2);
        const cx = (x + boxW / 2).toFixed(3);
        const cy = (y + boxH / 2).toFixed(3);
        const bgR = (iconSize * 0.48).toFixed(3);
        const bgCircle = `<circle cx="${cx}" cy="${cy}" r="${bgR}" fill="white"/>`;
        const sw = Math.max(0.5, 1.6 / iconScale).toFixed(3);
        const shapesAdj = symbolShapes.replace(/stroke-width="[^"]*"/g, `stroke-width="${sw}"`);
        return `<g data-family-marker="true">${bgCircle}<g transform="translate(${iconX.toFixed(3)} ${iconY.toFixed(3)}) scale(${iconScale.toFixed(5)})" style="color:${strokeColor};opacity:1">${shapesAdj}</g></g>`;
    }

    function _extractElementCenterFromHtml(htmlStr) {
        try {
            const parser = new DOMParser();
            const frag = parser.parseFromString(`<svg xmlns="http://www.w3.org/2000/svg">${htmlStr}</svg>`, 'image/svg+xml');
            // Account for <g transform="translate(tx ty)"> wrappers (markers)
            let txOff = 0, tyOff = 0;
            const gTx = frag.querySelector('g[transform]');
            if (gTx) {
                const m = (gTx.getAttribute('transform') || '').match(/translate\(\s*([\-\d.eE]+)[\s,]+([\-\d.eE]+)/);
                if (m) { txOff = parseFloat(m[1]) || 0; tyOff = parseFloat(m[2]) || 0; }
            }
            const img = frag.querySelector('image') || frag.querySelector('use') || frag.querySelector('rect') || frag.querySelector('circle');
            if (!img) return null;
            
            const tag = String(img.tagName || '').toLowerCase();
            let bx = 0, by = 0, bw = 0, bh = 0, bcx = 0, bcy = 0;
            
            if (tag === 'circle' || tag === 'ellipse') {
                bcx = parseFloat(img.getAttribute('cx') || '0') || 0;
                bcy = parseFloat(img.getAttribute('cy') || '0') || 0;
                bw = parseFloat(img.getAttribute('r') || img.getAttribute('rx') || '0') * 2 || 0;
                bh = parseFloat(img.getAttribute('r') || img.getAttribute('ry') || '0') * 2 || 0;
                bx = bcx - bw / 2;
                by = bcy - bh / 2;
            } else {
                bx = parseFloat(img.getAttribute('x') || '0') || 0;
                by = parseFloat(img.getAttribute('y') || '0') || 0;
                bw = parseFloat(img.getAttribute('width') || '0') || 0;
                bh = parseFloat(img.getAttribute('height') || '0') || 0;
                const explicitCx = parseFloat(img.getAttribute('data-center-x') || '');
                const explicitCy = parseFloat(img.getAttribute('data-center-y') || '');
                bcx = Number.isFinite(explicitCx) ? explicitCx : (bx + bw / 2);
                bcy = Number.isFinite(explicitCy) ? explicitCy : (by + bh / 2);
            }
            
            const out = {
                x: txOff + bx,
                y: tyOff + by,
                w: bw,
                h: bh,
                cx: txOff + bcx,
                cy: tyOff + bcy
            };
            _debugPdfSplitLog('[FamilyDetector][ExtractHtmlCenter]', {
                htmlSnippet: String(htmlStr || '').slice(0, 220),
                txOff,
                tyOff,
                tag,
                bounds: { x: bx, y: by, w: bw, h: bh },
                explicitCenter: {
                    x: img.getAttribute('data-center-x') || '',
                    y: img.getAttribute('data-center-y') || ''
                },
                out
            });
            return out;
        } catch {
            return null;
        }
    }

    function _computeFamilyMarkerSize(vbStr) {
        const vb = _parseViewBoxStr(vbStr);
        return vb ? Math.max(Math.min(vb.w, vb.h) * 0.018, 10) : 16;
    }

    async function injectFamilyLayers(svgText, layers) {
        try {
            if (!svgText || typeof svgText !== 'string') return layers;
            if (!layers || !Array.isArray(layers) || layers.length === 0) return layers;

            const fams = await loadObjectFamilies(false);
            if (!fams || fams.length === 0) return layers;

            const parser = new DOMParser();
            const doc = parser.parseFromString(svgText, 'image/svg+xml');
            const svgRoot = doc.querySelector('svg');
            if (!svgRoot) return layers;

            const vb = svgRoot.getAttribute('viewBox') || '';
            const w = svgRoot.getAttribute('width') || '';
            const h = svgRoot.getAttribute('height') || '';
            const defsHtml = [...svgRoot.querySelectorAll('defs')].map(d => d.outerHTML).join('\n');
            const parsedVb = _parseViewBoxStr(vb);

            const idMap = new Map();
            [...svgRoot.querySelectorAll('[id]')].forEach(el => {
                const id = (el.getAttribute('id') || '').trim();
                if (id) idMap.set(id, el);
            });

            const uses = [...svgRoot.querySelectorAll('use')].filter(u => { try { return !u.closest('defs'); } catch { return true; } });
            if (uses.length === 0) return layers;

            const useItems = uses.map(u => {
                const href = (u.getAttribute('href') || u.getAttribute('xlink:href') || '').trim();
                return {
                    href,
                    norm: _normalizeSymbolHref(href),
                    el: u,
                    html: u.outerHTML
                };
            }).filter(x => x.href || x.norm);

            const familyLayers = [];
            for (const f of fams) {
                if (!f || f.isActive === false) continue;
                const sampleHrefs = Array.isArray(f.sampleHrefs) ? f.sampleHrefs : [];
                if (sampleHrefs.length === 0) continue;
                const keySet = new Set();
                for (const sh of sampleHrefs) {
                    const a = (sh || '').toString().trim();
                    const b = _normalizeSymbolHref(a);
                    if (a) keySet.add(a);
                    if (b) keySet.add(b);
                }
                if (keySet.size === 0) continue;

                const matched = [];
                for (const u of useItems) {
                    if (keySet.has(u.href) || (u.norm && keySet.has(u.norm))) matched.push(u);
                }
                if (matched.length === 0) continue;

                const name = String(f.name || '').trim() || 'Family';
                const typeKey = _getFamilyTypeMeta(f.typeKey, name).key;
                const symbolKey = _getFamilySymbolKey(typeKey, name, f.symbolKey);
                const markerColor = _getFamilyTypeMarkerColor(typeKey);
                const symbolShapes = _getFamilyTypeSymbolShapesMarkup(symbolKey);
                const markerSize = _computeFamilyMarkerSize(vb);

                const markerHtmlArr = matched.map(u => {
                    const pos = _extractUseElementCenter(u.el);
                    let cx = pos.x + (pos.w > 0 ? pos.w / 2 : 0);
                    let cy = pos.y + (pos.h > 0 ? pos.h / 2 : 0);
                    
                    try {
                        const estimatedBB = _estimateUseBBox(u.el, svgRoot, idMap);
                        if (estimatedBB && isFinite(estimatedBB.x1) && isFinite(estimatedBB.x2)) {
                            cx = (estimatedBB.x1 + estimatedBB.x2) / 2;
                            cy = (estimatedBB.y1 + estimatedBB.y2) / 2;
                        }
                    } catch { /* fallback */ }

                    return _buildFamilySymbolMarkerSvg(cx - markerSize / 2, cy - markerSize / 2, markerSize, markerSize, symbolShapes, markerColor);
                });

                familyLayers.push({
                    layerName: `🏷️ Family: ${name} (${matched.length})`,
                    color: '',
                    icon: 'fa-tag',
                    svgContent: _injectFamilyMapBadgeSvg(wrapPaths(markerHtmlArr, vb, w, h, ''), typeKey, name, symbolKey),
                    objectCount: matched.length,
                    isFamilyLayer: true,
                    familyId: f.id || null,
                    familyTypeKey: typeKey,
                    familySymbolKey: symbolKey
                });
            }

            if (familyLayers.length === 0) return layers;

            const out = [...layers];
            const fullIdx = out.findIndex(l => l && l.layerName && String(l.layerName).includes('Full SVG (all layers)'));
            const insertAt = fullIdx >= 0 ? fullIdx + 1 : 0;
            out.splice(insertAt, 0, ...familyLayers);
            return out;
        } catch {
            return layers;
        }
    }

    // ── Color helpers ──
    function hexToRgb(hex) {
        if (!hex) return null;
        hex = hex.replace('#', '');
        if (hex.length === 3) hex = hex[0]+hex[0]+hex[1]+hex[1]+hex[2]+hex[2];
        if (hex.length !== 6) return null;
        return { r: parseInt(hex.substring(0,2),16), g: parseInt(hex.substring(2,4),16), b: parseInt(hex.substring(4,6),16) };
    }

    function rgbToHex(rgb) {
        return '#' + [rgb.r, rgb.g, rgb.b].map(v => Math.min(255, Math.max(0, v)).toString(16).padStart(2, '0')).join('');
    }

    function rgbToHsl(r, g, b) {
        r /= 255; g /= 255; b /= 255;
        const max = Math.max(r, g, b), min = Math.min(r, g, b);
        let h, s, l = (max + min) / 2;
        if (max === min) { h = s = 0; }
        else {
            const d = max - min;
            s = l > 0.5 ? d / (2 - max - min) : d / (max + min);
            if (max === r)      h = ((g - b) / d + (g < b ? 6 : 0)) / 6;
            else if (max === g) h = ((b - r) / d + 2) / 6;
            else                h = ((r - g) / d + 4) / 6;
        }
        return { h: h * 360, s, l };
    }

    function isNeutralRgb(rgb) {
        if (!rgb) return true;
        const hsl = rgbToHsl(rgb.r, rgb.g, rgb.b);
        const maxc = Math.max(rgb.r, rgb.g, rgb.b);
        const minc = Math.min(rgb.r, rgb.g, rgb.b);
        const range = maxc - minc;
        if (hsl.l <= 0.06 || hsl.l >= 0.96) return true;
        if (hsl.s < 0.12) return true;
        if (range < 18) return true;
        return false;
    }

    function hueDistance(h1, h2) {
        const diff = Math.abs(h1 - h2);
        return Math.min(diff, 360 - diff);
    }

    function colorDistance(rgb1, rgb2) {
        return Math.sqrt(
            Math.pow(rgb1.r - rgb2.r, 2) +
            Math.pow(rgb1.g - rgb2.g, 2) +
            Math.pow(rgb1.b - rgb2.b, 2)
        );
    }

    // Match an element's color against a target: RGB distance + hue-based matching.
    function colorMatchesTarget(elRgb, targetRgb, tolerance) {
        if (!elRgb || !targetRgb) return false;
        const elHsl  = rgbToHsl(elRgb.r, elRgb.g, elRgb.b);
        const tgtHsl = rgbToHsl(targetRgb.r, targetRgb.g, targetRgb.b);

        // If target is chromatic, do not match neutral/pastel element colors
        if (tgtHsl.s > 0.20 && isNeutralRgb(elRgb)) return false;

        // Direct RGB distance
        if (colorDistance(elRgb, targetRgb) <= tolerance) return true;

        // Hue-based: require fairly strong chroma (avoid pastel background tints)
        if (elHsl.s >= 0.28 && tgtHsl.s > 0.15 && elHsl.l > 0.08 && elHsl.l < 0.92) {
            // Match if hues are within the same color family (35° tolerance)
            if (hueDistance(elHsl.h, tgtHsl.h) <= 35) return true;
        }
        return false;
    }

    // Extract RGB from a color string (hex, rgb(), or named)
    function resolveColor(val) {
        if (!val) return null;
        val = val.trim().toLowerCase();
        if (val === 'none' || val === 'transparent' || val === '') return null;

        // Inline style: look for fill: or stroke: or color:
        if (val.includes(':')) {
            const m = val.match(/(?:fill|stroke|color)\s*:\s*([^;]+)/);
            if (m) val = m[1].trim();
        }

        // hex
        if (val.startsWith('#')) return hexToRgb(val);

        // rgb(r,g,b)
        const rgbMatch = val.match(/rgb\(\s*(\d+)\s*,\s*(\d+)\s*,\s*(\d+)/);
        if (rgbMatch) return { r: +rgbMatch[1], g: +rgbMatch[2], b: +rgbMatch[3] };

        // Named colors (common in SVG output)
        const named = { red:{r:255,g:0,b:0}, blue:{r:0,g:0,b:255}, green:{r:0,g:128,b:0},
            black:{r:0,g:0,b:0}, white:{r:255,g:255,b:255}, gray:{r:128,g:128,b:128}, grey:{r:128,g:128,b:128},
            magenta:{r:255,g:0,b:255}, fuchsia:{r:255,g:0,b:255}, purple:{r:128,g:0,b:128},
            cyan:{r:0,g:255,b:255}, aqua:{r:0,g:255,b:255}, yellow:{r:255,g:255,b:0},
            orange:{r:255,g:165,b:0}, pink:{r:255,g:192,b:203}, brown:{r:165,g:42,b:42},
            maroon:{r:128,g:0,b:0}, navy:{r:0,g:0,b:128}, lime:{r:0,g:255,b:0},
            olive:{r:128,g:128,b:0}, teal:{r:0,g:128,b:128}, silver:{r:192,g:192,b:192},
            darkred:{r:139,g:0,b:0}, darkblue:{r:0,g:0,b:139}, darkgreen:{r:0,g:100,b:0},
            darkgray:{r:169,g:169,b:169}, darkgrey:{r:169,g:169,b:169},
            lightgray:{r:211,g:211,b:211}, lightgrey:{r:211,g:211,b:211},
            crimson:{r:220,g:20,b:60}, coral:{r:255,g:127,b:80}, tomato:{r:255,g:99,b:71},
            salmon:{r:250,g:128,b:114}, indianred:{r:205,g:92,b:92},
            hotpink:{r:255,g:105,b:180}, deeppink:{r:255,g:20,b:147} };
        return named[val] || null;
    }

    function normaliseColour(c) {
        if (!c) return 'none';
        c = c.trim().toLowerCase();
        if (c === '' || c === 'none' || c === 'transparent') return 'none';
        return c;
    }

    async function renderPdfPreview(file, opts) {
        const _prevScroll = (pdfViewport && opts && opts.preserveZoom) ? { sl: pdfViewport.scrollLeft, st: pdfViewport.scrollTop } : null;
        const token = ++_pdfPreviewRenderToken;
        if (pdfPages) pdfPages.innerHTML = '';
        if (pdfPreviewCard) pdfPreviewCard.classList.add('hidden');
        lastPdfPageDims = [];
        lastPdfPreviewMeta = null;
        if (btnOpenPdfSizeDrawer) btnOpenPdfSizeDrawer.disabled = true;
        if (pdfSizePanel) pdfSizePanel.classList.add('hidden');
        renderPdfSizePanel();
        renderPdfSizeInfoCard();
        if (!file) {
            setPdfLoadingOverlay(false);
            return;
        }

        setPdfLoadingOverlay(true, 'Rendering preview pages...');

        _currentPdfPreviewFile = file;
        const fileKey = _getPdfFileKey(file);
        const sameFile = !!(fileKey && _currentPdfPreviewFileKey && fileKey === _currentPdfPreviewFileKey);
        _currentPdfPreviewFileKey = fileKey;

        const preserveRegions = (opts && typeof opts.preserveRegions === 'boolean') ? opts.preserveRegions : sameFile;
        const preserveZoom = (opts && typeof opts.preserveZoom === 'boolean') ? opts.preserveZoom : preserveRegions;
        const autoDetectColors = (opts && typeof opts.autoDetectColors === 'boolean') ? opts.autoDetectColors : !preserveRegions;

        if (!preserveRegions) {
            cropSelections = {};
            outputCrop = null;
            updateCropClearBtn();
        }

        try {
            const fd = new FormData();
            fd.append('pdf', file, file.name);
            const dpi = getSelectedPdfPreviewDpi();
            if (pdfPreviewDpiEl) pdfPreviewDpiEl.value = String(dpi);
            const qs = new URLSearchParams({ dpi: String(dpi) });
            const previewAbort = (typeof AbortController !== 'undefined') ? new AbortController() : null;
            const previewTimeout = previewAbort
                ? setTimeout(() => {
                    try { previewAbort.abort(); } catch { /* ignore */ }
                }, 60000)
                : null;

            let resp;
            try {
                resp = await fetch(`${PREVIEW_ENDPOINT}?${qs}`, {
                    method: 'POST', body: fd,
                    headers: { 'X-Client-Id': 'admin' },
                    cache: 'no-store',
                    signal: previewAbort ? previewAbort.signal : undefined
                });
                const text = await resp.text();
                if (previewTimeout) clearTimeout(previewTimeout);
                if (!resp.ok) {
                    if (token === _pdfPreviewRenderToken) {
                        _showPdfPreviewStatus(`Failed to render PDF preview (HTTP ${resp.status}).`);
                        setPdfLoadingOverlay(false);
                    }
                    if (token === _pdfPreviewRenderToken) setPdfLoadingOverlay(false);
                    return;
                }

                // If a newer render started while we were waiting, ignore this response.
                if (token !== _pdfPreviewRenderToken) return;

                let payload;
                try { payload = JSON.parse(text); } catch {
                    if (token === _pdfPreviewRenderToken) {
                        _showPdfPreviewStatus('Failed to parse the PDF preview response.');
                        setPdfLoadingOverlay(false);
                    }
                    return;
                }
                if (!payload || !payload.pages) {
                    if (token === _pdfPreviewRenderToken) {
                        _showPdfPreviewStatus('The server returned no PDF preview pages.');
                        setPdfLoadingOverlay(false);
                    }
                    return;
                }

                lastPdfPages = Array.isArray(payload.pages) ? payload.pages : [];
                lastPdfPageDims = Array.isArray(payload.pageDims) ? payload.pageDims : [];
                lastPdfPreviewMeta = {
                    dpiUsed: (payload && payload.dpiUsed != null && isFinite(payload.dpiUsed)) ? Number(payload.dpiUsed) : null,
                    maxDimUsed: (payload && payload.maxDimUsed != null && isFinite(payload.maxDimUsed)) ? Number(payload.maxDimUsed) : null
                };
                if (btnOpenPdfSizeDrawer) btnOpenPdfSizeDrawer.disabled = lastPdfPageDims.length === 0;
                renderPdfSizePanel();
                renderPdfSizeInfoCard();
                pdfPages.innerHTML = '';
                updateCropClearBtn();
                for (let pi = 0; pi < lastPdfPages.length; pi++) {
                    const src = lastPdfPages[pi];
                    const wrap = document.createElement('div');
                    wrap.className = 'pdf-page-wrap';
                    wrap.dataset.pageIndex = pi;

                    const shell = document.createElement('div');
                    shell.className = 'pdf-page-shell';

                    const world = document.createElement('div');
                    world.className = 'pdf-page-world';

                    const img = document.createElement('img');
                    img.alt = 'PDF page ' + (pi + 1);
                    img.className = 'block max-w-none';
                    img.draggable = false;
                    img._baseW = 0;
                    img._baseH = 0;
                    img._viewW = 0;
                    img._viewH = 0;

                    const cvs = document.createElement('canvas');
                    cvs.className = 'crop-overlay';
                    cvs.dataset.pageIndex = pi;

                    const markCvs = document.createElement('canvas');
                    markCvs.className = 'pdf-mark-canvas';
                    markCvs.dataset.pageIndex = pi;
                    markCvs.style.cssText = 'position:absolute;top:0;left:0;pointer-events:none;z-index:20;';

                    const onPreviewImgLoad = () => {
                        img._baseW = img.naturalWidth;
                        img._baseH = img.naturalHeight;

                        cvs.width  = img.naturalWidth;
                        cvs.height = img.naturalHeight;

                        markCvs.width  = img.naturalWidth;
                        markCvs.height = img.naturalHeight;
                        markCvs.style.pointerEvents = _pdfMarkMode ? 'auto' : 'none';
                        markCvs.style.cursor = _pdfMarkMode ? 'crosshair' : '';

                        try {
                            if (cropMode || (outputCrop && outputCrop.pageIndex === pi)) drawAllRegions(cvs, pi);
                        } catch { /* ignore */ }
                    };
                    img.addEventListener('load', onPreviewImgLoad, { once: true });

                    img.addEventListener('error', () => {
                        img._baseW = 0;
                        img._baseH = 0;
                    }, { once: true });

                    img.src = src;

                    world.appendChild(img);
                    world.appendChild(cvs);
                    world.appendChild(markCvs);
                    shell.appendChild(world);
                    wrap.appendChild(shell);
                    pdfPages.appendChild(wrap);
                    setupCropHandlers(cvs, pi);
                }
                if (pdfPreviewCard) pdfPreviewCard.classList.toggle('hidden', lastPdfPages.length === 0);
                const pageCount = lastPdfPages.length;
                let _loadedCount = 0;
                const _onAllLoaded = () => {
                    if (token !== _pdfPreviewRenderToken) return;

                    if (preserveZoom) {
                        _pendingPdfInitialFit = false;
                        _applyZoomToImages(pdfZoom);
                        if (_prevScroll && pdfViewport) {
                            pdfViewport.scrollLeft = _prevScroll.sl;
                            pdfViewport.scrollTop  = _prevScroll.st;
                        }
                    } else {
                        const canMeasureNow = _canMeasurePdfViewport();
                        const initialZoom = canMeasureNow ? Math.max(0.0001, _fitZoomWidth()) : 1;
                        _setPdfBaseViewZoom(initialZoom);
                        if (canMeasureNow) {
                            setPdfZoom(initialZoom, { resetScroll: true });
                            _pendingPdfInitialFit = false;
                        } else {
                            setPdfZoom(1, { resetScroll: true });
                            _pendingPdfInitialFit = true;
                        }
                    }
                    if (autoDetectColors) detectColorsFromPages(lastPdfPages);
                    setPdfLoadingOverlay(false);
                };
                for (const wrap of pdfPages.querySelectorAll('.pdf-page-wrap')) {
                    const img = wrap.querySelector('img');
                    if (!img) { _loadedCount++; continue; }
                    if (img.complete && img._baseW > 0) {
                        _loadedCount++;
                        if (_loadedCount === pageCount) _onAllLoaded();
                    } else {
                        img.addEventListener('load', () => {
                            _loadedCount++;
                            if (_loadedCount === pageCount) _onAllLoaded();
                        }, { once: true });
                        img.addEventListener('error', () => {
                            _loadedCount++;
                            if (_loadedCount === pageCount) _onAllLoaded();
                        }, { once: true });
                    }
                }
                if (pageCount === 0) _onAllLoaded();
                return;
            } finally {
                if (previewTimeout) clearTimeout(previewTimeout);
            }
        } catch (err) {
            try {
                if (token === _pdfPreviewRenderToken) {
                    const msg = e && e.name === 'AbortError'
                        ? 'PDF preview timed out. Try a lower DPI or a smaller file.'
                        : `Failed to render PDF preview: ${String(e && e.message ? e.message : e)}`;
                    _showPdfPreviewStatus(msg);
                }
                if (err && (err.name === 'AbortError' || String(err).includes('AbortError'))) {
                    showError('PDF preview timed out. Try a lower DPI value for preview.');
                }
            } catch { /* ignore */ }
            if (token === _pdfPreviewRenderToken) setPdfLoadingOverlay(false);
        }
    }

    // ── Auto-detect dominant chromatic colors from PDF page rasters ──
    // Groups pixels by hue-bucket, maps each bucket to a pure primary color.
    function detectColorsFromPages(pageDataUrls) {
        if (!pageDataUrls || pageDataUrls.length === 0) return;

        // Hue buckets → pure primary colors that vtracer actually outputs
        const hueBuckets = [
            { minH: 345, maxH: 360, hex: '#ff0000', name: 'Red'     },
            { minH:   0, maxH:  15, hex: '#ff0000', name: 'Red'     },
            { minH:  15, maxH:  45, hex: '#ff6600', name: 'Orange'  },
            { minH:  45, maxH:  70, hex: '#cccc00', name: 'Yellow'  },
            { minH:  70, maxH: 160, hex: '#00aa00', name: 'Green'   },
            { minH: 160, maxH: 200, hex: '#008888', name: 'Cyan'    },
            { minH: 200, maxH: 260, hex: '#0000ff', name: 'Blue'    },
            { minH: 260, maxH: 300, hex: '#6600cc', name: 'Purple'  },
            { minH: 300, maxH: 345, hex: '#cc00cc', name: 'Magenta' },
        ];

        const bucketCounts = {};  // bucket name → pixel count
        for (const b of hueBuckets) {
            if (!bucketCounts[b.name]) bucketCounts[b.name] = { hex: b.hex, name: b.name, count: 0 };
        }

        let loaded = 0;
        const total = pageDataUrls.length;

        for (const dataUrl of pageDataUrls) {
            const img = new Image();
            img.onload = () => {
                const maxSample = 500;
                const scale = Math.min(1, maxSample / Math.max(img.width, img.height));
                const sw = Math.round(img.width * scale);
                const sh = Math.round(img.height * scale);
                const cvs = document.createElement('canvas');
                cvs.width = sw; cvs.height = sh;
                const ctx = cvs.getContext('2d');
                ctx.drawImage(img, 0, 0, sw, sh);
                const data = ctx.getImageData(0, 0, sw, sh).data;

                for (let i = 0; i < data.length; i += 4) {
                    const r = data[i], g = data[i+1], b = data[i+2], a = data[i+3];
                    if (a < 200) continue;
                    const maxC = Math.max(r, g, b), minC = Math.min(r, g, b);
                    const sat = maxC === 0 ? 0 : (maxC - minC) / maxC;
                    if (sat < 0.25) continue;   // must be chromatic
                    if (maxC < 40) continue;     // too dark
                    if (minC > 210) continue;    // too washed out

                    // Compute hue (0-360)
                    const hsl = rgbToHsl(r, g, b);
                    const hue = hsl.h;

                    // Find matching bucket
                    for (const bk of hueBuckets) {
                        if (hue >= bk.minH && hue < bk.maxH) {
                            bucketCounts[bk.name].count++;
                            break;
                        }
                    }
                }
                loaded++;
                if (loaded === total) buildColorDefsFromBuckets(bucketCounts);
            };
            img.onerror = () => { loaded++; if (loaded === total) buildColorDefsFromBuckets(bucketCounts); };
            img.src = dataUrl;
        }
    }

    function buildColorDefsFromBuckets(bucketCounts) {
        // Sort by count descending, filter significant
        const sorted = Object.values(bucketCounts)
            .filter(b => b.count >= 30)
            .sort((a, b) => b.count - a.count);

        if (sorted.length === 0) return;  // keep defaults

        colorLayerDefs = [];
        _colorIdSeq = 0;
        for (const b of sorted.slice(0, 6)) {
            addLayerDef(b.name, [{ color: b.hex, tolerance: 80 }], true);
        }
    }

