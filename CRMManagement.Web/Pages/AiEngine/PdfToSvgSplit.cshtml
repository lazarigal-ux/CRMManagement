            candidates.push(result);
            const tag = (result.metrics && result.metrics.tagName) || (el.tagName || '').toLowerCase();
            stats.byTag[tag] = (stats.byTag[tag] || 0) + 1;
            for (const reason of (result.reasons || [])) stats.byReason[reason] = (stats.byReason[reason] || 0) + 1;
            if (result.decision === 'remove') {
                stats.removedCount++;
                if ((result.reasons || []).includes('near-white-fill')) stats.whiteFillRemoved++;
                if ((result.reasons || []).includes('dense-short-cluster')) stats.hatchRemoved++;
                if ((result.reasons || []).includes('no-meaningful-neighbors')) stats.isolatedNoiseRemoved++;
            } else if (result.decision === 'unsure') stats.unsureCount++;
            else stats.keptCount++;
        }
        stats.removeRatio = stats.supportedCount > 0 ? (stats.removedCount / stats.supportedCount) : 0;
        if (stats.removeRatio > opts.aggressiveRemoveThreshold) { stats.previewOnly = true; stats.warnings.push('cleanup too aggressive'); }
        if (stats.originalCount > 10000 && stats.keptCount < 200) stats.warnings.push('suspiciously few kept elements');
        const keptWhiteFillCount = candidates.filter(c => c.decision === 'keep' && c.metrics && c.metrics.nearWhiteFill && !c.metrics.visibleStroke).length;
        if (stats.keptCount > 0 && keptWhiteFillCount / Math.max(1, stats.keptCount) > 0.6) stats.warnings.push('remaining output dominated by white fills');
        const actualDebugMode = !!opts.debugMode || stats.previewOnly;
        for (const item of candidates) {
            const el = item.metrics && item.metrics.element;
            if (!el) continue;
            if (item.decision === 'unsure') {
                markUnsure(el, item.reasons || []);
                if (actualDebugMode && opts.enableUnsureBucket) {
                    const clone = el.cloneNode(true);
                    markUnsure(clone, item.reasons || []);
                    let group = svgRoot.querySelector('#ai-unsure-preview');
                    if (!group) { group = doc.createElementNS('http://www.w3.org/2000/svg', 'g'); group.setAttribute('id', 'ai-unsure-preview'); group.setAttribute('opacity', '0.65'); svgRoot.appendChild(group); }
                    group.appendChild(clone);
                }
                continue;
            }
            if (item.decision !== 'remove') continue;
            el.setAttribute('data-ai-class', stats.previewOnly ? 'remove-preview' : 'remove');
            el.setAttribute('data-ai-reasons', (item.reasons || []).join('|'));
            if (actualDebugMode) moveToDebugGroup(el, 'ai-removed-preview');
            else el.remove();
        }
        try {
            console.groupCollapsed('[AI CLEANUP] conservative-remove-small');
            console.log(serializeCleanupDiagnostics(stats));
            console.log('diagnostics', stats);
            console.groupEnd();
        } catch { /* ignore */ }
        return { svgRoot, diagnostics: stats, removedCount: stats.removedCount, keptCount: stats.keptCount, unsureCount: stats.unsureCount, warning: stats.warnings[0] || '', previewOnly: stats.previewOnly };
    }

    function evaluateCleanupGuardrails(originalSvgText, cleanedSvgText, options) {
        const crop = _parseViewBoxStr(options && options.cropViewBox) || null;
        const aggressiveRemoveThreshold = Number.isFinite(Number(options && options.aggressiveRemoveThreshold))
            ? Number(options.aggressiveRemoveThreshold)
            : 0.70;
        const originalCount = countSvgObjects(originalSvgText);
        const remainingCount = countSvgObjects(cleanedSvgText);
        const removedCount = Math.max(0, originalCount - remainingCount);
        const removeRatio = originalCount > 0 ? (removedCount / originalCount) : 0;
        let remainingSupportedCount = 0;
        let remainingWhiteFillCount = 0;
        try {
            const doc = new DOMParser().parseFromString(String(cleanedSvgText || ''), 'image/svg+xml');
            const svgRoot = doc.querySelector('svg');
            if (svgRoot) {
                const metricsList = [...svgRoot.querySelectorAll(_CONSERVATIVE_CLEANUP_SELECTOR)]
                    .filter(el => { try { return !(el.closest && el.closest('defs')); } catch { return true; } })
                    .map(el => collectElementMetrics(el, svgRoot))
                    .filter(m => m && m.supported && (!crop || _cleanupRectIntersects(m.bbox, crop)));
                remainingSupportedCount = metricsList.length;
                remainingWhiteFillCount = metricsList.filter(m => m.nearWhiteFill && !m.visibleStroke).length;
            }
        } catch { /* ignore */ }

        const warnings = [];
        if (removeRatio > aggressiveRemoveThreshold) warnings.push('cleanup too aggressive');
        if (originalCount > 10000 && remainingCount < 200) warnings.push('suspiciously few kept elements');
        if (remainingSupportedCount > 0 && (remainingWhiteFillCount / Math.max(1, remainingSupportedCount)) > 0.6) warnings.push('remaining output dominated by white fills');

        return {
            originalCount,
            remainingCount,
            removedCount,
            removeRatio,
            remainingSupportedCount,
            remainingWhiteFillCount,
            warnings,
            tooAggressive: warnings.includes('cleanup too aggressive') || warnings.includes('suspiciously few kept elements')
        };
    }

    function recomputeFullLayerFromSum(layers) {
        try {
            if (!layers || !Array.isArray(layers) || layers.length === 0) return;
            const full = layers.find(l => (l && l.layerName && String(l.layerName).includes('Full SVG (all layers)')));
            if (!full) return;
            let total = 0;
            for (const l of layers) {
                if (!l || l === full) continue;
                if (l.isFamilyLayer) continue;
                let c = 0;
                if (typeof l.objectCount === 'number' && isFinite(l.objectCount)) c = l.objectCount;
                else if (l.svgContent) c = countSvgObjects(l.svgContent);
                if (isFinite(c) && c > 0) total += c;
            }
            full.objectCount = total;
            full.layerName = `🖼️ Full SVG (all layers) (${total})`;
        } catch {
            // ignore
        }
    }
    function parseJsonSafe(str) {
        if (!str) return null;
        try { return JSON.parse(str); } catch { return null; }
    }
    function analyzeSvg(svgText) {
        if (!svgText || typeof svgText !== 'string') return null;
        try {
            const doc = new DOMParser().parseFromString(svgText, 'image/svg+xml');
            const svg = doc.querySelector('svg');
            if (!svg) return null;
            const vb = svg.getAttribute('viewBox') || '';
            const w = svg.getAttribute('width') || '';
            const h = svg.getAttribute('height') || '';
            const els = [...svg.querySelectorAll('*')];
            const tags = {};
            for (const el of els) {
                const t = (el.tagName || '').toLowerCase();
                tags[t] = (tags[t] || 0) + 1;
            }
            const tagTop = Object.entries(tags).sort((a,b)=>b[1]-a[1]).slice(0, 12);
            return {
                width: w,
                height: h,
                viewBox: vb,
                elementCount: els.length,
                topTags: tagTop
            };
        } catch {
            return null;
        }
    }

    function countSvgTextElements(svgText) {
        try {
            if (!svgText) return 0;
            const doc = new DOMParser().parseFromString(svgText, 'image/svg+xml');
            const svg = doc.querySelector('svg');
            if (!svg) return 0;
            return svg.querySelectorAll('text').length;
        } catch {
            return 0;
        }
    }

    function extractSvgTextSummary(svgText, maxSamples) {
        try {
            if (!svgText) return { textElements: 0, uniqueStrings: 0, totalChars: 0, samples: [] };
            const doc = new DOMParser().parseFromString(svgText, 'image/svg+xml');
            const svg = doc.querySelector('svg');
            if (!svg) return { textElements: 0, uniqueStrings: 0, totalChars: 0, samples: [] };

            const texts = [...svg.querySelectorAll('text')];
            const norm = (s) => String(s || '').replace(/\s+/g, ' ').trim();
            const seen = new Set();
            const samples = [];
            let totalChars = 0;

            for (const t of texts) {
                const raw = norm(t.textContent);
                if (!raw) continue;
                totalChars += raw.length;
                if (!seen.has(raw)) seen.add(raw);
                if (samples.length < (maxSamples || 15)) {
                    const x = t.getAttribute('x');
                    const y = t.getAttribute('y');
                    const fill = t.getAttribute('fill');
                    const fontSize = t.getAttribute('font-size');
                    samples.push({ text: raw.slice(0, 160), x: x || null, y: y || null, fill: fill || null, fontSize: fontSize || null });
                }
            }

            return {
                textElements: texts.length,
                uniqueStrings: seen.size,
                totalChars,
                samples
            };
        } catch {
            return { textElements: 0, uniqueStrings: 0, totalChars: 0, samples: [] };
        }
    }

    function escapeXml(s) {
        return String(s || '')
            .replace(/&/g, '&amp;')
            .replace(/</g, '&lt;')
            .replace(/>/g, '&gt;')
            .replace(/"/g, '&quot;')
            .replace(/'/g, '&apos;');
    }

    function buildPdfExtractTextLayerSvg(lines, vb, w, h) {
        const safeLines = (Array.isArray(lines) ? lines : []).map(l => String(l || '').trim()).filter(l => l.length > 0);
        if (safeLines.length === 0) return '';
        const box = getSvgBox(`<svg viewBox="${vb || ''}" width="${w || ''}" height="${h || ''}"></svg>`) || { w: 1000, h: 1000 };
        const lineH = Math.max(10, Math.round((box.h || 1000) * 0.018));
        const fontSize = Math.max(10, Math.round(lineH * 0.85));
        const maxLines = Math.min(120, safeLines.length);

        const textEls = [];
        let y = Math.max(fontSize + 8, Math.round((box.h || 1000) * 0.05));
        for (let i = 0; i < maxLines; i++) {
            const t = escapeXml(safeLines[i]);
            textEls.push(`<text x="${Math.round((box.w || 1000) * 0.05)}" y="${y}" fill="#111" font-size="${fontSize}" font-family="Arial, sans-serif">${t}</text>`);
            y += lineH;
            if (y > (box.h || 1000) * 0.95) break;
        }
        return wrapPaths(textEls, vb, w, h);
    }

    async function buildPdfBboxTextLayerSvg(words, meta, vb, w, h, options) {
        const useProvidedWords = !!(options && options.useProvidedWords);
        const preferVectorText = !!(options && options.preferVectorText);
        // When merge-before-split is enabled, skip the HIDE EXACT LABELS / LANGUAGES filter — keep all text
        const safeWords = useProvidedWords
            ? (Array.isArray(words) ? words.filter(Boolean) : [])
            : (_pdfPreSplitMergeEnabled ? (Array.isArray(words) ? words.filter(Boolean) : []) : _getVisiblePdfExtractWords(words));
        if (safeWords.length === 0) return '';
        const maxWords = 20000;

        const box = getSvgBox(`<svg viewBox="${vb || ''}" width="${w || ''}" height="${h || ''}"></svg>`) || { w: 1000, h: 1000 };
        const vbParts = String(vb || '').trim().split(/[\s,]+/).map(Number);
        const boxX = (vbParts.length === 4 && vbParts.every(n => isFinite(n))) ? vbParts[0] : 0;
        const boxY = (vbParts.length === 4 && vbParts.every(n => isFinite(n))) ? vbParts[1] : 0;

        const metaW = (meta && isFinite(meta.pageWidthPt)) ? Number(meta.pageWidthPt) : null;
        const metaH = (meta && isFinite(meta.pageHeightPt)) ? Number(meta.pageHeightPt) : null;
        const pageNumber = (meta && isFinite(meta.page)) ? Math.max(1, Number(meta.page) | 0) : 1;

        function isRtlText(s) {
            return /[\u0590-\u05FF\u0600-\u06FF\u0750-\u077F\u08A0-\u08FF]/.test(String(s || ''));
        }

        function _isHebrewFinalLetter(ch) {
            return ch === '\u05DA' || ch === '\u05DD' || ch === '\u05DF' || ch === '\u05E3' || ch === '\u05E5'
                || ch === 'ך' || ch === 'ם' || ch === 'ן' || ch === 'ף' || ch === 'ץ';
        }

        function reversePreservingKeepTokens(s) {
            const str = String(s || '');
            const re = /([0-9A-Za-z\.,:+=\-\/×xX]+|\s+|[^0-9A-Za-z\s]+)/g;
            const parts = str.match(re) || [str];
            const rev = parts.reverse().map(p => {
                if (/^[0-9A-Za-z\.,:+=\-\/×xX]+$/.test(p) || /^\s+$/.test(p)) return p;
                return Array.from(p).reverse().join('');
            });
            return rev.join('');
        }

        let _docVotesReversed = 0;
        let _docVotesCorrect = 0;
        for (let i = 0; i < safeWords.length && i < maxWords; i++) {
            const t = ((safeWords[i] || {}).text == null) ? '' : String(safeWords[i].text).trim();
            const tokens = t.match(/[\u0590-\u05FF]{2,}/g) || [];
            for (const tok of tokens) {
                if (!tok) continue;
                const fFirst = _isHebrewFinalLetter(tok[0]);
                const fLast = _isHebrewFinalLetter(tok[tok.length - 1]);
                if (fFirst && !fLast) _docVotesReversed++;
                else if (fLast && !fFirst) _docVotesCorrect++;
            }
        }
        const _docMajorityReversed = _docVotesReversed > _docVotesCorrect;

        function shouldReverseHebrew(s) {
            const tokens = String(s || '').match(/[\u0590-\u05FF]{2,}/g) || [];
            for (const tok of tokens) {
                if (!tok) continue;
                const fFirst = _isHebrewFinalLetter(tok[0]);
                const fLast = _isHebrewFinalLetter(tok[tok.length - 1]);
                if (fFirst && !fLast) return true;
                if (fLast && !fFirst) return false;
            }
            return _docMajorityReversed;
        }

        function _drawWordMask(ctx, text, width, height, rtl) {
            if (!ctx || !text) return false;
            const pad = Math.max(3, Math.min(12, Math.min(width, height) * 0.14));
            const fontFamily = `Arial, 'Noto Sans Hebrew', 'Segoe UI', sans-serif`;
            const looksVertical = text.length >= 2 && height > (width * 1.8);
            const fontSize = looksVertical
                ? Math.max(5, Math.min(48, width * 0.92))
                : Math.max(5, Math.min(48, height * 0.92));

            function drawDilatedText() {
                ctx.fillText(text, 0, 0);
                ctx.fillText(text, 0.75, 0);
                ctx.fillText(text, -0.75, 0);
                ctx.fillText(text, 0, 0.75);
                ctx.fillText(text, 0, -0.75);
            }

            function measureBounds() {
                const m = ctx.measureText(text);
                const left = Number.isFinite(m.actualBoundingBoxLeft) ? m.actualBoundingBoxLeft : 0;
                const right = Number.isFinite(m.actualBoundingBoxRight) ? m.actualBoundingBoxRight : m.width;
                const ascent = Number.isFinite(m.actualBoundingBoxAscent) ? m.actualBoundingBoxAscent : fontSize * 0.8;
                const descent = Number.isFinite(m.actualBoundingBoxDescent) ? m.actualBoundingBoxDescent : fontSize * 0.2;
                return {
                    width: Math.max(1, left + right, m.width || 0),
                    height: Math.max(1, ascent + descent),
                    ascent,
                    descent
                };
            }

            ctx.save();
            ctx.clearRect(0, 0, width, height);
            ctx.fillStyle = '#fff';
            ctx.font = `${fontSize}px ${fontFamily}`;
            ctx.textBaseline = looksVertical ? 'alphabetic' : 'hanging';
            ctx.textAlign = rtl ? 'right' : 'left';
            try { ctx.direction = rtl ? 'rtl' : 'ltr'; } catch { /* ignore */ }
            const bounds = measureBounds();

            if (looksVertical) {
                const targetW = Math.max(fontSize, width - pad * 2);
                const targetH = Math.max(fontSize, height - pad * 2);
                const scaleX = Math.max(0.6, Math.min(4.0, targetH / bounds.width));
                const scaleY = Math.max(0.6, Math.min(4.0, targetW / bounds.height));
                const ox = rtl ? (width - pad) : pad;
                const oy = height - pad - (bounds.descent * scaleY * 0.25);
                ctx.translate(ox, oy);
                ctx.rotate(-Math.PI / 2);
                ctx.scale(scaleX, scaleY);
                drawDilatedText();
                ctx.restore();
                return true;
            }

            const targetW = Math.max(fontSize, width - pad * 2);
            const targetH = Math.max(fontSize, height - pad * 2);
            const scaleX = Math.max(0.35, Math.min(4.0, targetW / bounds.width));
            const scaleY = Math.max(0.6, Math.min(4.0, targetH / bounds.height));
            const ox = rtl ? (width - pad) : pad;
            const oy = pad + (bounds.ascent * scaleY * 0.9);
            ctx.translate(ox, oy);
            ctx.scale(scaleX, scaleY);
            drawDilatedText();
            ctx.restore();
            return true;
        }

        function _filterCropToLikelyText(cropCtx, guideCtx, width, height) {
            if (!cropCtx || !(width > 0) || !(height > 0)) return false;
            let srcImageData = null;
            let guideImageData = null;
            try {
                srcImageData = cropCtx.getImageData(0, 0, width, height);
                guideImageData = guideCtx ? guideCtx.getImageData(0, 0, width, height) : null;
            } catch {
                return false;
            }
            if (!srcImageData || !srcImageData.data) return false;

            const src = srcImageData.data;
            const guide = (guideImageData && guideImageData.data) ? guideImageData.data : null;
            let kept = 0;

            for (let i = 0; i < src.length; i += 4) {
                const a = src[i + 3];
                if (a <= 0) {
                    src[i + 3] = 0;
                    continue;
                }

                const r = src[i];
                const g = src[i + 1];
                const b = src[i + 2];
                const luminance = (r * 0.299) + (g * 0.587) + (b * 0.114);
                const darkness = 255 - luminance;
                const guideAlpha = guide ? (guide[i + 3] / 255) : 1;
                const nearGuide = guideAlpha > 0.015;
                const threshold = nearGuide ? 22 : 92;
                const allowStrongLoosePixel = (!nearGuide && darkness >= 150);
                if (darkness <= threshold || (!nearGuide && !allowStrongLoosePixel)) {
                    src[i + 3] = 0;
                    continue;
                }

                const computedAlpha = Math.max(0, Math.min(255, Math.round((darkness - threshold) * (nearGuide ? 5.0 : 3.2))));
                src[i + 3] = Math.min(a, computedAlpha);
                kept++;
            }

            if (!kept) return false;
            cropCtx.clearRect(0, 0, width, height);
            cropCtx.putImageData(srcImageData, 0, 0);
            return true;
        }

        async function tryBuildFromPreviewRaster() {
            const pageSrc = Array.isArray(lastPdfPages) ? String(lastPdfPages[pageNumber - 1] || '') : '';
            if (!pageSrc) return '';

            const img = await new Promise((resolve) => {
                try {
                    const el = new Image();
                    el.onload = () => resolve(el);
                    el.onerror = () => resolve(null);
                    el.src = pageSrc;
                } catch {
                    resolve(null);
                }
            });
            if (!img) return '';

            const imgW = img.naturalWidth || img.width || 0;
            const imgH = img.naturalHeight || img.height || 0;
            if (!(imgW > 0) || !(imgH > 0)) return '';

            function scoreDims(pw, ph) {
                if (!pw || !ph || pw <= 0 || ph <= 0) return Number.POSITIVE_INFINITY;
                return Math.abs((imgW / pw) - 1) + Math.abs((imgH / ph) - 1);
            }

            let pageW = metaW;
            let pageH = metaH;
            if (metaW && metaH) {
                const sNormal = scoreDims(metaW, metaH);
                const sSwapped = scoreDims(metaH, metaW);
                if (sSwapped < sNormal) {
                    pageW = metaH;
                    pageH = metaW;
                }
            }
            if (!pageW || !pageH) {
                pageW = imgW;
                pageH = imgH;
            }

            const scaleX = (pageW > 0) ? (imgW / pageW) : 1;
            const scaleY = (pageH > 0) ? (imgH / pageH) : 1;

            const canvas = document.createElement('canvas');
            canvas.width = imgW;
            canvas.height = imgH;
            const ctx = canvas.getContext('2d');
            if (!ctx) return '';

            ctx.clearRect(0, 0, imgW, imgH);
            ctx.imageSmoothingEnabled = true;

            let painted = 0;
            for (let i = 0; i < safeWords.length && i < maxWords; i++) {
                const it = safeWords[i] || {};
                const tRaw = (it.text == null) ? '' : String(it.text).trim();
                if (!tRaw) continue;
                const xMin = Number(it.xMin);
                const yMin = Number(it.yMin);
                const xMax = Number(it.xMax);
                const yMax = Number(it.yMax);
                if (!isFinite(xMin) || !isFinite(yMin) || !isFinite(xMax) || !isFinite(yMax)) continue;

                const rtl = isRtlText(tRaw);
                const tDraw = (rtl && shouldReverseHebrew(tRaw)) ? reversePreservingKeepTokens(tRaw) : tRaw;

                const rawW = Math.abs(xMax - xMin) * scaleX;
                const rawH = Math.abs(yMax - yMin) * scaleY;
                const padPx = Math.max(8, Math.min(20, Math.round(Math.max(rawW, rawH) * 0.22)));

                const sx = Math.max(0, Math.floor(Math.min(xMin, xMax) * scaleX) - padPx);
                const sy = Math.max(0, Math.floor(Math.min(yMin, yMax) * scaleY) - padPx);
                const sw = Math.min(imgW - sx, Math.max(1, Math.ceil(Math.abs(xMax - xMin) * scaleX) + padPx * 2));
                const sh = Math.min(imgH - sy, Math.max(1, Math.ceil(Math.abs(yMax - yMin) * scaleY) + padPx * 2));
                if (!(sw > 0) || !(sh > 0)) continue;

                try {
                    const cropCanvas = document.createElement('canvas');
                    cropCanvas.width = sw;
                    cropCanvas.height = sh;
                    const cropCtx = cropCanvas.getContext('2d');
                    if (!cropCtx) continue;

                    cropCtx.clearRect(0, 0, sw, sh);
                    cropCtx.drawImage(img, sx, sy, sw, sh, 0, 0, sw, sh);

                    const maskCanvas = document.createElement('canvas');
                    maskCanvas.width = sw;
                    maskCanvas.height = sh;
                    const maskCtx = maskCanvas.getContext('2d');
                    if (!maskCtx) continue;

                    if (!_drawWordMask(maskCtx, tDraw, sw, sh, rtl)) continue;

                    if (!_filterCropToLikelyText(cropCtx, maskCtx, sw, sh)) continue;

                    ctx.drawImage(cropCanvas, sx, sy, sw, sh);
                    painted++;
                } catch {
                    // ignore per-word draw failure
                }
            }

            if (!painted) return '';

            const pngDataUrl = canvas.toDataURL('image/png');
            return wrapPaths([
                '<g pointer-events="none">',
                `<image href="${pngDataUrl}" x="${boxX.toFixed(2)}" y="${boxY.toFixed(2)}" width="${(box.w || imgW).toFixed(2)}" height="${(box.h || imgH).toFixed(2)}" preserveAspectRatio="none" />`,
                '</g>'
            ], vb, w, h);
        }

        if (!preferVectorText) {
            try {
                const rasterSvg = await tryBuildFromPreviewRaster();
                if (rasterSvg) return rasterSvg;
            } catch {
                // fall back to vector text approximation below
            }
        }

        function scoreDims(pw, ph) {
            if (!pw || !ph || pw <= 0 || ph <= 0) return Number.POSITIVE_INFINITY;
            const bw = (box.w || 1000);
            const bh = (box.h || 1000);
            return Math.abs((bw / pw) - 1) + Math.abs((bh / ph) - 1);
        }

        let pageW = metaW;
        let pageH = metaH;
        if (metaW && metaH) {
            const sNormal = scoreDims(metaW, metaH);
            const sSwapped = scoreDims(metaH, metaW);
            if (sSwapped < sNormal) {
                pageW = metaH;
                pageH = metaW;
            }
        }
        if (!pageW || !pageH) {
            // Fall back to viewBox size if we have no reliable page size.
            pageW = (box.w || 1000);
            pageH = (box.h || 1000);
        }

        const scaleX = (pageW > 0) ? ((box.w || 1000) / pageW) : 1;
        const scaleY = (pageH > 0) ? ((box.h || 1000) / pageH) : 1;

        const textEls = [];

        for (let i = 0; i < safeWords.length && i < maxWords; i++) {
            const it = safeWords[i] || {};
            const tRaw = (it.text == null) ? '' : String(it.text).trim();
            if (!tRaw) continue;
            const xMin = Number(it.xMin);
            const yMin = Number(it.yMin);
            const xMax = Number(it.xMax);
            const yMax = Number(it.yMax);
            if (!isFinite(xMin) || !isFinite(yMin) || !isFinite(xMax) || !isFinite(yMax)) continue;

            const rtl = isRtlText(tRaw);
            const tDraw = (rtl && shouldReverseHebrew(tRaw)) ? reversePreservingKeepTokens(tRaw) : tRaw;
            const boxX = xMin * scaleX;
            const boxY = yMin * scaleY;
            const boxW = Math.max(0.5, (xMax - xMin) * scaleX);
            const hSvg = Math.max(0, (yMax - yMin) * scaleY);
            const boxH = Math.max(0.5, hSvg);
            const looksVertical = tDraw.length >= 2 && boxH > (boxW * 1.8);
            const fontSize = looksVertical
                ? Math.max(5, Math.min(42, boxW * 0.82))
                : Math.max(5, Math.min(42, boxH * 0.82));
            const fontFamily = `Arial, 'Noto Sans Hebrew', 'Segoe UI', sans-serif`;

            if (looksVertical) {
                const vx = boxX;
                const vy = boxY + boxH;
                const vTextLen = Math.max(fontSize, boxH * 0.96);
                textEls.push(
                    `<text x="${vx.toFixed(2)}" y="${vy.toFixed(2)}" fill="#111" font-size="${fontSize.toFixed(2)}" font-family="${fontFamily}" dominant-baseline="alphabetic" text-anchor="start" lengthAdjust="spacingAndGlyphs" textLength="${vTextLen.toFixed(2)}" transform="rotate(-90 ${vx.toFixed(2)} ${vy.toFixed(2)})"${rtl ? ' direction="rtl" unicode-bidi="plaintext"' : ' direction="ltr" unicode-bidi="plaintext"'}>${escapeXml(tDraw)}</text>`
                );
                continue;
            }

            // For RTL, anchor on the right edge and fit glyphs into the bbox width.
            const x = (rtl ? (boxX + boxW) : boxX);
            const y = boxY;
            const textLen = Math.max(fontSize, boxW * 0.96);

            textEls.push(
                `<text x="${x.toFixed(2)}" y="${y.toFixed(2)}" fill="#111" font-size="${fontSize.toFixed(2)}" font-family="${fontFamily}" dominant-baseline="hanging" lengthAdjust="spacingAndGlyphs" textLength="${textLen.toFixed(2)}"${rtl ? ' direction="rtl" unicode-bidi="plaintext" text-anchor="end"' : ' direction="ltr" unicode-bidi="plaintext" text-anchor="start"'}>${escapeXml(tDraw)}</text>`
            );
        }

        if (textEls.length === 0) return '';
        // Make the overlay non-interactive.
        const wrapped = ['<g pointer-events="none">', ...textEls, '</g>'];
        return wrapPaths(wrapped, vb, w, h);
    }

    async function _appendPdfBboxTextLayersToLayers(layers, baseVb, baseW, baseH, cropFrac) {
        if (!(layers && Array.isArray(layers))) {
            return { addedGroups: 0, visibleWords: 0, hiddenWords: 0 };
        }
        if (!(pdfExtractWords && Array.isArray(pdfExtractWords) && pdfExtractWords.length > 0)) {
            return { addedGroups: 0, visibleWords: 0, hiddenWords: 0 };
        }

        // When merge-before-split is enabled, skip the HIDE EXACT LABELS / LANGUAGES filter — keep all text
        const skipTextFilter = !!_pdfPreSplitMergeEnabled;
        const visiblePdfWords = skipTextFilter ? [...pdfExtractWords] : _getVisiblePdfExtractWords(pdfExtractWords);
        const ignoredPdfWords = skipTextFilter ? [] : _getIgnoredPdfExtractWords(pdfExtractWords);
        const visibleWordGroups = _groupPdfTextItemsByLanguage(visiblePdfWords, word => word && word.text != null ? String(word.text) : '');
        let addedPdfTextLayerCount = 0;

        for (const group of visibleWordGroups) {
            let textSvg = await buildPdfBboxTextLayerSvg(group.items, pdfExtractWordsMeta || {}, baseVb, baseW, baseH, { useProvidedWords: true });
            if (cropFrac && textSvg) textSvg = cropSvgByFraction(textSvg, cropFrac);
            if (!textSvg) continue;

            const shown = Math.min(20000, group.items.length);
            const textLayer = {
                layerName: `🔤 ${group.label} (PDF bbox) (${shown})`,
                color: '#4A5568',
                svgContent: textSvg,
                icon: 'fa-font',
                objectCount: shown
            };
            const otherIdx = layers.findIndex(l => (l && l.layerName && String(l.layerName).toLowerCase().includes('other elements')));
            if (otherIdx >= 0) layers.splice(otherIdx, 0, textLayer);
            else layers.push(textLayer);
            addedPdfTextLayerCount++;
        }

        if (ignoredPdfWords.length > 0) {
            let ignoredTextSvg = await buildPdfBboxTextLayerSvg(ignoredPdfWords, pdfExtractWordsMeta || {}, baseVb, baseW, baseH, { useProvidedWords: true });
            if (cropFrac && ignoredTextSvg) ignoredTextSvg = cropSvgByFraction(ignoredTextSvg, cropFrac);
            if (ignoredTextSvg) {
                _appendElementsToOtherLayer(
                    layers,
                    _extractSvgLayerBodyElements(ignoredTextSvg),
                    cropFrac ? '' : baseVb,
                    cropFrac ? '' : baseW,
                    cropFrac ? '' : baseH,
                    ''
                );
            }
        }

        return {
            addedGroups: addedPdfTextLayerCount,
            visibleWords: visiblePdfWords.length,
            hiddenWords: ignoredPdfWords.length
        };
    }

    function _appendSvgOverlay(baseSvgText, overlaySvgText) {
        try {
            const baseSvg = String(baseSvgText || '');
            const overlaySvg = String(overlaySvgText || '');
            if (!baseSvg || !overlaySvg) return baseSvg;
            const baseMetrics = _getSvgRootMetrics(baseSvg);
            if (!baseMetrics) return baseSvg;
            const mergedBody = [
                ..._extractSvgLayerBodyElements(baseSvg),
                ..._extractSvgLayerBodyElements(overlaySvg)
            ];
            return wrapPaths(mergedBody, baseMetrics.vb, baseMetrics.w, baseMetrics.h, baseMetrics.defsHtml || '');
        } catch {
            return String(baseSvgText || '');
        }
    }

    async function _fetchPdfTextWordsForPage(file, pageNumber) {
        if (!file) return { words: [], meta: {} };
        const page = Math.max(1, Number(pageNumber) || 1);
        const fd = new FormData();
        fd.append('pdf', file, file.name || 'document.pdf');
        const resp = await fetch(`${VECTOR_PDF_TEXT_WORDS_ENDPOINT}?page=${page}`, {
            method: 'POST',
            body: fd,
            headers: { 'X-Client-Id': 'admin' }
        });
        if (!resp.ok) {
            const errText = await resp.text();
            throw new Error(`PDF text words failed: HTTP ${resp.status} ${String(errText || '').slice(0, 200)}`);
        }
        const obj = await resp.json();
        const words = (obj && Array.isArray(obj.words)) ? obj.words : [];
        const meta = {
            page,
            pageWidthPt: obj && Number.isFinite(Number(obj.pageWidthPt)) ? Number(obj.pageWidthPt) : null,
            pageHeightPt: obj && Number.isFinite(Number(obj.pageHeightPt)) ? Number(obj.pageHeightPt) : null
        };
        pdfExtractWords = words;
        pdfExtractWordsMeta = meta;
        return { words, meta };
    }

    function getImageSize(dataUrl) {
        return new Promise((resolve) => {
            if (!dataUrl) return resolve(null);
            const img = new Image();
            img.onload = () => resolve({ w: img.width, h: img.height });
            img.onerror = () => resolve(null);
            img.src = dataUrl;
        });
    }

    function setSummaryItems(items) {
        if (!processReportSummary) return;
        processReportSummary.innerHTML = '';
        if (!items || items.length === 0) return;

        for (const it of items) {
            const card = document.createElement('div');
            card.className = 'rounded-xl border border-slate-700/40 bg-slate-900/20 px-3 py-2';

            const k = document.createElement('div');
            k.className = 'text-[11px] text-slate-400 uppercase tracking-wider';
            k.textContent = it.label || '';

            const v = document.createElement('div');
            v.className = 'mt-0.5 text-sm text-slate-100 break-words';
            v.textContent = it.value || '';

            const s = document.createElement('div');
            s.className = 'mt-0.5 text-[11px] text-slate-400 break-words';
            s.textContent = it.sub || '';
            if (!it.sub) s.classList.add('hidden');

            card.appendChild(k);
            card.appendChild(v);
            card.appendChild(s);
            processReportSummary.appendChild(card);
        }
    }

    function reportReset() {
        _processReport = null;
        if (processReportText) processReportText.textContent = '';
        if (processReportSummary) processReportSummary.innerHTML = '';
        if (processReportCard) processReportCard.classList.add('hidden');
        if (pdfTextPanel) pdfTextPanel.classList.add('hidden');
        if (pdfSizePanel) pdfSizePanel.classList.add('hidden');
        if (pdfSizeInfoCard) pdfSizeInfoCard.classList.add('hidden');
