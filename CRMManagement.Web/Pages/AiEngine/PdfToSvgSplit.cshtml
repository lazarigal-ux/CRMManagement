        }

        const first = dims[0] || {};
        const pxW = (first.pixelWidth != null && isFinite(first.pixelWidth)) ? Number(first.pixelWidth) : null;
        const pxH = (first.pixelHeight != null && isFinite(first.pixelHeight)) ? Number(first.pixelHeight) : null;
        const ptW = (pxW != null && dpi > 0) ? (pxW * 72.0) / dpi : null;
        const ptH = (pxH != null && dpi > 0) ? (pxH * 72.0) / dpi : null;
        const mmW = (ptW != null) ? (ptW * 25.4 / 72.0) : null;
        const mmH = (ptH != null) ? (ptH * 25.4 / 72.0) : null;
        const inW = (ptW != null) ? (ptW / 72.0) : null;
        const inH = (ptH != null) ? (ptH / 72.0) : null;
        const capped = !!(maxDimUsed && pxW != null && pxH != null && (Math.abs(pxW - maxDimUsed) < 1 || Math.abs(pxH - maxDimUsed) < 1));

        let mixedSizes = false;
        const firstKey = (ptW != null && ptH != null) ? `${Math.round(ptW * 100)}/${Math.round(ptH * 100)}` : null;
        for (let i = 1; i < dims.length; i++) {
            const d = dims[i] || {};
            const pxw = (d.pixelWidth != null && isFinite(d.pixelWidth)) ? Number(d.pixelWidth) : null;
            const pxh = (d.pixelHeight != null && isFinite(d.pixelHeight)) ? Number(d.pixelHeight) : null;
            const w = (pxw != null && dpi > 0) ? (pxw * 72.0) / dpi : null;
            const h = (pxh != null && dpi > 0) ? (pxh * 72.0) / dpi : null;
            const key = (w != null && h != null) ? `${Math.round(w * 100)}/${Math.round(h * 100)}` : null;
            if (firstKey && key && key !== firstKey) { mixedSizes = true; break; }
        }

        pdfSizeInfoSummary.textContent = `${dims.length} page(s)`
            + ((ptW != null && ptH != null) ? ` • ${mixedSizes ? 'mixed sizes' : `${fmtNum(ptW)}×${fmtNum(ptH)} pt`}` : '')
            + ((dpi && isFinite(dpi)) ? ` • preview ${fmtNum(dpi)} DPI` : '')
