    function setFamilyYoloDetectPreset(v) {
        const preset = (v == null) ? 'balanced' : String(v).trim().toLowerCase();
        if (preset === 'custom') {
            _familyYoloDetectSettings = { ..._getFamilyYoloDetectSettings(), preset: 'custom' };
        } else {
            const next = Object.prototype.hasOwnProperty.call(_familyYoloDetectPresets, preset) ? preset : 'balanced';
            _familyYoloDetectSettings = { preset: next, ..._familyYoloDetectPresets[next] };
        }
        _saveFamilyYoloDetectSettings();
        _updateSelectedFamilyRecordDetectSettings(_familyYoloDetectSettings);
        _persistSelectedFamilyYoloDetectSettings();
        _rerenderFamilyLearnPanelIfNeeded();
    }

    function setFamilyYoloDetectField(field, value) {
        const key = (field == null) ? '' : String(field).trim().toLowerCase();
        const current = _getFamilyYoloDetectSettings();
        const n = Number(value);
        if (key === 'conf' && Number.isFinite(n)) current.conf = Math.max(0.01, Math.min(0.95, n));
        else if (key === 'iou' && Number.isFinite(n)) current.iou = Math.max(0.05, Math.min(0.95, n));
        else if (key === 'imgsz' && Number.isFinite(n)) current.imgsz = Math.max(640, Math.min(3072, Math.round(n)));
        current.preset = 'custom';
        _familyYoloDetectSettings = _normalizeFamilyYoloDetectSettings(current);
        _saveFamilyYoloDetectSettings();
        _updateSelectedFamilyRecordDetectSettings(_familyYoloDetectSettings);
        _persistSelectedFamilyYoloDetectSettings();
        _rerenderFamilyLearnPanelIfNeeded();
    }

    function resetFamilyYoloDetectSettings() {
        _familyYoloDetectSettings = { preset: 'balanced', ..._familyYoloDetectPresets.balanced };
        _saveFamilyYoloDetectSettings();
        _updateSelectedFamilyRecordDetectSettings(_familyYoloDetectSettings);
        _persistSelectedFamilyYoloDetectSettings();
        _rerenderFamilyLearnPanelIfNeeded();
    }

    function _syncFamilyYoloDetectSettingsFromResponse(obj) {
        try {
            const s = obj && obj.yolo && obj.yolo.detectSettings ? obj.yolo.detectSettings : null;
            if (!s) return;
            _familyYoloDetectSettings = _normalizeFamilyYoloDetectSettings({ conf: s.conf, iou: s.iou, imgsz: s.imgsz });
            _updateSelectedFamilyRecordDetectSettings(_familyYoloDetectSettings);
            _saveFamilyYoloDetectSettings();
        } catch { /* ignore */ }
    }

    function _setFamilyYoloMemoryFilter(filter) {
        const next = (filter || 'all').toString().trim().toLowerCase();
        _familyYoloMemoryFilter = (next === 'positive' || next === 'negative') ? next : 'all';
        _familyYoloMemoryVisibleCount = _familyYoloMemoryPageSize;
        try { if (_lastFamilyLearnModel) _renderFamilyLearnPanel(_lastFamilyLearnModel); } catch { /* ignore */ }
    }

    function _showMoreFamilyYoloMemory() {
        _familyYoloMemoryVisibleCount += _familyYoloMemoryPageSize;
        try { if (_lastFamilyLearnModel) _renderFamilyLearnPanel(_lastFamilyLearnModel); } catch { /* ignore */ }
    }

    function setFamilyScanAiModel(v) {
        try {
            const s = (v == null) ? '' : String(v);
            _familyScanAiModel = s.trim().slice(0, 120);
        } catch {
            _familyScanAiModel = '';
        }
        try { _syncSvgAiModelPicker(); } catch { /* ignore */ }
    }

    function _appendFamilyScanLog(msg) {
        try {
            const now = new Date();
            const ts = now.toISOString().substring(11, 19);
            const line = `[${ts}] ${(msg == null) ? '' : String(msg)}`.trim();
            if (!_familyScanLogLines) _familyScanLogLines = [];
            _familyScanLogLines.push(line);
            // Keep logs small (avoid UI lag)
            if (_familyScanLogLines.length > 60) _familyScanLogLines = _familyScanLogLines.slice(-60);
            try { console.log('[FAMILY-SCAN]', line); } catch { /* ignore */ }
        } catch { /* ignore */ }
    }

    function _clearFamilyYoloStatusPoll() {
        try {
            if (_familyYoloStatusPollTimer) clearTimeout(_familyYoloStatusPollTimer);
        } catch { /* ignore */ }
        _familyYoloStatusPollTimer = 0;
    }

    function _clearAnnotatedHotspotClickTimer() {
        try {
            if (_annotatedHotspotClickTimer) clearTimeout(_annotatedHotspotClickTimer);
        } catch { /* ignore */ }
        _annotatedHotspotClickTimer = 0;
    }

    function _resetFamilyYoloMirroredLogs(famId) {
        _familyYoloMirroredLogKey = String(Number.isFinite(famId) ? famId : 0);
        _familyYoloMirroredLogCount = 0;
    }

    function _mirrorFamilyYoloStatusLogs() {
        try {
            const st = _familyYoloStatus;
            if (!st) return;
            const famKey = String(Number.isFinite(st.familyId) ? st.familyId : 0);
            const lines = Array.isArray(st.logLines) ? st.logLines.map(x => String(x || '').trim()).filter(Boolean) : [];
            if (_familyYoloMirroredLogKey !== famKey) {
                _familyYoloMirroredLogKey = famKey;
                _familyYoloMirroredLogCount = 0;
            }
            if (lines.length < _familyYoloMirroredLogCount) _familyYoloMirroredLogCount = 0;
            const fresh = lines.slice(_familyYoloMirroredLogCount);
            _familyYoloMirroredLogCount = lines.length;
            for (const line of fresh) {
                const normalized = line.replace(/^\[[^\]]+\]\s*/, '').trim();
                if (!normalized) continue;
                _appendFamilyScanLog(`YOLO ${normalized}`);
            }
        } catch { /* ignore */ }
    }

    function _queueFamilyYoloStatusPoll(delayMs) {
        _clearFamilyYoloStatusPoll();
        const ms = Math.max(1000, isFinite(delayMs) ? Number(delayMs) : 2500);
        _familyYoloStatusPollTimer = setTimeout(() => {
            _familyYoloStatusPollTimer = 0;
            refreshSelectedFamilyYoloStatus(true).catch(() => { /* ignore */ });
        }, ms);
    }

    function _getSelectedFamilyName() {
        try {
            const famId = _getSelectedFamilyId();
            const fam = Array.isArray(_objectFamilies) ? _objectFamilies.find(f => Number(f && f.id) === famId) : null;
            if (fam && fam.name != null) return String(fam.name || '').trim();
            const raw = (familySelect && familySelect.selectedOptions && familySelect.selectedOptions[0])
                ? String(familySelect.selectedOptions[0].dataset.familyName || familySelect.selectedOptions[0].textContent || '').trim()
                : '';
            return raw.replace(/\s+\(\d+\)\s*$/, '').trim();
        } catch {
            return '';
        }
    }

    function _getSelectedFamilyTypeKey() {
        try {
            const fam = _getSelectedFamilyRecord();
            if (fam) return _getFamilyTypeMeta(fam.typeKey, fam.name).key;
            const raw = (familySelect && familySelect.selectedOptions && familySelect.selectedOptions[0])
                ? String(familySelect.selectedOptions[0].dataset.familyTypeKey || '').trim()
                : '';
            return _getFamilyTypeMeta(raw, _getSelectedFamilyName()).key;
        } catch {
            return 'other';
        }
    }

    function _formatUtcShort(v) {
        try {
            if (!v) return '';
            const d = new Date(v);
            if (!isFinite(d.getTime())) return '';
            return d.toISOString().substring(0, 19).replace('T', ' ');
        } catch {
            return '';
        }
    }

    function _getFamilyYoloTrainingProgress(st) {
        try {
            const lines = Array.isArray(st && st.logLines) ? st.logLines : [];
            let current = 0;
            let total = 0;
            for (const rawLine of lines) {
                const line = String(rawLine || '').replace(/^\[[^\]]+\]\s*/, '').trim();
                if (!line || line.startsWith('ERR ')) continue;
                const explicit = /^PROGRESS\s+([0-9]+)\s*\/\s*([0-9]+)\b/i.exec(line);
                if (explicit) {
                    const cur = parseInt(explicit[1], 10);
                    const all = parseInt(explicit[2], 10);
                    if (Number.isFinite(cur) && Number.isFinite(all) && all > 0) {
                        if (all > total || (all === total && cur >= current)) {
                            current = cur;
                            total = all;
                        }
                    }
                    continue;
                }
                const m = /^([0-9]+)\s*\/\s*([0-9]+)\b/.exec(line);
                if (!m) continue;
                const cur = parseInt(m[1], 10);
                const all = parseInt(m[2], 10);
                if (!Number.isFinite(cur) || !Number.isFinite(all) || cur <= 0 || all <= 0) continue;
                if (all > total || (all === total && cur > current)) {
                    current = cur;
                    total = all;
                }
            }

            if (total > 0) {
                const percent = Math.max(1, Math.min(100, Math.round((current / total) * 100)));
                return { current, total, percent, label: `Epoch ${current}/${total}` };
            }

            if (st && st.isTraining) {
                return { current: 0, total: 0, percent: 8, label: 'Preparing training…' };
            }

            return null;
        } catch {
            return null;
        }
    }

    function _getFamilyYoloStatusSummaryHtml() {
        try {
            const famId = _getSelectedFamilyId();
            const st = (_familyYoloStatus && _familyYoloStatus.familyId === famId) ? _familyYoloStatus : null;
            if (!st) {
                return '<span class="text-[11px] text-slate-500">YOLO status: not loaded</span>';
            }
            const hasModel = !!st.hasModel;
            const isTraining = !!st.isTraining;
            const updated = _formatUtcShort(st.modelUpdatedAtUtc || st.finishedAtUtc || '');
            const badgeCls = isTraining
                ? 'border-amber-500/40 bg-amber-900/20 text-amber-200'
                : (hasModel ? 'border-emerald-500/40 bg-emerald-900/20 text-emerald-200' : 'border-slate-600/40 bg-slate-900/20 text-slate-300');
            const badgeText = isTraining ? 'training' : (hasModel ? 'ready' : 'not trained');
            const meta = [];
            if (isFinite(st.detectionCount) && st.detectionCount > 0) meta.push(`${st.detectionCount | 0} boxes`);
            if (isFinite(st.pagesExported) && st.pagesExported > 0) meta.push(`${st.pagesExported | 0} pages`);
            if (updated) meta.push(updated);
            if (st.error) meta.push(String(st.error));
            const progress = isTraining ? _getFamilyYoloTrainingProgress(st) : null;
            const progressHtml = progress
                ? `<div class="flex items-center gap-2 min-w-[260px] max-w-[420px] w-full sm:w-auto">
                        <div class="relative h-5 flex-1 overflow-hidden rounded-full border border-amber-500/30 bg-slate-900/50">
                            <div class="h-full rounded-full bg-gradient-to-r from-amber-400 via-yellow-300 to-amber-500 transition-all duration-500" style="width:${Math.max(4, progress.percent)}%"></div>
                            <div class="absolute inset-0 flex items-center justify-center px-2 text-[10px] font-bold tracking-wide text-slate-950">${escapeHtml(progress.percent + '%')}</div>
                        </div>
                        <span class="text-[10px] font-semibold text-amber-200 whitespace-nowrap">${escapeHtml(progress.label)}</span>
                    </div>`
                : '';
            return `<div class="flex items-center gap-2 flex-wrap">
                        <span class="inline-flex items-center rounded border px-2 py-0.5 text-[11px] font-semibold ${badgeCls}">YOLO ${escapeHtml(badgeText)}</span>
                        <span class="text-[11px] text-slate-500">${escapeHtml(meta.join(' • ') || 'Family-specific detector')}</span>
                        ${progressHtml}
                    </div>`;
        } catch {
            return '<span class="text-[11px] text-slate-500">YOLO status unavailable</span>';
        }
    }

    async function refreshSelectedFamilyYoloStatus(silent = false) {
        const famId = _getSelectedFamilyId();
        if (!famId) {
            _familyYoloStatus = null;
            _resetFamilyYoloMirroredLogs(0);
            _clearFamilyYoloStatusPoll();
            return null;
        }
        try {
            const wasTraining = !!(_familyYoloStatus && _familyYoloStatus.familyId === famId && _familyYoloStatus.isTraining);
            const resp = await fetch(`${OBJECT_FAMILIES_ENDPOINT}/${famId}/yolo-status`, { headers: { 'X-Client-Id': 'admin' } });
            if (!resp.ok) {
                if (!silent) {
                    const t = await resp.text();
                    throw new Error(`HTTP ${resp.status}: ${t.substring(0, 300)}`);
                }
                return _familyYoloStatus;
            }
            const obj = await resp.json();
            const st = obj && obj.status ? obj.status : null;
            if (st) _familyYoloStatus = st;
            _mirrorFamilyYoloStatusLogs();
            if (_familyYoloStatus && _familyYoloStatus.isTraining) _queueFamilyYoloStatusPoll(2500);
            else _clearFamilyYoloStatusPoll();
            if (wasTraining && _familyYoloStatus && !_familyYoloStatus.isTraining) {
                try { await _refreshFamilySamplesPanel(famId); } catch { /* ignore */ }
            }
            try { if (_lastFamilyLearnModel) _renderFamilyLearnPanel(_lastFamilyLearnModel); } catch { /* ignore */ }
            return _familyYoloStatus;
        } catch (e) {
            if (!silent) {
                _appendFamilyScanLog(`YOLO status failed: ${String(e)}`);
                cgAlert(`YOLO status failed: ${String(e)}`);
            }
            return _familyYoloStatus;
        }
    }

    function _getFamilyScanLogHtml() {
        try {
            const lines = Array.isArray(_familyScanLogLines) ? _familyScanLogLines : [];
            if (!lines.length) return '';
            const text = lines.join('\n');
            return `<div class="mt-2 rounded-xl border border-slate-700/40 bg-slate-950/40 px-3 py-2">
                        <div class="flex items-center gap-2">
                            <div class="text-[11px] text-slate-400">Scan log</div>
                            <div class="ms-auto text-[11px] text-slate-500">(latest first)</div>
                        </div>
                        <pre class="mt-1 whitespace-pre-wrap break-words text-[11px] leading-snug text-slate-200">${escapeHtml(text.split('\n').reverse().join('\n'))}</pre>
                    </div>`;
        } catch {
            return '';
        }
    }

    function _getAnnotatedDisplayCrop(pageIndex) {
        try {
            if (!outputCrop || !outputCrop.frac || typeof outputCrop.frac !== 'object') return null;
            const pi = (outputCrop.pageIndex != null && isFinite(outputCrop.pageIndex)) ? (outputCrop.pageIndex | 0) : -1;
            if (pi !== (pageIndex | 0)) return null;

            const fx = Number(outputCrop.frac.x);
            const fy = Number(outputCrop.frac.y);
            const fw = Number(outputCrop.frac.w);
            const fh = Number(outputCrop.frac.h);
            if (!Number.isFinite(fx) || !Number.isFinite(fy) || !Number.isFinite(fw) || !Number.isFinite(fh)) return null;
            if (fw <= 0.0005 || fh <= 0.0005) return null;

            const x = Math.max(0, Math.min(1, fx));
            const y = Math.max(0, Math.min(1, fy));
            const w = Math.max(0.0005, Math.min(1 - x, fw));
            const h = Math.max(0.0005, Math.min(1 - y, fh));
            return { x, y, w, h };
        } catch {
            return null;
        }
    }

    function _getDetectionApprovalValue(r, idx, includePending = true) {
        let committed = null;
        if (r && r.approved === true) committed = true;
        else if (r && r.approved === false) committed = false;
        if (!includePending) return committed;
        const i = parseInt(String(idx != null ? idx : ''), 10);
        if (!Number.isFinite(i) || i < 0) return committed;
        if (_pendingDetectionApprovalChanges && Object.prototype.hasOwnProperty.call(_pendingDetectionApprovalChanges, String(i))) {
            const pendingValue = _pendingDetectionApprovalChanges[String(i)];
            return pendingValue === true ? true : (pendingValue === false ? false : null);
        }
        return committed;
    }

    function _getDetectionApprovedState(r, idx, includePending = true) {
        return _getDetectionApprovalValue(r, idx, includePending) === true;
    }

    function _getDetectionRejectedState(r, idx, includePending = true) {
        return _getDetectionApprovalValue(r, idx, includePending) === false;
    }

    function _getDetectionVisualState(r) {
        const idx = (arguments.length > 1 && Number.isFinite(arguments[1])) ? (arguments[1] | 0) : -1;
        const includePending = arguments.length > 2 ? !!arguments[2] : true;
        if (r && r.isManualAdd) return 'manual';
        const approval = _getDetectionApprovalValue(r, idx, includePending);
        if (approval === true) return 'approved';
        if (approval === false) return 'rejected';
        return 'detected';
    }

    function _getDetectionSourceLabel(r) {
        try {
            const src = (r && r.detectSource != null) ? String(r.detectSource).trim().toLowerCase() : '';
            if (src === 'yolo') return 'YOLO';
            if (src === 'cv+yolo' || src === 'parallel') return 'CV+YOLO';
            if (src === 'cv' || src === 'opencv') return 'CV';
            return 'Detected';
        } catch {
            return 'Detected';
        }
    }

    function _getYoloMemoryDisplayIndexMap() {
        const map = new Map();
        try {
            const items = Array.isArray(_lastFamilyLearnModel && _lastFamilyLearnModel.yoloMemory) ? _lastFamilyLearnModel.yoloMemory : [];
            for (let i = 0; i < items.length; i++) {
                const id = (items[i] && items[i].id != null) ? String(items[i].id).trim() : '';
                if (!id || map.has(id)) continue;
                map.set(id, i + 1);
            }
        } catch { /* ignore */ }
        return map;
    }

    function _getYoloMemoryItemById(id) {
        try {
            const key = (id == null) ? '' : String(id).trim();
            if (!key) return null;
            const items = Array.isArray(_lastFamilyLearnModel && _lastFamilyLearnModel.yoloMemory) ? _lastFamilyLearnModel.yoloMemory : [];
            return items.find(x => x && String(x.id || '').trim() === key) || null;
        } catch {
            return null;
        }
    }

    function _getDetectionMemoryLinkInfo(r) {
        try {
            const id = (r && r.matchedMemoryId != null) ? String(r.matchedMemoryId).trim() : '';
            if (!id) return null;
            const item = _getYoloMemoryItemById(id);
            const displayIndex = _getYoloMemoryDisplayIndexMap().get(id) || 0;
            const distance = (r && isFinite(r.matchedMemoryDistance)) ? (Number(r.matchedMemoryDistance) | 0) : null;
            const similarity = (distance != null) ? Math.max(0, Math.min(100, Math.round(100 - ((distance / 64) * 100)))) : null;
            const label = displayIndex > 0 ? `#${displayIndex}` : id.slice(0, 12);
            const shortLabel = displayIndex > 0 ? `M${displayIndex}` : 'MEM';
            const trainingRunNumber = (item && isFinite(item.trainingRunNumber)) ? (Number(item.trainingRunNumber) | 0) : 0;
            const title = similarity != null
                ? `Closest YOLO memory ${label}${trainingRunNumber > 0 ? ` • train #${trainingRunNumber}` : ''} • similarity ${similarity}%`
                : `Closest YOLO memory ${label}${trainingRunNumber > 0 ? ` • train #${trainingRunNumber}` : ''}`;
            return { id, displayIndex, label, shortLabel, title, similarity, trainingRunNumber };
        } catch {
            return null;
        }
    }

    function _getAnnotatedPagesHtml() {
        try {
            const pages = Array.isArray(_familyScanAnnotatedPages) ? _familyScanAnnotatedPages : [];
            const pagesToShow = pages.filter(Boolean);
            if (!pagesToShow.length) return '';

            const cards = pagesToShow.map(p => {
