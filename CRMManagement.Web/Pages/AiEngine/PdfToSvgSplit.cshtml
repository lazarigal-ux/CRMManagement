    async function _probeSvgAiCandidatesServer(r, cropViewBox, scanToken, options) {
        if (!r || !r.svgContent || !_isOtherElementsLayerResult(r) || !cropViewBox) return;
        const force = !!(options && options.force);
        const key = `${Number(_svgPreviewActiveResultIdx)}|${cropViewBox}|${String(r.svgContent || '').length}`;
