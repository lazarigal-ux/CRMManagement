    function _isFamilySplitTab(tab) {
        return tab === 'familyObjects' || tab === 'yoloMemory' || tab === 'scanLog' || tab === 'annotatedPages';
    }

    function _getWallResultIndexes() {
        const indexes = [];
        for (let i = 0; i < pageResults.length; i++) {
            if (_isWallLayerResult(pageResults[i])) indexes.push(i);
        }
        return indexes;
    }

    function _renderWallResultsTab() {
        if (!wallResultsGrid || !wallResultsSummary || !wallResultsEmpty || !btnDownloadAllWalls) return;

        const wallIndexes = _getWallResultIndexes();
        wallResultsGrid.innerHTML = '';

        if (!wallIndexes.length) {
            wallResultsSummary.textContent = pageResults.length
                ? 'No dedicated wall layer was detected in the current result set.'
                : 'No wall layers yet.';
            wallResultsEmpty.textContent = pageResults.length
                ? 'The current conversion did not produce a "Walls (thick strokes)" layer.'
                : 'Run Split & Convert first. Detected wall layers will appear here in a separate tab.';
            wallResultsEmpty.classList.remove('hidden');
            wallResultsGrid.classList.add('hidden');
            btnDownloadAllWalls.disabled = true;
            return;
        }

        for (const idx of wallIndexes) {
            const card = _buildResultCardElement(idx);
            if (card) wallResultsGrid.appendChild(card);
        }

        const totalObjects = wallIndexes.reduce((sum, idx) => {
            const r = pageResults[idx];
            return sum + ((r && isFinite(r.objectCount)) ? (r.objectCount | 0) : 0);
        }, 0);
        wallResultsSummary.textContent = `${wallIndexes.length} wall layer(s) • ${formatInt(totalObjects)} thick-stroke object(s)`;
        wallResultsEmpty.classList.add('hidden');
        wallResultsGrid.classList.remove('hidden');
        btnDownloadAllWalls.disabled = false;
    }

    function _getMovedOtherElementsResultIndexes() {
        const indexes = [];
        for (let i = 0; i < pageResults.length; i++) {
            if (pageResults[i] && pageResults[i].movedFromOtherElements) indexes.push(i);
        }
        return indexes;
    }

    function _renderMovedOtherElementsSection() {
        if (!movedOtherElementsSection || !movedOtherElementsSummary || !movedOtherElementsGrid) return;

        const indexes = _getMovedOtherElementsResultIndexes();
        movedOtherElementsGrid.innerHTML = '';
        if (!indexes.length) {
            movedOtherElementsSection.classList.add('hidden');
            movedOtherElementsSummary.textContent = 'No moved items yet.';
            return;
        }

        let totalObjects = 0;
        for (const idx of indexes) {
            const r = pageResults[idx];
            const c = (r && isFinite(r.objectCount)) ? Number(r.objectCount) : (r && r.svgContent ? countSvgObjects(r.svgContent) : 0);
            if (isFinite(c) && c > 0) totalObjects += c;
            const card = _buildResultCardElement(idx);
            if (card) movedOtherElementsGrid.appendChild(card);
        }

        movedOtherElementsSummary.textContent = `${indexes.length} separated layer(s) • ${formatInt(totalObjects)} moved sign(s)`;
        movedOtherElementsSection.classList.remove('hidden');
    }

