    async function _renderSvgToPngDataUrl(svgText, maxDim) {
        const md = (isFinite(maxDim) && maxDim > 16) ? (maxDim | 0) : 256;
        return new Promise((resolve, reject) => {
            try {
                const parser = new DOMParser();
                const doc = parser.parseFromString(svgText, 'image/svg+xml');
                const svgEl = doc.querySelector('svg');
                if (!svgEl) { reject(new Error('No <svg> found')); return; }

                let vbW = 0, vbH = 0, vbX = 0, vbY = 0;
                const vbAttr = svgEl.getAttribute('viewBox');
                if (vbAttr) {
                    const parts = vbAttr.trim().split(/[\s,]+/).map(Number);
                    if (parts.length === 4 && parts.every(n => isFinite(n))) {
                        vbX = parts[0]; vbY = parts[1]; vbW = parts[2]; vbH = parts[3];
                    }
                }
                if (!(vbW > 0) || !(vbH > 0)) {
                    vbW = parseFloat(svgEl.getAttribute('width')) || 800;
                    vbH = parseFloat(svgEl.getAttribute('height')) || 600;
                }

                const scale = Math.min(1, md / Math.max(vbW, vbH));
                const canvasW = Math.max(1, Math.round(vbW * scale));
                const canvasH = Math.max(1, Math.round(vbH * scale));

                svgEl.setAttribute('width', String(canvasW));
                svgEl.setAttribute('height', String(canvasH));
                if (!svgEl.getAttribute('viewBox')) {
                    svgEl.setAttribute('viewBox', `${vbX} ${vbY} ${vbW} ${vbH}`);
                }
                const svgStr = new XMLSerializer().serializeToString(svgEl);
                const blob = new Blob([svgStr], { type: 'image/svg+xml;charset=utf-8' });
                const url = URL.createObjectURL(blob);

                const img = new Image();
                img.onload = () => {
                    try {
                        const canvas = document.createElement('canvas');
                        canvas.width = canvasW;
                        canvas.height = canvasH;
                        const ctx = canvas.getContext('2d');
                        ctx.drawImage(img, 0, 0, canvasW, canvasH);
                        URL.revokeObjectURL(url);
                        resolve(canvas.toDataURL('image/png'));
                    } catch (e) {
                        URL.revokeObjectURL(url);
                        reject(e);
                    }
                };
                img.onerror = (e) => {
                    URL.revokeObjectURL(url);
                    reject(new Error('Image render failed: ' + String(e)));
                };
                img.src = url;
            } catch (e) {
                reject(e);
            }
        });
    }

    function _extractEmbeddedRasterDataUrl(svgText) {
        try {
            if (!svgText) return '';
            const parser = new DOMParser();
            const doc = parser.parseFromString(String(svgText), 'image/svg+xml');
            const imgEl = doc.querySelector('image');
            if (!imgEl) return '';
            const href = (imgEl.getAttribute('href') || imgEl.getAttribute('xlink:href') || '').trim();
            return href.startsWith('data:image/') ? href : '';
        } catch {
            return '';
        }
    }

    async function _normalizeTemplateDataUrl(dataUrl, maxDim, whiteThreshold = 245, paddingPx = 2) {
        const md = (isFinite(maxDim) && maxDim > 16) ? (maxDim | 0) : 512;
        return new Promise((resolve, reject) => {
            try {
                const img = new Image();
                img.onload = () => {
                    try {
                        const srcW = img.naturalWidth || img.width || 0;
                        const srcH = img.naturalHeight || img.height || 0;
                        if (srcW < 2 || srcH < 2) { resolve(dataUrl); return; }

                        const srcCanvas = document.createElement('canvas');
                        srcCanvas.width = srcW;
                        srcCanvas.height = srcH;
                        const srcCtx = srcCanvas.getContext('2d', { willReadFrequently: true });
                        if (!srcCtx) { resolve(dataUrl); return; }
                        srcCtx.drawImage(img, 0, 0, srcW, srcH);

                        const imgData = srcCtx.getImageData(0, 0, srcW, srcH);
                        const px = imgData.data;
                        let minX = srcW, minY = srcH, maxX = -1, maxY = -1;

                        for (let y = 0; y < srcH; y++) {
                            for (let x = 0; x < srcW; x++) {
                                const i = ((y * srcW) + x) * 4;
                                const a = px[i + 3];
                                const r = px[i], g = px[i + 1], b = px[i + 2];
                                const isForeground = a > 8 && (r < whiteThreshold || g < whiteThreshold || b < whiteThreshold);
                                if (!isForeground) continue;
                                if (x < minX) minX = x;
                                if (y < minY) minY = y;
                                if (x > maxX) maxX = x;
                                if (y > maxY) maxY = y;
                            }
                        }

                        if (maxX < minX || maxY < minY) { resolve(dataUrl); return; }

                        minX = Math.max(0, minX - paddingPx);
                        minY = Math.max(0, minY - paddingPx);
                        maxX = Math.min(srcW - 1, maxX + paddingPx);
                        maxY = Math.min(srcH - 1, maxY + paddingPx);

                        const cropW = Math.max(1, maxX - minX + 1);
                        const cropH = Math.max(1, maxY - minY + 1);
                        const scale = Math.min(1, md / Math.max(cropW, cropH));
                        const outW = Math.max(1, Math.round(cropW * scale));
                        const outH = Math.max(1, Math.round(cropH * scale));

                        const outCanvas = document.createElement('canvas');
                        outCanvas.width = outW;
                        outCanvas.height = outH;
                        const outCtx = outCanvas.getContext('2d');
                        if (!outCtx) { resolve(dataUrl); return; }
                        outCtx.imageSmoothingEnabled = true;
                        outCtx.imageSmoothingQuality = 'high';
                        outCtx.drawImage(srcCanvas, minX, minY, cropW, cropH, 0, 0, outW, outH);
                        resolve(outCanvas.toDataURL('image/png'));
                    } catch (e) {
                        reject(e);
                    }
                };
                img.onerror = reject;
                img.src = dataUrl;
            } catch (e) {
                reject(e);
            }
        });
    }

    async function _buildTemplateImageDataUrl(svgText, maxDim) {
        const embeddedRaster = _extractEmbeddedRasterDataUrl(svgText);
        if (embeddedRaster) {
            return await _normalizeTemplateDataUrl(embeddedRaster, maxDim);
        }

        const rendered = await _renderSvgToPngDataUrl(svgText, maxDim);
        return await _normalizeTemplateDataUrl(rendered, maxDim);
    }

    async function _cropDataUrlImage(dataUrl, sx, sy, sw, sh) {
        const src = (dataUrl || '').toString().trim();
        if (!src.startsWith('data:image/')) return '';
        return await new Promise((resolve) => {
            try {
                const img = new Image();
                img.onload = () => {
                    try {
                        const srcW = img.naturalWidth || img.width || 0;
                        const srcH = img.naturalHeight || img.height || 0;
                        if (!(srcW > 0) || !(srcH > 0)) { resolve(''); return; }

                        const x = Math.max(0, Math.min(srcW - 1, Math.floor(Number(sx) || 0)));
                        const y = Math.max(0, Math.min(srcH - 1, Math.floor(Number(sy) || 0)));
                        const w = Math.max(1, Math.min(srcW - x, Math.ceil(Number(sw) || 0)));
                        const h = Math.max(1, Math.min(srcH - y, Math.ceil(Number(sh) || 0)));
                        if (!(w > 0) || !(h > 0)) { resolve(''); return; }

                        const canvas = document.createElement('canvas');
                        canvas.width = w;
                        canvas.height = h;
                        const ctx = canvas.getContext('2d');
                        if (!ctx) { resolve(''); return; }
                        ctx.imageSmoothingEnabled = true;
                        ctx.imageSmoothingQuality = 'high';
                        ctx.drawImage(img, x, y, w, h, 0, 0, w, h);
                        resolve(canvas.toDataURL('image/png'));
                    } catch {
                        resolve('');
                    }
                };
                img.onerror = () => resolve('');
                img.src = src;
            } catch {
                resolve('');
            }
        });
    }

    async function _buildAiTextOnlyCroppedPayload(svgText, cropViewBoxStr) {
        try {
            const srcSvg = (svgText || '').toString();
            const crop = _parseViewBoxStr(cropViewBoxStr);
            if (!srcSvg || !crop) return { svgContent: _getSvgContentForExport(srcSvg), previewImageDataUrl: '' };

            const parser = new DOMParser();
            const doc = parser.parseFromString(srcSvg, 'image/svg+xml');
            const svgEl = doc.querySelector('svg');
            const imgEl = doc.querySelector('image');
            const hasTextNodes = !!doc.querySelector('text, tspan, textPath');
            if (!svgEl) {
                const exported = _getSvgContentForExport(srcSvg);
                return {
                    svgContent: exported,
                    previewImageDataUrl: exported ? await _buildTemplateImageDataUrl(exported, 1200) : ''
                };
            }

            // If the source SVG already contains vector text, keep the full original SVG and
            // let the backend crop deterministically by `cropViewBox`. Converting it here into
            // a raster-only wrapper would hide the existing text nodes and force an AI OCR path.
            if (hasTextNodes) {
                const exported = _getSvgContentForExport(srcSvg);
                if (!imgEl) {
                    return {
                        svgContent: exported,
                        previewImageDataUrl: exported ? await _buildTemplateImageDataUrl(exported, 1200) : ''
                    };
                }
            }

            if (!imgEl) {
                const exported = _getSvgContentForExport(srcSvg);
                return {
                    svgContent: exported,
                    previewImageDataUrl: exported ? await _buildTemplateImageDataUrl(exported, 1200) : ''
                };
            }

            const href = (imgEl.getAttribute('href') || imgEl.getAttribute('xlink:href') || '').trim();
            if (!href.startsWith('data:image/')) {
                const exported = _getSvgContentForExport(srcSvg);
                return {
                    svgContent: exported,
                    previewImageDataUrl: exported ? await _buildTemplateImageDataUrl(exported, 1200) : ''
                };
            }

            const vbAttr = svgEl.getAttribute('viewBox') || '';
            const vb = _parseViewBoxStr(vbAttr) || { x: 0, y: 0, w: parseFloat(svgEl.getAttribute('width')) || crop.w, h: parseFloat(svgEl.getAttribute('height')) || crop.h };
            const imgX = parseFloat(imgEl.getAttribute('x') || '') || vb.x || 0;
            const imgY = parseFloat(imgEl.getAttribute('y') || '') || vb.y || 0;
            const imgW = parseFloat(imgEl.getAttribute('width') || '') || vb.w || crop.w;
            const imgH = parseFloat(imgEl.getAttribute('height') || '') || vb.h || crop.h;

            const rasterSize = await getImageSize(href);
            if (!rasterSize || !(rasterSize.w > 0) || !(rasterSize.h > 0) || !(imgW > 0) || !(imgH > 0)) {
                const exported = _getSvgContentForExport(srcSvg);
                return {
                    svgContent: exported,
                    previewImageDataUrl: exported ? await _buildTemplateImageDataUrl(exported, 1200) : ''
                };
            }

            const ix = ((crop.x - imgX) / imgW) * rasterSize.w;
            const iy = ((crop.y - imgY) / imgH) * rasterSize.h;
            const iw = (crop.w / imgW) * rasterSize.w;
            const ih = (crop.h / imgH) * rasterSize.h;
            const croppedRaster = await _cropDataUrlImage(href, ix, iy, iw, ih);
            if (!croppedRaster) {
                const exported = _getSvgContentForExport(srcSvg);
                return {
                    svgContent: exported,
                    previewImageDataUrl: exported ? await _buildTemplateImageDataUrl(exported, 1200) : ''
                };
            }

            if (hasTextNodes) {
                return {
                    svgContent: _getSvgContentForExport(srcSvg),
                    previewImageDataUrl: await _normalizeTemplateDataUrl(croppedRaster, 1200)
                };
            }

            const croppedSvg = `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 ${crop.w} ${crop.h}" width="${crop.w}" height="${crop.h}"><image href="${croppedRaster}" x="0" y="0" width="${crop.w}" height="${crop.h}" preserveAspectRatio="none" /></svg>`;
            return {
                svgContent: croppedSvg,
                previewImageDataUrl: await _normalizeTemplateDataUrl(croppedRaster, 1200)
            };
        } catch {
            const exported = _getSvgContentForExport(svgText || '');
            return {
                svgContent: exported,
                previewImageDataUrl: exported ? await _buildTemplateImageDataUrl(exported, 1200) : ''
            };
        }
    }

