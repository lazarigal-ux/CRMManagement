    async function _deleteSampleFromBrowser(sampleId) {
        const famId = _savedSamplesBrowserFamId || _getSelectedFamilyId();
        if (!famId) { cgAlert('No family found.'); return; }
        const sid = parseInt(String(sampleId || ''), 10);
        if (!Number.isFinite(sid) || sid <= 0) return;
        if (!await cgConfirm('Delete this object from the database?')) return;
        try {
            const resp = await fetch(`${OBJECT_FAMILIES_ENDPOINT}/${famId}/samples/${sid}`, {
                method: 'DELETE',
                headers: { 'X-Client-Id': 'admin' }
            });
            if (!resp.ok) {
                const t = await resp.text();
                cgAlert(`Delete failed: HTTP ${resp.status}: ${t.substring(0, 400)}`);
                return;
            }
            // Remove from in-memory array and refresh tabs
            const delIdx = _savedSamplesBrowserSamples.findIndex(s => s && (s.id | 0) === sid);
            if (delIdx >= 0) _savedSamplesBrowserSamples.splice(delIdx, 1);
            // Update subtitle count
            if (_savedSamplesBrowserSubtitle) {
