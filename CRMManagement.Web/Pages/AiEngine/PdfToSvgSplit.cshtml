    // Convert mouse event to SVG user-space coordinates
    function _familyEditMouseToSvg(e, svg) {
        const pt = svg.createSVGPoint();
        pt.x = e.clientX;
        pt.y = e.clientY;
        const ctm = svg.getScreenCTM();
        if (!ctm) return null;
        return pt.matrixTransform(ctm.inverse());
    }

    // Check if two rectangles overlap (each: {x,y,w,h})
    function _rectsOverlap(a, b) {
        return !(a.x + a.w <= b.x || b.x + b.w <= a.x || a.y + a.h <= b.y || b.y + b.h <= a.y);
    }

    function _pointInRect(px, py, r) {
        return px >= r.x && px <= (r.x + r.w) && py >= r.y && py <= (r.y + r.h);
    }

    function _getElBBoxInSvg(el) {
        try {
            const bb = el.getBBox();
            const m = el.getCTM();
            if (!bb || !m) return null;
            const tx = (x, y) => {
                // m is typically a DOMMatrix; use the SVGMatrix-compatible fields.
                const a = isFinite(m.a) ? m.a : 1;
                const b = isFinite(m.b) ? m.b : 0;
                const c = isFinite(m.c) ? m.c : 0;
                const d = isFinite(m.d) ? m.d : 1;
                const e = isFinite(m.e) ? m.e : 0;
                const f = isFinite(m.f) ? m.f : 0;
                return { x: a * x + c * y + e, y: b * x + d * y + f };
            };
            const pts = [
                tx(bb.x, bb.y),
                tx(bb.x + bb.width, bb.y),
                tx(bb.x, bb.y + bb.height),
                tx(bb.x + bb.width, bb.y + bb.height)
            ];
            let minX = Infinity, minY = Infinity, maxX = -Infinity, maxY = -Infinity;
            for (const p of pts) {
                if (p.x < minX) minX = p.x;
                if (p.y < minY) minY = p.y;
                if (p.x > maxX) maxX = p.x;
                if (p.y > maxY) maxY = p.y;
            }
            if (!isFinite(minX) || !isFinite(minY) || !isFinite(maxX) || !isFinite(maxY)) return null;
            return { x: minX, y: minY, w: Math.max(0, maxX - minX), h: Math.max(0, maxY - minY) };
        } catch {
            return null;
        }
    }

    function _getImageRectSimple(imgEl) {
        try {
            const x = parseFloat(imgEl.getAttribute('x') || '0');
            const y = parseFloat(imgEl.getAttribute('y') || '0');
            const w = parseFloat(imgEl.getAttribute('width') || '0');
            const h = parseFloat(imgEl.getAttribute('height') || '0');
            if (isFinite(x) && isFinite(y) && isFinite(w) && isFinite(h) && w > 0 && h > 0) {
                return { x, y, w, h };
            }
        } catch { /* ignore */ }
        return null;
    }

    function _getPrimaryImageElement(svg) {
        try {
            const imgs = [...svg.querySelectorAll('image')]
                .filter(im => { try { return !im.closest('defs'); } catch { return true; } })
                .filter(im => {
                    const href = (im.getAttribute('href') || im.getAttribute('xlink:href') || '').toString();
                    return href.startsWith('data:image');
                });
            if (!imgs.length) return null;
            // Pick the largest image by area (most common case: single raster tile).
            let best = null;
            let bestArea = -1;
            for (const im of imgs) {
                const r = _getImageRectSimple(im) || _getElBBoxInSvg(im);
                const area = r && isFinite(r.w) && isFinite(r.h) ? (r.w * r.h) : 0;
                if (area > bestArea) { bestArea = area; best = im; }
            }
            return best;
        } catch {
            return null;
        }
    }

    function _setImageHref(imgEl, dataUrl) {
        try {
            imgEl.setAttribute('href', dataUrl);
            imgEl.setAttribute('xlink:href', dataUrl);
        } catch { /* ignore */ }
    }

    async function _ensureImageLoaded(image) {
        try {
            if ((image.naturalWidth || 0) > 0 && (image.naturalHeight || 0) > 0) return true;
        } catch { /* ignore */ }
        try {
            if (typeof image.decode === 'function') {
                await image.decode();
                return (image.naturalWidth || 0) > 0;
            }
        } catch { /* ignore */ }
        // Fallback for browsers where decode() is unavailable/buggy
        try {
            await new Promise((resolve, reject) => {
                const t = setTimeout(() => reject(new Error('image load timeout')), 3000);
                image.onload = () => { try { clearTimeout(t); } catch { } resolve(); };
                image.onerror = () => { try { clearTimeout(t); } catch { } reject(new Error('image load error')); };
            });
            return (image.naturalWidth || 0) > 0;
        } catch {
            return false;
        }
    }

    async function _rasterEditImageByRegion(svg, imgEl, mode, regionRect) {
        try {
            const href = (imgEl.getAttribute('href') || imgEl.getAttribute('xlink:href') || '').toString();
            if (!href || !href.startsWith('data:image')) return { ok: false, removedCount: 0 };

            const imgRect = _getImageRectSimple(imgEl) || _getElBBoxInSvg(imgEl);
            if (!imgRect || !(imgRect.w > 0 && imgRect.h > 0)) return { ok: false, removedCount: 0 };

            // Intersect region with image rect
            const ix0 = Math.max(imgRect.x, regionRect.x);
            const iy0 = Math.max(imgRect.y, regionRect.y);
            const ix1 = Math.min(imgRect.x + imgRect.w, regionRect.x + regionRect.w);
            const iy1 = Math.min(imgRect.y + imgRect.h, regionRect.y + regionRect.h);
            const iw = Math.max(0, ix1 - ix0);
            const ih = Math.max(0, iy1 - iy0);
            if (!(iw > 0 && ih > 0)) return { ok: false, removedCount: 0 };

            const image = new Image();
            image.src = href;
            await _ensureImageLoaded(image);
            const nw = image.naturalWidth || 0;
            const nh = image.naturalHeight || 0;
            if (!nw || !nh) return { ok: false, removedCount: 0 };

            const sx = Math.floor(((ix0 - imgRect.x) / imgRect.w) * nw);
            const sy = Math.floor(((iy0 - imgRect.y) / imgRect.h) * nh);
            const sw = Math.max(1, Math.floor((iw / imgRect.w) * nw));
            const sh = Math.max(1, Math.floor((ih / imgRect.h) * nh));

            if (mode === 'keep') {
                const c = document.createElement('canvas');
                c.width = sw;
                c.height = sh;
                const ctx = c.getContext('2d');
                if (!ctx) return { ok: false, removedCount: 0 };
                ctx.clearRect(0, 0, sw, sh);
                ctx.drawImage(image, sx, sy, sw, sh, 0, 0, sw, sh);
                const outUrl = c.toDataURL('image/png');

                // Replace with a new image positioned at the kept rect in SVG space
                const ns = 'http://www.w3.org/2000/svg';
                const newImg = document.createElementNS(ns, 'image');
                _setImageHref(newImg, outUrl);
                newImg.setAttribute('x', String(ix0));
                newImg.setAttribute('y', String(iy0));
                newImg.setAttribute('width', String(iw));
                newImg.setAttribute('height', String(ih));
                newImg.style.pointerEvents = 'visible';
                newImg.style.cursor = 'pointer';
                try {
                    const p = imgEl.parentNode;
                    if (p) p.insertBefore(newImg, imgEl.nextSibling);
                    imgEl.remove();
                } catch { /* ignore */ }
                return { ok: true, removedCount: 1 };
            }

            // erase pixels inside region (paint white)
            const c = document.createElement('canvas');
            c.width = nw;
            c.height = nh;
            const ctx = c.getContext('2d');
            if (!ctx) return { ok: false, removedCount: 0 };
            ctx.clearRect(0, 0, nw, nh);
            ctx.drawImage(image, 0, 0);
            const id = ctx.getImageData(0, 0, nw, nh);
            const data = id.data;
            const ex0 = Math.max(0, Math.min(nw - 1, sx));
            const ey0 = Math.max(0, Math.min(nh - 1, sy));
            const ex1 = Math.max(0, Math.min(nw, sx + sw));
            const ey1 = Math.max(0, Math.min(nh, sy + sh));
            for (let y = ey0; y < ey1; y++) {
                const row = y * nw * 4;
                for (let x = ex0; x < ex1; x++) {
                    const i = row + x * 4;
                    data[i] = 255;
                    data[i + 1] = 255;
                    data[i + 2] = 255;
                    data[i + 3] = 255;
                }
            }
            ctx.putImageData(id, 0, 0);
            const outUrl = c.toDataURL('image/png');

            const ns = 'http://www.w3.org/2000/svg';
            const newImg = document.createElementNS(ns, 'image');
            _setImageHref(newImg, outUrl);
            newImg.setAttribute('x', String(imgRect.x));
            newImg.setAttribute('y', String(imgRect.y));
            newImg.setAttribute('width', String(imgRect.w));
            newImg.setAttribute('height', String(imgRect.h));
            newImg.style.pointerEvents = 'visible';
            newImg.style.cursor = 'pointer';
            try {
                const p = imgEl.parentNode;
                if (p) p.insertBefore(newImg, imgEl.nextSibling);
                imgEl.remove();
            } catch { /* ignore */ }
            return { ok: true, removedCount: 1 };
        } catch {
            return { ok: false, removedCount: 0 };
        }
    }

    async function _rasterEraseImageByBrush(svg, imgEl, pointsSvg) {
        try {
            const href = (imgEl.getAttribute('href') || imgEl.getAttribute('xlink:href') || '').toString();
            if (!href || !href.startsWith('data:image')) return { ok: false };

            const imgRect = _getImageRectSimple(imgEl) || _getElBBoxInSvg(imgEl);
            if (!imgRect || !(imgRect.w > 0 && imgRect.h > 0)) return { ok: false };

            const image = new Image();
            image.src = href;
            await _ensureImageLoaded(image);
            const nw = image.naturalWidth || 0;
            const nh = image.naturalHeight || 0;
            if (!nw || !nh) return { ok: false };

            const pts = Array.isArray(pointsSvg) ? pointsSvg : [];
            if (!pts.length) return { ok: false };

            const toPix = (p) => {
                const x = ((p.x - imgRect.x) / imgRect.w) * nw;
                const y = ((p.y - imgRect.y) / imgRect.h) * nh;
                const cx = Math.max(0, Math.min(nw - 1, isFinite(x) ? x : 0));
                const cy = Math.max(0, Math.min(nh - 1, isFinite(y) ? y : 0));
                return { x: cx, y: cy };
            };

            const pixPts = pts.map(toPix);

            const c = document.createElement('canvas');
            c.width = nw;
            c.height = nh;
            const ctx = c.getContext('2d');
            if (!ctx) return { ok: false };

            ctx.clearRect(0, 0, nw, nh);
            ctx.drawImage(image, 0, 0);

            // Paint white strokes (opaque) so later alpha-dropping doesn't turn it black.
            ctx.save();
            ctx.globalCompositeOperation = 'source-over';
            ctx.strokeStyle = '#ffffff';
            ctx.fillStyle = '#ffffff';
            // Convert brush width from SVG user units → image pixels
            // so the erased area matches the on-screen stroke width.
            const sx = nw / imgRect.w;
            const sy = nh / imgRect.h;
            const scale = (isFinite(sx) && isFinite(sy) && sx > 0 && sy > 0) ? ((sx + sy) / 2) : (isFinite(sx) && sx > 0 ? sx : 1);
            const wSvg = Math.max(0.25, Number(_familyEditBrushSizeSvg) || 1.5);
            const w = Math.max(1, Math.min(80, wSvg * scale));
            ctx.lineWidth = w;
            ctx.lineJoin = 'round';
            ctx.lineCap = 'round';

            if (pixPts.length === 1) {
                const p0 = pixPts[0];
                ctx.beginPath();
                ctx.arc(p0.x, p0.y, w / 2, 0, Math.PI * 2);
                ctx.fill();
            } else {
                ctx.beginPath();
                ctx.moveTo(pixPts[0].x, pixPts[0].y);
                for (let i = 1; i < pixPts.length; i++) ctx.lineTo(pixPts[i].x, pixPts[i].y);
                ctx.stroke();
            }
            ctx.restore();

            const outUrl = c.toDataURL('image/png');

            const ns = 'http://www.w3.org/2000/svg';
            const newImg = document.createElementNS(ns, 'image');
            _setImageHref(newImg, outUrl);
            newImg.setAttribute('x', String(imgRect.x));
            newImg.setAttribute('y', String(imgRect.y));
            newImg.setAttribute('width', String(imgRect.w));
            newImg.setAttribute('height', String(imgRect.h));
            newImg.style.pointerEvents = 'visible';
            newImg.style.cursor = 'pointer';
            try {
                const p = imgEl.parentNode;
                if (p) p.insertBefore(newImg, imgEl.nextSibling);
                imgEl.remove();
            } catch { /* ignore */ }

            return { ok: true };
        } catch {
            return { ok: false };
        }
    }

    // Pointer handlers for region drawing (attached to document so they work globally)
    document.addEventListener('pointerdown', (e) => {
        try {
            if (_familyEditBrushMode) {
                const scaleEl = document.getElementById('svgPreviewScale');
                const svg = scaleEl ? scaleEl.querySelector('svg') : null;
                if (!svg || (!svg.contains(e.target) && e.target !== svg)) return;
                const pt = _familyEditMouseToSvg(e, svg);
                if (!pt) return;
                e.preventDefault();
                e.stopPropagation();

                // Visual stroke overlay
                const ns = 'http://www.w3.org/2000/svg';
                try { document.getElementById('_familyEditBrushStroke')?.remove(); } catch {}
                const poly = document.createElementNS(ns, 'polyline');
                poly.id = '_familyEditBrushStroke';
                poly.setAttribute('fill', 'none');
                poly.setAttribute('stroke', '#f97316');
                poly.setAttribute('stroke-opacity', '0.9');
                poly.setAttribute('stroke-width', String(Math.max(0.25, Number(_familyEditBrushSizeSvg) || 1.5)));
                poly.setAttribute('stroke-linecap', 'round');
                poly.setAttribute('stroke-linejoin', 'round');
                poly.style.pointerEvents = 'none';
                svg.appendChild(poly);

                _familyEditBrushDraw = { svg, polyEl: poly, points: [{ x: pt.x, y: pt.y }] };
                poly.setAttribute('points', `${pt.x},${pt.y}`);
                return;
            }
            if (!_familyEditRegionMode) return;
            const scaleEl = document.getElementById('svgPreviewScale');
            const svg = scaleEl ? scaleEl.querySelector('svg') : null;
            if (!svg || !svg.contains(e.target) && e.target !== svg) return;
            const pt = _familyEditMouseToSvg(e, svg);
            if (!pt) return;
            e.preventDefault();
            e.stopPropagation();

            // Create visual rect overlay in SVG
            const ns = 'http://www.w3.org/2000/svg';
            const rectEl = document.createElementNS(ns, 'rect');
            rectEl.id = '_familyEditRegionRect';
            rectEl.setAttribute('x', pt.x);
            rectEl.setAttribute('y', pt.y);
            rectEl.setAttribute('width', 0);
            rectEl.setAttribute('height', 0);
            rectEl.setAttribute('fill', _familyEditRegionMode === 'erase' ? '#f97316' : '#14b8a6');
            rectEl.setAttribute('fill-opacity', '0.15');
            rectEl.setAttribute('stroke', _familyEditRegionMode === 'erase' ? '#f97316' : '#14b8a6');
            rectEl.setAttribute('stroke-width', '1');
            rectEl.setAttribute('stroke-dasharray', '4 2');
            rectEl.style.pointerEvents = 'none';
            svg.appendChild(rectEl);

            _familyEditRegionDraw = { startX: pt.x, startY: pt.y, rectEl, svg };
        } catch {}
    }, { capture: true });

    document.addEventListener('pointermove', (e) => {
        try {
            if (_familyEditBrushDraw && _familyEditBrushMode) {
                const { svg, polyEl, points } = _familyEditBrushDraw;
                const pt = _familyEditMouseToSvg(e, svg);
                if (!pt) return;
                const last = points && points.length ? points[points.length - 1] : null;
                if (last) {
                    const dx = pt.x - last.x;
                    const dy = pt.y - last.y;
                    if ((dx * dx + dy * dy) < 0.25) return;
                }
                points.push({ x: pt.x, y: pt.y });
                if (points.length > 1200) points.shift();
                try { polyEl.setAttribute('points', points.map(p => `${p.x},${p.y}`).join(' ')); } catch { /* ignore */ }
                return;
            }
            if (!_familyEditRegionDraw) return;
            const { startX, startY, rectEl, svg } = _familyEditRegionDraw;
            const pt = _familyEditMouseToSvg(e, svg);
            if (!pt) return;
            const x = Math.min(startX, pt.x);
            const y = Math.min(startY, pt.y);
            const w = Math.abs(pt.x - startX);
            const h = Math.abs(pt.y - startY);
            rectEl.setAttribute('x', x);
            rectEl.setAttribute('y', y);
            rectEl.setAttribute('width', w);
            rectEl.setAttribute('height', h);
        } catch {}
    }, { capture: true });

    document.addEventListener('pointerup', async (e) => {
        try {
            if (_familyEditBrushDraw && _familyEditBrushMode) {
                const { svg, polyEl, points } = _familyEditBrushDraw;
                try { polyEl.remove(); } catch { /* ignore */ }
                _familyEditBrushDraw = null;

                const primaryImg = _getPrimaryImageElement(svg);
                if (!primaryImg) {
                    const lbl = document.getElementById('familyEditSelected');
                    if (lbl) lbl.textContent = 'Eraser works on raster <image> samples (no image found here).';
                    _familyEditCancelBrushEraseMode();
                    return;
                }

                const undoLenBefore = _familyEditUndoStack.length;
                _familyEditPushUndo();
                const r = await _rasterEraseImageByBrush(svg, primaryImg, points);
                if (!(r && r.ok)) {
                    try {
                        while (_familyEditUndoStack.length > undoLenBefore) _familyEditUndoStack.pop();
                        _familyEditUpdateUndoRedoButtons();
                    } catch { /* ignore */ }
                }

                const lbl = document.getElementById('familyEditSelected');
                if (lbl) lbl.textContent = (r && r.ok) ? 'Erased with pencil.' : 'Eraser did nothing.';
                _familyEditCancelBrushEraseMode();
                return;
            }
            if (!_familyEditRegionDraw || !_familyEditRegionMode) return;
            const { startX, startY, rectEl, svg } = _familyEditRegionDraw;
            const pt = _familyEditMouseToSvg(e, svg);
            if (!pt) { _familyEditRegionDraw = null; try { rectEl.remove(); } catch {} return; }

            const rx = Math.min(startX, pt.x);
            const ry = Math.min(startY, pt.y);
            const rw = Math.abs(pt.x - startX);
            const rh = Math.abs(pt.y - startY);

            // Remove visual rect
            try { rectEl.remove(); } catch {}

            // Minimum drag threshold
            if (rw < 1 || rh < 1) { _familyEditRegionDraw = null; return; }

            const regionRect = { x: rx, y: ry, w: rw, h: rh };
            const mode = _familyEditRegionMode;

            let removedCount = 0;

            // Special case: if this is just a single raster <image>, edit pixels instead of deleting the element.
            const primaryImg = _getPrimaryImageElement(svg);
            if (primaryImg) {
                const undoLenBefore = _familyEditUndoStack.length;
                _familyEditPushUndo(); // snapshot BEFORE editing
                const r = await _rasterEditImageByRegion(svg, primaryImg, mode, regionRect);
                if (r && r.ok) {
                    removedCount = r.removedCount || 0;
                } else {
                    // No-op: revert the snapshot we just pushed.
                    try {
                        while (_familyEditUndoStack.length > undoLenBefore) _familyEditUndoStack.pop();
                        _familyEditUpdateUndoRedoButtons();
                    } catch { /* ignore */ }
                }
            }

            if (!removedCount) {
                // Vector-ish case: remove elements by CENTER-in-rect (much less destructive than bbox overlap)
                // If a primary raster image exists, do not delete it in the fallback path.
                const sel = primaryImg
                    ? 'use, path, rect, circle, ellipse, polygon, polyline, line, text'
                    : 'image, use, path, rect, circle, ellipse, polygon, polyline, line, text';
                const candidates = svg.querySelectorAll(sel);
                const toRemove = [];
                for (const el of candidates) {
                    try { if (el.closest('defs')) continue; } catch {}
                    if (el.id === '_familyEditRegionRect') continue;
                    const bbSvg = _getElBBoxInSvg(el);
                    if (!bbSvg || !(bbSvg.w > 0 || bbSvg.h > 0)) continue;
                    const cx = bbSvg.x + bbSvg.w / 2;
                    const cy = bbSvg.y + bbSvg.h / 2;
                    const centerIn = _pointInRect(cx, cy, regionRect);
                    if (mode === 'erase' && centerIn) toRemove.push(el);
                    if (mode === 'keep' && !centerIn) toRemove.push(el);
                }

                if (toRemove.length) {
                    _familyEditPushUndo();
                    for (const el of toRemove) {
                        try { el.remove(); removedCount++; } catch { /* ignore */ }
                    }
                }
            }

            console.log(`[EDITOR] Region ${mode}: removed ${removedCount} element(s)`);

            _familyEditRegionDraw = null;
            _familyEditCancelRegionMode();

            // Update label
            const lbl = document.getElementById('familyEditSelected');
            if (lbl) lbl.textContent = `${mode === 'erase' ? 'Erased' : 'Kept'} region — ${removedCount} element(s) removed`;
        } catch (err) {
            console.warn('[EDITOR] region mode error:', err);
            _familyEditRegionDraw = null;
        }
    }, { capture: true });
