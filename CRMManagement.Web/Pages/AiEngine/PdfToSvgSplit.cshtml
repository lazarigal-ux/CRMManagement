            if (!yoloMemoryItems.length) return summary + transferHtml + `<div class="mt-3 rounded-xl border border-slate-600/35 bg-slate-900/25 px-4 py-3 text-xs text-slate-400">No persisted YOLO memory yet. New approved and rejected detections will accumulate here after training.</div>`;

            const filteredItems = activeFilter === 'all'
