    function openFamilyDetectionPreview(idx) {
        const i = parseInt(String(idx != null ? idx : ''), 10);
        if (!Number.isFinite(i) || i < 0) {
            _debugAnnotatedDetectionMenu('preview-invalid-index', { detectionIndex: idx }, true);
            return;
        }
        const rows = Array.isArray(_familyScanDetections) ? _familyScanDetections : [];
        if (i >= rows.length) {
            _debugAnnotatedDetectionMenu('preview-index-out-of-range', { detectionIndex: i, rowCount: rows.length }, true);
            return;
        }
        const r = rows[i] || {};

        const img = (r && r.thumbDataUrl != null) ? String(r.thumbDataUrl) : '';
        if (!img) {
            _debugAnnotatedDetectionMenu('preview-missing-image', {
                detectionIndex: i,
                pageIndex: Number.isFinite(r.pageIndex) ? (r.pageIndex | 0) : null,
                hasThumbDataUrl: false
            }, true);
            return;
        }

        const modal = document.getElementById('svgPreviewModal');
        const body = document.getElementById('svgPreviewBody');
        const title = document.getElementById('previewTitle');
        if (!modal || !body || !title) {
            _debugAnnotatedDetectionMenu('preview-missing-modal-elements', {
                detectionIndex: i,
                hasModal: !!modal,
                hasBody: !!body,
                hasTitle: !!title
            }, true);
            return;
        }

        const page = (r && isFinite(r.pageIndex)) ? ((r.pageIndex | 0) + 1) : 0;
        const prov = (r && r.detectedBy) ? r.detectedBy : {};
        const engines = [prov.ollama ? 'ollama' : '', prov.gemini ? 'gemini' : '', prov.openai ? 'openai' : ''].filter(Boolean).join(', ');

        title.textContent = `Detection preview — p${page || '—'}${engines ? (' — ' + engines) : ''}`;
        _debugAnnotatedDetectionMenu('preview-opening', {
            detectionIndex: i,
            pageIndex: page || null,
            engines: engines || null
        }, true);

        body.innerHTML = `
            <div id="svgPreviewScale" style="display:inline-block;">
                <img id="familyDetectionPreviewImg" src="${img}" class="block rounded-xl border border-slate-200 bg-white" style="max-width:none; max-height:none;" alt="Detection preview" />
            </div>`;

        // Open modal before applying zoom so sizing math has real dimensions.
        try { _setSvgPreviewToolbarMode('family'); } catch { /* ignore */ }
        setSvgPreviewZoom(1.0);
        _applySvgPreviewModalSidebarOffset();
        modal.classList.remove('hidden');

        const imgEl = document.getElementById('familyDetectionPreviewImg');
        if (imgEl && imgEl.addEventListener) {
            imgEl.addEventListener('load', async () => {
                try { await _autoTrimImageElementToInk(imgEl, { pad: 4, threshold: 248, step: 2 }); } catch { /* ignore */ }
                try {
                    if (!imgEl.dataset.baseW) imgEl.dataset.baseW = String(imgEl.naturalWidth || 0);
                    if (!imgEl.dataset.baseH) imgEl.dataset.baseH = String(imgEl.naturalHeight || 0);
                } catch { /* ignore */ }
                try { setSvgPreviewZoom(4.0); } catch { /* ignore */ }
                try { _centerSvgPreviewScroll(); } catch { /* ignore */ }
            }, { once: true });
        }
    }

    function _getFamilyScanModelHintForProvider(provider) {
        const p = (provider || '').toString().trim().toLowerCase();
        if (p === 'ollama') return 'llava:7b';
        if (p === 'gemini') return 'gemini-2.5-flash';
        return 'gpt-4.1';
    }

    function _getFamilyScanModelHint() {
        try {
            const p = (providerSelect && providerSelect.value) ? String(providerSelect.value).trim().toLowerCase() : '';
            return _getFamilyScanModelHintForProvider(p);
        } catch {
            return 'gpt-4.1';
        }
    }

    function _getFamilyScanModelOptionsForProvider(provider) {
        const p = (provider || '').toString().trim().toLowerCase();
        if (p === 'ollama') return ['llava:7b', 'llava', 'llava:13b'];
        if (p === 'gemini') return ['gemini-2.5-flash', 'gemini-2.5-pro'];
        return ['gpt-image-1', 'gpt-4.1', 'gpt-4.1-mini', 'gpt-4o-mini'];
    }

    function _getSvgAiProviderValue() {
        try {
            const p = (svgAiProviderSelect && svgAiProviderSelect.value)
                ? String(svgAiProviderSelect.value).trim().toLowerCase()
                : '';
            if (p === 'openai' || p === 'gemini' || p === 'ollama') return p;
        } catch { /* ignore */ }
        try {
            const p = (svgCodeAiProviderSelect && svgCodeAiProviderSelect.value)
                ? String(svgCodeAiProviderSelect.value).trim().toLowerCase()
                : '';
            if (p === 'openai' || p === 'gemini' || p === 'ollama') return p;
        } catch { /* ignore */ }
        try {
            const p = (providerSelect && providerSelect.value) ? String(providerSelect.value).trim().toLowerCase() : '';
            if (p === 'openai' || p === 'gemini' || p === 'ollama') return p;
        } catch { /* ignore */ }
        return 'openai';
    }

