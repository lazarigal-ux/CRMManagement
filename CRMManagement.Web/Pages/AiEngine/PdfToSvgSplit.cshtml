                                ${crop ? '<span class="text-[10px] text-emerald-300 border border-emerald-500/40 rounded px-1.5 py-0.5">CROP only</span>' : ''}
                                <button type="button" class="text-[10px] text-slate-400 hover:text-white border border-slate-600/40 rounded px-1.5 py-0.5" onclick="annotatedPageZoomReset(${pi})">Reset</button>
                                <button type="button" class="text-[10px] text-slate-400 hover:text-white border border-slate-600/40 rounded px-1.5 py-0.5" onclick="annotatedPageZoomFit(${pi})">Fit</button>
                                <button type="button" id="btnMarkMissing_${pi}" class="text-[10px] text-amber-300 hover:text-amber-100 border border-amber-500/40 rounded px-1.5 py-0.5" onclick="toggleMarkMissingMode(${pi}, 'table')" title="Draw a rectangle and add the missing object to the detections table only"><i class="fa-solid fa-crosshairs me-1"></i>Mark Missing</button>
                                <button type="button" id="btnAddMissing_${pi}" class="text-[10px] text-emerald-300 hover:text-emerald-100 border border-emerald-500/40 rounded px-1.5 py-0.5" onclick="toggleMarkMissingMode(${pi}, 'memory')" title="Draw a rectangle and add the missing object to the detections table and YOLO memory"><i class="fa-solid fa-plus me-1"></i>Add to YOLO</button>
                                <span class="ms-auto text-[11px] text-slate-400" id="annotatedDetectionsCountLabel_${pi}">${cnt} detection(s) • red=neutral • green=add • yellow=cancel</span>
                                <button type="button" class="text-[10px] text-sky-300 hover:text-sky-100 border border-sky-500/40 rounded px-1.5 py-0.5" onclick="openAnnotatedPagePreview(${pi})" title="Open in full-screen modal"><i class="fa-solid fa-expand me-1"></i>Enlarge</button>
