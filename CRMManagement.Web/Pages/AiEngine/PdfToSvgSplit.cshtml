        if (!(targetAspect > 0)) return bb;

        let width = bb.width;
        let height = bb.height;
        const currentAspect = width / height;
        if (currentAspect < targetAspect) width = height * targetAspect;
        else height = width / targetAspect;

        if (width > pageRect.w || height > pageRect.h) {
            return { x: pageRect.x, y: pageRect.y, width: pageRect.w, height: pageRect.h };
        }

        const cx = bb.x + bb.width / 2;
        const cy = bb.y + bb.height / 2;
        let x = cx - width / 2;
        let y = cy - height / 2;

        if (x < pageRect.x) x = pageRect.x;
        if (y < pageRect.y) y = pageRect.y;
        if (x + width > pageRect.x + pageRect.w) x = pageRect.x + pageRect.w - width;
        if (y + height > pageRect.y + pageRect.h) y = pageRect.y + pageRect.h - height;

        if (x > bb.x || y > bb.y || (x + width) < (bb.x + bb.width) || (y + height) < (bb.y + bb.height)) {
