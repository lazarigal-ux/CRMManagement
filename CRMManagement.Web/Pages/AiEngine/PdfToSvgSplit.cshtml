    function _isTextOnlyAiEligibleResult(r) {
        try {
            return !!(r && r.svgContent);
        } catch {
            return false;
        }
    }

    function _renderFamilyScanModelOptionsHtml() {
        try {
            const p = (providerSelect && providerSelect.value) ? String(providerSelect.value).trim().toLowerCase() : '';
            const opts = _getFamilyScanModelOptionsForProvider(p);
            const selected = (_familyScanAiModel || '').toString().trim();

            const uniq = [];
            const seen = new Set();
            for (const o of opts) {
                const s = (o || '').toString().trim();
                if (!s) continue;
                const k = s.toLowerCase();
                if (seen.has(k)) continue;
                seen.add(k);
                uniq.push(s);
            }

            // If user already selected a custom model, keep it visible/selected.
            if (selected) {
                const k = selected.toLowerCase();
                if (!seen.has(k)) {
                    uniq.unshift(selected);
                    seen.add(k);
                }
            }

            const autoSelected = !selected;
            const parts = [];
            parts.push('\x3Coption value="" ' + (autoSelected ? 'selected' : '') + '>Auto (server default)\x3C/option>');
            for (const s of uniq) {
                const sel = (selected && s.toLowerCase() === selected.toLowerCase()) ? 'selected' : '';
                parts.push('\x3Coption value="' + escapeHtml(s) + '" ' + sel + '>' + escapeHtml(s) + '\x3C/option>');
            }
            return parts.join('');
        } catch {
            return '\x3Coption value="" selected>Auto (server default)\x3C/option>';
        }
    }

    function _revokeFamilyPanelUrls(urls) {
        const list = Array.isArray(urls) ? urls : _familyPanelObjectUrls;
        if (!list || !list.length) return;
        for (const u of list) {
            try { URL.revokeObjectURL(u); } catch { /* ignore */ }
        }
        if (!urls) _familyPanelObjectUrls = [];
    }

    function _revokeFamilyPanelUrlsDelayed(urls, delayMs) {
        const list = Array.isArray(urls) ? urls.slice(0) : [];
        if (!list.length) return;
        const ms = (isFinite(delayMs) && delayMs >= 0) ? (delayMs | 0) : 1500;
        try {
            setTimeout(() => {
                try { _revokeFamilyPanelUrls(list); } catch { /* ignore */ }
            }, ms);
        } catch {
            try { _revokeFamilyPanelUrls(list); } catch { /* ignore */ }
        }
    }

    function _createSvgObjectUrl(svgText) {
        try {
            if (!svgText) return null;
            const blob = new Blob([svgText], { type: 'image/svg+xml' });
            const url = URL.createObjectURL(blob);
