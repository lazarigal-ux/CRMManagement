                const tooTall = bb.height > orig.h * 1.1;
                const tooFar = (bb.x < orig.x - orig.w * 0.25) || (bb.y < orig.y - orig.h * 0.25)
                           || (bb.x + bb.width > orig.x + orig.w * 1.25) || (bb.y + bb.height > orig.y + orig.h * 1.25);
                if (tooWide || tooTall || tooFar) {
                    const ix1 = Math.max(bb.x, orig.x);
                    const iy1 = Math.max(bb.y, orig.y);
                    const ix2 = Math.min(bb.x + bb.width, orig.x + orig.w);
                    const iy2 = Math.min(bb.y + bb.height, orig.y + orig.h);
                    const iw = ix2 - ix1;
                    const ih = iy2 - iy1;
                    if (iw > 1 && ih > 1) {
                        _debugPdfSplitLog('[SVG-FIT] bbox exceeds page bounds, intersecting with page rect');
                        bb = { x: ix1, y: iy1, width: iw, height: ih };
                    } else {
                        _debugPdfSplitLog('[SVG-FIT] bbox intersection invalid, falling back to page rect');
                        bb = { x: orig.x, y: orig.y, width: orig.w, height: orig.h };
                    }
                }

                // For full-page previews, only crop if bbox is meaningfully smaller.
                if (!force) {
                    const nearFullW = bb.width >= orig.w * 0.98;
                    const nearFullH = bb.height >= orig.h * 0.98;
                    if (nearFullW && nearFullH) {
                        return;
                    }
                }

                if (preservePageAspect) {
                    bb = _expandSvgBoxToAspectWithinPage(bb, orig);
                }
            }

            const pad = Math.max(2, Math.min(20, Math.max(bb.width, bb.height) * 0.02));
            svg.setAttribute('viewBox', `${bb.x - pad} ${bb.y - pad} ${bb.width + pad * 2} ${bb.height + pad * 2}`);
            svg.setAttribute('preserveAspectRatio', 'xMidYMid meet');
        } catch {
            // getBBox can fail for some SVGs; keep original viewBox
        }

        // Ensure 1 viewBox unit ≈ 1 CSS pixel at zoom=1
        try {
            const vb = svg.viewBox && svg.viewBox.baseVal ? svg.viewBox.baseVal : null;
            if (vb && vb.width > 0 && vb.height > 0) {
                svg.style.width = vb.width + 'px';
                svg.style.height = vb.height + 'px';
            }
        } catch { }
    }

    function setSvgPreviewZoom(z, opts) {
        const body = document.getElementById('svgPreviewBody');
        const scaleEl = document.getElementById('svgPreviewScale');
        if (!body || !scaleEl) return;
        const svg = scaleEl.querySelector('svg');
        const img = !svg ? scaleEl.querySelector('img') : null;
        const canvas = (!svg && !img) ? scaleEl.querySelector('canvas') : null;

        const prevZoom = svgPreviewZoom;
        svgPreviewZoom = Math.max(0.05, Math.min(40, z));

        // Scale SVG by setting explicit dimensions (no CSS transform) so scroll/centering works.
        // For non-SVG content (img/canvas), also scale by explicit dimensions using recorded base size.
        if (svg) {
            const vb = svg.viewBox && svg.viewBox.baseVal;
            if (vb && vb.width > 0 && vb.height > 0) {
                svg.style.width = (vb.width * svgPreviewZoom) + 'px';
                svg.style.height = (vb.height * svgPreviewZoom) + 'px';
            }
            scaleEl.style.transform = '';
        } else if (img) {
            const bw = parseFloat(String(img.dataset.baseW || img.naturalWidth || '0')) || 0;
            const bh = parseFloat(String(img.dataset.baseH || img.naturalHeight || '0')) || 0;
            if (bw > 0 && bh > 0) {
                img.style.maxWidth = 'none';
                img.style.maxHeight = 'none';
                img.style.width = (bw * svgPreviewZoom) + 'px';
                img.style.height = (bh * svgPreviewZoom) + 'px';
            }
            scaleEl.style.transform = '';
        } else if (canvas) {
            const bw = parseFloat(String(canvas.dataset.baseW || canvas.width || '0')) || 0;
            const bh = parseFloat(String(canvas.dataset.baseH || canvas.height || '0')) || 0;
            if (bw > 0 && bh > 0) {
                canvas.style.maxWidth = 'none';
                canvas.style.maxHeight = 'none';
                canvas.style.width = (bw * svgPreviewZoom) + 'px';
                canvas.style.height = (bh * svgPreviewZoom) + 'px';
            }
            scaleEl.style.transform = '';
        }

        const lbl = document.getElementById('svgZoomLabel');
        if (lbl) lbl.textContent = `${Math.round(svgPreviewZoom * 100)}%`;

        if (opts && opts.anchor) {
            const rect = body.getBoundingClientRect();
            const x = opts.anchor.x - rect.left;
            const y = opts.anchor.y - rect.top;

            const contentX = (body.scrollLeft + x) / prevZoom;
            const contentY = (body.scrollTop + y) / prevZoom;

            body.scrollLeft = contentX * svgPreviewZoom - x;
            body.scrollTop = contentY * svgPreviewZoom - y;
        }

        // Re-render crop overlay so it matches the new zoom (defer to ensure layout is updated)
        requestAnimationFrame(() => {
            try { _renderSvgPreviewCropOverlayNow(); } catch { /* ignore */ }
        });
    }

    function fitSvgPreviewToViewport() {
        const body = document.getElementById('svgPreviewBody');
        const scaleEl = document.getElementById('svgPreviewScale');
        if (!body || !scaleEl) return;
        const svg = scaleEl.querySelector('svg');
        const img = !svg ? scaleEl.querySelector('img') : null;
        const canvas = (!svg && !img) ? scaleEl.querySelector('canvas') : null;

        if (!svg && !img && !canvas) return;

        let w = 0;
        let h = 0;
        if (svg) {
            // Crop (layer-forced; full-page only if bbox smaller)
            if (svgPreviewUseAutoCrop) autoFitSvgPreviewViewBoxToContent(svg, { force: svgPreviewAutoCropForce, preservePageAspect: svgPreviewAutoCropPreservePageAspect });

            const vb = svg.viewBox && svg.viewBox.baseVal ? svg.viewBox.baseVal : null;
            w = vb && vb.width ? vb.width : 0;
            h = vb && vb.height ? vb.height : 0;
        } else if (img) {
            w = parseFloat(String(img.dataset.baseW || img.naturalWidth || '0')) || 0;
            h = parseFloat(String(img.dataset.baseH || img.naturalHeight || '0')) || 0;
        } else if (canvas) {
            w = parseFloat(String(canvas.dataset.baseW || canvas.width || '0')) || 0;
            h = parseFloat(String(canvas.dataset.baseH || canvas.height || '0')) || 0;
        }

        if (!w || !h) {
            setSvgPreviewZoom(1.0);
            return;
        }

        const pad = 24;
        const availW = Math.max(10, body.clientWidth - pad);
        const availH = Math.max(10, body.clientHeight - pad);
        const z = Math.min(availW / w, availH / h);

        try {
            if (svg) {
                const vb = svg.viewBox && svg.viewBox.baseVal ? svg.viewBox.baseVal : null;
                _debugPdfSplitLog('[SVG-FIT]', { origPage: svg._origPageRect, viewBox: vb ? `${vb.x} ${vb.y} ${vb.width} ${vb.height}` : '', availW, availH, zoom: z });
            }
        } catch { /* ignore */ }

        setSvgPreviewZoom(z);

        // CSS flex + margin:auto on #svgPreviewScale centres the SVG
        // when it is smaller than the viewport; reset scroll for that case.
        body.scrollLeft = 0;
        body.scrollTop  = 0;
    }

    function _getVisibleSidebarWidthPx() {
        try {
            if (document.body.classList.contains('sidebar-collapsed')) return 0;
            const sb = document.querySelector('aside[data-sidebar="main"]');
            if (!sb) return 0;
            const cs = window.getComputedStyle(sb);
            if (!cs || cs.display === 'none' || cs.visibility === 'hidden') return 0;
            const w = sb.getBoundingClientRect().width;
            return (w && w > 0) ? w : 0;
        } catch {
            return 0;
        }
    }

    function _applySvgPreviewModalSidebarOffset() {
        const modal = document.getElementById('svgPreviewModal');
        if (!modal) return;
        const sbW = _getVisibleSidebarWidthPx();
        // Shift the modal content area to the right so the window isn't obscured by the sidebar.
        // Also expose the width to CSS so the window can clamp its max-width.
        modal.style.paddingLeft = sbW ? `${sbW}px` : '';
        modal.style.setProperty('--cgSidebarW', sbW ? `${sbW}px` : '0px');
    }

    // The preview modal is shared by multiple flows.
    // In family-sample preview/edit mode we hide crop controls to reduce confusion.
    let _svgPreviewToolbarMode = 'default';

    function _setSvgPreviewToolbarMode(mode) {
        const m = (mode || '').toString().trim().toLowerCase();
        _svgPreviewToolbarMode = m || 'default';
        const hideCrop = _svgPreviewToolbarMode === 'family';
        const ids = [
            'btnSvgCropAll', 'btnSvgCropShrink', 'btnSvgCropExpand',
            'btnSvgCropLeft', 'btnSvgCropRight', 'btnSvgCropUp', 'btnSvgCropDown',
            'btnSvgCropTrimLeft', 'btnSvgCropTrimRight', 'btnSvgCropTrimTop', 'btnSvgCropTrimBottom',
            'svgCropLabel'
        ];
        for (const id of ids) {
            const el = document.getElementById(id);
            if (!el) continue;
            el.classList.toggle('hidden', hideCrop);
        }
    }

    function _updateSvgCropUi() {
        const lbl = document.getElementById('svgCropLabel');
        const btn = document.getElementById('btnSvgCropAll');
        const btnShrink = document.getElementById('btnSvgCropShrink');
        const btnExpand = document.getElementById('btnSvgCropExpand');
        const btnLeft = document.getElementById('btnSvgCropLeft');
        const btnRight = document.getElementById('btnSvgCropRight');
        const btnUp = document.getElementById('btnSvgCropUp');
        const btnDown = document.getElementById('btnSvgCropDown');
        const btnTrimL = document.getElementById('btnSvgCropTrimLeft');
        const btnTrimR = document.getElementById('btnSvgCropTrimRight');
        const btnTrimT = document.getElementById('btnSvgCropTrimTop');
        const btnTrimB = document.getElementById('btnSvgCropTrimBottom');
        if (lbl) lbl.textContent = svgPreviewFixedCropEnabled ? 'CLEAR AREA' : (svgPreviewCropDrawMode ? 'CANCEL AREA' : 'SELECT AREA');
        if (btn) {
            btn.classList.toggle('ring-1', svgPreviewFixedCropEnabled);
            btn.classList.toggle('ring-emerald-400/40', svgPreviewFixedCropEnabled);
            btn.classList.toggle('border-emerald-500/60', svgPreviewFixedCropEnabled);
            btn.classList.toggle('ring-fuchsia-400/40', svgPreviewCropDrawMode && !svgPreviewFixedCropEnabled);
            btn.classList.toggle('border-fuchsia-500/60', svgPreviewCropDrawMode && !svgPreviewFixedCropEnabled);
        }
        if (btnShrink) btnShrink.disabled = !svgPreviewFixedCropEnabled;
        if (btnExpand) btnExpand.disabled = !svgPreviewFixedCropEnabled;
        if (btnLeft) btnLeft.disabled = !svgPreviewFixedCropEnabled;
        if (btnRight) btnRight.disabled = !svgPreviewFixedCropEnabled;
        if (btnUp) btnUp.disabled = !svgPreviewFixedCropEnabled;
        if (btnDown) btnDown.disabled = !svgPreviewFixedCropEnabled;
        if (btnTrimL) btnTrimL.disabled = !svgPreviewFixedCropEnabled;
        if (btnTrimR) btnTrimR.disabled = !svgPreviewFixedCropEnabled;
        if (btnTrimT) btnTrimT.disabled = !svgPreviewFixedCropEnabled;
        if (btnTrimB) btnTrimB.disabled = !svgPreviewFixedCropEnabled;

        // Keep the preview size unchanged; crop is only a selection for AI input.
        try {
            const scaleEl = document.getElementById('svgPreviewScale');
            if (scaleEl) {
                scaleEl.style.border = '';
                scaleEl.style.borderRadius = '';
                scaleEl.style.background = '';
                scaleEl.style.overflow = '';
            }
        } catch { }

        _renderSvgPreviewCropOverlay();
    }

    function _refreshAllResultThumbnails() {
        try {
            if (!resultsGrid && !movedOtherElementsGrid) return;
            // Replace existing object URLs so thumbs reflect the latest crop.
            revokeThumbObjectUrls();

            const grids = [resultsGrid, movedOtherElementsGrid].filter(Boolean);
            for (const grid of grids) {
                const cards = grid.querySelectorAll('.page-card');
                for (const card of cards) {
                    const idx = parseInt(card.dataset.idx || (card.querySelector('.btn-preview')?.dataset?.idx || ''), 10);
                    if (!Number.isFinite(idx) || idx < 0 || idx >= pageResults.length) continue;
                    const r = pageResults[idx];
                    if (!r || !r.svgContent) continue;

                    const thumbEl = card.querySelector('.svg-thumb');
                    if (!thumbEl) continue;

                    const alt = thumbEl.getAttribute('alt') || (r.isLayer
                        ? `Region ${r.regionIndex || ''} (Page ${r.pageNumber})`
                        : `Page ${r.pageNumber}`);

                    let src;
                    if (!r.isLayer && r.thumbnailDataUrl) {
                        src = r.thumbnailDataUrl;
                    } else {
                        src = svgToObjectUrl(r.svgContent);
                    }

                    if (thumbEl.tagName && thumbEl.tagName.toLowerCase() === 'img') {
                        thumbEl.setAttribute('alt', alt);
                        thumbEl.src = src;
                    } else {
                        const img = document.createElement('img');
                        img.className = thumbEl.className || 'svg-thumb';
                        img.alt = alt;
                        img.loading = 'lazy';
                        img.src = src;
                        thumbEl.replaceWith(img);
                    }
                }
            }
        } catch {
            // best-effort UI refresh
        }
    }

    function _parseViewBoxStr(vbStr) {
        const parts = String(vbStr || '').trim().split(/[\s,]+/).filter(Boolean);
        if (parts.length !== 4) return null;
        const x = parseFloat(parts[0]);
        const y = parseFloat(parts[1]);
        const w = parseFloat(parts[2]);
        const h = parseFloat(parts[3]);
        if (![x, y, w, h].every(n => Number.isFinite(n)) || !(w > 0) || !(h > 0)) return null;
        return { x, y, w, h };
    }

    function _formatViewBox(vb) {
        return `${vb.x} ${vb.y} ${vb.w} ${vb.h}`;
    }

    function _scaleFixedCrop(factor) {
        if (!svgPreviewFixedCropEnabled || !svgPreviewFixedCropViewBoxStr) return;
        const vb = _parseViewBoxStr(svgPreviewFixedCropViewBoxStr);
        if (!vb) return;
        const cx = vb.x + vb.w / 2;
        const cy = vb.y + vb.h / 2;
        const newW = Math.max(5, vb.w * factor);
        const newH = Math.max(5, vb.h * factor);
        const next = { x: cx - newW / 2, y: cy - newH / 2, w: newW, h: newH };
        svgPreviewFixedCropViewBoxStr = _formatViewBox(next);
    }

    function _translateFixedCrop(dx, dy, svgForClamp) {
        if (!svgPreviewFixedCropEnabled || !svgPreviewFixedCropViewBoxStr) return;
        const vb = _parseViewBoxStr(svgPreviewFixedCropViewBoxStr);
        if (!vb) return;
        const next = { x: vb.x + dx, y: vb.y + dy, w: vb.w, h: vb.h };

        // Optional clamp to the current SVG's original page rect.
        try {
            const pr = svgForClamp && svgForClamp._origPageRect ? svgForClamp._origPageRect : null;
            if (pr && pr.w > 0 && pr.h > 0) {
                const minX = pr.x;
                const minY = pr.y;
                const maxX = pr.x + pr.w - next.w;
                const maxY = pr.y + pr.h - next.h;
                if (isFinite(maxX)) next.x = Math.max(minX, Math.min(next.x, maxX));
                if (isFinite(maxY)) next.y = Math.max(minY, Math.min(next.y, maxY));
            }
        } catch { }

        svgPreviewFixedCropViewBoxStr = _formatViewBox(next);
    }

    function _shrinkFixedCropSide(side, svgForClamp) {
        if (!svgPreviewFixedCropEnabled || !svgPreviewFixedCropViewBoxStr) return;
        const vb = _parseViewBoxStr(svgPreviewFixedCropViewBoxStr);
        if (!vb) return;

        const stepX = Math.max(1, vb.w * 0.05);
        const stepY = Math.max(1, vb.h * 0.05);

        const right = vb.x + vb.w;
        const bottom = vb.y + vb.h;

        let x = vb.x, y = vb.y, w = vb.w, h = vb.h;
        const minSize = 5;

        if (side === 'l') {
            w = Math.max(minSize, w - stepX);
            x = right - w; // keep right edge fixed
        } else if (side === 'r') {
            w = Math.max(minSize, w - stepX); // keep left edge fixed
        } else if (side === 't') {
            h = Math.max(minSize, h - stepY);
            y = bottom - h; // keep bottom edge fixed
        } else if (side === 'b') {
            h = Math.max(minSize, h - stepY); // keep top edge fixed
        } else {
            return;
        }

        // Optional clamp to the current SVG's original page rect.
        try {
            const pr = svgForClamp && svgForClamp._origPageRect ? svgForClamp._origPageRect : null;
            if (pr && pr.w > 0 && pr.h > 0) {
                const minX = pr.x;
                const minY = pr.y;
                const maxX = pr.x + pr.w - w;
                const maxY = pr.y + pr.h - h;
                if (isFinite(maxX)) x = Math.max(minX, Math.min(x, maxX));
                if (isFinite(maxY)) y = Math.max(minY, Math.min(y, maxY));
            }
        } catch { }

        svgPreviewFixedCropViewBoxStr = _formatViewBox({ x, y, w, h });
    }

    function _getSvgContentForExport(svgText) {
        return svgText;
    }

    function _rectIntersectsViewBoxRect(a, b, pad = 0) {
        if (!a || !b) return false;
        const ax1 = Number(a.x);
        const ay1 = Number(a.y);
        const ax2 = ax1 + Math.max(0, Number(a.width) || 0);
        const ay2 = ay1 + Math.max(0, Number(a.height) || 0);
        const bx1 = Number(b.x) - pad;
        const by1 = Number(b.y) - pad;
        const bx2 = Number(b.x) + Math.max(0, Number(b.w) || 0) + pad;
        const by2 = Number(b.y) + Math.max(0, Number(b.h) || 0) + pad;
        return ax2 >= bx1 && ax1 <= bx2 && ay2 >= by1 && ay1 <= by2;
    }

    function _inflateSvgCandidateRectForHitTest(rect, minThickness = 2) {
        if (!rect) return null;
        let x = Number(rect.x) || 0;
        let y = Number(rect.y) || 0;
        let width = Math.max(0, Number(rect.width) || 0);
        let height = Math.max(0, Number(rect.height) || 0);

        if (width < minThickness) {
            const delta = (minThickness - width) / 2;
            x -= delta;
            width = minThickness;
        }

        if (height < minThickness) {
            const delta = (minThickness - height) / 2;
            y -= delta;
            height = minThickness;
        }

        return { x, y, width, height };
    }

    function _getSvgAiCandidateHitPad(crop) {
        if (!crop) return 2;
        return Math.max(6, Math.min(18, Math.max(Number(crop.w) || 0, Number(crop.h) || 0) * 0.12));
    }

    function _buildCropReducedSvgPayload(svgText, cropViewBoxStr) {
        try {
            const srcSvg = (svgText || '').toString();
            const crop = _parseViewBoxStr(cropViewBoxStr);
            if (!srcSvg || !crop) return _getSvgContentForExport(srcSvg);

            const parser = new DOMParser();
            const doc = parser.parseFromString(srcSvg, 'image/svg+xml');
            const svgRoot = doc.querySelector('svg');
            if (!svgRoot) return _getSvgContentForExport(srcSvg);

            const serializer = new XMLSerializer();
            const reducedRoot = svgRoot.cloneNode(false);
            try {
                reducedRoot.setAttribute('viewBox', `${crop.x} ${crop.y} ${crop.w} ${crop.h}`);
                reducedRoot.setAttribute('width', `${crop.w}`);
                reducedRoot.setAttribute('height', `${crop.h}`);
            } catch { /* ignore */ }

            function _bboxBelongsToSelectedArea(bb, cropRect, pad) {
                if (!bb || !cropRect) return false;
                const p = Number.isFinite(pad) ? pad : 0;
                // Only include elements whose center falls inside the crop area
                const cx = (Number(bb.x) || 0) + ((Number(bb.width) || 0) / 2);
                const cy = (Number(bb.y) || 0) + ((Number(bb.height) || 0) / 2);
                return cx >= (cropRect.x - p) && cx <= (cropRect.x + cropRect.w + p)
                    && cy >= (cropRect.y - p) && cy <= (cropRect.y + cropRect.h + p);
            }

            function appendIntersectingChildren(srcParent, dstParent, inheritedMatrix) {
                if (!srcParent || !dstParent) return 0;
                let appended = 0;
                const parentMatrix = inheritedMatrix || _svgIdentityMatrix();

                for (const child of Array.from(srcParent.childNodes || [])) {
                    if (!child || child.nodeType !== 1) continue;

                    const el = child;
                    const tag = String(el.tagName || '').toLowerCase();
                    if (!tag) continue;
                    const localMatrix = _svgMultiplyMatrices(parentMatrix, _svgParseTransformMatrix(el.getAttribute('transform')));

                    if (tag === 'defs') {
                        dstParent.appendChild(el.cloneNode(true));
                        appended++;
                        continue;
                    }

                    if (tag === 'g' || tag === 'a' || tag === 'symbol' || tag === 'switch') {
                        const wrapper = el.cloneNode(false);
                        const nested = appendIntersectingChildren(el, wrapper, localMatrix);
                        if (nested > 0) {
                            dstParent.appendChild(wrapper);
                            appended++;
                        }
                        continue;
                    }

                    if (tag === 'text' || tag === 'tspan' || tag === 'textpath') {
                        const xs = String(el.getAttribute('x') || '').trim().split(/[\s,]+/).filter(Boolean).map(Number).filter(Number.isFinite);
                        const ys = String(el.getAttribute('y') || '').trim().split(/[\s,]+/).filter(Boolean).map(Number).filter(Number.isFinite);
                        const x = xs.length ? xs[0] : NaN;
                        const y = ys.length ? ys[0] : NaN;
                        const pt = Number.isFinite(x) && Number.isFinite(y) ? _svgApplyMatrixToPoint(x, y, localMatrix) : null;
                        if (pt
                            && pt.x >= (crop.x - 2) && pt.x <= (crop.x + crop.w + 2)
                            && pt.y >= (crop.y - 2) && pt.y <= (crop.y + crop.h + 2)) {
                            dstParent.appendChild(el.cloneNode(true));
                            appended++;
                        }
                        continue;
                    }

                    // For paths, use fast crop-optimized bounds estimation (no d-length cap)
                    let bb;
                    if (tag === 'path') {
                        bb = _estimateSvgPathBoundsForCrop(el.getAttribute('d'));
                    } else {
                        bb = _estimateSvgElementBoundsFast(el, { skipPaths: false });
                    }
                    bb = _svgTransformRect(bb, localMatrix);
                    if (!bb || !_bboxBelongsToSelectedArea(bb, crop, 2)) continue;

                    dstParent.appendChild(el.cloneNode(true));
                    appended++;
                }

                return appended;
            }

            const keptCount = appendIntersectingChildren(svgRoot, reducedRoot, _svgIdentityMatrix());
            if (!(keptCount > 0)) return serializer.serializeToString(reducedRoot);

            const reduced = serializer.serializeToString(reducedRoot);
            return reduced || serializer.serializeToString(reducedRoot);
        } catch {
            return _getSvgContentForExport(svgText || '');
        }
    }

    function _computeFixedCropViewBoxFromSvg(svg) {
        if (!svg) return null;
        try {
            let bb = _svgComputeBBoxIgnoringPageBg(svg);
            if (!bb || !isFinite(bb.x) || !isFinite(bb.y) || !(bb.width > 0) || !(bb.height > 0)) return null;

            const orig = svg._origPageRect;
            if (orig && orig.w > 0 && orig.h > 0) {
                const tooWide = bb.width > orig.w * 1.1;
                const tooTall = bb.height > orig.h * 1.1;
                const tooFar = (bb.x < orig.x - orig.w * 0.25) || (bb.y < orig.y - orig.h * 0.25)
                           || (bb.x + bb.width > orig.x + orig.w * 1.25) || (bb.y + bb.height > orig.y + orig.h * 1.25);
                if (tooWide || tooTall || tooFar) {
                    const ix1 = Math.max(bb.x, orig.x);
                    const iy1 = Math.max(bb.y, orig.y);
                    const ix2 = Math.min(bb.x + bb.width, orig.x + orig.w);
                    const iy2 = Math.min(bb.y + bb.height, orig.y + orig.h);
                    const iw = ix2 - ix1;
                    const ih = iy2 - iy1;
                    if (iw > 1 && ih > 1) bb = { x: ix1, y: iy1, width: iw, height: ih };
                }
            }

            const pad = Math.max(2, Math.min(20, Math.max(bb.width, bb.height) * 0.02));
            const x = bb.x - pad;
            const y = bb.y - pad;
            const w = bb.width + pad * 2;
            const h = bb.height + pad * 2;
            return `${x} ${y} ${w} ${h}`;
        } catch {
            return null;
        }
