                                <div style="display:inline-block; transform-origin:0 0; position:relative; overflow:hidden; background:#fff;" id="annotatedPageScale_${pi}" data-crop-x="${cropX}" data-crop-y="${cropY}" data-crop-w="${cropW}" data-crop-h="${cropH}">
                                    <img src="${img}" class="block rounded-lg border border-slate-700/40 bg-white" style="max-width:none; max-height:none; position:absolute; left:0; top:0;" alt="Annotated page ${pi + 1}" draggable="false"
                                         onload="annotatedPageFitOnLoad(${pi})" />
