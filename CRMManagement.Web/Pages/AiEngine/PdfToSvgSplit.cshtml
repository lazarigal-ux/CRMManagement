        function _getLastCreatedGroupElement() {
            if (!_lastCreatedGroupInfo?.id || !mergedSvgPreviewScale) return null;
            const svg = mergedSvgPreviewScale.querySelector('svg');
            if (!svg) return null;
            return _findSvgElementById(svg, _lastCreatedGroupInfo.id);
        }

        function _buildStandaloneSvgFromElement(sourceEl) {
            const sourceSvg = mergedSvgPreviewScale ? mergedSvgPreviewScale.querySelector('svg') : null;
            if (!sourceSvg || !sourceEl) return '';
            if (_isColorGroupType(groupNameSelect ? groupNameSelect.value : '')) {
                const color = _pickRepresentativeColorFromElements([sourceEl]);
                return _buildColorSwatchStandaloneSvg(color);
            }
            const bb = _getElementBbox(sourceEl, sourceSvg);
            if (!bb || !isFinite(bb.x) || !isFinite(bb.y) || !isFinite(bb.w) || !isFinite(bb.h)) return '';

            const pad = Math.max(6, Math.min(18, Math.max(bb.w, bb.h) * 0.12 || 6));
            const doc = document.implementation.createDocument('http://www.w3.org/2000/svg', 'svg', null);
            const outSvg = doc.documentElement;
            outSvg.setAttribute('xmlns', 'http://www.w3.org/2000/svg');
            outSvg.setAttribute('xmlns:xlink', 'http://www.w3.org/1999/xlink');
            outSvg.setAttribute('viewBox', `${bb.x - pad} ${bb.y - pad} ${Math.max(bb.w + pad * 2, 1)} ${Math.max(bb.h + pad * 2, 1)}`);

            _appendSelectedObjectPreviewDefs(sourceSvg, outSvg, sourceEl);
            _appendSelectedObjectCloneInRootSpace(outSvg, sourceSvg, sourceEl);
            const raw = new XMLSerializer().serializeToString(outSvg);
            return _normalizeMapIconSampleSvg(raw) || raw;
        }

        /** Build a standalone SVG string from the currently selected items (client-side, no server). */
        function _buildStandaloneSvgFromSelectedItems() {
            const sourceSvg = mergedSvgPreviewScale ? mergedSvgPreviewScale.querySelector('svg') : null;
            if (!sourceSvg) return '';
            const activeItems = (_currentSelectedItems || []).filter(i => i && i.enabled !== false && i.el);
            if (!activeItems.length) return '';

            if (_isColorGroupType(groupNameSelect ? groupNameSelect.value : '')) {
                const color = _pickRepresentativeColorFromElements(activeItems.map(i => i.el));
                return _buildColorSwatchStandaloneSvg(color);
            }

            let minX = Infinity, minY = Infinity, maxX = -Infinity, maxY = -Infinity;
            const validItems = [];
            for (const item of activeItems) {
                const bb = item.bb || _getElementBbox(item.el, sourceSvg);
                if (!bb || !isFinite(bb.x) || !isFinite(bb.y) || !isFinite(bb.w) || !isFinite(bb.h)) continue;
                validItems.push({ el: item.el, bb });
                minX = Math.min(minX, bb.x);
                minY = Math.min(minY, bb.y);
                maxX = Math.max(maxX, bb.x + bb.w);
                maxY = Math.max(maxY, bb.y + bb.h);
            }
            if (!validItems.length) return '';

            const width = Math.max(maxX - minX, 1);
            const height = Math.max(maxY - minY, 1);
            const pad = Math.max(6, Math.min(18, Math.max(width, height) * 0.12 || 6));

            const doc = document.implementation.createDocument('http://www.w3.org/2000/svg', 'svg', null);
            const outSvg = doc.documentElement;
            outSvg.setAttribute('xmlns', 'http://www.w3.org/2000/svg');
            outSvg.setAttribute('xmlns:xlink', 'http://www.w3.org/1999/xlink');
            outSvg.setAttribute('viewBox', `${minX - pad} ${minY - pad} ${width + pad * 2} ${height + pad * 2}`);

            const appendedIds = new Set();
            for (const { el } of validItems) {
                _appendSelectedObjectPreviewDefs(sourceSvg, outSvg, el, appendedIds);
            }
            for (const { el } of validItems) {
                _appendSelectedObjectCloneInRootSpace(outSvg, sourceSvg, el);
            }
            const raw = new XMLSerializer().serializeToString(outSvg);
            // Skip color normalization for color groups — preserve original colors
            if (_isColorGroupType(groupNameSelect ? groupNameSelect.value : '')) return raw;
            return _normalizeMapIconSampleSvg(raw) || raw;
        }

        async function _saveCreatedGroupToFamily() {
            console.log('[SaveGroup] START');
            const prevHtml = btnSaveGroup ? btnSaveGroup.innerHTML : '';
            if (btnSaveGroup) {
                btnSaveGroup.disabled = true;
                btnSaveGroup.innerHTML = '<i class="fa-solid fa-spinner fa-spin text-[9px]"></i> Saving...';
            }

            // Build standalone SVG from selected elements (client-side only — no server round-trip)
            const activeCount = (_currentSelectedItems || []).filter(i => i && i.enabled !== false && i.el).length;
            let sampleSvg = '';
            let previewSvgEl = null;

            if (activeCount > 0) {
                // Build from selected items directly
                sampleSvg = _buildStandaloneSvgFromSelectedItems();
                console.log('[SaveGroup] Built SVG from %d selected items, length=%d', activeCount, sampleSvg.length);
                // Also build a live preview
                try {
                    const items = (_currentSelectedItems || [])
                        .map((item, idx) => (item && item.enabled !== false) ? { item, idx } : null)
                        .filter(Boolean);
                    previewSvgEl = _buildSelectedObjectsCombinedPreviewSvg(items);
                } catch { /* ignore */ }
            } else if (_lastCreatedGroupInfo && _lastCreatedGroupInfo.id) {
                // Fallback: use previously created group element
                const groupEl = _getLastCreatedGroupElement();
                if (groupEl) {
                    sampleSvg = _buildStandaloneSvgFromElement(groupEl);
                    try { previewSvgEl = _buildElementPreviewSvg(groupEl, { padFactor: 0.08, minPad: 2, maxPad: 6 }); } catch { /* ignore */ }
                }
                console.log('[SaveGroup] Built SVG from last group element, length=%d', sampleSvg.length);
            }

            if (!sampleSvg) {
                cgAlert('Select elements first, then save.');
                if (btnSaveGroup) { btnSaveGroup.innerHTML = prevHtml || '<i class="fa-solid fa-floppy-disk text-[9px]"></i> Save object in Group'; btnSaveGroup.disabled = false; }
                return;
            }

            // Auto-select (or create) the family matching the group type — suppress tab navigation
            const groupType = (groupNameSelect ? groupNameSelect.value : '') || _lastCreatedGroupInfo?.groupName || 'lighting';
            console.log('[SaveGroup] groupType=%s', groupType);
            _suppressFamilySelectNav = true;
            try { await _ensureFamilySelectionForType(groupType); } catch (e) { console.error('[SaveGroup] _ensureFamilySelectionForType error:', e); }
            _suppressFamilySelectNav = false;
            const famId = _getSelectedFamilyId();
            console.log('[SaveGroup] famId=%s', famId);
            if (!famId) {
                cgAlert(`Could not find or create a family for type: ${groupType}`);
                if (btnSaveGroup) { btnSaveGroup.innerHTML = prevHtml || '<i class="fa-solid fa-floppy-disk text-[9px]"></i> Save object in Group'; _updateSelectedPreviewActions(); }
                return;
            }

            const symbolHref = `#${groupType}-group-${Date.now()}`;
            let existingId = 0;
            try {
                _setGroupStatus('Saving object to database…');

                // Check if already exists (dedup)
                try {
                    const viewForDedup = await _fetchFamilySamplesForPanel(famId);
                    if (viewForDedup && Array.isArray(viewForDedup.samples)) {
                        const target = _normalizeSymbolHref(symbolHref);
                        for (const s of viewForDedup.samples) {
                            if (!s || !s.symbolHref) continue;
                            if (_normalizeSymbolHref(s.symbolHref) === target) { existingId = s.id || 0; break; }
                        }
                    }
                } catch { /* ignore */ }

                console.log('[SaveGroup] POST famId=%s, symbolHref=%s, sampleSvg.length=%d', famId, symbolHref, sampleSvg.length);
                let resp;
                if (existingId > 0) {
                    resp = await fetch(`${OBJECT_FAMILIES_ENDPOINT}/${famId}/samples/${existingId}`, {
                        method: 'PUT',
                        headers: { 'Content-Type': 'application/json', 'X-Client-Id': 'admin' },
                        body: JSON.stringify({ sampleSvg })
                    });
                } else {
                    resp = await fetch(`${OBJECT_FAMILIES_ENDPOINT}/${famId}/samples`, {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json', 'X-Client-Id': 'admin' },
                        body: JSON.stringify({ symbolHref, sampleSvg })
                    });
                }
                console.log('[SaveGroup] Response: status=%d, ok=%s', resp.status, resp.ok);
                if (!resp.ok) {
                    const t = await resp.text();
                    throw new Error(`HTTP ${resp.status}: ${String(t || '').slice(0, 300)}`);
                }

                const familyName = _getSelectedFamilyName() || `Family #${famId}`;
                const msg = `✔ Object saved [${groupType}] → ${familyName}${existingId > 0 ? ' (updated)' : ''}`;
                _setGroupStatus(msg);
                _showGroupResult(msg);

                // Show the saved object SVG preview
                try { _renderSavedObjectPreview(previewSvgEl, sampleSvg, groupType, familyName); } catch (previewEx) { console.error('[SaveGroup] preview error:', previewEx); }

            } catch (ex) {
                console.error('[SaveGroup] SAVE FAILED:', ex);
                cgAlert(`Save failed: ${ex.message || ex}`);
                _setGroupStatus(`Save failed: ${ex.message || ex}`);
            } finally {
                _suppressFamilySelectNav = false;
                if (btnSaveGroup) {
                    btnSaveGroup.innerHTML = prevHtml || '<i class="fa-solid fa-floppy-disk text-[9px]"></i> Save object in Group';
                    _updateSelectedPreviewActions();
                }
            }
        }

        /* ── Inline group objects state ── */
        let _inlineGroupObjects = [];  // samples array for inline display
        let _inlineGroupObjectsGroupType = '';

        /* ── When SELECT group type changes, show saved objects for that type ── */
        async function _onGroupTypeSelectChanged() {
            const lastCreatedWrap = document.getElementById('mergedSvgLastCreatedGroupPreview');
            if (!lastCreatedWrap) return;
            const groupType = groupNameSelect ? groupNameSelect.value : '';
            if (!groupType) { lastCreatedWrap.classList.add('hidden'); return; }

            // Show loading indicator immediately
            lastCreatedWrap.innerHTML = '<div style="display:flex;align-items:center;gap:8px;padding:8px 10px;border-radius:8px;border:1px solid rgba(100,116,139,0.3);background:rgba(15,23,42,0.4);margin-top:6px;font-size:11px;color:#94a3b8;"><i class="fa-solid fa-spinner fa-spin"></i> Loading saved objects for <strong style="color:#fff;">' + escapeHtml(groupType) + '</strong>…</div>';
            lastCreatedWrap.classList.remove('hidden');

            try {
                // Ensure family exists for this type (suppress tab navigation)
                _suppressFamilySelectNav = true;
                try { await _ensureFamilySelectionForType(groupType); } catch { /* ignore */ }
                _suppressFamilySelectNav = false;

                const famId = _getSelectedFamilyId();
                const famName = _getSelectedFamilyName() || groupType;
                if (!famId) {
                    lastCreatedWrap.innerHTML = '<div style="display:flex;align-items:center;gap:8px;padding:8px 10px;border-radius:8px;border:1px solid rgba(100,116,139,0.3);background:rgba(15,23,42,0.4);margin-top:6px;font-size:11px;color:#94a3b8;"><i class="fa-regular fa-folder-open"></i> No family found for <strong>' + escapeHtml(groupType) + '</strong></div>';
                    return;
                }

                const data = await _fetchFamilySamplesForPanel(famId);
                const samples = (data && Array.isArray(data.samples)) ? data.samples : [];
                _inlineGroupObjects = samples;
                _inlineGroupObjectsGroupType = groupType;

                if (!samples.length) {
                    lastCreatedWrap.innerHTML = '<div style="display:flex;align-items:center;gap:8px;padding:8px 10px;border-radius:8px;border:1px solid rgba(100,116,139,0.3);background:rgba(15,23,42,0.4);margin-top:6px;font-size:11px;color:#94a3b8;"><i class="fa-regular fa-folder-open"></i> No saved objects for <strong style="color:#fff;">' + escapeHtml(groupType) + '</strong></div>';
                    return;
                }

                _renderInlineGroupThumbnails(lastCreatedWrap, samples, groupType);
            } catch (e) {
                console.error('[GroupSelect] Error loading saved objects:', e);
                lastCreatedWrap.innerHTML = '<div style="padding:8px 10px;border-radius:8px;border:1px solid rgba(239,68,68,0.3);background:rgba(127,29,29,0.15);margin-top:6px;font-size:11px;color:#fca5a5;">Error loading objects: ' + escapeHtml(String(e)) + '</div>';
            } finally {
                _suppressFamilySelectNav = false;
            }
        }

