        // ── DELETE ALL elements in selected area / visible code ──
        const btnDeleteAll = document.getElementById('btnSvgCodeDeleteAll');
        if (btnDeleteAll) {
            btnDeleteAll.addEventListener('click', async () => {
                const code = textarea.value;
                if (!code) return;

                // Collect all SVG element lines (not the <svg> root, not </svg>)
                const allLines = code.split('\n');
                const elementLineIndexes = [];
                for (let i = 0; i < allLines.length; i++) {
                    const t = allLines[i].trim();
                    if (!t) continue;
                    // Skip the SVG root open/close, xml declaration, defs
                    if (t.startsWith('<svg ') || t.startsWith('</svg') || t.startsWith('<?xml') || t.startsWith('<defs') || t.startsWith('</defs')) continue;
                    if (t.startsWith('<')) elementLineIndexes.push(i);
                }

                if (elementLineIndexes.length === 0) {
                    if (deleteStatus) { deleteStatus.textContent = 'No elements to delete'; deleteStatus.classList.remove('hidden'); setTimeout(() => deleteStatus.classList.add('hidden'), 2000); }
                    return;
                }

                const isCropped = !!(svgPreviewFixedCropEnabled && svgPreviewFixedCropViewBoxStr);
                const areaLabel = isCropped ? 'selected area' : 'full layer';
                const ok = await cgConfirm(`Delete ALL ${elementLineIndexes.length} element(s) from the ${areaLabel}?`);
                if (!ok) return;

