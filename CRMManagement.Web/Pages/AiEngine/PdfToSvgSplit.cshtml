        /* ── Delete a single item from SVG by index ── */
        function _deleteItemFromSvg(idx) {
            if (idx < 0 || idx >= _currentSelectedItems.length) return;
            const item = _currentSelectedItems[idx];
            if (!item) return;
            const el = item.el;
            console.log('[GroupObjects] _deleteItemFromSvg: idx=%d, tag=%s', idx, el.tagName);
            // Remove highlight
            el.classList.remove('merged-svg-el-highlight', 'merged-svg-el-cluster-highlight', 'merged-svg-el-color-highlight');
            try { el.style.outline = ''; } catch {}
            // Remove from SVG DOM
            try { el.parentNode && el.parentNode.removeChild(el); } catch {}
            // Remove from table
            const tbody = document.querySelector('#selectedObjectsTable tbody');
            const rows = tbody ? [...tbody.querySelectorAll('tr')] : [];
            const row = rows.find(r => parseInt(r.dataset.idx) === idx);
            if (row) row.remove();
            // Mark as deleted in items array
            _currentSelectedItems[idx] = null;
            _syncMergedSvgAfterDelete();
            _clearObjectSelectionState('Selection cleared after delete.');
        }

        /* ── Bulk Delete: remove all checked (enabled) items from SVG ── */
        function _deleteSelectedFromSvg() {
            const toDelete = [];
            _currentSelectedItems.forEach((item, idx) => {
                if (item && item.enabled) toDelete.push(idx);
            });
            if (!toDelete.length) {
                _setGroupStatus('No checked items to delete.');
                return;
            }
            if (!confirm(`Delete ${toDelete.length} element(s) from the SVG? This cannot be undone.`)) return;
            const btnDelSel = document.getElementById('btnDeleteSelectedObjects');
            if (btnDelSel) { btnDelSel.disabled = true; btnDelSel.classList.add('btn-delete-working'); btnDelSel.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Deleting …'; }
            console.log('[GroupObjects] _deleteSelectedFromSvg: deleting %d items', toDelete.length);
            for (const idx of toDelete) {
                const item = _currentSelectedItems[idx];
                if (!item) continue;
                item.el.classList.remove('merged-svg-el-highlight', 'merged-svg-el-cluster-highlight', 'merged-svg-el-color-highlight');
                try { item.el.style.outline = ''; } catch {}
                try { item.el.parentNode && item.el.parentNode.removeChild(item.el); } catch {}
                _currentSelectedItems[idx] = null;
            }
            // Remove all deleted rows from table
            const tbody = document.querySelector('#selectedObjectsTable tbody');
            if (tbody) {
                for (const idx of toDelete) {
                    const row = [...tbody.querySelectorAll('tr')].find(r => parseInt(r.dataset.idx) === idx);
                    if (row) row.remove();
                }
            }
            _syncMergedSvgAfterDelete();
            if (btnDelSel) { btnDelSel.disabled = false; btnDelSel.classList.remove('btn-delete-working'); btnDelSel.innerHTML = '<i class="fa-solid fa-trash-can"></i> Delete Selected'; }
            _clearObjectSelectionState(`Deleted ${toDelete.length} element(s) from SVG. Selection cleared.`);
        }

        /* ── Re-serialize SVG DOM to _pdfPreSplitMergedSvg after deletion ── */
        function _syncMergedSvgAfterDelete() {
            if (!mergedSvgPreviewScale) return;
            const svg = mergedSvgPreviewScale.querySelector('svg');
            if (!svg) return;
            _pdfPreSplitMergedSvg = new XMLSerializer().serializeToString(svg);
            console.log('[GroupObjects] _syncMergedSvgAfterDelete: new svgLen=%d', _pdfPreSplitMergedSvg.length);

            // Recount element types from live DOM and refresh legend chips
            _refreshLegendFromDom(svg);

            // Update the summary header with current counts
            _updateMergedSvgSummaryAfterEdit(svg);
        }

        /** Refresh the "paths X → Y · Z MB" summary bar after map edits */
        function _updateMergedSvgSummaryAfterEdit(svg) {
            if (!mergedSvgPreviewSummary || !svg) return;
            const pathCount = svg.querySelectorAll('path').length;
            const st = _pdfPreSplitMergedStats || {};
            const groups = svg.querySelectorAll('g[data-family]').length;
            const sizeStr = formatBytes(new Blob([_pdfPreSplitMergedSvg]).size);
            mergedSvgPreviewSummary.textContent = `${_pdfPreSplitMergedLabel || 'Merged SVG'} · groups=${groups} · paths ${st.pathCountBefore ?? '?'} → ${pathCount} · ${sizeStr}`;
        }

        function _refreshLegendFromDom(svg) {
            if (!svg) return;
            const counts = _collectMergedSvgLegendCounts(svg);
            const order = ['path', 'line', 'polyline', 'polygon', 'rect', 'circle', 'ellipse', 'text', 'image', 'use', 'group:lighting', 'group:emergency-lighting', 'group:camera', 'group:suppression', 'group:access-control', 'group:intrusion', 'group:communication', 'group:automation', 'group:other'];
            _pdfPreSplitMergedLegend = [...counts.entries()]
                .map(([tag, count]) => ({ tag, label: _getMergedSvgTypeLabel(tag), count }))
                .sort((a, b) => {
                    const ai = order.indexOf(a.tag);
                    const bi = order.indexOf(b.tag);
                    if (ai >= 0 || bi >= 0) {
                        if (ai < 0) return 1;
                        if (bi < 0) return -1;
                        if (ai !== bi) return ai - bi;
                    }
                    return b.count - a.count || a.label.localeCompare(b.label);
                });
            _renderMergedSvgLegend();
            console.log('[GroupObjects] _refreshLegendFromDom: updated legend with %d types', _pdfPreSplitMergedLegend.length);
        }

        /* ── Update count after deletions (handles null items) ── */
        function _updateSelectedCountAfterDelete() {
            const countEl = document.getElementById('selectedObjectsCount');
            const remaining = _currentSelectedItems.filter(i => i !== null);
            const active = remaining.filter(i => i.enabled).length;
