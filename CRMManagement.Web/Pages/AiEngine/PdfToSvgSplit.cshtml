    function _resetFamilyLocateUi(modeLabel) {
                        _familyScanModeLabel = modeLabel || 'Locate';
                        _familyScanDetections = [];
                        _familyScanAnnotatedPages = [];
                        _pendingDetectionApprovalChanges = {};
                    }

                    function _setFamilyLocateResults(modeLabel, rows, annotatedPages) {
                        const out = Array.isArray(rows) ? rows.slice() : [];
                        out.sort((a, b) => (a.pageIndex - b.pageIndex) || (b.confidence - a.confidence) || (a.y - b.y) || (a.x - b.x));
                        _familyScanModeLabel = modeLabel || 'Locate';
                        _pendingDetectionApprovalChanges = {};
                        _familyScanDetections = out;
                        _familyScanAnnotatedPages = Array.isArray(annotatedPages) ? annotatedPages : [];
                        try { _refreshAnnotatedDetectionsOverlay(); } catch { /* ignore */ }
                        if (_familyScanAnnotatedPages.length) {
                            const withDet = _familyScanAnnotatedPages.filter(p => p && p.detectionCount > 0);
                            _appendFamilyScanLog(`Annotated pages: ${_familyScanAnnotatedPages.length} total, ${withDet.length} with detections`);
                        }
                    }

                    function _normalizeLocateDetections(det, detectSource, pageDims) {
                        const arr = Array.isArray(det) ? det : [];
                        const dimsList = Array.isArray(pageDims) ? pageDims : [];
                        const dimsMap = new Map();
                        for (let i = 0; i < dimsList.length; i++) {
                            const pd = dimsList[i] || {};
                            const pi = (pd && isFinite(pd.pageIndex)) ? (pd.pageIndex | 0) : i;
                            if (pi < 0) continue;
                            if (!dimsMap.has(pi)) dimsMap.set(pi, pd);
                        }
                        return arr.map(d => {
                            const pageIndex = (d && isFinite(d.pageIndex)) ? (d.pageIndex | 0) : 0;
                            const sid = (d && isFinite(d.sampleId)) ? (d.sampleId | 0) : 0;
                            const href = (d && d.symbolHref != null) ? String(d.symbolHref) : '';
                            const thumb = (d && d.thumbDataUrl) ? String(d.thumbDataUrl) : '';
                            const conf = (d && isFinite(d.confidence)) ? Number(d.confidence) : 0;
                            const pd = dimsMap.get(pageIndex) || dimsList[pageIndex] || dimsList[0] || {};
                            const pageRawWidth = (d && isFinite(d.pageRawWidth)) ? Number(d.pageRawWidth)
                                : ((d && isFinite(d.rawWidth)) ? Number(d.rawWidth)
                                    : ((pd && isFinite(pd.rawWidth)) ? Number(pd.rawWidth) : 0));
                            const pageRawHeight = (d && isFinite(d.pageRawHeight)) ? Number(d.pageRawHeight)
                                : ((d && isFinite(d.rawHeight)) ? Number(d.rawHeight)
                                    : ((pd && isFinite(pd.rawHeight)) ? Number(pd.rawHeight) : 0));
                            const pagePixelWidth = (d && isFinite(d.pagePixelWidth)) ? Number(d.pagePixelWidth)
                                : ((d && isFinite(d.pixelWidth)) ? Number(d.pixelWidth)
                                    : ((pd && isFinite(pd.pixelWidth)) ? Number(pd.pixelWidth) : 0));
                            const pagePixelHeight = (d && isFinite(d.pagePixelHeight)) ? Number(d.pagePixelHeight)
                                : ((d && isFinite(d.pixelHeight)) ? Number(d.pixelHeight)
                                    : ((pd && isFinite(pd.pixelHeight)) ? Number(pd.pixelHeight) : 0));
                            const matchedMemoryId = (d && d.matchedMemoryId != null) ? String(d.matchedMemoryId).trim() : '';
                            const matchedMemoryDistance = (d && isFinite(d.matchedMemoryDistance)) ? (Number(d.matchedMemoryDistance) | 0) : null;
                            const coordSpace = (d && (d.coordSpace != null || d.coordsSpace != null || d.normalizedTo != null))
                                ? String(d.coordSpace ?? d.coordsSpace ?? d.normalizedTo).trim().toLowerCase()
                                : 'full-page';
                            const normalized = {
                                pageIndex,
                                x: (d && isFinite(d.x)) ? Number(d.x) : 0,
                                y: (d && isFinite(d.y)) ? Number(d.y) : 0,
                                w: (d && isFinite(d.w)) ? Number(d.w) : 0,
                                h: (d && isFinite(d.h)) ? Number(d.h) : 0,
                                thumbDataUrl: thumb,
                                confidence: conf,
                                coordSpace,
                                pageRawWidth,
                                pageRawHeight,
                                pagePixelWidth,
                                pagePixelHeight,
                                isManualAdd: false,
                                sampleId: sid,
                                detectTemplateSampleId: sid,
                                detectTemplateSymbolHref: href,
                                sampleIds: sid > 0 ? [sid] : [],
                                matchedMemoryId,
                                matchedMemoryDistance,
                                detectSource: detectSource || 'cv'
                            };
                            try {
                                if (pageIndex === 0 && (sid > 0 || arr.indexOf(d) === 0)) {
                                    _debugPdfSplitLog('[FamilyDetector][NormalizeDetection]', {
                                        detectSource: detectSource || 'cv',
                                        pageIndex,
                                        coordSpace,
                                        pageRawWidth,
                                        pageRawHeight,
                                        pagePixelWidth,
                                        pagePixelHeight,
                                        raw: { x: normalized.x, y: normalized.y, w: normalized.w, h: normalized.h }
                                    });
                                }
                            } catch { /* ignore */ }
                            return normalized;
                        });
                    }

                    function _appendLocateCropToFormData(fd, options) {
                        try {
                            const includeCrop = !!(options && options.includeCrop);
                            if (!includeCrop) {
                                if (outputCrop && outputCrop.frac && typeof outputCrop.frac === 'object') {
                                    _appendFamilyScanLog('Locate uses full-page scan (global CROP is ignored for locate).');
                                }
                                return;
                            }
                            if (!(outputCrop && outputCrop.frac && typeof outputCrop.frac === 'object')) return;
                            const fx = Number(outputCrop.frac.x);
                            const fy = Number(outputCrop.frac.y);
                            const fw = Number(outputCrop.frac.w);
                            const fh = Number(outputCrop.frac.h);
                            const pi = (outputCrop.pageIndex != null && isFinite(outputCrop.pageIndex)) ? (outputCrop.pageIndex | 0) : -1;
                            if (!(Number.isFinite(fx) && Number.isFinite(fy) && Number.isFinite(fw) && Number.isFinite(fh) && fw > 0.0005 && fh > 0.0005)) return;
                            const cropObj = { pageIndex: pi, x: fx, y: fy, w: fw, h: fh };
                            fd.append('cropJson', JSON.stringify(cropObj));
                            _appendFamilyScanLog(`CROP enabled for Locate: page=${(pi >= 0 ? (pi + 1) : 'all')} frac=(${fx.toFixed(4)},${fy.toFixed(4)},${fw.toFixed(4)},${fh.toFixed(4)})`);
                        } catch { /* ignore */ }
                    }

                    async function _buildFamilyLocateTemplates(samples) {
                        const templates = [];
                        const maxTemplates = 30;
                        for (const s of (Array.isArray(samples) ? samples : [])) {
                            const sid = (s && isFinite(s.id)) ? (s.id | 0) : 0;
                            if (sid <= 0) continue;
                            const href = (s && s.symbolHref != null) ? String(s.symbolHref).trim() : '';
                            let svgText = (s && s.sampleSvg != null) ? String(s.sampleSvg) : '';
                            let expectedWFrac = -1;
                            let expectedHFrac = -1;

                            try {
                                const cropJson = (s && s.cropFracJson) ? String(s.cropFracJson) : '';
                                if (cropJson) {
                                    const frac = JSON.parse(cropJson);
                                    const fw = Number(frac && frac.w);
                                    const fh = Number(frac && frac.h);
                                    if (Number.isFinite(fw) && fw > 0 && fw <= 1) expectedWFrac = fw;
                                    if (Number.isFinite(fh) && fh > 0 && fh <= 1) expectedHFrac = fh;
                                }
                            } catch { /* ignore */ }

                            if (!svgText) {
                                try {
                                    const cropJson = (s && s.cropFracJson) ? String(s.cropFracJson) : '';
                                    const pageIdx = (s && isFinite(s.pageIndex)) ? (s.pageIndex | 0) : 0;
                                    if (cropJson && pageResults && pageResults.length > 0) {
                                        const frac = JSON.parse(cropJson);
                                        const pr = pageResults.find(r => r && r.svgContent && ((r.pageNumber || 1) - 1) === pageIdx);
                                        if (pr && pr.svgContent) {
                                            const regen = cropSvgByFraction(pr.svgContent, frac);
                                            if (regen && regen.length > 100) svgText = regen;
                                        }
                                    }
                                } catch { /* ignore */ }
                            }

                            if (!svgText) continue;
                            try {
                                const pngDataUrl = await _buildTemplateImageDataUrl(svgText, 1536);
                                if (pngDataUrl && pngDataUrl.startsWith('data:image/')) {
                                    templates.push({ sampleId: sid, symbolHref: href, imageDataUrl: pngDataUrl, expectedWFrac, expectedHFrac });
                                }
                            } catch {
                                _appendFamilyScanLog(`Template render failed sid=${sid}`);
                            }
                            if (templates.length >= maxTemplates) break;
                        }
                        return templates;
                    }

                    function _logLocateResponseSummary(label, obj) {
                        const det = (obj && Array.isArray(obj.detections)) ? obj.detections : [];
                        const warns = (obj && Array.isArray(obj.warnings)) ? obj.warnings : [];
                        try {
                            const pd = (obj && Array.isArray(obj.pageDims) && obj.pageDims[0]) ? obj.pageDims[0] : null;
                            const pInfo = pd ? (` page0=${pd.pixelWidth || '?'}x${pd.pixelHeight || '?'} raw=${pd.rawWidth || '?'}x${pd.rawHeight || '?'}`) : '';
                            _appendFamilyScanLog(`${label}: ${det.length} detections, ${warns.length} warnings, mode=${obj && obj.mode ? obj.mode : '?'}, dpi=${obj && obj.dpi ? obj.dpi : '?'}, targetMaxDim=${obj && obj.targetMaxDim ? obj.targetMaxDim : '?'}${pInfo}`);
                        } catch {
                            _appendFamilyScanLog(`${label}: ${det.length} detections, ${warns.length} warnings`);
                        }
                        for (const w of warns.slice(0, 5)) {
                            _appendFamilyScanLog(`warning: ${String(w || '').substring(0, 280)}`);
                        }
                        try {
                            const dbg = (obj && Array.isArray(obj.debug)) ? obj.debug : [];
                            if (dbg.length) {
                                for (const line of dbg.slice(0, 18)) {
                                    _appendFamilyScanLog(`debug: ${String(line).substring(0, 320)}`);
                                }
                                if (dbg.length > 18) _appendFamilyScanLog(`debug: … (${dbg.length - 18} more)`);
                            }
                        } catch { /* ignore */ }
                    }

                    function _buildParallelAnnotatedPages(cvPages, yoloPages, rows) {
                        const pageMap = new Map();
                        const addPages = (pages) => {
                            for (const p of (Array.isArray(pages) ? pages : [])) {
                                const pi = (p && isFinite(p.pageIndex)) ? (p.pageIndex | 0) : -1;
                                if (pi < 0) continue;
                                const baseImg = (p && p.originalImageDataUrl) ? String(p.originalImageDataUrl) : ((p && p.imageDataUrl) ? String(p.imageDataUrl) : '');
                                if (!baseImg) continue;
                                if (!pageMap.has(pi)) pageMap.set(pi, baseImg);
                            }
                        };
                        addPages(cvPages);
                        addPages(yoloPages);
                        const counts = new Map();
                        for (const r of (Array.isArray(rows) ? rows : [])) {
                            const pi = (r && isFinite(r.pageIndex)) ? (r.pageIndex | 0) : -1;
                            if (pi < 0) continue;
                            counts.set(pi, (counts.get(pi) || 0) + 1);
                        }
                        return [...pageMap.entries()].sort((a, b) => a[0] - b[0]).map(([pageIndex, img]) => ({
                            pageIndex,
                            imageDataUrl: img,
                            originalImageDataUrl: img,
                            detectionCount: counts.get(pageIndex) || 0,
                            renderClientOverlays: true
                        }));
                    }

                    function _boxIou(a, b) {
                        try {
                            if (!a || !b || ((a.pageIndex | 0) !== (b.pageIndex | 0))) return 0;
                            const ax1 = Number(a.x) + Number(a.w);
                            const ay1 = Number(a.y) + Number(a.h);
                            const bx1 = Number(b.x) + Number(b.w);
                            const by1 = Number(b.y) + Number(b.h);
                            const ix = Math.max(0, Math.min(ax1, bx1) - Math.max(Number(a.x), Number(b.x)));
                            const iy = Math.max(0, Math.min(ay1, by1) - Math.max(Number(a.y), Number(b.y)));
                            const inter = ix * iy;
                            if (!(inter > 0)) return 0;
                            const areaA = Math.max(0, Number(a.w) * Number(a.h));
                            const areaB = Math.max(0, Number(b.w) * Number(b.h));
                            const denom = areaA + areaB - inter;
                            return denom > 0 ? (inter / denom) : 0;
                        } catch {
                            return 0;
                        }
                    }

                    function _mergeParallelDetections(cvRows, yoloRows) {
                        const merged = (Array.isArray(cvRows) ? cvRows : []).map(r => ({ ...r, sampleIds: Array.isArray(r.sampleIds) ? r.sampleIds.slice() : [] }));
                        for (const src of (Array.isArray(yoloRows) ? yoloRows : [])) {
                            if (!src) continue;
                            let bestIdx = -1;
                            let bestIou = 0;
                            for (let i = 0; i < merged.length; i++) {
                                const iou = _boxIou(src, merged[i]);
                                if (iou > bestIou) {
                                    bestIou = iou;
                                    bestIdx = i;
                                }
                            }
                            if (bestIdx >= 0 && bestIou >= 0.45) {
                                const cur = merged[bestIdx];
                                if ((Number(src.confidence) || 0) > (Number(cur.confidence) || 0)) {
                                    cur.x = src.x; cur.y = src.y; cur.w = src.w; cur.h = src.h;
                                    if (src.thumbDataUrl) cur.thumbDataUrl = src.thumbDataUrl;
                                }
                                cur.confidence = Math.max(Number(cur.confidence) || 0, Number(src.confidence) || 0);
                                cur.detectSource = 'cv+yolo';
                                const ids = new Set([...(Array.isArray(cur.sampleIds) ? cur.sampleIds : []), ...(Array.isArray(src.sampleIds) ? src.sampleIds : [])]);
                                cur.sampleIds = [...ids].filter(v => isFinite(v) && Number(v) > 0).map(v => Number(v) | 0);
                                if (!cur.detectTemplateSymbolHref && src.detectTemplateSymbolHref) cur.detectTemplateSymbolHref = src.detectTemplateSymbolHref;
                            } else {
                                merged.push({ ...src, sampleIds: Array.isArray(src.sampleIds) ? src.sampleIds.slice() : [] });
                            }
                        }
                        return merged;
                    }

                    async function _requestCvLocate(famId, file, options) {
                        const allowEmpty = !!(options && options.allowEmpty);
                        const view = await _fetchFamilySamplesForPanel(famId);
                        const samples = (view && Array.isArray(view.samples)) ? view.samples : [];
                        if (!samples.length) throw new Error('No saved objects for this family yet.');
                        _appendFamilyScanLog(`Building templates from ${samples.length} sample(s)…`);
                        const templates = await _buildFamilyLocateTemplates(samples);
                        if (!templates.length) throw new Error('Could not build template images for this family.');
                        _appendFamilyScanLog(`Templates ready: ${templates.length}. Sending ALL templates pngs for OpenCV matching.`);

                        const fd = new FormData();
                        fd.append('pdf', file, file.name || 'document.pdf');
                        fd.append('templatesJson', JSON.stringify({ templates }));
                        _appendLocateCropToFormData(fd, { includeCrop: false });

                        const userDpi = Math.max(72, Math.min(1200, getSelectedProcessingDpi()));
                        const qs = new URLSearchParams({ provider: 'ollama', mode: 'detect', dpi: String(userDpi), maxDetections: '500', debug: '1' });
                        const url = `${OBJECT_FAMILIES_ENDPOINT}/${famId}/scan-pdf?${qs.toString()}`;
                        _appendFamilyScanLog(`POST ${url} (templates=${templates.length})`);

                        const resp = await fetch(url, { method: 'POST', headers: { 'X-Client-Id': 'admin' }, body: fd });
                        const raw = await resp.text();
                        if (!resp.ok) throw new Error(`HTTP ${resp.status}: ${raw.substring(0, 600)}`);
                        let obj = null;
                        try { obj = raw ? JSON.parse(raw) : null; } catch { obj = null; }
                        if (!obj) throw new Error('Invalid response from server.');

                        _logLocateResponseSummary('CV detect response', obj);
                        const rows = _normalizeLocateDetections(obj && obj.detections, 'cv', obj && obj.pageDims);
                        if (!rows.length && !allowEmpty) throw new Error('No detections found by OpenCV template matching.');
                        return {
                            modeLabel: 'OpenCV Template Match',
                            rows,
                            annotatedPages: (obj && Array.isArray(obj.annotatedPages)) ? obj.annotatedPages : [],
                            raw: obj
                        };
                    }

                    async function _requestYoloLocate(famId, file, options) {
                        const allowEmpty = !!(options && options.allowEmpty);
                        const userDpi = Math.max(72, Math.min(1200, getSelectedProcessingDpi()));
                        const detectSettings = _getFamilyYoloDetectSettings();
                        const fd = new FormData();
                        fd.append('pdf', file, file.name || 'document.pdf');
                        fd.append('dpi', String(userDpi));
                        fd.append('conf', String(detectSettings.conf));
                        fd.append('iou', String(detectSettings.iou));
                        fd.append('imgsz', String(detectSettings.imgsz));
                        _appendLocateCropToFormData(fd, { includeCrop: true });

                        const url = `${OBJECT_FAMILIES_ENDPOINT}/${famId}/scan-pdf-yolo?dpi=${encodeURIComponent(String(userDpi))}&conf=${encodeURIComponent(String(detectSettings.conf))}&iou=${encodeURIComponent(String(detectSettings.iou))}&imgsz=${encodeURIComponent(String(detectSettings.imgsz))}`;
                        _appendFamilyScanLog(`POST ${url} (family YOLO conf=${detectSettings.conf.toFixed(2)} iou=${detectSettings.iou.toFixed(2)} imgsz=${detectSettings.imgsz})`);
                        const resp = await fetch(url, { method: 'POST', headers: { 'X-Client-Id': 'admin' }, body: fd });
                        const raw = await resp.text();
                        if (!resp.ok) throw new Error(`HTTP ${resp.status}: ${raw.substring(0, 600)}`);
                        let obj = null;
                        try { obj = raw ? JSON.parse(raw) : null; } catch { obj = null; }
                        if (!obj) throw new Error('Invalid response from server.');

                        _syncFamilyYoloDetectSettingsFromResponse(obj);
                        _logLocateResponseSummary('YOLO detect response', obj);
                        const rows = _normalizeLocateDetections(obj && obj.detections, 'yolo', obj && obj.pageDims);
                        if (!rows.length && !allowEmpty) throw new Error('No detections found by YOLO.');
                        return {
                            modeLabel: 'YOLO',
                            rows,
                            annotatedPages: (obj && Array.isArray(obj.annotatedPages)) ? obj.annotatedPages : [],
                            raw: obj
                        };
                    }

                    async function trainSelectedFamilyYolo() {
                        const famId = _getSelectedFamilyId();
                        if (!famId) { cgAlert('Pick a family first.'); return; }
                        const file = (pdfFileInput && pdfFileInput.files && pdfFileInput.files.length) ? pdfFileInput.files[0] : null;
                        if (!file) { cgAlert('Pick a PDF first.'); return; }
                        const approvedRows = _getApprovedFamilyScanDetections();
                        const rejectedRows = _getRejectedFamilyScanDetections();
                        const trainReadiness = _getFamilyYoloTrainingReadiness();
                        const datasetSummary = trainReadiness.datasetSummary;
                        if (!trainReadiness.canTrain) {
                            cgAlert('No green/yellow detection changes or persisted positive YOLO memory to train from. Mark detections as green/yellow or save positive memory first.');
                            return;
                        }
                        const warningText = [
                            'Start YOLO training?',
                            '',
                            `Green additions: ${approvedRows.length}`,
                            `Yellow cancellations: ${rejectedRows.length}`,
                            `Neutral detections (ignored): ${datasetSummary.neutralDetectionCount || 0}`,
                            `Persisted memory positives: ${trainReadiness.memoryPositiveCount || 0}`,
                            `Persisted memory negatives: ${trainReadiness.memoryNegativeCount || 0}`,
                            '',
                            trainReadiness.hasCurrentDetections
                                ? 'Current green/yellow changes will be merged with persisted YOLO memory for training.'
                                : 'No current green/yellow changes are selected. Training will reuse persisted YOLO memory only.',
                            'Neutral detections stay unchanged and are not re-learned.'
                        ].join('\n');
                        if (!await cgConfirm(warningText)) return;

                        try {
                            _yoloTrainBusy = true;
                            _resetFamilyYoloMirroredLogs(famId);
                            if (_lastFamilyLearnModel) _renderFamilyLearnPanel(_lastFamilyLearnModel);
                            const payload = _buildYoloTrainingPayload();
                            const fd = new FormData();
                            fd.append('pdf', file, file.name || 'document.pdf');
                            fd.append('detectionsJson', JSON.stringify(payload));
                            fd.append('familyName', _getSelectedFamilyName());
                            fd.append('dpi', String(getSelectedProcessingDpi()));
                            _appendLocateCropToFormData(fd, { includeCrop: true });

                            _appendFamilyScanLog(`YOLO train start: ${approvedRows.length} green addition(s), ${rejectedRows.length} yellow cancellation(s), memory +${trainReadiness.memoryPositiveCount} / -${trainReadiness.memoryNegativeCount}`);
                            const resp = await fetch(`${OBJECT_FAMILIES_ENDPOINT}/${famId}/train-yolo`, {
                                method: 'POST',
                                headers: { 'X-Client-Id': 'admin' },
                                body: fd
                            });
                            const raw = await resp.text();
                            if (!resp.ok) throw new Error(`HTTP ${resp.status}: ${raw.substring(0, 500)}`);
                            let obj = null;
                            try { obj = raw ? JSON.parse(raw) : null; } catch { obj = null; }
                            _familyYoloStatus = obj && obj.status ? obj.status : _familyYoloStatus;
                            _appendFamilyScanLog('YOLO training queued. Polling status…');
                            _queueFamilyYoloStatusPoll(1200);
                            try { if (_lastFamilyLearnModel) _renderFamilyLearnPanel(_lastFamilyLearnModel); } catch { /* ignore */ }
                        } catch (e) {
                            _appendFamilyScanLog(`YOLO train failed: ${String(e)}`);
                            cgAlert(`YOLO train failed: ${String(e)}`);
                        } finally {
                            _yoloTrainBusy = false;
                            if (_lastFamilyLearnModel) _renderFamilyLearnPanel(_lastFamilyLearnModel);
                        }
                    }

