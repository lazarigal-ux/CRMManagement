                    : (active ? SPLIT_TAB_BTN_ACTIVE_CLASS : SPLIT_TAB_BTN_INACTIVE_CLASS);
                if (isMergedSvgBtn && !_pdfPreSplitMergedSvg && !(_requestedSplitMainTab === 'mergedSvg' || _mergedSvgOnlyMode)) btn.classList.add('hidden');
                if (active) {
                    try { btn.scrollIntoView({ block: 'nearest', inline: 'nearest', behavior: 'smooth' }); } catch { /* ignore */ }
