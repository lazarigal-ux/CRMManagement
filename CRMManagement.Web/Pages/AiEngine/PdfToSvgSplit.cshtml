    function _isSvgAiCandidateAutoScanAllowed(r) {
        const objectCount = Math.max(0, Number(r && r.objectCount) || 0);
        const svgBytes = Math.max(0, Number(r && r.svgSizeBytes) || 0);
        return objectCount <= _svgAiCandidateAutoScanMaxObjects && svgBytes <= _svgAiCandidateAutoScanMaxBytes;
    }

    function _updateSvgAiCandidateCountUi(count) {
        if (!svgAiCandidateCount || !svgAiCandidateCountValue) return;
        const idx = Number(_svgPreviewActiveResultIdx);
        const r = Number.isFinite(idx) && idx >= 0 && idx < pageResults.length ? pageResults[idx] : null;
        const isEligible = !!r && _isOtherElementsLayerResult(r);
        const autoAllowed = isEligible ? _isSvgAiCandidateAutoScanAllowed(r) : false;
        const isScanning = count === '…';
        const safeCount = isScanning ? '…' : Math.max(0, Number(count) || 0);
        svgAiCandidateCount.classList.toggle('hidden', !isEligible);
        if (svgAiCandidateCountLabel) svgAiCandidateCountLabel.textContent = 'marked';
        if (isEligible && !autoAllowed) {
            if (_svgAiCandidateEstimateBusy) {
                svgAiCandidateCountValue.textContent = '…';
                if (svgAiCandidateCountLabel) svgAiCandidateCountLabel.textContent = 'estimating';
            } else if (Number.isFinite(_svgAiCandidateEstimatedCount)) {
                svgAiCandidateCountValue.textContent = `~${formatInt(Math.max(0, Number(_svgAiCandidateEstimatedCount) || 0))}`;
                if (svgAiCandidateCountLabel) svgAiCandidateCountLabel.textContent = 'estimated';
            } else {
                svgAiCandidateCountValue.textContent = 'OFF';
            }
        } else {
            svgAiCandidateCountValue.textContent = String(safeCount);
        }
        svgAiCandidateCount.title = isScanning
            ? 'Scanning objects inside the selected area…'
            : isEligible && !autoAllowed && _svgAiCandidateEstimateBusy
            ? 'Client-side marking is disabled for this huge OTHER ELEMENTS layer. Estimating intersecting objects on the server for the selected area…'
            : isEligible && !autoAllowed && Number.isFinite(_svgAiCandidateEstimatedCount)
            ? `Client-side blue marking is disabled for this huge OTHER ELEMENTS layer. Estimated intersecting objects in the selected area: ${formatInt(Math.max(0, Number(_svgAiCandidateEstimatedCount) || 0))}.`
