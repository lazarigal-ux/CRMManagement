    async function deleteFamilySample(sampleId) {
        const famId = _getSelectedFamilyId();
        if (!famId) { cgAlert('Pick a family first.'); return; }
        const sid = parseInt(String(sampleId || ''), 10);
        if (!Number.isFinite(sid) || sid <= 0) return;
        if (!await cgConfirm('Delete this sample from the family?')) return;
        try {
            const resp = await fetch(`${OBJECT_FAMILIES_ENDPOINT}/${famId}/samples/${sid}`, {
                method: 'DELETE',
                headers: { 'X-Client-Id': 'admin' }
            });
            if (!resp.ok) {
                const t = await resp.text();
                cgAlert(`Delete failed: HTTP ${resp.status}: ${t.substring(0, 600)}`);
                return;
            }
            try {
                const obj = await resp.json();
                const del = (obj && isFinite(obj.deleted)) ? (obj.deleted | 0) : null;
                if (del === 0) cgAlert('Nothing was deleted (already removed).');
            } catch { /* ignore */ }
            await loadObjectFamilies(true);
            try { if (familySelect) familySelect.value = String(famId); } catch { /* ignore */ }
            await viewSelectedFamily();
        } catch (e) {
            cgAlert(`Delete failed: ${String(e)}`);
        }
    }

    async function deleteFamilyObject(symbolHref) {
        const famId = _getSelectedFamilyId();
        if (!famId) { cgAlert('Pick a family first.'); return; }
        const href = (symbolHref || '').toString().trim();
        if (!href) return;
        if (!await cgConfirm(`Delete object from family?\n${href}`)) return;
        try {
            const url = `${OBJECT_FAMILIES_ENDPOINT}/${famId}/samples?symbolHref=${encodeURIComponent(href)}`;
            const resp = await fetch(url, { method: 'DELETE', headers: { 'X-Client-Id': 'admin' } });
            if (!resp.ok) {
                const t = await resp.text();
                cgAlert(`Delete failed: HTTP ${resp.status}: ${t.substring(0, 600)}`);
                return;
            }
            try {
                const obj = await resp.json();
                const del = (obj && isFinite(obj.deleted)) ? (obj.deleted | 0) : null;
                if (del === 0) cgAlert('Nothing was deleted (no matching samples for this symbol).');
            } catch { /* ignore */ }
            await loadObjectFamilies(true);
            try { if (familySelect) familySelect.value = String(famId); } catch { /* ignore */ }
            await viewSelectedFamily();
        } catch (e) {
            cgAlert(`Delete failed: ${String(e)}`);
        }
    }

