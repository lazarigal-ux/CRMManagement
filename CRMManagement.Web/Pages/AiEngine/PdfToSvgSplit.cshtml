            }

            return new XMLSerializer().serializeToString(svg);
        } catch {
            return src;
        }
    }

    function _isTextLabelsLayerResult(r) {
        if (!r) return false;
        const icon = (r.icon || r.layerIcon || '').toString().trim().toLowerCase();
        const name = (r.layerName || '').toString().trim().toLowerCase();
        return icon === 'fa-font' || name.includes('text / labels');
    }

    function _isPdfBboxTextLayerResult(r) {
        const name = (r && r.layerName ? r.layerName : '').toString().trim().toLowerCase();
        return name.includes('text / labels (pdf bbox)');
    }

    function _isOtherElementsLayerResult(r) {
        const name = (r && r.layerName ? r.layerName : '').toString().trim().toLowerCase();
        return !!name && name.includes('other elements') && !r?.movedFromOtherElements;
    }

    function _fitFamilyDetectorSvgToImages(svgText, sourceMetrics, contentBounds) {
        const src = String(svgText || '');
        if (!src || !src.includes('<svg')) return src;
        try {
            const parser = new DOMParser();
            const doc = parser.parseFromString(src, 'image/svg+xml');
            const svg = doc.querySelector('svg');
            if (!svg) return src;

            const currentView = _parseViewBoxStr(svg.getAttribute('viewBox') || '');
            const currentW = String(svg.getAttribute('width') || '').trim();
            const currentH = String(svg.getAttribute('height') || '').trim();
            const sourceView = _parseViewBoxStr(sourceMetrics && sourceMetrics.vb);
            const sourceW = String(sourceMetrics && sourceMetrics.w || '').trim();
            const sourceH = String(sourceMetrics && sourceMetrics.h || '').trim();

            _debugPdfSplitLog('[FitFamily][input]', {
                currentViewBox: currentView ? `${currentView.x} ${currentView.y} ${currentView.w} ${currentView.h}` : '(none)',
                sourceViewBox: sourceView ? `${sourceView.x} ${sourceView.y} ${sourceView.w} ${sourceView.h}` : '(none)',
                contentBounds,
                currentW, currentH, sourceW, sourceH
            });

            if (!currentView) {
                if (sourceView) {
                    svg.setAttribute('viewBox', `${sourceView.x} ${sourceView.y} ${sourceView.w} ${sourceView.h}`);
                    if (!currentW && sourceW) svg.setAttribute('width', sourceW);
                    if (!currentH && sourceH) svg.setAttribute('height', sourceH);
                }
            }

            const baseVb = (sourceMetrics && sourceMetrics.vb) || (currentView ? `${currentView.x} ${currentView.y} ${currentView.w} ${currentView.h}` : '');
            const baseW = sourceW || currentW || '';
            const baseH = sourceH || currentH || '';
            const previewViewport = _computeFamilyLayerViewport(baseVb, baseW, baseH, contentBounds);

            _debugPdfSplitLog('[FitFamily][viewport]', {
                baseVb,
                previewViewportVb: previewViewport && previewViewport.vb,
                previewViewportW: previewViewport && previewViewport.w,
                previewViewportH: previewViewport && previewViewport.h
            });

            if (previewViewport && previewViewport.vb) {
                svg.setAttribute('viewBox', previewViewport.vb);
                if (previewViewport.w) svg.setAttribute('width', previewViewport.w);
                if (previewViewport.h) svg.setAttribute('height', previewViewport.h);
            }

            const images = [...svg.querySelectorAll('image')].filter(im => { try { return !im.closest('defs'); } catch { return true; } });
            // If no <image> elements (marker-based family layer), return with corrected viewBox
            _debugPdfSplitLog('[FitFamily][images]', { imageCount: images.length });
            if (!images.length) return new XMLSerializer().serializeToString(svg);
            for (const im of images) {
                try { im.setAttribute('preserveAspectRatio', 'xMidYMid meet'); } catch { /* ignore */ }
            }

            const rootView = _parseViewBoxStr(svg.getAttribute('viewBox') || '') || (() => {
                const rw = parseFloat(svg.getAttribute('width') || '0');
                const rh = parseFloat(svg.getAttribute('height') || '0');
                return (Number.isFinite(rw) && Number.isFinite(rh) && rw > 0 && rh > 0)
                    ? { x: 0, y: 0, w: rw, h: rh }
                    : null;
            })();

            const rects = [];
            let normalizedCount = 0;
            for (const im of images) {
                const x = parseFloat(im.getAttribute('x') || '0');
                const y = parseFloat(im.getAttribute('y') || '0');
                const w = parseFloat(im.getAttribute('width') || '0');
                const h = parseFloat(im.getAttribute('height') || '0');
                if (!(Number.isFinite(x) && Number.isFinite(y) && Number.isFinite(w) && Number.isFinite(h) && w > 0 && h > 0)) continue;
                rects.push({ im, x, y, w, h });
                if (x <= 1.000001 && y <= 1.000001 && w <= 1.000001 && h <= 1.000001) normalizedCount++;
            }
            if (!rects.length) return src;

            if (rootView && normalizedCount === rects.length) {
                for (const rect of rects) {
                    const absX = rootView.x + (rect.x * rootView.w);
                    const absY = rootView.y + (rect.y * rootView.h);
                    const absW = rect.w * rootView.w;
                    const absH = rect.h * rootView.h;
                    rect.im.setAttribute('x', absX.toFixed(6));
                    rect.im.setAttribute('y', absY.toFixed(6));
                    rect.im.setAttribute('width', absW.toFixed(6));
                    rect.im.setAttribute('height', absH.toFixed(6));
                    rect.x = absX;
                    rect.y = absY;
                    rect.w = absW;
                    rect.h = absH;
                }
            }

            let minX = Infinity;
            let minY = Infinity;
            let maxX = -Infinity;
            let maxY = -Infinity;
            for (const { x, y, w, h } of rects) {
                minX = Math.min(minX, x);
                minY = Math.min(minY, y);
                maxX = Math.max(maxX, x + w);
                maxY = Math.max(maxY, y + h);
            }
            if (!(Number.isFinite(minX) && Number.isFinite(minY) && Number.isFinite(maxX) && Number.isFinite(maxY) && maxX > minX && maxY > minY)) return src;

            return new XMLSerializer().serializeToString(svg);
        } catch {
            return src;
        }
    }

    function _deriveFullPageMetricsFromCrop(metrics, cropFrac) {
        try {
            const cf = cropFrac;
            if (!(cf && Number.isFinite(cf.x) && Number.isFinite(cf.y) && Number.isFinite(cf.w) && Number.isFinite(cf.h) && cf.w > 0 && cf.h > 0)) return null;
            const view = _parseViewBoxStr(metrics && metrics.vb);
            if (!view || !(view.w > 0) || !(view.h > 0)) return null;

            const fullW = view.w / cf.w;
            const fullH = view.h / cf.h;
            if (!(Number.isFinite(fullW) && Number.isFinite(fullH) && fullW > 0 && fullH > 0)) return null;

            const fullX = view.x - (cf.x * fullW);
            const fullY = view.y - (cf.y * fullH);
            const normX = Math.abs(fullX) < 0.000001 ? 0 : fullX;
            const normY = Math.abs(fullY) < 0.000001 ? 0 : fullY;

            return {
                vb: `${normX} ${normY} ${fullW} ${fullH}`,
                w: String(fullW),
                h: String(fullH),
                defsHtml: String(metrics && metrics.defsHtml || ''),
                derivedFromCrop: true
            };
        } catch {
            return null;
        }
    }

    function _resolveFamilyDetectorMapMetrics(src, cropFrac) {
        try {
            const hasCf = cropFrac && Number.isFinite(cropFrac.x) && Number.isFinite(cropFrac.y)
                && Number.isFinite(cropFrac.w) && Number.isFinite(cropFrac.h)
                && cropFrac.w > 0 && cropFrac.h > 0;

            // 1. If sourceSvgMetrics exists, it was captured BEFORE crop (pre-crop / full-page).
            //    Trust it directly — it's the correct full-page reference.
            if (src && src.sourceSvgMetrics && typeof src.sourceSvgMetrics === 'object') {
                const direct = {
                    vb: String(src.sourceSvgMetrics.vb || ''),
                    w: String(src.sourceSvgMetrics.w || ''),
                    h: String(src.sourceSvgMetrics.h || ''),
                    defsHtml: String(src.sourceSvgMetrics.defsHtml || '')
                };
                if (direct.vb || direct.w || direct.h) {
                    _debugPdfSplitLog('[FamilyDetector][Metrics:source]', { path: 'sourceSvgMetrics-trusted', vb: direct.vb, hasCrop: !!hasCf });
                    return direct;
                }
            }

            // 2. Parse current SVG content viewBox
            const current = src && src.svgContent ? _getSvgRootMetrics(src.svgContent) : null;

            // 3. If crop is active and sourceSvgMetrics is absent, the SVG content viewBox may be
            //    cropped (vector pipeline) or already full-page (raster pipeline after restoreCroppedSvgToPageSpace).
            //    Heuristic: a full-page viewBox typically starts near origin (x ≈ 0, y ≈ 0).
            //    A cropped viewBox has a large positive origin offset relative to its dimensions.
            if (hasCf && current) {
                const curView = _parseViewBoxStr(current.vb);
                if (curView && curView.w > 0 && curView.h > 0) {
                    // A cropped viewBox has origin shifted by (cropFrac.x * fullW, cropFrac.y * fullH).
                    // If origin is near zero, it's likely already full-page.
                    // If origin >> 0 relative to dimensions, it's likely cropped.
                    const originOffsetRatioX = (curView.w > 0) ? Math.abs(curView.x) / curView.w : 0;
                    const originOffsetRatioY = (curView.h > 0) ? Math.abs(curView.y) / curView.h : 0;
                    // For a crop like frac=(0.23,0.56,0.45,0.32), the cropped viewBox origin would be
                    // at ~(0.23*fullW, 0.56*fullH) ≈ (0.51*cropW, 1.75*cropH) — significant offsets.
                    // A full-page viewBox might start at (0,0) or small offsets.
                    const looksFullPage = (originOffsetRatioX < 0.05 && originOffsetRatioY < 0.05);
                    if (!looksFullPage) {
                        // SVG content is cropped — derive full-page from it
                        const derived = _deriveFullPageMetricsFromCrop(current, cropFrac);
                        if (derived) {
                            _debugPdfSplitLog('[FamilyDetector][Metrics:derived]', {
                                path: 'derived-from-cropped-svg',
                                croppedVb: current.vb,
                                originOffsetRatioX: originOffsetRatioX.toFixed(3),
                                originOffsetRatioY: originOffsetRatioY.toFixed(3),
                                fullVb: derived.vb
                            });
                            return derived;
                        }
                    } else {
                        // SVG is already full-page (e.g. restoreCroppedSvgToPageSpace was applied, or raster pipeline)
                        _debugPdfSplitLog('[FamilyDetector][Metrics:full-page-svg]', {
                            path: 'svg-already-full-page',
                            vb: current.vb,
                            originOffsetRatioX: originOffsetRatioX.toFixed(3),
                            originOffsetRatioY: originOffsetRatioY.toFixed(3)
                        });
                        return current;
                    }
                }
            }

            _debugPdfSplitLog('[FamilyDetector][Metrics:fallback]', { path: 'current-svg', vb: current && current.vb });
            return current;
        } catch {
            return null;
        }
    }

    function _getFamilyDetectorSourceMetrics(r) {
        try {
            if (!r || !r.isFamilyDetectorLayer) return null;
            const pageIndexes = Array.isArray(r.sourcePageIndexes)
                ? r.sourcePageIndexes.map(v => Number(v) | 0).filter(v => Number.isFinite(v) && v >= 0)
                : [];
            const pi = pageIndexes.length === 1
                ? pageIndexes[0]
                : ((Number.isFinite(Number(r.pageNumber)) && Number(r.pageNumber) > 0) ? ((Number(r.pageNumber) | 0) - 1) : null);
            if (!(pi >= 0)) return null;
            const src = _getSvgSplitSourceResultForDetection(pi);
            if (!src) return null;
            return _resolveFamilyDetectorMapMetrics(src, outputCrop && outputCrop.frac ? outputCrop.frac : null);
        } catch {
            return null;
        }
    }

    async function _getSvgContentForPreviewDisplayAsync(r) {
        const svgText = (r && r.svgContent) ? String(r.svgContent) : '';
        if (r && r.isFamilyDetectorLayer) return _fitFamilyDetectorSvgToImages(svgText, _getFamilyDetectorSourceMetrics(r), r.familyContentBounds || null);
        if (!svgText || !_isTextLabelsLayerResult(r)) return svgText;
        // When merge-before-split is enabled, skip text label filtering entirely
        if (_pdfPreSplitMergeEnabled) return svgText;

        if (_isPdfBboxTextLayerResult(r) && Array.isArray(pdfExtractWords) && pdfExtractWords.length > 0) {
            try {
                const parser = new DOMParser();
                const doc = parser.parseFromString(svgText, 'image/svg+xml');
                const svg = doc.querySelector('svg');
                if (svg) {
                    const vb = svg.getAttribute('viewBox') || '';
                    const w = svg.getAttribute('width') || '';
                    const h = svg.getAttribute('height') || '';
                    const rebuilt = await buildPdfBboxTextLayerSvg(pdfExtractWords, pdfExtractWordsMeta || {}, vb, w, h);
                    if (rebuilt) return rebuilt;
                }
            } catch { /* ignore */ }
        }

        return _removeIgnoredTextLabelsFromSvg(svgText);
    }

    function _getSvgContentForPreviewDisplay(r) {
        const svgText = (r && r.svgContent) ? String(r.svgContent) : '';
        if (!svgText || !_isTextLabelsLayerResult(r)) return svgText;
        // When merge-before-split is enabled, skip text label filtering entirely
        if (_pdfPreSplitMergeEnabled) return svgText;
        return _removeIgnoredTextLabelsFromSvg(svgText);
    }

    async function _refreshActiveSvgPreviewForHiddenTextLabels() {
        try {
            const modal = document.getElementById('svgPreviewModal');
            if (!modal || modal.classList.contains('hidden')) return;
            const idx = Number(_svgPreviewActiveResultIdx);
            if (!Number.isFinite(idx) || idx < 0 || idx >= pageResults.length) return;
            const r = pageResults[idx];
            if (!_isTextLabelsLayerResult(r)) return;
            const body = document.getElementById('svgPreviewBody');
            if (!body) return;
            const prevLeft = body.scrollLeft;
            const prevTop = body.scrollTop;
            const svgMarkup = await _getSvgContentForPreviewDisplayAsync(r);
            body.innerHTML = `<div id="svgPreviewScale" style="display:inline-block;">${svgMarkup}</div>`;
            const svg = body.querySelector('#svgPreviewScale svg');
            if (svg) {
                svg._origViewBoxStr = svg.getAttribute('viewBox');
                const origVB = svg.viewBox && svg.viewBox.baseVal
                    ? { x: svg.viewBox.baseVal.x, y: svg.viewBox.baseVal.y, w: svg.viewBox.baseVal.width, h: svg.viewBox.baseVal.height }
                    : null;
                const origW = parseFloat(svg.getAttribute('width')) || (origVB ? origVB.w : 0);
                const origH = parseFloat(svg.getAttribute('height')) || (origVB ? origVB.h : 0);
                svg._origPageRect = {
                    x: origVB ? origVB.x : 0,
                    y: origVB ? origVB.y : 0,
                    w: origW,
                    h: origH
                };
                if ((!origVB || !origVB.w || !origVB.h) && svg._origPageRect.w > 0 && svg._origPageRect.h > 0)
                    svg.setAttribute('viewBox', `${svg._origPageRect.x} ${svg._origPageRect.y} ${svg._origPageRect.w} ${svg._origPageRect.h}`);
                svg.removeAttribute('width');
                svg.removeAttribute('height');
            }
            body.scrollLeft = prevLeft;
            body.scrollTop = prevTop;
            try { _renderSvgPreviewCropOverlay(); } catch { /* ignore */ }
        } catch { /* ignore */ }
    }

    function _renderPdfTextHiddenLabelsUi() {
        const set = _getHiddenTextLabelSet();
        const selectedLanguages = _getSelectedPdfTextLanguages();
        if (pdfTextHiddenLabelsInput && pdfTextHiddenLabelsInput.value !== String(_pdfTextHiddenLabelsRaw || ''))
            pdfTextHiddenLabelsInput.value = String(_pdfTextHiddenLabelsRaw || '');
        if (pdfTextLangEnglish) pdfTextLangEnglish.checked = selectedLanguages.has('english');
        if (pdfTextLangHebrew) pdfTextLangHebrew.checked = selectedLanguages.has('hebrew');
        if (pdfTextLangArabic) pdfTextLangArabic.checked = selectedLanguages.has('arabic');
        if (pdfTextHiddenLabelsSummary)
            pdfTextHiddenLabelsSummary.textContent = set.size > 0
                ? `${set.size} hidden exact label(s)`
                : 'No hidden labels';
        if (pdfTextLanguageSummary) {
            const labels = _pdfTextLanguageOrder.filter(x => selectedLanguages.has(x)).map(x => _pdfTextLanguageLabels[x]);
            pdfTextLanguageSummary.textContent = labels.length === _pdfTextLanguageOrder.length
                ? 'All selected'
                : (labels.length ? labels.join(', ') : 'No languages selected');
        }
    }

    function fmtNum(n) {
        const x = Number(n);
        if (!isFinite(x)) return '—';
        return (Math.round(x * 100) / 100).toString();
    }

    function fmtPct(n) {
        const x = Number(n);
        if (!isFinite(x)) return '—';
        return `${Math.round(x)}%`;
    }

    function fmtMb(n) {
        const x = Number(n);
        if (!isFinite(x)) return '—';
        return `${Math.round(x)} MB`;
    }

    function escapeHtml(s) {
        return String(s)
            .replaceAll('&', '&amp;')
            .replaceAll('<', '&lt;')
            .replaceAll('>', '&gt;')
            .replaceAll('"', '&quot;')
            .replaceAll("'", '&#39;');
    }

    function setPdfLoadingOverlay(active, message) {
        if (pdfLoadingOverlayText && typeof message === 'string' && message.trim()) {
            pdfLoadingOverlayText.textContent = message.trim();
        }
        if (pdfLoadingOverlay) pdfLoadingOverlay.classList.toggle('hidden', !active);
        if (pdfFileInput) pdfFileInput.disabled = !!active;
    }

    function setUsageBar(el, value) {
        if (!el) return;
        const pct = Number(value);
        el.style.width = `${Math.max(0, Math.min(100, isFinite(pct) ? pct : 0))}%`;
    }

    function renderResourceUsage(data) {
        const cpuSystem = Number(data?.cpu?.systemPercent);
        const cpuProcess = Number(data?.cpu?.processPercent);
        const ramSystem = Number(data?.ram?.systemPercent);
        const ramUsedMb = Number(data?.ram?.usedMb);
        const ramTotalMb = Number(data?.ram?.totalMb);
        const ramProcessMb = Number(data?.ram?.processRssMb);
        const gpuAvailable = !!data?.gpu?.available;
        const gpuUtil = Number(data?.gpu?.utilizationPercent);
        const gpuMemUtil = Number(data?.gpu?.memoryUtilizationPercent);
        const gpuMemUsedMb = Number(data?.gpu?.memoryUsedMb);
        const gpuMemTotalMb = Number(data?.gpu?.memoryTotalMb);
        const gpuTemp = Number(data?.gpu?.temperatureC);
        const gpuName = data?.gpu?.name ? String(data.gpu.name) : '';
        const gpuWorkers = Number(data?.gpu?.workerCount);

        if (resourceUsageUpdated) {
            const stamp = data?.timestampUtc ? new Date(data.timestampUtc) : null;
            resourceUsageUpdated.textContent = stamp && !isNaN(stamp.getTime())
                ? `Updated ${stamp.toLocaleTimeString()}`
                : 'Updated now';
        }

        if (resourceCpuValue) resourceCpuValue.textContent = fmtPct(cpuSystem);
        if (resourceCpuMeta) resourceCpuMeta.textContent = `system ${fmtPct(cpuSystem)} • app ${fmtPct(cpuProcess)} • ${data?.cpu?.cores ?? '—'} core(s)`;
        setUsageBar(resourceCpuBar, cpuSystem);

        if (resourceRamValue) resourceRamValue.textContent = fmtPct(ramSystem);
        if (resourceRamMeta) {
            const sysText = isFinite(ramUsedMb) && isFinite(ramTotalMb) ? `${fmtMb(ramUsedMb)} / ${fmtMb(ramTotalMb)}` : 'system —';
            resourceRamMeta.textContent = `${sysText} • app RSS ${fmtMb(ramProcessMb)}`;
        }
        setUsageBar(resourceRamBar, ramSystem);

        if (gpuAvailable) {
            if (resourceGpuValue) resourceGpuValue.textContent = fmtPct(gpuUtil);
            if (resourceGpuWorkers) resourceGpuWorkers.textContent = `workers ${isFinite(gpuWorkers) ? Math.max(0, Math.round(gpuWorkers)) : '—'}`;
            if (resourceGpuMeta) {
                const memText = isFinite(gpuMemUsedMb) && isFinite(gpuMemTotalMb)
                    ? `${fmtMb(gpuMemUsedMb)} / ${fmtMb(gpuMemTotalMb)}`
                    : 'VRAM —';
                const tempText = isFinite(gpuTemp) ? ` • ${Math.round(gpuTemp)}°C` : '';
                const workerText = isFinite(gpuWorkers) ? ` • workers ${Math.max(0, Math.round(gpuWorkers))}` : '';
                resourceGpuMeta.textContent = `${gpuName || 'GPU'} • ${memText} (${fmtPct(gpuMemUtil)})${tempText}${workerText}`;
            }
            setUsageBar(resourceGpuBar, gpuUtil);
        } else {
            if (resourceGpuValue) resourceGpuValue.textContent = '—';
            if (resourceGpuWorkers) resourceGpuWorkers.textContent = 'workers —';
            if (resourceGpuMeta) resourceGpuMeta.textContent = data?.gpu?.error ? String(data.gpu.error) : 'GPU metrics unavailable';
            setUsageBar(resourceGpuBar, 0);
        }
    }

    async function refreshResourceUsage() {
        if (_resourceUsageLoading) return;
        _resourceUsageLoading = true;
        try {
            const resp = await fetch(`${RESOURCE_USAGE_ENDPOINT}?t=${Date.now()}`, {
                headers: { 'X-Client-Id': 'admin' },
                cache: 'no-store'
            });
            if (!resp.ok) throw new Error(`HTTP ${resp.status}`);
            const data = await resp.json();
            renderResourceUsage(data || {});
        } catch (err) {
            if (resourceUsageUpdated) resourceUsageUpdated.textContent = 'Metrics unavailable';
            if (resourceCpuMeta) resourceCpuMeta.textContent = String(err);
            if (resourceGpuMeta) resourceGpuMeta.textContent = 'GPU metrics unavailable';
            if (resourceRamMeta) resourceRamMeta.textContent = 'RAM metrics unavailable';
        } finally {
            _resourceUsageLoading = false;
        }
    }

    function startResourceUsagePolling() {
        if (_resourceUsageTimer) clearInterval(_resourceUsageTimer);
        refreshResourceUsage();
        _resourceUsageTimer = setInterval(() => {
            if (document.hidden) return;
            refreshResourceUsage();
        }, 2000);
    }

    function renderPdfTextPanel() {
        if (!pdfTextPanelBody || !pdfTextPanelSummary) return;
        const meta = pdfExtractWordsMeta || {};
        const allWords = (pdfExtractWords && Array.isArray(pdfExtractWords)) ? pdfExtractWords : [];
        const words = _getVisiblePdfExtractWords(allWords);
        const hiddenCount = Math.max(0, allWords.length - words.length);
        const page = meta.page || 1;
        const wPt = (meta.pageWidthPt != null) ? meta.pageWidthPt : null;
        const hPt = (meta.pageHeightPt != null) ? meta.pageHeightPt : null;
        pdfTextPanelSummary.textContent = `P${page} • ${words.length} word(s)`
            + (hiddenCount > 0 ? ` • hidden ${hiddenCount}` : '')
            + ((wPt && hPt) ? ` • ${wPt}×${hPt} pt` : '');

        if (!words.length) {
            pdfTextPanelBody.innerHTML = '<div class="p-3 text-xs text-slate-400">No extracted text items after label/language filtering.</div>';
            return;
        }

        const maxRender = 50000;
        const rows = [];
        const count = Math.min(words.length, maxRender);
        for (let i = 0; i < count; i++) {
            const it = words[i] || {};
            const t = (it.text == null) ? '' : String(it.text);
            rows.push(
                `<tr class="border-b border-slate-800/60">
                    <td class="px-3 py-2 align-top text-slate-200" dir="auto" style="unicode-bidi: plaintext;">${escapeHtml(t)}</td>
                    <td class="px-3 py-2 align-top text-slate-400 whitespace-nowrap">${fmtNum(it.xMin)}, ${fmtNum(it.yMin)}</td>
                    <td class="px-3 py-2 align-top text-slate-400 whitespace-nowrap">${fmtNum(it.xMax)}, ${fmtNum(it.yMax)}</td>
                </tr>`
            );
        }

        pdfTextPanelBody.innerHTML = `
            <table class="w-full text-xs">
                <thead class="sticky top-0 bg-slate-950 border-b border-slate-800">
                    <tr>
                        <th class="px-3 py-2 text-left text-slate-400 font-semibold">Text</th>
                        <th class="px-3 py-2 text-left text-slate-400 font-semibold">(xMin, yMin)</th>
                        <th class="px-3 py-2 text-left text-slate-400 font-semibold">(xMax, yMax)</th>
                    </tr>
                </thead>
                <tbody>${rows.join('')}</tbody>
            </table>`;
    }

    function renderPdfSizePanel() {
        if (!pdfSizePanelBody || !pdfSizePanelSummary) return;

        const dims = Array.isArray(lastPdfPageDims) ? lastPdfPageDims : [];
        const previewMeta = lastPdfPreviewMeta || {};
        const dpi = (previewMeta && isFinite(previewMeta.dpiUsed)) ? Number(previewMeta.dpiUsed) : getSelectedPdfPreviewDpi();
        const maxDimUsed = (previewMeta && isFinite(previewMeta.maxDimUsed)) ? Number(previewMeta.maxDimUsed) : null;

        if (!dims.length) {
            pdfSizePanelSummary.textContent = 'No PDF size data';
            pdfSizePanelBody.innerHTML = '<div class="p-3 text-xs text-slate-400">Load a PDF preview first.</div>';
            return;
        }

        const rows = [];
        let firstPtKey = null;
        let mixedSizes = false;

        for (let i = 0; i < dims.length; i++) {
            const d = dims[i] || {};
            const pxW = (d.pixelWidth != null && isFinite(d.pixelWidth)) ? Number(d.pixelWidth) : null;
            const pxH = (d.pixelHeight != null && isFinite(d.pixelHeight)) ? Number(d.pixelHeight) : null;
            let ptW = null;
            let ptH = null;

            if (pxW && pxH && dpi > 0) {
                ptW = (pxW * 72.0) / dpi;
                ptH = (pxH * 72.0) / dpi;
            }

            const mmW = (ptW != null) ? (ptW * 25.4 / 72.0) : null;
            const mmH = (ptH != null) ? (ptH * 25.4 / 72.0) : null;
            const inW = (ptW != null) ? (ptW / 72.0) : null;
            const inH = (ptH != null) ? (ptH / 72.0) : null;
            const orient = (ptW != null && ptH != null)
                ? (Math.abs(ptW - ptH) < 0.01 ? 'Square' : (ptW > ptH ? 'Landscape' : 'Portrait'))
                : '—';
            const capped = !!(maxDimUsed && pxW != null && pxH != null && (Math.abs(pxW - maxDimUsed) < 1 || Math.abs(pxH - maxDimUsed) < 1));

            const ptKey = (ptW != null && ptH != null) ? `${Math.round(ptW * 100)}/${Math.round(ptH * 100)}` : null;
            if (i === 0) firstPtKey = ptKey;
            else if (firstPtKey && ptKey && firstPtKey !== ptKey) mixedSizes = true;

            rows.push(`
                <tr class="border-b border-slate-800/60">
                    <td class="px-3 py-2 align-top text-slate-200 whitespace-nowrap">P${i + 1}</td>
                    <td class="px-3 py-2 align-top text-slate-300 whitespace-nowrap">${(pxW != null && pxH != null) ? `${fmtNum(pxW)} × ${fmtNum(pxH)} px${capped ? ' (cap)' : ''}` : '—'}</td>
                    <td class="px-3 py-2 align-top text-slate-300 whitespace-nowrap">${(ptW != null && ptH != null) ? `${fmtNum(ptW)} × ${fmtNum(ptH)} pt` : '—'}</td>
                    <td class="px-3 py-2 align-top text-slate-300 whitespace-nowrap">${(mmW != null && mmH != null) ? `${fmtNum(mmW)} × ${fmtNum(mmH)} mm` : '—'}</td>
                    <td class="px-3 py-2 align-top text-slate-300 whitespace-nowrap">${(inW != null && inH != null) ? `${fmtNum(inW)} × ${fmtNum(inH)} in` : '—'}</td>
                    <td class="px-3 py-2 align-top text-slate-400 whitespace-nowrap">${orient}${capped ? ' • capped' : ''}</td>
                </tr>`);
        }

        const first = dims[0] || {};
        const firstPxW = (first.pixelWidth != null && isFinite(first.pixelWidth)) ? Number(first.pixelWidth) : null;
        const firstPxH = (first.pixelHeight != null && isFinite(first.pixelHeight)) ? Number(first.pixelHeight) : null;
        const firstPtW = (firstPxW != null && dpi > 0) ? (firstPxW * 72.0) / dpi : null;
        const firstPtH = (firstPxH != null && dpi > 0) ? (firstPxH * 72.0) / dpi : null;
        const firstCapped = !!(maxDimUsed && firstPxW != null && firstPxH != null && (Math.abs(firstPxW - maxDimUsed) < 1 || Math.abs(firstPxH - maxDimUsed) < 1));
        pdfSizePanelSummary.textContent = `${dims.length} page(s)`
            + ((firstPtW != null && firstPtH != null) ? ` • ${mixedSizes ? 'mixed sizes' : `${fmtNum(firstPtW)}×${fmtNum(firstPtH)} pt`}` : '')
            + ((dpi && isFinite(dpi)) ? ` • preview ${fmtNum(dpi)} DPI` : '')
            + (firstCapped && maxDimUsed ? ` • capped at ${fmtNum(maxDimUsed)} px` : '');

        pdfSizePanelBody.innerHTML = `
            <div class="p-3 space-y-3">
                <div class="grid grid-cols-1 md:grid-cols-3 gap-3">
                    <div class="rounded-lg border border-slate-700/50 bg-slate-900/30 px-3 py-2">
                        <div class="text-[11px] uppercase tracking-wider text-slate-500">Pages</div>
                        <div class="mt-1 text-sm font-semibold text-slate-100">${dims.length}</div>
                    </div>
                    <div class="rounded-lg border border-slate-700/50 bg-slate-900/30 px-3 py-2">
                        <div class="text-[11px] uppercase tracking-wider text-slate-500">Preview DPI</div>
                        <div class="mt-1 text-sm font-semibold text-slate-100">${(dpi && isFinite(dpi)) ? fmtNum(dpi) : '—'}</div>
                    </div>
                    <div class="rounded-lg border border-slate-700/50 bg-slate-900/30 px-3 py-2">
                        <div class="text-[11px] uppercase tracking-wider text-slate-500">Page Sizes</div>
                        <div class="mt-1 text-sm font-semibold text-slate-100">${mixedSizes ? 'Mixed' : 'Uniform'}</div>
                    </div>
                </div>

                ${firstCapped && maxDimUsed ? `<div class="rounded-lg border border-amber-500/30 bg-amber-900/10 px-3 py-2 text-[11px] text-amber-200">Preview pixel size reached the render cap of ${escapeHtml(fmtNum(maxDimUsed))} px, so increasing DPI further may not increase the shown px size.</div>` : ''}

                <table class="w-full text-xs">
                    <thead class="sticky top-0 bg-slate-950 border-b border-slate-800">
                        <tr>
                            <th class="px-3 py-2 text-left text-slate-400 font-semibold">Page</th>
                            <th class="px-3 py-2 text-left text-slate-400 font-semibold">Rendered</th>
