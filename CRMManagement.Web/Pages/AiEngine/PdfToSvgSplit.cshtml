            _svgAiCandidateDebugInfo = {
                cropViewBox,
                totalNodes: 0,
                skippedDefs: 0,
                bboxMisses: 0,
                nonIntersecting: 0,
                marked: 0,
                limitHit: false,
                serverEstimated: false,
                samples: [{ tag: 'server', id: '', reason: isAbort ? `estimate-timeout after ${Math.round(_svgAiCandidateEstimateTimeoutMs / 1000)}s` : 'estimate-request-failed' }]
