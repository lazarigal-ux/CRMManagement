        } catch (e) {
            const msg = e && e.message ? e.message : String(e || 'Failed to apply alignment.');
            try { showError(msg); } catch { /* ignore */ }
            cgAlert(msg);
        }
    });

    function addResultCard(idx) {
        const card = _buildResultCardElement(idx);
        if (!card) return;
        if (pageResults[idx] && pageResults[idx].movedFromOtherElements) {
            if (movedOtherElementsGrid) movedOtherElementsGrid.appendChild(card);
            try { _renderMovedOtherElementsSection(); } catch { /* ignore */ }
        } else {
            if (resultsGrid) resultsGrid.appendChild(card);
        }
        try { _renderWallResultsTab(); } catch { /* ignore */ }
    }

    function _upsertResultCard(idx) {
        try {
            const r = pageResults[idx];
            if (!r) return;

            const selector = `.page-card[data-idx="${idx}"]`;
            const grid = r.movedFromOtherElements ? movedOtherElementsGrid : resultsGrid;
            if (!grid) return;

            const nextCard = _buildResultCardElement(idx);
            if (!nextCard) return;

            const existing = grid.querySelector(selector);
            if (existing) existing.replaceWith(nextCard);
            else grid.appendChild(nextCard);

            try { _renderMovedOtherElementsSection(); } catch { /* ignore */ }
            try { _renderWallResultsTab(); } catch { /* ignore */ }
        } catch { /* ignore */ }
    }

    function _syncResultMetadataAfterSvgChange(idx) {
        try {
            if (!Number.isFinite(idx) || idx < 0 || idx >= pageResults.length) return;
            const r = pageResults[idx];
            if (!r) return;

            const svgText = r.svgContent ? String(r.svgContent) : '';
            r.svgSizeBytes = svgText ? new Blob([svgText]).size : 0;
            r.objectCount = svgText ? countSvgObjects(svgText) : 0;

            if (r.isLayer) {
                const currentName = String(r.layerName || 'Layer').trim();
                if (/\(\s*\d[\d,\.]*\s*\)\s*$/.test(currentName)) {
                    r.layerName = currentName.replace(/\(\s*\d[\d,\.]*\s*\)\s*$/, `(${formatInt(r.objectCount)})`);
                }
            }

            if (Number(_svgPreviewActiveResultIdx) === idx) {
                try {
                    const titleEl = document.getElementById('previewTitle');
                    if (titleEl) {
                        const title = r.isLayer ? r.layerName : ('Page ' + r.pageNumber);
                        titleEl.textContent = 'SVG Preview — ' + title;
                    }
                } catch { /* ignore */ }
            }

            try { recomputeFullLayerFromSum(pageResults); } catch { /* ignore */ }
            try { _upsertResultCard(idx); } catch { /* ignore */ }

            const fullIdx = pageResults.findIndex(x => x && x !== r && x.layerName && String(x.layerName).includes('Full SVG (all layers)'));
            if (fullIdx >= 0) {
                try { _upsertResultCard(fullIdx); } catch { /* ignore */ }
            }
        } catch { /* ignore */ }
    }

    function _rerenderAllResultCards() {
        try {
            try { _purgeFamilyDebugLayers(pageResults); } catch { /* ignore */ }
            revokeThumbObjectUrls();
            if (resultsGrid) resultsGrid.innerHTML = '';
            if (movedOtherElementsGrid) movedOtherElementsGrid.innerHTML = '';
            for (let i = 0; i < pageResults.length; i++) addResultCard(i);
            try { _updateSelectedLayoutsUi(); } catch { /* ignore */ }
            try { _renderMovedOtherElementsSection(); } catch { /* ignore */ }
        } catch { /* ignore */ }
    }

    // ── Download All ──
