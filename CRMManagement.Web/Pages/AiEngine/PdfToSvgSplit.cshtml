    const VECTOR_PDF_TEXT_LINES_ENDPOINT = '@Url.Content("~/fire/pdf/vector/text-lines")';
    const VECTOR_PDF_TEXT_WORDS_ENDPOINT = '@Url.Content("~/fire/pdf/vector/text-words")';
    const SHAPELY_MERGE_ENDPOINT = '@Url.Content("~/fire/svg/shapely/merge-paths")';
    const SHAPELY_GROUP_OBJECTS_ENDPOINT = '@Url.Content("~/fire/svg/shapely/group-objects")';
    const SVG_AI_TEXT_ONLY_ENDPOINT = '@Url.Content("~/fire/svg/ai/text-only")';
    const SVG_AI_CLEAN_OTHER_ELEMENTS_ENDPOINT = '@Url.Content("~/fire/svg/ai/clean-other-elements")';
    const SVG_OTHER_ELEMENTS_CLEAN_SIGNS_ENDPOINT = '@Url.Content("~/fire/svg/other-elements/clean-signs")';
    const SVG_OTHER_ELEMENTS_CANDIDATE_DEBUG_ENDPOINT = '@Url.Content("~/fire/svg/other-elements/candidate-debug")';
    const OBJECT_FAMILIES_ENDPOINT = '@Url.Content("~/fire/object-families")';
    const CUSTOMER_LIST_ENDPOINT = '@Url.Content("~/fire/customers/list")';
    const RESOURCE_USAGE_ENDPOINT = '@Url.Content("~/fire/system/usage")';
    const SVG_DELETE_RULES_ENDPOINT = '@Url.Content("~/fire/svg/delete-rules")';
    const PAGE_SESSIONS_ENDPOINT = '@Url.Content("~/fire/svg/page-sessions")';

    // ── DOM refs ──
    let _smallSignsSizePercent = 100; // UI-controlled: 20..300 (percentage of default thresholds)
    window._smallSignsSizePercent = _smallSignsSizePercent;
    const pdfFileInput    = document.getElementById('pdfFileInput');
    const providerSelect  = document.getElementById('provider');
    const dpiInput        = document.getElementById('dpiInput');
    const clientIdSelect  = document.getElementById('clientIdSelect');
    const btnPreSplitMerge = document.getElementById('btnPreSplitMerge');
    const btnSplitConvert = document.getElementById('btnSplitConvert');
    const btnMergedSvgTab = document.getElementById('btnMergedSvgTab');
    const pdfPreviewCard  = document.getElementById('pdfPreviewCard');
    const mergedSvgPreviewCard = document.getElementById('mergedSvgPreviewCard');
    const mergedSvgPreviewSummary = document.getElementById('mergedSvgPreviewSummary');
    const mergedSvgLegendSummary = document.getElementById('mergedSvgLegendSummary');
    const mergedSvgLegendChips = document.getElementById('mergedSvgLegendChips');
    const mergedSvgDebugSummary = document.getElementById('mergedSvgDebugSummary');
    const mergedSvgDebugText = document.getElementById('mergedSvgDebugText');
    const btnCopyMergedSvgDebug = document.getElementById('btnCopyMergedSvgDebug');
    const mergedSvgPreviewViewport = document.getElementById('mergedSvgPreviewViewport');
    const mergedSvgPreviewScale = document.getElementById('mergedSvgPreviewScale');
    const mergedSvgZoomLabel = document.getElementById('mergedSvgZoomLabel');
    const btnMergedSvgZoomOut = document.getElementById('btnMergedSvgZoomOut');
    const btnMergedSvgZoomFit = document.getElementById('btnMergedSvgZoomFit');
    const btnMergedSvgZoomIn = document.getElementById('btnMergedSvgZoomIn');
    const btnMergedSvgFilterAll = document.getElementById('btnMergedSvgFilterAll');
    const btnMergedSvgFilterNone = document.getElementById('btnMergedSvgFilterNone');
    const btnDownloadMergedSvg = document.getElementById('btnDownloadMergedSvg');
    const pdfViewport     = document.getElementById('pdfViewport');
    const pdfInner        = document.getElementById('pdfInner');
    const pdfPages        = document.getElementById('pdfPages');
    const errorCard       = document.getElementById('errorCard');
    const resultsSection  = document.getElementById('resultsSection');
    const resultsGrid     = document.getElementById('resultsGrid');
    const resultsSummary  = document.getElementById('resultsSummary');
    const btnPreviewSelectedLayouts = document.getElementById('btnPreviewSelectedLayouts');
    const movedOtherElementsSection = document.getElementById('movedOtherElementsSection');
    const movedOtherElementsSummary = document.getElementById('movedOtherElementsSummary');
    const movedOtherElementsGrid = document.getElementById('movedOtherElementsGrid');
    const pdfPreviewDpiEl = document.getElementById('pdfPreviewDpi');
    const colorLayerSection = document.getElementById('colorLayerSection');
    const regionTextSection = document.getElementById('regionTextSection');
    const pdfTextHiddenLabelsInput = document.getElementById('pdfTextHiddenLabelsInput');
    const pdfTextHiddenLabelsSummary = document.getElementById('pdfTextHiddenLabelsSummary');
    const pdfTextLanguageSummary = document.getElementById('pdfTextLanguageSummary');
    const pdfTextLangEnglish = document.getElementById('pdfTextLangEnglish');
    const pdfTextLangHebrew = document.getElementById('pdfTextLangHebrew');
    const pdfTextLangArabic = document.getElementById('pdfTextLangArabic');
    const btnPdfTextLangAll = document.getElementById('btnPdfTextLangAll');
    const btnPdfTextLangNone = document.getElementById('btnPdfTextLangNone');
    const btnPdfTextHiddenLabelsReset = document.getElementById('btnPdfTextHiddenLabelsReset');
    const processReportCard = document.getElementById('processReportCard');
    const processReportSummary = document.getElementById('processReportSummary');
    const processReportText = document.getElementById('processReportText');
    const btnCopyReport = document.getElementById('btnCopyReport');
    const btnOpenTextDrawer = document.getElementById('btnOpenTextDrawer');
    const btnOpenPdfSizeDrawer = document.getElementById('btnOpenPdfSizeDrawer');
    const pdfTextPanel = document.getElementById('pdfTextPanel');
    const pdfTextPanelSummary = document.getElementById('pdfTextPanelSummary');
    const pdfTextPanelBody = document.getElementById('pdfTextPanelBody');
    const pdfSizePanel = document.getElementById('pdfSizePanel');
    const pdfSizePanelSummary = document.getElementById('pdfSizePanelSummary');
    const pdfSizePanelBody = document.getElementById('pdfSizePanelBody');
    const pdfSizeInfoCard = document.getElementById('pdfSizeInfoCard');
    const pdfSizeInfoSummary = document.getElementById('pdfSizeInfoSummary');
    const pdfSizeInfoBody = document.getElementById('pdfSizeInfoBody');
    const pdfLoadingOverlay = document.getElementById('pdfLoadingOverlay');
    const pdfLoadingOverlayText = document.getElementById('pdfLoadingOverlayText');
    const resourceUsageUpdated = document.getElementById('resourceUsageUpdated');
    const resourceCpuValue = document.getElementById('resourceCpuValue');
    const resourceCpuBar = document.getElementById('resourceCpuBar');
    const resourceCpuMeta = document.getElementById('resourceCpuMeta');
    const resourceGpuWorkers = document.getElementById('resourceGpuWorkers');
    const resourceGpuValue = document.getElementById('resourceGpuValue');
    const resourceGpuBar = document.getElementById('resourceGpuBar');
    const resourceGpuMeta = document.getElementById('resourceGpuMeta');
    const resourceRamValue = document.getElementById('resourceRamValue');
    const resourceRamBar = document.getElementById('resourceRamBar');
    const resourceRamMeta = document.getElementById('resourceRamMeta');
    const splitMainTabBar = document.getElementById('splitMainTabBar');
    const familyLearnPanel = document.getElementById('familyLearnPanel');
    const familyLearnPanelSummary = document.getElementById('familyLearnPanelSummary');
    const familyLearnPanelBody = document.getElementById('familyLearnPanelBody');
    const btnCloseFamilyLearnPanel = document.getElementById('btnCloseFamilyLearnPanel');
    const familyEditorModal = document.getElementById('familyEditorModal');
    const familyEditorTitle = document.getElementById('familyEditorTitle');
    const familyEditorNameInput = document.getElementById('familyEditorNameInput');
    const familyEditorTypeSelect = document.getElementById('familyEditorTypeSelect');
    const familyEditorSymbolPicker = document.getElementById('familyEditorSymbolPicker');
    const familyEditorTypePreview = document.getElementById('familyEditorTypePreview');
    const btnCloseFamilyEditorModal = document.getElementById('btnCloseFamilyEditorModal');
    const btnFamilyEditorCancel = document.getElementById('btnFamilyEditorCancel');
    const btnFamilyEditorSave = document.getElementById('btnFamilyEditorSave');
    const pdfSetupCard = document.getElementById('pdfSetupCard');
    const wallResultsCard = document.getElementById('wallResultsCard');
    const wallResultsGrid = document.getElementById('wallResultsGrid');
    const wallResultsSummary = document.getElementById('wallResultsSummary');
    const CUSTOMER_ID_STORAGE_KEY = 'pdfToSvgSplit.customerId.v1';
    const FAMILY_ID_STORAGE_KEY_PREFIX = 'pdfToSvgSplit.familyIdByCustomer.v1.';
    let _customerListLoaded = false;

    function _normalizeClientId(v) {
        const s = (v || '').toString().trim();
        return s || 'admin';
    }

    function _getCustomerIdFromUrl() {
        try {
            const raw = new URLSearchParams(window.location.search).get('clientId');
            if (raw == null) return '';
            return _normalizeClientId(raw);
        } catch {
            return '';
        }
    }

    function _renderCustomerOptions(customers, selectedValue) {
        if (!clientIdSelect) return;
        const rows = Array.isArray(customers) ? customers : [];
        const selected = _normalizeClientId(selectedValue || (rows[0] && rows[0].id) || 'admin');
        const options = rows.map(row => {
            const id = _normalizeClientId(row && row.id);
            const name = (row && row.name) ? String(row.name).trim() : `Customer ${id}`;
            return `<option value="${escapeHtml(id)}">${escapeHtml(name)}</option>`;
        });
        if (!options.length) options.push('<option value="admin">admin</option>');
        clientIdSelect.innerHTML = options.join('');
        clientIdSelect.value = options.some(() => true) && Array.from(clientIdSelect.options).some(o => o.value === selected)
            ? selected
            : clientIdSelect.options[0].value;
    }

    function _rememberCustomerId(value) {
        const clientId = _normalizeClientId(value);
        try { localStorage.setItem(CUSTOMER_ID_STORAGE_KEY, clientId); } catch { /* ignore */ }
    }

    function _getFamilyStorageKey() {
        return `${FAMILY_ID_STORAGE_KEY_PREFIX}${getSelectedClientId()}`;
    }

    function _rememberSelectedFamilyId(value) {
        try { localStorage.setItem(_getFamilyStorageKey(), String(value || '').trim()); } catch { /* ignore */ }
    }

    function _getRememberedFamilyId() {
        try { return String(localStorage.getItem(_getFamilyStorageKey()) || '').trim(); } catch { return ''; }
    }

    function getSelectedClientId() {
        return _normalizeClientId(clientIdSelect && clientIdSelect.value ? clientIdSelect.value : 'admin');
    }

    async function _loadCustomersIntoSelect() {
        if (!clientIdSelect) return;
        let initial = '';
        try {
            initial = _normalizeClientId(localStorage.getItem(CUSTOMER_ID_STORAGE_KEY) || '');
        } catch { /* ignore */ }
        const fromUrl = _getCustomerIdFromUrl();
        if (fromUrl) initial = fromUrl;

        try {
            const resp = await _nativeFetch(CUSTOMER_LIST_ENDPOINT, {
                headers: { 'X-Client-Id': 'admin' }
            });
            const text = await resp.text();
            let obj = null;
            try { obj = text ? JSON.parse(text) : null; } catch { obj = null; }
            const customers = obj && obj.ok && Array.isArray(obj.customers) ? obj.customers : [];
            _renderCustomerOptions(customers, initial);
            _rememberCustomerId(getSelectedClientId());
            _customerListLoaded = true;
            _objectFamiliesLoadedAt = 0;
            _objectFamilies = [];
            try { _renderFamiliesSelect([]); } catch { /* ignore */ }
            try { await loadObjectFamilies(true); } catch { /* ignore */ }
        } catch {
            _renderCustomerOptions([], initial || 'admin');
            _rememberCustomerId(getSelectedClientId());
            _customerListLoaded = true;
            _objectFamiliesLoadedAt = 0;
            _objectFamilies = [];
            try { _renderFamiliesSelect([]); } catch { /* ignore */ }
            try { await loadObjectFamilies(true); } catch { /* ignore */ }
        }
    }

    const _nativeFetch = window.fetch.bind(window);
    window.fetch = function (resource, init) {
        try {
            const rawUrl = resource instanceof Request ? resource.url : String(resource || '');
            const resolvedUrl = new URL(rawUrl || '', window.location.href);
            if (resolvedUrl.origin === window.location.origin) {
                const headers = new Headers(resource instanceof Request ? resource.headers : undefined);
                if (init && init.headers) {
                    const extra = new Headers(init.headers);
                    extra.forEach((value, key) => headers.set(key, value));
                }
                headers.set('X-Client-Id', getSelectedClientId());
                init = { ...(init || {}), headers };
            }
        } catch { /* ignore */ }
        return _nativeFetch(resource, init);
    };

    (function initClientIdSelect() {
        if (!clientIdSelect) return;
        clientIdSelect.addEventListener('change', async () => {
            if (_customerListLoaded) {
                _rememberCustomerId(clientIdSelect.value);
            }
            _objectFamiliesLoadedAt = 0;
            _objectFamilies = [];
            try { closeFamilyLearnPanel(); } catch { /* ignore */ }
            try { await loadObjectFamilies(true); } catch { /* ignore */ }
        });
        _loadCustomersIntoSelect();
    })();

    function _updateCustomerSelectLock() {
        if (!clientIdSelect || !pdfFileInput) return;
        const hasPdf = !!(pdfFileInput.files && pdfFileInput.files[0]);
        clientIdSelect.disabled = hasPdf;
        if (hasPdf) {
            clientIdSelect.title = 'Customer is locked after choosing a PDF file';
        } else {
            clientIdSelect.title = 'Choose which customer to use for AI and ChatGateway requests';
        }
    }

    _updateCustomerSelectLock();

    const wallResultsEmpty = document.getElementById('wallResultsEmpty');
    const btnDownloadAllWalls = document.getElementById('btnDownloadAllWalls');
    const btnSvgAiTextOnly = document.getElementById('btnSvgAiTextOnly');
    const btnSvgAiClean = document.getElementById('btnSvgAiClean');
    const btnSvgMoveSmallSigns = document.getElementById('btnSvgMoveSmallSigns');
    const smallSignsSizeSlider = document.getElementById('smallSignsSizeSlider');
    const smallSignsSizeLabel = document.getElementById('smallSignsSizeLabel');
    const btnSmallSignsSizeReset = document.getElementById('btnSmallSignsSizeReset');
    if (smallSignsSizeSlider) {
        const _ssKey = 'pdfToSvgSplit.smallSignsSize.v1';
        const _ssStored = localStorage.getItem(_ssKey);
        if (_ssStored && isFinite(Number(_ssStored))) {
            _smallSignsSizePercent = Math.max(20, Math.min(300, Number(_ssStored)));
            smallSignsSizeSlider.value = String(_smallSignsSizePercent);
        }
        if (smallSignsSizeLabel) smallSignsSizeLabel.textContent = _smallSignsSizePercent + '%';
        smallSignsSizeSlider.addEventListener('input', () => {
            _smallSignsSizePercent = Number(smallSignsSizeSlider.value) || 100;
            window._smallSignsSizePercent = _smallSignsSizePercent;
            if (smallSignsSizeLabel) smallSignsSizeLabel.textContent = _smallSignsSizePercent + '%';
            try { localStorage.setItem(_ssKey, String(_smallSignsSizePercent)); } catch {}
        });
        if (btnSmallSignsSizeReset) {
            btnSmallSignsSizeReset.addEventListener('click', () => {
                _smallSignsSizePercent = 100;
                smallSignsSizeSlider.value = '100';
                if (smallSignsSizeLabel) smallSignsSizeLabel.textContent = '100%';
                try { localStorage.setItem(_ssKey, '100'); } catch {}
            });
        }
    }

    let _selectedLayoutPreviewIdxs = new Set();

    function _getValidSelectedLayoutPreviewIdxs() {
        const valid = [];
        for (const raw of (_selectedLayoutPreviewIdxs || [])) {
            const idx = Number(raw);
            if (!Number.isFinite(idx) || idx < 0 || idx >= pageResults.length) continue;
            const r = pageResults[idx];
            if (!r || !r.svgContent) continue;
            valid.push(idx | 0);
        }
        return Array.from(new Set(valid)).sort((a, b) => a - b);
    }

    function _isLayoutPreviewSelected(idx) {
        return _selectedLayoutPreviewIdxs instanceof Set && _selectedLayoutPreviewIdxs.has(Number(idx));
    }

    function _updateSelectedLayoutsUi() {
        const valid = _getValidSelectedLayoutPreviewIdxs();
        _selectedLayoutPreviewIdxs = new Set(valid);
        if (btnPreviewSelectedLayouts) {
            btnPreviewSelectedLayouts.disabled = valid.length === 0;
            const label = btnPreviewSelectedLayouts.querySelector('span');
            if (label) label.textContent = valid.length > 0 ? `Preview selected layouts (${valid.length})` : 'Preview selected layouts';
            btnPreviewSelectedLayouts.title = valid.length > 0
                ? `Preview ${valid.length} selected SVG layer(s) together in one layout`
                : 'Select one or more SVG cards to preview them together';
        }
    }

    function _setLayoutPreviewSelected(idx, selected) {
        const key = Number(idx);
        if (!Number.isFinite(key)) return;
        if (!(_selectedLayoutPreviewIdxs instanceof Set)) _selectedLayoutPreviewIdxs = new Set();
        if (selected) _selectedLayoutPreviewIdxs.add(key);
        else _selectedLayoutPreviewIdxs.delete(key);
        _updateSelectedLayoutsUi();
    }

    async function _buildCombinedSvgPreviewMarkup(indices) {
        const ids = Array.isArray(indices) ? indices.map(v => Number(v)).filter(v => Number.isFinite(v) && v >= 0) : [];
        const rows = ids.map(i => ({ idx: i | 0, result: pageResults[i | 0] })).filter(x => x.result && x.result.svgContent);
        if (!rows.length) return '';

        const prepared = [];
        for (const row of rows) {
            // For family detector layers (markers & debug boxes) in combined layout,
            // use raw svgContent (full-page viewBox) so they overlay correctly on
            // the base drawing. _getSvgContentForPreviewDisplayAsync crops the viewBox
            // to contentBounds which is correct for standalone preview but wrong for
            // combined overlay.
            const isFamilyLayer = !!(row.result && (row.result.isFamilyDetectorLayer || row.result.isFamilyDetectorDebugLayer));
            const svgText = isFamilyLayer
                ? String(row.result.svgContent || '')
                : await _getSvgContentForPreviewDisplayAsync(row.result);
            _debugPdfSplitLog('[CombinedLayout][prepare]', {
                idx: row.idx,
                layerName: row.result && row.result.layerName,
                isFamilyLayer,
                svgSnippet: String(svgText || '').substring(0, 300)
            });
            if (!svgText || !String(svgText).includes('<svg')) continue;
            prepared.push({ idx: row.idx, result: row.result, svgText: String(svgText) });
        }
        if (!prepared.length) return '';

        const parsed = prepared.map(item => {
            try {
                const doc = new DOMParser().parseFromString(item.svgText, 'image/svg+xml');
                const svg = doc.querySelector('svg');
                if (!svg) return null;
                return {
                    ...item,
                    svg,
                    vb: svg.getAttribute('viewBox') || '',
                    w: svg.getAttribute('width') || '',
                    h: svg.getAttribute('height') || ''
                };
            } catch {
                return null;
            }
        }).filter(Boolean);
        if (!parsed.length) return '';

        // Log all parsed layers' viewBoxes for diagnostics
        _debugPdfSplitLog('[CombinedLayout][parsed-layers]', parsed.map(p => ({
            idx: p.idx,
            layerName: p.result && p.result.layerName,
            vb: p.vb,
            w: p.w,
            h: p.h,
            isFamilyLayer: !!(p.result && p.result.isFamilyDetectorLayer),
            familyContentBounds: (p.result && p.result.familyContentBounds) || null
        })));

        const base = (() => {
            const full = parsed.find(x => x && x.result && x.result.layerName && String(x.result.layerName).includes('Full SVG (all layers)'));
            if (full) return full;
            const byArea = parsed
                .map(x => ({ item: x, vb: _parseViewBoxStr(x.vb) }))
                .filter(x => x.vb)
                .sort((a, b) => (b.vb.w * b.vb.h) - (a.vb.w * a.vb.h));
            return byArea.length ? byArea[0].item : parsed[0];
        })();

        _debugPdfSplitLog('[CombinedLayout][base-selected]', {
            idx: base && base.idx,
            layerName: base && base.result && base.result.layerName,
            vb: base && base.vb,
            w: base && base.w,
            h: base && base.h
        });

        const defsParts = [];
        const defsSeen = new Set();
        const bodyParts = [];
        for (const item of parsed) {
            try {
                const defs = item.svg.querySelector('defs');
                if (defs) {
                    const defsHtml = defs.outerHTML;
                    if (defsHtml && !defsSeen.has(defsHtml)) {
                        defsSeen.add(defsHtml);
                        defsParts.push(defsHtml);
                    }
                }
            } catch { }

            try {
                const children = [...item.svg.children].filter(el => String(el.tagName || '').toLowerCase() !== 'defs');
                const layerTitle = item.result && item.result.isLayer ? (item.result.layerName || `Layer ${item.idx + 1}`) : `Page ${item.result && item.result.pageNumber ? item.result.pageNumber : (item.idx + 1)}`;

                // Diagnostic: log first few child elements for family layers
                const isFam = !!(item.result && item.result.isFamilyDetectorLayer);
                if (isFam && children.length > 0) {
                    const sampleChildren = children.slice(0, 3).map((ch, ci) => {
                        const circles = [...ch.querySelectorAll('circle')];
                        return {
                            childIndex: ci,
                            tagName: ch.tagName,
                            outerHtmlSnippet: ch.outerHTML.substring(0, 250),
                            circles: circles.slice(0, 2).map(c => ({
                                cx: c.getAttribute('cx'),
                                cy: c.getAttribute('cy'),
                                r: c.getAttribute('r')
                            }))
                        };
                    });
                    _debugPdfSplitLog('[CombinedLayout][family-children]', {
                        idx: item.idx,
                        layerName: layerTitle,
                        totalChildren: children.length,
                        itemViewBox: item.vb,
                        sampleChildren
                    });
                }

                bodyParts.push(`<g data-combined-layout-idx="${item.idx}" data-combined-layout-name="${escapeHtml(String(layerTitle))}">`);
                for (const child of children) bodyParts.push(child.outerHTML);
                bodyParts.push(`</g>`);
            } catch { }
        }

        const finalVb = base && base.vb ? base.vb : '';
        const finalW = base && base.w ? base.w : '';
        const finalH = base && base.h ? base.h : '';
        _debugPdfSplitLog('[CombinedLayout][final]', {
            finalViewBox: finalVb,
            finalWidth: finalW,
            finalHeight: finalH,
            bodyPartsCount: bodyParts.length,
            defsCount: defsParts.length
        });
        return wrapPaths(bodyParts, finalVb, finalW, finalH, defsParts.join('\n'));
    }

    async function _openCombinedSvgPreview(indices) {
