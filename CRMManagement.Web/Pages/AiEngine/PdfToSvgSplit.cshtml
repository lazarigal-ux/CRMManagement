    // ── SVG Preview modal ──
    let svgPreviewZoom = 1.0;
    let svgPreviewUseAutoCrop = true;
    let svgPreviewAutoCropForce = false;
    let svgPreviewAutoCropPreservePageAspect = false;

    // Fixed crop applied to ALL previews + downloads.
    // When enabled, we force the same viewBox on every SVG.
    let svgPreviewFixedCropEnabled = false;
    let svgPreviewFixedCropViewBoxStr = null; // "x y w h"
    let svgPreviewCropDrawMode = false;
    let _svgPreviewCropDrag = null;
    let _svgPreviewCropEditDrag = null;
    let _svgPreviewCropDraft = null;
    let _svgPreviewCropOverlayRaf = 0;
    let _svgPreviewAiCandidateHighlightTimer = 0;
    let _svgPreviewAiCandidateMarkedNodes = [];
    let _svgPreviewAiCandidateLastKey = '';
    let _svgPreviewAiCandidateLastSvg = null;
    let _layerAlignState = null;

    function _svgMatrixToString(matrix) {
        const m = matrix || _svgIdentityMatrix();
        const fmt = n => {
            const num = Number(n);
            if (!Number.isFinite(num)) return '0';
            const rounded = Math.abs(num) < 1e-12 ? 0 : num;
            return String(parseFloat(rounded.toFixed(8)));
        };
        return `matrix(${fmt(m.a)} ${fmt(m.b)} ${fmt(m.c)} ${fmt(m.d)} ${fmt(m.e)} ${fmt(m.f)})`;
    }

    function _svgIsIdentityMatrix(matrix, epsilon) {
        const eps = Number.isFinite(epsilon) ? epsilon : 1e-6;
        const m = matrix || _svgIdentityMatrix();
        return Math.abs((m.a || 0) - 1) <= eps
            && Math.abs(m.b || 0) <= eps
            && Math.abs(m.c || 0) <= eps
            && Math.abs((m.d || 0) - 1) <= eps
            && Math.abs(m.e || 0) <= eps
            && Math.abs(m.f || 0) <= eps;
    }

    function _solveLinearSystem3x3(A, b) {
        try {
            const M = [
                [Number(A[0][0]) || 0, Number(A[0][1]) || 0, Number(A[0][2]) || 0, Number(b[0]) || 0],
                [Number(A[1][0]) || 0, Number(A[1][1]) || 0, Number(A[1][2]) || 0, Number(b[1]) || 0],
                [Number(A[2][0]) || 0, Number(A[2][1]) || 0, Number(A[2][2]) || 0, Number(b[2]) || 0]
            ];
            for (let col = 0; col < 3; col++) {
                let pivot = col;
                for (let row = col + 1; row < 3; row++) {
                    if (Math.abs(M[row][col]) > Math.abs(M[pivot][col])) pivot = row;
                }
                if (Math.abs(M[pivot][col]) < 1e-10) return null;
                if (pivot !== col) [M[col], M[pivot]] = [M[pivot], M[col]];
                const div = M[col][col];
                for (let k = col; k < 4; k++) M[col][k] /= div;
                for (let row = 0; row < 3; row++) {
                    if (row === col) continue;
                    const factor = M[row][col];
                    for (let k = col; k < 4; k++) M[row][k] -= factor * M[col][k];
                }
            }
            return [M[0][3], M[1][3], M[2][3]];
        } catch {
            return null;
        }
    }

    function _fitAffineCoefficients3(pairs, key) {
        try {
            const ATA = [[0, 0, 0], [0, 0, 0], [0, 0, 0]];
            const ATb = [0, 0, 0];
            for (const pair of (Array.isArray(pairs) ? pairs : [])) {
                if (!pair || !pair.source || !pair.target) continue;
                const row = [Number(pair.source.x) || 0, Number(pair.source.y) || 0, 1];
                const val = Number(pair.target[key]);
                if (!Number.isFinite(val)) continue;
                for (let r = 0; r < 3; r++) {
                    ATb[r] += row[r] * val;
                    for (let c = 0; c < 3; c++) ATA[r][c] += row[r] * row[c];
                }
            }
            return _solveLinearSystem3x3(ATA, ATb);
        } catch {
            return null;
        }
    }

    function _computeAlignmentMatrixFromPairs(pairs) {
        const arr = Array.isArray(pairs) ? pairs.filter(p => p && p.source && p.target) : [];
        if (!arr.length) return _svgIdentityMatrix();
        if (arr.length === 1) {
            const p = arr[0];
            return {
                a: 1,
                b: 0,
                c: 0,
                d: 1,
                e: (Number(p.target.x) || 0) - (Number(p.source.x) || 0),
                f: (Number(p.target.y) || 0) - (Number(p.source.y) || 0)
            };
        }
        if (arr.length === 2) {
            const p1 = arr[0].source;
            const p2 = arr[1].source;
            const q1 = arr[0].target;
            const q2 = arr[1].target;
            const spx = (Number(p2.x) || 0) - (Number(p1.x) || 0);
            const spy = (Number(p2.y) || 0) - (Number(p1.y) || 0);
            const tpx = (Number(q2.x) || 0) - (Number(q1.x) || 0);
            const tpy = (Number(q2.y) || 0) - (Number(q1.y) || 0);
            const sLen = Math.hypot(spx, spy);
            const tLen = Math.hypot(tpx, tpy);
            if (!(sLen > 1e-9) || !(tLen > 1e-9)) {
                return {
                    a: 1,
                    b: 0,
                    c: 0,
                    d: 1,
                    e: (Number(q1.x) || 0) - (Number(p1.x) || 0),
                    f: (Number(q1.y) || 0) - (Number(p1.y) || 0)
                };
            }
            const scale = tLen / sLen;
            const angle = Math.atan2(tpy, tpx) - Math.atan2(spy, spx);
            const cos = Math.cos(angle) * scale;
            const sin = Math.sin(angle) * scale;
            return {
                a: cos,
                b: sin,
                c: -sin,
                d: cos,
                e: (Number(q1.x) || 0) - ((cos * (Number(p1.x) || 0)) + (-sin * (Number(p1.y) || 0))),
                f: (Number(q1.y) || 0) - ((sin * (Number(p1.x) || 0)) + (cos * (Number(p1.y) || 0)))
            };
        }
        const xCoeffs = _fitAffineCoefficients3(arr, 'x');
        const yCoeffs = _fitAffineCoefficients3(arr, 'y');
        if (!xCoeffs || !yCoeffs) return _svgIdentityMatrix();
        return {
            a: xCoeffs[0],
            b: yCoeffs[0],
            c: xCoeffs[1],
            d: yCoeffs[1],
            e: xCoeffs[2],
            f: yCoeffs[2]
        };
    }

    function _findFullSvgResultIndex(forResult) {
        try {
            const r = forResult || null;
            const sourcePages = Array.isArray(r && r.sourcePageIndexes) ? r.sourcePageIndexes.map(v => Number(v) | 0) : [];
            const preferredPage = Number.isFinite(Number(r && r.pageNumber)) ? ((Number(r.pageNumber) | 0) - 1) : null;
            const exact = pageResults.findIndex(it => it && it.svgContent && String(it.layerName || '').includes('Full SVG (all layers)')
                && (
                    (preferredPage != null && ((Number(it.pageNumber) || 1) - 1) === preferredPage)
                    || sourcePages.some(pi => ((Number(it.pageNumber) || 1) - 1) === pi)
                ));
            if (exact >= 0) return exact;
            return pageResults.findIndex(it => it && it.svgContent && String(it.layerName || '').includes('Full SVG (all layers)'));
        } catch {
            return -1;
        }
    }

    function _parseAlignmentLayerParts(svgText) {
        try {
            const parser = new DOMParser();
            const doc = parser.parseFromString(String(svgText || ''), 'image/svg+xml');
            const svg = doc.querySelector('svg');
            if (!svg) return null;
            const metrics = _getSvgRootMetrics(svgText);
            const bodyChildren = [...svg.children].filter(el => String(el.tagName || '').toLowerCase() !== 'defs');
            const manual = bodyChildren.find(el => String(el.tagName || '').toLowerCase() === 'g' && String(el.getAttribute('data-manual-align') || '').toLowerCase() === 'true');
            return {
                metrics,
                sourceBody: manual ? [...manual.children].map(el => el.outerHTML) : bodyChildren.map(el => el.outerHTML),
                baseMatrix: manual ? _svgParseTransformMatrix(manual.getAttribute('transform') || '') : _svgIdentityMatrix()
            };
        } catch {
            return null;
        }
    }

    function _buildAlignmentMarkers(pairs, pending, kind) {
        try {
            const items = [];
            const safePairs = Array.isArray(pairs) ? pairs : [];
            for (let i = 0; i < safePairs.length; i++) {
                const pair = safePairs[i];
                const pt = pair && pair[kind];
                if (!pt) continue;
                const x = Number(pt.x);
                const y = Number(pt.y);
                if (!Number.isFinite(x) || !Number.isFinite(y)) continue;
                const color = kind === 'source' ? '#2563eb' : '#16a34a';       // blue for source, green for target
                const colorLight = kind === 'source' ? '#93c5fd' : '#86efac';
                items.push(
                    `<g data-align-marker-layer="true" pointer-events="none">` +
                    // crosshair lines
                    `<line x1="${(x - 18).toFixed(4)}" y1="${y.toFixed(4)}" x2="${(x + 18).toFixed(4)}" y2="${y.toFixed(4)}" stroke="${color}" stroke-width="2" vector-effect="non-scaling-stroke" stroke-dasharray="3,2"/>` +
                    `<line x1="${x.toFixed(4)}" y1="${(y - 18).toFixed(4)}" x2="${x.toFixed(4)}" y2="${(y + 18).toFixed(4)}" stroke="${color}" stroke-width="2" vector-effect="non-scaling-stroke" stroke-dasharray="3,2"/>` +
                    // outer ring
                    `<circle cx="${x.toFixed(4)}" cy="${y.toFixed(4)}" r="12" fill="none" stroke="${color}" stroke-width="2.5" vector-effect="non-scaling-stroke" opacity="0.7"/>` +
                    // filled center with white outline
                    `<circle cx="${x.toFixed(4)}" cy="${y.toFixed(4)}" r="6" fill="${color}" stroke="#ffffff" stroke-width="2" vector-effect="non-scaling-stroke"/>` +
                    // inner dot
                    `<circle cx="${x.toFixed(4)}" cy="${y.toFixed(4)}" r="2.5" fill="#ffffff" vector-effect="non-scaling-stroke"/>` +
                    // number label with background
                    `<rect x="${(x + 10).toFixed(4)}" y="${(y - 22).toFixed(4)}" width="18" height="16" rx="4" fill="${color}" stroke="#ffffff" stroke-width="1.5" vector-effect="non-scaling-stroke"/>` +
                    `<text x="${(x + 19).toFixed(4)}" y="${(y - 10).toFixed(4)}" fill="#ffffff" font-size="11" font-weight="700" text-anchor="middle" dominant-baseline="central" vector-effect="non-scaling-stroke">${i + 1}</text>` +
                    `</g>`
                );
            }
            const pen = pending && pending[kind];
            if (pen && Number.isFinite(Number(pen.x)) && Number.isFinite(Number(pen.y))) {
                const px = Number(pen.x);
                const py = Number(pen.y);
                const nextNum = safePairs.length + 1;
                items.push(
                    `<g data-align-marker-layer="true" pointer-events="none">` +
                    // pulsing crosshair for pending
                    `<line x1="${(px - 22).toFixed(4)}" y1="${py.toFixed(4)}" x2="${(px + 22).toFixed(4)}" y2="${py.toFixed(4)}" stroke="#f59e0b" stroke-width="2.5" vector-effect="non-scaling-stroke" opacity="0.8"/>` +
                    `<line x1="${px.toFixed(4)}" y1="${(py - 22).toFixed(4)}" x2="${px.toFixed(4)}" y2="${(py + 22).toFixed(4)}" stroke="#f59e0b" stroke-width="2.5" vector-effect="non-scaling-stroke" opacity="0.8"/>` +
                    `<circle cx="${px.toFixed(4)}" cy="${py.toFixed(4)}" r="10" fill="rgba(245,158,11,0.2)" stroke="#f59e0b" stroke-width="3" vector-effect="non-scaling-stroke">` +
                    `<animate attributeName="r" values="10;14;10" dur="1s" repeatCount="indefinite"/></circle>` +
                    `<circle cx="${px.toFixed(4)}" cy="${py.toFixed(4)}" r="4" fill="#f59e0b" stroke="#ffffff" stroke-width="1.5" vector-effect="non-scaling-stroke"/>` +
                    // number label with orange background
                    `<rect x="${(px + 10).toFixed(4)}" y="${(py - 22).toFixed(4)}" width="18" height="16" rx="4" fill="#f59e0b" stroke="#ffffff" stroke-width="1.5" vector-effect="non-scaling-stroke"/>` +
                    `<text x="${(px + 19).toFixed(4)}" y="${(py - 10).toFixed(4)}" fill="#ffffff" font-size="11" font-weight="700" text-anchor="middle" dominant-baseline="central" vector-effect="non-scaling-stroke">${nextNum}</text>` +
                    `</g>`
                );
            }
            return items.join('');
        } catch {
            return '';
        }
    }

    function _buildAlignmentTargetPreview(fullSvgText, sourceParts, matrix, pairs, pending) {
        try {
            const fullMetrics = _getSvgRootMetrics(fullSvgText);
            if (!fullMetrics) return '';
            const fullBody = _extractSvgLayerBodyElements(fullSvgText);
            const markers = _buildAlignmentMarkers(pairs, pending, 'target');
            return wrapPaths([...fullBody, markers].filter(Boolean), fullMetrics.vb, fullMetrics.w, fullMetrics.h, fullMetrics.defsHtml || '');
        } catch {
            return String(fullSvgText || '');
        }
    }

    function _buildAlignmentSourcePreview(sourceParts, pairs, pending) {
        if (!sourceParts || !sourceParts.metrics) return '';
        return wrapPaths([
            ...(Array.isArray(sourceParts.sourceBody) ? sourceParts.sourceBody : []),
            _buildAlignmentMarkers(pairs, pending, 'source')
        ].filter(Boolean), sourceParts.metrics.vb, sourceParts.metrics.w, sourceParts.metrics.h, sourceParts.metrics.defsHtml || '');
    }

    function _decorateAlignmentHostSvg(host) {
        try {
            const svg = host ? host.querySelector('svg') : null;
            if (!svg) return null;
            svg.removeAttribute('width');
            svg.removeAttribute('height');
            svg.style.width = '100%';
            svg.style.height = '100%';
            svg.style.display = 'block';
            svg.style.cursor = 'crosshair';
            if (!svg.getAttribute('preserveAspectRatio')) svg.setAttribute('preserveAspectRatio', 'xMidYMid meet');
            // make host fill its flex cell
            if (host) {
                host.style.display = 'flex';
                host.style.flexDirection = 'column';
                host.style.height = '100%';
            }
            return svg;
        } catch {
            return null;
        }
    }

    function _getAlignmentClickPoint(ev, svg) {
        try {
            if (!ev || !svg) return null;
            const target = ev.target instanceof Element ? ev.target : null;
            if (target && target !== svg && !target.closest('[data-align-marker-layer="true"]')) {
                const bb = _getElBBoxInSvg(target);
                if (bb && bb.w >= 0 && bb.h >= 0) {
                    return { x: bb.x + (bb.w / 2), y: bb.y + (bb.h / 2) };
                }
            }
            const ctm = svg.getScreenCTM();
            if (!ctm || !ctm.inverse) return null;
            const pt = new DOMPoint(ev.clientX, ev.clientY).matrixTransform(ctm.inverse());
            if (!Number.isFinite(pt.x) || !Number.isFinite(pt.y)) return null;
            return { x: pt.x, y: pt.y };
        } catch {
            return null;
        }
    }

    function _alignmentNormalizeViewBox(vb) {
        if (!vb) return null;
        const x = Number(vb.x);
        const y = Number(vb.y);
        const w = Number(vb.w != null ? vb.w : vb.width);
        const h = Number(vb.h != null ? vb.h : vb.height);
        if (![x, y, w, h].every(Number.isFinite) || !(w > 0) || !(h > 0)) return null;
        return { x, y, w, h };
    }

    function _alignmentCloneViewBox(vb) {
        const n = _alignmentNormalizeViewBox(vb);
        return n ? { x: n.x, y: n.y, w: n.w, h: n.h } : null;
    }

    function _alignmentGetSvgViewBox(svg) {
        try {
            if (!svg) return null;
            const vb = svg.viewBox && svg.viewBox.baseVal ? svg.viewBox.baseVal : null;
            if (vb && vb.width > 0 && vb.height > 0) return { x: vb.x || 0, y: vb.y || 0, w: vb.width, h: vb.height };
            const attr = svg.getAttribute('viewBox');
            if (attr) return _parseViewBoxStr(attr);
        } catch { /* ignore */ }
        return null;
    }

    function _alignmentSetSvgViewBox(svg, vb) {
        const next = _alignmentNormalizeViewBox(vb);
        if (!svg || !next) return;
        svg.setAttribute('viewBox', _formatViewBox(next));
        svg.setAttribute('preserveAspectRatio', 'xMidYMid meet');
    }

    function _alignmentClampViewBoxToBounds(vb, bounds) {
        const box = _alignmentNormalizeViewBox(vb);
        const lim = _alignmentNormalizeViewBox(bounds);
        if (!box || !lim) return box;

        let w = Math.min(box.w, lim.w);
        let h = Math.min(box.h, lim.h);
        let x = box.x;
        let y = box.y;

        const maxX = lim.x + lim.w - w;
        const maxY = lim.y + lim.h - h;
        x = Math.max(lim.x, Math.min(x, maxX));
        y = Math.max(lim.y, Math.min(y, maxY));
        return { x, y, w, h };
    }

    function _alignmentFitBox(bb, bounds, padFactor) {
        if (!bb || !(bb.width > 0) || !(bb.height > 0)) return _alignmentCloneViewBox(bounds);
        const lim = _alignmentNormalizeViewBox(bounds) || { x: bb.x, y: bb.y, w: bb.width, h: bb.height };
        const pad = Math.max(2, Math.min(30, Math.max(bb.width, bb.height) * (padFactor || 0.08)));
        const fitted = {
            x: bb.x - pad,
            y: bb.y - pad,
            w: bb.width + (pad * 2),
            h: bb.height + (pad * 2)
        };
        return _alignmentClampViewBoxToBounds(fitted, lim);
    }

    function _fitAlignmentSvgToContent(kind, svg, force) {
        try {
            const st = _layerAlignState;
            if (!st || !svg) return;
            const stateKey = kind === 'source' ? 'sourceViewBox' : 'targetViewBox';
            const boundsKey = kind === 'source' ? 'sourceBounds' : 'targetBounds';
            if (!force && _alignmentNormalizeViewBox(st[stateKey])) {
                _alignmentSetSvgViewBox(svg, st[stateKey]);
                return;
            }

            const bounds = _alignmentNormalizeViewBox(st[boundsKey]) || _alignmentGetSvgViewBox(svg);
            let bb = null;
            if (kind === 'target') {
                const overlay = svg.querySelector('[data-align-preview="true"]');
                if (overlay && typeof overlay.getBBox === 'function') {
                    try { bb = overlay.getBBox(); } catch { bb = null; }
                }
            }
            if (!bb || !(bb.width > 0) || !(bb.height > 0)) {
                try { bb = _svgComputeBBoxIgnoringPageBg(svg); } catch { bb = null; }
            }
            const fitted = _alignmentFitBox(bb, bounds, kind === 'target' ? 0.12 : 0.10) || bounds;
            if (fitted) {
                st[stateKey] = _alignmentCloneViewBox(fitted);
                _alignmentSetSvgViewBox(svg, fitted);
            }
        } catch { /* ignore */ }
    }

    function _zoomAlignmentSvgAt(kind, svg, clientX, clientY, deltaY) {
        try {
            const st = _layerAlignState;
            if (!st || !svg || !Number.isFinite(deltaY)) return;
            const curr = _alignmentGetSvgViewBox(svg);
            const bounds = _alignmentNormalizeViewBox(kind === 'source' ? st.sourceBounds : st.targetBounds) || curr;
            if (!curr || !bounds) return;
            const ctm = svg.getScreenCTM();
            if (!ctm || !ctm.inverse) return;
            const pt = new DOMPoint(clientX, clientY).matrixTransform(ctm.inverse());
            if (!Number.isFinite(pt.x) || !Number.isFinite(pt.y)) return;

            const factor = deltaY < 0 ? 0.86 : 1.16;
            const minSize = Math.max(1, Math.min(bounds.w, bounds.h) * 0.01);
            let newW = Math.max(minSize, Math.min(bounds.w, curr.w * factor));
            let newH = Math.max(minSize, Math.min(bounds.h, curr.h * factor));
            const sx = newW / curr.w;
            const sy = newH / curr.h;
            let next = {
                x: pt.x - ((pt.x - curr.x) * sx),
                y: pt.y - ((pt.y - curr.y) * sy),
                w: newW,
                h: newH
            };
            next = _alignmentClampViewBoxToBounds(next, bounds) || next;
            _alignmentSetSvgViewBox(svg, next);
            if (kind === 'source') st.sourceViewBox = _alignmentCloneViewBox(next);
            else st.targetViewBox = _alignmentCloneViewBox(next);
        } catch { /* ignore */ }
    }

    function _wireAlignmentSvgViewport(host, svg, kind) {
        try {
            if (!host || !svg) return;
            _fitAlignmentSvgToContent(kind, svg, false);

            /* ── Wheel zoom ── */
            svg.addEventListener('wheel', (ev) => {
                ev.preventDefault();
                ev.stopPropagation();
                _zoomAlignmentSvgAt(kind, svg, ev.clientX, ev.clientY, ev.deltaY);
            }, { passive: false });

            /* ── Double-click fit ── */
            svg.addEventListener('dblclick', (ev) => {
                ev.preventDefault();
                ev.stopPropagation();
                const st = _layerAlignState;
                if (!st) return;
                if (kind === 'source') st.sourceViewBox = null;
                else st.targetViewBox = null;
                _fitAlignmentSvgToContent(kind, svg, true);
            });

            /* ── Middle-button / Ctrl+Left drag-to-pan ── */
            let panState = null;
            svg.addEventListener('mousedown', (ev) => {
                // pan with middle button, or Ctrl+left
                const isPanBtn = ev.button === 1 || (ev.button === 0 && ev.ctrlKey);
                if (!isPanBtn) return;
                ev.preventDefault();
                ev.stopPropagation();
                const ctm = svg.getScreenCTM();
                if (!ctm || !ctm.inverse) return;
                const curr = _alignmentGetSvgViewBox(svg);
                if (!curr) return;
                panState = { startX: ev.clientX, startY: ev.clientY, origVB: { ...curr }, ctm };
                svg.style.cursor = 'grabbing';
            });
            window.addEventListener('mousemove', (ev) => {
                if (!panState) return;
                ev.preventDefault();
                const scale = panState.ctm.a; // px-per-svg-unit
                if (!scale || !Number.isFinite(scale)) return;
                const dx = (ev.clientX - panState.startX) / scale;
                const dy = (ev.clientY - panState.startY) / scale;
                const st = _layerAlignState;
                const bounds = st ? _alignmentNormalizeViewBox(kind === 'source' ? st.sourceBounds : st.targetBounds) : null;
                let next = { x: panState.origVB.x - dx, y: panState.origVB.y - dy, w: panState.origVB.w, h: panState.origVB.h };
                if (bounds) next = _alignmentClampViewBoxToBounds(next, bounds) || next;
                _alignmentSetSvgViewBox(svg, next);
                if (st) {
                    if (kind === 'source') st.sourceViewBox = _alignmentCloneViewBox(next);
                    else st.targetViewBox = _alignmentCloneViewBox(next);
                }
            });
            window.addEventListener('mouseup', (ev) => {
                if (!panState) return;
                panState = null;
                svg.style.cursor = 'crosshair';
            });

            host.title = 'גלגלת = זום | דאבל-קליק = התאם | Ctrl+גרירה = הזזה';
        } catch { /* ignore */ }
    }

    function _setLayerAlignActiveTab(tab) {
        try {
            if (!_layerAlignState) return;
            _layerAlignState.activeTab = (tab === 'target') ? 'target' : 'source';
            _updateLayerAlignStepUi();
        } catch { /* ignore */ }
    }

    /* ── Drag-to-move the alignment modal ── */
    function _wireLayerAlignDrag() {
        const handle = document.getElementById('layerAlignDragHandle');
        const dialog = document.getElementById('layerAlignDialog');
        if (!handle || !dialog || handle._dragWired) return;
        handle._dragWired = true;
        let startX = 0, startY = 0, origX = 0, origY = 0, dragging = false;

        function getTranslate() {
            const m = (dialog.style.transform || '').match(/translate\(\s*(-?[\d.]+)px\s*,\s*(-?[\d.]+)px\s*\)/);
            return m ? { x: parseFloat(m[1]), y: parseFloat(m[2]) } : { x: 0, y: 0 };
        }

        handle.addEventListener('mousedown', (e) => {
            if (e.target.closest('button')) return;           // don't hijack buttons
            e.preventDefault();
            dragging = true;
            const t = getTranslate();
            origX = t.x; origY = t.y;
            startX = e.clientX; startY = e.clientY;
            handle.style.cursor = 'grabbing';
        });

        window.addEventListener('mousemove', (e) => {
            if (!dragging) return;
            const dx = e.clientX - startX;
            const dy = e.clientY - startY;
            dialog.style.transform = `translate(${origX + dx}px, ${origY + dy}px)`;
        });

        window.addEventListener('mouseup', () => {
            if (!dragging) return;
            dragging = false;
            handle.style.cursor = 'grab';
        });
    }

    function _updateLayerAlignStepUi() {
        try {
            const st = _layerAlignState;
            const step1Bar = document.getElementById('layerAlignStep1Bar');
            const step2Bar = document.getElementById('layerAlignStep2Bar');
            const step1Num = document.getElementById('layerAlignStep1Num');
            const step2Num = document.getElementById('layerAlignStep2Num');
            const step1PanelNum = document.getElementById('layerAlignStep1PanelNum');
            const step2PanelNum = document.getElementById('layerAlignStep2PanelNum');
            const sourcePanel = document.getElementById('layerAlignSourcePanel');
            const targetPanel = document.getElementById('layerAlignTargetPanel');
            const sourceHint = document.getElementById('layerAlignSourceHint');
            const targetHint = document.getElementById('layerAlignTargetHint');
            const step1Icon = document.getElementById('layerAlignStep1Icon');
            const step2Icon = document.getElementById('layerAlignStep2Icon');
            const tabSource = document.getElementById('btnLayerAlignTabSource');
            const tabTarget = document.getElementById('btnLayerAlignTabTarget');

            if (!step1Bar || !step2Bar) return;

            const hasPendingSource = !!(st && st.pending && st.pending.source);
            const waitingForSource = !hasPendingSource;
            const activeTab = (st && (st.activeTab === 'target' || st.activeTab === 'source'))
                ? st.activeTab
                : (waitingForSource ? 'source' : 'target');

            // Step 1 — active when waiting for source click
            const s1ActiveCls = 'text-sky-300 bg-sky-900/30';
            const s1InactiveCls = 'text-slate-500 bg-transparent';
            const s1NumActiveCls = 'border-sky-400 bg-sky-500 text-white';
            const s1NumDoneCls = 'border-emerald-500 bg-emerald-600 text-white';
            const s1NumInactiveCls = 'border-slate-600 bg-slate-700 text-slate-400';
            const panelActiveCls = 'border-sky-400/80';
            const panelWaitingCls = 'border-slate-700/40';
            const panelTargetActiveCls = 'border-emerald-400/80';

            if (waitingForSource) {
                // Step 1 highlighted
                step1Bar.className = `flex items-center gap-2 px-5 py-2.5 flex-1 justify-center font-semibold transition-all duration-200 border-r border-slate-700/40 ${s1ActiveCls}`;
                if (step1Num) step1Num.className = `w-6 h-6 rounded-full flex items-center justify-center font-bold text-xs border-2 transition-all duration-200 ${s1NumActiveCls}`;
                if (step1PanelNum) step1PanelNum.className = `w-6 h-6 rounded-full flex items-center justify-center font-bold text-xs border-2 transition-all duration-200 flex-shrink-0 ${s1NumActiveCls}`;
                if (sourcePanel) sourcePanel.className = sourcePanel.className.replace(/border-[^\s]+/g, '').trim() + ` border-2 ${panelActiveCls} bg-slate-800/35 rounded-2xl flex flex-col overflow-hidden transition-all duration-200 min-h-0`;
                if (targetPanel) targetPanel.className = targetPanel.className.replace(/border-[^\s]+/g, '').trim() + ` border-2 ${panelWaitingCls} bg-slate-800/35 rounded-2xl flex flex-col overflow-hidden transition-all duration-200 min-h-0`;
                if (sourceHint) { sourceHint.textContent = '← לחץ כאן עכשיו!'; sourceHint.className = 'ml-auto text-[11px] text-sky-300 font-semibold animate-pulse'; }
                if (targetHint) { targetHint.textContent = '← ממתין לשלב 1'; targetHint.className = 'ml-auto text-[11px] text-slate-500'; }
                step2Bar.className = `flex items-center gap-2 px-5 py-2.5 flex-1 justify-center font-semibold transition-all duration-200 border-l border-slate-700/40 ${s1InactiveCls}`;
                if (step2Num) step2Num.className = `w-6 h-6 rounded-full flex items-center justify-center font-bold text-xs border-2 transition-all duration-200 ${s1NumInactiveCls}`;
                if (step2PanelNum) step2PanelNum.className = `w-6 h-6 rounded-full flex items-center justify-center font-bold text-xs border-2 transition-all duration-200 flex-shrink-0 ${s1NumInactiveCls}`;
                if (step1Icon) step1Icon.style.display = '';
                if (step2Icon) step2Icon.style.display = 'none';
            } else {
                // Step 2 highlighted
                step1Bar.className = `flex items-center gap-2 px-5 py-2.5 flex-1 justify-center font-semibold transition-all duration-200 border-r border-slate-700/40 text-emerald-400 bg-emerald-900/20`;
                if (step1Num) step1Num.className = `w-6 h-6 rounded-full flex items-center justify-center font-bold text-xs border-2 transition-all duration-200 ${s1NumDoneCls}`;
                if (step1PanelNum) step1PanelNum.className = `w-6 h-6 rounded-full flex items-center justify-center font-bold text-xs border-2 transition-all duration-200 flex-shrink-0 ${s1NumDoneCls}`;
                if (sourcePanel) sourcePanel.className = sourcePanel.className.replace(/border-[^\s]+/g, '').trim() + ` border-2 border-emerald-500/60 bg-slate-800/35 rounded-2xl flex flex-col overflow-hidden transition-all duration-200 min-h-0`;
                if (targetPanel) targetPanel.className = targetPanel.className.replace(/border-[^\s]+/g, '').trim() + ` border-2 ${panelTargetActiveCls} bg-slate-800/35 rounded-2xl flex flex-col overflow-hidden transition-all duration-200 min-h-0`;
                if (sourceHint) { sourceHint.textContent = '✓ אובייקט נבחר'; sourceHint.className = 'ml-auto text-[11px] text-emerald-400 font-semibold'; }
                if (targetHint) { targetHint.textContent = '← לחץ כאן עכשיו!'; targetHint.className = 'ml-auto text-[11px] text-emerald-300 font-semibold animate-pulse'; }
                step2Bar.className = `flex items-center gap-2 px-5 py-2.5 flex-1 justify-center font-semibold transition-all duration-200 border-l border-slate-700/40 text-emerald-300 bg-emerald-900/25`;
                if (step2Num) step2Num.className = `w-6 h-6 rounded-full flex items-center justify-center font-bold text-xs border-2 transition-all duration-200 border-emerald-400 bg-emerald-500 text-white`;
                if (step2PanelNum) step2PanelNum.className = `w-6 h-6 rounded-full flex items-center justify-center font-bold text-xs border-2 transition-all duration-200 flex-shrink-0 border-emerald-400 bg-emerald-500 text-white`;
                if (step1Icon) step1Icon.style.display = 'none';
                if (step2Icon) step2Icon.style.display = '';
            }

            if (sourcePanel) sourcePanel.style.display = activeTab === 'source' ? 'flex' : 'none';
            if (targetPanel) targetPanel.style.display = activeTab === 'target' ? 'flex' : 'none';

            if (tabSource) {
                tabSource.className = `inline-flex items-center gap-2 rounded-xl border px-3 py-2 text-xs font-semibold transition ${activeTab === 'source' ? 'border-sky-400/70 bg-sky-900/30 text-sky-200' : 'border-slate-600/60 bg-slate-800/40 text-slate-300 hover:bg-slate-700/60'}`;
            }
            if (tabTarget) {
                const targetActive = activeTab === 'target';
                tabTarget.className = `inline-flex items-center gap-2 rounded-xl border px-3 py-2 text-xs font-semibold transition ${targetActive ? 'border-emerald-400/70 bg-emerald-900/30 text-emerald-200' : 'border-slate-600/60 bg-slate-800/40 text-slate-300 hover:bg-slate-700/60'}`;
            }
        } catch { /* ignore */ }
    }

    function _updateLayerAlignPairsUi() {
        try {
            const list = document.getElementById('layerAlignPairsList');
            const status = document.getElementById('layerAlignStatus');
            const btnApply = document.getElementById('btnLayerAlignApply');
            const btnUndo = document.getElementById('btnLayerAlignUndoPair');
            const st = _layerAlignState;
            if (!list || !btnApply || !btnUndo) return;
            if (!st) {
                list.innerHTML = '';
                if (status) status.textContent = '';
                btnApply.disabled = true;
                btnUndo.disabled = true;
                return;
            }
            const hasPendingSource = !!(st.pending && st.pending.source);
            if (status) {
                if (!hasPendingSource) {
                    status.textContent = st.pairs.length
                        ? `${st.pairs.length} זוג(ות) מקושרים ✓ — גלגלת = זום | Ctrl+גרירה = הזזה | דאבל-קליק = התאם`
                        : 'שלב 1: בחר בטאב Source ולחץ על האובייקט. גלגלת = זום | Ctrl+גרירה = הזזה | דאבל-קליק = התאם';
                } else {
                    status.textContent = `✓ Source נבחר — שלב 2: עבור לטאב Full SVG ולחץ על האובייקט המקביל. גלגלת = זום | Ctrl+גרירה = הזזה`;
                }
            }
            btnApply.disabled = !(st.pairs.length > 0);
            btnUndo.disabled = !(st.pairs.length > 0);
            if (!st.pairs.length) {
                list.innerHTML = `<div class="text-slate-400 text-xs">אין זוגות עדיין. לחץ על אובייקט ב-Source ואז על האובייקט המקביל ב-Full SVG. אפשר למחוק זוג שגוי מהטבלה.</div>`;
                return;
            }
            list.innerHTML = st.pairs.map((pair, i) => {
                const sx = Number(pair.source.x).toFixed(1);
                const sy = Number(pair.source.y).toFixed(1);
                const tx = Number(pair.target.x).toFixed(1);
                const ty = Number(pair.target.y).toFixed(1);
                return `<div class="rounded-lg border border-slate-700/40 bg-slate-900/30 px-3 py-1.5 flex items-center gap-2">
                    <span class="w-5 h-5 rounded-full bg-sky-600 text-white flex items-center justify-center font-bold text-[10px] flex-shrink-0">${i + 1}</span>
                    <span class="text-slate-300">Source (${sx}, ${sy})</span>
                    <i class="fa-solid fa-arrow-right text-slate-500 text-[10px]"></i>
                    <span class="text-emerald-300">Full SVG (${tx}, ${ty})</span>
                    <button type="button" class="ml-auto inline-flex items-center gap-1 rounded-md border border-rose-500/50 bg-rose-900/20 hover:bg-rose-900/35 text-rose-300 px-2 py-1 text-[10px] transition" data-remove-align-pair="${i}" title="Delete this pair">
                        <i class="fa-solid fa-trash-can"></i>
                        מחק
                    </button>
                </div>`;
            }).join('');
            list.querySelectorAll('[data-remove-align-pair]').forEach(btn => {
                btn.addEventListener('click', () => {
                    const idx = Number(btn.getAttribute('data-remove-align-pair'));
                    if (!_layerAlignState || !Number.isFinite(idx) || idx < 0 || idx >= _layerAlignState.pairs.length) return;
                    _layerAlignState.pairs.splice(idx, 1);
                    _renderLayerAlignmentModal();
                });
            });
            _updateLayerAlignStepUi();
        } catch { /* ignore */ }
    }

    function _renderLayerAlignmentModal() {
        try {
            const st = _layerAlignState;
            if (!st) return;
            const targetHost = document.getElementById('layerAlignTargetHost');
            const sourceHost = document.getElementById('layerAlignSourceHost');
            const title = document.getElementById('layerAlignTitle');
            if (!targetHost || !sourceHost || !title) return;
            const effectiveMatrix = (Array.isArray(st.pairs) && st.pairs.length)
                ? _computeAlignmentMatrixFromPairs(st.pairs)
                : (st.baseMatrix || _svgIdentityMatrix());
            title.textContent = `Align — ${st.layerName}`;
            targetHost.innerHTML = _buildAlignmentTargetPreview(st.fullSvgText, st.sourceParts, effectiveMatrix, st.pairs, st.pending);
            sourceHost.innerHTML = _buildAlignmentSourcePreview(st.sourceParts, st.pairs, st.pending);
            const targetSvg = _decorateAlignmentHostSvg(targetHost);
            const sourceSvg = _decorateAlignmentHostSvg(sourceHost);
            _wireAlignmentSvgViewport(targetHost, targetSvg, 'target');
            _wireAlignmentSvgViewport(sourceHost, sourceSvg, 'source');

            const hasPendingSource = !!(st.pending && st.pending.source);

            // Step 1: SOURCE click — always available
            if (sourceSvg) {
                sourceSvg.style.cursor = 'crosshair';
                sourceSvg.addEventListener('click', (ev) => {
                    const state = _layerAlignState;
                    if (!state) return;
                    const pt = _getAlignmentClickPoint(ev, sourceSvg);
                    if (!pt) return;
                    state.pending.source = pt;
                    state.pending.target = null; // reset any stale target
                    state.activeTab = 'target';
                    _renderLayerAlignmentModal();
                }, { once: true });
            }

            // Step 2: TARGET click — ONLY allowed after source is set
            if (targetSvg) {
                if (hasPendingSource) {
                    targetSvg.style.cursor = 'crosshair';
                    targetSvg.addEventListener('click', (ev) => {
                        const state = _layerAlignState;
                        if (!state || !state.pending.source) return;
                        const pt = _getAlignmentClickPoint(ev, targetSvg);
                        if (!pt) return;
                        state.pairs.push({ source: state.pending.source, target: pt });
                        state.pending = { source: null, target: null };
                        state.activeTab = 'source';
                        _renderLayerAlignmentModal();
                    }, { once: true });
                } else {
                    // Visually disabled — show "not-allowed" cursor, show tooltip
                    targetSvg.style.cursor = 'not-allowed';
                    targetSvg.style.opacity = '0.65';
                    targetSvg.addEventListener('click', (ev) => {
                        ev.stopPropagation();
                        const state = _layerAlignState;
                        if (!state) return;
                        if (!state.pending || !state.pending.source) {
                            state.activeTab = 'source';
                            // Flash the source panel to guide the user
                            const sourcePanel = document.getElementById('layerAlignSourcePanel');
                            if (sourcePanel) {
                                sourcePanel.style.outline = '3px solid #38bdf8';
                                setTimeout(() => { if (sourcePanel) sourcePanel.style.outline = ''; }, 700);
                            }
                        }
                    }, { once: true });
                }
            }

            _updateLayerAlignPairsUi();
            _updateLayerAlignStepUi();
        } catch { /* ignore */ }
    }

    function _closeLayerAlignmentModal() {
        _layerAlignState = null;
        const modal = document.getElementById('layerAlignModal');
        if (modal) modal.classList.add('hidden');
    }

    async function _openLayerAlignmentModal(idx) {
        const layer = pageResults[idx];
        if (!layer || !layer.svgContent || !layer.isLayer) throw new Error('Layer is not available for alignment.');
        if (layer.isFamilyDetectorDebugLayer) throw new Error('Debug layers cannot be aligned.');
        if (String(layer.layerName || '').includes('Full SVG (all layers)')) throw new Error('Full SVG is already the target layer.');
        const fullIdx = _findFullSvgResultIndex(layer);
        if (!(fullIdx >= 0) || !pageResults[fullIdx] || !pageResults[fullIdx].svgContent) throw new Error('Full SVG layer was not found.');
        const sourceParts = _parseAlignmentLayerParts(layer.svgContent);
        if (!sourceParts || !sourceParts.metrics) throw new Error('Could not parse the selected layer SVG.');

        // Build a filtered Full SVG that excludes the current source layer
        const rawFullSvg = String(pageResults[fullIdx].svgContent || '');
        const filteredFullSvg = (() => {
            try {
                const fullMetrics = _getSvgRootMetrics(rawFullSvg);
                if (!fullMetrics) return rawFullSvg;
                // Parse the viewBox for white bg rect
                const vbParts = (fullMetrics.vb || '').split(/\s+/).map(Number);
                const bgRect = (vbParts.length === 4 && vbParts.every(Number.isFinite))
                    ? `<rect x="${vbParts[0]}" y="${vbParts[1]}" width="${vbParts[2]}" height="${vbParts[3]}" fill="white" data-page-bg="true"/>`
                    : `<rect x="0" y="0" width="${fullMetrics.w || 1000}" height="${fullMetrics.h || 1000}" fill="white" data-page-bg="true"/>`;
                // Collect body elements from all OTHER layers (exclude current source, debug, Full SVG itself)
                const otherBodies = [];
                for (let i = 0; i < pageResults.length; i++) {
                    const r = pageResults[i];
                    if (!r || !r.svgContent || !r.isLayer) continue;
                    if (i === idx) continue;
                    if (r.isFamilyDetectorDebugLayer) continue;
                    if (String(r.layerName || '').includes('Full SVG (all layers)')) continue;
                    otherBodies.push(..._extractSvgLayerBodyElements(r.svgContent));
                }
                if (!otherBodies.length) return rawFullSvg;
                return wrapPaths([bgRect, ...otherBodies], fullMetrics.vb, fullMetrics.w, fullMetrics.h, fullMetrics.defsHtml || '');
            } catch {
                return rawFullSvg;
            }
        })();

        _layerAlignState = {
            layerIdx: idx,
            layerName: String(layer.layerName || `Layer ${idx + 1}`),
            fullIdx,
            fullSvgText: filteredFullSvg,
            sourceParts,
            sourceBounds: _parseViewBoxStr(sourceParts.metrics.vb) || { x: 0, y: 0, w: Math.max(1, Number(sourceParts.metrics.w) || 1), h: Math.max(1, Number(sourceParts.metrics.h) || 1) },
            targetBounds: (() => {
                const fullMetrics = _getSvgRootMetrics(pageResults[fullIdx].svgContent || '');
                return (fullMetrics && _parseViewBoxStr(fullMetrics.vb)) || (fullMetrics ? {
                    x: 0,
                    y: 0,
                    w: Math.max(1, Number(fullMetrics.w) || 1),
                    h: Math.max(1, Number(fullMetrics.h) || 1)
                } : null);
            })(),
            sourceViewBox: null,
            targetViewBox: null,
            activeTab: 'source',
            baseMatrix: sourceParts.baseMatrix || _svgIdentityMatrix(),
            pending: { source: null, target: null },
            pairs: []
        };
        const modal = document.getElementById('layerAlignModal');
        const dialog = document.getElementById('layerAlignDialog');
        if (dialog) { dialog.style.transform = ''; dialog.style.margin = ''; }
        if (modal) modal.classList.remove('hidden');
        _renderLayerAlignmentModal();
        _wireLayerAlignDrag();
    }

    async function _applyLayerAlignmentFromModal() {
        const st = _layerAlignState;
        if (!st) return;
        const idx = Number(st.layerIdx);
        const layer = pageResults[idx];
        if (!layer || !layer.svgContent) return;
        const matrix = st.pairs.length ? _computeAlignmentMatrixFromPairs(st.pairs) : (st.baseMatrix || _svgIdentityMatrix());
        _pushSvgUndo(idx);
        const nextBody = _svgIsIdentityMatrix(matrix)
            ? [...st.sourceParts.sourceBody]
            : [`<g data-manual-align="true" transform="${escapeXml(_svgMatrixToString(matrix))}">${st.sourceParts.sourceBody.join('')}</g>`];
        layer.svgContent = wrapPaths(nextBody, st.sourceParts.metrics.vb, st.sourceParts.metrics.w, st.sourceParts.metrics.h, st.sourceParts.metrics.defsHtml || '');
        _syncResultMetadataAfterSvgChange(idx);
        if (Number(_svgPreviewActiveResultIdx) === idx) {
            try { await _openSvgPreviewForResult(idx, { preserveView: true }); } catch { /* ignore */ }
        }
        _closeLayerAlignmentModal();
        cgAlert(`Alignment applied to ${layer.layerName || 'layer'}.`);
    }
    let _svgPreviewAiCandidateScanToken = 0;
    let _svgAiCandidateDebugEnabled = false;
    let _svgAiCandidateDebugInfo = null;
    let _svgAiCandidateEstimatedCount = null;
    let _svgAiCandidateEstimateBusy = false;
    let _svgAiCandidateEstimateKey = '';
    const _svgAiCandidateAutoScanMaxObjects = 25000;
    const _svgAiCandidateAutoScanMaxBytes = 6 * 1024 * 1024;
    const _svgAiCandidateEstimateTimeoutMs = 12000;

    function _getSvgPreviewScaleAndSvg() {
        const scaleEl = document.getElementById('svgPreviewScale');
        const svg = scaleEl ? scaleEl.querySelector('svg') : null;
        return { scaleEl, svg };
    }

    function _ensureSvgPreviewCropOverlay() {
        const { scaleEl } = _getSvgPreviewScaleAndSvg();
        if (!scaleEl) return null;
        if (!scaleEl.style.position) scaleEl.style.position = 'relative';

        let overlay = scaleEl.querySelector('.svg-crop-overlay');
        if (!overlay) {
            overlay = document.createElement('div');
            overlay.className = 'svg-crop-overlay';
            overlay.style.position = 'absolute';
            overlay.style.inset = '0';
            overlay.style.zIndex = '20';
            overlay.style.pointerEvents = 'none';
            overlay.style.background = 'transparent';
            overlay.style.userSelect = 'none';
            overlay.style.touchAction = 'none';

            const box = document.createElement('div');
            box.className = 'svg-crop-overlay-box';
            box.style.position = 'absolute';
            box.style.border = '2px dashed rgba(236,72,153,.95)';
            box.style.background = 'rgba(236,72,153,.12)';
            box.style.display = 'none';
            box.style.boxSizing = 'border-box';
            box.style.cursor = 'move';

            const handleDefs = [
                ['nw', 'nwse-resize', 'left:-6px;top:-6px;'],
                ['ne', 'nesw-resize', 'right:-6px;top:-6px;'],
                ['sw', 'nesw-resize', 'left:-6px;bottom:-6px;'],
                ['se', 'nwse-resize', 'right:-6px;bottom:-6px;']
            ];
            for (const [dir, cursor, pos] of handleDefs) {
                const handle = document.createElement('div');
                handle.className = 'svg-crop-overlay-handle';
                handle.dataset.dir = dir;
                handle.style.position = 'absolute';
                handle.style.width = '12px';
                handle.style.height = '12px';
                handle.style.borderRadius = '999px';
                handle.style.border = '2px solid rgba(236,72,153,.98)';
                handle.style.background = '#fff';
                handle.style.boxShadow = '0 0 0 1px rgba(15,23,42,.25)';
                handle.style.cursor = cursor;
                handle.style.touchAction = 'none';
                handle.style.cssText += pos;
                box.appendChild(handle);
            }
            overlay.appendChild(box);

            scaleEl.appendChild(overlay);
        }
        return overlay;
    }

    function _svgPreviewClientToLocal(clientX, clientY) {
        const { svg } = _getSvgPreviewScaleAndSvg();
        if (!svg || !svg.getScreenCTM) return null;
        const ctm = svg.getScreenCTM();
        if (!ctm || !ctm.inverse) return null;
        try {
            const pt = new DOMPoint(clientX, clientY).matrixTransform(ctm.inverse());
            if (!Number.isFinite(pt.x) || !Number.isFinite(pt.y)) return null;
            return { x: pt.x, y: pt.y };
        } catch {
            return null;
        }
    }

    function _renderSvgPreviewCropOverlayNow() {
        const overlay = _ensureSvgPreviewCropOverlay();
        if (!overlay) return;
        const box = overlay.querySelector('.svg-crop-overlay-box');
        if (!box) return;

        overlay.style.pointerEvents = (svgPreviewCropDrawMode || svgPreviewFixedCropEnabled) ? 'auto' : 'none';
        overlay.style.cursor = svgPreviewCropDrawMode ? 'crosshair' : 'default';
        overlay.style.display = (svgPreviewCropDrawMode || svgPreviewFixedCropEnabled) ? 'block' : 'none';

        const draft = svgPreviewCropDrawMode
            ? _svgPreviewCropDraft
            : (svgPreviewFixedCropEnabled ? _parseViewBoxStr(svgPreviewFixedCropViewBoxStr) : null);
        if (!draft || !(draft.w > 0) || !(draft.h > 0)) {
            box.style.display = 'none';
            return;
        }

        const { svg } = _getSvgPreviewScaleAndSvg();
        if (!svg || !svg.getScreenCTM) {
            box.style.display = 'none';
            return;
        }

        try {
            const ctm = svg.getScreenCTM();
            if (!ctm) {
                box.style.display = 'none';
                return;
            }

            const p1 = new DOMPoint(draft.x, draft.y).matrixTransform(ctm);
            const p2 = new DOMPoint(draft.x + draft.w, draft.y + draft.h).matrixTransform(ctm);
            const ob = overlay.getBoundingClientRect();
            const left = Math.min(p1.x, p2.x) - ob.left;
            const top = Math.min(p1.y, p2.y) - ob.top;
            const width = Math.abs(p2.x - p1.x);
            const height = Math.abs(p2.y - p1.y);

            box.style.display = 'block';
            box.style.left = `${left}px`;
            box.style.top = `${top}px`;
            box.style.width = `${width}px`;
            box.style.height = `${height}px`;
        } catch {
            box.style.display = 'none';
        }
    }

    function _clampSvgPreviewCropRect(rect, svgForClamp) {
        if (!rect) return null;
        const minSize = 5;
        let x = Number(rect.x) || 0;
        let y = Number(rect.y) || 0;
        let w = Math.max(minSize, Number(rect.w) || 0);
        let h = Math.max(minSize, Number(rect.h) || 0);
        try {
            const pr = svgForClamp && svgForClamp._origPageRect ? svgForClamp._origPageRect : null;
            if (pr && pr.w > 0 && pr.h > 0) {
                w = Math.min(w, pr.w);
                h = Math.min(h, pr.h);
                const maxX = pr.x + pr.w - w;
                const maxY = pr.y + pr.h - h;
                x = Math.max(pr.x, Math.min(x, maxX));
                y = Math.max(pr.y, Math.min(y, maxY));
            }
        } catch { /* ignore */ }
        return { x, y, w, h };
    }

    function _renderSvgPreviewCropOverlay() {
        if (_svgPreviewCropOverlayRaf) return;
        _svgPreviewCropOverlayRaf = requestAnimationFrame(() => {
            _svgPreviewCropOverlayRaf = 0;
            _renderSvgPreviewCropOverlayNow();
            _scheduleSvgPreviewAiCandidateHighlight();
        });
    }

    function _setSvgPreviewCropDrawMode(active) {
        svgPreviewCropDrawMode = !!active;
        const body = document.getElementById('svgPreviewBody');
        if (!svgPreviewCropDrawMode) {
            _svgPreviewCropDrag = null;
            _svgPreviewCropEditDrag = null;
            _svgPreviewCropDraft = null;
        }
        if (body) body.style.overflow = svgPreviewCropDrawMode ? 'hidden' : '';
        _updateSvgCropUi();
        _renderSvgPreviewCropOverlay();
    }

    function _clearSvgPreviewAiCandidateHighlight() {
        _svgPreviewAiCandidateScanToken++;
        if (_svgPreviewAiCandidateHighlightTimer) {
            clearTimeout(_svgPreviewAiCandidateHighlightTimer);
            _svgPreviewAiCandidateHighlightTimer = 0;
        }
        if (Array.isArray(_svgPreviewAiCandidateMarkedNodes)) {
            for (const el of _svgPreviewAiCandidateMarkedNodes) {
                try {
                    el.classList.remove('svg-ai-clean-candidate');
                    el.removeAttribute('data-ai-clean-fill-none');
                } catch { /* ignore */ }
            }
        }
        _svgPreviewAiCandidateMarkedNodes = [];
        _svgPreviewAiCandidateLastKey = '';
        _svgPreviewAiCandidateLastSvg = null;
        _svgAiCandidateDebugInfo = null;
        _svgAiCandidateEstimatedCount = null;
        _svgAiCandidateEstimateBusy = false;
        _svgAiCandidateEstimateKey = '';
        _updateSvgAiCandidateCountUi(0);
    }

    function _updateSvgAiCandidateDebugUi() {
        if (!btnSvgAiCandidateDebug || !svgAiCandidateDebugPanel) return;
        const idx = Number(_svgPreviewActiveResultIdx);
        const r = Number.isFinite(idx) && idx >= 0 && idx < pageResults.length ? pageResults[idx] : null;
        const isEligible = !!r && _isOtherElementsLayerResult(r);
        btnSvgAiCandidateDebug.classList.toggle('hidden', !isEligible);
        btnSvgAiCandidateDebug.classList.toggle('ring-1', !!_svgAiCandidateDebugEnabled && isEligible);
        btnSvgAiCandidateDebug.classList.toggle('ring-violet-300/50', !!_svgAiCandidateDebugEnabled && isEligible);
        svgAiCandidateDebugPanel.classList.toggle('hidden', !isEligible || !_svgAiCandidateDebugEnabled);
        if (!isEligible || !_svgAiCandidateDebugEnabled) return;

        const info = _svgAiCandidateDebugInfo;
        if (!info) {
            svgAiCandidateDebugPanel.textContent = 'Debug mode on. Select an area to inspect candidate detection.';
            return;
        }

        const lines = [
            `crop: ${info.cropViewBox || '—'}`,
            `scanned: ${info.totalNodes} | defs skipped: ${info.skippedDefs} | bbox misses: ${info.bboxMisses} | outside crop: ${info.nonIntersecting} | marked: ${info.marked}`,
            info.limitHit ? `limit: stopped after ${info.marked} marked objects` : 'limit: not hit'
        ];

        if (info.serverEstimated) {
            lines.push(`server estimate: ${formatInt(Math.max(0, Number(info.marked) || 0))} intersecting object(s) in the selected area`);
            const visited = Math.max(0, Number(info.serverVisitedElements) || 0);
            const pruned = Math.max(0, Number(info.serverPrunedContainers) || 0);
            const cacheHits = Math.max(0, Number(info.serverBoundsCacheHits) || 0);
            const cacheMisses = Math.max(0, Number(info.serverBoundsCacheMisses) || 0);
            const nearby = Math.max(0, Number(info.serverNearbyCandidates) || 0);
            if (visited > 0 || pruned > 0 || cacheHits > 0 || cacheMisses > 0) {
                lines.push(`server scan: visited ${formatInt(visited)} | pruned containers ${formatInt(pruned)} | bbox cache hits ${formatInt(cacheHits)} | misses ${formatInt(cacheMisses)}${info.serverStoppedEarly ? ' | stopped early' : ''}`);
            }
            if (nearby > 0) {
                lines.push(`nearby objects: ${formatInt(nearby)} object(s) were found close to the selected square, but not intersecting it exactly.`);
            }
            if (visited >= 50000 && pruned === 0) {
                lines.push('note: this OTHER ELEMENTS SVG is effectively flat (no useful groups/containers to prune), so the server had to inspect almost every object before deciding whether the small selected area contains matching SVG objects.');
            }
            if (visited > 0 && Number(info.marked) === 0) {
                lines.push('note: the server scan finished and found no intersecting SVG objects in the selected area. This is not a stuck state.');
            }
        }

        if (Array.isArray(info.samples) && info.samples.length > 0) {
            lines.push('samples:');
            for (const s of info.samples) {
                lines.push(`- ${s.tag}${s.id ? `#${s.id}` : ''}: ${s.reason}`);
            }
        }

