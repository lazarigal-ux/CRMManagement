                _svgAiCandidateEstimatedCount = null;
                _svgAiCandidateDebugInfo = {
                    cropViewBox,
                    totalNodes: 0,
                    skippedDefs: 0,
                    bboxMisses: 0,
                    nonIntersecting: 0,
                    marked: 0,
                    limitHit: false,
                    serverEstimated: false,
                    samples: [{ tag: 'server', id: '', reason: (payload && payload.error) ? String(payload.error) : `estimate-failed http=${resp.status}` }]
                };
                return;
            }

            const totalCandidates = Math.max(0, Number(payload.totalCandidates) || 0);
            const intersectingCandidates = Math.max(0, Number(payload.intersectingCandidates) || 0);
            const tagCounts = payload && typeof payload.tagCounts === 'object' && payload.tagCounts ? payload.tagCounts : {};
            const samples = Object.entries(tagCounts)
                .sort((a, b) => (Number(b[1]) || 0) - (Number(a[1]) || 0))
                .slice(0, 8)
                .map(([tag, value]) => ({ tag: String(tag || 'unknown'), id: '', reason: `${formatInt(Math.max(0, Number(value) || 0))} intersecting` }));

            _svgAiCandidateEstimatedCount = intersectingCandidates;
            _svgAiCandidateDebugInfo = {
                cropViewBox,
                totalNodes: totalCandidates,
                skippedDefs: 0,
                bboxMisses: 0,
                nonIntersecting: Math.max(0, totalCandidates - intersectingCandidates),
                marked: intersectingCandidates,
                limitHit: false,
                serverEstimated: true,
                serverNearbyCandidates: Math.max(0, Number(payload.nearbyCandidates) || 0),
                serverVisitedElements: Math.max(0, Number(payload.visitedElements) || 0),
                serverPrunedContainers: Math.max(0, Number(payload.prunedContainers) || 0),
                serverBoundsCacheHits: Math.max(0, Number(payload.boundsCacheHits) || 0),
                serverBoundsCacheMisses: Math.max(0, Number(payload.boundsCacheMisses) || 0),
