        if (pdfPreviewCard) pdfPreviewCard.classList.toggle('split-main-panel-active', _splitMainTab === 'pdfPreview');
        if (mergedSvgPreviewCard) mergedSvgPreviewCard.classList.toggle('split-main-panel-active', _splitMainTab === 'mergedSvg');
        if (wallResultsCard) wallResultsCard.classList.toggle('split-main-panel-active', false);
        if (_splitMainTab === 'pdfPreview') {
