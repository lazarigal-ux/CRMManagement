    document.addEventListener('pointerdown', (e) => {
        try {
            const menu = e.target && e.target.closest ? e.target.closest('#annotatedDetectionActionMenu') : null;
            if (!menu) return;
            e.stopPropagation();
        } catch { /* ignore */ }
    }, true);

    document.addEventListener('click', (e) => {
        try {
            const btn = e.target && e.target.closest ? e.target.closest('#annotatedDetectionActionMenu [data-menu-action]') : null;
            if (!btn) return;

            e.preventDefault();
            e.stopPropagation();

            const menu = btn.closest('#annotatedDetectionActionMenu');
            if (!menu) return;

            const pageIndex = parseInt(String(menu.dataset.pageIndex || ''), 10);
            const idx = parseInt(String(menu.dataset.detectionIdx || ''), 10);
            const action = String(btn.dataset.menuAction || '').trim().toLowerCase();
            _debugAnnotatedDetectionMenu('menu-click', {
                action,
                pageIndex: Number.isFinite(pageIndex) ? pageIndex : null,
                detectionIndex: Number.isFinite(idx) ? idx : null
            }, true);

            if (action === 'close') {
                _debugAnnotatedDetectionMenu('menu-close', { pageIndex: Number.isFinite(pageIndex) ? pageIndex : null, detectionIndex: Number.isFinite(idx) ? idx : null }, false);
                closeAnnotatedDetectionActionMenu();
                return;
            }
            if (!Number.isFinite(idx) || idx < 0) {
                _debugAnnotatedDetectionMenu('invalid-detection-index', {
                    action,
                    rawDetectionIdx: String(menu.dataset.detectionIdx || '')
                }, true);
                return;
            }
            if (action === 'mark-correct') {
                _debugAnnotatedDetectionMenu('mark-correct-dispatch', { detectionIndex: idx, approved: true }, false);
                setAnnotatedDetectionApproved(idx, true);
                return;
            }
            if (action === 'mark-incorrect') {
                _debugAnnotatedDetectionMenu('mark-incorrect-dispatch', { detectionIndex: idx, approved: false }, false);
                setAnnotatedDetectionApproved(idx, false);
                return;
            }
            if (action === 'preview') {
                _debugAnnotatedDetectionMenu('preview-dispatch', { detectionIndex: idx }, false);
                openFamilyDetectionPreview(idx);
                closeAnnotatedDetectionActionMenu();
                return;
            }
            _debugAnnotatedDetectionMenu('unknown-action', { action, detectionIndex: idx }, true);
        } catch (err) {
            _debugAnnotatedDetectionMenu('menu-click-error', { message: err && err.message ? err.message : String(err || 'unknown') }, true);
        }
    }, true);

    function openAnnotatedDetectionActionMenuFromHotspot(pi, idx, el) {
        try {
            _clearAnnotatedHotspotClickTimer();
            const hit = _getAnnotatedDetectionBoxes(pi).find(x => x && x.idx === (idx | 0));
            if (!hit) return;
            const rect = el && el.getBoundingClientRect ? el.getBoundingClientRect() : null;
            const clientX = rect ? (rect.left + Math.min(rect.width, 24)) : 0;
            const clientY = rect ? (rect.top + Math.min(rect.height, 24)) : 0;
            _showAnnotatedDetectionActionMenu(pi, hit, clientX, clientY);
        } catch { /* ignore */ }
    }

    function scheduleAnnotatedDetectionActionMenuFromHotspot(pi, idx, el) {
        _clearAnnotatedHotspotClickTimer();
        _annotatedHotspotClickTimer = setTimeout(() => {
            _annotatedHotspotClickTimer = 0;
            openAnnotatedDetectionActionMenuFromHotspot(pi, idx, el);
        }, 220);
    }

    function setAnnotatedDetectionApproved(idx, approved) {
        try {
            const i = parseInt(String(idx != null ? idx : ''), 10);
            const rows = Array.isArray(_familyScanDetections) ? _familyScanDetections : [];
            if (!Number.isFinite(i) || i < 0 || i >= rows.length || !rows[i]) {
                _debugAnnotatedDetectionMenu('toggle-approval-invalid-row', { detectionIndex: idx, rowCount: rows.length }, true);
                return;
            }
            rows[i].approved = !!approved;
            _debugAnnotatedDetectionMenu('toggle-approval-applied', {
                detectionIndex: i,
                approved: !!approved,
                pageIndex: Number.isFinite(rows[i].pageIndex) ? (rows[i].pageIndex | 0) : null
            }, true);
            if (_pendingDetectionApprovalChanges) delete _pendingDetectionApprovalChanges[String(i)];
            _refreshFamilyDetectionsUi();
            try {
                const r = rows[i];
                const pageIndex = (r && Number.isFinite(r.pageIndex)) ? ((r.pageIndex | 0) + 1) : '?';
                _appendFamilyScanLog(`${approved ? 'Marked green (+)' : 'Marked yellow (-)'} from map (page ${pageIndex})`);
            } catch { /* ignore */ }
        } finally {
            _closeAnnotatedDetectionActionMenu();
        }
    }

    function toggleAnnotatedDetectionFromMap(idx) {
        try {
            _clearAnnotatedHotspotClickTimer();
            const i = parseInt(String(idx != null ? idx : ''), 10);
            const rows = Array.isArray(_familyScanDetections) ? _familyScanDetections : [];
            if (!Number.isFinite(i) || i < 0 || i >= rows.length || !rows[i]) return;
            const current = _getDetectionApprovalValue(rows[i], i, true);
            const nextApproved = current === true ? false : true;
            setAnnotatedDetectionApproved(i, nextApproved);
        } catch { /* ignore */ }
    }

    function _refreshAnnotatedDetectionsOverlay() {
        try {
            const pages = Array.isArray(_familyScanAnnotatedPages) ? _familyScanAnnotatedPages : [];
            for (const p of pages) {
                const pi = (p && isFinite(p.pageIndex)) ? (p.pageIndex | 0) : -1;
                if (pi >= 0) _drawAnnotatedDetectionOverlays(pi);
            }
        } catch { /* ignore */ }
    }

    function _syncAnnotatedPageDetectionCounts() {
        try {
            const pages = Array.isArray(_familyScanAnnotatedPages) ? _familyScanAnnotatedPages : [];
            const rows = Array.isArray(_familyScanDetections) ? _familyScanDetections : [];
            const counts = new Map();
            for (const row of rows) {
                if (!row || !Number.isFinite(row.pageIndex)) continue;
                const pi = row.pageIndex | 0;
                counts.set(pi, (counts.get(pi) || 0) + 1);
            }
            for (const page of pages) {
                if (!page || !Number.isFinite(page.pageIndex)) continue;
                const pi = page.pageIndex | 0;
                page.detectionCount = counts.get(pi) || 0;
            }
        } catch { /* ignore */ }
    }

    function _refreshAnnotatedPageCountLabels() {
        try {
            const pages = Array.isArray(_familyScanAnnotatedPages) ? _familyScanAnnotatedPages : [];
            for (const page of pages) {
                if (!page || !Number.isFinite(page.pageIndex)) continue;
                const pi = page.pageIndex | 0;
                const label = document.getElementById(`annotatedDetectionsCountLabel_${pi}`);
                if (label) label.textContent = `${page.detectionCount || 0} detection(s) • red=neutral • green=add • yellow=cancel`;
            }
        } catch { /* ignore */ }
    }

    function _captureAnnotatedPagesViewState() {
        try {
            const state = {};
            const pages = Array.isArray(_familyScanAnnotatedPages) ? _familyScanAnnotatedPages : [];
            for (const p of pages) {
                const pi = (p && isFinite(p.pageIndex)) ? (p.pageIndex | 0) : -1;
                if (pi < 0) continue;
                const container = document.getElementById(`annotatedPageContainer_${pi}`);
                state[String(pi)] = {
                    zoom: _annotatedPageZooms[pi] || 1,
                    scrollLeft: container ? container.scrollLeft : 0,
                    scrollTop: container ? container.scrollTop : 0
                };
            }
            return state;
        } catch {
            return {};
        }
    }

    function _restoreAnnotatedPagesViewState(state) {
        try {
            const entries = state ? Object.entries(state) : [];
            if (!entries.length) return;
            const applyState = (attempt) => {
                let pending = false;
                for (const [k, v] of entries) {
                    const pi = parseInt(k, 10);
                    if (!Number.isFinite(pi) || pi < 0) continue;
                    const zoom = (v && isFinite(v.zoom)) ? Number(v.zoom) : 1;
                    const metrics = _getAnnotatedPageDisplayMetrics(pi);
                    if (!metrics || !metrics.bw || !metrics.bh || !metrics.displayW || !metrics.displayH) {
                        pending = true;
                        continue;
                    }
                    try { _setAnnotatedPageZoom(pi, zoom); } catch { /* ignore */ }
                    const container = document.getElementById(`annotatedPageContainer_${pi}`);
                    if (container) {
                        try { container.scrollLeft = (v && isFinite(v.scrollLeft)) ? Number(v.scrollLeft) : 0; } catch { /* ignore */ }
                        try { container.scrollTop = (v && isFinite(v.scrollTop)) ? Number(v.scrollTop) : 0; } catch { /* ignore */ }
                    }
                }
                if (pending && attempt < 12) {
                    setTimeout(() => applyState(attempt + 1), 60);
                }
            };
            requestAnimationFrame(() => applyState(0));
        } catch { /* ignore */ }
    }

    function _refreshAnnotatedPagesUi() {
        try {
            _syncAnnotatedPageDetectionCounts();
            const host = document.getElementById('annotatedPagesSection');
            if (!host) {
                _refreshAnnotatedDetectionsOverlay();
                return;
            }
            const viewState = _captureAnnotatedPagesViewState();
            host.innerHTML = _getAnnotatedPagesHtml();
            _restoreAnnotatedPagesViewState(viewState);
        } catch { /* ignore */ }
    }

    function _setAnnotatedPageZoom(pi, z, anchorX, anchorY) {
        const cid = `annotatedPageContainer_${pi}`;
        const container = document.getElementById(cid);
        const metrics = _getAnnotatedPageDisplayMetrics(pi);
        if (!container || !metrics) return;
        const { scaleEl, img, bw, bh, cropX, cropY, displayW, displayH } = metrics;
        const canvas = document.getElementById(`markMissingCanvas_${pi}`);
        const overlayCanvas = document.getElementById(`annotatedDetectionsCanvas_${pi}`);
        const hotspotLayer = document.getElementById(`annotatedDetectionsHotspots_${pi}`);

        const prev = _annotatedPageZooms[pi] || 1;
        const newZ = Math.max(0.1, Math.min(50, z));
        _annotatedPageZooms[pi] = newZ;

        scaleEl.style.width = (displayW * newZ) + 'px';
        scaleEl.style.height = (displayH * newZ) + 'px';
        img.style.width = (bw * newZ) + 'px';
        img.style.height = (bh * newZ) + 'px';
        img.style.left = (-cropX * bw * newZ) + 'px';
        img.style.top = (-cropY * bh * newZ) + 'px';
        if (overlayCanvas) {
            overlayCanvas.style.width = (displayW * newZ) + 'px';
            overlayCanvas.style.height = (displayH * newZ) + 'px';
        }
        if (hotspotLayer) {
            hotspotLayer.style.width = displayW + 'px';
            hotspotLayer.style.height = displayH + 'px';
            hotspotLayer.style.transform = `scale(${newZ})`;
        }
        if (canvas) {
            canvas.style.width = (displayW * newZ) + 'px';
            canvas.style.height = (displayH * newZ) + 'px';
        }

        try { _drawAnnotatedDetectionOverlays(pi); } catch { /* ignore */ }

        const lbl = document.getElementById(`annotatedZoomLabel_${pi}`);
        if (lbl) lbl.textContent = `${Math.round(newZ * 100)}%`;

        // Anchor-based scroll adjustment so zoom targets the cursor position.
        if (anchorX != null && anchorY != null) {
            const rect = container.getBoundingClientRect();
            const x = anchorX - rect.left;
            const y = anchorY - rect.top;
            const contentX = (container.scrollLeft + x) / prev;
            const contentY = (container.scrollTop + y) / prev;
            container.scrollLeft = contentX * newZ - x;
            container.scrollTop = contentY * newZ - y;
        }
    }

    function annotatedPageZoomReset(pi) { _setAnnotatedPageZoom(pi, 1); }

    function annotatedPageZoomFit(pi) {
        const container = document.getElementById(`annotatedPageContainer_${pi}`);
        const metrics = _getAnnotatedPageDisplayMetrics(pi);
        if (!container || !metrics) return;
        const bw = metrics.displayW || 1;
        const bh = metrics.displayH || 1;
        const cw = container.clientWidth || 300;
        const ch = container.clientHeight || 300;
        const z = Math.min(cw / bw, ch / bh, 1);
        _setAnnotatedPageZoom(pi, z);
    }

    function _getAnnotatedPageInitialZoom() {
        const currentPdfZoom = Number(pdfZoom);
        if (!Number.isFinite(currentPdfZoom) || currentPdfZoom <= 0) return 1;
        return Math.max(1, currentPdfZoom);
    }

    function annotatedPageFitOnLoad(pi) {
        // New annotated pages follow the current PDF zoom, but never open below 100%.
        try { _setAnnotatedPageZoom(pi, _getAnnotatedPageInitialZoom()); } catch { /* ignore */ }
        try { _drawAnnotatedDetectionOverlays(pi); } catch { /* ignore */ }
    }

    // Delegate wheel events for annotated page containers.
    document.addEventListener('wheel', (e) => {
        if (!e.target || !e.target.closest) return;
        const container = e.target.closest('[id^="annotatedPageContainer_"]');
        if (!container) return;
        const pi = parseInt(container.dataset.page, 10);
        if (!Number.isFinite(pi)) return;

        e.preventDefault();
        const cur = _annotatedPageZooms[pi] || 1;
        const factor = e.deltaY < 0 ? 1.15 : 1 / 1.15;
        _setAnnotatedPageZoom(pi, cur * factor, e.clientX, e.clientY);
    }, { passive: false });

    // Click-drag panning for annotated page containers (disabled when mark-missing mode active).
    document.addEventListener('pointerdown', (e) => {
        if (!e.target || !e.target.closest) return;
        if (e.target.closest('[data-annotated-detection-hotspot]')) return;
        const container = e.target.closest('[id^="annotatedPageContainer_"]');
        if (!container || e.button !== 0) return;
        const pi = parseInt(container.dataset.page, 10);
        if (_markMissingActive[pi]) return; // drawing mode — don't pan

        e.preventDefault();
        _closeAnnotatedDetectionActionMenu();
        container.style.cursor = 'grabbing';
        const startX = e.clientX, startY = e.clientY;
        const sl = container.scrollLeft, st = container.scrollTop;
        _annotatedPanState = { pageIndex: pi, moved: false };

        const onMove = (ev) => {
            if (_annotatedPanState && _annotatedPanState.pageIndex === pi && (Math.abs(ev.clientX - startX) > 4 || Math.abs(ev.clientY - startY) > 4)) {
                _annotatedPanState.moved = true;
            }
            container.scrollLeft = sl - (ev.clientX - startX);
            container.scrollTop = st - (ev.clientY - startY);
        };
        const onUp = (ev) => {
            container.style.cursor = _markMissingActive[pi] ? 'crosshair' : 'grab';
            const panState = _annotatedPanState && _annotatedPanState.pageIndex === pi
                ? { ..._annotatedPanState }
                : null;
            const endClientX = ev && Number.isFinite(ev.clientX) ? ev.clientX : startX;
            const endClientY = ev && Number.isFinite(ev.clientY) ? ev.clientY : startY;
            try {
                setTimeout(() => {
                    if (_annotatedPanState && _annotatedPanState.pageIndex === pi) _annotatedPanState = null;
                }, 0);
            } catch {
                _annotatedPanState = null;
            }
            document.removeEventListener('pointermove', onMove);
            document.removeEventListener('pointerup', onUp);

            if (!panState || panState.moved || _markMissingActive[pi]) return;
            try {
                const hit = _findAnnotatedDetectionHit(pi, endClientX, endClientY);
                if (hit) _showAnnotatedDetectionActionMenu(pi, hit, endClientX, endClientY);
            } catch { /* ignore */ }
        };
        document.addEventListener('pointermove', onMove);
        document.addEventListener('pointerup', onUp);
    });

    document.addEventListener('click', (e) => {
        try {
            const menuTarget = e.target && e.target.closest ? e.target.closest('#annotatedDetectionActionMenu') : null;
            if (menuTarget) return;

            const container = e.target && e.target.closest ? e.target.closest('[id^="annotatedPageContainer_"]') : null;
            if (!container) {
                _closeAnnotatedDetectionActionMenu();
                return;
            }

            const pi = parseInt(container.dataset.page, 10);
            if (!Number.isFinite(pi) || _markMissingActive[pi]) {
                _closeAnnotatedDetectionActionMenu();
                return;
            }
            if (_isAnnotatedPanInProgress(pi)) {
                _closeAnnotatedDetectionActionMenu();
                return;
            }

            const hit = _findAnnotatedDetectionHit(pi, e.clientX, e.clientY);
            if (!hit) {
                _closeAnnotatedDetectionActionMenu();
                return;
            }

            e.preventDefault();
            e.stopPropagation();
            _showAnnotatedDetectionActionMenu(pi, hit, e.clientX, e.clientY);
        } catch { /* ignore */ }
    });

    document.addEventListener('dblclick', (e) => {
        try {
            const container = e.target && e.target.closest ? e.target.closest('[id^="annotatedPageContainer_"]') : null;
            if (!container) return;

            const pi = parseInt(container.dataset.page, 10);
            if (!Number.isFinite(pi) || _markMissingActive[pi]) return;

            const hit = _findAnnotatedDetectionHit(pi, e.clientX, e.clientY);
            if (!hit) return;

            e.preventDefault();
            e.stopPropagation();
            toggleAnnotatedDetectionFromMap(hit.idx);
        } catch { /* ignore */ }
    });

    document.addEventListener('keydown', (e) => {
        if (e && e.key === 'Escape') _closeAnnotatedDetectionActionMenu();
    });

    /* ══════════════════════════════════════════════════════════════════
       Mark Missing mode — draw rectangle on annotated page to teach engine
       ══════════════════════════════════════════════════════════════════ */
    const _markMissingActive = {};

    function _syncMarkMissingInteractionLayers(pi, enabled) {
        try {
            const hotspotLayer = document.getElementById(`annotatedDetectionsHotspots_${pi}`);
            const overlayCanvas = document.getElementById(`annotatedDetectionsCanvas_${pi}`);
            const drawCanvas = document.getElementById(`markMissingCanvas_${pi}`);
            const allowDraw = !!enabled;

            if (hotspotLayer) hotspotLayer.style.pointerEvents = allowDraw ? 'none' : 'auto';
            if (overlayCanvas) overlayCanvas.style.opacity = allowDraw ? '0.5' : '1';
            if (drawCanvas) {
                drawCanvas.style.zIndex = allowDraw ? '6' : '4';
                drawCanvas.style.pointerEvents = allowDraw ? 'auto' : 'none';
                drawCanvas.style.cursor = allowDraw ? 'crosshair' : 'default';
                drawCanvas.style.touchAction = allowDraw ? 'none' : 'auto';
            }
        } catch { /* ignore */ }
    }

    function _clearMarkMissingUi(pi) {
        const container = document.getElementById(`annotatedPageContainer_${pi}`);
        const banner = document.getElementById(`markMissingBanner_${pi}`);
        const btn = document.getElementById(`btnMarkMissing_${pi}`);
        const btnAdd = document.getElementById(`btnAddMissing_${pi}`);
        const canvas = document.getElementById(`markMissingCanvas_${pi}`);
        const preview = document.getElementById(`markMissingPreview_${pi}`);

        delete _markMissingActive[pi];
        if (container) container.style.cursor = 'grab';
        _syncMarkMissingInteractionLayers(pi, false);
        if (banner) {
            banner.classList.add('hidden');
            banner.innerHTML = '<i class="fa-solid fa-info-circle me-1"></i> Draw a rectangle around equipment that was NOT detected. Click &amp; drag on the image.';
        }
        if (btn) {
            btn.classList.add('text-amber-300', 'border-amber-500/40');
            btn.classList.remove('text-amber-100', 'bg-amber-700/50', 'border-amber-400');
            btn.innerHTML = '<i class="fa-solid fa-crosshairs me-1"></i>Mark Missing';
        }
        if (btnAdd) {
            btnAdd.classList.add('text-emerald-300', 'border-emerald-500/40');
            btnAdd.classList.remove('text-emerald-100', 'bg-emerald-700/50', 'border-emerald-400');
            btnAdd.innerHTML = '<i class="fa-solid fa-plus me-1"></i>Add Missing';
        }
        if (canvas) {
            canvas.classList.add('hidden');
            canvas.style.pointerEvents = 'none';
            const ctx = canvas.getContext('2d');
            if (ctx) ctx.clearRect(0, 0, canvas.width, canvas.height);
        }
        if (preview) {
            preview.classList.add('hidden');
            preview.innerHTML = '';
            delete preview.dataset.cropDataUrl;
        }
    }

    function toggleMarkMissingMode(pi, mode) {
        const nextMode = (mode === 'memory') ? 'memory' : 'table';
        const current = _markMissingActive[pi] || '';
        if (current === nextMode) {
            _clearMarkMissingUi(pi);
            return;
        }

        _markMissingActive[pi] = nextMode;
    _closeAnnotatedDetectionActionMenu();
        const container = document.getElementById(`annotatedPageContainer_${pi}`);
        const banner = document.getElementById(`markMissingBanner_${pi}`);
        const btn = document.getElementById(`btnMarkMissing_${pi}`);
        const btnAdd = document.getElementById(`btnAddMissing_${pi}`);
        const canvas = document.getElementById(`markMissingCanvas_${pi}`);
        const preview = document.getElementById(`markMissingPreview_${pi}`);

        if (container) container.style.cursor = 'crosshair';
        if (banner) {
            banner.classList.remove('hidden');
            banner.innerHTML = nextMode === 'memory'
                ? '<i class="fa-solid fa-info-circle me-1"></i> Draw a rectangle and add it to the detections table and positive YOLO memory.'
                : '<i class="fa-solid fa-info-circle me-1"></i> Draw a rectangle and add it to the detections table only.';
        }
        if (btn) {
            if (nextMode === 'table') {
                btn.classList.remove('text-amber-300', 'border-amber-500/40');
                btn.classList.add('text-amber-100', 'bg-amber-700/50', 'border-amber-400');
                btn.innerHTML = '<i class="fa-solid fa-xmark me-1"></i>Cancel Mark';
            } else {
                btn.classList.add('text-amber-300', 'border-amber-500/40');
                btn.classList.remove('text-amber-100', 'bg-amber-700/50', 'border-amber-400');
                btn.innerHTML = '<i class="fa-solid fa-crosshairs me-1"></i>Mark Missing';
            }
        }
        if (btnAdd) {
            if (nextMode === 'memory') {
                btnAdd.classList.remove('text-emerald-300', 'border-emerald-500/40');
                btnAdd.classList.add('text-emerald-100', 'bg-emerald-700/50', 'border-emerald-400');
                btnAdd.innerHTML = '<i class="fa-solid fa-xmark me-1"></i>Cancel YOLO';
            } else {
                btnAdd.classList.add('text-emerald-300', 'border-emerald-500/40');
                btnAdd.classList.remove('text-emerald-100', 'bg-emerald-700/50', 'border-emerald-400');
                btnAdd.innerHTML = '<i class="fa-solid fa-plus me-1"></i>Add to YOLO';
            }
        }
        if (canvas) {
            const metrics = _getAnnotatedPageDisplayMetrics(pi);
            if (metrics) {
                canvas.width = metrics.displayW || 100;
                canvas.height = metrics.displayH || 100;
                const z = _annotatedPageZooms[pi] || 1;
                canvas.style.width = (canvas.width * z) + 'px';
                canvas.style.height = (canvas.height * z) + 'px';
            }
            canvas.classList.remove('hidden');
        }
        _syncMarkMissingInteractionLayers(pi, true);
        if (preview) { preview.classList.add('hidden'); preview.innerHTML = ''; }
    }

    function _addManualMissingDetection(pi, fx, fy, fw, fh, cropDataUrl, sampleId, symbolHref) {
        try {
            const rows = Array.isArray(_familyScanDetections) ? _familyScanDetections.slice(0) : [];
            const savedSampleId = (sampleId && isFinite(sampleId)) ? (sampleId | 0) : 0;
            rows.push({
                pageIndex: pi,
                x: fx,
                y: fy,
                w: fw,
                h: fh,
                thumbDataUrl: cropDataUrl || '',
                confidence: 1,
                approved: true,
                isManualAdd: true,
                sampleId: savedSampleId,
                detectTemplateSampleId: savedSampleId,
                detectTemplateSymbolHref: symbolHref || '',
                sampleIds: savedSampleId > 0 ? [savedSampleId] : []
            });
            rows.sort((a, b) => (a.pageIndex - b.pageIndex) || ((b.isManualAdd ? 1 : 0) - (a.isManualAdd ? 1 : 0)) || (b.confidence - a.confidence) || (a.y - b.y) || (a.x - b.x));
            _familyScanDetections = rows;
            try { _syncAnnotatedPageDetectionCounts(); } catch { /* ignore */ }
        } catch { /* ignore */ }
    }

    async function _refreshFamilySamplesPanel(famId) {
        try {
            const annotatedViewState = _captureAnnotatedPagesViewState();
            await loadObjectFamilies(true);
            const currentFamId = (familySelect && familySelect.value) ? parseInt(String(familySelect.value), 10) : 0;
            if (familySelect && famId > 0) familySelect.value = String(famId);
            if (_lastFamilyLearnModel && famId > 0 && (!currentFamId || currentFamId === famId)) {
                const samplesView = await _fetchFamilySamplesForPanel(famId);
                const memoryView = await _fetchFamilyYoloMemoryForPanel(famId);
                _lastFamilyLearnModel.familySamples = samplesView && Array.isArray(samplesView.samples) ? samplesView.samples : [];
                _lastFamilyLearnModel.familySampleHrefs = samplesView && Array.isArray(samplesView.samples)
                    ? [...new Set(samplesView.samples.map(s => (s && s.symbolHref != null) ? String(s.symbolHref).trim() : '').filter(Boolean))]
                    : [];
                if (samplesView && samplesView.familyName) _lastFamilyLearnModel.familyName = samplesView.familyName;
                _lastFamilyLearnModel.yoloMemory = memoryView && Array.isArray(memoryView.items) ? memoryView.items : [];
                _lastFamilyLearnModel.yoloMemoryPositiveCount = memoryView && isFinite(memoryView.positiveCount) ? (memoryView.positiveCount | 0) : 0;
                _lastFamilyLearnModel.yoloMemoryNegativeCount = memoryView && isFinite(memoryView.negativeCount) ? (memoryView.negativeCount | 0) : 0;
                _renderFamilyLearnPanel(_lastFamilyLearnModel);
                _restoreAnnotatedPagesViewState(annotatedViewState);
            }
        } catch { /* ignore */ }
    }

    // Drawing rectangle on the mark-missing canvas.
    (function bindMarkMissingDraw() {
        let drawState = null;

        document.addEventListener('pointerdown', (e) => {
            if (!e.target || !e.target.id) return;
            const m = e.target.id.match(/^markMissingCanvas_(\d+)$/);
            if (!m) return;
            const pi = parseInt(m[1], 10);
            if (!_markMissingActive[pi]) return;

            e.preventDefault();
            e.stopPropagation();
            const canvas = e.target;
            const rect = canvas.getBoundingClientRect();
            const z = _annotatedPageZooms[pi] || 1;
            const sx = canvas.width / rect.width;
            const sy = canvas.height / rect.height;
            const x0 = (e.clientX - rect.left) * sx;
            const y0 = (e.clientY - rect.top) * sy;
            drawState = { pi, canvas, x0, y0, rect, sx, sy };
        });

        document.addEventListener('pointermove', (e) => {
            if (!drawState) return;
            const { pi, canvas, x0, y0, rect, sx, sy } = drawState;
            const x1 = (e.clientX - rect.left) * sx;
            const y1 = (e.clientY - rect.top) * sy;
            const ctx = canvas.getContext('2d');
            if (!ctx) return;
            ctx.clearRect(0, 0, canvas.width, canvas.height);
            ctx.strokeStyle = '#00ff00';
            ctx.lineWidth = 3;
            ctx.setLineDash([8, 4]);
            ctx.strokeRect(Math.min(x0, x1), Math.min(y0, y1), Math.abs(x1 - x0), Math.abs(y1 - y0));
            ctx.fillStyle = 'rgba(0, 255, 0, 0.12)';
            ctx.fillRect(Math.min(x0, x1), Math.min(y0, y1), Math.abs(x1 - x0), Math.abs(y1 - y0));
        });

        document.addEventListener('pointerup', (e) => {
            if (!drawState) return;
            const { pi, canvas, x0, y0, rect, sx, sy } = drawState;
            const x1 = (e.clientX - rect.left) * sx;
            const y1 = (e.clientY - rect.top) * sy;
            drawState = null;

            const rx = Math.min(x0, x1);
            const ry = Math.min(y0, y1);
            const rw = Math.abs(x1 - x0);
            const rh = Math.abs(y1 - y0);

            // Ignore tiny drags (accidental clicks).
            if (rw < 8 || rh < 8) return;

            // Normalize to 0..1 fractions.
            const localFracX = rx / canvas.width;
            const localFracY = ry / canvas.height;
            const localFracW = rw / canvas.width;
            const localFracH = rh / canvas.height;

            const metrics = _getAnnotatedPageDisplayMetrics(pi);
            const fracX = metrics ? (metrics.cropX + (localFracX * metrics.cropW)) : localFracX;
            const fracY = metrics ? (metrics.cropY + (localFracY * metrics.cropH)) : localFracY;
            const fracW = metrics ? (localFracW * metrics.cropW) : localFracW;
            const fracH = metrics ? (localFracH * metrics.cropH) : localFracH;

            _showMarkMissingPreview(pi, fracX, fracY, fracW, fracH, _markMissingActive[pi] || 'table');
        });
    })();

    async function _showMarkMissingPreview(pi, fx, fy, fw, fh, mode) {
        const previewDiv = document.getElementById(`markMissingPreview_${pi}`);
        if (!previewDiv) return;

        const actionMode = (mode === 'memory') ? 'memory' : 'table';

        previewDiv.innerHTML = `<div class="text-[11px] text-slate-400">Preparing high-resolution crop...</div>`;
        previewDiv.classList.remove('hidden');

        const origSrc = await _getBestPdfPageSourceForSample(pi);
        if (!origSrc) {
            previewDiv.classList.add('hidden');
            previewDiv.innerHTML = '';
            return;
        }

        const cropDataUrl = await _cropDataUrlFromPageSource(origSrc, fx, fy, fw, fh);
        if (!cropDataUrl) {
            previewDiv.classList.add('hidden');
            previewDiv.innerHTML = '';
            return;
        }

        previewDiv.innerHTML = `
                <div class="flex items-start gap-3">
                    <img src="${cropDataUrl}" class="w-24 h-24 rounded-lg border border-green-500/60 bg-white object-contain" />
