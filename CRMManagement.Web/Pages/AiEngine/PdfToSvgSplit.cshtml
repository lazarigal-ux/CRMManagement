        _svgPreviewAiCandidateMarkedNodes = marked;
        _svgPreviewAiCandidateLastSvg = svg;
        _svgPreviewAiCandidateLastKey = key;
        debugInfo.marked = marked.length;
        _svgAiCandidateDebugInfo = debugInfo;
        _updateSvgAiCandidateCountUi(marked.length);
    }

    function _scheduleSvgPreviewAiCandidateHighlight() {
        if (_svgPreviewAiCandidateHighlightTimer) clearTimeout(_svgPreviewAiCandidateHighlightTimer);
        _svgPreviewAiCandidateHighlightTimer = setTimeout(() => {
            _svgPreviewAiCandidateHighlightTimer = 0;
            _applySvgPreviewAiCandidateHighlightNow().catch(() => { /* ignore */ });
        }, 80);
    }

    function _svgIsNoneish(paint) {
        const v = (paint || '').toString().trim().toLowerCase();
        return v === 'none' || v === 'transparent';
    }

    function _svgGetOpacity(el) {
        if (!el) return 1;
        const direct = el.getAttribute('opacity');
        if (direct != null && String(direct).trim() !== '') {
            const n = parseFloat(String(direct).trim());
            if (Number.isFinite(n)) return n;
        }
        const style = el.getAttribute('style') || '';
        if (style) {
            const m = String(style).match(/opacity\s*:\s*([^;]+)/i);
            if (m && (m[1] || '').trim()) {
                const n = parseFloat((m[1] || '').trim());
                if (Number.isFinite(n)) return n;
            }
        }
        return 1;
    }

    function _svgGetPaint(el, name) {
        if (!el) return '';
        const direct = el.getAttribute(name);
        if (direct && String(direct).trim() !== '') return String(direct).trim();
        const style = el.getAttribute('style') || '';
        if (style) {
            const re = new RegExp(`${name}\\s*:\\s*([^;]+)`, 'i');
            const m = String(style).match(re);
            if (m && (m[1] || '').trim()) return (m[1] || '').trim();
        }
        return '';
    }

    function _svgIsWhiteish(paint) {
        const v = (paint || '').toString().trim().toLowerCase();
        if (!v) return false;
        if (v === 'white' || v === '#fff' || v === '#ffffff') return true;
        if (v.startsWith('rgb(') || v.startsWith('rgba(')) {
            const m = v.match(/rgba?\(\s*(\d+)\s*,\s*(\d+)\s*,\s*(\d+)/i);
            if (m) {
                const r = parseInt(m[1], 10), g = parseInt(m[2], 10), b = parseInt(m[3], 10);
