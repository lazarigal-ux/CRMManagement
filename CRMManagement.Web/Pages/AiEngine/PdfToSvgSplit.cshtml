        }

        function _syncElementHighlight(el, enabled, isSeed) {
            if (enabled) {
                _saveSelectionStroke(el);
                el.classList.add(isSeed ? 'merged-svg-el-highlight' : 'merged-svg-el-cluster-highlight');
            } else {
                el.classList.remove('merged-svg-el-highlight', 'merged-svg-el-cluster-highlight', 'merged-svg-el-color-highlight');
                // Restore original stroke
                if (el.dataset.origStroke !== undefined) {
                    if (el.dataset.origStroke) el.setAttribute('stroke', el.dataset.origStroke);
                    else el.removeAttribute('stroke');
                    delete el.dataset.origStroke;
                }
                if (el.dataset.origStrokeWidth !== undefined) {
                    if (el.dataset.origStrokeWidth) el.setAttribute('stroke-width', el.dataset.origStrokeWidth);
                    else el.removeAttribute('stroke-width');
                    delete el.dataset.origStrokeWidth;
                }
            }
        }

        function _updateSelectedCount() {
            const countEl = document.getElementById('selectedObjectsCount');
            const active = _currentSelectedItems.filter(i => i.enabled).length;
            const total = _currentSelectedItems.length;
            if (countEl) countEl.textContent = total ? `(1 object • ${active}/${total} elements)` : '(0)';
            _renderSelectedObjectsHeaderSummary();
            _updateSelectedPreviewActions();
            _setGroupStatus(total
                ? `Selected 1 object with ${active}/${total} active element(s). Merge & Group will merge it as one object.`
                : 'Drag an area around one lamp, then merge it or auto-detect similar lamps.');
        }

        /* ── Normalize any CSS color to a canonical lowercase rgb/rgba string ── */
        const _colorCanvas = document.createElement('canvas');
        _colorCanvas.width = 1; _colorCanvas.height = 1;
        const _colorCtx = _colorCanvas.getContext('2d', { willReadFrequently: true });
        function _normalizeColor(c) {
            if (!c || c === 'none' || c === 'transparent' || c.startsWith('url(')) return '';
            _colorCtx.clearRect(0, 0, 1, 1);
            _colorCtx.fillStyle = '#000000';
            _colorCtx.fillStyle = c;
            _colorCtx.fillRect(0, 0, 1, 1);
            const px = _colorCtx.getImageData(0, 0, 1, 1).data;
            if (px[3] === 0) return '';
            return `rgb(${px[0]},${px[1]},${px[2]})`;
        }

        function _getElementFill(el) {
            // Try attribute first, then inline style, then getComputedStyle
            let fill = el.getAttribute('fill') || '';
            if (!fill) {
                const style = el.getAttribute('style') || '';
                const m = style.match(/(?:^|;)\s*fill\s*:\s*([^;]+)/i);
                if (m) fill = m[1].trim();
            }
            if (!fill || fill === 'none') {
                try { fill = getComputedStyle(el).fill || ''; } catch {}
            }
            return fill;
        }

        function _getElementStroke(el) {
            let stroke = el.getAttribute('stroke') || '';
            if (!stroke) {
                const style = el.getAttribute('style') || '';
                const m = style.match(/(?:^|;)\s*stroke\s*:\s*([^;]+)/i);
                if (m) stroke = m[1].trim();
            }
            if (!stroke || stroke === 'none') {
                try { stroke = getComputedStyle(el).stroke || ''; } catch {}
            }
            return stroke;
        }

        /* ── Select All Colors: scan page for same fill as clicked row, show in 2nd table ── */
        function _selectByColor() {
            console.time('[GroupObjects] _selectByColor');
            if (!mergedSvgPreviewScale) { console.warn('[GroupObjects] _selectByColor: no scale'); return; }
            const svg = mergedSvgPreviewScale.querySelector('svg');
            if (!svg) { console.warn('[GroupObjects] _selectByColor: no svg'); return; }
            const groupParams = _getGroupParams();

            // Must have a selected row in the original table
            if (_selectedColorSourceIdx < 0 || !_currentSelectedItems[_selectedColorSourceIdx]) {
                _setGroupStatus('Click a row in the Selected Objects table first, then press "Select All Colors".');
                console.warn('[GroupObjects] _selectByColor: no source row selected');
                console.timeEnd('[GroupObjects] _selectByColor');
                return;
            }

            const sourceItem = _currentSelectedItems[_selectedColorSourceIdx];
            let rawFill = _getElementFill(sourceItem.el);
            let targetColor = _normalizeColor(rawFill);
            let _matchByStroke = false;
            // If fill is empty/none, try stroke color
            if (!targetColor) {
                const rawStroke = _getElementStroke(sourceItem.el);
                targetColor = _normalizeColor(rawStroke);
                if (targetColor) {
                    rawFill = rawStroke;
                    _matchByStroke = true;
                    console.log('[GroupObjects] _selectByColor: fill empty, falling back to stroke=%s', rawStroke);
                }
            }
            if (!targetColor) {
                _setGroupStatus('The selected row has no fill or stroke color.');
                console.timeEnd('[GroupObjects] _selectByColor');
                return;
            }
            console.log('[GroupObjects] _selectByColor: sourceIdx=%d, rawColor=%s, targetColor=%s, matchBy=%s', _selectedColorSourceIdx, rawFill, targetColor, _matchByStroke ? 'stroke' : 'fill');

            const sourceBb = sourceItem.bb || _getElementBbox(sourceItem.el, svg);
            const sourceW = Math.max(0, Number(sourceBb?.w) || 0);
            const sourceH = Math.max(0, Number(sourceBb?.h) || 0);
            const sourceDiag = Math.hypot(sourceW, sourceH);
            const sourceLongest = Math.max(sourceW, sourceH, 0.0001);
            const sourceShortest = Math.max(Math.min(sourceW, sourceH), 0.0001);
            const configuredMaxDiag = Math.max(1, Number(groupParams?.maxClusterDiagonal) || 120);
            const maxDiagAllowed = sourceDiag > 0
                ? Math.min(configuredMaxDiag, Math.max(sourceDiag * 2.5, sourceDiag + 4))
                : configuredMaxDiag;
            const minDiagAllowed = sourceDiag > 0 ? Math.max(0.2, sourceDiag * 0.25) : 0;
            console.log('[GroupObjects] _selectByColor: source bbox=%o diag=%f allowed=[%f..%f]', sourceBb, sourceDiag, minDiagAllowed, maxDiagAllowed);

            // Cache SVG screen CTM inverse
            const svgSCTM = svg.getScreenCTM();
            _svgScreenCTMInv = svgSCTM ? svgSCTM.inverse() : null;

            // Clear previous color highlights (but keep blue selection highlights)
            _clearColorMatchHighlights();
            _setGroupStatus(`Scanning all shapes for ${_matchByStroke ? 'stroke' : 'fill'} ${targetColor} …`);
            const counterEl = document.getElementById('btnColorCounter');
            if (btnSelectByColor) {
                btnSelectByColor.disabled = true;
                btnSelectByColor.classList.add('btn-color-scanning');
                btnSelectByColor.innerHTML = '<i class="fa-solid fa-spinner fa-spin text-[9px]"></i> Scanning … <span id="btnColorCounter" class="ml-0.5 rounded-full bg-emerald-500/50 text-white px-1.5 py-0 text-[10px] font-bold min-w-[20px] text-center tabular-nums">0</span>';
            }
            const _ctr = () => document.getElementById('btnColorCounter');

            requestAnimationFrame(() => {
                const shapes = svg.querySelectorAll(_SHAPE_SELECTOR);
                const matched = [];
                let scanned = 0;
                let rejectedBySize = 0;
                for (const el of shapes) {
                    try { if (el.closest && el.closest('defs')) continue; } catch {}
                    scanned++;
                    const norm = _matchByStroke ? _normalizeColor(_getElementStroke(el)) : _normalizeColor(_getElementFill(el));
                    if (norm !== targetColor) continue;
                    const bb = _getElementBbox(el, svg);
                    if (!bb) continue;
                    const diag = Math.hypot(bb.w, bb.h);
                    if (diag > maxDiagAllowed || diag < minDiagAllowed) {
                        rejectedBySize++;
                        continue;
                    }

                    if (sourceDiag > 0) {
                        const longest = Math.max(bb.w, bb.h, 0.0001);
                        const shortest = Math.max(Math.min(bb.w, bb.h), 0.0001);
                        const longestRatio = longest / sourceLongest;
                        const shortestRatio = shortest / sourceShortest;
                        const diagRatio = diag / Math.max(sourceDiag, 0.0001);
                        if (longestRatio < 0.25 || longestRatio > 4.0 || shortestRatio < 0.15 || shortestRatio > 6.0 || diagRatio < 0.25 || diagRatio > 3.0) {
                            rejectedBySize++;
                            continue;
                        }
                    }

                    matched.push({ el, bb, diag, dist: 0, fullyInside: true, centerInside: true, intersects: true, fillColor: norm });
                }
                const ctrNow = _ctr(); if (ctrNow) ctrNow.textContent = matched.length;
                console.log('[GroupObjects] _selectByColor: scanned=%d, matched=%d, rejectedBySize=%d for color=%s', scanned, matched.length, rejectedBySize, targetColor);

                if (!matched.length) {
                    if (btnSelectByColor) {
                        btnSelectByColor.disabled = false;
                        btnSelectByColor.classList.remove('btn-color-scanning');
                        btnSelectByColor.innerHTML = '<i class="fa-solid fa-palette text-[9px]"></i> Select All Colors <span id="btnColorCounter" class="ml-0.5 rounded-full bg-emerald-500/30 text-emerald-200 px-1.5 py-0 text-[10px] font-bold min-w-[20px] text-center tabular-nums">0</span>';
                    }
                    _setGroupStatus(`No elements found with ${_matchByStroke ? 'stroke' : 'fill'} color ${targetColor} in the selected size range.`);
                    console.timeEnd('[GroupObjects] _selectByColor');
                    return;
                }

                // Animate green highlights in batches
                const BATCH = 200;
                let i = 0;
                function _animateBatch() {
                    const end = Math.min(i + BATCH, matched.length);
                    for (; i < end; i++) {
                        _saveSelectionStroke(matched[i].el);
                        matched[i].el.classList.add('merged-svg-el-color-highlight');
                    }
                    _setGroupStatus(`Highlighting … ${i}/${matched.length} elements with ${_matchByStroke ? 'stroke' : 'fill'} ${targetColor}`);
                    { const c = _ctr(); if (c) c.textContent = `${i}/${matched.length}`; }
                    if (i < matched.length) {
                        requestAnimationFrame(_animateBatch);
                    } else {
                        if (btnSelectByColor) {
                            btnSelectByColor.disabled = false;
                            btnSelectByColor.classList.remove('btn-color-scanning');
                            btnSelectByColor.innerHTML = '<i class="fa-solid fa-palette text-[9px]"></i> Select All Colors <span id="btnColorCounter" class="ml-0.5 rounded-full bg-emerald-500/30 text-emerald-200 px-1.5 py-0 text-[10px] font-bold min-w-[20px] text-center tabular-nums">' + matched.length + '</span>';
                        }
                        _setGroupStatus(`Found ${matched.length} element(s) with ${_matchByStroke ? 'stroke' : 'fill'} ${targetColor} (size-filtered; rejected ${rejectedBySize}).`);
                        _populateColorMatchTable(matched, targetColor, rawFill);
                        // Deactivate select mode buttons, but keep tables & highlights
                        _selectMode = false;
                        _selectDragActive = false;
                        _selectDragStartPt = null;
                        _selectDragCurrentPt = null;
                        if (btnSelectFull) btnSelectFull.classList.remove('active-select-mode');
                        if (btnSelectPartial) btnSelectPartial.classList.remove('active-select-mode');
                        if (mergedSvgPreviewViewport) mergedSvgPreviewViewport.classList.remove('select-mode');
                        console.log('[GroupObjects] _selectByColor: DONE → %d elements, select mode deactivated', matched.length);
                        console.timeEnd('[GroupObjects] _selectByColor');
                    }
                }
                requestAnimationFrame(_animateBatch);
            });
        }

        /* ── Clear only color-match highlights (green), not blue selection highlights ── */
        function _clearColorMatchHighlights() {
            if (!mergedSvgPreviewScale) return;
            mergedSvgPreviewScale.querySelectorAll('.merged-svg-el-color-highlight').forEach(el => {
                el.classList.remove('merged-svg-el-color-highlight');
                if (el.dataset.origStroke !== undefined && !el.classList.contains('merged-svg-el-highlight') && !el.classList.contains('merged-svg-el-cluster-highlight')) {
                    if (el.dataset.origStroke) el.setAttribute('stroke', el.dataset.origStroke);
                    else el.removeAttribute('stroke');
                    delete el.dataset.origStroke;
                    if (el.dataset.origStrokeWidth) el.setAttribute('stroke-width', el.dataset.origStrokeWidth);
                    else el.removeAttribute('stroke-width');
                    delete el.dataset.origStrokeWidth;
                }
            });
            _clearColorMatchTable();
        }

        /* ── Populate Color Match Table (second table) ── */
        function _populateColorMatchTable(items, normColor, rawColor) {
            const panel = document.getElementById('colorMatchPanel');
            const tbody = document.querySelector('#colorMatchTable tbody');
            const countEl = document.getElementById('colorMatchCount');
            const swatchEl = document.getElementById('colorMatchSwatch');
            const checkAll = document.getElementById('colorMatchCheckAll');
            if (!panel || !tbody) return;
            tbody.innerHTML = '';
            _colorMatchItems = items.map(item => ({ ...item, enabled: true }));
            panel.classList.remove('hidden');
            if (countEl) countEl.textContent = `(${items.length})`;
            if (swatchEl) { swatchEl.style.display = 'inline-block'; swatchEl.style.background = rawColor || normColor; }

            const _esc = s => { const d = document.createElement('span'); d.textContent = s; return d.innerHTML; };

            items.forEach((item, idx) => {
                const el = item.el;
                const tag = el.tagName.toLowerCase();
                const fill = el.getAttribute('fill') || rawColor || '';
                const bb = item.bb;
                const bboxStr = bb ? `${bb.x.toFixed(1)}, ${bb.y.toFixed(1)}, ${bb.w.toFixed(1)}, ${bb.h.toFixed(1)}` : '';

                const tr = document.createElement('tr');
                tr.dataset.idx = idx;

                const cb = document.createElement('input');
                cb.type = 'checkbox'; cb.checked = true; cb.title = 'Include/exclude';
                cb.style.cssText = 'accent-color:#22c55e;width:13px;height:13px;cursor:pointer';
                const cbTd = document.createElement('td');
                cbTd.appendChild(cb);

                tr.innerHTML =
                    `<td class="sel-idx">${idx + 1}</td>` +
                    `<td class="sel-tag">&lt;${_esc(tag)}&gt;</td>` +
                    `<td><span class="sel-color-swatch" style="background:${_esc(fill || 'transparent')}"></span>${_esc(fill || '—')}</td>` +
                    `<td class="sel-dim">${_esc(bboxStr)}</td>` +
                    `<td></td>`;
                tr.insertBefore(cbTd, tr.firstChild);

                // Delete button
                const delBtn = document.createElement('button');
                delBtn.className = 'sel-del-btn';
                delBtn.title = 'Delete from SVG';
                delBtn.innerHTML = '<i class="fa-solid fa-trash-can"></i>';
                delBtn.addEventListener('click', (e) => { e.stopPropagation(); _deleteColorMatchItem(idx); });
                tr.lastElementChild.appendChild(delBtn);

                // Checkbox toggle
                cb.addEventListener('change', () => {
                    _colorMatchItems[idx].enabled = cb.checked;
                    tr.classList.toggle('sel-obj-disabled', !cb.checked);
                    if (cb.checked) { _saveSelectionStroke(el); el.classList.add('merged-svg-el-color-highlight'); }
                    else { el.classList.remove('merged-svg-el-color-highlight'); }
                    _updateColorMatchCount();
                });

                // Hover
                tr.addEventListener('mouseenter', () => { tr.classList.add('sel-obj-highlight'); try { el.style.outline = '2px solid #22c55e'; el.style.outlineOffset = '1px'; } catch {} });
                tr.addEventListener('mouseleave', () => { tr.classList.remove('sel-obj-highlight'); try { el.style.outline = ''; el.style.outlineOffset = ''; } catch {} });
                tbody.appendChild(tr);
            });

            if (checkAll) {
                checkAll.checked = true;
                checkAll.onchange = () => {
                    const checked = checkAll.checked;
                    const BATCH = 300;
                    const cbs = [...tbody.querySelectorAll('input[type="checkbox"]')];
                    const toToggle = cbs.filter(c => c.checked !== checked);
                    if (!toToggle.length) return;
                    _setGroupStatus(`${checked ? 'Selecting' : 'Deselecting'} ${toToggle.length} items …`);
                    let i = 0;
                    function _batchToggle() {
                        const end = Math.min(i + BATCH, toToggle.length);
                        for (; i < end; i++) {
                            const c = toToggle[i];
                            c.checked = checked;
                            const row = c.closest('tr');
                            const ridx = row ? parseInt(row.dataset.idx) : -1;
                            if (ridx >= 0 && _colorMatchItems[ridx]) {
                                _colorMatchItems[ridx].enabled = checked;
                                if (row) row.classList.toggle('sel-obj-disabled', !checked);
                                const mel = _colorMatchItems[ridx].el;
                                if (checked) { _saveSelectionStroke(mel); mel.classList.add('merged-svg-el-color-highlight'); }
                                else { mel.classList.remove('merged-svg-el-color-highlight'); }
                            }
                        }
                        _setGroupStatus(`${checked ? 'Selecting' : 'Deselecting'} … ${i}/${toToggle.length}`);
                        if (i < toToggle.length) {
                            requestAnimationFrame(_batchToggle);
                        } else {
                            _updateColorMatchCount();
                            const active = _colorMatchItems.filter(x => x && x.enabled).length;
                            _setGroupStatus(`${active} element(s) ${checked ? 'highlighted' : 'unhighlighted'} on map.`);
                        }
                    }
                    requestAnimationFrame(_batchToggle);
                };
            }
        }

        function _clearColorMatchTable() {
            const panel = document.getElementById('colorMatchPanel');
            const tbody = document.querySelector('#colorMatchTable tbody');
            if (tbody) tbody.innerHTML = '';
            if (panel) panel.classList.add('hidden');
            _colorMatchItems = [];
        }

        function _updateColorMatchCount() {
            const countEl = document.getElementById('colorMatchCount');
            const active = _colorMatchItems.filter(i => i && i.enabled).length;
            const total = _colorMatchItems.filter(i => i !== null).length;
            if (countEl) countEl.textContent = `(${active}/${total})`;
        }

        function _deleteColorMatchItem(idx, skipSync) {
            if (idx < 0 || idx >= _colorMatchItems.length) return;
            const item = _colorMatchItems[idx];
            if (!item) return;
            item.el.classList.remove('merged-svg-el-color-highlight');
            try { item.el.style.outline = ''; } catch {}
            try { item.el.parentNode && item.el.parentNode.removeChild(item.el); } catch {}
            const tbody = document.querySelector('#colorMatchTable tbody');
            if (tbody) { const row = tbody.querySelector(`tr[data-idx="${idx}"]`); if (row) row.remove(); }
            _colorMatchItems[idx] = null;
            if (!skipSync) {
                _syncMergedSvgAfterDelete();
                _clearObjectSelectionState('Selection cleared after delete.');
            }
        }

        function _deleteCheckedColorMatchItems() {
            const toDelete = [];
            _colorMatchItems.forEach((item, idx) => { if (item && item.enabled) toDelete.push(idx); });
            if (!toDelete.length) { _setGroupStatus('No checked items to delete.'); return; }
            if (!confirm(`Delete ${toDelete.length} color-matched element(s) from the SVG?`)) return;

            const btnDel = document.getElementById('btnDeleteColorMatchObjects');
            if (btnDel) { btnDel.disabled = true; btnDel.classList.add('btn-delete-working'); btnDel.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Deleting …'; }

            const BATCH = 200;
            let i = 0;
            function _batchDelete() {
                const end = Math.min(i + BATCH, toDelete.length);
                for (; i < end; i++) {
                    const idx = toDelete[i];
                    const item = _colorMatchItems[idx];
                    if (!item) continue;
                    item.el.classList.remove('merged-svg-el-color-highlight');
                    try { item.el.style.outline = ''; } catch {}
                    try { item.el.parentNode && item.el.parentNode.removeChild(item.el); } catch {}
                    _colorMatchItems[idx] = null;
                }
                _setGroupStatus(`Deleting … ${i}/${toDelete.length}`);
                if (i < toDelete.length) {
                    requestAnimationFrame(_batchDelete);
                } else {
                    // Clear table rows in one shot, update count, serialize once
                    const tbody = document.querySelector('#colorMatchTable tbody');
                    if (tbody) {
                        for (const didx of toDelete) {
                            const row = tbody.querySelector(`tr[data-idx="${didx}"]`);
                            if (row) row.remove();
                        }
                    }
                    _syncMergedSvgAfterDelete();
                    if (btnDel) { btnDel.disabled = false; btnDel.classList.remove('btn-delete-working'); btnDel.innerHTML = '<i class="fa-solid fa-trash-can"></i> Delete Matched'; }
                    _clearObjectSelectionState(`Deleted ${toDelete.length} color-matched element(s). Selection cleared.`);
                    console.log('[GroupObjects] _deleteCheckedColorMatchItems: deleted %d elements', toDelete.length);
                }
            }
            requestAnimationFrame(_batchDelete);
        }

        /** Returns only enabled items from current selection (for backend calls) */
        function _getActiveSelectedItems() {
            return _currentSelectedItems.filter(i => i.enabled);
        }

        function _clearSelectedObjectsTable() {
            const panel = document.getElementById('selectedObjectsPanel');
            const tbody = document.querySelector('#selectedObjectsTable tbody');
            const countEl = document.getElementById('selectedObjectsCount');
            if (tbody) tbody.innerHTML = '';
            if (countEl) countEl.textContent = '(0)';
            if (panel) panel.classList.add('hidden');
            _renderSelectedObjectsHeaderSummary();
            _updateSelectedPreviewActions();
        }

        function _highlightNearbyElements(seedEl) {
            if (!mergedSvgPreviewScale) return;
            const svg = mergedSvgPreviewScale.querySelector('svg');
            if (!svg) return;
            const seedBbox = _getElementBbox(seedEl);
            if (!seedBbox) return;

            _selectedSeedBbox = seedBbox;
            if (btnMergeSelected) btnMergeSelected.disabled = false;

            const params = _getGroupParams();
            const radius = params.proximityRadius;
            const maxDiag = params.maxClusterDiagonal;

            // Find all nearby elements using expanded bbox
            const shapes = svg.querySelectorAll(_SHAPE_SELECTOR);
            const cluster = [];
            let minX = Infinity, minY = Infinity, maxX = -Infinity, maxY = -Infinity;

            for (const el of shapes) {
                try { if (el.closest && el.closest('defs')) continue; } catch { /* ignore */ }
                const bb = _getElementBbox(el);
                if (!bb) continue;
                // Check if this element's bbox is near any element already in cluster
                const dx = Math.max(0, Math.max(seedBbox.x - (bb.x + bb.w), bb.x - (seedBbox.x + seedBbox.w)));
                const dy = Math.max(0, Math.max(seedBbox.y - (bb.y + bb.h), bb.y - (seedBbox.y + seedBbox.h)));
                const dist = Math.hypot(dx, dy);
                if (dist <= radius) {
                    cluster.push(el);
                    minX = Math.min(minX, bb.x);
                    minY = Math.min(minY, bb.y);
                    maxX = Math.max(maxX, bb.x + bb.w);
                    maxY = Math.max(maxY, bb.y + bb.h);
                }
            }

            // Expand cluster: iteratively add elements near any cluster member
            let changed = true;
            const clusterSet = new Set(cluster);
            while (changed) {
                changed = false;
                for (const el of shapes) {
                    if (clusterSet.has(el)) continue;
                    try { if (el.closest && el.closest('defs')) continue; } catch { /* ignore */ }
                    const bb = _getElementBbox(el);
                    if (!bb) continue;
                    for (const member of clusterSet) {
                        const mbb = _getElementBbox(member);
                        if (!mbb) continue;
                        const dx2 = Math.max(0, Math.max(mbb.x - (bb.x + bb.w), bb.x - (mbb.x + mbb.w)));
                        const dy2 = Math.max(0, Math.max(mbb.y - (bb.y + bb.h), bb.y - (mbb.y + mbb.h)));
                        if (Math.hypot(dx2, dy2) <= radius) {
                            clusterSet.add(el);
                            minX = Math.min(minX, bb.x);
                            minY = Math.min(minY, bb.y);
                            maxX = Math.max(maxX, bb.x + bb.w);
                            maxY = Math.max(maxY, bb.y + bb.h);
                            changed = true;
                            break;
                        }
                    }
                }
            }

            // Check size constraint
            const clusterDiag = Math.hypot(maxX - minX, maxY - minY);
            if (clusterDiag > maxDiag) {
                _setGroupStatus(`Cluster too large (${Math.round(clusterDiag)} > ${maxDiag}). Reduce proximity or increase max size.`);
            }

            // Highlight elements – save original stroke so we can restore later
            _saveSelectionStroke(seedEl);
            seedEl.classList.add('merged-svg-el-highlight');
            for (const el of clusterSet) {
                if (el !== seedEl) {
                    _saveSelectionStroke(el);
                    el.classList.add('merged-svg-el-cluster-highlight');
                }
            }

            // Draw cluster bounding rect
            if (clusterSet.size > 0 && isFinite(minX)) {
                const rectEl = document.createElementNS('http://www.w3.org/2000/svg', 'rect');
                rectEl.setAttribute('x', String(minX - 2));
                rectEl.setAttribute('y', String(minY - 2));
                rectEl.setAttribute('width', String(maxX - minX + 4));
                rectEl.setAttribute('height', String(maxY - minY + 4));
                rectEl.classList.add('merged-svg-cluster-rect');
                svg.appendChild(rectEl);
            }

            // Update seed bbox to cover entire cluster
            if (isFinite(minX)) {
                _selectedSeedBbox = { x: minX, y: minY, w: maxX - minX, h: maxY - minY };
            }

            _setGroupStatus(`Selected cluster: ${clusterSet.size} element(s), diagonal ${Math.round(clusterDiag)} SVG units.`);
        }

        function _beginMergedSvgAreaSelection(e) {
            console.log('[GroupObjects] _beginMergedSvgAreaSelection: selectMode=%s, busy=%s, hasSvg=%s, target=%s', _selectMode, _groupBusy, !!_pdfPreSplitMergedSvg, e.target?.tagName);
            if (!_selectMode || _groupBusy || !_pdfPreSplitMergedSvg || !mergedSvgPreviewViewport) return;
            if (e.button !== 0) return;
            const tag = (e.target && e.target.tagName ? e.target.tagName : '').toLowerCase();
            if (tag === 'button' || tag === 'select' || tag === 'input' || tag === 'option') return;
            const startPt = _getSvgCoords(e.clientX, e.clientY);
            if (!startPt) { console.warn('[GroupObjects] _beginMergedSvgAreaSelection: _getSvgCoords returned null'); return; }
            _selectDragActive = true;
            _selectDragStartPt = startPt;
            _selectDragCurrentPt = startPt;
            _updateSelectionRect(_normalizeSvgBbox(startPt, startPt));
            console.log('[GroupObjects] _beginMergedSvgAreaSelection: STARTED drag at svg(%f,%f)', startPt.x, startPt.y);
            e.preventDefault();
            e.stopPropagation();
        }

        function _moveMergedSvgAreaSelection(e) {
            if (!_selectMode || !_selectDragActive) return;
            const currentPt = _getSvgCoords(e.clientX, e.clientY);
            if (!currentPt) return;
            _selectDragCurrentPt = currentPt;
            _updateSelectionRect(_normalizeSvgBbox(_selectDragStartPt, currentPt));
            e.preventDefault();
        }

        function _finishMergedSvgAreaSelection(e) {
            console.log('[GroupObjects] _finishMergedSvgAreaSelection: dragActive=%s', _selectDragActive);
            if (!_selectDragActive) return;
            const currentPt = (e && isFinite(e.clientX) && isFinite(e.clientY))
                ? (_getSvgCoords(e.clientX, e.clientY) || _selectDragCurrentPt || _selectDragStartPt)
                : (_selectDragCurrentPt || _selectDragStartPt);
            let bbox = _normalizeSvgBbox(_selectDragStartPt, currentPt || _selectDragStartPt);
            console.log('[GroupObjects] _finishMergedSvgAreaSelection: startPt=%o, endPt=%o, bbox=%o', _selectDragStartPt, currentPt, bbox);
            _selectDragActive = false;
            _selectDragCurrentPt = null;
            _selectDragStartPt = null;
            _removeSelectionRect();
            if (!bbox) { console.warn('[GroupObjects] _finishMergedSvgAreaSelection: bbox is null, aborting'); return; }

            const minWorldSize = Math.max(4, 10 / Math.max(_mergedSvgZoom || 1, 0.1));
            console.log('[GroupObjects] _finishMergedSvgAreaSelection: raw bbox w=%f h=%f, minWorldSize=%f, zoom=%f', bbox.w, bbox.h, minWorldSize, _mergedSvgZoom);
            if (bbox.w < minWorldSize) {
                bbox.x -= (minWorldSize - bbox.w) / 2;
                bbox.w = minWorldSize;
            }
            if (bbox.h < minWorldSize) {
                bbox.y -= (minWorldSize - bbox.h) / 2;
                bbox.h = minWorldSize;
            }
            console.log('[GroupObjects] _finishMergedSvgAreaSelection: adjusted bbox=%o → calling _selectElementsInArea', bbox);

            _suppressNextSelectClick = true;
            _selectElementsInArea(bbox);
            if (e) e.preventDefault();
        }

        function _cancelMergedSvgAreaSelection() {
            if (!_selectDragActive) return;
            _selectDragActive = false;
            _selectDragStartPt = null;
            _selectDragCurrentPt = null;
            _removeSelectionRect();
        }

        function _onMergedSvgClick(e) {
            if (!_selectMode || _groupBusy) return;
            if (_suppressNextSelectClick) {
                _suppressNextSelectClick = false;
                e.preventDefault();
                e.stopPropagation();
                return;
            }

            e.preventDefault();
            e.stopPropagation();
            if (!_selectedSeedBbox) {
                _setGroupStatus('Select Mode now works by area: drag a small box around one lamp/object.');
            }
        }

        async function _mergeSelectedCluster(options) {
            const opts = options || {};
            const sameIconGroup = !!opts.sameIconGroup;
            console.log('[GroupObjects] _mergeSelectedCluster: seedBbox=%o, hasSvg=%s, busy=%s', _selectedSeedBbox, !!_pdfPreSplitMergedSvg, _groupBusy);
            if (!_selectedSeedBbox || !_pdfPreSplitMergedSvg || _groupBusy) return;
            _groupBusy = true;
            console.time('[GroupObjects] mergeSelectedCluster');
            const activeItems = _getActiveSelectedItems();
            const prevHtml = btnMergeSelected ? btnMergeSelected.innerHTML : '';
            if (btnMergeSelected) {
                btnMergeSelected.disabled = true;
                btnMergeSelected.innerHTML = '<i class="fa-solid fa-spinner fa-spin text-[9px]"></i> Grouping...';
            }
            if (btnSaveGroup) {
                btnSaveGroup.disabled = true;
            }
            _setGroupStatus(sameIconGroup
                ? `Creating 1 same-icon group from ${activeItems.length} element(s)...`
                : `Merging 1 selected object (${activeItems.length} element(s)) to group...`);

            try {
                const params = _getGroupParams();
                // 5-minute abort timeout for large SVGs
                const abortCtrl = new AbortController();
                const abortTimer = setTimeout(() => abortCtrl.abort(), 5 * 60 * 1000);
                console.log('[GroupObjects] _mergeSelectedCluster: sending POST svgLen=%d, seedBbox=%o', _pdfPreSplitMergedSvg.length, _selectedSeedBbox);
                const resp = await fetch(GROUP_OBJ_ENDPOINT, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    signal: abortCtrl.signal,
                    body: JSON.stringify({
                        svgContent: _pdfPreSplitMergedSvg,
                        seedBbox: _selectedSeedBbox,
                        selectionMode: _selectedSeedMode || 'cluster-seed',
                        groupName: params.groupName,
                        sameIconGroup,
                        sourceElementCount: activeItems.length,
                        proximityRadius: params.proximityRadius,
                        autoDetectAll: false,
                        minClusterElements: params.minClusterElements,
                        maxClusterDiagonal: params.maxClusterDiagonal,
                        similarityThreshold: params.similarityThreshold
                    })
                });
                clearTimeout(abortTimer);
                if (!resp.ok) {
                    const errText = await resp.text();
                    throw new Error(`HTTP ${resp.status}: ${String(errText || '').slice(0, 300)}`);
                }
                const data = await resp.json();
                if (!data.ok) throw new Error(data.error || data.message || 'Group failed');

                _lastGroupClusters = data.clusters || [];
                _pdfPreSplitMergedSvg = String(data.svgContent || _pdfPreSplitMergedSvg);
                _pdfPreSplitMergedLegend = _analyzeMergedSvgLegend(_pdfPreSplitMergedSvg);
                _pdfPreSplitMergedFilterTags = _pdfPreSplitMergedLegend.map(item => item.tag);
                _renderPreSplitMergedPreview();
                _selectedSeedBbox = null;
                _selectedSeedMode = '';
                _lastCreatedGroupInfo = (Array.isArray(data.clusters) && data.clusters[0] && data.clusters[0].id)
                    ? {
                        id: String(data.clusters[0].id),
                        groupName: params.groupName,
                        elementCount: data.elementsGrouped || activeItems.length
                    }
                    : null;
                _renderSelectedObjectsHeaderSummary();
                _updateSelectedPreviewActions();

                const msg = sameIconGroup
                    ? `Created 1 same-icon group [${params.groupName}]${_getSelectedFamilyId() ? ` · family selected: ${_getSelectedFamilyName()}` : ''}`
                    : `Grouped ${data.elementsGrouped || 0} elements into ${data.groupsCreated || 0} group(s) [${params.groupName}]`;
                _setGroupStatus(msg);
                _showGroupResult(msg);
                console.log('[GroupObjects] merge selected result:', data);
                console.timeEnd('[GroupObjects] mergeSelectedCluster');
            } catch (ex) {
                _setGroupStatus(`Error: ${ex.message}`);
                console.error('[GroupObjects] merge error:', ex);
                console.timeEnd('[GroupObjects] mergeSelectedCluster');
            } finally {
                _groupBusy = false;
                if (btnMergeSelected) {
                    btnMergeSelected.innerHTML = prevHtml || '<i class="fa-solid fa-object-group text-[9px]"></i> Merge & Group';
                    btnMergeSelected.disabled = !_selectedSeedBbox;
                }

                _updateSelectedPreviewActions();
            }
        }

        async function _autoDetectAllLamps() {
            console.log('[GroupObjects] _autoDetectAllLamps: hasSvg=%s, busy=%s, seedBbox=%o, seedMode=%s', !!_pdfPreSplitMergedSvg, _groupBusy, _selectedSeedBbox, _selectedSeedMode);
            if (!_pdfPreSplitMergedSvg || _groupBusy) return;
            _groupBusy = true;
            console.time('[GroupObjects] autoDetectAllLamps');
            const prevHtml = btnAutoDetect ? btnAutoDetect.innerHTML : '';
            if (btnAutoDetect) {
                btnAutoDetect.disabled = true;
                btnAutoDetect.innerHTML = '<i class="fa-solid fa-spinner fa-spin text-[9px]"></i> Detecting...';
            }
            _setGroupStatus('Auto-detecting all lamp clusters...');

            try {
                const params = _getGroupParams();
                const body = {
                    svgContent: _pdfPreSplitMergedSvg,
                    groupName: params.groupName,
                    proximityRadius: params.proximityRadius,
                    autoDetectAll: true,
                    minClusterElements: params.minClusterElements,
                    maxClusterDiagonal: params.maxClusterDiagonal,
                    similarityThreshold: params.similarityThreshold
                };

                // If user already selected a seed, use it for similarity matching
                if (_selectedSeedBbox) {
                    body.seedBbox = _selectedSeedBbox;
                    body.selectionMode = _selectedSeedMode || 'cluster-seed';
                }

                const abortCtrl = new AbortController();
                const abortTimer = setTimeout(() => abortCtrl.abort(), 5 * 60 * 1000);
                const resp = await fetch(GROUP_OBJ_ENDPOINT, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    signal: abortCtrl.signal,
                    body: JSON.stringify(body)
                });
                clearTimeout(abortTimer);
                if (!resp.ok) {
                    const errText = await resp.text();
                    throw new Error(`HTTP ${resp.status}: ${String(errText || '').slice(0, 300)}`);
                }
                const data = await resp.json();
                if (!data.ok) throw new Error(data.error || data.message || 'Auto-detect failed');

                _lastGroupClusters = data.clusters || [];
                _pdfPreSplitMergedSvg = String(data.svgContent || _pdfPreSplitMergedSvg);
                _pdfPreSplitMergedLegend = _analyzeMergedSvgLegend(_pdfPreSplitMergedSvg);
                _pdfPreSplitMergedFilterTags = _pdfPreSplitMergedLegend.map(item => item.tag);
                _renderPreSplitMergedPreview();
                _selectedSeedBbox = null;
                _selectedSeedMode = '';

                // Draw cluster overlay rectangles on the rendered SVG
                _drawGroupOverlays(_lastGroupClusters);

                const msg = `Auto-detected ${data.groupsCreated || 0} lamp group(s) with ${data.elementsGrouped || 0} elements [${params.groupName}]`;
                _setGroupStatus(msg);
                _showGroupResult(msg);
                console.log('[GroupObjects] auto-detect result:', data);
                console.timeEnd('[GroupObjects] autoDetectAllLamps');
            } catch (ex) {
                _setGroupStatus(`Error: ${ex.message}`);
                console.error('[GroupObjects] auto-detect error:', ex);
                console.timeEnd('[GroupObjects] autoDetectAllLamps');
            } finally {
                _groupBusy = false;
                if (btnAutoDetect) {
                    btnAutoDetect.innerHTML = prevHtml || '<i class="fa-solid fa-wand-magic-sparkles text-[9px]"></i> Auto-detect All Lamps';
                    btnAutoDetect.disabled = !_pdfPreSplitMergedSvg;
                }
            }
        }

        function _drawGroupOverlays(clusters) {
            if (!mergedSvgPreviewScale || !clusters || !clusters.length) return;
            const svg = mergedSvgPreviewScale.querySelector('svg');
            if (!svg) return;
            for (const cl of clusters) {
                const rectEl = document.createElementNS('http://www.w3.org/2000/svg', 'rect');
                rectEl.setAttribute('x', String(cl.x - 2));
                rectEl.setAttribute('y', String(cl.y - 2));
                rectEl.setAttribute('width', String(cl.w + 4));
                rectEl.setAttribute('height', String(cl.h + 4));
                rectEl.classList.add('merged-svg-group-rect');
                svg.appendChild(rectEl);
            }
        }

        // Listen for mergedSvgReady event to enable buttons immediately
        document.addEventListener('mergedSvgReady', (e) => {
            const hasSvg = !!(e.detail && e.detail.hasSvg);
            _enableGroupButtons(hasSvg);
        });

        // Wire up event listeners
        btnSelectFull?.addEventListener('click', () => _toggleSelectMode(true));
        btnSelectPartial?.addEventListener('click', () => _toggleSelectMode(false));
        btnMergeSelected?.addEventListener('click', () => _mergeSelectedCluster());
        btnSaveGroup?.addEventListener('click', () => _saveCreatedGroupToFamily());
        btnSelectByColor?.addEventListener('click', _selectByColor);
        btnAutoDetect?.addEventListener('click', _autoDetectAllLamps);
        groupNameSelect?.addEventListener('change', () => _onGroupTypeSelectChanged());
        document.getElementById('btnDeleteSelectedObjects')?.addEventListener('click', _deleteSelectedFromSvg);
        document.getElementById('btnDeleteColorMatchObjects')?.addEventListener('click', _deleteCheckedColorMatchItems);

        // Click handler for element selection in merged SVG viewport
        if (mergedSvgPreviewViewport) {
            mergedSvgPreviewViewport.addEventListener('mousedown', _beginMergedSvgAreaSelection);
            mergedSvgPreviewViewport.addEventListener('click', _onMergedSvgClick);
        }

        window.addEventListener('mousemove', _moveMergedSvgAreaSelection);
        window.addEventListener('mouseup', _finishMergedSvgAreaSelection);
        window.addEventListener('blur', _cancelMergedSvgAreaSelection);

        // Enable/disable group buttons when merged SVG changes
        // Use MutationObserver on the viewport to detect SVG content changes
        if (mergedSvgPreviewScale) {
            const _groupObserver = new MutationObserver(() => {
                _enableGroupButtons(!!_pdfPreSplitMergedSvg);
            });
            _groupObserver.observe(mergedSvgPreviewScale, { childList: true, subtree: false });
        }

        // Also poll periodically to catch any missed state changes (e.g. tab switch)
        setInterval(() => {
