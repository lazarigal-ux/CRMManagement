    function _inferFamilyTypeKeyByName(name) {
        const s = (name || '').toString().trim().toLowerCase();
        if (!s) return 'other';
        if (/(צבע|color|colour)/i.test(s)) return 'color';
        if (/(טקסט|כתב|text|label|labels)/i.test(s)) return 'text';
        if (/(חרום|חירום|emergency|exit)/i.test(s)) return 'emergency-lighting';
        if (/(תאורה|lighting|light|lamp|luminaire)/i.test(s)) return 'lighting';
        if (/(מצלמ|camera|cctv|video)/i.test(s)) return 'camera';
        if (/(גלא|עשן|אש|alarm|detector|fire|heat|horn|siren|sensor)/i.test(s)) return 'fire-detection';
        if (/(suppression|sprinkler|exting|כיבוי|מטף)/i.test(s)) return 'suppression';
        if (/(access|door|entry|בקרת|כניסה)/i.test(s)) return 'access-control';
        if (/(intrusion|burglar|burglary|pir|motion|reed|magnet|פריצה|אזעקת פריצה|אבטחה)/i.test(s)) return 'intrusion';
        if (/(intercom|voice|communication|כריזה|תקשורת)/i.test(s)) return 'communication';
        if (/(automation|control|בקרה|פיקוד)/i.test(s)) return 'automation';
        return 'other';
    }

    function _getFamilyTypeMeta(typeKey, familyName) {
        const key = _normalizeFamilyTypeKey(typeKey) || _inferFamilyTypeKeyByName(familyName);
        return FAMILY_TYPE_META[key] || FAMILY_TYPE_META.other;
    }

    function _normalizeFamilySymbolKeyForMeta(meta, rawSymbolKey) {
        const raw = String(rawSymbolKey || '').trim().toLowerCase();
        const choices = Array.isArray(meta && meta.familySymbols) ? meta.familySymbols : [];
        if (raw && choices.includes(raw)) return raw;
        return (meta && meta.primarySymbol) ? meta.primarySymbol : 'generic';
    }

    function _getFamilySymbolKey(typeKey, familyName, rawSymbolKey) {
        const meta = _getFamilyTypeMeta(typeKey, familyName);
        return _normalizeFamilySymbolKeyForMeta(meta, rawSymbolKey);
    }

    function _findFamilyRecordByIdOrName(familyId, familyName) {
        const famId = Number.isFinite(Number(familyId)) && Number(familyId) > 0 ? (Number(familyId) | 0) : 0;
        const safeName = String(familyName || '').trim().toLowerCase();
        if (!Array.isArray(_objectFamilies) || !_objectFamilies.length) return null;
        return _objectFamilies.find(f => {
            const idOk = famId > 0 && Number(f && f.id) === famId;
            const nameOk = !!safeName && String(f && f.name || '').trim().toLowerCase() === safeName;
            return idOk || nameOk;
        }) || null;
    }

    function _getSelectedFamilyRecord() {
        const famId = _getSelectedFamilyId();
        return Array.isArray(_objectFamilies) ? (_objectFamilies.find(f => Number(f && f.id) === famId) || null) : null;
    }

