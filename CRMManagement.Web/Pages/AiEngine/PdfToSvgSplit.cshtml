                const img = (item && item.imageDataUrl) ? String(item.imageDataUrl) : '';
                const itemId = JSON.stringify(itemIdRaw);
                const kindArg = JSON.stringify(kind);
                const targetKindArg = JSON.stringify(targetKind);
                const created = (item && item.createdAtUtc) ? String(item.createdAtUtc).replace('T', ' ').substring(0, 19) : '';
                const hasLabel = !!(item && item.hasLabel);
                const trainingRunNumber = (item && isFinite(item.trainingRunNumber)) ? (Number(item.trainingRunNumber) | 0) : 0;
                return `<div class="rounded-2xl border border-slate-600/40 bg-slate-900/35 p-3 shadow-[0_10px_30px_-18px_rgba(15,23,42,.85)]">
                            <div class="flex items-center gap-2">
                                ${displayIndex > 0 ? `<span class="rounded-full border border-sky-500/30 bg-sky-900/20 px-2 py-0.5 text-[10px] font-semibold text-sky-200">#${displayIndex}</span>` : ''}
