        /* ── Back to thumbnails ── */
        function _backToInlineGroupThumbnails() {
            const lastCreatedWrap = document.getElementById('mergedSvgLastCreatedGroupPreview');
            if (!lastCreatedWrap || !_inlineGroupObjects.length) return;
            _renderInlineGroupThumbnails(lastCreatedWrap, _inlineGroupObjects, _inlineGroupObjectsGroupType);
        }

        /* ── Delete an object inline and refresh ── */
        async function _deleteInlineGroupObject(sampleId) {
            const famId = _getSelectedFamilyId();
            if (!famId) { cgAlert('No family found.'); return; }
            if (!confirm('Delete this object?')) return;
            try {
                const resp = await fetch(`${OBJECT_FAMILIES_ENDPOINT}/${encodeURIComponent(famId)}/samples/${encodeURIComponent(sampleId)}`, { method: 'DELETE' });
                if (!resp.ok) throw new Error(await resp.text());
                // Remove from local array
                _inlineGroupObjects = _inlineGroupObjects.filter(s => !s || (s.id | 0) !== (sampleId | 0));
                // Refresh the view
                const lastCreatedWrap = document.getElementById('mergedSvgLastCreatedGroupPreview');
                if (!lastCreatedWrap) return;
                if (_inlineGroupObjects.length > 0) {
                    _renderInlineGroupThumbnails(lastCreatedWrap, _inlineGroupObjects, _inlineGroupObjectsGroupType);
                } else {
                    lastCreatedWrap.innerHTML = '<div style="display:flex;align-items:center;gap:8px;padding:8px 10px;border-radius:8px;border:1px solid rgba(100,116,139,0.3);background:rgba(15,23,42,0.4);margin-top:6px;font-size:11px;color:#94a3b8;"><i class="fa-regular fa-folder-open"></i> No saved objects for <strong style="color:#fff;">' + escapeHtml(_inlineGroupObjectsGroupType) + '</strong></div>';
                }
            } catch (e) {
                cgAlert('Delete failed: ' + String(e));
            }
        }

        /* ── Extract normalized path d-values from a sample SVG for matching ── */
        /**
         * Extract position-independent signatures from a sample SVG.
         * For each path, we compute a "delta" signature: the path commands with
         * coordinates relative to the first point (translated to 0,0).
         * This allows matching the same shape at any position on the map.
         */
        function _extractSamplePathSignatures(svgText) {
            const sigs = [];
            if (!svgText) return sigs;
            try {
                const doc = new DOMParser().parseFromString(svgText, 'image/svg+xml');
                if (doc.querySelector('parsererror')) { console.warn('[SearchObj] parsererror in sample SVG'); return sigs; }
                const svg = doc.querySelector('svg');
                if (!svg) { console.warn('[SearchObj] no <svg> in sample'); return sigs; }
                sigs._pathFeatures = [];

                // ── Object size from viewBox (most reliable — getBBox fails in DOMParser docs) ──
                let objW = 0, objH = 0;
                let objX = 0, objY = 0;
                const vbAttr = svg.getAttribute('viewBox');
                if (vbAttr) {
                    const vbParts = vbAttr.trim().split(/[\s,]+/).map(Number);
                    if (vbParts.length >= 4 && isFinite(vbParts[2]) && isFinite(vbParts[3])) {
                        objX = vbParts[0] || 0;
                        objY = vbParts[1] || 0;
                        objW = vbParts[2];
                        objH = vbParts[3];
                    }
                }
                // Fallback: width/height attributes
                if (objW <= 0 || objH <= 0) {
                    const wAttr = parseFloat(svg.getAttribute('width') || '0');
                    const hAttr = parseFloat(svg.getAttribute('height') || '0');
                    if (wAttr > 0 && hAttr > 0) { objW = wAttr; objH = hAttr; }
                }
                // Last resort: coordinate scan
                if (objW <= 0 || objH <= 0) {
                    let mnX = Infinity, mnY = Infinity, mxX = -Infinity, mxY = -Infinity;
                    svg.querySelectorAll('path').forEach(p => {
                        const d = (p.getAttribute('d') || '');
                        const tokens = d.match(/[MmLlCcSsQqTt][^MmLlHhVvCcSsQqTtAaZz]*/g);
                        if (!tokens) return;
                        for (const tok of tokens) {
                            const nums = tok.substring(1).trim().match(/-?[\d.]+/g);
                            if (!nums) continue;
                            for (let i = 0; i < nums.length - 1; i += 2) {
                                const x = parseFloat(nums[i]), y = parseFloat(nums[i + 1]);
                                if (isFinite(x) && isFinite(y)) {
                                    mnX = Math.min(mnX, x); mxX = Math.max(mxX, x);
                                    mnY = Math.min(mnY, y); mxY = Math.max(mxY, y);
                                }
                            }
                        }
                    });
                    if (isFinite(mnX)) { objW = mxX - mnX; objH = mxY - mnY; }
                }
                if (objW <= 0) objW = 50;
                if (objH <= 0) objH = 50;
                sigs._objectSize = { w: objW, h: objH };
                sigs._objectOrigin = { x: objX, y: objY };
                console.log('[SearchObj] Estimated sample object size: %dx%d (from %s)',
                    Math.round(objW), Math.round(objH),
                    vbAttr ? 'viewBox="' + vbAttr + '"' : 'coordinate-scan');

                svg.querySelectorAll('path').forEach(p => {
                    const d = (p.getAttribute('d') || '').trim();
                    if (d && d.length > 3) {
                        // 1. Exact normalized match
                        const norm = d.replace(/\s+/g, ' ').replace(/,\s*/g, ',');
                        sigs.push({ type: 'path-d-exact', value: norm });
                        // 2. Delta-vector match: normalize path to origin (position-independent)
                        const delta = _normalizePath(d);
                        if (delta) {
                            sigs.push({ type: 'path-d-delta', value: delta });
                            const start = _getPathStartPoint(d);
                            if (start) {
                                sigs._pathFeatures.push({
                                    delta,
                                    exact: norm,
                                    sampleX: start.x - objX,
                                    sampleY: start.y - objY
                                });
                            }
                        }
                    }
                });

                // Also extract from <use> references
                svg.querySelectorAll('use').forEach(u => {
                    const href = u.getAttribute('href') || u.getAttribute('xlink:href') || '';
                    if (href) sigs.push({ type: 'use-href', value: href.replace(/^#/, '') });
                });

                // If no paths, use other elements as fingerprints
                if (sigs.length === 0) {
                    svg.querySelectorAll('circle, rect, ellipse, polygon, polyline, line').forEach(el => {
                        const tag = el.tagName.toLowerCase();
                        if (tag === 'circle') {
                            const r = el.getAttribute('r') || '0';
                            sigs.push({ type: 'circle-r', value: r });
                        } else if (tag === 'rect') {
                            const w = el.getAttribute('width') || '0';
                            const h = el.getAttribute('height') || '0';
                            sigs.push({ type: 'rect-wh', value: w + 'x' + h });
                        }
                    });
                }
                const exactCount = sigs.filter(s => s.type === 'path-d-exact').length;
                const deltaCount = sigs.filter(s => s.type === 'path-d-delta').length;
                const hrefCount = sigs.filter(s => s.type === 'use-href').length;
                const otherCount = sigs.length - exactCount - deltaCount - hrefCount;
                console.log('[SearchObj] Extracted %d signatures from sample SVG (%d chars): exact=%d, delta=%d, href=%d, other=%d',
                    sigs.length, svgText.length, exactCount, deltaCount, hrefCount, otherCount);
                // Log first 3 delta signatures for debugging
                const deltaSamples = sigs.filter(s => s.type === 'path-d-delta').slice(0, 3);
                if (deltaSamples.length > 0) {
                    console.log('[SearchObj] Sample delta sigs (first 3):', deltaSamples.map(s => s.value.substring(0, 80)));
                }
                // Warn if delta extraction failed for some paths
                if (exactCount > 0 && deltaCount === 0) {
                    console.warn('[SearchObj] WARNING: %d exact sigs but 0 delta sigs — _normalizePath may have failed for all paths!', exactCount);
                    // Log first 3 path d values to debug normalization
                    sigs.filter(s => s.type === 'path-d-exact').slice(0, 3).forEach((s, i) => {
                        console.warn('[SearchObj]   exact[%d] d=%s → normalizePath result: %s', i, s.value.substring(0, 60), _normalizePath(s.value) || 'NULL');
                    });
                }
                if (exactCount > 0 && deltaCount < exactCount) {
                    console.warn('[SearchObj] NOTE: %d/%d paths produced delta sigs — some paths may be too short or have unusual commands', deltaCount, exactCount);
                }
            } catch (e) { console.error('[SearchObj] Error extracting signatures:', e); }
            return sigs;
        }

        /**
         * Normalize a path d attribute to be position-independent.
         * Translates the path so the first M coordinate is at (0,0).
         * Returns a string of rounded relative coordinates, e.g. "M0,0L-17,-13"
         */
        function _normalizePath(d) {
            try {
                const tokens = d.match(/[MmLlHhVvCcSsQqTtAaZz][^MmLlHhVvCcSsQqTtAaZz]*/g);
                if (!tokens || tokens.length < 2) return null;
                let firstX = null, firstY = null;
                const parts = [];
                for (const tok of tokens) {
                    const cmd = tok.charAt(0);
                    const nums = (tok.substring(1).trim().match(/-?[\d.]+(?:e[+-]?\d+)?/gi) || []).map(Number);
                    const CMD = cmd.toUpperCase();
                    // For relative commands, coordinates are already relative
                    if (cmd !== CMD && firstX !== null) {
                        // relative command - keep as-is but round
                        parts.push(CMD + nums.map(n => Math.round(n)).join(','));
                        continue;
                    }
                    // Absolute commands - translate to origin
                    if (CMD === 'Z') {
                        parts.push('Z');
                        continue;
                    }
                    if (CMD === 'H' && nums.length >= 1) {
                        if (firstX === null) { firstX = nums[0]; firstY = 0; }
                        parts.push('H' + Math.round(nums[0] - firstX));
                        continue;
                    }
                    if (CMD === 'V' && nums.length >= 1) {
                        if (firstX === null) { firstX = 0; firstY = nums[0]; }
                        parts.push('V' + Math.round(nums[0] - firstY));
                        continue;
                    }
                    // Commands with x,y pairs: M, L, C, S, Q, T
                    if (nums.length >= 2) {
                        if (firstX === null) { firstX = nums[0]; firstY = nums[1]; }
                        const rel = [];
                        for (let i = 0; i < nums.length; i++) {
                            rel.push(Math.round(nums[i] - (i % 2 === 0 ? firstX : firstY)));
                        }
                        parts.push(CMD + rel.join(','));
                    }
                }
                if (parts.length < 2) return null;
                return parts.join('');
            } catch { return null; }
        }

        function _getPathStartPoint(d) {
            try {
                const m = String(d || '').match(/[Mm]\s*(-?[\d.]+(?:e[+-]?\d+)?)\s*,?\s*(-?[\d.]+(?:e[+-]?\d+)?)/i);
                if (!m) return null;
                return { x: parseFloat(m[1]), y: parseFloat(m[2]) };
            } catch {
                return null;
            }
        }

        /**
         * Get element bounding box in ROOT SVG coordinate space.
         * getBBox() returns local coords which may be wrong if the element
         * is inside a <g transform="..."> group.  This helper uses getCTM()
         * to transform the local bbox into the root SVG viewport space.
         */
        function _getElementBBoxInSvgSpace(el, rootSvg) {
            const bb = el.getBBox();
            const localW = bb.width, localH = bb.height;
            try {
                const ctm = el.getCTM();
                const rootCTM = rootSvg.getCTM();
                if (ctm && rootCTM) {
                    const transform = rootCTM.inverse().multiply(ctm);
                    const corners = [
                        { x: bb.x, y: bb.y },
                        { x: bb.x + bb.width, y: bb.y },
                        { x: bb.x + bb.width, y: bb.y + bb.height },
                        { x: bb.x, y: bb.y + bb.height }
                    ];
                    const transformed = corners.map(c => {
                        const p = rootSvg.createSVGPoint();
                        p.x = c.x; p.y = c.y;
                        return p.matrixTransform(transform);
                    });
                    const xs = transformed.map(t => t.x);
                    const ys = transformed.map(t => t.y);
                    return {
                        x: Math.min(...xs),
                        y: Math.min(...ys),
                        w: Math.max(...xs) - Math.min(...xs),
                        h: Math.max(...ys) - Math.min(...ys)
                    };
                }
            } catch { /* fallback to raw bbox */ }
            return { x: bb.x, y: bb.y, w: localW, h: localH };
        }

        function _bboxIntersectsVisibleViewBox(bb, svg, margin = 0) {
            try {
                if (!bb || !svg) return false;
                const vb = svg.viewBox && svg.viewBox.baseVal ? svg.viewBox.baseVal : null;
                if (!vb) return true;
                const x1 = bb.x;
                const y1 = bb.y;
                const x2 = bb.x + bb.w;
                const y2 = bb.y + bb.h;
                const vx1 = vb.x - margin;
                const vy1 = vb.y - margin;
                const vx2 = vb.x + vb.width + margin;
                const vy2 = vb.y + vb.height + margin;
                return x2 >= vx1 && x1 <= vx2 && y2 >= vy1 && y1 <= vy2;
            } catch {
                return true;
            }
        }

        /**
         * Find matching elements on the merged SVG map.
         * Strategy:
         *   1. Try exact d‑string match (fastest, finds the original saved instance)
         *   2. Delta‑vector match: normalize every map path to origin and compare
         *      with sample delta signatures. This is POSITION‑INDEPENDENT.
         *   3. Use‑href match: look for <use> elements with the same symbol ref.
         * After collecting raw matches, cluster them by proximity into "object groups".
         */
        function _findMatchingElementsOnMap(sigs) {
            const matches = []; // array of { el, bbox }
            if (!sigs.length || !mergedSvgPreviewScale) return matches;
            const svg = mergedSvgPreviewScale.querySelector('svg');
            if (!svg) return matches;
            const activeViewBox = svg.viewBox && svg.viewBox.baseVal
                ? { x: svg.viewBox.baseVal.x, y: svg.viewBox.baseVal.y, w: svg.viewBox.baseVal.width, h: svg.viewBox.baseVal.height }
                : null;

            // Build signature sets
            const exactDSet = new Set();
            const deltaSet = new Set();
            const useHrefSet = new Set();
            sigs.forEach(s => {
                if (s.type === 'path-d-exact') exactDSet.add(s.value);
                else if (s.type === 'path-d-delta') deltaSet.add(s.value);
                else if (s.type === 'use-href') useHrefSet.add(s.value);
            });

            // Object size estimate for clustering
            const objSize = sigs._objectSize || { w: 50, h: 50 };
            const objDiag = Math.hypot(objSize.w, objSize.h);
            const totalUniqueDeltaSigs = deltaSet.size;
            // clusterRadius: just slightly larger than the object diagonal, NOT huge
            const clusterRadius = Math.max(objDiag * 1.5, 15);
            // maxClusterSize: reject clusters whose bbox diagonal exceeds this
            const maxClusterDiag = objDiag * 8;
            // Minimum fraction of unique delta sigs that must appear in a valid cluster
            // Higher threshold filters out partial/false-positive matches
            const minSigCoverage = totalUniqueDeltaSigs > 10 ? 0.40 : 0.30;
            const structuralMinVotes = Math.max(3, Math.ceil((Array.isArray(sigs._pathFeatures) ? sigs._pathFeatures.length : 0) * 0.10));
            const objOrigin = sigs._objectOrigin || { x: 0, y: 0 };

            console.log('[SearchObj] Searching map SVG. Exact sigs: %d, Delta sigs: %d, Use hrefs: %d',
                exactDSet.size, deltaSet.size, useHrefSet.size);
            console.log('[SearchObj] Object size: %dx%d, diag=%.0f, clusterRadius=%.0f, maxClusterDiag=%.0f, minSigCoverage=%.0f%%',
                Math.round(objSize.w), Math.round(objSize.h), objDiag, clusterRadius, maxClusterDiag, minSigCoverage * 100);
            if (activeViewBox) {
                console.log('[SearchObj] Active crop/viewBox restriction: x=%.0f y=%.0f w=%.0f h=%.0f', activeViewBox.x, activeViewBox.y, activeViewBox.w, activeViewBox.h);
            }

            const allMapPaths = svg.querySelectorAll('path');
            console.log('[SearchObj] Total <path> elements on map: %d', allMapPaths.length);

            let exactMatches = 0, deltaMatches = 0, hrefMatches = 0;
            let deltaSkippedSize = 0, deltaTestedCount = 0;
            const matchedEls = new Set();

            console.time('[SearchObj] exact match scan');
            // ── 1. Exact d match ──
            if (exactDSet.size > 0) {
                allMapPaths.forEach(p => {
                    const d = (p.getAttribute('d') || '').trim();
                    if (!d) return;
                    const norm = d.replace(/\s+/g, ' ').replace(/,\s*/g, ',');
                    if (exactDSet.has(norm)) {
                        try {
                            const bb = _getElementBBoxInSvgSpace(p, svg);
                            if (bb && (bb.w > 0 || bb.h > 0)) {
                                matches.push({ el: p, bbox: bb, matchType: 'exact', deltaKey: norm });
                                matchedEls.add(p);
                                exactMatches++;
                            }
                        } catch { /* ignore */ }
                    }
                });
            }
            console.timeEnd('[SearchObj] exact match scan');
            console.log('[SearchObj] Step 1 - Exact matches: %d (from %d exact sigs)', exactMatches, exactDSet.size);

            console.time('[SearchObj] delta match scan');
            // ── 2. Delta‑vector match (position‑independent) ──
            if (deltaSet.size > 0) {
                const vb = svg.viewBox?.baseVal;
                const maxDim = vb ? Math.max(vb.width, vb.height) * 0.15 : 10000;
                console.log('[SearchObj] Step 2 - Delta matching: %d unique delta sigs, maxDim filter=%d, viewBox=%s',
                    deltaSet.size, Math.round(maxDim), vb ? `${vb.x},${vb.y},${vb.width},${vb.height}` : 'none');
                allMapPaths.forEach(p => {
                    if (matchedEls.has(p)) return;
                    const d = (p.getAttribute('d') || '').trim();
                    if (!d || d.length < 4) return;
                    deltaTestedCount++;
                    const delta = _normalizePath(d);
                    if (delta && deltaSet.has(delta)) {
                        try {
                            const bb = _getElementBBoxInSvgSpace(p, svg);
                            if (bb && (bb.w > 0 || bb.h > 0)) {
                                if (bb.w < maxDim && bb.h < maxDim) {
                                    matches.push({ el: p, bbox: bb, matchType: 'delta', deltaKey: delta });
                                    matchedEls.add(p);
                                    deltaMatches++;
                                } else {
                                    deltaSkippedSize++;
                                }
                            }
                        } catch { /* ignore */ }
                    }
                });
            }
            console.timeEnd('[SearchObj] delta match scan');
            console.log('[SearchObj] Step 2 - Delta matches: %d (tested %d paths, skipped %d too-large)', deltaMatches, deltaTestedCount, deltaSkippedSize);

            // ── 3. Use‑href match ──
            if (useHrefSet.size > 0) {
                const allUses = svg.querySelectorAll('use');
                console.log('[SearchObj] Step 3 - Use-href: checking %d <use> elements for %d hrefs', allUses.length, useHrefSet.size);
                allUses.forEach(u => {
                    const href = (u.getAttribute('href') || u.getAttribute('xlink:href') || '').replace(/^#/, '');
                    if (useHrefSet.has(href)) {
                        try {
                            const bb = _getElementBBoxInSvgSpace(u, svg);
                            if (bb && bb.w > 0 && bb.h > 0) {
                                matches.push({ el: u, bbox: bb, matchType: 'href' });
                                hrefMatches++;
                            }
                        } catch { /* ignore */ }
                    }
                });
                console.log('[SearchObj] Step 3 - Href matches: %d', hrefMatches);
            }

            // ── 4. Non‑path fallback ──
            let fallbackMatches = 0;
            sigs.forEach(s => {
                if (s.type === 'circle-r') {
                    svg.querySelectorAll('circle').forEach(c => {
                        if ((c.getAttribute('r') || '0') === s.value) {
                            try {
                                const bb = _getElementBBoxInSvgSpace(c, svg);
                                if (bb && bb.w > 0) { matches.push({ el: c, bbox: bb, matchType: 'circle' }); fallbackMatches++; }
                            } catch { /* ignore */ }
                        }
                    });
                } else if (s.type === 'rect-wh') {
                    svg.querySelectorAll('rect:not(.merged-svg-search-highlight-rect):not(.merged-svg-selected-object-rect):not(.merged-svg-group-rect)').forEach(r => {
                        const wh = (r.getAttribute('width') || '0') + 'x' + (r.getAttribute('height') || '0');
                        if (wh === s.value) {
                            try {
                                const bb = _getElementBBoxInSvgSpace(r, svg);
                                if (bb && bb.w > 0) { matches.push({ el: r, bbox: bb, matchType: 'rect' }); fallbackMatches++; }
                            } catch { /* ignore */ }
                        }
                    });
                }
            });
            if (fallbackMatches > 0) console.log('[SearchObj] Step 4 - Fallback matches: %d', fallbackMatches);

            console.log('[SearchObj] ┌─── RAW MATCH SUMMARY ───┐');
            console.log('[SearchObj] │ Exact:    %d', exactMatches);
            console.log('[SearchObj] │ Delta:    %d (tested %d, skipped-size %d)', deltaMatches, deltaTestedCount, deltaSkippedSize);
            console.log('[SearchObj] │ Href:     %d', hrefMatches);
            console.log('[SearchObj] │ Fallback: %d', fallbackMatches);
            console.log('[SearchObj] │ TOTAL:    %d raw matches', matches.length);
            console.log('[SearchObj] └─────────────────────────┘');

            // Debug diagnostics when matches are low
            if (matches.length < 5) {
                console.warn('[SearchObj] LOW MATCH COUNT (%d) — dumping diagnostics:', matches.length);
                // Log sample delta sigs
                if (deltaSet.size > 0) {
                    const sampleDeltas = [...deltaSet].slice(0, 5);
                    console.log('[SearchObj] Sample delta values (first 5):', sampleDeltas);
                }
                // Log a few random map path deltas to compare
                const mapDeltaSample = [];
                const step = Math.max(1, Math.floor(allMapPaths.length / 20));
                for (let k = 0; k < allMapPaths.length && mapDeltaSample.length < 20; k += step) {
                    const d = (allMapPaths[k].getAttribute('d') || '').trim();
                    if (d && d.length > 3) {
                        const nd = _normalizePath(d);
                        if (nd) mapDeltaSample.push({ idx: k, deltaLen: nd.length, delta: nd.substring(0, 60) });
                    }
                }
                console.log('[SearchObj] Map path delta samples (evenly spaced, first 20):', mapDeltaSample);
                // Log exact sigs comparison
                if (exactDSet.size > 0) {
                    const sampleExact = [...exactDSet].slice(0, 3);
                    console.log('[SearchObj] Sample exact d (first 3, truncated):', sampleExact.map(d => d.substring(0, 80)));
                    // Find the closest near-miss on the map
                    let closestDist = Infinity, closestD = '';
                    for (let k = 0; k < Math.min(5000, allMapPaths.length); k++) {
                        const d = (allMapPaths[k].getAttribute('d') || '').trim();
                        if (!d) continue;
                        const norm = d.replace(/\s+/g, ' ').replace(/,\s*/g, ',');
                        // Simple length-based distance as quick heuristic
                        const lenDiff = Math.abs(norm.length - sampleExact[0].length);
                        if (lenDiff < closestDist) {
                            closestDist = lenDiff;
                            closestD = norm;
                        }
                    }
                    if (closestD) console.log('[SearchObj] Closest map path by length (lenDiff=%d): %s', closestDist, closestD.substring(0, 80));
                }
            }

            // Log first 5 match locations for verification
            matches.slice(0, 5).forEach((m, i) => {
                console.log('[SearchObj] Match[%d] type=%s bbox={x:%.0f, y:%.0f, w:%.0f, h:%.0f} tag=%s',
                    i, m.matchType, m.bbox.x, m.bbox.y, m.bbox.w, m.bbox.h, m.el?.tagName || '?');
            });

            let voteResultGroups = [];

            // ── Structural translation voting for repeated object detection ──
            const sampleFeatures = Array.isArray(sigs._pathFeatures) ? sigs._pathFeatures : [];
            if (sampleFeatures.length >= 3 && deltaSet.size > 0) {
                console.log('[SearchObj][Vote] Starting translation voting: sampleFeatures=%d, minVotes=%d', sampleFeatures.length, structuralMinVotes);
                const featureMap = new Map();
                sampleFeatures.forEach((f, idx) => {
                    if (!featureMap.has(f.delta)) featureMap.set(f.delta, []);
                    featureMap.get(f.delta).push({ ...f, idx });
                });

                const voteBuckets = new Map();
                allMapPaths.forEach(p => {
                    const d = (p.getAttribute('d') || '').trim();
                    if (!d || d.length < 4) return;
                    const delta = _normalizePath(d);
                    if (!delta || !featureMap.has(delta)) return;
                    const start = _getPathStartPoint(d);
                    if (!start) return;
                    let bb = null;
                    try { bb = _getElementBBoxInSvgSpace(p, svg); } catch { bb = null; }
                    if (!bb || !(bb.w > 0 || bb.h > 0)) return;
                    for (const f of featureMap.get(delta)) {
                        const tx = start.x - f.sampleX;
                        const ty = start.y - f.sampleY;
                        const qx = Math.round(tx / 4) * 4;
                        const qy = Math.round(ty / 4) * 4;
                        const key = `${qx},${qy}`;
                        if (!voteBuckets.has(key)) {
                            voteBuckets.set(key, {
                                tx: qx,
                                ty: qy,
                                elements: [],
                                featureIds: new Set(),
                                deltaKeys: new Set(),
                                bbox: { x: qx, y: qy, w: objSize.w, h: objSize.h }
                            });
                        }
                        const bucket = voteBuckets.get(key);
                        bucket.elements.push({ el: p, bbox: bb, matchType: 'vote', deltaKey: delta, featureIdx: f.idx });
                        bucket.featureIds.add(f.idx);
                        bucket.deltaKeys.add(delta);
                    }
                });

                const votedGroups = [...voteBuckets.values()]
                    .sort((a, b) => b.featureIds.size - a.featureIds.size || b.elements.length - a.elements.length);

                const mergedVoteGroups = [];
                for (const vg of votedGroups) {
                    let mergedInto = null;
                    for (const mg of mergedVoteGroups) {
                        if (Math.hypot(vg.tx - mg.tx, vg.ty - mg.ty) <= Math.max(objDiag * 0.55, 8)) {
                            mergedInto = mg;
                            break;
                        }
                    }
                    if (!mergedInto) {
                        mergedInto = {
                            tx: vg.tx,
                            ty: vg.ty,
                            elements: [],
                            featureIds: new Set(),
                            deltaKeys: new Set(),
                            source: 'vote'
                        };
                        mergedVoteGroups.push(mergedInto);
                    }
                    vg.elements.forEach(el => mergedInto.elements.push(el));
                    vg.featureIds.forEach(id => mergedInto.featureIds.add(id));
                    vg.deltaKeys.forEach(key => mergedInto.deltaKeys.add(key));
                }

                mergedVoteGroups.slice(0, 10).forEach((g, i) => {
                    const coverage = totalUniqueDeltaSigs > 0 ? (g.deltaKeys.size / totalUniqueDeltaSigs) : 0;
                    console.log('[SearchObj][Vote] Candidate[%d] tx=%.0f ty=%.0f features=%d deltas=%d coverage=%.0f%% elements=%d',
                        i, g.tx, g.ty, g.featureIds.size, g.deltaKeys.size, coverage * 100, g.elements.length);
                });

                const dedupedVotedGroups = mergedVoteGroups
                    .filter(g => g.featureIds.size >= structuralMinVotes && g.deltaKeys.size >= Math.min(2, structuralMinVotes))
                    .map(g => ({
                        elements: g.elements,
                        bbox: {
                            x: g.tx,
                            y: g.ty,
                            w: objSize.w,
                            h: objSize.h
                        },
                        source: 'vote',
                        matchedFeatures: g.featureIds.size,
                        matchedDeltas: g.deltaKeys.size
                    }))
                    .filter(g => {
                        if (!_bboxIntersectsVisibleViewBox(g.bbox, svg, 0)) return false;
                        // Apply same coverage filter as post-cluster: reject groups with too few matched delta sigs
                        if (totalUniqueDeltaSigs >= 3) {
                            const coverage = (g.matchedDeltas || 0) / totalUniqueDeltaSigs;
                            if (coverage < minSigCoverage) {
                                console.log('[SearchObj][Vote] REJECT group (low coverage): %d/%d deltas (%.0f%% < %.0f%%), features=%d',
                                    g.matchedDeltas || 0, totalUniqueDeltaSigs, coverage * 100, minSigCoverage * 100, g.matchedFeatures || 0);
                                return false;
                            }
                        }
                        return true;
                    })
                    .sort((a, b) => (b.matchedFeatures || 0) - (a.matchedFeatures || 0) || (b.matchedDeltas || 0) - (a.matchedDeltas || 0));

                console.log('[SearchObj][Vote] Buckets=%d, merged=%d, deduped=%d', voteBuckets.size, mergedVoteGroups.length, dedupedVotedGroups.length);
                dedupedVotedGroups.slice(0, 5).forEach((g, i) => {
                    console.log('[SearchObj][Vote] Group[%d] features=%d deltas=%d elements=%d bbox={x:%.0f,y:%.0f,w:%.0f,h:%.0f}',
                        i, g.matchedFeatures || 0, g.matchedDeltas || 0, g.elements.length, g.bbox.x, g.bbox.y, g.bbox.w, g.bbox.h);
                });
                if (dedupedVotedGroups.length > 0) {
                    voteResultGroups = dedupedVotedGroups;
                    console.log('[SearchObj][Vote] Keeping %d vote groups and continuing to fallback clustering for additional candidates', voteResultGroups.length);
                }
            }

            // Cluster matches by proximity → each cluster = one object instance
            console.time('[SearchObj] clustering');
            const rawGroups = _clusterMatchesByProximity(matches, clusterRadius);
            console.timeEnd('[SearchObj] clustering');
            console.log('[SearchObj] After clustering: %d raw groups from %d matches (radius=%.0f)', rawGroups.length, matches.length, clusterRadius);

            // ── Post-cluster validation: filter out false positives ──
            const groups = [];
            let rejectedSize = 0, rejectedCoverage = 0;
            for (const g of rawGroups) {
                const gDiag = Math.hypot(g.bbox.w, g.bbox.h);
                const hasExactEvidence = exactMatches > 0;
                const maxAllowedDiag = hasExactEvidence ? maxClusterDiag : (objDiag * 2.5);
                const maxAllowedWidth = Math.max(objSize.w * (hasExactEvidence ? 3.5 : 2.5), 12);
                const maxAllowedHeight = Math.max(objSize.h * (hasExactEvidence ? 3.5 : 2.5), 12);
                if (!_bboxIntersectsVisibleViewBox(g.bbox, svg, 0)) {
                    continue;
                }
                // 1. Reject clusters that are way too large for the expected object
                if (gDiag > maxAllowedDiag || g.bbox.w > maxAllowedWidth || g.bbox.h > maxAllowedHeight) {
                    rejectedSize++;
                    console.log('[SearchObj][Filter] REJECT group (bbox mismatch): diag=%.0f > max=%.0f or bbox=%.0fx%.0f > %.0fx%.0f, elements=%d, exactEvidence=%s',
                        gDiag, maxAllowedDiag, g.bbox.w, g.bbox.h, maxAllowedWidth, maxAllowedHeight, g.elements.length, hasExactEvidence);
                    continue;
                }
                // 2. Require minimum distinct delta-sig coverage (only when we have complex-enough sigs)
                if (totalUniqueDeltaSigs >= 3) {
                    const sigSet = new Set();
                    for (const m of g.elements) {
                        if (m.deltaKey) sigSet.add(m.deltaKey);
                    }
                    const coverage = sigSet.size / totalUniqueDeltaSigs;
                    // Reject if coverage is too low OR too few distinct sigs
                    if (coverage < minSigCoverage || sigSet.size < 2) {
                        rejectedCoverage++;
                        if (rejectedCoverage <= 5) {
                            console.log('[SearchObj][Filter] REJECT group (low sig coverage): %d/%d sigs (%.0f%% < %.0f%%), elements=%d, bbox=%.0fx%.0f',
                                sigSet.size, totalUniqueDeltaSigs, coverage * 100, minSigCoverage * 100, g.elements.length, g.bbox.w, g.bbox.h);
                        }
                        continue;
                    }
                    if (groups.length < 10) {
                        console.log('[SearchObj][Filter] ACCEPT group candidate: %d/%d sigs (%.0f%%), elements=%d, bbox=%.0fx%.0f, sizeRatio=%.2fx%.2f',
                            sigSet.size, totalUniqueDeltaSigs, coverage * 100, g.elements.length, g.bbox.w, g.bbox.h,
                            g.bbox.w / Math.max(objSize.w, 1), g.bbox.h / Math.max(objSize.h, 1));
                    }
                }
                groups.push(g);
            }
            console.log('[SearchObj] Post-filter: %d valid groups (rejected: %d too-large, %d low-coverage)',
                groups.length, rejectedSize, rejectedCoverage);

            // Log cluster stats
            if (groups.length > 0) {
                const sizes = groups.map(g => g.elements.length);
                const avgSize = (sizes.reduce((a, b) => a + b, 0) / sizes.length).toFixed(1);
                const maxSize = Math.max(...sizes);
                const minSize = Math.min(...sizes);
                console.log('[SearchObj] Valid cluster stats: count=%d, avgElements=%s, minElements=%d, maxElements=%d',
                    groups.length, avgSize, minSize, maxSize);
                groups.slice(0, 5).forEach((g, i) => {
                    console.log('[SearchObj] Group[%d] elements=%d bbox={x:%.0f, y:%.0f, w:%.0f, h:%.0f} diag=%.0f',
                        i, g.elements.length, g.bbox.x, g.bbox.y, g.bbox.w, g.bbox.h, Math.hypot(g.bbox.w, g.bbox.h));
                });
            }
            if (voteResultGroups.length > 0) {
                const mergedGroups = [...voteResultGroups];
                let dedupedClusterGroups = 0;
                groups.forEach((g, idx) => {
                    const gb = g.bbox;
                    const gcx = gb.x + gb.w / 2;
                    const gcy = gb.y + gb.h / 2;
                    let duplicate = false;
                    for (const existing of mergedGroups) {
                        const eb = existing.bbox;
                        const ecx = eb.x + eb.w / 2;
                        const ecy = eb.y + eb.h / 2;
                        const dist = Math.hypot(gcx - ecx, gcy - ecy);
                        const dupThreshold = Math.max(objDiag * 0.75, Math.max(gb.w, gb.h, eb.w, eb.h));
                        const overlapX = Math.max(0, Math.min(gb.x + gb.w, eb.x + eb.w) - Math.max(gb.x, eb.x));
                        const overlapY = Math.max(0, Math.min(gb.y + gb.h, eb.y + eb.h) - Math.max(gb.y, eb.y));
                        if (dist <= dupThreshold || (overlapX > 0 && overlapY > 0)) {
                            duplicate = true;
                            break;
                        }
                    }
                    if (duplicate) {
                        dedupedClusterGroups++;
                        console.log('[SearchObj][MergeLocal] Cluster group[%d] skipped as duplicate of vote result: bbox={x:%.0f,y:%.0f,w:%.0f,h:%.0f}',
                            idx, gb.x, gb.y, gb.w, gb.h);
                        return;
                    }
                    mergedGroups.push({ ...g, source: g.source || 'cluster' });
                    console.log('[SearchObj][MergeLocal] Added fallback cluster group[%d]: bbox={x:%.0f,y:%.0f,w:%.0f,h:%.0f}, elements=%d',
                        idx, gb.x, gb.y, gb.w, gb.h, g.elements.length);
                });
                console.log('[SearchObj][MergeLocal] vote=%d + cluster=%d => total=%d (deduped cluster=%d)',
                    voteResultGroups.length, groups.length, mergedGroups.length, dedupedClusterGroups);
                return mergedGroups;
            }

            return groups;
        }

        /**
         * Cluster matches by proximity into object groups.
         * All paths within `radius` distance are merged into one cluster.
         * Each cluster represents one object instance on the map.
         */
        function _clusterMatchesByProximity(matches, radius) {
            if (matches.length === 0) return [];
            if (matches.length === 1) {
                const b = matches[0].bbox;
                return [{ elements: [matches[0]], bbox: { x: b.x, y: b.y, w: b.w, h: b.h } }];
            }

            // Compute center point for each match
            const centers = matches.map(m => ({
                cx: m.bbox.x + m.bbox.w / 2,
                cy: m.bbox.y + m.bbox.h / 2
            }));

            const used = new Uint8Array(matches.length);
            const groups = [];

            for (let i = 0; i < matches.length; i++) {
                if (used[i]) continue;
                used[i] = 1;
                const cluster = [i];
                let gx = matches[i].bbox.x, gy = matches[i].bbox.y;
                let gx2 = gx + matches[i].bbox.w, gy2 = gy + matches[i].bbox.h;

                // Expand cluster: add neighbours within radius of any cluster member
                let changed = true;
                while (changed) {
                    changed = false;
                    for (let j = 0; j < matches.length; j++) {
                        if (used[j]) continue;
                        // Check distance to any member in cluster
                        for (const ci of cluster) {
                            const dx = centers[j].cx - centers[ci].cx;
                            const dy = centers[j].cy - centers[ci].cy;
                            if (Math.hypot(dx, dy) <= radius) {
                                used[j] = 1;
                                cluster.push(j);
                                const b = matches[j].bbox;
                                gx = Math.min(gx, b.x);
                                gy = Math.min(gy, b.y);
                                gx2 = Math.max(gx2, b.x + b.w);
                                gy2 = Math.max(gy2, b.y + b.h);
                                changed = true;
                                break; // restart scan
                            }
                        }
                    }
                }

                groups.push({
                    elements: cluster.map(idx => matches[idx]),
                    bbox: { x: gx, y: gy, w: gx2 - gx, h: gy2 - gy }
                });
            }
            return groups;
        }

        /* ── Remove search highlight overlays ── */
        function _removeSearchHighlights() {
            if (!mergedSvgPreviewScale) return;
            const svg = mergedSvgPreviewScale.querySelector('svg');
            if (!svg) return;
            svg.querySelectorAll('.merged-svg-search-highlight-rect, .merged-svg-search-highlight-label, .merged-svg-search-highlight-label-bg').forEach(el => el.remove());
        }

        /* ── Draw green highlight rectangles with numbering on the map ── */
        function _drawSearchHighlights(groups) {
            _removeSearchHighlights();
            if (!mergedSvgPreviewScale || !groups.length) {
                console.warn('[SearchObj][Draw] Early exit: scale=%o, groups=%d', !!mergedSvgPreviewScale, groups.length);
                return;
            }
            const svg = mergedSvgPreviewScale.querySelector('svg');
            if (!svg) { console.warn('[SearchObj][Draw] No <svg> element found!'); return; }
            const vb = svg.viewBox?.baseVal;
            console.log('[SearchObj][Draw] Drawing %d highlight rects. SVG viewBox=%s, size=%sx%s',
                groups.length,
                vb ? `${vb.x},${vb.y},${vb.width},${vb.height}` : 'none',
                svg.getAttribute('width') || '?', svg.getAttribute('height') || '?');
            // Log first 5 group bboxes for verification
            groups.slice(0, 5).forEach((g, i) => {
                console.log('[SearchObj][Draw] Group[%d] bbox={x:%.1f, y:%.1f, w:%.1f, h:%.1f}',
                    i, g.bbox.x, g.bbox.y, g.bbox.w, g.bbox.h);
            });
            const pad = 4;
            let drawn = 0;
            groups.forEach((g, idx) => {
                const bb = g.bbox;
                if (!isFinite(bb.x) || !isFinite(bb.y) || bb.w <= 0 || bb.h <= 0) return;
                // Green highlight rect
                const rectEl = document.createElementNS('http://www.w3.org/2000/svg', 'rect');
                rectEl.setAttribute('x', String(bb.x - pad));
                rectEl.setAttribute('y', String(bb.y - pad));
                rectEl.setAttribute('width', String(bb.w + pad * 2));
                rectEl.setAttribute('height', String(bb.h + pad * 2));
                rectEl.classList.add('merged-svg-search-highlight-rect');
                svg.appendChild(rectEl);
                // Number label background
                const labelBg = document.createElementNS('http://www.w3.org/2000/svg', 'rect');
                labelBg.setAttribute('x', String(bb.x - pad - 1));
                labelBg.setAttribute('y', String(bb.y - pad - 14));
                labelBg.setAttribute('width', '20');
                labelBg.setAttribute('height', '14');
                labelBg.classList.add('merged-svg-search-highlight-label-bg');
                svg.appendChild(labelBg);
                // Number label
                const label = document.createElementNS('http://www.w3.org/2000/svg', 'text');
                label.setAttribute('x', String(bb.x - pad + 9));
                label.setAttribute('y', String(bb.y - pad - 3));
                label.setAttribute('text-anchor', 'middle');
                label.classList.add('merged-svg-search-highlight-label');
                label.textContent = String(idx + 1);
                svg.appendChild(label);
                drawn++;
            });
            // Verify rects are in the DOM
            const actualRects = svg.querySelectorAll('.merged-svg-search-highlight-rect').length;
            console.log('[SearchObj][Draw] Done: drew %d/%d rects. Verified in DOM: %d', drawn, groups.length, actualRects);
            if (drawn === 0) {
                console.warn('[SearchObj][Draw] 0 rects drawn! All bboxes may have been invalid (NaN/zero).');
            }
        }

        /* ── Extract the target color from a color-swatch or any sample SVG ── */
        function _extractColorFromSwatchSvg(svgText) {
            try {
                const raw = String(svgText || '').trim();
                if (!raw || raw.indexOf('<svg') < 0) return '';
                const doc = new DOMParser().parseFromString(raw, 'image/svg+xml');
                if (doc.querySelector('parsererror')) return '';
                // Try to find a non-white, non-none fill from shapes (rects, paths, circles etc.)
                const shapes = doc.querySelectorAll('rect, path, circle, ellipse, polygon, polyline');
                for (let i = shapes.length - 1; i >= 0; i--) {
                    const fill = shapes[i].getAttribute('fill') || '';
                    const low = fill.toLowerCase().trim();
                    if (fill && low !== '#ffffff' && low !== '#fff' && low !== 'white' && low !== 'none'
                        && low !== 'transparent' && !low.startsWith('url(')) {
                        return fill;
                    }
                }
                // Fallback: also check stroke
                for (let i = shapes.length - 1; i >= 0; i--) {
                    const stroke = shapes[i].getAttribute('stroke') || '';
                    const low = stroke.toLowerCase().trim();
                    if (stroke && low !== '#ffffff' && low !== '#fff' && low !== 'white' && low !== 'none'
                        && low !== 'transparent' && !low.startsWith('url(')) {
                        return stroke;
                    }
                }
            } catch { /* ignore */ }
            return '';
        }

        /* ── Color-based search: highlight all elements on the map with matching fill/stroke color ── */
        function _findColorMatchingElementsOnMap(targetColors) {
            if (!targetColors.length || !mergedSvgPreviewScale) return 0;
            const svg = mergedSvgPreviewScale.querySelector('svg');
            if (!svg) return 0;

            // Normalize all target colors
            const normalizedTargets = new Set();
            for (const c of targetColors) {
                const n = _normalizeColor(c);
                if (n) normalizedTargets.add(n);
            }
            if (!normalizedTargets.size) return 0;
            console.log('[SearchObj][Color] Searching for %d normalized target colors: %s',
                normalizedTargets.size, [...normalizedTargets].join(', '));

            const shapes = svg.querySelectorAll(_SHAPE_SELECTOR);
            let scanned = 0, matched = 0;
            for (const el of shapes) {
                try { if (el.closest && el.closest('defs')) continue; } catch {}
                scanned++;
                const fillNorm = _normalizeColor(_getElementFill(el));
                const strokeNorm = _normalizeColor(_getElementStroke(el));
                if (!normalizedTargets.has(fillNorm) && !normalizedTargets.has(strokeNorm)) continue;
                // Highlight the element directly with the green color-highlight class
                el.classList.add('merged-svg-el-color-highlight');
                matched++;
            }
            console.log('[SearchObj][Color] Scanned %d shapes, highlighted %d color matches', scanned, matched);
            return matched;
        }

        /* ── Search & Highlight checked objects on the map ── */
        async function _searchAndHighlightCheckedObjects() {
            console.log('[SearchObj] === SEARCH & HIGHLIGHT START ===');
            _removeSearchHighlights();
            const checkboxes = document.querySelectorAll('.inlineGroupObjCheckbox:checked');
            const samples = _inlineGroupObjects;
            console.log('[SearchObj] Total samples: %d, Checked checkboxes: %d', samples.length, checkboxes.length);
            // If none checked, use all
            const indices = [];
            if (checkboxes.length > 0) {
                checkboxes.forEach(cb => {
                    const idx = parseInt(cb.dataset.sampleIdx, 10);
                    if (Number.isFinite(idx) && idx >= 0 && idx < samples.length) indices.push(idx);
                });
            } else {
                for (let i = 0; i < samples.length; i++) indices.push(i);
            }

            if (!indices.length) { cgAlert('No objects selected'); return; }
            console.log('[SearchObj] Using %d sample indices: %s', indices.length, JSON.stringify(indices));

            // ── Color group type: search by color, not by shape ──
            const currentGroupType = _inlineGroupObjectsGroupType || (groupNameSelect ? groupNameSelect.value : '');
            console.log('[SearchObj] currentGroupType=%s, _inlineGroupObjectsGroupType=%s, selectValue=%s, isColor=%s',
                currentGroupType, _inlineGroupObjectsGroupType, groupNameSelect ? groupNameSelect.value : '(null)', _isColorGroupType(currentGroupType));
            if (_isColorGroupType(currentGroupType)) {
                console.log('[SearchObj] Color group type detected — using COLOR-BASED search');
                const targetColors = [];
                indices.forEach(idx => {
                    const s = samples[idx];
                    if (!s) return;
                    const svgText = (s.sampleSvg != null) ? String(s.sampleSvg) : '';
                    const color = _extractColorFromSwatchSvg(svgText);
                    if (color) {
                        targetColors.push(color);
                        console.log('[SearchObj][Color] Sample[%d] → extracted color: %s', idx, color);
                    } else {
                        console.warn('[SearchObj][Color] Sample[%d] → no color found in swatch SVG', idx);
                    }
                });

                if (!targetColors.length) {
                    cgAlert('No target colors found in selected samples');
                    return;
                }

                const badge = document.getElementById('inlineGroupSearchBadge');
                if (badge) { badge.textContent = 'Searching by color...'; badge.style.display = 'inline-block'; }

                // Remove any previous color highlights
                _clearColorMatchHighlights();

                const matchCount = _findColorMatchingElementsOnMap(targetColors);

                if (badge) {
                    badge.textContent = 'Found ' + matchCount + ' elements';
                    badge.style.display = matchCount > 0 ? 'inline-block' : 'none';
                }

                console.log('[SearchObj][Color] SEARCH COMPLETE: %d elements highlighted', matchCount);
                if (matchCount === 0) {
                    cgAlert('No matching color objects found on the map');
                }
                return;
            }

            // ── Shape-based search (non-color groups) ──
            // Collect all path signatures from selected samples
            let allSigs = [];
            let bestObjSize = { w: 0, h: 0 };
            let bestObjOrigin = { x: 0, y: 0 };
            let allPathFeatures = [];
            indices.forEach(idx => {
                const s = samples[idx];
                if (!s) return;
                const svgText = (s.sampleSvg != null) ? String(s.sampleSvg) : '';
                console.log('[SearchObj] Sample[%d] id=%s href=%s svgLen=%d', idx, s.id, s.symbolHref, svgText.length);
                const sigs = _extractSamplePathSignatures(svgText);
                // Preserve _objectSize (lost during Array.concat)
                if (sigs._objectSize && (sigs._objectSize.w > bestObjSize.w || sigs._objectSize.h > bestObjSize.h)) {
                    bestObjSize = sigs._objectSize;
                    bestObjOrigin = sigs._objectOrigin || bestObjOrigin;
                }
                if (Array.isArray(sigs._pathFeatures) && sigs._pathFeatures.length) {
                    allPathFeatures = allPathFeatures.concat(sigs._pathFeatures);
                }
                allSigs = allSigs.concat(sigs);
            });
            // Re-attach the best object size to the merged sigs array
            if (!(bestObjSize.w > 0) || !(bestObjSize.h > 0)) bestObjSize = { w: 50, h: 50 };
            allSigs._objectSize = bestObjSize;
            allSigs._objectOrigin = bestObjOrigin;
            allSigs._pathFeatures = allPathFeatures;
            console.log('[SearchObj] Total signatures collected: %d, objectSize: %dx%d',
                allSigs.length, Math.round(bestObjSize.w), Math.round(bestObjSize.h));

            // Update badge to show "Searching..."
            const badge = document.getElementById('inlineGroupSearchBadge');
            if (badge) {
                badge.textContent = 'Searching...';
                badge.style.display = 'inline-block';
            }

            // ── Run client-side delta matching + Shapely server-side matching in parallel ──
            const clientPromise = new Promise(resolve => {
                try {
                    const groups = allSigs.length > 0 ? _findMatchingElementsOnMap(allSigs) : [];
                    resolve(groups);
                } catch (e) {
                    console.error('[SearchObj] Client-side matching error:', e);
                    resolve([]);
                }
            });

            const shapelyPromise = _searchViaShapely(indices, samples);

            const [clientGroups, shapelyGroups] = await Promise.all([clientPromise, shapelyPromise]);

            console.log('[SearchObj] Client-side groups: %d, Shapely groups: %d', clientGroups.length, shapelyGroups.length);

            // Merge results: combine both, then deduplicate overlapping bboxes
            const mergedGroups = _mergeSearchResults(clientGroups, shapelyGroups);
            const liveSvg = mergedSvgPreviewScale ? mergedSvgPreviewScale.querySelector('svg') : null;
            const visibleGroups = liveSvg
                ? mergedGroups.filter(g => _bboxIntersectsVisibleViewBox(g.bbox, liveSvg, Math.max(6, Math.max(g.bbox.w || 0, g.bbox.h || 0))))
                : mergedGroups;

            console.log('[SearchObj] Visible groups on current map viewBox: %d/%d', visibleGroups.length, mergedGroups.length);

            _drawSearchHighlights(visibleGroups);

            // Update badge
            if (badge) {
                badge.textContent = 'Found ' + visibleGroups.length + ' objects';
                badge.style.display = visibleGroups.length > 0 ? 'inline-block' : 'none';
            }

            console.log('[SearchObj] ╔══════════════════════════════════════════════╗');
            console.log('[SearchObj] ║ SEARCH COMPLETE — FINAL SUMMARY              ║');
            console.log('[SearchObj] ╠══════════════════════════════════════════════╣');
            console.log('[SearchObj] ║ Client-side groups:  %d', clientGroups.length);
            console.log('[SearchObj] ║ Shapely groups:      %d', shapelyGroups.length);
            console.log('[SearchObj] ║ MERGED TOTAL:        %d', mergedGroups.length);
            console.log('[SearchObj] ║ VISIBLE ON MAP:      %d', visibleGroups.length);
            console.log('[SearchObj] ╚══════════════════════════════════════════════╝');
            if (visibleGroups.length === 0) {
                console.warn('[SearchObj] ⚠ NO OBJECTS FOUND. Possible reasons:');
                console.warn('[SearchObj]   1. The saved sample paths have different coordinate precision than the map');
                console.warn('[SearchObj]   2. The sample was created from a different SVG version/merge');
                console.warn('[SearchObj]   3. The Shapely similarity threshold is too strict');
                console.warn('[SearchObj]   Check the detailed logs above for diagnostics.');
                cgAlert('No matching objects found on the map');
            } else if (visibleGroups.length > 200) {
                console.warn('[SearchObj] ⚠ HIGH COUNT (%d groups). Possible false positives from overly generic signatures.', visibleGroups.length);
            }
        }

        /**
         * Call Shapely group-objects endpoint server-side to find matching clusters.
         * Sends the full merged SVG + a seed bbox derived from the sample object.
         * Returns array of { bbox } groups compatible with _drawSearchHighlights.
         */
        async function _searchViaShapely(indices, samples) {
            console.log('[SearchObj][Shapely] === SHAPELY SEARCH START ===');
            try {
                if (!_pdfPreSplitMergedSvg) {
                    console.warn('[SearchObj][Shapely] No merged SVG available — skipping');
                    return [];
                }

                // Build a combined seedBbox from all selected samples
                let seedW = 0, seedH = 0;
                for (const idx of indices) {
                    const s = samples[idx];
                    if (!s) continue;
                    const svgText = (s.sampleSvg != null) ? String(s.sampleSvg) : '';
                    if (!svgText) continue;
                    const vbMatch = svgText.match(/viewBox="([^"]+)"/);
                    if (vbMatch) {
                        const parts = vbMatch[1].trim().split(/[\s,]+/).map(Number);
                        if (parts.length >= 4) {
                            seedW = Math.max(seedW, parts[2]);
                            seedH = Math.max(seedH, parts[3]);
                        }
                    }
                }
                console.log('[SearchObj][Shapely] Seed dimensions from sample viewBox: %dx%d', Math.round(seedW), Math.round(seedH));

                const params = _getGroupParams();
                const groupType = _inlineGroupObjectsGroupType || params.groupName;

                const body = {
                    svgContent: _pdfPreSplitMergedSvg,
                    groupName: groupType,
                    proximityRadius: params.proximityRadius,
                    autoDetectAll: true,
                    minClusterElements: 1,
                    maxClusterDiagonal: Math.max(params.maxClusterDiagonal, Math.hypot(seedW, seedH) * 2),
                    similarityThreshold: params.similarityThreshold
                };

                if (seedW > 0 && seedH > 0) {
                    body.seedBbox = { x: 0, y: 0, w: seedW, h: seedH };
                    body.selectionMode = 'cluster-seed';
                }

                console.log('[SearchObj][Shapely] Request params: groupName=%s, proximity=%d, maxDiag=%d, similarity=%s, svgLen=%d',
                    groupType, body.proximityRadius, Math.round(body.maxClusterDiagonal),
                    body.similarityThreshold, _pdfPreSplitMergedSvg.length);
                console.log('[SearchObj][Shapely] seedBbox=%o, selectionMode=%s', body.seedBbox || null, body.selectionMode || 'auto');

                const abortCtrl = new AbortController();
                const abortTimer = setTimeout(() => abortCtrl.abort(), 180_000);
                const resp = await fetch(GROUP_OBJ_ENDPOINT, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    signal: abortCtrl.signal,
                    body: JSON.stringify(body)
                });
                clearTimeout(abortTimer);

                console.log('[SearchObj][Shapely] Response status: %d %s', resp.status, resp.statusText);

                if (!resp.ok) {
                    const errText = await resp.text();
                    console.warn('[SearchObj][Shapely] HTTP ERROR %d: %s', resp.status, errText.substring(0, 500));
                    return [];
                }

                const data = await resp.json();
                console.log('[SearchObj][Shapely] Response: ok=%s, groupsCreated=%d, elementsGrouped=%d, clusters=%d, message=%s',
                    data.ok, data.groupsCreated || 0, data.elementsGrouped || 0,
                    (data.clusters || []).length, data.message || '');

                if (!data.ok) {
                    console.warn('[SearchObj][Shapely] Server returned ok=false: error=%s message=%s', data.error || '', data.message || '');
                    return [];
                }

                const clusters = data.clusters || [];

                // Log each cluster for inspection
                clusters.forEach((cl, i) => {
                    console.log('[SearchObj][Shapely] Cluster[%d] id=%s cx=%.0f cy=%.0f bbox={x:%.0f,y:%.0f,w:%.0f,h:%.0f} elements=%d',
                        i, cl.id || '', cl.cx || 0, cl.cy || 0, cl.x, cl.y, cl.w, cl.h, cl.elementCount || 0);
                });

                if (clusters.length === 0) {
                    console.warn('[SearchObj][Shapely] Server found 0 clusters — no similar objects detected by Shapely');
                }

                console.log('[SearchObj][Shapely] === SHAPELY SEARCH END: %d clusters ===', clusters.length);

                return clusters.map(cl => ({
                    elements: [],
                    bbox: { x: cl.x, y: cl.y, w: cl.w, h: cl.h },
                    source: 'shapely'
                }));
            } catch (e) {
                if (e.name === 'AbortError' || (e.message && String(e.message).includes('abort'))) {
                    console.warn('[SearchObj][Shapely] Request ABORTED/TIMED OUT: %s', e.message || e);
                } else {
                    console.warn('[SearchObj][Shapely] Error: %s', e.message || e);
                    console.warn('[SearchObj][Shapely] Stack:', e.stack || '');
                }
                return [];
            }
        }

        /**
         * Merge client-side and Shapely search results.
         * Removes duplicates where bboxes overlap significantly.
         */
        function _mergeSearchResults(clientGroups, shapelyGroups) {
            console.log('[SearchObj][Merge] === MERGE START: client=%d, shapely=%d ===', clientGroups.length, shapelyGroups.length);

            if (!shapelyGroups.length && !clientGroups.length) {
                console.warn('[SearchObj][Merge] Both sources returned 0 results — nothing found');
                return [];
            }
            if (!shapelyGroups.length) {
                console.log('[SearchObj][Merge] No Shapely results — using %d client groups only', clientGroups.length);
                return clientGroups;
            }
            if (!clientGroups.length) {
                console.log('[SearchObj][Merge] No client results — using %d Shapely groups only', shapelyGroups.length);
                return shapelyGroups;
            }

            const merged = [...clientGroups];
            let dupCount = 0, addedCount = 0;

            for (const sg of shapelyGroups) {
                const sb = sg.bbox;
                const scx = sb.x + sb.w / 2, scy = sb.y + sb.h / 2;
                let isDuplicate = false;
                let closestDist = Infinity, closestIdx = -1;
                for (let ci = 0; ci < merged.length; ci++) {
                    const cb = merged[ci].bbox;
                    const ccx = cb.x + cb.w / 2, ccy = cb.y + cb.h / 2;
                    const dist = Math.hypot(scx - ccx, scy - ccy);
                    if (dist < closestDist) { closestDist = dist; closestIdx = ci; }
                    const maxDiag = Math.max(Math.hypot(sb.w, sb.h), Math.hypot(cb.w, cb.h));
                    if (dist < maxDiag * 0.5) {
                        isDuplicate = true;
                        break;
                    }
                }
                if (isDuplicate) {
                    dupCount++;
                    console.log('[SearchObj][Merge] Shapely group at (%.0f,%.0f) DUPLICATE of client group[%d] (dist=%.0f)',
                        scx, scy, closestIdx, closestDist);
                } else {
                    addedCount++;
                    merged.push(sg);
                    console.log('[SearchObj][Merge] Shapely group at (%.0f,%.0f) ADDED (nearest client at dist=%.0f)',
                        scx, scy, closestDist);
                }
            }

            console.log('[SearchObj][Merge] === MERGE RESULT: %d client + %d shapely → %d added + %d duplicates = %d total ===',
                clientGroups.length, shapelyGroups.length, addedCount, dupCount, merged.length);
            return merged;
        }

        /* ── Delete checked objects from the merged SVG map ── */
        function _deleteCheckedObjectsFromMap() {
            console.log('[SearchObj] === DELETE FROM MAP START ===');
            const checkboxes = document.querySelectorAll('.inlineGroupObjCheckbox:checked');
            const samples = _inlineGroupObjects;
            const indices = [];
            if (checkboxes.length > 0) {
                checkboxes.forEach(cb => {
                    const idx = parseInt(cb.dataset.sampleIdx, 10);
                    if (Number.isFinite(idx) && idx >= 0 && idx < samples.length) indices.push(idx);
                });
            } else {
                for (let i = 0; i < samples.length; i++) indices.push(i);
            }

            if (!indices.length) { cgAlert('No objects selected'); return; }
            if (!confirm('Delete matching objects from the map?')) return;

            if (!mergedSvgPreviewScale) return;
            const svg = mergedSvgPreviewScale.querySelector('svg');
            if (!svg) return;

            // ── Color group type: delete by color, not shape ──
            const currentGroupType = _inlineGroupObjectsGroupType || (groupNameSelect ? groupNameSelect.value : '');
            if (_isColorGroupType(currentGroupType)) {
                console.log('[SearchObj][Delete] Color group — deleting by color match');
                const targetColors = new Set();
                indices.forEach(idx => {
                    const s = samples[idx];
                    if (!s) return;
                    const svgText = (s.sampleSvg != null) ? String(s.sampleSvg) : '';
                    const color = _extractColorFromSwatchSvg(svgText);
                    if (color) {
                        const n = _normalizeColor(color);
                        if (n) targetColors.add(n);
                    }
                });
                if (!targetColors.size) { cgAlert('No target colors found'); return; }

                let removed = 0;
                const toRemove = [];
                const shapes = svg.querySelectorAll(_SHAPE_SELECTOR);
                for (const el of shapes) {
                    try { if (el.closest && el.closest('defs')) continue; } catch {}
                    const fillNorm = _normalizeColor(_getElementFill(el));
                    const strokeNorm = _normalizeColor(_getElementStroke(el));
                    if (targetColors.has(fillNorm) || targetColors.has(strokeNorm)) {
                        toRemove.push(el);
                    }
                }
                const removedSet = new Set();
                toRemove.forEach(el => {
                    if (removedSet.has(el)) return;
                    removedSet.add(el);
                    try { el.remove(); removed++; } catch {}
                });
                _pdfPreSplitMergedSvg = svg.outerHTML;
                _removeSearchHighlights();
                _refreshLegendFromDom(svg);
                _updateMergedSvgSummaryAfterEdit(svg);
                console.log('[SearchObj][Delete] Color delete complete: removed %d elements', removed);
                cgAlert(`Deleted ${removed} color-matched objects from the map`);
                return;
            }

            // ── Shape-based delete (non-color groups) ──
            // Collect signatures
            let allSigs = [];
            indices.forEach(idx => {
                const s = samples[idx];
                if (!s) return;
                const svgText = (s.sampleSvg != null) ? String(s.sampleSvg) : '';
                allSigs = allSigs.concat(_extractSamplePathSignatures(svgText));
            });

            if (!allSigs.length) { cgAlert('No search signatures found'); return; }

            // Find & remove from the live SVG DOM (svg already declared above)

            const pathDSet = new Set();
            const deltaSet = new Set();
            allSigs.forEach(s => {
                if (s.type === 'path-d-exact') pathDSet.add(s.value);
                else if (s.type === 'path-d-delta') deltaSet.add(s.value);
            });

            let removed = 0;
            const toRemove = [];

            // Use both exact and delta matching
            svg.querySelectorAll('path').forEach(p => {
                if (toRemove.includes(p) || toRemove.includes(p.parentElement)) return;
                const d = (p.getAttribute('d') || '').trim();
                if (!d) return;

                let matched = false;
                // Exact match
                if (pathDSet.size > 0) {
                    const norm = d.replace(/\s+/g, ' ').replace(/,\s*/g, ',');
                    if (pathDSet.has(norm)) matched = true;
                }
                // Delta match
                if (!matched && deltaSet.size > 0 && d.length >= 4) {
                    const delta = _normalizePath(d);
                    if (delta && deltaSet.has(delta)) {
                        const vb = svg.viewBox?.baseVal;
                        const maxDim = vb ? Math.max(vb.width, vb.height) * 0.15 : 10000;
                        try {
                            const bb = _getElementBBoxInSvgSpace(p, svg);
                            if (bb && bb.w < maxDim && bb.h < maxDim) matched = true;
                        } catch { matched = true; }
                    }
                }

                if (matched) {
                    const parent = p.parentElement;
                    if (parent && parent.tagName.toLowerCase() === 'g' && parent !== svg) {
                        toRemove.push(parent);
                    } else {
                        toRemove.push(p);
                    }
                }
            });

            // Remove unique elements
            const removedSet = new Set();
            toRemove.forEach(el => {
                if (removedSet.has(el)) return;
                removedSet.add(el);
                try { el.remove(); removed++; } catch { /* ignore */ }
            });

            // Update the stored SVG string
            _pdfPreSplitMergedSvg = svg.outerHTML;
            _removeSearchHighlights();
            _refreshLegendFromDom(svg);
            _updateMergedSvgSummaryAfterEdit(svg);

            console.log('[SearchObj] === DELETE COMPLETE: removed %d elements ===', removed);
            cgAlert(`Deleted ${removed} objects from the map`);
        }

        function _renderSavedObjectPreview(previewSvgEl, sampleSvg, groupType, familyName) {
