@page "{id:guid?}"
@model CRMManagement.Web.Pages.Admin.Pipelines.UpsertModel
@{
    var isNew = Model.Id is null;
    ViewData["Title"] = isNew ? "New Pipeline" : "Edit Pipeline";
}

<style>
    .cred-form-input{background:light-dark(#ffffff,rgba(15,23,42,.4));border-color:light-dark(#aab7b8,rgba(100,116,139,.5));color:light-dark(#16191f,#f1f5f9)}
    .cred-form-input::placeholder{color:light-dark(#687078,rgba(148,163,184,.65))}
    .cred-form-input:focus{outline:none;border-color:#0ea5e9;box-shadow:0 0 0 2px rgba(14,165,233,.25)}
    .cred-form-label{color:light-dark(#545b64,#94a3b8)}
    .comm-section-title{display:flex;align-items:center;gap:.5rem;font-size:.8125rem;line-height:1.25rem;font-weight:600;text-transform:uppercase;letter-spacing:.08em;color:light-dark(#16191f,rgb(203 213 225))}
    .comm-section-title i{color:light-dark(#0073bb,rgb(59 130 246));font-size:.875rem}
    .vm-action-btn{border-color:light-dark(#c5ccd3,rgba(71,85,105,.5));color:light-dark(#16191f,#f1f5f9)}
    html[data-theme="gray"] .cred-form-card{background:rgb(51,65,85)!important;border-color:rgba(71,85,105,.55)!important;box-shadow:0 2px 8px rgba(0,0,0,.35)!important}
    html[data-theme="gray"] .cred-form-input{background:rgba(15,23,42,.4)!important;border-color:rgba(100,116,139,.5)!important}
    html[data-theme="gray"] .vm-action-btn{border-color:rgba(100,116,139,.6)!important;color:#f1f5f9!important}
    html[data-theme="black"] .cred-form-card{background:rgb(22,22,22)!important;border-color:rgba(255,255,255,.08)!important;box-shadow:0 2px 12px rgba(0,0,0,.6)!important}
    html[data-theme="black"] .cred-form-input{background:rgba(0,0,0,.4)!important;border-color:rgba(255,255,255,.10)!important}
    html[data-theme="black"] .vm-action-btn{border-color:rgba(255,255,255,.12)!important;color:#f1f5f9!important}
    html[data-theme="light"] .cred-form-card{background:#ffffff!important;border-color:#d5dbdb!important;box-shadow:0 1px 4px rgba(0,0,0,.1)!important}
    html[data-theme="light"] .cred-form-input{background:#ffffff!important;border-color:#aab7b8!important;color:#16191f!important}
    html[data-theme="light"] .cred-form-label{color:#545b64!important}
    @@media(max-width:767px){#pipe-form-root .grid{grid-template-columns:1fr!important;gap:.65rem!important}#pipe-form-root .grid>[style*="grid-column"]{grid-column:auto!important}}
</style>

<section id="pipe-form-root" class="w-full" style="padding-left:0;padding-right:0;padding-bottom:2rem;margin-top:.5rem;">
    <div class="cred-form-card w-full rounded-2xl border overflow-hidden">
        <form method="post">
        <input type="hidden" asp-for="Id" />
        <div class="flex flex-col gap-2 py-2">
            <div class="px-4 flex flex-col md:flex-row md:items-start md:justify-between gap-3">
                <div>
                    <h2 class="comm-section-title"><i class="fa-solid fa-diagram-project"></i><span>@ViewData["Title"]</span></h2>
                    <div class="text-sm mt-0.5" style="color:light-dark(#545b64,#94a3b8)">@(isNew ? "Create a new pipeline with stages." : "Edit pipeline details and stages.")</div>
                </div>
                <div class="flex flex-wrap items-center gap-2 shrink-0">
                    <button type="submit" class="inline-flex items-center gap-2 rounded-full bg-sky-600 hover:bg-sky-500 px-3 py-1.5 text-sm text-white transition font-medium"><i class="fas fa-save text-xs"></i> Save</button>
                    <a asp-page="/Admin/Pipelines/Index" class="vm-action-btn inline-flex items-center gap-2 rounded-full border px-3 py-1.5 text-sm hover:opacity-80 transition" title="Back to pipelines"><i class="fa-solid fa-arrow-left text-xs"></i><span>Back</span></a>
                </div>
            </div>
            <div class="border-t" style="border-color:light-dark(#d5dbdb,rgba(255,255,255,.08))!important;"></div>
            <div class="px-4 py-3">
                <div asp-validation-summary="ModelOnly" class="text-red-400 text-sm mb-2"></div>
                <div class="grid" style="grid-template-columns:repeat(2,minmax(0,1fr));gap:.75rem;">
                    <div class="space-y-1.5">
                        <label asp-for="Name" class="cred-form-label block text-sm font-medium"><span class="inline-flex items-center gap-2"><i class="fa-solid fa-diagram-project text-xs"></i><span>Name</span><span class="text-red-500">*</span></span></label>
                        <input asp-for="Name" required placeholder="Pipeline name" class="cred-form-input w-full rounded-lg border px-3 py-2 text-sm" />
                        <span asp-validation-for="Name" class="text-red-400 text-xs"></span>
                    </div>
                    <div class="space-y-1.5">
                        <label asp-for="SortOrder" class="cred-form-label block text-sm font-medium"><span class="inline-flex items-center gap-2"><i class="fa-solid fa-sort text-xs"></i><span>Sort Order</span></span></label>
                        <input asp-for="SortOrder" type="number" placeholder="0" class="cred-form-input w-full rounded-lg border px-3 py-2 text-sm" />
                    </div>
                    <div class="space-y-1.5" style="grid-column:1/-1;">
                        <label asp-for="Description" class="cred-form-label block text-sm font-medium"><span class="inline-flex items-center gap-2"><i class="fa-solid fa-align-left text-xs"></i><span>Description</span></span></label>
                        <input asp-for="Description" placeholder="Pipeline description" class="cred-form-input w-full rounded-lg border px-3 py-2 text-sm" />
                    </div>
                    <div class="space-y-1.5" style="grid-column:1/-1;">
                        <label class="inline-flex items-center gap-2 text-sm" style="color:light-dark(#16191f,#f1f5f9)"><input type="checkbox" asp-for="IsDefault" class="accent-sky-500" /> Default</label>
                    </div>
                </div>
            </div>
        </div>
        </form>
    </div>

    <div class="cred-form-card w-full rounded-2xl border overflow-hidden mt-3">
        <div class="px-4 py-3" style="border-bottom:1px solid light-dark(#d5dbdb,rgba(255,255,255,.08))">
            <h2 class="comm-section-title"><i class="fa-solid fa-layer-group"></i><span>Stages</span></h2>
        </div>
        <div class="px-4 py-3 space-y-2">
            @for (int i = 0; i < Model.Stages.Count; i++)
            {
                <div class="grid gap-2" style="grid-template-columns:repeat(5,minmax(0,1fr));">
                    <input type="hidden" name="Stages[@i].Id" value="@Model.Stages[i].Id" />
                    <input name="Stages[@i].Name" value="@Model.Stages[i].Name" placeholder="Name" class="cred-form-input rounded-lg border px-3 py-2 text-sm" />
                    <input name="Stages[@i].SortOrder" value="@Model.Stages[i].SortOrder" type="number" placeholder="Order" class="cred-form-input rounded-lg border px-3 py-2 text-sm" />
                    <input name="Stages[@i].Probability" value="@Model.Stages[i].Probability" type="number" placeholder="Probability" class="cred-form-input rounded-lg border px-3 py-2 text-sm" />
                    <label class="inline-flex items-center gap-2 text-sm" style="color:light-dark(#16191f,#f1f5f9)"><input type="checkbox" name="Stages[@i].IsWon" value="true" class="accent-sky-500" @(Model.Stages[i].IsWon ? "checked" : "") /> Won</label>
                    <label class="inline-flex items-center gap-2 text-sm" style="color:light-dark(#16191f,#f1f5f9)"><input type="checkbox" name="Stages[@i].IsLost" value="true" class="accent-sky-500" @(Model.Stages[i].IsLost ? "checked" : "") /> Lost</label>
                </div>
            }
            @for (int i = Model.Stages.Count; i < Model.Stages.Count + 3; i++)
            {
                <div class="grid gap-2" style="grid-template-columns:repeat(5,minmax(0,1fr));">
                    <input name="Stages[@i].Name" placeholder="New stage name" class="cred-form-input rounded-lg border px-3 py-2 text-sm" />
                    <input name="Stages[@i].SortOrder" type="number" value="@i" class="cred-form-input rounded-lg border px-3 py-2 text-sm" />
                    <input name="Stages[@i].Probability" type="number" value="0" class="cred-form-input rounded-lg border px-3 py-2 text-sm" />
                    <label class="inline-flex items-center gap-2 text-sm" style="color:light-dark(#16191f,#f1f5f9)"><input type="checkbox" name="Stages[@i].IsWon" value="true" class="accent-sky-500" /> Won</label>
                    <label class="inline-flex items-center gap-2 text-sm" style="color:light-dark(#16191f,#f1f5f9)"><input type="checkbox" name="Stages[@i].IsLost" value="true" class="accent-sky-500" /> Lost</label>
                </div>
            }
        </div>
    </div>
</section>
