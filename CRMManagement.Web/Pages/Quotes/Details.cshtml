@page "{id:guid}"
@model CRMManagement.Web.Pages.Quotes.DetailsModel
@{ ViewData["Title"] = "Quote Details"; }

@if (Model.Item is null)
{
    <div class="p-4 text-slate-300">Not found.</div>
}
else
{
    var q = Model.Item;
    <section class="p-4 space-y-4">
        <div class="flex items-center justify-between">
            <h1 class="text-2xl font-semibold text-slate-100">@q.QuoteNumber - @q.Name</h1>
            <a asp-page="/Quotes/Upsert" asp-route-id="@q.Id" class="px-4 py-2 rounded-xl bg-blue-600 hover:bg-blue-500 text-white text-sm">Edit</a>
        </div>
        <div class="rounded-2xl border border-slate-700/50 bg-slate-800/40 p-6 grid grid-cols-1 md:grid-cols-2 gap-4 text-sm text-slate-200">
            <div><span class="text-slate-400">Status:</span> @q.Status</div>
            <div><span class="text-slate-400">Expires:</span> @(q.ExpiresAt?.ToString("yyyy-MM-dd") ?? "-")</div>
            <div><span class="text-slate-400">Subtotal:</span> @q.Subtotal.ToString("N2")</div>
            <div><span class="text-slate-400">Discount:</span> @q.Discount.ToString("N2")</div>
            <div><span class="text-slate-400">Tax:</span> @q.Tax.ToString("N2")</div>
            <div><span class="text-slate-400">Total:</span> @q.Total.ToString("N2") @q.Currency</div>
            <div class="md:col-span-2"><span class="text-slate-400">Notes:</span> @q.Notes</div>
        </div>
        <div class="rounded-2xl border border-slate-700/50 bg-slate-800/40 p-6">
            <h2 class="text-lg font-semibold text-slate-100 mb-3">Lines</h2>
            <table class="w-full text-sm text-slate-200">
                <thead><tr class="text-left text-xs uppercase text-slate-400"><th class="py-2">Product</th><th class="py-2">Description</th><th class="py-2">Qty</th><th class="py-2">Unit</th><th class="py-2">Total</th></tr></thead>
                <tbody>
                @foreach (var l in q.Lines)
                {
                    <tr class="border-t border-slate-700/40">
                        <td class="py-2">@l.ProductId</td><td class="py-2">@l.Description</td><td class="py-2">@l.Quantity</td><td class="py-2">@l.UnitPrice.ToString("N2")</td><td class="py-2">@l.LineTotal.ToString("N2")</td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
        <partial name="_CustomFields" model='(EntityType: "Quote", EntityId: Model.Item!.Id)' />
</section>
}
