@page
@model CRMManagement.Web.Pages.Dashboard.IndexModel
@{
    ViewData["Title"] = "Dashboard";
}

<section class="crm-dash-page w-full mt-2 space-y-3" data-page="crm-dashboard">
    <style>
        .crm-dash-page {
            box-sizing: border-box;
            max-width: 100%;
            overflow-x: hidden;
            padding-left: 0;
            padding-right: 0;
        }

        .app-content:has(.crm-dash-page) { overflow-x: hidden !important; max-width: 100vw; }
        .app-main:has(.crm-dash-page) {
            padding-left: 0.5rem !important;
            padding-right: 0.5rem !important;
            overflow-x: hidden !important;
            max-width: 100%;
        }

        .crm-dash-shell { overflow: hidden; max-width: 100%; box-sizing: border-box; }
        .crm-dash-content { padding: 1.5rem; max-width: 100%; box-sizing: border-box; }

        .crm-dash-kpi-grid {
            display: grid;
            grid-template-columns: repeat(5, minmax(0, 1fr));
            column-gap: 0.75rem;
            row-gap: 2rem;
            max-width: 100%;
            box-sizing: border-box;
            margin-bottom: 0.25rem;
        }
        .crm-dash-kpi-grid > div { width: 100%; min-width: 0; overflow: hidden; }

        .crm-dash-detail-grid {
            display: grid;
            grid-template-columns: 1fr;
            gap: 0.75rem;
        }

        .crm-dash-panel { padding: 1.25rem; }

        .crm-dash-opp-cards {
            display: grid;
            grid-template-columns: repeat(2, minmax(0, 1fr));
            gap: 0.75rem;
        }
        .crm-dash-opp-cards > div { width: 100%; min-width: 0; }

        @@media (max-width: 1300px) {
            .crm-dash-kpi-grid { grid-template-columns: repeat(3, minmax(0, 1fr)); }
        }
        @@media (max-width: 900px) {
            .crm-dash-opp-cards { grid-template-columns: 1fr; }
        }
        @@media (max-width: 700px) {
            .crm-dash-kpi-grid { grid-template-columns: 1fr; }
        }
        @@media (max-width: 640px) {
            .app-main:has(.crm-dash-page) {
                padding-left: 0 !important;
                padding-right: 0 !important;
                padding-top: 0.5rem !important;
            }
            .crm-dash-page { padding-left: 0 !important; padding-right: 0 !important; margin-top: 0; }
            .crm-dash-shell { border-left: 0; border-right: 0; border-radius: 0; }
            .crm-dash-shell > div:first-child { padding-left: 0.9rem; padding-right: 0.9rem; }
            .crm-dash-content { padding: 0.9rem; }
            .crm-dash-kpi-grid { gap: 0.75rem; }
            .crm-dash-panel { padding: 0.9rem; }
            .crm-dash-opp-cards { gap: 0.6rem; }
        }

        /* ── GRAY theme: raised card ── */
        html[data-theme="gray"] .crm-dash-kpi-grid > div,
        html[data-theme="gray"] .crm-dash-panel,
        html[data-theme="gray"] .crm-dash-content > .rounded-2xl {
            background-color: rgba(255,255,255,.10) !important;
            border-color: rgba(148,163,184,.45) !important;
            box-shadow: 0 6px 24px -4px rgba(0,0,0,.55), 0 0 0 1px rgba(255,255,255,.07) !important;
        }
        html[data-theme="gray"] .crm-dash-opp-cards > div {
            background-color: rgba(255,255,255,.06) !important;
            border-color: rgba(148,163,184,.30) !important;
        }

        /* ── LIGHT theme: raised card ── */
        html[data-theme="light"] .crm-dash-kpi-grid > div,
        html[data-theme="light"] .crm-dash-panel,
        html[data-theme="light"] .crm-dash-content > .rounded-2xl {
            box-shadow: 0 6px 24px -4px rgba(0,0,0,.15), 0 0 0 1px rgba(0,0,0,.06) !important;
        }

        /* ── BLACK theme ── */
        html[data-theme="black"] .crm-dash-shell {
            background: #0a0a0a !important; border-color: rgba(255,255,255,.08) !important;
            box-shadow: 0 2px 8px rgba(0,0,0,.6) !important; color: #e4e4e7 !important;
        }
        html[data-theme="black"] .crm-dash-shell > div:first-child { border-bottom-color: rgba(255,255,255,.06) !important; }
        html[data-theme="black"] .crm-dash-kpi-grid > div,
        html[data-theme="black"] .crm-dash-panel,
        html[data-theme="black"] .crm-dash-content > .rounded-2xl {
            background-color: rgba(255,255,255,.02) !important;
            border-color: rgba(255,255,255,.05) !important;
            box-shadow: 0 6px 24px -4px rgba(0,0,0,.7), 0 0 0 1px rgba(255,255,255,.04) !important;
        }
        html[data-theme="black"] .crm-dash-opp-cards > div {
            background-color: rgba(255,255,255,.015) !important;
            border-color: rgba(255,255,255,.04) !important;
        }

        /* ── Mobile card-table ── */
        @@media (max-width: 768px) {
            .crm-dash-table thead { display: none; }
            .crm-dash-table, .crm-dash-table tbody, .crm-dash-table tr, .crm-dash-table td { display: block; width: 100%; box-sizing: border-box; }
            .crm-dash-table tr { padding: 0.75rem 1rem; border-bottom: 1px solid rgba(82,82,91,.35); }
            .crm-dash-table td { padding: 0.2rem 0; white-space: normal !important; }
            .crm-dash-table td::before {
                content: attr(data-label);
                display: block; font-size: 0.65rem; font-weight: 600;
                text-transform: uppercase; letter-spacing: 0.12em;
                color: light-dark(#545b64, #a1a1aa); margin-bottom: 0.15rem;
            }
        }
    </style>

    @if (Model.Summary is null)
    {
        <div class="rounded-2xl border p-6" style="background:light-dark(#ffffff, rgb(51,65,85));border-color:light-dark(#d5dbdb, rgba(71,85,105,.5));color:light-dark(#16191f, #cbd5e1)">Loading...</div>
    }
    else
    {
        var s = Model.Summary;

        <div class="crm-dash-shell rounded-2xl border overflow-hidden"
             style="background:light-dark(#ffffff, rgb(51,65,85));
                    border-color:light-dark(#d5dbdb, rgba(71,85,105,.5));
                    box-shadow:light-dark(0 1px 4px rgba(0,0,0,.1), 0 2px 8px rgba(0,0,0,.35));
                    color:light-dark(#16191f, #f1f5f9)">

            <!-- ── Header ── -->
            <div class="flex flex-wrap items-center gap-3 px-4 py-3"
                 style="border-bottom:1px solid light-dark(#d5dbdb, rgba(255,255,255,.08))">
                <i class="fa-solid fa-address-book text-sm" style="color:light-dark(#0073bb, #3b82f6)"></i>
                <div class="min-w-0">
                    <h3 class="text-sm font-semibold uppercase tracking-wider"
                        style="color:light-dark(#545b64, #cbd5e1)">CRM Dashboard</h3>
                    <div class="mt-0.5 text-xs" style="color:light-dark(#687078, #94a3b8)">Leads, opportunities, tickets, and pipeline overview.</div>
                </div>
            </div>

            <!-- ── Content ── -->
            <div class="crm-dash-content" style="display:flex;flex-direction:column;gap:0.85rem;">

                <!-- ── KPI Summary Grid ── -->
                <div class="crm-dash-kpi-grid">
                    <div class="rounded-xl border px-4 py-4"
                         style="background-color:light-dark(#e8eef5, rgba(255,255,255,.06));border-color:light-dark(#adb8c4, rgba(255,255,255,.10));box-shadow:light-dark(0 2px 8px rgba(0,0,0,.08), 0 2px 10px rgba(0,0,0,.25))">
                        <div class="text-xs uppercase tracking-wide font-semibold" style="color:light-dark(#0073bb, #7dd3fc)">Open Leads</div>
                        <div class="mt-1 text-2xl font-bold leading-tight" style="color:light-dark(#16191f, #f8fafc)">@s.OpenLeads</div>
                    </div>
                    <div class="rounded-xl border px-4 py-4"
                         style="background-color:light-dark(#e8eef5, rgba(255,255,255,.06));border-color:light-dark(#adb8c4, rgba(255,255,255,.10));box-shadow:light-dark(0 2px 8px rgba(0,0,0,.08), 0 2px 10px rgba(0,0,0,.25))">
                        <div class="text-xs uppercase tracking-wide font-semibold" style="color:light-dark(#0073bb, #7dd3fc)">Open Opportunities</div>
                        <div class="mt-1 text-2xl font-bold leading-tight" style="color:light-dark(#16191f, #f8fafc)">@s.OpenOpportunities</div>
                        <div class="mt-1 text-xs" style="color:light-dark(#687078, #94a3b8)">Pipeline @s.TotalPipelineAmount.ToString("N2")</div>
                    </div>
                    <div class="rounded-xl border px-4 py-4"
                         style="background-color:light-dark(#e8eef5, rgba(255,255,255,.06));border-color:light-dark(#adb8c4, rgba(255,255,255,.10));box-shadow:light-dark(0 2px 8px rgba(0,0,0,.08), 0 2px 10px rgba(0,0,0,.25))">
                        <div class="text-xs uppercase tracking-wide font-semibold" style="color:light-dark(#0073bb, #7dd3fc)">Won This Month</div>
                        <div class="mt-1 text-2xl font-bold leading-tight" style="color:light-dark(#16191f, #f8fafc)">@s.WonOpportunitiesThisMonth</div>
                        <div class="mt-1 text-xs" style="color:light-dark(#687078, #94a3b8)">Amount @s.WonAmountThisMonth.ToString("N2")</div>
                    </div>
                    <div class="rounded-xl border px-4 py-4"
                         style="background-color:light-dark(#e8eef5, rgba(255,255,255,.06));border-color:light-dark(#adb8c4, rgba(255,255,255,.10));box-shadow:light-dark(0 2px 8px rgba(0,0,0,.08), 0 2px 10px rgba(0,0,0,.25))">
                        <div class="text-xs uppercase tracking-wide font-semibold" style="color:light-dark(#0073bb, #7dd3fc)">Open Tickets</div>
                        <div class="mt-1 text-2xl font-bold leading-tight" style="color:light-dark(#16191f, #f8fafc)">@s.OpenTickets</div>
                    </div>
                    <div class="rounded-xl border px-4 py-4"
                         style="background-color:light-dark(#e8eef5, rgba(255,255,255,.06));border-color:light-dark(#adb8c4, rgba(255,255,255,.10));box-shadow:light-dark(0 2px 8px rgba(0,0,0,.08), 0 2px 10px rgba(0,0,0,.25))">
                        <div class="text-xs uppercase tracking-wide font-semibold" style="color:light-dark(#0073bb, #7dd3fc)">Pipeline Amount</div>
                        <div class="mt-1 text-2xl font-bold leading-tight" style="color:light-dark(#16191f, #f8fafc)">@s.TotalPipelineAmount.ToString("N2")</div>
                    </div>
                </div>

                <!-- ── Top Opportunities Panel ── -->
                <div class="crm-dash-panel rounded-2xl border space-y-3"
                     style="background-color:light-dark(#e8eef5, rgba(255,255,255,.03));border-color:light-dark(#adb8c4, rgba(255,255,255,.06))">
                    <div class="flex items-center justify-between gap-3">
                        <div>
                            <h3 class="text-sm font-semibold uppercase tracking-[0.18em]" style="color:light-dark(#545b64, #cbd5e1)">Top opportunities</h3>
                            <div class="mt-1 text-xs" style="color:light-dark(#687078, #94a3b8)">Top 5 opportunities ranked by deal amount.</div>
                        </div>
                        <i class="fa-solid fa-trophy text-brand text-sm"></i>
                    </div>

                    @if (s.TopOpportunities.Count == 0)
                    {
                        <div class="text-sm" style="color:light-dark(#687078, #94a3b8)">No opportunities yet.</div>
                    }
                    else
                    {
                        <div class="crm-dash-opp-cards">
                            @foreach (var o in s.TopOpportunities)
                            {
                                <div class="rounded-xl border p-4"
                                     style="background-color:light-dark(#e8eef5, rgba(255,255,255,.03));border-color:light-dark(#adb8c4, rgba(255,255,255,.06))">
                                    <div class="flex items-start justify-between gap-3">
                                        <div class="min-w-0">
                                            <a asp-page="/Opportunities/Details" asp-route-id="@o.Id"
                                               class="text-sm font-semibold hover:underline truncate block"
                                               style="color:light-dark(#0073bb, #7dd3fc)">@o.Name</a>
                                            <div class="mt-1 text-xs" style="color:light-dark(#687078, #94a3b8)">@o.Status · @(o.CloseDate?.ToString("yyyy-MM-dd") ?? "No close date")</div>
                                        </div>
                                        <div class="text-lg font-semibold whitespace-nowrap" style="color:light-dark(#16191f, #f1f5f9)">@o.Amount.ToString("N2") @o.Currency</div>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>

                <!-- ── Recent Activities Panel ── -->
                <div class="rounded-2xl border overflow-hidden"
                     style="background-color:light-dark(#e8eef5, rgba(255,255,255,.03));border-color:light-dark(#adb8c4, rgba(255,255,255,.06))">
                    <div class="flex flex-wrap items-center gap-3 px-5 py-4"
                         style="border-bottom:1px solid light-dark(#d5dbdb, rgba(255,255,255,.08))">
                        <div>
                            <h3 class="text-sm font-semibold uppercase tracking-[0.18em]" style="color:light-dark(#545b64, #cbd5e1)">Recent activities</h3>
                            <div class="mt-1 text-xs" style="color:light-dark(#687078, #94a3b8)">Latest tasks, calls, meetings, and emails across the CRM.</div>
                        </div>
                        <i class="ml-auto fa-solid fa-clock-rotate-left text-brand text-sm"></i>
                    </div>

                    @if (s.RecentActivities.Count == 0)
                    {
                        <div class="p-5 text-sm" style="color:light-dark(#687078, #94a3b8)">No recent activities.</div>
                    }
                    else
                    {
                        <div class="overflow-x-auto">
                            <table class="crm-dash-table min-w-full divide-y text-sm" style="--tw-divide-opacity:.12; border-color:light-dark(#d5dbdb, rgba(255,255,255,.08))">
                                <thead style="background-color:light-dark(#dde3ea, rgba(0,0,0,.15))">
                                    <tr style="color:light-dark(#545b64, #94a3b8)">
                                        <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wider">Subject</th>
                                        <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wider">Type</th>
                                        <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wider">Status</th>
                                        <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wider">Due Date</th>
                                    </tr>
                                </thead>
                                <tbody class="divide-y" style="border-color:light-dark(#d5dbdb, rgba(255,255,255,.06))">
                                    @foreach (var a in s.RecentActivities)
                                    {
                                        <tr>
                                            <td data-label="Subject" class="px-4 py-3" style="color:light-dark(#16191f, #f1f5f9)">@a.Subject</td>
                                            <td data-label="Type" class="px-4 py-3" style="color:light-dark(#545b64, #cbd5e1)">@a.Type</td>
                                            <td data-label="Status" class="px-4 py-3" style="color:light-dark(#545b64, #cbd5e1)">@a.Status</td>
                                            <td data-label="Due Date" class="px-4 py-3" style="color:light-dark(#687078, #94a3b8)">@(a.DueDate?.ToString("yyyy-MM-dd") ?? "-")</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>

            </div>
        </div>
    }
</section>
