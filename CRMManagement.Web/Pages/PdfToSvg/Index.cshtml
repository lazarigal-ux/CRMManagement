    const shapeRow = document.getElementById(`fpShapeRow_${idx}`);
    if (shapeRow) {
      shapeRow.style.display = (mode === 'off') ? 'none' : 'flex';
      // Highlight active shape button
      shapeRow.querySelectorAll('.fpShapeBtn').forEach(b => {
        if (b.dataset.shape === shape) {
          b.className = b.className.replace(/\bp2s-btn\b/g, 'border-cyan-500/60 bg-cyan-900/40 text-cyan-200');
        } else {
          b.className = b.className.replace(/border-cyan-500\/60 bg-cyan-900\/40 text-cyan-200/g, 'p2s-btn');
        }
      });
    }

    const svg = document.getElementById(svgId);
    if (svg) {
      const cursor = (mode === 'select') ? 'crosshair'
        : (mode === 'delete') ? 'not-allowed'
        : (mode === 'cleanup') ? 'cell'
        : '';
      svg.style.cursor = cursor;

      const objCursor = (mode === 'off') ? 'pointer' : cursor;
      svg.querySelectorAll('g[data-fp-item-idx], g[data-fp-wall-idx], g[data-fp-door-idx]').forEach(g => {
        g.style.cursor = objCursor;
        g.querySelectorAll('circle, text, line, path').forEach(child => { child.style.cursor = objCursor; });
      });
    }
  }
  function _fpUpdateAreaShapeUi(svgId, btnId) {
    // Shape UI is now integrated into the Area Select button
    _fpUpdateAreaModeUi(svgId, btnId);
  }
  function _fpSvgPoint(svg, e) {
    const pt = svg.createSVGPoint();
    pt.x = e.clientX;
    pt.y = e.clientY;
    return pt.matrixTransform(svg.getScreenCTM().inverse());
  }
  // Ray-casting point-in-polygon test
  function _fpPointInPolygon(px, py, poly) {
    let inside = false;
    for (let i = 0, j = poly.length - 1; i < poly.length; j = i++) {
      const xi = poly[i].x, yi = poly[i].y;
      const xj = poly[j].x, yj = poly[j].y;
      if (((yi > py) !== (yj > py)) && (px < (xj - xi) * (py - yi) / (yj - yi) + xi))
        inside = !inside;
    }
    return inside;
  }
  window.fpToggleAreaSelect = function(svgId, btnId) {
    const cur = _fpGetAreaMode(svgId);
    const next = (cur === 'off') ? 'select'
      : (cur === 'select') ? 'delete'
      : (cur === 'delete') ? 'cleanup'
      : 'off';
    _fpAreaMode[svgId] = next;
    _fpUpdateAreaModeUi(svgId, btnId);
  };
  // Set a specific area shape (called from shape picker buttons)
  window.fpSetAreaShape = function(svgId, shape, shapeRowId, areaBtnId) {
    _fpAreaShape[svgId] = shape;
    if (_fpGetAreaMode(svgId) === 'off') {
      _fpAreaMode[svgId] = 'select';
    }
    _fpUpdateAreaModeUi(svgId, areaBtnId);
  };
  window.fpToggleAreaShape = function(svgId, btnId) {
    const cur = _fpGetAreaShape(svgId);
    const next = cur === 'rect' ? 'square'
      : cur === 'square' ? 'circle'
      : cur === 'circle' ? 'triangle'
      : 'rect';
    _fpAreaShape[svgId] = next;
    if (_fpGetAreaMode(svgId) === 'off') {
      _fpAreaMode[svgId] = 'select';
    }
    _fpUpdateAreaModeUi(svgId, btnId);
  };

  // Attach click + area-select drag handlers to all floor-plan SVGs
  window.fpAttachSvgHandlers = function() {
    document.querySelectorAll('svg[id^="fpSvg_"]').forEach(svg => {
      // Mouse wheel zoom + drag-to-pan on the scroll wrapper.
      // Matches the PDF Image tab behavior exactly.
      try {
        const wrap = svg.parentElement;
        if (wrap && wrap instanceof HTMLElement && !wrap.dataset.fpPanZoomInit) {
          wrap.dataset.fpPanZoomInit = '1';
          wrap.style.overscrollBehavior = 'contain';

          // ── Wheel zoom (identical to PDF Image tab) ──
          wrap.addEventListener('wheel', (ev) => {
            ev.preventDefault();
            const cur = _fpZoomLevels[svg.id] || 1;
            const factor = ev.deltaY < 0 ? 1.10 : 0.90;
            const next = _fpClamp(cur * factor, 0.25, 6.0);
            _fpSetZoomAnchored(svg, wrap, next, ev.clientX, ev.clientY);
          }, { passive: false });

          // ── Drag-to-pan (identical to PDF Image tab) ──
          let isPanning = false;
          let panStartX = 0, panStartY = 0;
          let panScrollLeft = 0, panScrollTop = 0;

          function canPanNow() {
            if (_fpGetAreaMode(svg.id) !== 'off') return false;
            if (_fpMarkWallsMode && _fpMarkWallsMode[svg.id]) return false;
            return true;
          }

          wrap.addEventListener('mousedown', (ev) => {
            if (ev.button !== 0) return;
            if (!canPanNow()) return;
            isPanning = true;
            panStartX = ev.clientX;
            panStartY = ev.clientY;
            panScrollLeft = wrap.scrollLeft;
            panScrollTop = wrap.scrollTop;
            wrap.style.cursor = 'grabbing';
            ev.preventDefault();
          });

          window.addEventListener('mousemove', (ev) => {
            if (!isPanning) return;
            const dx = ev.clientX - panStartX;
            const dy = ev.clientY - panStartY;
            if (Math.abs(dx) + Math.abs(dy) > 3) {
              try { svg.dataset.fpSuppressClick = '1'; } catch { }
            }
            wrap.scrollLeft = Math.max(0, panScrollLeft - dx);
            wrap.scrollTop = Math.max(0, panScrollTop - dy);
          });

          window.addEventListener('mouseup', () => {
            if (!isPanning) return;
            isPanning = false;
            wrap.style.cursor = canPanNow() ? 'grab' : '';
          });

          // Set default cursor
          if (canPanNow()) wrap.style.cursor = 'grab';
        }
      } catch { }

      // Prefer analysis-generated groups; otherwise fall back to generic SVG primitives.
      const groupSel = 'g[data-fp-item-idx], g[data-fp-wall-idx], g[data-fp-door-idx]';
      let targets = Array.from(svg.querySelectorAll(groupSel));

      if (targets.length === 0) {
        // Mark primitives selectable (so selection/delete works on traced SVGs).
        svg.querySelectorAll('path, line, polyline, polygon, rect, circle, ellipse, text').forEach(el => {
          try {
            if (el.closest && el.closest('defs')) return;
            if (el.id && String(el.id).startsWith('_fpSel')) return;
            el.setAttribute('data-fp-selectable', '1');
          } catch { }
        });
        targets = Array.from(svg.querySelectorAll('[data-fp-selectable="1"]'));
      }

      targets.forEach(el => {
        try {
          el.style.cursor = 'pointer';
          el.setAttribute('pointer-events', 'all');
        } catch { }

        el.addEventListener('click', (e) => {
          e.stopPropagation();
          // If the user just panned (dragged), suppress the click toggle.
          try {
            if (svg.dataset && svg.dataset.fpSuppressClick === '1') {
              svg.dataset.fpSuppressClick = '0';
              return;
            }
          } catch { }
          // Mark Walls mode is only meaningful for analysis walls.
          if (_fpMarkWallsMode[svg.id] && el.hasAttribute && el.hasAttribute('data-fp-wall-idx')) {
            _fpHandleWallMarkClick(svg, el);
            return;
          }
          const areaMode = _fpGetAreaMode(svg.id);
          if (areaMode !== 'off') {
            if (areaMode === 'select') {
              const isSelected = el.classList.contains('fp-selected');
              _fpMarkSelected(el, !isSelected);
              return;
            }
            if (areaMode === 'delete') {
              _fpClearAllSelected(svg);
              _fpMarkSelected(el, true);
              window.fpDeleteSelected(svg.id);
            } else if (areaMode === 'cleanup') {
              _fpMarkSelected(el, false);
            }
            return;
          }
          const isSelected = el.classList.contains('fp-selected');
          _fpMarkSelected(el, !isSelected);
        });
      });

      // Area-select drag handlers (Rect/Square/Circle/Triangle)
      _fpDragState[svg.id] = null;
      svg.addEventListener('mousedown', (e) => {
        const areaMode = _fpGetAreaMode(svg.id);
        if (areaMode === 'off') return;
        e.preventDefault();
        const pt = _fpSvgPoint(svg, e);
        const areaShape = _fpGetAreaShape(svg.id);
        _fpDragState[svg.id] = { x0: pt.x, y0: pt.y, mode: areaMode, shape: areaShape };

        svg.getElementById('_fpSelRect')?.remove();
        svg.getElementById('_fpSelCircle')?.remove();
        svg.getElementById('_fpSelTri')?.remove();

        const fill = areaMode === 'delete'
          ? 'rgba(239,68,68,0.08)'
          : areaMode === 'cleanup'
            ? 'rgba(100,116,139,0.08)'
            : 'rgba(14,165,233,0.08)';
        const stroke = areaMode === 'delete'
          ? '#ef4444'
          : areaMode === 'cleanup'
            ? '#64748b'
            : '#0ea5e9';

        if (areaShape === 'circle') {
          const c = document.createElementNS('http://www.w3.org/2000/svg', 'circle');
          c.id = '_fpSelCircle';
          c.setAttribute('cx', pt.x);
          c.setAttribute('cy', pt.y);
          c.setAttribute('r', 0);
          c.setAttribute('fill', fill);
          c.setAttribute('stroke', stroke);
          c.setAttribute('stroke-width', '1.5');
          c.setAttribute('stroke-dasharray', '6,3');
          c.setAttribute('pointer-events', 'none');
          svg.appendChild(c);
        } else if (areaShape === 'triangle') {
          const tri = document.createElementNS('http://www.w3.org/2000/svg', 'polygon');
          tri.id = '_fpSelTri';
          tri.setAttribute('points', `${pt.x},${pt.y} ${pt.x},${pt.y} ${pt.x},${pt.y}`);
          tri.setAttribute('fill', fill);
          tri.setAttribute('stroke', stroke);
          tri.setAttribute('stroke-width', '1.5');
          tri.setAttribute('stroke-dasharray', '6,3');
          tri.setAttribute('pointer-events', 'none');
          svg.appendChild(tri);
        } else {
          const rect = document.createElementNS('http://www.w3.org/2000/svg', 'rect');
          rect.id = '_fpSelRect';
          rect.setAttribute('x', pt.x);
          rect.setAttribute('y', pt.y);
          rect.setAttribute('width', 0);
          rect.setAttribute('height', 0);
          rect.setAttribute('fill', fill);
          rect.setAttribute('stroke', stroke);
          rect.setAttribute('stroke-width', '1.5');
          rect.setAttribute('stroke-dasharray', '6,3');
          rect.setAttribute('pointer-events', 'none');
          svg.appendChild(rect);
        }
      });
      svg.addEventListener('mousemove', (e) => {
        const ds = _fpDragState[svg.id];
        if (!ds) return;
        const pt = _fpSvgPoint(svg, e);
        const dx = pt.x - ds.x0;
        const dy = pt.y - ds.y0;
        const xMin = Math.min(ds.x0, pt.x);
        const yMin = Math.min(ds.y0, pt.y);
        const wRaw = Math.abs(dx);
        const hRaw = Math.abs(dy);

        if (ds.shape === 'circle') {
          const side = Math.max(wRaw, hRaw);
          const x = dx >= 0 ? ds.x0 : ds.x0 - side;
          const y = dy >= 0 ? ds.y0 : ds.y0 - side;
          const cx = x + side / 2;
          const cy = y + side / 2;
          const r = side / 2;
          const c = svg.getElementById('_fpSelCircle');
          if (!c) return;
          c.setAttribute('cx', cx);
          c.setAttribute('cy', cy);
          c.setAttribute('r', r);
          return;
        }

        if (ds.shape === 'triangle') {
          const x = xMin;
          const y = yMin;
          const w = wRaw;
          const h = hRaw;
          const tri = svg.getElementById('_fpSelTri');
          if (!tri) return;
          const p1 = `${(x + w / 2)},${y}`;
          const p2 = `${x},${(y + h)}`;
          const p3 = `${(x + w)},${(y + h)}`;
          tri.setAttribute('points', `${p1} ${p2} ${p3}`);
          return;
        }

        const rect = svg.getElementById('_fpSelRect');
        if (!rect) return;
        if (ds.shape === 'square') {
          const side = Math.max(wRaw, hRaw);
          const x = dx >= 0 ? ds.x0 : ds.x0 - side;
          const y = dy >= 0 ? ds.y0 : ds.y0 - side;
          rect.setAttribute('x', x);
          rect.setAttribute('y', y);
          rect.setAttribute('width', side);
          rect.setAttribute('height', side);
        } else {
          rect.setAttribute('x', xMin);
          rect.setAttribute('y', yMin);
          rect.setAttribute('width', wRaw);
          rect.setAttribute('height', hRaw);
        }
      });
      svg.addEventListener('mouseup', (e) => {
        const ds = _fpDragState[svg.id];
        _fpDragState[svg.id] = null;
        const rect = svg.getElementById('_fpSelRect');
        if (rect) rect.remove();
        const c = svg.getElementById('_fpSelCircle');
        if (c) c.remove();
        const tri = svg.getElementById('_fpSelTri');
        if (tri) tri.remove();
        if (!ds) return;
        const mode = ds.mode || 'select';

        let hitTest;
        const pt = _fpSvgPoint(svg, e);
        const dx = pt.x - ds.x0;
        const dy = pt.y - ds.y0;
        const xMin = Math.min(ds.x0, pt.x);
        const yMin = Math.min(ds.y0, pt.y);
        const wRaw = Math.abs(dx);
        const hRaw = Math.abs(dy);
        if (wRaw < 3 && hRaw < 3) return;

        if (ds.shape === 'circle') {
          const side = Math.max(wRaw, hRaw);
          const x = dx >= 0 ? ds.x0 : ds.x0 - side;
          const y = dy >= 0 ? ds.y0 : ds.y0 - side;
          const cx0 = x + side / 2;
          const cy0 = y + side / 2;
          const r = side / 2;
          hitTest = (cx, cy) => {
            const ddx = cx - cx0;
            const ddy = cy - cy0;
            return (ddx * ddx + ddy * ddy) <= (r * r);
          };
        } else if (ds.shape === 'triangle') {
          const poly = [
            { x: xMin + wRaw / 2, y: yMin },
            { x: xMin, y: yMin + hRaw },
            { x: xMin + wRaw, y: yMin + hRaw }
          ];
          hitTest = (cx, cy) => _fpPointInPolygon(cx, cy, poly);
        } else if (ds.shape === 'square') {
          const side = Math.max(wRaw, hRaw);
          const x = dx >= 0 ? ds.x0 : ds.x0 - side;
          const y = dy >= 0 ? ds.y0 : ds.y0 - side;
          hitTest = (cx, cy) => cx >= x && cx <= x + side && cy >= y && cy <= y + side;
        } else {
          hitTest = (cx, cy) => cx >= xMin && cx <= xMin + wRaw && cy >= yMin && cy <= yMin + hRaw;
        }

        if (mode === 'delete') _fpClearAllSelected(svg);

        let hitCount = 0;
        // Affect all groups whose center falls inside the selected area
        svg.querySelectorAll('g[data-fp-item-idx], g[data-fp-wall-idx], g[data-fp-door-idx], [data-fp-selectable="1"]').forEach(g => {
          try {
            const bb = g.getBBox();
            const cx = bb.x + bb.width / 2, cy = bb.y + bb.height / 2;
            if (hitTest(cx, cy)) {
              hitCount++;
              if (mode === 'cleanup') _fpMarkSelected(g, false);
              else _fpMarkSelected(g, true);
            }
          } catch(ex) {}
        });

        if (mode === 'delete' && hitCount > 0) {
          window.fpDeleteSelected(svg.id);
        }
      });
      svg.addEventListener('mouseleave', () => {
        _fpDragState[svg.id] = null;
        const rect = svg.getElementById('_fpSelRect');
        if (rect) rect.remove();
        const c = svg.getElementById('_fpSelCircle');
        if (c) c.remove();
        const tri = svg.getElementById('_fpSelTri');
        if (tri) tri.remove();
      });
    });
    // Update selection info bar with total count
    fpUpdateSelectionInfo();
  };

  // ── SVG export ──
  function exportSvg() {
    const svgEls = fpContainer.querySelectorAll('svg');
    if (!svgEls.length) { setStatus('No floor plan to export.', 'error'); return; }

    // Combine all pages into one SVG by stacking vertically
    let totalH = 0;
    const fragments = [];
    svgEls.forEach(svg => {
      const vb = svg.getAttribute('viewBox').split(/\s+/).map(Number);
      fragments.push({ svg, w: vb[2], h: vb[3], y: totalH });
      totalH += vb[3] + 20;
    });
    const maxW = Math.max(...fragments.map(f => f.w));
    let combined = `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 ${maxW} ${totalH}" style="background:#fff">`;
    for (const f of fragments) {
      combined += `<g transform="translate(0,${f.y})">${f.svg.innerHTML}</g>`;
    }
    combined += `</svg>`;

    const blob = new Blob([combined], { type: 'image/svg+xml;charset=utf-8' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    const fn = (lastAnalysis && lastAnalysis.fileName)
      || ((pdfInput && pdfInput.files && pdfInput.files[0]) ? (pdfInput.files[0].name || 'floorplan') : 'floorplan');
    a.download = `${fn.replace(/\.[^.]+$/, '')}_floorplan.svg`;
    document.body.appendChild(a); a.click(); a.remove();
    setTimeout(() => URL.revokeObjectURL(url), 2500);
    setStatus('SVG exported.', 'success');
  }

  // ── JSON export ──
  function exportJson() {
    if (!lastAnalysis) { setStatus('No analysis data.', 'error'); return; }
    const json = JSON.stringify(lastAnalysis, null, 2);
    const blob = new Blob([json], { type: 'application/json;charset=utf-8' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    const fn = (lastAnalysis.fileName || 'floorplan');
    a.download = `${fn.replace(/\.[^.]+$/, '')}_analysis.json`;
    document.body.appendChild(a); a.click(); a.remove();
    setTimeout(() => URL.revokeObjectURL(url), 2500);
    setStatus('JSON exported.', 'success');
  }

  btnExportSvg.addEventListener('click', exportSvg);
  btnExportJson.addEventListener('click', exportJson);

  // ── Save to Database ──
  btnSaveDb.addEventListener('click', async function () {
    if (!lastAnalysis) { setStatus('Nothing to save – run Analyze first.', 'error'); return; }

    const projectId = fireProjectSelect ? parseInt((fireProjectSelect.value || '').trim(), 10) : 0;
    if (!projectId) { setStatus('Select an existing project before saving.', 'error'); return; }

    btnSaveDb.disabled = true;
    setStatus('Saving to database…');

    try {
      function getPreviewPagesFromDom() {
        try {
          if (!pdfPages) return [];
          const imgs = Array.from(pdfPages.querySelectorAll('img'));
          const out = [];
          for (const img of imgs) {
            const src = (img && img.getAttribute) ? (img.getAttribute('src') || '') : '';
            if (src && typeof src === 'string') out.push(src);
          }
          return out;
        } catch { return []; }
      }

      // Flush current PDF Image canvas back into the pages array (so it persists).
      let pagesForSave = [];
      try {
        if (window._pdfImageFlushCurrentToPages) {
          const flushed = window._pdfImageFlushCurrentToPages();
          if (Array.isArray(flushed)) pagesForSave = flushed;
        }
      } catch { }
      if (!Array.isArray(pagesForSave) || pagesForSave.length === 0) {
        pagesForSave = Array.isArray(lastPdfPages) ? lastPdfPages : [];
      }
      if (!Array.isArray(pagesForSave) || pagesForSave.length === 0) {
        pagesForSave = getPreviewPagesFromDom();
      }
      pagesForSave = (Array.isArray(pagesForSave) ? pagesForSave : [])
        .filter(x => typeof x === 'string' && x.length > 0);

      ensureReportNameDefaultIfEmpty();
      const reportName = fireReportNameInput ? (fireReportNameInput.value || '').trim() : '';

      function snapshotWallMarks() {
        // _fpGlobalWallMarks: pageNo -> Map(wallIdx -> 'thin'|'thick')
        const out = {};
        try {
          for (const k of Object.keys(_fpGlobalWallMarks || {})) {
            const m = _fpGlobalWallMarks[k];
            if (!m || typeof m.forEach !== 'function') continue;
            const o = {};
            m.forEach((v, kk) => { o[String(kk)] = v; });
            out[String(k)] = o;
          }
        } catch { }
        return out;
      }

      const pdfImageState = (() => {
        try { return window._pdfImageGetState ? window._pdfImageGetState() : null; } catch { return null; }
      })();

      const uiState = {
        source: 'PDFTOSVGWALL',
        visibleLayerIndices: Array.from(selectedVisibleLayerIndices.values()).sort((a,b)=>a-b),
        pdfZoom: pdfZoom,
        pdfMarkWallsOn: !!window._pdfMarkWallsOn,
        wallMarks: snapshotWallMarks(),
        pdfImage: pdfImageState,
        appliedOps: Array.isArray(window._fpLastAppliedOps) ? window._fpLastAppliedOps.slice() : [],
        cleanedSvgs: window._fpCleanedSvgs || {}
      };

      const payload = {
        id: currentReportId,
        projectId: projectId,
        reportName: reportName,
        fileName: lastAnalysis.fileName || '',
        analysisJson: JSON.stringify(lastAnalysis),
        reportJson: '{}',
        pdfPagesJson: JSON.stringify(pagesForSave),
        uiStateJson: JSON.stringify(uiState),
        itemsJson: JSON.stringify(lastAnalysis.items || []),
        scaleLabel: lastAnalysis.scaleInfo?.scaleLabel || '',
        heightM: parseFloat(heightInput.value) || null,
        deviceCount: (lastAnalysis.items || []).length,
        spacingIssues: 0
      };

      const resp = await fetch(REPORT_SAVE_ENDPOINT, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'X-Client-Id': 'admin' },
        body: JSON.stringify(payload)
      });

      const respText = await resp.text();
      const result = safeJsonParse(respText, null);
      if (!resp.ok) {
        const ct = resp.headers && resp.headers.get ? (resp.headers.get('content-type') || '') : '';
        const snippet = (respText || '').slice(0, 240);
        setStatus(`Save failed (${resp.status})${ct ? ` [${ct}]` : ''}: ${snippet || '(empty response)'}`, 'error');
        return;
      }

      if (!result) {
        const ct = resp.headers && resp.headers.get ? (resp.headers.get('content-type') || '') : '';
        const snippet = (respText || '').slice(0, 240);
        setStatus(`Save failed: server did not return JSON${ct ? ` [${ct}]` : ''}: ${snippet || '(empty response)'}`, 'error');
        return;
      }

      if (result.ok) {
        currentReportId = result.id;
        const pn = (result && result.projectName) ? result.projectName : (fireProjectSelect && fireProjectSelect.options[fireProjectSelect.selectedIndex] ? fireProjectSelect.options[fireProjectSelect.selectedIndex].textContent : ('#' + projectId));
        const rn = (result && result.reportName) ? result.reportName : (reportName || '(unnamed)');
        setStatus(`${result.isUpdate ? 'Updated' : 'Saved'} "${rn}" to project "${pn}" (Report ID: ${result.id})`, 'success');
      } else {
        setStatus('Save failed: ' + (result.error || 'Unknown error'), 'error');
      }
    } catch (e) {
      setStatus('Save failed: ' + (e.message || e), 'error');
    } finally {
      btnSaveDb.disabled = false;
    }
  });

  // ── Load from Database ──
  btnLoadDb.addEventListener('click', async function () {
    btnLoadDb.disabled = true;
    setStatus('Loading saved reports…');

    try {
      const resp = await fetch(REPORT_LIST_ENDPOINT, { headers: { 'X-Client-Id': 'admin' } });
      const respText = await resp.text();
      const result = safeJsonParse(respText, null);
      if (!resp.ok) {
        const ct = resp.headers && resp.headers.get ? (resp.headers.get('content-type') || '') : '';
        setStatus(`Load list failed (${resp.status})${ct ? ` [${ct}]` : ''}: ${(respText || '').slice(0, 240)}`, 'error');
        btnLoadDb.disabled = false;
        return;
      }
      if (!result) {
        const ct = resp.headers && resp.headers.get ? (resp.headers.get('content-type') || '') : '';
        setStatus(`Load list failed: server did not return JSON${ct ? ` [${ct}]` : ''}`, 'error');
        btnLoadDb.disabled = false;
        return;
      }
      if (!result.ok || !result.reports || !result.reports.length) {
        setStatus('No saved reports found.', 'error');
        btnLoadDb.disabled = false;
        return;
      }

      // Build and show modal with report list
      let overlay = document.getElementById('loadReportOverlay');
      if (overlay) overlay.remove();

      overlay = document.createElement('div');
      overlay.id = 'loadReportOverlay';
      overlay.style.cssText = 'position:fixed;inset:0;z-index:9999;background:rgba(2,6,23,0.86);display:flex;align-items:center;justify-content:center;padding:16px;';

      let rows = '';
      for (const r of result.reports) {
        const d = new Date(r.createdAtUtc).toLocaleString();
        const title = r.reportName || r.projectName || r.fileName || '(unnamed)';
        const srcTag = r.source ? `<span class="ml-2 text-[10px] px-1.5 py-0.5 rounded p2s-badge border">${escapeHtml(r.source)}</span>` : '';
        const proj = r.projectName || ('#' + r.projectId);
        rows += `<tr class="p2s-dropdown-item cursor-pointer transition" data-report-id="${r.id}">
          <td class="px-3 py-2 text-sm p2s-text">${escapeHtml(title)}${srcTag}</td>
          <td class="px-3 py-2 text-xs p2s-label">${escapeHtml(proj)}</td>
          <td class="px-3 py-2 text-xs p2s-muted">${escapeHtml(r.fileName)}</td>
          <td class="px-3 py-2 text-xs p2s-muted text-center">${r.deviceCount}</td>
          <td class="px-3 py-2 text-xs p2s-muted">${escapeHtml(r.scaleLabel || '-')}</td>
          <td class="px-3 py-2 text-xs p2s-muted">${d}</td>
        </tr>`;
      }

      overlay.innerHTML = `
        <div class="p2s-card p2s-card--dialog rounded-2xl border shadow-2xl max-w-3xl w-full max-h-[80vh] flex flex-col">
          <div class="flex items-center gap-2 px-5 py-3 p2s-toolbar border-b">
            <i class="fa-solid fa-folder-open text-blue-400"></i>
            <h3 class="text-sm font-semibold uppercase tracking-wider p2s-hdr-title">Load Saved Report</h3>
            <button id="loadReportClose" class="ml-auto p2s-muted hover:opacity-80 text-lg">&times;</button>
          </div>
          <div class="overflow-auto flex-1 px-2 py-2 p2s-inner">
            <table class="w-full text-left">
              <thead><tr class="p2s-toolbar border-b">
                <th class="px-3 py-2 text-xs p2s-muted font-semibold">Report</th>
                <th class="px-3 py-2 text-xs p2s-muted font-semibold">Project</th>
                <th class="px-3 py-2 text-xs p2s-muted font-semibold">File</th>
                <th class="px-3 py-2 text-xs p2s-muted font-semibold text-center">Items</th>
                <th class="px-3 py-2 text-xs p2s-muted font-semibold">Scale</th>
                <th class="px-3 py-2 text-xs p2s-muted font-semibold">Date</th>
              </tr></thead>
              <tbody>${rows}</tbody>
            </table>
          </div>
        </div>`;

      document.body.appendChild(overlay);

      // Close button
      overlay.querySelector('#loadReportClose').addEventListener('click', () => { overlay.remove(); });
      overlay.addEventListener('click', (e) => { if (e.target === overlay) overlay.remove(); });

      // Row click = load that report
      overlay.querySelectorAll('tr[data-report-id]').forEach(tr => {
        tr.addEventListener('click', async () => {
          const reportId = tr.getAttribute('data-report-id');
          overlay.remove();
          setStatus('Loading report…');

          try {
            const loadResp = await fetch(`${REPORT_LOAD_ENDPOINT}/${reportId}`, { headers: { 'X-Client-Id': 'admin' } });
            const loadText = await loadResp.text();
            const loadResult = safeJsonParse(loadText, null);
            if (!loadResp.ok) {
              const ct = loadResp.headers && loadResp.headers.get ? (loadResp.headers.get('content-type') || '') : '';
              setStatus(`Failed to load report (${loadResp.status})${ct ? ` [${ct}]` : ''}: ${(loadText || '').slice(0, 240)}`, 'error');
              return;
            }
            if (!loadResult) {
              const ct = loadResp.headers && loadResp.headers.get ? (loadResp.headers.get('content-type') || '') : '';
              setStatus(`Failed to load report: server did not return JSON${ct ? ` [${ct}]` : ''}`, 'error');
              return;
            }
            if (!loadResult.ok || !loadResult.report) {
              setStatus('Failed to load report.', 'error');
              return;
            }

            const report = loadResult.report;
            const analysis = safeJsonParse(report.analysisJson, null);
            if (!analysis) {
              setStatus('Report has no analysis data.', 'error');
              return;
            }

            currentReportId = report.id;
            if (fireProjectSelect && report.projectId) {
              try { fireProjectSelect.value = String(report.projectId); } catch { }
            }
            if (fireReportNameInput) {
              fireReportNameInput.value = (report.reportName || '').trim();
              ensureReportNameDefaultIfEmpty();
            }

            const uiState = safeJsonParse(report.uiStateJson, null);
            if (uiState && uiState.wallMarks) {
              try {
                // Clear existing saved marks
                for (const k of Object.keys(_fpGlobalWallMarks || {})) {
                  const m = _fpGlobalWallMarks[k];
                  if (m && typeof m.clear === 'function') m.clear();
                }
                // Apply saved marks
                for (const pageNo of Object.keys(uiState.wallMarks)) {
                  const o = uiState.wallMarks[pageNo] || {};
                  const m = _fpEnsureGlobalPageMap(parseInt(pageNo, 10));
                  if (m && typeof m.clear === 'function') m.clear();
                  for (const wallIdx of Object.keys(o)) {
                    m.set(parseInt(wallIdx, 10), o[wallIdx]);
                  }
                }
              } catch { }
            }
            if (uiState && Array.isArray(uiState.visibleLayerIndices)) {
              try {
                selectedVisibleLayerIndices = new Set(uiState.visibleLayerIndices.map(x => parseInt(x, 10)).filter(Number.isFinite));
              } catch { }
            }
            const desiredPdfZoom = (uiState && typeof uiState.pdfZoom === 'number') ? uiState.pdfZoom : null;
            if (uiState && typeof uiState.pdfMarkWallsOn !== 'undefined') {
              window._pdfMarkWallsOn = !!uiState.pdfMarkWallsOn;
            }

            lastAnalysis = analysis;
            renderScale(analysis);
            renderFloorPlan(analysis);

            // Apply saved marks to floor-plan SVGs
            try { if (window._fpApplyGlobalMarksToAllFloorSvgs) window._fpApplyGlobalMarksToAllFloorSvgs(); } catch { }

            // Re-apply saved SVG operations (remove doors, B&W, etc.)
            if (uiState && Array.isArray(uiState.appliedOps) && uiState.appliedOps.length > 0) {
              try {
                const reapplyResult = window._fpReapplyOps(uiState.appliedOps);
                if (reapplyResult && reapplyResult.results.length) {
                  console.log('[Load] Re-applied SVG ops:', reapplyResult.results.join(', '), 'in', reapplyResult.totalMs, 'ms');
                }
              } catch (e) { console.warn('[Load] Failed to re-apply SVG ops:', e); }
            }

            // Re-apply Clean SVG (building envelope) if it was active
            if (uiState && uiState.cleanedSvgs && typeof uiState.cleanedSvgs === 'object') {
              try {
                // Wait a tick for SVGs to be fully in the DOM
                await new Promise(r => requestAnimationFrame(r));
                for (const [svgId, info] of Object.entries(uiState.cleanedSvgs)) {
                  if (document.getElementById(svgId) && window.fpCleanSvg) {
                    await window.fpCleanSvg(svgId, { mode: info.mode || 'clean', askDownload: false });
                    console.log('[Load] Re-applied fpCleanSvg on', svgId, 'mode:', info.mode);
                  }
                }
              } catch (e) { console.warn('[Load] Failed to re-apply clean SVG:', e); }
            }

            // Restore PDF pages from DB (Preview + PDF Image tabs)
            const savedPages = safeJsonParse(report.pdfPagesJson, []);
            if (Array.isArray(savedPages) && savedPages.length) {
              renderPdfPreviewFromPages(savedPages);

              // Apply zoom AFTER pages exist in the DOM.
              if (desiredPdfZoom !== null) {
                try { setPdfZoom(desiredPdfZoom); } catch { }
              }

              // Restore wall overlay in Preview.
              try { if (window.pdfBuildWallOverlay) window.pdfBuildWallOverlay(analysis); } catch { }

              // Defer PDF Image rendering until the user opens the tab (so layout is correct).
              const initialIdx = (uiState && uiState.pdfImage && Number.isFinite(parseInt(uiState.pdfImage.selectedIdx, 10)))
                ? parseInt(uiState.pdfImage.selectedIdx, 10)
                : 0;
              window._pendingPdfImageRestore = { initialPageIndex: initialIdx, restoreState: (uiState ? uiState.pdfImage : null) };
            }
            else {
              // Still restore zoom preference even if no pages were saved.
              if (desiredPdfZoom !== null) {
                try { setPdfZoom(desiredPdfZoom); } catch { }
              }
            }

            // Restore scale inputs
            if (report.heightM) heightInput.value = report.heightM;
            if (analysis.scaleInfo?.scaleRatio) scaleRatioInput.value = analysis.scaleInfo.scaleRatio;
            if (analysis.scaleInfo?.referenceDoorWidthCm) doorWidthInput.value = analysis.scaleInfo.referenceDoorWidthCm;

            btnExportSvg.classList.remove('hidden');
            btnExportJson.classList.remove('hidden');

            // Switch to Floor Plan tab
            switchTab('tabFloorPlan');

            setStatus(`Loaded "${report.reportName || report.projectName || report.fileName}" — ${(analysis.items || []).length} items`, 'success');
          } catch (e) {
            setStatus('Load failed: ' + (e.message || e), 'error');
          }
        });
      });

    } catch (e) {
      setStatus('Load failed: ' + (e.message || e), 'error');
    } finally {
      btnLoadDb.disabled = false;
    }
  });

  // ── File Attachments for AI Query (Images / PDF / Excel) ──
  // Global state: attachments array of { name, type, dataUrl, textContent? }
  window._pdfImageAttachments = [];

  (function initFileAttachments() {
    const attachInput   = document.getElementById('pdfImageAttachInput');
    const btnAttach     = document.getElementById('btnPdfImageAttach');
    const previewWrap   = document.getElementById('pdfImageAttachPreview');
    const countLabel    = document.getElementById('pdfImageAttachCount');
    if (!attachInput || !btnAttach || !previewWrap) return;

    btnAttach.addEventListener('click', () => attachInput.click());

    attachInput.addEventListener('change', async () => {
      const files = Array.from(attachInput.files || []);
      if (!files.length) return;
      for (const file of files) {
        await processAttachedFile(file);
      }
      attachInput.value = '';
      refreshAttachmentUI();
    });

    // Drag-and-drop on the preview area
    previewWrap.addEventListener('dragover', (e) => { e.preventDefault(); previewWrap.classList.add('ring-2', 'ring-sky-400/50'); });
    previewWrap.addEventListener('dragleave', () => { previewWrap.classList.remove('ring-2', 'ring-sky-400/50'); });
    previewWrap.addEventListener('drop', async (e) => {
      e.preventDefault();
      previewWrap.classList.remove('ring-2', 'ring-sky-400/50');
      const files = Array.from(e.dataTransfer.files || []);
      for (const file of files) {
        await processAttachedFile(file);
      }
      refreshAttachmentUI();
    });

    async function processAttachedFile(file) {
      const name = file.name;
      const ext  = name.split('.').pop().toLowerCase();
      const type = file.type || '';

      if (type.startsWith('image/') || ['png','jpg','jpeg','gif','bmp','webp','svg'].includes(ext)) {
        // ── Image: convert to base64 dataUrl ──
        const dataUrl = await fileToDataUrl(file);
        window._pdfImageAttachments.push({ name, type: 'image', dataUrl, mimeType: type || 'image/png' });
      }
      else if (ext === 'pdf' || type === 'application/pdf') {
        // ── PDF: read as base64 and also try to render first page as image ──
        const dataUrl = await fileToDataUrl(file);
        // Store the raw PDF data URL for AI providers that support documents
        window._pdfImageAttachments.push({ name, type: 'pdf', dataUrl, mimeType: 'application/pdf' });
        // Also render the first page as an image for vision models
        try {
          const pageDataUrl = await renderPdfFirstPageAsImage(dataUrl);
          if (pageDataUrl) {
            window._pdfImageAttachments.push({ name: name + ' (page 1)', type: 'image', dataUrl: pageDataUrl, mimeType: 'image/png', _fromPdf: true });
          }
        } catch (e) { console.warn('[Attach] Could not render PDF page:', e); }
      }
      else if (['xlsx','xls','csv'].includes(ext) || type.includes('spreadsheet') || type === 'text/csv') {
        // ── Excel / CSV: read as text to embed in the prompt ──
        if (ext === 'csv' || type === 'text/csv') {
          const text = await file.text();
          window._pdfImageAttachments.push({ name, type: 'excel', textContent: text, mimeType: 'text/csv' });
        } else {
          // For xlsx/xls: read as base64 and try to extract text via SheetJS if loaded
          const dataUrl = await fileToDataUrl(file);
          const extracted = await tryExtractExcelText(file);
          window._pdfImageAttachments.push({
            name, type: 'excel', dataUrl, mimeType: type || 'application/vnd.openxmlformats-officedocument.spreadsheetml.sheet',
            textContent: extracted || null
          });
        }
      }
      else {
        // ── Unknown: try as generic binary attachment ──
        const dataUrl = await fileToDataUrl(file);
        window._pdfImageAttachments.push({ name, type: 'file', dataUrl, mimeType: type || 'application/octet-stream' });
      }
    }

    function fileToDataUrl(file) {
      return new Promise((resolve, reject) => {
        const reader = new FileReader();
        reader.onload = () => resolve(reader.result);
        reader.onerror = () => reject(reader.error);
        reader.readAsDataURL(file);
      });
    }

    async function renderPdfFirstPageAsImage(pdfDataUrl) {
      // Use browser canvas to render PDF if pdfjsLib is available, otherwise skip
      if (typeof pdfjsLib === 'undefined') {
        // Try loading pdf.js from CDN dynamically
        try {
          await loadScript('https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.min.js');
          if (typeof pdfjsLib !== 'undefined') {
            pdfjsLib.GlobalWorkerOptions.workerSrc = 'https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.worker.min.js';
          }
        } catch { return null; }
      }
      if (typeof pdfjsLib === 'undefined') return null;

      // Extract base64 from data URL
      const commaIdx = pdfDataUrl.indexOf(',');
      const b64 = commaIdx >= 0 ? pdfDataUrl.slice(commaIdx + 1) : pdfDataUrl;
      const binary = atob(b64);
      const bytes  = new Uint8Array(binary.length);
      for (let i = 0; i < binary.length; i++) bytes[i] = binary.charCodeAt(i);

      const doc = await pdfjsLib.getDocument({ data: bytes }).promise;
      const page = await doc.getPage(1);
      const scale = 2;
      const viewport = page.getViewport({ scale });
      const canvas = document.createElement('canvas');
      canvas.width  = viewport.width;
      canvas.height = viewport.height;
      const ctx = canvas.getContext('2d');
      await page.render({ canvasContext: ctx, viewport }).promise;
      return canvas.toDataURL('image/png');
    }

    async function tryExtractExcelText(file) {
      // If SheetJS (XLSX) is available, parse the spreadsheet to CSV text
      if (typeof XLSX === 'undefined') {
        try {
          await loadScript('https://cdn.sheetjs.com/xlsx-0.20.3/package/dist/xlsx.full.min.js');
        } catch { return null; }
      }
      if (typeof XLSX === 'undefined') return null;
      try {
        const ab = await file.arrayBuffer();
        const wb = XLSX.read(ab, { type: 'array' });
        const lines = [];
        for (const sheetName of wb.SheetNames) {
          lines.push(`--- Sheet: ${sheetName} ---`);
          lines.push(XLSX.utils.sheet_to_csv(wb.Sheets[sheetName]));
        }
        return lines.join('\n');
      } catch (e) { console.warn('[Attach] Excel parse error:', e); return null; }
    }

    function loadScript(src) {
      return new Promise((resolve, reject) => {
        if (document.querySelector(`script[src="${src}"]`)) { resolve(); return; }
        const s = document.createElement('script');
        s.src = src;
        s.onload = resolve;
        s.onerror = reject;
        document.head.appendChild(s);
      });
    }

    function refreshAttachmentUI() {
      const attachments = window._pdfImageAttachments;
      // Filter out auto-generated PDF page images from the count
      const userAttachments = attachments.filter(a => !a._fromPdf);
      if (countLabel) {
        countLabel.textContent = userAttachments.length > 0
          ? `${userAttachments.length} file${userAttachments.length > 1 ? 's' : ''} attached`
          : '';
      }
      if (!previewWrap) return;
      previewWrap.innerHTML = '';
      if (attachments.length === 0) {
        previewWrap.classList.add('hidden');
        return;
      }
      previewWrap.classList.remove('hidden');

      attachments.forEach((att, idx) => {
        if (att._fromPdf) return; // Don't show auto-rendered PDF pages separately
        const card = document.createElement('div');
        card.className = 'relative group flex flex-col items-center gap-1 p-1 rounded border border-slate-600/30 bg-slate-800/50';
        card.style.minWidth = '72px';
        card.style.maxWidth = '90px';

        if (att.type === 'image') {
          const img = document.createElement('img');
          img.src = att.dataUrl;
          img.className = 'w-16 h-16 object-contain rounded';
          img.alt = att.name;
          card.appendChild(img);
        } else if (att.type === 'pdf') {
          const icon = document.createElement('div');
          icon.className = 'w-16 h-16 flex items-center justify-center';
          icon.innerHTML = '<i class="fa-solid fa-file-pdf text-2xl text-rose-400"></i>';
          card.appendChild(icon);
        } else if (att.type === 'excel') {
          const icon = document.createElement('div');
          icon.className = 'w-16 h-16 flex items-center justify-center';
          icon.innerHTML = '<i class="fa-solid fa-file-excel text-2xl text-emerald-400"></i>';
          card.appendChild(icon);
        } else {
          const icon = document.createElement('div');
          icon.className = 'w-16 h-16 flex items-center justify-center';
          icon.innerHTML = '<i class="fa-solid fa-file text-2xl text-slate-400"></i>';
          card.appendChild(icon);
        }

        const label = document.createElement('span');
        label.className = 'text-[9px] text-slate-400 truncate w-full text-center';
        label.textContent = att.name.length > 14 ? att.name.slice(0, 12) + '…' : att.name;
        label.title = att.name;
        card.appendChild(label);

        // Remove button
        const removeBtn = document.createElement('button');
        removeBtn.type = 'button';
        removeBtn.className = 'absolute -top-1 -right-1 w-4 h-4 rounded-full bg-rose-600 text-white text-[8px] flex items-center justify-center opacity-0 group-hover:opacity-100 transition';
        removeBtn.innerHTML = '<i class="fa-solid fa-xmark"></i>';
        removeBtn.title = 'Remove';
        removeBtn.onclick = () => {
          // Remove this attachment and any auto-generated ones from the same PDF
          window._pdfImageAttachments = window._pdfImageAttachments.filter((a, i) => {
            if (i === idx) return false;
            if (att.type === 'pdf' && a._fromPdf && a.name.startsWith(att.name)) return false;
            return true;
          });
          refreshAttachmentUI();
        };
        card.appendChild(removeBtn);

        previewWrap.appendChild(card);
      });
    }

    // Expose refresh for external use
    window._refreshPdfImageAttachments = refreshAttachmentUI;
  })();

  // ── Floor Plan SVG Operations (multi-select + apply + undo) ──
  (function initFpSvgOps() {
    const _opsBtn   = document.getElementById('fpOpsMultiBtn');
    const _opsLabel = document.getElementById('fpOpsMultiLabel');
    const _opsMenu  = document.getElementById('fpOpsMultiMenu');
    const btnApply  = document.getElementById('btnFpApplyEdit');
    const btnUndo   = document.getElementById('btnFpUndoEdit');
    const btnRedo   = document.getElementById('btnFpRedoEdit');
    const logEl     = document.getElementById('fpEditLog');
    const applyIcon = document.getElementById('fpApplyIcon');
    if (!_opsBtn || !_opsMenu || !btnApply) return;

    const maxUndo = 10;
    let undoStack = [];
    let redoStack = [];

    function getAllSvgs() { return Array.from(document.querySelectorAll('#fpContainer svg')); }

    /** Convert an SVG element to a data-URL image (for AI training logging) */
    function svgToDataUrl(svgEl, maxDim) {
      return new Promise((resolve) => {
        try {
          if (!svgEl) { resolve(null); return; }
          maxDim = maxDim || 1024;
          const clone = svgEl.cloneNode(true);
          clone.setAttribute('xmlns', 'http://www.w3.org/2000/svg');
          const vb = (svgEl.getAttribute('viewBox') || '').split(/[\s,]+/).map(Number);
          const origW = vb[2] || svgEl.clientWidth || 800;
          const origH = vb[3] || svgEl.clientHeight || 600;
          const scale = Math.min(1, maxDim / Math.max(origW, origH));
          const w = Math.round(origW * scale);
          const h = Math.round(origH * scale);
          const svgStr = new XMLSerializer().serializeToString(clone);
          const blob = new Blob([svgStr], { type: 'image/svg+xml;charset=utf-8' });
          const url = URL.createObjectURL(blob);
          const img = new Image();
          img.onload = () => {
            const c = document.createElement('canvas');
            c.width = w; c.height = h;
            const ctx = c.getContext('2d');
            ctx.fillStyle = '#ffffff';
            ctx.fillRect(0, 0, w, h);
            ctx.drawImage(img, 0, 0, w, h);
            URL.revokeObjectURL(url);
            resolve(c.toDataURL('image/jpeg', 0.8));
          };
          img.onerror = () => { URL.revokeObjectURL(url); resolve(null); };
          img.src = url;
        } catch (e) { console.warn('[svgToDataUrl] error:', e); resolve(null); }
      });
    }
    // Expose globally for use outside the IIFE (e.g., fpCleanSvg)
    window._svgToDataUrl = svgToDataUrl;

    function snapshotSvgs() {
      const svgs = getAllSvgs();
      return svgs.map(s => s.innerHTML);
    }

    function restoreSvgs(state) {
      if (!state) return;
      const svgs = getAllSvgs();
      svgs.forEach((svg, i) => { if (state[i] !== undefined) svg.innerHTML = state[i]; });
    }

    function refreshUndoRedoButtons() {
      if (btnUndo) btnUndo.disabled = undoStack.length === 0;
      if (btnRedo) btnRedo.disabled = redoStack.length === 0;
    }

    // Dropdown toggle
    _opsBtn.addEventListener('click', (e) => { e.stopPropagation(); _opsMenu.classList.toggle('hidden'); });
    document.addEventListener('click', () => _opsMenu.classList.add('hidden'));

    // Checkbox toggling
    _opsMenu.querySelectorAll('li[data-op]').forEach(li => {
      li.addEventListener('click', (e) => {
        e.stopPropagation();
        const cb = li.querySelector('input[type="checkbox"]');
        if (cb) cb.checked = !cb.checked;
        const checked = Array.from(_opsMenu.querySelectorAll('input:checked'))
          .map(c => c.closest('li').querySelector('span').textContent.trim());
        _opsLabel.textContent = checked.length === 0 ? 'SVG Operations...' : checked.length === 1 ? checked[0] : checked.length + ' selected';
      });
    });

    function setLog(html) { if (logEl) logEl.innerHTML = html; }

    function getSelectedOps() {
      return Array.from(_opsMenu.querySelectorAll('input:checked')).map(c => c.closest('li').dataset.op);
    }

    // Save SVG state for undo
    function pushUndo() {
      const state = snapshotSvgs();
      undoStack.push(state);
      if (undoStack.length > maxUndo) undoStack.shift();
      // New apply action invalidates redo history
      redoStack = [];
      refreshUndoRedoButtons();
    }

    // Helper: get effective stroke-width of an element
    function getStrokeWidth(el) {
      const attr = el.getAttribute('stroke-width');
      if (attr) return parseFloat(attr);
      const cs = el.style.strokeWidth;
      if (cs) return parseFloat(cs);
      return 1;
    }

    // Helper: element bounding box size
    function elBBoxSize(el) {
      try { const b = el.getBBox(); return Math.max(b.width, b.height); } catch { return 999; }
    }

    // ─── SVG operation implementations ───

    function svgRemoveThinWalls(svg) {
      let count = 0;
      svg.querySelectorAll('line, path, polyline, polygon, rect').forEach(el => {
        if (getStrokeWidth(el) <= 2 && el.getAttribute('pointer-events') !== 'stroke') {
          const g = el.closest('g');
          if (g) { g.remove(); count++; } else { el.remove(); count++; }
        }
      });
      return count;
    }

    function svgThickenWalls(svg) {
      let count = 0;
      svg.querySelectorAll('g[data-fp-wall-idx] line').forEach(el => {
        if (el.getAttribute('pointer-events') === 'stroke') return;
        const sw = getStrokeWidth(el);
        el.setAttribute('stroke-width', (sw + 2).toFixed(1));
        count++;
      });
      return count;
    }

    function svgRemoveDoors(svg) {
      let count = 0;
      svg.querySelectorAll('g[data-fp-door-idx]').forEach(g => { g.remove(); count++; });
      return count;
    }

    function svgRemoveText(svg) {
      let count = 0;
      svg.querySelectorAll('text, tspan').forEach(el => {
        const parent = el.closest('g') || el;
        parent.remove(); count++;
      });
      return count;
    }

    function svgRemoveSmallElements(svg) {
      let count = 0;
      const minSize = 8;
      svg.querySelectorAll('circle, ellipse, rect, path, polygon').forEach(el => {
        if (el.getAttribute('pointer-events') === 'stroke') return;
        // small circle / ellipse
        if (el.tagName === 'circle') {
          const r = parseFloat(el.getAttribute('r') || '0');
          if (r < minSize) { const g = el.closest('g'); (g || el).remove(); count++; return; }
        }
        if (el.tagName === 'ellipse') {
          const rx = parseFloat(el.getAttribute('rx') || '0');
          const ry = parseFloat(el.getAttribute('ry') || '0');
          if (Math.max(rx, ry) < minSize) { const g = el.closest('g'); (g || el).remove(); count++; return; }
        }
        // Generic small element by bbox
        if (elBBoxSize(el) < minSize) { const g = el.closest('g'); (g || el).remove(); count++; }
      });
      return count;
    }

    function svgRemoveFills(svg) {
      let count = 0;
      svg.querySelectorAll('*').forEach(el => {
        const fill = el.getAttribute('fill');
        if (fill && fill !== 'none' && fill !== 'transparent' && fill !== '#ffffff' && fill !== 'white') {
          el.setAttribute('fill', 'none');
          count++;
        }
      });
      return count;
    }

    function svgBlackWhite(svg) {
      let count = 0;
      svg.querySelectorAll('*').forEach(el => {
        const stroke = el.getAttribute('stroke');
        if (stroke && stroke !== 'none' && stroke !== 'transparent' && stroke !== '#000000' && stroke !== 'black') {
          el.setAttribute('stroke', '#000000');
          count++;
        }
        const fill = el.getAttribute('fill');
        if (fill && fill !== 'none' && fill !== 'transparent' && fill !== '#000000' && fill !== 'black' && fill !== 'white' && fill !== '#ffffff') {
          el.setAttribute('fill', 'none');
          count++;
        }
      });
      return count;
    }

    /* ── Shared helper: build spatial grid + line metadata for wall elements ── */
    function _buildWallGrid(svg, cellPct) {
      // Determine SVG viewport size for adaptive thresholds
      let svgSize = 1000;
      const vb = svg.getAttribute('viewBox');
      if (vb) { const p = vb.split(/[\s,]+/).map(Number); svgSize = Math.max(p[2]||1000, p[3]||1000); }
      else { svgSize = Math.max(svg.clientWidth||1000, svg.clientHeight||1000); }

      const CELL = Math.max(15, svgSize * (cellPct || 0.025));
      const tolDeg = 15;
      const walls = [];
      const grid = {};

      svg.querySelectorAll('g[data-fp-wall-idx]').forEach(g => {
        const line = g.querySelector('line:not([pointer-events="stroke"])');
        if (!line) return;
        const x1 = +line.getAttribute('x1'), y1 = +line.getAttribute('y1');
        const x2 = +line.getAttribute('x2'), y2 = +line.getAttribute('y2');
        const dx = x2 - x1, dy = y2 - y1;
        const len = Math.sqrt(dx * dx + dy * dy);
        const mx = (x1 + x2) / 2, my = (y1 + y2) / 2;
        const angle = Math.abs(Math.atan2(dy, dx) * 180 / Math.PI);
        const nearH = angle < tolDeg || angle > (180 - tolDeg);
        const nearV = Math.abs(angle - 90) < tolDeg;
        const gx = Math.floor(mx / CELL), gy = Math.floor(my / CELL);
        const w = { g, len, mx, my, gx, gy, diagonal: !nearH && !nearV };
        walls.push(w);
        const key = gx + ',' + gy;
        if (!grid[key]) grid[key] = [];
        grid[key].push(walls.length - 1);
      });

      // Long-line threshold: 8% of SVG size (structural walls are at least this long)
      const longThresh = svgSize * 0.08;
      return { walls, grid, CELL, longThresh, svgSize };
    }

    function _countNeighbors(w, grid) {
      let n = 0;
      for (let dx = -1; dx <= 1; dx++)
        for (let dy = -1; dy <= 1; dy++) {
          const c = grid[(w.gx + dx) + ',' + (w.gy + dy)];
          if (c) n += c.length;
        }
      return n - 1; // subtract self
    }

    function svgRemoveHatching(svg) {
      let count = 0;
      // Remove pattern defs
      svg.querySelectorAll('defs pattern, defs hatch').forEach(p => { p.remove(); count++; });

      const { walls, grid, longThresh } = _buildWallGrid(svg, 0.025);
      if (!walls.length) return count;

      // Density-based removal: lines in dense clusters are hatching fill.
      // Keep long lines (structural) regardless of density.
      const DENSITY = 6;
      walls.forEach(w => {
        if (w.len >= longThresh) return;  // keep long structural lines
        const nbrs = _countNeighbors(w, grid);
        if (nbrs >= DENSITY) { w.g.remove(); count++; }
      });
      return count;
    }

    function svgRemoveDiagonals(svg) {
      let count = 0;
      const { walls, grid, longThresh, svgSize } = _buildWallGrid(svg, 0.025);
      if (!walls.length) return 0;

      // Only remove DIAGONAL lines that sit in dense areas (hatching fill).
      // Keep H/V lines always. Keep long diagonal lines (structural).
      const DENSITY = 4;
      walls.forEach(w => {
        if (!w.diagonal) return;           // keep H/V lines
        if (w.len >= longThresh) return;   // keep long structural diagonals
        const nbrs = _countNeighbors(w, grid);
        if (nbrs >= DENSITY) { w.g.remove(); count++; }
      });

      // Also handle standalone diagonal lines/polylines (not in wall-groups)
      const tolDeg = 15;
      svg.querySelectorAll('line, polyline').forEach(el => {
        if (el.closest('g[data-fp-wall-idx]')) return;
        if (el.getAttribute('pointer-events') === 'stroke') return;
        if (el.tagName === 'line') {
          const x1 = +el.getAttribute('x1'), y1 = +el.getAttribute('y1');
          const x2 = +el.getAttribute('x2'), y2 = +el.getAttribute('y2');
          const dx = x2 - x1, dy = y2 - y1;
          const len = Math.sqrt(dx * dx + dy * dy);
          if (len >= longThresh) return;
          const angle = Math.abs(Math.atan2(dy, dx) * 180 / Math.PI);
          const nearH = angle < tolDeg || angle > (180 - tolDeg);
          const nearV = Math.abs(angle - 90) < tolDeg;
          if (!nearH && !nearV) { const g = el.closest('g'); (g || el).remove(); count++; }
        }
      });
      return count;
    }

    function svgStraightenWalls(svg) {
      let count = 0;
      const snapDeg = 5; // snap to H/V if within this many degrees
      svg.querySelectorAll('g[data-fp-wall-idx] line').forEach(el => {
        if (el.getAttribute('pointer-events') === 'stroke') return;
        const x1 = parseFloat(el.getAttribute('x1')), y1 = parseFloat(el.getAttribute('y1'));
        const x2 = parseFloat(el.getAttribute('x2')), y2 = parseFloat(el.getAttribute('y2'));
        const dx = x2 - x1, dy = y2 - y1;
        const angle = Math.abs(Math.atan2(dy, dx) * 180 / Math.PI);
        // Near horizontal
        if (angle < snapDeg || angle > (180 - snapDeg)) {
          const midY = (y1 + y2) / 2;
          el.setAttribute('y1', midY.toFixed(1));
          el.setAttribute('y2', midY.toFixed(1));
          // Also fix the transparent hit-line sibling
          const hitLine = el.parentElement && el.parentElement.querySelector('line[pointer-events="stroke"]');
          if (hitLine) { hitLine.setAttribute('y1', midY.toFixed(1)); hitLine.setAttribute('y2', midY.toFixed(1)); }
          count++;
        }
        // Near vertical
        else if (Math.abs(angle - 90) < snapDeg) {
          const midX = (x1 + x2) / 2;
          el.setAttribute('x1', midX.toFixed(1));
          el.setAttribute('x2', midX.toFixed(1));
          const hitLine = el.parentElement && el.parentElement.querySelector('line[pointer-events="stroke"]');
          if (hitLine) { hitLine.setAttribute('x1', midX.toFixed(1)); hitLine.setAttribute('x2', midX.toFixed(1)); }
          count++;
        }
      });
      return count;
    }

    function svgKeepWallsOnly(svg) {
      let count = 0;
      // Remove everything that is NOT a wall group
      Array.from(svg.children).forEach(child => {
        if (child.tagName === 'g' && child.hasAttribute('data-fp-wall-idx')) return; // keep wall
        if (child.tagName === 'defs') return; // keep defs
        child.remove(); count++;
      });
      return count;
    }

    const OP_MAP = {
      svgRemoveThinWalls:    svgRemoveThinWalls,
      svgThickenWalls:       svgThickenWalls,
      svgRemoveDoors:        svgRemoveDoors,
      svgRemoveText:         svgRemoveText,
      svgRemoveSmallElements:svgRemoveSmallElements,
      svgRemoveFills:        svgRemoveFills,
      svgBlackWhite:         svgBlackWhite,
      svgRemoveHatching:     svgRemoveHatching,
      svgRemoveDiagonals:    svgRemoveDiagonals,
      svgStraightenWalls:    svgStraightenWalls,
      svgKeepWallsOnly:      svgKeepWallsOnly,
    };

    // Expose OP_MAP globally for re-apply on load
    window._fpOpMap = OP_MAP;
    window._fpLastAppliedOps = [];

    /**
     * Re-apply a list of SVG operation keys to all floor-plan SVGs.
     * Used when loading a saved report to restore cleaning state.
     * Returns { results: string[], totalMs: number }.
     */
    window._fpReapplyOps = function(opKeys) {
      if (!Array.isArray(opKeys) || !opKeys.length) return { results: [], totalMs: 0 };
      const svgs = getAllSvgs();
      if (!svgs.length) return { results: [], totalMs: 0 };
      const t0 = performance.now();
      const results = [];
      for (const opKey of opKeys) {
        const fn = OP_MAP[opKey];
        if (!fn) { results.push(opKey + ': unknown'); continue; }
        let totalCount = 0;
        for (const svg of svgs) totalCount += fn(svg);
        results.push(opKey + ': ' + totalCount);
      }
      window._fpLastAppliedOps = opKeys.slice();
      // Also check the corresponding checkboxes in the UI
      try {
        if (_opsMenu) {
          _opsMenu.querySelectorAll('li[data-op] input[type="checkbox"]').forEach(cb => cb.checked = false);
          for (const opKey of opKeys) {
            const li = _opsMenu.querySelector('li[data-op="' + opKey + '"] input[type="checkbox"]');
            if (li) li.checked = true;
          }
          const checked = Array.from(_opsMenu.querySelectorAll('input:checked'))
            .map(c => c.closest('li').querySelector('span').textContent.trim());
          if (_opsLabel) _opsLabel.textContent = checked.length === 0 ? 'SVG Operations...' : checked.length === 1 ? checked[0] : checked.length + ' selected';
        }
      } catch(e) { console.warn('[ReapplyOps] UI sync error:', e); }
      return { results, totalMs: Math.round(performance.now() - t0) };
    };

    // Apply button
    btnApply.addEventListener('click', async () => {
      const ops = getSelectedOps();
      if (!ops.length) { setLog('<span class="text-amber-400">Select at least one operation</span>'); return; }

      const svgs = getAllSvgs();
      if (!svgs.length) { setLog('<span class="text-rose-400">No SVG found in Floor Plan</span>'); return; }

      btnApply.disabled = true;
      btnApply.classList.add('animate-pulse');
      if (applyIcon) {
        applyIcon.classList.remove('fa-play');
        applyIcon.classList.add('fa-circle-notch', 'fa-spin');
      }
      await new Promise(r => requestAnimationFrame(r));

      // Capture before image for AI training
      let beforeImg = null;
      try { beforeImg = svgs[0] ? await svgToDataUrl(svgs[0], 1024) : null; } catch {}

      try {
        pushUndo();
        const t0 = performance.now();
        const results = [];

        for (const opKey of ops) {
          const fn = OP_MAP[opKey];
          if (!fn) { results.push(`${opKey}: unknown`); continue; }
          let totalCount = 0;
          for (const svg of svgs) totalCount += fn(svg);
          const label = _opsMenu.querySelector(`li[data-op="${opKey}"] span`);
          results.push(`${label ? label.textContent.trim() : opKey}: ${totalCount}`);
        }

        const ms = Math.round(performance.now() - t0);
        setLog(
          `<span class="text-emerald-400">Done</span>` +
          `<span class="p2s-sep mx-1">|</span>` +
          `<span class="p2s-text">${results.join(' · ')}</span>` +
          `<span class="p2s-sep mx-1">|</span>` +
          `<span class="p2s-muted-text">${ms}ms</span>` +
          `<span class="p2s-sep mx-1">|</span>` +
          `<span class="p2s-muted-text">Undo: ${undoStack.length}/${maxUndo}</span>`
        );
        // Track applied ops for save/load persistence
        window._fpLastAppliedOps = ops.slice();

        // ── Log SVG operations as AI training data ──
        try {
          const afterImg = svgs[0] ? await svgToDataUrl(svgs[0], 1024) : null;
          const resultJson = JSON.stringify({
            mode: 'svg-ops',
            operations: ops,
            results: results,
            totalMs: ms,
            svgCount: svgs.length
          });
          const opsDescription = ops.map(o => {
            const li = _opsMenu ? _opsMenu.querySelector(`li[data-op="${o}"] span`) : null;
            return li ? li.textContent.trim() : o;
          }).join(', ');

          await logAiInteraction(
            `SVG operations: ${opsDescription}`,
            'svg-ops',
            'svg-clean',
            true,
            results.join('; '),
            resultJson,
            ms, ms, 0, null,
            beforeImg, afterImg
          );

          // Also save as AI example for clean-drawing category
          const [beforeSmall, afterSmall] = await Promise.all([
            _downscaleForLog(beforeImg, 512),
            _downscaleForLog(afterImg, 512)
          ]);
          await saveAiExample(
            'clean-drawing',
            ['ניקוי', 'clean', 'svg-ops', ...ops],
            `SVG ops: ${opsDescription}`,
            'svg-ops',
            results.join('; '),
            resultJson,
            beforeSmall, afterSmall,
            1
          );
        } catch (e) { console.warn('[SvgOps] AI training log failed:', e); }
      } finally {
        btnApply.classList.remove('animate-pulse');
        btnApply.disabled = false;
        if (applyIcon) {
          applyIcon.classList.remove('fa-circle-notch', 'fa-spin');
          applyIcon.classList.add('fa-play');
        }
      }
    });

    // Undo button
    if (btnUndo) btnUndo.addEventListener('click', () => {
      if (!undoStack.length) { setLog('<span class="text-amber-400">Nothing to undo</span>'); return; }

      const current = snapshotSvgs();
      const prev = undoStack.pop();
      redoStack.push(current);
      restoreSvgs(prev);
      refreshUndoRedoButtons();
      setLog('<span class="text-sky-400">Undo applied</span>');
    });

    // Redo button
    if (btnRedo) btnRedo.addEventListener('click', () => {
      if (!redoStack.length) { setLog('<span class="text-amber-400">Nothing to redo</span>'); return; }

      const current = snapshotSvgs();
      const next = redoStack.pop();
      undoStack.push(current);
      if (undoStack.length > maxUndo) undoStack.shift();
      restoreSvgs(next);
      refreshUndoRedoButtons();
      setLog('<span class="text-sky-400">Redo applied</span>');
    });

    refreshUndoRedoButtons();
  })();

  // ── Custom dropdown for Image-Editor provider (one-time init) ──
  (function initProviderDropdown() {
    const _provBtn   = document.getElementById('pdfImageEditProviderBtn');
    const _provLabel = document.getElementById('pdfImageEditProviderLabel');
    const _provMenu  = document.getElementById('pdfImageEditProviderMenu');
    const _provSel   = document.getElementById('pdfImageEditProvider');
    if (!_provBtn || !_provMenu || !_provSel) return;

    _provBtn.addEventListener('click', (e) => {
      e.preventDefault(); e.stopPropagation();
      _provMenu.classList.toggle('hidden');
    });

    // Use event delegation on the <ul> for robust click handling
    _provMenu.addEventListener('click', (e) => {
      e.preventDefault(); e.stopPropagation();
      const li = e.target.closest('li[data-value]');
      if (!li) return;
      const val = li.dataset.value;
      _provSel.value = val;
      if (_provLabel) _provLabel.textContent = li.textContent.trim();
      // highlight active
      _provMenu.querySelectorAll('li[data-value]').forEach(x => x.classList.remove('bg-sky-900/30','bg-amber-900/30','bg-emerald-900/30'));
      li.classList.add(val === 'gemini' ? 'bg-amber-900/30' : (val === 'local' ? 'bg-emerald-900/30' : 'bg-sky-900/30'));
      _provMenu.classList.add('hidden');
      try { _provSel.dispatchEvent(new Event('change', { bubbles: true })); } catch { }
      console.log('[Provider] Selected:', val);
    });

    document.addEventListener('click', () => _provMenu.classList.add('hidden'));
  })();

  // ── Floor Plan provider selector (mirrors PDF Image provider) ──
  (function initFloorPlanProviderMirror() {
    const fpProviderBtn = document.getElementById('fpBuildProviderBtn');
    const fpProviderLabel = document.getElementById('fpBuildProviderLabel');
    const fpProviderMenu = document.getElementById('fpBuildProviderMenu');
    const fpProviderSel = document.getElementById('fpBuildProvider');
    const _provLabel = document.getElementById('pdfImageEditProviderLabel');
    const _provMenu  = document.getElementById('pdfImageEditProviderMenu');
    const _provSel   = document.getElementById('pdfImageEditProvider');
    const fpLogEl    = document.getElementById('fpEditLog');
    if (!fpProviderBtn || !fpProviderMenu || !fpProviderSel || !_provSel) return;

    function providerLabel(v) {
      const p = String(v || '').trim().toLowerCase();
      return p === 'local' ? 'DIRECT (Local / No AI)'
        : p === 'gemini' ? 'ONLINE (Google Gemini)'
        : p === 'claude' ? 'ONLINE (Claude)'
        : p === 'ollama' ? 'OFFLINE (Ollama vision model)'
        : 'ONLINE (OpenAI)';
    }

    function syncPdfProviderVisuals(val) {
      if (_provLabel) _provLabel.textContent = providerLabel(val);
      if (_provMenu) {
        _provMenu.querySelectorAll('li[data-value]').forEach(li => {
          li.classList.remove('bg-sky-900/30', 'bg-amber-900/30', 'bg-emerald-900/30');
          if (li.dataset.value === val) {
            li.classList.add(val === 'gemini' ? 'bg-amber-900/30' : (val === 'local' ? 'bg-emerald-900/30' : 'bg-sky-900/30'));
          }
        });
      }
    }

    function syncFloorProviderVisuals(val) {
      if (fpProviderLabel) fpProviderLabel.textContent = providerLabel(val);
      if (fpProviderMenu) {
        fpProviderMenu.querySelectorAll('li[data-value]').forEach(li => {
          li.classList.remove('bg-sky-900/30', 'bg-amber-900/30', 'bg-emerald-900/30');
          if (li.dataset.value === val) {
            li.classList.add(val === 'gemini' ? 'bg-amber-900/30' : (val === 'local' ? 'bg-emerald-900/30' : 'bg-sky-900/30'));
          }
        });
      }
    }

    function syncFromPdfToFloor() {
      const v = _provSel.value || 'openai';
      fpProviderSel.value = v;
      syncFloorProviderVisuals(v);
      syncPdfProviderVisuals(v);
    }

    // Initial sync
    syncFromPdfToFloor();

    // If user changes provider in PDF Image tab, reflect it in Floor Plan tab.
    _provSel.addEventListener('change', syncFromPdfToFloor);

    fpProviderBtn.addEventListener('click', (e) => {
      e.preventDefault(); e.stopPropagation();
      fpProviderMenu.classList.toggle('hidden');
    });

    fpProviderMenu.addEventListener('click', (e) => {
      e.preventDefault(); e.stopPropagation();
      const li = e.target.closest('li[data-value]');
      if (!li) return;
      const v = li.dataset.value || 'openai';
      fpProviderSel.value = v;
      syncFloorProviderVisuals(v);
      fpProviderMenu.classList.add('hidden');
      try { fpProviderSel.dispatchEvent(new Event('change', { bubbles: true })); } catch { }
    });

    document.addEventListener('click', () => fpProviderMenu.classList.add('hidden'));

    // If user changes provider in Floor Plan tab, reflect it in PDF Image tab.
    fpProviderSel.addEventListener('change', () => {
      const v = fpProviderSel.value || 'openai';
      syncFloorProviderVisuals(v);
      _provSel.value = v;
      syncPdfProviderVisuals(v);
      try { _provSel.dispatchEvent(new Event('change', { bubbles: true })); } catch { }

      if (fpLogEl) {
        fpLogEl.innerHTML =
          `<span class="p2s-muted">Provider:</span> ` +
          `<span class="p2s-text font-semibold">${providerLabel(v)}</span>`;
      }
      console.log('[FloorPlan] Provider selected:', v, '| label:', providerLabel(v));
    });
  })();

