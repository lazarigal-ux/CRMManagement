    // Last AI-returned operations (for log display)
    let _lastAiOps = null;

    function extractJsonFromAiResponse(rawText) {
      // The AI response may come in various wrapper formats
      let text = (rawText || '').trim();

      // Try to find JSON in the response - could be wrapped in the API response object
      const parsed = safeJsonParse(text, null);

      // If the response is the API wrapper, look for the text content
      let contentText = null;
      if (parsed) {
        // Gemini chat/completions style
        if (parsed.choices && parsed.choices[0] && parsed.choices[0].message) {
          contentText = parsed.choices[0].message.content || '';
        }
        // Ollama style
        else if (parsed.message && parsed.message.content) {
          contentText = parsed.message.content || '';
        }
        // OpenAI responses style
        else if (parsed.output) {
          const msgObj = Array.isArray(parsed.output) ? parsed.output.find(o => o.type === 'message') : null;
          if (msgObj && msgObj.content) {
            const txtPart = Array.isArray(msgObj.content) ? msgObj.content.find(c => c.type === 'output_text' || c.type === 'text') : null;
            contentText = txtPart ? (txtPart.text || '') : '';
          }
        }
        // Already the ops JSON
        else if (parsed.operations) {
          return parsed;
        }
      }

      if (!contentText) contentText = text;

      // Strip markdown code fences if present
      contentText = contentText.replace(/^```(?:json)?\s*/i, '').replace(/\s*```\s*$/i, '').trim();

      const opsJson = safeJsonParse(contentText, null);
      if (opsJson && opsJson.operations) return opsJson;

      // Try to find JSON object in the text
      const match = contentText.match(/\{[\s\S]*"operations"[\s\S]*\}/);
      if (match) {
        const found = safeJsonParse(match[0], null);
        if (found && found.operations) return found;
      }

      return null;
    }

    /**
     * Apply AI-returned pixel operations on image dataUrl. Returns new dataUrl.
     */
    function applyVisionOps(dataUrl, operations) {
      return new Promise((resolve) => {
        const img = new Image();
        img.onload = () => {
          const canvas = document.createElement('canvas');
          canvas.width = img.naturalWidth;
          canvas.height = img.naturalHeight;
          const ctx = canvas.getContext('2d', { willReadFrequently: true });
          ctx.drawImage(img, 0, 0);

          const imageData = ctx.getImageData(0, 0, canvas.width, canvas.height);
          const d = imageData.data;
          const w = canvas.width, h = canvas.height;

          for (const op of operations) {
            const type = (op.type || '').toLowerCase();
            const tolerance = Math.max(0, Math.min(100, op.tolerance ?? 35));
            console.log(`[AI Vision Ops] Executing operation: ${type}(${op.color || ''}) with tolerance ${tolerance}`);

            let modCount = 0;
            if (type === 'keepcolor' && op.color) {
              modCount = applyKeepColor(d, op.color, tolerance);
            } else if (type === 'removecolor' && op.color) {
              modCount = applyRemoveColor(d, op.color, tolerance);
            } else if (type === 'removethinlines') {
              applyRemoveThinLines(d, w, h);
            } else if (type === 'removethicklines') {
              modCount = applyRemoveThickLines(d, w, h);
            } else if (type === 'keepthicklines' || type === 'keepwalls') {
              modCount = applyKeepThickLines(d, w, h, op.params);
            } else if (type === 'finalizewalls' || type === 'finalwalls' || type === 'cleanwallsfinal') {
              modCount = applyFinalizeWalls(d, w, h);
            } else if (type === 'keeponlylines') {
              applyKeepOnlyLines(d);
            } else if (type === 'removebackground') {
              applyRemoveBackground(d);
            } else if (type === 'invertcolors') {
              for (let i = 0; i < d.length; i += 4) {
                d[i] = 255 - d[i]; d[i+1] = 255 - d[i+1]; d[i+2] = 255 - d[i+2];
              }
            }
            if (modCount !== undefined && modCount > 0) {
              console.log(`[AI Vision Ops] ${type}(${op.color}) turned ${modCount} pixels white.`);
            } else if (modCount === 0 && (type === 'keepcolor' || type === 'removecolor')) {
              console.log(`[AI Vision Ops] ${type}(${op.color}) matched no colors or modified 0 pixels.`);
            }
          }

          ctx.putImageData(imageData, 0, 0);
          resolve(canvas.toDataURL('image/png'));
        };
        img.onerror = () => resolve(dataUrl);
        img.src = dataUrl;
      });
    }

    // ── Color matching helpers ──
    function colorNameToHSL(name) {
      const map = {
        red:     { h: 0,   s: 100, l: 50 },
        orange:  { h: 30,  s: 100, l: 50 },
        yellow:  { h: 60,  s: 100, l: 50 },
        green:   { h: 120, s: 100, l: 40 },
        cyan:    { h: 180, s: 100, l: 50 },
        blue:    { h: 240, s: 100, l: 50 },
        purple:  { h: 270, s: 100, l: 50 },
        magenta: { h: 300, s: 100, l: 50 },
        pink:    { h: 330, s: 80,  l: 70 },
        brown:   { h: 20,  s: 60,  l: 30 },
        black:   { h: 0,   s: 0,   l: 0 },
        gray:    { h: 0,   s: 0,   l: 50 },
        white:   { h: 0,   s: 0,   l: 100 }
      };
      return map[(name || '').toLowerCase()] || null;
    }

    function rgbToHsl(r, g, b) {
      r /= 255; g /= 255; b /= 255;
      const max = Math.max(r, g, b), min = Math.min(r, g, b);
      let h = 0, s = 0, l = (max + min) / 2;
      if (max !== min) {
        const d = max - min;
        s = l > 0.5 ? d / (2 - max - min) : d / (max + min);
        switch (max) {
          case r: h = ((g - b) / d + (g < b ? 6 : 0)) / 6; break;
          case g: h = ((b - r) / d + 2) / 6; break;
          case b: h = ((r - g) / d + 4) / 6; break;
        }
      }
      return { h: h * 360, s: s * 100, l: l * 100 };
    }

    function pixelMatchesColor(r, g, b, targetHSL, tolerance) {
      const pHSL = rgbToHsl(r, g, b);
      
      // For black/white/gray, use luminance-based matching AND check saturation
      if (targetHSL.s === 0) {
        const lum = (r * 0.299 + g * 0.587 + b * 0.114) / 255 * 100;
        if (Math.abs(lum - targetHSL.l) > tolerance) return false;
        
        // Prevent heavily saturated colors (like pure red) from matching gray
        // Allow up to ~25% saturation for valid grays
        if (targetHSL.l > 15 && targetHSL.l < 85 && pHSL.s > 25) {
            return false; 
        }
        return true;
      }
      
      // Skip near-white or near-black desaturated pixels for chromatic colors
      if (pHSL.s < 15 && targetHSL.s > 20) return false;
      // Hue distance (circular)
      let hDist = Math.abs(pHSL.h - targetHSL.h);
      if (hDist > 180) hDist = 360 - hDist;
      const hTol = Math.max(tolerance * 1.2, 20); // Lenient hue
      const sTol = Math.max(tolerance * 1.5, 30); // Lenient saturation
      return hDist <= hTol && Math.abs(pHSL.s - targetHSL.s) <= sTol;
    }

    function applyKeepColor(d, colorName, tolerance) {
      const target = colorNameToHSL(colorName);
      if (!target) return 0;
      let count = 0;
      for (let i = 0; i < d.length; i += 4) {
        if (!pixelMatchesColor(d[i], d[i+1], d[i+2], target, tolerance)) {
          d[i] = 255; d[i+1] = 255; d[i+2] = 255;
          count++;
        }
      }
      return count;
    }

    function applyRemoveColor(d, colorName, tolerance) {
      const target = colorNameToHSL(colorName);
      if (!target) return 0;
      let count = 0;
      for (let i = 0; i < d.length; i += 4) {
        if (pixelMatchesColor(d[i], d[i+1], d[i+2], target, tolerance)) {
          d[i] = 255; d[i+1] = 255; d[i+2] = 255;
          count++;
        }
      }
      return count;
    }

    function applyRemoveThinLines(d, w, h, maxThicknessPx = 3, rect = null) {
      const t = Math.max(1, Math.min(5, Number(maxThicknessPx) || 3));
      const darkThreshold = 200; // Catch lighter gray thin lines too
      // Higher thickness => allow more neighbors + more passes (stronger removal)
      const neighborMax = Math.max(2, Math.min(7, t + 1));
      const passes = Math.max(1, Math.min(4, t));
      let mods = 0;

      // Optional ROI (rectangle). If provided, only pixels inside ROI can be removed.
      // We still consider a small margin around the ROI to keep neighborhood logic stable.
      let rx0 = 0, ry0 = 0, rx1 = w, ry1 = h; // [x0,x1) [y0,y1)
      if (rect && Number.isFinite(rect.x0) && Number.isFinite(rect.y0) && Number.isFinite(rect.w) && Number.isFinite(rect.h)) {
        rx0 = Math.max(0, Math.min(w, Math.floor(rect.x0)));
        ry0 = Math.max(0, Math.min(h, Math.floor(rect.y0)));
        rx1 = Math.max(rx0, Math.min(w, Math.floor(rect.x0 + rect.w)));
        ry1 = Math.max(ry0, Math.min(h, Math.floor(rect.y0 + rect.h)));
      }

      // Expand by (passes+1) pixels so neighborhood decisions at the ROI edge behave.
      const margin = Math.max(2, Math.min(16, passes + 2));
      const ex0 = Math.max(0, rx0 - margin);
      const ey0 = Math.max(0, ry0 - margin);
      const ex1 = Math.min(w, rx1 + margin);
      const ey1 = Math.min(h, ry1 + margin);

      const mask = new Uint8Array(w * h);
      for (let y = ey0; y < ey1; y++) {
        const row = y * w;
        for (let x = ex0; x < ex1; x++) {
          const p = row + x;
          const i = p * 4;
          if (d[i + 3] < 50) { mask[p] = 0; continue; }
          const lum = d[i] * 0.299 + d[i + 1] * 0.587 + d[i + 2] * 0.114;
          mask[p] = lum < darkThreshold ? 1 : 0;
        }
      }

      // Iterative prune in the expanded region only.
      let cur = mask;
      let next = new Uint8Array(w * h);
      for (let pass = 0; pass < passes; pass++) {
        for (let y = ey0; y < ey1; y++) {
          const row = y * w;
          for (let x = ex0; x < ex1; x++) {
            const p = row + x;
            const v = cur[p];
            if (v === 0) { next[p] = 0; continue; }
            if (x <= 0 || y <= 0 || x >= w - 1 || y >= h - 1) { next[p] = v; continue; }

            const n =
              cur[p - w - 1] + cur[p - w] + cur[p - w + 1] +
              cur[p - 1] + cur[p + 1] +
              cur[p + w - 1] + cur[p + w] + cur[p + w + 1];
            next[p] = (n <= neighborMax) ? 0 : 1;
          }
        }
        const tmp = cur;
        cur = next;
        next = tmp;
      }

      // Apply whitening ONLY inside the ROI rectangle.
      for (let y = ry0; y < ry1; y++) {
        const row = y * w;
        for (let x = rx0; x < rx1; x++) {
          const p = row + x;
          if (mask[p] === 1 && cur[p] === 0) {
            const i = p * 4;
            d[i] = 255; d[i + 1] = 255; d[i + 2] = 255;
            mods++;
          }
        }
      }
      return mods;
    }

    // Remove strokes by estimated thickness using a Chebyshev distance-to-background transform.
    // Works well on continuous thin lines (borders, contour lines) inside a selected ROI.
    function applyRemoveThinLinesByStrokeWidth(d, w, h, maxThicknessPx = 3, rect = null, exclude = null) {
      const t = Math.max(1, Math.min(5, Number(maxThicknessPx) || 3));
      const distT = Math.max(1, Math.min(12, Math.ceil(t / 2))); // thickness~(2r+1) => dist~(r+1)

      // ROI bounds
      let rx0 = 0, ry0 = 0, rx1 = w, ry1 = h; // [x0,x1) [y0,y1)
      if (rect && Number.isFinite(rect.x0) && Number.isFinite(rect.y0) && Number.isFinite(rect.w) && Number.isFinite(rect.h)) {
        rx0 = Math.max(0, Math.min(w, Math.floor(rect.x0)));
        ry0 = Math.max(0, Math.min(h, Math.floor(rect.y0)));
        rx1 = Math.max(rx0, Math.min(w, Math.floor(rect.x0 + rect.w)));
        ry1 = Math.max(ry0, Math.min(h, Math.floor(rect.y0 + rect.h)));
      }
      if (rx1 - rx0 < 2 || ry1 - ry0 < 2) return 0;

      // Expand compute window so strokes near ROI edges get correct distances.
      const margin = Math.max(2, Math.min(24, distT + 6));
      const ex0 = Math.max(0, rx0 - margin);
      const ey0 = Math.max(0, ry0 - margin);
      const ex1 = Math.min(w, rx1 + margin);
      const ey1 = Math.min(h, ry1 + margin);

      const bw = Math.max(1, ex1 - ex0);
      const bh = Math.max(1, ey1 - ey0);
      // Safety: avoid huge allocations on very large selections.
      if (bw * bh > 18_000_000) {
        console.warn('[ThinStrokeWidth] ROI too large:', bw, 'x', bh);
        return 0;
      }

      // Consider ink pixels as anything not near-white. This is intentionally lenient
      // so colored/gray thin strokes (e.g. red stamps) are included.
      const inkThreshold = 235;

      const ink = new Uint8Array(bw * bh);
      const dist = new Uint16Array(bw * bh);
      const INF = 0xffff;

      for (let y = 0; y < bh; y++) {
        const gy = ey0 + y;
        for (let x = 0; x < bw; x++) {
          const gx = ex0 + x;
          const p = y * bw + x;
          const i = (gy * w + gx) * 4;
          const a = d[i + 3];
          if (a < 50) {
            ink[p] = 0;
            dist[p] = 0;
            continue;
          }
          const lum = d[i] * 0.299 + d[i + 1] * 0.587 + d[i + 2] * 0.114;
          const isInk = lum < inkThreshold;
          ink[p] = isInk ? 1 : 0;
          dist[p] = isInk ? INF : 0;
        }
      }

      // Two-pass Chebyshev distance transform (8-connected, cost=1).
      for (let y = 0; y < bh; y++) {
        for (let x = 0; x < bw; x++) {
          const idx = y * bw + x;
          if (dist[idx] === 0) continue;
          let best = dist[idx];
          if (x > 0) best = Math.min(best, dist[idx - 1] + 1);
          if (y > 0) best = Math.min(best, dist[idx - bw] + 1);
          if (x > 0 && y > 0) best = Math.min(best, dist[idx - bw - 1] + 1);
          if (x + 1 < bw && y > 0) best = Math.min(best, dist[idx - bw + 1] + 1);
          dist[idx] = best;
        }
      }
      for (let y = bh - 1; y >= 0; y--) {
        for (let x = bw - 1; x >= 0; x--) {
          const idx = y * bw + x;
          if (dist[idx] === 0) continue;
          let best = dist[idx];
          if (x + 1 < bw) best = Math.min(best, dist[idx + 1] + 1);
          if (y + 1 < bh) best = Math.min(best, dist[idx + bw] + 1);
          if (x + 1 < bw && y + 1 < bh) best = Math.min(best, dist[idx + bw + 1] + 1);
          if (x > 0 && y + 1 < bh) best = Math.min(best, dist[idx + bw - 1] + 1);
          dist[idx] = best;
        }
      }

      // Whiten ink pixels within ROI whose distance-to-background is <= distT.
      let changed = 0;
      for (let gy = ry0; gy < ry1; gy++) {
        const y = gy - ey0;
        if (y < 0 || y >= bh) continue;
        for (let gx = rx0; gx < rx1; gx++) {
          const x = gx - ex0;
          if (x < 0 || x >= bw) continue;
          const p = y * bw + x;
          if (!ink[p]) continue;
          if (exclude && exclude.data) {
            const lx = gx - rx0;
            const ly = gy - ry0;
            if (lx >= 0 && ly >= 0 && lx < exclude.w && ly < exclude.h) {
              const ei = (ly * exclude.w + lx) * 4 + 3;
              if (exclude.data[ei] > 0) continue;
            }
          }
          if (dist[p] <= distT) {
            const i = (gy * w + gx) * 4;
            d[i] = 255; d[i + 1] = 255; d[i + 2] = 255; d[i + 3] = 255;
            changed++;
          }
        }
      }
      return changed;
    }

    function applyRemoveThickLines(d, w, h) {
      const darkThreshold = 200;
      const neighborMin = 6;
      let mods = 0;
      const mask = new Uint8Array(w * h);
      for (let y = 0; y < h; y++) {
        for (let x = 0; x < w; x++) {
          const i = (y * w + x) * 4;
          if (d[i+3] < 50) continue;
          const lum = d[i] * 0.299 + d[i+1] * 0.587 + d[i+2] * 0.114;
          mask[y * w + x] = lum < darkThreshold ? 1 : 0;
        }
      }
      for (let y = 1; y < h - 1; y++) {
        for (let x = 1; x < w - 1; x++) {
          const p = y * w + x;
          if (mask[p] === 0) continue;
          let n = mask[p-w-1]+mask[p-w]+mask[p-w+1]+mask[p-1]+mask[p+1]+mask[p+w-1]+mask[p+w]+mask[p+w+1];
          if (n >= neighborMin) {
            const i = p * 4;
            d[i] = 255; d[i+1] = 255; d[i+2] = 255;
            mods++;
          }
        }
      }
      return mods;
    }
    
    /**
     * applyKeepThickLines – morphological-opening approach via distance transforms.
     *
     * Why this works better than neighbour-counting:
     *   Hatching patterns have many dark neighbours but each individual stroke
     *   is only 1-2 px from a white gap → distance-to-background is 0-1.
     *   True walls are solid bands ≥ 4-5 px → their centres have distance ≥ 2.
     *   A morphological opening (erode then dilate) eliminates thin features
     *   while preserving thick ones.
     *
     * Pipeline:
     *   1. Binary ink mask (luminance < threshold)
     *   2. Chebyshev distance-to-background  (O(w·h), two-pass)
     *   3. Core pixels = dist ≥ coreThreshold  (survive erosion)
     *   4. Distance-to-nearest-core            (another Chebyshev DT)
     *   5. keep = ink ∩ (distToCore ≤ dilR)    (morphological dilation)
     *   6. Long-run fallback for thin walls     (perpendicular-thickness validated)
     *   7. Remove small isolated components
     *   8. Paint pixels
     */
    function applyKeepThickLines(d, w, h, aiParams) {
      const p = aiParams || {};
      const INF = 0xffff;
      const sizeRef = Math.min(w, h);
      let mods = 0;

      // ── AI-tuned parameters (Claude analyses the image and supplies these) ──
      const wallPx         = Math.max(2, Math.min(20, Number(p.wallThicknessPx) || 0));
      const darkThreshold  = Math.max(100, Math.min(240, Number(p.darkThreshold) || 205));
      const hasHatching    = !!p.hasHatching;
      const hasDimLines    = !!p.hasDimensionLines;
      const aiConfidence   = Math.max(0, Math.min(1, Number(p.confidence) || 0.5));
      console.log('[keepThickLines] AI params:', JSON.stringify(p), '| wallPx:', wallPx, '| dark:', darkThreshold, '| hatch:', hasHatching, '| dim:', hasDimLines, '| confidence:', aiConfidence);

      // Derive morphological radii from AI-estimated wall thickness
      //   wallPx=3-4 → core=1, wallPx=5-6 → core=2, wallPx=8+ → core=3
      let coreThreshold  = wallPx > 0
        ? Math.max(1, Math.min(5, Math.round(wallPx / 2) - 1))
        : (hasHatching ? 3 : 2);                                           // aggressive erosion when hatching present
      let dilR           = coreThreshold + 1;                            // dilation restore radius
      const minRun         = Math.max(25, Math.round(sizeRef * 0.03));     // min run length for thin-wall fallback
      const minPerpThickness = hasDimLines ? 2 : 1;                        // reject 1px lines only when dim-lines present
      const maxPerpThickness = Math.max(12, wallPx > 0 ? wallPx * 3 : Math.round(sizeRef * 0.012));
      const minComponentArea  = hasHatching
        ? Math.max(150, Math.round((w * h) * 0.0005))                     // stricter when hatching
        : Math.max(80, Math.round((w * h) * 0.0003));

      // ── 1. Binary ink mask ──
      const mask = new Uint8Array(w * h);
      let totalInkPixels = 0;
      for (let y = 0; y < h; y++) {
        for (let x = 0; x < w; x++) {
          const i = (y * w + x) * 4;
          if (d[i + 3] < 50) continue;
          const lum = d[i] * 0.299 + d[i + 1] * 0.587 + d[i + 2] * 0.114;
          if (lum < darkThreshold) {
            mask[y * w + x] = 1;
            totalInkPixels++;
          }
        }
      }
      console.log('[keepThickLines] Total ink pixels:', totalInkPixels, '| initial coreThreshold:', coreThreshold);

      // ── 2. Chebyshev distance-to-background (two-pass O(w·h)) ──
      const dist = new Uint16Array(w * h);
      for (let i = 0; i < w * h; i++) dist[i] = mask[i] ? INF : 0;

      for (let y = 0; y < h; y++) {                       // forward
        for (let x = 0; x < w; x++) {
          const p = y * w + x;
          if (dist[p] === 0) continue;
          let b = dist[p];
          if (x > 0)                b = Math.min(b, dist[p - 1] + 1);
          if (y > 0)                b = Math.min(b, dist[p - w] + 1);
          if (x > 0 && y > 0)       b = Math.min(b, dist[p - w - 1] + 1);
          if (x + 1 < w && y > 0)   b = Math.min(b, dist[p - w + 1] + 1);
          dist[p] = b;
        }
      }
      for (let y = h - 1; y >= 0; y--) {                  // backward
        for (let x = w - 1; x >= 0; x--) {
          const p = y * w + x;
          if (dist[p] === 0) continue;
          let b = dist[p];
          if (x + 1 < w)                b = Math.min(b, dist[p + 1] + 1);
          if (y + 1 < h)                b = Math.min(b, dist[p + w] + 1);
          if (x + 1 < w && y + 1 < h)   b = Math.min(b, dist[p + w + 1] + 1);
          if (x > 0 && y + 1 < h)       b = Math.min(b, dist[p + w - 1] + 1);
          dist[p] = b;
        }
      }

      // ── 3. Wall cores (survived morphological erosion) ──
      // Auto-reduce coreThreshold if too few pixels survive (AI mis-estimated wall thickness)
      const core = new Uint8Array(w * h);
      const MIN_CORE_SURVIVAL_RATIO = 0.02; // at least 2% of ink should survive as cores
      while (coreThreshold >= 1) {
        let coreCount = 0;
        for (let i = 0; i < w * h; i++) {
          core[i] = dist[i] >= coreThreshold ? 1 : 0;
          if (core[i]) coreCount++;
        }
        const survivalRatio = totalInkPixels > 0 ? coreCount / totalInkPixels : 0;
        console.log(`[keepThickLines] coreThreshold=${coreThreshold} → ${coreCount} core pixels (${(survivalRatio * 100).toFixed(1)}% of ink)`);
        if (coreCount > 0 && survivalRatio >= MIN_CORE_SURVIVAL_RATIO) break;
        // Too aggressive — reduce and retry
        coreThreshold--;
        dilR = coreThreshold + 1;
        console.log(`[keepThickLines] Too few cores survived, reducing coreThreshold to ${coreThreshold}`);
      }
      // If coreThreshold reached 0, keep all ink pixels as cores (fallback to long-run filter only)
      if (coreThreshold < 1) {
        console.log('[keepThickLines] coreThreshold=0 fallback: using all ink as potential walls, long-run filter will discriminate');
        for (let i = 0; i < w * h; i++) core[i] = mask[i];
        dilR = 1;
      }

      // ── 4. Distance-to-nearest-core (Chebyshev DT on cores) ──
      const dCore = new Uint16Array(w * h);
      for (let i = 0; i < w * h; i++) dCore[i] = core[i] ? 0 : INF;

      for (let y = 0; y < h; y++) {
        for (let x = 0; x < w; x++) {
          const p = y * w + x;
          if (dCore[p] === 0) continue;
          let b = dCore[p];
          if (x > 0)                b = Math.min(b, dCore[p - 1] + 1);
          if (y > 0)                b = Math.min(b, dCore[p - w] + 1);
          if (x > 0 && y > 0)       b = Math.min(b, dCore[p - w - 1] + 1);
          if (x + 1 < w && y > 0)   b = Math.min(b, dCore[p - w + 1] + 1);
          dCore[p] = b;
        }
      }
      for (let y = h - 1; y >= 0; y--) {
        for (let x = w - 1; x >= 0; x--) {
          const p = y * w + x;
          if (dCore[p] === 0) continue;
          let b = dCore[p];
          if (x + 1 < w)                b = Math.min(b, dCore[p + 1] + 1);
          if (y + 1 < h)                b = Math.min(b, dCore[p + w] + 1);
          if (x + 1 < w && y + 1 < h)   b = Math.min(b, dCore[p + w + 1] + 1);
          if (x > 0 && y + 1 < h)       b = Math.min(b, dCore[p + w - 1] + 1);
          dCore[p] = b;
        }
      }

      // ── 5. keep = dark pixels near a wall core ──
      const keep = new Uint8Array(w * h);
      for (let i = 0; i < w * h; i++) {
        keep[i] = (mask[i] === 1 && dCore[i] <= dilR) ? 1 : 0;
      }

      // ── 6. Long-run fallback for thin structural walls ──
      // Thin walls (2-4 px) don't survive coreThreshold=2 but they ARE long
      // straight lines.  Validate with perpendicular thickness to reject
      // dimension lines (1 px) and dense fill bands (very wide).
      function perpH(y0, x0) {
        let up = 0, dn = 0;
        while (y0 - up - 1 >= 0 && mask[(y0 - up - 1) * w + x0]) up++;
        while (y0 + dn + 1 < h  && mask[(y0 + dn + 1) * w + x0]) dn++;
        return up + dn + 1;
      }
      function perpV(y0, x0) {
        let lt = 0, rt = 0;
        while (x0 - lt - 1 >= 0 && mask[y0 * w + (x0 - lt - 1)]) lt++;
        while (x0 + rt + 1 < w  && mask[y0 * w + (x0 + rt + 1)]) rt++;
        return lt + rt + 1;
      }
      const sampleFracs = [0.1, 0.3, 0.5, 0.7, 0.9];

      // horizontal runs
      for (let y = 0; y < h; y++) {
        let x = 0;
        while (x < w) {
          while (x < w && mask[y * w + x] === 0) x++;
          if (x >= w) break;
          const s = x;
          while (x < w && mask[y * w + x] === 1) x++;
          if (x - s >= minRun) {
            let totalP = 0;
            for (const f of sampleFracs) totalP += perpH(y, s + Math.floor((x - s) * f));
            const avgP = totalP / sampleFracs.length;
            if (avgP >= minPerpThickness && avgP <= maxPerpThickness) {
              for (let xx = s; xx < x; xx++) keep[y * w + xx] = 1;
            }
          }
        }
      }
      // vertical runs
      for (let x = 0; x < w; x++) {
        let y = 0;
        while (y < h) {
          while (y < h && mask[y * w + x] === 0) y++;
          if (y >= h) break;
          const s = y;
          while (y < h && mask[y * w + x] === 1) y++;
          if (y - s >= minRun) {
            let totalP = 0;
            for (const f of sampleFracs) totalP += perpV(s + Math.floor((y - s) * f), x);
            const avgP = totalP / sampleFracs.length;
            if (avgP >= minPerpThickness && avgP <= maxPerpThickness) {
              for (let yy = s; yy < y; yy++) keep[yy * w + x] = 1;
            }
          }
        }
      }

      // ── 7. Remove small isolated components ──
      const visited = new Uint8Array(w * h);
      for (let y = 0; y < h; y++) {
        for (let x = 0; x < w; x++) {
          const start = y * w + x;
          if (keep[start] === 0 || visited[start] === 1) continue;
          const stack = [start];
          const component = [];
          visited[start] = 1;
          while (stack.length) {
            const p = stack.pop();
            component.push(p);
            const py = (p / w) | 0;
            const px = p - py * w;
            for (let ny = Math.max(0, py - 1); ny <= Math.min(h - 1, py + 1); ny++) {
              for (let nx = Math.max(0, px - 1); nx <= Math.min(w - 1, px + 1); nx++) {
                const np = ny * w + nx;
                if (keep[np] === 0 || visited[np] === 1) continue;
                visited[np] = 1;
                stack.push(np);
              }
            }
          }
          if (component.length < minComponentArea) {
            for (const p of component) keep[p] = 0;
          }
        }
      }

      // ── 7b. Final survival safety net ──
      let finalSurvivors = 0;
      for (let p = 0; p < w * h; p++) if (keep[p] === 1) finalSurvivors++;
      const finalSurvivalPct = totalInkPixels > 0 ? (finalSurvivors / totalInkPixels * 100) : 0;
      console.log('[keepThickLines] final survivors after full pipeline:', finalSurvivors,
        '(' + finalSurvivalPct.toFixed(1) + '% of ink)');

      if (finalSurvivors < totalInkPixels * 0.01 && totalInkPixels > 100) {
        // Full pipeline failed — fall back: keep ALL ink pixels darker than a stricter threshold
        console.warn('[keepThickLines] SAFETY FALLBACK — pipeline left < 1% ink, keeping all dark ink');
        const strictDark = Math.min(darkThreshold, 140);  // tighter threshold for safety fallback
        for (let p = 0; p < w * h; p++) {
          const i4 = p * 4;
          const lum = d[i4] * 0.299 + d[i4+1] * 0.587 + d[i4+2] * 0.114;
          keep[p] = (lum < strictDark && d[i4+3] > 0) ? 1 : 0;
        }
      }

      // ── 8. Apply to pixels ──
      for (let p = 0; p < w * h; p++) {
        const i = p * 4;
        if (keep[p] === 1) {
          d[i] = 0; d[i + 1] = 0; d[i + 2] = 0; d[i + 3] = 255;
        } else if (d[i + 3] > 0) {
          const lum = d[i] * 0.299 + d[i + 1] * 0.587 + d[i + 2] * 0.114;
          if (lum < 250) {
            d[i] = 255; d[i + 1] = 255; d[i + 2] = 255; d[i + 3] = 255;
            mods++;
          }
        }
      }
      return mods;
    }

    function applyKeepOnlyLines(d) {
      for (let i = 0; i < d.length; i += 4) {
        const lum = d[i] * 0.299 + d[i+1] * 0.587 + d[i+2] * 0.114;
        if (lum > 160) { d[i] = 255; d[i+1] = 255; d[i+2] = 255; }
        else { d[i] = 0; d[i+1] = 0; d[i+2] = 0; }
      }
    }

    function applyRemoveBackground(d) {
      for (let i = 0; i < d.length; i += 4) {
        const lum = d[i] * 0.299 + d[i+1] * 0.587 + d[i+2] * 0.114;
        if (lum > 210) { d[i] = 255; d[i+1] = 255; d[i+2] = 255; }
      }
    }

    function applyFinalizeWalls(d, w, h) {
      // Goal: crisp black/white walls, less speckle/dots, fewer jaggies.
      // Best results when run AFTER keepThickLines.
      // NOTE: Use a *lower* ink threshold to avoid turning light-gray texture into black.
      const inkThreshold = 185; // treat darker than this as ink
      const passesPrune = 5;
      const smoothPasses = 2;
      const neighborPruneMax = 2; // remove isolated pixels / tiny spurs
      const smoothKeepMin = 5;    // majority filter

      // Orthogonal rectification (mostly-rectangular plans):
      // Rebuild walls from *stable* horizontal/vertical bands.
      // (A diagonal blob has long runs too, but they shift each row; stability filtering removes it.)
      const orthoMinRun = Math.max(14, Math.round(Math.min(w, h) * 0.02));
      const orthoGapMax = 3;
      const orthoPosTol = 2;
      const orthoMinBand = 3;

      let mods = 0;
      let mask = new Uint8Array(w * h);

      for (let y = 0; y < h; y++) {
        for (let x = 0; x < w; x++) {
          const p = y * w + x;
          const i = p * 4;
          if (d[i + 3] < 30) { mask[p] = 0; continue; }
          const lum = d[i] * 0.299 + d[i + 1] * 0.587 + d[i + 2] * 0.114;
          mask[p] = lum < inkThreshold ? 1 : 0;
        }
      }

      // Prune tiny speckles/spurs
      for (let pass = 0; pass < passesPrune; pass++) {
        const next = new Uint8Array(mask);
        for (let y = 1; y < h - 1; y++) {
          const row = y * w;
          for (let x = 1; x < w - 1; x++) {
            const p = row + x;
            if (mask[p] === 0) continue;
            const n =
              mask[p - w - 1] + mask[p - w] + mask[p - w + 1] +
              mask[p - 1] + mask[p + 1] +
              mask[p + w - 1] + mask[p + w] + mask[p + w + 1];
            if (n <= neighborPruneMax) next[p] = 0;
          }
        }
        mask = next;
      }

      // Majority smoothing: reduces pepper noise and sharpens edges.
      for (let pass = 0; pass < smoothPasses; pass++) {
        const next = new Uint8Array(mask);
        for (let y = 1; y < h - 1; y++) {
          const row = y * w;
          for (let x = 1; x < w - 1; x++) {
            const p = row + x;
            const n =
              mask[p - w - 1] + mask[p - w] + mask[p - w + 1] +
              mask[p - 1] + mask[p + 1] +
              mask[p + w - 1] + mask[p + w] + mask[p + w + 1];
            next[p] = (n >= smoothKeepMin) ? 1 : 0;
          }
        }
        mask = next;
      }

      // Snap to axis-aligned, *stable* bands (horizontal + vertical) and bridge tiny gaps.
      // Works best after keepThickLines and the smoothing above.
      {
        const out = new Uint8Array(w * h);

        const getRowSegments = (y) => {
          const segs = [];
          const row = y * w;
          let x = 0;
          while (x < w) {
            while (x < w && mask[row + x] === 0) x++;
            if (x >= w) break;
            let start = x;
            let end = x;
            while (x < w) {
              while (x < w && mask[row + x] === 1) { end = x; x++; }
              let gap = 0;
              while (x < w && mask[row + x] === 0 && gap < orthoGapMax) { x++; gap++; }
              if (gap > 0 && x < w && mask[row + x] === 1) {
                // bridge and continue
                continue;
              }
              // stop at the end of the last 1-run
              break;
            }
            segs.push([start, end]);
          }
          return segs;
        };

        const getColSegments = (x) => {
          const segs = [];
          let y = 0;
          while (y < h) {
            while (y < h && mask[y * w + x] === 0) y++;
            if (y >= h) break;
            let start = y;
            let end = y;
            while (y < h) {
              while (y < h && mask[y * w + x] === 1) { end = y; y++; }
              let gap = 0;
              while (y < h && mask[y * w + x] === 0 && gap < orthoGapMax) { y++; gap++; }
              if (gap > 0 && y < h && mask[y * w + x] === 1) {
                continue;
              }
              break;
            }
            segs.push([start, end]);
          }
          return segs;
        };

        const finalizeHorizontal = (active, yEndExclusive) => {
          for (const a of active) {
            if (!a) continue;
            if (a.height >= orthoMinBand) {
              const s = Math.max(0, Math.min(w - 1, Math.round(a.sumS / a.height)));
              const e = Math.max(0, Math.min(w - 1, Math.round(a.sumE / a.height)));
              if ((e - s + 1) >= orthoMinRun) {
                for (let yy = a.y0; yy < yEndExclusive; yy++) {
                  const row = yy * w;
                  for (let x = s; x <= e; x++) out[row + x] = 1;
                }
              }
            }
          }
        };

        // Horizontal stable bands across rows
        let activeH = [];
        for (let y = 0; y < h; y++) {
          const segs = getRowSegments(y);
          const used = new Array(activeH.length).fill(false);
          const nextActive = [];

          for (const [s, e] of segs) {
            let bestIdx = -1;
            let bestScore = 1e9;
            for (let i = 0; i < activeH.length; i++) {
              if (used[i]) continue;
              const a = activeH[i];
              const ds = Math.abs(s - a.lastS);
              const de = Math.abs(e - a.lastE);
              if (ds <= orthoPosTol && de <= orthoPosTol) {
                const score = ds + de;
                if (score < bestScore) { bestScore = score; bestIdx = i; }
              }
            }

            if (bestIdx >= 0) {
              const a = activeH[bestIdx];
              used[bestIdx] = true;
              a.height++;
              a.sumS += s;
              a.sumE += e;
              a.lastS = s;
              a.lastE = e;
              nextActive.push(a);
            } else {
              nextActive.push({ y0: y, height: 1, sumS: s, sumE: e, lastS: s, lastE: e });
            }
          }

          // finalize bands that did not continue on this row
          const ended = [];
          for (let i = 0; i < activeH.length; i++) {
            if (!used[i]) ended.push(activeH[i]);
          }
          finalizeHorizontal(ended, y);

          activeH = nextActive;
        }
        finalizeHorizontal(activeH, h);

        const finalizeVertical = (active, xEndExclusive) => {
          for (const a of active) {
            if (!a) continue;
            if (a.width >= orthoMinBand) {
              const s = Math.max(0, Math.min(h - 1, Math.round(a.sumS / a.width)));
              const e = Math.max(0, Math.min(h - 1, Math.round(a.sumE / a.width)));
              if ((e - s + 1) >= orthoMinRun) {
                for (let xx = a.x0; xx < xEndExclusive; xx++) {
                  for (let y = s; y <= e; y++) out[y * w + xx] = 1;
                }
              }
            }
          }
        };

        // Vertical stable bands across columns
        let activeV = [];
        for (let x = 0; x < w; x++) {
          const segs = getColSegments(x);
          const used = new Array(activeV.length).fill(false);
          const nextActive = [];

          for (const [s, e] of segs) {
            let bestIdx = -1;
            let bestScore = 1e9;
            for (let i = 0; i < activeV.length; i++) {
              if (used[i]) continue;
              const a = activeV[i];
              const ds = Math.abs(s - a.lastS);
              const de = Math.abs(e - a.lastE);
              if (ds <= orthoPosTol && de <= orthoPosTol) {
                const score = ds + de;
                if (score < bestScore) { bestScore = score; bestIdx = i; }
              }
            }

            if (bestIdx >= 0) {
              const a = activeV[bestIdx];
              used[bestIdx] = true;
              a.width++;
              a.sumS += s;
              a.sumE += e;
              a.lastS = s;
              a.lastE = e;
              nextActive.push(a);
            } else {
              nextActive.push({ x0: x, width: 1, sumS: s, sumE: e, lastS: s, lastE: e });
            }
          }

          const ended = [];
          for (let i = 0; i < activeV.length; i++) {
            if (!used[i]) ended.push(activeV[i]);
          }
          finalizeVertical(ended, x);

          activeV = nextActive;
        }
        finalizeVertical(activeV, w);

        mask = out;
      }

      // Write crisp output
      for (let p = 0; p < mask.length; p++) {
        const i = p * 4;
        if (mask[p] === 1) {
          if (d[i] !== 0 || d[i + 1] !== 0 || d[i + 2] !== 0 || d[i + 3] !== 255) mods++;
          d[i] = 0; d[i + 1] = 0; d[i + 2] = 0; d[i + 3] = 255;
        } else {
          if (d[i] !== 255 || d[i + 1] !== 255 || d[i + 2] !== 255 || d[i + 3] !== 255) mods++;
          d[i] = 255; d[i + 1] = 255; d[i + 2] = 255; d[i + 3] = 255;
        }
      }

      return mods;
    }

    async function applyEdits() {
      if (!instrEl) return;
