    function applyZoom() {
      if (!canvasWrap || !editCanvas || !markCanvas) return;

      // IMPORTANT: avoid transform:scale() because it does not change scrollWidth/Height.
      // Scale via CSS size so scrollbars match what the user sees.
      const cssW = Math.max(1, Math.round(editCanvas.width * zoom));
      const cssH = Math.max(1, Math.round(editCanvas.height * zoom));
      canvasWrap.style.position = 'relative';
      if (canvasOverlay) {
        canvasOverlay.style.position = 'absolute';
        canvasOverlay.style.left = '0';
        canvasOverlay.style.top = '0';
        canvasOverlay.style.width = `${cssW}px`;
        canvasOverlay.style.height = `${cssH}px`;
      }
      editCanvas.style.width = `${cssW}px`;
      editCanvas.style.height = `${cssH}px`;
      // Explicitly size markCanvas — do NOT rely on 'absolute inset-0'
      // because canvas is a replaced element and may not stretch properly.
      markCanvas.style.width = `${cssW}px`;
      markCanvas.style.height = `${cssH}px`;
      markCanvas.style.position = 'absolute';
      markCanvas.style.left = '0';
      markCanvas.style.top = '0';
      if (protectCanvas) {
        protectCanvas.style.width = `${cssW}px`;
        protectCanvas.style.height = `${cssH}px`;
        protectCanvas.style.position = 'absolute';
        protectCanvas.style.left = '0';
        protectCanvas.style.top = '0';
      }
      canvasWrap.style.width = `${cssW}px`;
      canvasWrap.style.height = `${cssH}px`;

      // Center the canvas in the viewport when it's smaller than the viewport,
      // but allow full scrolling (no negative scroll) when it's larger.
      const stage = document.getElementById('pdfImageCanvasStage');
      if (stage && canvasViewport) {
        const vpW = canvasViewport.clientWidth;
        const vpH = canvasViewport.clientHeight;
        const padded = 16; // p-2 = 8px each side
        const contentW = cssW + padded;
        const contentH = cssH + padded;
        // Use padding to center when content is smaller than viewport
        const padLeft = contentW < vpW ? Math.floor((vpW - contentW) / 2) : 8;
        const padTop = contentH < vpH ? Math.floor((vpH - contentH) / 2) : 8;
        stage.style.paddingLeft = `${padLeft}px`;
        stage.style.paddingTop = `${padTop}px`;
        stage.style.paddingRight = '8px';
        stage.style.paddingBottom = '8px';
      }

      if (zoomLabel) zoomLabel.textContent = `${Math.round(zoom * 100)}%`;
    }

    function resetView100Centered() {
      pdfImageIsFitView = false;
      zoom = 1.0;
      applyZoom();
      ensurePdfImageViewportHeight();

      // No scrollbars at start when the image fits.
      try { if (canvasViewport) { canvasViewport.scrollTop = 0; canvasViewport.scrollLeft = 0; } } catch { }
    }

    function setZoomAtClientPoint(nextZoom, clientX, clientY) {
      if (!canvasViewport) {
        setZoom(nextZoom);
        return;
      }
      const vpRect = canvasViewport.getBoundingClientRect();
      const mx = clientX - vpRect.left;
      const my = clientY - vpRect.top;

      // World coords (unscaled) under the cursor before zoom.
      const worldX = (canvasViewport.scrollLeft + mx) / Math.max(0.0001, zoom);
      const worldY = (canvasViewport.scrollTop + my) / Math.max(0.0001, zoom);

      setZoom(nextZoom);

      // Restore scroll so the same world point stays under the cursor.
      canvasViewport.scrollLeft = Math.max(0, worldX * zoom - mx);
      canvasViewport.scrollTop = Math.max(0, worldY * zoom - my);
    }

    function fitZoomToViewport() {
      if (!canvasViewport || !editCanvas || !editCanvas.width || !editCanvas.height) return;

      // Account for the viewport padding (p-2) and keep a tiny margin.
      const pad = 24;
      const vw = Math.max(50, (canvasViewport.clientWidth || 0) - pad);
      const vh = Math.max(50, (canvasViewport.clientHeight || 0) - pad);
      const sx = vw / editCanvas.width;
      const sy = vh / editCanvas.height;
      const next = Math.max(0.05, Math.min(4.0, Math.min(sx, sy)));
      zoom = next;
      applyZoom();
      pdfImageIsFitView = true;

      // Keep view anchored top-left after fit.
      try { canvasViewport.scrollTop = 0; canvasViewport.scrollLeft = 0; } catch { }
    }

    // ── Mouse wheel zoom + drag-pan (viewport) ──
    if (canvasViewport) {
      canvasViewport.addEventListener('wheel', (ev) => {
        // Trackpad/mouse wheel zoom when cursor is over the editor.
        // Prevent the default page scroll.
        ev.preventDefault();

        // Natural feeling: wheel up => zoom in.
        // Use a small factor so trackpads don't jump too much.
        const delta = ev.deltaY;
        const factor = delta < 0 ? 1.10 : 0.90;
        const next = Math.max(0.25, Math.min(6.0, zoom * factor));
        setZoomAtClientPoint(next, ev.clientX, ev.clientY);
      }, { passive: false });

      let isPanning = false;
      let panStartX = 0;
      let panStartY = 0;
      let panScrollLeft = 0;
      let panScrollTop = 0;

      function canPanNow() {
        // When markCanvas is interactive, we are in a draw/select mode.
        // In that case, don't hijack mouse dragging.
        if (cropMode) return false;
        if (selectRegionMode) return false;
        if (markCanvas && markCanvas.style && markCanvas.style.pointerEvents === 'auto') return false;
        if (protectCanvas && protectCanvas.style && protectCanvas.style.pointerEvents === 'auto') return false;
        return true;
      }

      canvasViewport.addEventListener('mousedown', (ev) => {
        if (ev.button !== 0) return; // left button only
        if (!canPanNow()) return;
        isPanning = true;
        panStartX = ev.clientX;
        panStartY = ev.clientY;
        panScrollLeft = canvasViewport.scrollLeft;
        panScrollTop = canvasViewport.scrollTop;
        canvasViewport.style.cursor = 'grabbing';
        ev.preventDefault();
      });

      window.addEventListener('mousemove', (ev) => {
        if (!isPanning) return;
        const dx = ev.clientX - panStartX;
        const dy = ev.clientY - panStartY;
        canvasViewport.scrollLeft = Math.max(0, panScrollLeft - dx);
        canvasViewport.scrollTop = Math.max(0, panScrollTop - dy);
      });

      window.addEventListener('mouseup', () => {
        if (!isPanning) return;
        isPanning = false;
        canvasViewport.style.cursor = '';
      });
    }

    function setZoom(next) {
      pdfImageIsFitView = false;
      zoom = Math.max(0.25, Math.min(4.0, next));
      applyZoom();
    }

    let cropResizeHandle = null; // currently-dragged handle id (tl/tr/bl/br/tm/bm/ml/mr)

    function clearCropSelection() {
      cropSelection = null;
      cropStart = null;
      cropPreviewSnapshot = null;
      cropPreviewLastPt = null;
      cropPreviewRafPending = false;
      cropResizeHandle = null;
      // Clear the dimmed overlay
      if (markCanvas) {
        const vctx = markCanvas.getContext('2d', { willReadFrequently: true });
        vctx.clearRect(0, 0, markCanvas.width, markCanvas.height);
      }
    }

    async function drawDataUrlToCanvas(dataUrl) {
      if (!editCanvas || !markCanvas) return;
      const img = new Image();
      await new Promise((resolve) => {
        img.onload = resolve;
        img.onerror = resolve;
        img.src = dataUrl;
      });
      if (!img.naturalWidth || !img.naturalHeight) return;

      // Match canvas pixel size to image pixels (keeps edits precise)
      editCanvas.width = img.naturalWidth;
      editCanvas.height = img.naturalHeight;
      markCanvas.width = img.naturalWidth;
      markCanvas.height = img.naturalHeight;
      maskCanvas.width = img.naturalWidth;
      maskCanvas.height = img.naturalHeight;
      const protectNeedsResize = !!(
        (protectCanvas && (protectCanvas.width !== img.naturalWidth || protectCanvas.height !== img.naturalHeight)) ||
        (protectMaskCanvas.width !== img.naturalWidth || protectMaskCanvas.height !== img.naturalHeight)
      );
      if (protectNeedsResize) {
        if (protectCanvas) {
          protectCanvas.width = img.naturalWidth;
          protectCanvas.height = img.naturalHeight;
        }
        protectMaskCanvas.width = img.naturalWidth;
        protectMaskCanvas.height = img.naturalHeight;
        clearExclude();
      }

      const ctx = editCanvas.getContext('2d', { willReadFrequently: true });
      ctx.fillStyle = '#ffffff';
      ctx.fillRect(0, 0, editCanvas.width, editCanvas.height);
      ctx.drawImage(img, 0, 0);

      clearMarks();
      clearCropSelection();

      // Ensure the viewport height is correct before fitting.
      ensurePdfImageViewportHeight();

      // Initial view: FIT to viewport and fill the window.
      await new Promise(r => requestAnimationFrame(() => r()));
      ensurePdfImageViewportHeight();
      await new Promise(r => requestAnimationFrame(() => r()));
      fitZoomToViewport();
    }

    function clearMarks() {
      if (!markCanvas) return;
      const mctx = markCanvas.getContext('2d', { willReadFrequently: true });
      mctx.clearRect(0, 0, markCanvas.width, markCanvas.height);
      const xctx = maskCanvas.getContext('2d', { willReadFrequently: true });
      xctx.clearRect(0, 0, maskCanvas.width, maskCanvas.height);
      // Reset count/learning state when markers are cleared
      if (typeof _countState !== 'undefined') {
        _countState.matches = [];
        _countState.mainGray = null;
        _countState.mainDataUrl = null;
        _countState.templateDataUrl = null;
        _countState.sel = null;
      }
      if (window._lastCountResult) window._lastCountResult = null;
      // Restore pointer-events to none (no markers to click)
      markCanvas.style.pointerEvents = 'none';
      markCanvas.style.cursor = '';
    }

    function clearExclude() {
      try {
        if (protectCanvas) {
          const pctx = protectCanvas.getContext('2d', { willReadFrequently: true });
          pctx.clearRect(0, 0, protectCanvas.width, protectCanvas.height);
        }
      } catch { }
      try {
        const xctx = protectMaskCanvas.getContext('2d', { willReadFrequently: true });
        xctx.clearRect(0, 0, protectMaskCanvas.width, protectMaskCanvas.height);
      } catch { }
    }

    function pushUndoState(dataUrl) {
      if (!dataUrl) return;
      // Avoid pushing duplicates (e.g., clicking Apply with no actual change)
      if (undoStack.length > 0 && undoStack[undoStack.length - 1] === dataUrl) return;
      undoStack.push(dataUrl);
      if (undoStack.length > maxUndo) undoStack.shift();
      // New action invalidates redo history
      redoStack.length = 0;
      refreshUndoRedoButtons();
    }

    async function runControlNetClean() {
      if (!btnControlNetClean || !editCanvas) return;

      if (btnControlNetClean.dataset.busy === '1') return;
      btnControlNetClean.dataset.busy = '1';
      btnControlNetClean.disabled = true;

      const prevHtml = btnControlNetClean.innerHTML;
      btnControlNetClean.innerHTML = '<i class="fa-solid fa-circle-notch fa-spin text-[10px]"></i> Cleaning…';

      try {
        // Base state for undo
        const baseForUndo = currentDataUrl || editCanvas.toDataURL('image/png');
        pushUndoState(baseForUndo);

        setStatus('ControlNet: cleaning drawing…', 'info');

        // IMPORTANT: Canvas exports can have transparent background (alpha=0).
        // Flatten to white so the server/ComfyUI doesn't interpret transparency as black.
        const blob = await new Promise((resolve) => {
          try {
            const tmp = document.createElement('canvas');
            tmp.width = editCanvas.width;
            tmp.height = editCanvas.height;
            const tctx = tmp.getContext('2d', { willReadFrequently: true });
            tctx.fillStyle = '#ffffff';
            tctx.fillRect(0, 0, tmp.width, tmp.height);
            tctx.drawImage(editCanvas, 0, 0);
            tmp.toBlob(resolve, 'image/png');
          } catch {
            try { editCanvas.toBlob(resolve, 'image/png'); } catch { resolve(null); }
          }
        });
        if (!blob) throw new Error('Could not encode canvas to PNG');

        const fd = new FormData();
        fd.append('image', blob, 'pdf-image.png');

        let url = PDFIMG_CONTROLNET_CLEAN_ENDPOINT;
        try {
          const style = clipartStyleEl ? (clipartStyleEl.value || '') : '';
          if (style) {
            const u = new URL(url, window.location.origin);
            u.searchParams.set('style', style);
            url = u.toString();
          }
        } catch { }

        const resp = await fetch(url, {
          method: 'POST',
          body: fd
        });

        const reqId = resp.headers ? (resp.headers.get('X-ControlNet-RequestId') || resp.headers.get('x-controlnet-requestid') || '') : '';
        const dbgThreshold = resp.headers ? (resp.headers.get('X-ControlNet-Threshold') || '') : '';
        const dbgRadius = resp.headers ? (resp.headers.get('X-ControlNet-WallRadius') || '') : '';
        const dbgBox = resp.headers ? (resp.headers.get('X-ControlNet-ContentBox') || '') : '';
        const dbgPost = resp.headers ? (resp.headers.get('X-ControlNet-PostProcess') || '') : '';
        const dbgInkT = resp.headers ? (resp.headers.get('X-ControlNet-Ink-Target') || '') : '';
        const dbgInkC = resp.headers ? (resp.headers.get('X-ControlNet-Ink-Comfy') || '') : '';
        const dbgInkO = resp.headers ? (resp.headers.get('X-ControlNet-Ink-Original') || '') : '';
        if (reqId) {
          console.log('[ControlNet] requestId:', reqId, '| threshold:', dbgThreshold, '| wallRadius:', dbgRadius, '| contentBox:', dbgBox,
            '| post:', dbgPost, '| ink target/comfy/orig:', dbgInkT, dbgInkC, dbgInkO);
        }

        if (!resp.ok) {
          const txt = await resp.text();
          const baseMsg = (txt && String(txt).trim()) ? String(txt).trim() : ('HTTP ' + resp.status);
          throw new Error(reqId ? (baseMsg + `\nrequestId: ${reqId}`) : baseMsg);
        }

        const outBlob = await resp.blob();
        const objectUrl = URL.createObjectURL(outBlob);
        try {
          await drawDataUrlToCanvas(objectUrl);
        } finally {
          try { URL.revokeObjectURL(objectUrl); } catch { }
        }

        currentDataUrl = editCanvas.toDataURL('image/png');
        commitCurrentToPageList();
        refreshUndoRedoButtons();
        setStatus('ControlNet: done', 'success');
      } catch (e) {
        console.error('[PDF Image] ControlNet clean failed:', e);
        setStatus('ControlNet error: ' + (e && (e.message || e) ? (e.message || e) : 'Unknown'), 'error');
      } finally {
        btnControlNetClean.innerHTML = prevHtml;
        btnControlNetClean.disabled = false;
        btnControlNetClean.dataset.busy = '0';
      }
    }

    if (btnControlNetClean && !btnControlNetClean.dataset.bound) {
      btnControlNetClean.dataset.bound = '1';
      btnControlNetClean.addEventListener('click', (ev) => {
        ev.preventDefault();
        runControlNetClean();
      });
    }

    // Convenience: auto-run ControlNet clean when selecting the CAD black-clean preset.
    // Guard against programmatic changes (e.g., loading styles list) and when there is no image loaded yet.
    if (clipartStyleEl && !clipartStyleEl.dataset.autoCleanBound) {
      clipartStyleEl.dataset.autoCleanBound = '1';
      let lastAutoCleanAt = 0;
      clipartStyleEl.addEventListener('change', (ev) => {
        try {
          const v = (clipartStyleEl.value || '').trim();
          if (v !== 'cad_bw_clean') return;

          // Only run on real user action (not when options are replaced/restored).
          if (!ev || ev.isTrusted !== true) return;

          // Must have an image on canvas.
          if (!editCanvas || !editCanvas.width || !editCanvas.height) return;

          // Debounce to avoid double-trigger.
          const now = Date.now();
          if (now - lastAutoCleanAt < 1200) return;
          lastAutoCleanAt = now;

          runControlNetClean();
        } catch { }
      });
    }

    async function runThinLinesFromOriginal() {
      if (!btnThinFromOriginal || !editCanvas) return;
      if (btnThinFromOriginal.dataset.busy === '1') return;

      const maxThinPx = Math.max(1, Math.min(5, Number(thinWidthEl && thinWidthEl.value ? thinWidthEl.value : 3) || 3));

      // IMPORTANT: This action is meant to operate on a *selected area* only.
      // We reuse the existing Crop selection rectangle (without applying a crop).
      const roi = (cropSelection && cropSelection.w > 5 && cropSelection.h > 5)
        ? { x0: Math.floor(cropSelection.x0), y0: Math.floor(cropSelection.y0), w: Math.floor(cropSelection.w), h: Math.floor(cropSelection.h) }
        : null;
      if (!roi) {
        setStatus('Select an area first: click Crop, drag a rectangle, then click Thin Lines (Original).', 'warning');
        return;
      }

      btnThinFromOriginal.dataset.busy = '1';
      btnThinFromOriginal.disabled = true;
      const prevHtml = btnThinFromOriginal.innerHTML;
      btnThinFromOriginal.innerHTML = '<i class="fa-solid fa-circle-notch fa-spin text-[10px]"></i> Cleaning…';

      try {
        const baseForUndo = currentDataUrl || editCanvas.toDataURL('image/png');
        pushUndoState(baseForUndo);
        // NOTE: Run on the CURRENT edited canvas (cumulative), not on the original image.
        // Otherwise, each click would re-load the original and revert previous ROI cleanups.
        setStatus(`Removing thin lines in selected area (<=${maxThinPx}px)…`, 'info');

        const ctx = editCanvas.getContext('2d', { willReadFrequently: true });
        const imageData = ctx.getImageData(0, 0, editCanvas.width, editCanvas.height);

        let exclude = null;
        try {
          const exCtx = protectMaskCanvas.getContext('2d', { willReadFrequently: true });
          const exImg = exCtx.getImageData(roi.x0, roi.y0, roi.w, roi.h);
          const exd = exImg.data;
          let has = false;
          for (let i = 3; i < exd.length; i += 4) { if (exd[i] > 0) { has = true; break; } }
          if (has) exclude = { data: exd, w: roi.w, h: roi.h };
        } catch { }

        const mods = applyRemoveThinLinesByStrokeWidth(imageData.data, editCanvas.width, editCanvas.height, maxThinPx, roi, exclude);
        ctx.putImageData(imageData, 0, 0);

        currentDataUrl = editCanvas.toDataURL('image/png');
        commitCurrentToPageList();
        refreshUndoRedoButtons();
        setStatus(`Thin-line cleanup done (selected area, <=${maxThinPx}px, ${mods} pixels removed)`, 'success');
      } catch (e) {
        console.error('[PDF Image] Original thin-line cleanup failed:', e);
        setStatus('Original thin-line cleanup error: ' + (e && (e.message || e) ? (e.message || e) : 'Unknown'), 'error');
      } finally {
        btnThinFromOriginal.innerHTML = prevHtml;
        btnThinFromOriginal.disabled = false;
        btnThinFromOriginal.dataset.busy = '0';
      }
    }

    if (btnThinFromOriginal && !btnThinFromOriginal.dataset.bound) {
      btnThinFromOriginal.dataset.bound = '1';
      btnThinFromOriginal.addEventListener('click', (ev) => {
        ev.preventDefault();
        runThinLinesFromOriginal();
      });
    }

    // ── AI-assisted region detection helper ──────────────────────────────
    // Sends the canvas image to the server AI endpoint (Gemini → OpenAI fallback)
    // to get bounding boxes of text/hatching/arrows with high accuracy.
    // Returns array of { type, x, y, w, h } (pixel coords) or null on failure.
    async function aiDetectRegions(canvas, types, roi) {
      try {
        // Build image data URL from the canvas (or ROI crop for smaller payload)
        let dataUrl;
        if (roi && roi.w > 5 && roi.h > 5) {
          // Send only the ROI crop to save bandwidth & improve AI focus
          const tmpCanvas = document.createElement('canvas');
          tmpCanvas.width = roi.w;
          tmpCanvas.height = roi.h;
          const tmpCtx = tmpCanvas.getContext('2d');
          tmpCtx.drawImage(canvas, roi.x0, roi.y0, roi.w, roi.h, 0, 0, roi.w, roi.h);
          dataUrl = tmpCanvas.toDataURL('image/png');
        } else {
          dataUrl = canvas.toDataURL('image/png');
        }

        const resp = await fetch('/chatgateway/fire/pdfimg/ai-detect', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ image: dataUrl, types })
        });

        if (!resp.ok) {
          console.warn('[AI-Detect] Server returned', resp.status);
          return null;
        }

        const result = await resp.json();
        if (!result.regions || !Array.isArray(result.regions)) return null;

        // Convert normalized fractions to pixel coordinates (relative to canvas or ROI)
        const refW = (roi && roi.w > 5) ? roi.w : canvas.width;
        const refH = (roi && roi.h > 5) ? roi.h : canvas.height;
        const offX = (roi && roi.w > 5) ? roi.x0 : 0;
        const offY = (roi && roi.h > 5) ? roi.y0 : 0;

        const pixelRegions = result.regions.map(r => ({
          type: r.type,
          x0: Math.floor(offX + r.x * refW),
          y0: Math.floor(offY + r.y * refH),
          w: Math.ceil(r.w * refW),
          h: Math.ceil(r.h * refH)
        }));

        console.log(`[AI-Detect] Got ${pixelRegions.length} regions from ${result.provider}/${result.model}`);
        return { regions: pixelRegions, provider: result.provider, model: result.model };
      } catch (e) {
        console.warn('[AI-Detect] Failed:', e);
        return null;
      }
    }

    // Apply heuristic removal function within each AI-detected bounding box of given type.
    // Falls back to full ROI/image if AI detection returned nothing for this type.
    // aggressiveErase: if true, erase ALL ink pixels in AI regions (for text/arrows where
    // the AI has already confirmed the content type, so no heuristic filtering needed).
    function applyRemovalInAiRegions(d, w, h, aiRegions, targetType, removeFn, roi, exclude, aggressiveErase) {
      const typeRegions = aiRegions ? aiRegions.filter(r => r.type === targetType) : [];
      if (typeRegions.length === 0) {
        // No AI regions — fall back to heuristic on full ROI
        return removeFn(d, w, h, roi, exclude);
      }

      let totalRemoved = 0;
      const inkThreshold = 200;

      for (const region of typeRegions) {
        // Expand box slightly (10% padding) for safety — AI boxes can be tight
        const pad = Math.max(4, Math.round(Math.min(region.w, region.h) * 0.1));
        const rx0 = Math.max(0, region.x0 - pad);
        const ry0 = Math.max(0, region.y0 - pad);
        const rx1 = Math.min(w, region.x0 + region.w + pad);
        const ry1 = Math.min(h, region.y0 + region.h + pad);

        if (aggressiveErase) {
          // AI confirmed this is the target type — erase ALL ink pixels directly
          for (let y = ry0; y < ry1; y++) {
            for (let x = rx0; x < rx1; x++) {
              const i = (y * w + x) * 4;
              const a = d[i + 3];
              if (a < 50) continue;
              const lum = d[i] * 0.299 + d[i + 1] * 0.587 + d[i + 2] * 0.114;
              if (lum >= inkThreshold) continue; // not ink

              // Respect protect mask
              if (exclude && exclude.data) {
                // exclude is relative to the ROI, map global coords to exclude coords
                const ex = x - (roi ? roi.x0 : 0);
                const ey = y - (roi ? roi.y0 : 0);
                if (ex >= 0 && ex < exclude.w && ey >= 0 && ey < exclude.h) {
                  const ep = (ey * exclude.w + ex) * 4;
                  if (exclude.data[ep + 3] > 0) continue; // protected pixel
                }
              }

              d[i] = 255; d[i + 1] = 255; d[i + 2] = 255; d[i + 3] = 255;
              totalRemoved++;
            }
          }
        } else {
          // Use heuristic within the AI bounding box
          const subRect = { x0: rx0, y0: ry0, w: rx1 - rx0, h: ry1 - ry0 };
          const mods = removeFn(d, w, h, subRect, null);
          totalRemoved += mods;
        }
      }
      return totalRemoved;
    }

    // ── ControlNet Inpainting helper ──────────────────────────────────────
    // Builds a mask from AI-detected regions, sends image+mask to ControlNet
    // for inpainting, and returns the result as an ImageData-compatible image.
    // Returns the inpainted data URL or null on failure.
    async function controlNetInpaint(canvas, aiRegions, targetTypes, roi) {
      try {
        const cw = canvas.width, ch = canvas.height;

        // Build mask canvas: white = areas to inpaint, black = keep
        const maskCanvas = document.createElement('canvas');
        maskCanvas.width = cw;
        maskCanvas.height = ch;
        const maskCtx = maskCanvas.getContext('2d');
        maskCtx.fillStyle = '#000000';
        maskCtx.fillRect(0, 0, cw, ch);

        // Draw white rectangles for each detected region
        maskCtx.fillStyle = '#ffffff';
        const allTypes = Array.isArray(targetTypes) ? targetTypes : [targetTypes];
        const matchingRegions = aiRegions.filter(r => allTypes.includes(r.type));
        if (matchingRegions.length === 0) return null;

        for (const region of matchingRegions) {
          // Add padding around each region
          const pad = Math.max(6, Math.round(Math.min(region.w, region.h) * 0.15));
          const rx = Math.max(0, region.x0 - pad);
          const ry = Math.max(0, region.y0 - pad);
          const rw = Math.min(cw - rx, region.w + 2 * pad);
          const rh = Math.min(ch - ry, region.h + 2 * pad);
          maskCtx.fillRect(rx, ry, rw, rh);
        }

        const imageDataUrl = canvas.toDataURL('image/png');
        const maskDataUrl = maskCanvas.toDataURL('image/png');

        const resp = await fetch('/chatgateway/fire/pdfimg/controlnet/inpaint', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ image: imageDataUrl, mask: maskDataUrl })
        });

        if (!resp.ok) {
          const errText = await resp.text();
          console.warn('[ControlNet Inpaint] Server returned', resp.status, errText);
          return null;
        }

        // Response is a PNG blob
        const blob = await resp.blob();
        const resultUrl = await new Promise(resolve => {
          const reader = new FileReader();
          reader.onload = () => resolve(reader.result);
          reader.readAsDataURL(blob);
        });

        return resultUrl;
      } catch (e) {
        console.warn('[ControlNet Inpaint] Failed:', e);
        return null;
      }
    }

    // ── Remove Text (Hebrew / English) ──────────────────────────────────
    // Uses connected-component analysis on ink pixels to identify and erase
    // small components that look like text characters (letters/digits/punctuation).
    // Works on current edited canvas within the Crop selection (or full image).
    function removeTextFromImageData(d, w, h, rect, exclude) {
      // ROI bounds
      let rx0 = 0, ry0 = 0, rx1 = w, ry1 = h;
      if (rect && Number.isFinite(rect.x0) && Number.isFinite(rect.y0) && Number.isFinite(rect.w) && Number.isFinite(rect.h)) {
        rx0 = Math.max(0, Math.min(w, Math.floor(rect.x0)));
        ry0 = Math.max(0, Math.min(h, Math.floor(rect.y0)));
        rx1 = Math.max(rx0, Math.min(w, Math.floor(rect.x0 + rect.w)));
        ry1 = Math.max(ry0, Math.min(h, Math.floor(rect.y0 + rect.h)));
      }
      if (rx1 - rx0 < 2 || ry1 - ry0 < 2) return 0;

      const rw = rx1 - rx0;
      const rh = ry1 - ry0;

      // Safety: avoid extremely large allocations
      if (rw * rh > 40_000_000) {
        console.warn('[RemoveText] ROI too large:', rw, 'x', rh);
        return 0;
      }

      const inkThreshold = 200; // luminance below this = ink
      const N = rw * rh;
      const ink = new Uint8Array(N);
      const labels = new Int32Array(N); // 0 = background

      // Build ink mask
      for (let y = 0; y < rh; y++) {
        const gy = ry0 + y;
        for (let x = 0; x < rw; x++) {
          const gx = rx0 + x;
          const i = (gy * w + gx) * 4;
          const a = d[i + 3];
          if (a < 50) { ink[y * rw + x] = 0; continue; }
          const lum = d[i] * 0.299 + d[i + 1] * 0.587 + d[i + 2] * 0.114;
          ink[y * rw + x] = lum < inkThreshold ? 1 : 0;
        }
      }

      // Connected-component labeling (4-connected, union-find)
      const parent = new Int32Array(N);
      parent.fill(-1);

      function find(a) {
        while (parent[a] >= 0) { parent[a] = parent[parent[a]] >= 0 ? parent[parent[a]] : parent[a]; a = parent[a]; }
        return a;
      }
      function unite(a, b) {
        a = find(a); b = find(b);
        if (a === b) return;
        // Weighted union (parent stores -size)
        if (parent[a] > parent[b]) { const t = a; a = b; b = t; }
        parent[a] += parent[b];
        parent[b] = a;
      }

      let labelCount = 0;
      for (let y = 0; y < rh; y++) {
        for (let x = 0; x < rw; x++) {
          const p = y * rw + x;
          if (!ink[p]) continue;
          labels[p] = p; // self-label
          parent[p] = -1; // size = 1
          // Check left
          if (x > 0 && ink[p - 1]) unite(p, p - 1);
          // Check up
          if (y > 0 && ink[p - rw]) unite(p, p - rw);
        }
      }

      // Gather component stats: bounding box + pixel count
      const compStats = new Map(); // root -> { minX, minY, maxX, maxY, count }
      for (let y = 0; y < rh; y++) {
        for (let x = 0; x < rw; x++) {
          const p = y * rw + x;
          if (!ink[p]) continue;
          const root = find(p);
          let s = compStats.get(root);
          if (!s) {
            s = { minX: x, minY: y, maxX: x, maxY: y, count: 0 };
            compStats.set(root, s);
          }
          if (x < s.minX) s.minX = x;
          if (y < s.minY) s.minY = y;
          if (x > s.maxX) s.maxX = x;
          if (y > s.maxY) s.maxY = y;
          s.count++;
        }
      }

      // Heuristics to identify text-like components:
      // Text characters in architectural drawings are typically:
      // - Small: bounding-box area < certain threshold
      // - Not too elongated in one direction (unless it's a line/wall)
      // - Have moderate fill ratio (not solid blobs like symbols)
      //
      // Since the user manually selects the text area, we can be aggressive.
      // Structural lines in a small ROI are very elongated (aspect >> 10).
      // Text has moderate aspect ratio even for connected word groups.
      const roiMinDim = Math.min(rw, rh);
      const roiMaxDim = Math.max(rw, rh);

      // Allow characters up to 40% of the ROI height (user selected a text area)
      const maxCharH = Math.max(80, Math.round(roiMinDim * 0.40));
      const maxCharW = Math.max(80, Math.round(roiMinDim * 0.40));
      const maxCharArea = maxCharH * maxCharW;
      const minPixels = 3;
      const maxPixels = Math.max(2000, Math.round(maxCharArea * 0.8));

      // Structural lines (walls) have very high aspect ratio: > 12
      // Text characters/words have aspect ratio < 10 typically
      const maxAspect = 10;

      // Collect roots of text-like components
      const textRoots = new Set();
      for (const [root, s] of compStats) {
        const bw = s.maxX - s.minX + 1;
        const bh = s.maxY - s.minY + 1;
        const area = bw * bh;
        const aspect = bw > bh ? bw / bh : bh / bw;
        const fillRatio = s.count / area;

        // Skip tiny noise
        if (s.count < minPixels) continue;

        // Skip truly massive components (walls/large structures)
        // A component that spans nearly the entire ROI in both dimensions is likely structural
        if (bw > roiMaxDim * 0.85 && bh > roiMinDim * 0.85) continue;

        // Very high aspect ratio = structural line (wall), skip
        if (aspect > maxAspect && (bw > maxCharW || bh > maxCharH)) continue;

        // Very high pixel count AND high fill ratio = solid structural element
        if (s.count > maxPixels * 5 && fillRatio > 0.6) continue;

        // Classify as text if:
        // 1) Small enough to be a character
        const isSmallEnough = (bw <= maxCharW && bh <= maxCharH) || area <= maxCharArea;
        // 2) Not a long structural line
        const notLine = aspect < maxAspect;
        // 3) Has reasonable fill
        const okFill = fillRatio > 0.03 && fillRatio < 0.95;

        // Accept word groups: connected text in a horizontal/vertical band
        // Allow larger width for connected Hebrew text (right-to-left runs)
        const isWordGroup = (bh <= maxCharH * 1.5 || bw <= maxCharW * 1.5)
                            && s.count <= maxPixels * 6
                            && fillRatio > 0.03 && fillRatio < 0.75
                            && aspect < 25;

        // Accept medium components that aren't line-like
        const isMediumText = s.count <= maxPixels * 3 && aspect < maxAspect && okFill;

        if ((isSmallEnough && notLine && okFill) || isWordGroup || isMediumText) {
          textRoots.add(root);
        }
      }

      // Erase text-component pixels (set to white)
      let removed = 0;
      for (let y = 0; y < rh; y++) {
        const gy = ry0 + y;
        for (let x = 0; x < rw; x++) {
          const p = y * rw + x;
          if (!ink[p]) continue;
          const root = find(p);
          if (!textRoots.has(root)) continue;

          const gx = rx0 + x;

          // Respect exclude/protect mask
          if (exclude && exclude.data) {
            const ep = (y * exclude.w + x) * 4;
            if (exclude.data[ep + 3] > 0) continue; // protected pixel
          }

          const i = (gy * w + gx) * 4;
          d[i] = 255; d[i + 1] = 255; d[i + 2] = 255; d[i + 3] = 255;
          removed++;
        }
      }

      return removed;
    }

    async function runRemoveText() {
      if (!btnRemoveText || !editCanvas) return;
      if (btnRemoveText.dataset.busy === '1') return;

      // IMPORTANT: Like Thin Lines, this action requires a selected area.
      // The user marks the text area with Crop, then clicks Remove Text.
      const roi = (cropSelection && cropSelection.w > 5 && cropSelection.h > 5)
        ? { x0: Math.floor(cropSelection.x0), y0: Math.floor(cropSelection.y0), w: Math.floor(cropSelection.w), h: Math.floor(cropSelection.h) }
        : null;
      if (!roi) {
        setStatus('Select an area first: click Crop, drag a rectangle around the text, then click Remove Text.', 'warning');
        return;
      }

      btnRemoveText.dataset.busy = '1';
      btnRemoveText.disabled = true;
      const prevHtml = btnRemoveText.innerHTML;
      btnRemoveText.innerHTML = '<i class="fa-solid fa-circle-notch fa-spin text-[10px]"></i> Removing text…';

      try {
        const baseForUndo = currentDataUrl || editCanvas.toDataURL('image/png');
        pushUndoState(baseForUndo);

        setStatus('Analyzing text components in selected area…', 'info');

        const ctx = editCanvas.getContext('2d', { willReadFrequently: true });
        const W = editCanvas.width, H = editCanvas.height;

        // --- Step 1: Run CC analysis on a CLONE to identify text pixels ---
        const origImageData = ctx.getImageData(0, 0, W, H);
        const cloneData = new Uint8ClampedArray(origImageData.data);

        // Build protect mask for the ROI from the protect canvas
        let exclude = null;
        try {
          const exCtx = protectMaskCanvas.getContext('2d', { willReadFrequently: true });
          const exImg = exCtx.getImageData(roi.x0, roi.y0, roi.w, roi.h);
          const exd = exImg.data;
          let has = false;
          for (let i = 3; i < exd.length; i += 4) { if (exd[i] > 0) { has = true; break; } }
          if (has) exclude = { data: exd, w: roi.w, h: roi.h };
        } catch { }

        // CC-based text detection on the clone
        const mods = removeTextFromImageData(cloneData, W, H, roi, exclude);

        if (mods === 0) {
          ctx.putImageData(origImageData, 0, 0);
          cropSelection = null;
          clearMarks();
          setStatus('No text components found in selected area.', 'info');
          return;
        }

        // --- Step 2: Build erased-pixel mask and fill line gaps ---
        btnRemoveText.innerHTML = '<i class="fa-solid fa-circle-notch fa-spin text-[10px]"></i> Filling line gaps…';
        setStatus(`Removed ${mods} text pixels. Reconstructing lines behind text…`, 'info');

        const od = origImageData.data;
        // Build a boolean mask: true where text was erased
        const erased = new Uint8Array(W * H);
        for (let i = 0; i < W * H; i++) {
          const j = i * 4;
          if (od[j] !== cloneData[j] || od[j + 1] !== cloneData[j + 1] || od[j + 2] !== cloneData[j + 2]) {
            erased[i] = 1;
          }
        }

        // Also build an ink mask from the ORIGINAL image (before text removal)
        const INK_T = 180;
        const origInk = new Uint8Array(W * H);
        for (let i = 0; i < W * H; i++) {
          const j = i * 4;
          const lum = od[j] * 0.299 + od[j + 1] * 0.587 + od[j + 2] * 0.114;
          if (lum < INK_T) origInk[i] = 1;
        }

        // --- Line reconstruction through erased zone ---
        // Strategy: for each scanline (row and column), find structural ink
        // stubs on both sides of the erased zone and connect them.
        // This handles horizontal and vertical lines robustly regardless
        // of text width.  Also handles 45° diagonals.
        const cloneD = cloneData;
        let filled = 0;
        const ry0 = Math.max(0, roi.y0), ry1 = Math.min(H, roi.y0 + roi.h);
        const rx0 = Math.max(0, roi.x0), rx1 = Math.min(W, roi.x0 + roi.w);
        const STUB_LOOK = 15; // how far outside erased zone to search for structural ink
        const MAX_LINE_THICK = 8; // max line thickness (rows/cols) to reconstruct

        // Helper: check if a pixel is structural ink (original ink, not erased)
        const isStruct = (px, py) => {
          if (px < 0 || px >= W || py < 0 || py >= H) return false;
          const p = py * W + px;
          return origInk[p] && !erased[p];
        };

        // --- Horizontal lines (scan each row) ---
        // For each row, find if structural ink enters from the left and exits on
        // the right of the erased zone.
        const hLineRows = []; // bands of consecutive rows with horizontal line
        for (let y = ry0; y < ry1; y++) {
          // Find leftmost and rightmost erased pixel on this row
          let eL = -1, eR = -1;
          for (let x = rx0; x < rx1; x++) {
            if (erased[y * W + x]) { if (eL < 0) eL = x; eR = x; }
          }
          if (eL < 0) continue; // no erased pixels on this row

          // Look left of eL for structural ink
          let foundL = false;
          for (let x = eL - 1; x >= Math.max(0, eL - STUB_LOOK); x--) {
            if (isStruct(x, y)) { foundL = true; break; }
            // Allow crossing white, but stop at non-ink non-erased after some gap
          }

          // Look right of eR for structural ink
          let foundR = false;
          for (let x = eR + 1; x < Math.min(W, eR + STUB_LOOK + 1); x++) {
            if (isStruct(x, y)) { foundR = true; break; }
          }

          if (foundL && foundR) hLineRows.push(y);
        }

        // Group consecutive rows into bands; only fill thin bands (lines)
        {
          let i = 0;
          while (i < hLineRows.length) {
            let bandStart = i;
            while (i + 1 < hLineRows.length && hLineRows[i + 1] === hLineRows[i] + 1) i++;
            const bandH = i - bandStart + 1;
            if (bandH <= MAX_LINE_THICK) {
              // This is a thin horizontal band → reconstruct line
              for (let bi = bandStart; bi <= i; bi++) {
                const y = hLineRows[bi];
                for (let x = rx0; x < rx1; x++) {
                  const p = y * W + x;
                  if (erased[p]) {
                    cloneD[p * 4] = 0; cloneD[p * 4 + 1] = 0; cloneD[p * 4 + 2] = 0; cloneD[p * 4 + 3] = 255;
                    filled++;
                  }
                }
              }
            }
            i++;
          }
        }

        // --- Vertical lines (scan each column) ---
        const vLineCols = [];
        for (let x = rx0; x < rx1; x++) {
          let eT = -1, eB = -1;
          for (let y = ry0; y < ry1; y++) {
            if (erased[y * W + x]) { if (eT < 0) eT = y; eB = y; }
          }
          if (eT < 0) continue;

          let foundT = false;
          for (let y = eT - 1; y >= Math.max(0, eT - STUB_LOOK); y--) {
            if (isStruct(x, y)) { foundT = true; break; }
          }
          let foundB = false;
          for (let y = eB + 1; y < Math.min(H, eB + STUB_LOOK + 1); y++) {
            if (isStruct(x, y)) { foundB = true; break; }
          }

          if (foundT && foundB) vLineCols.push(x);
        }

        {
          let i = 0;
          while (i < vLineCols.length) {
            let bandStart = i;
            while (i + 1 < vLineCols.length && vLineCols[i + 1] === vLineCols[i] + 1) i++;
            const bandW = i - bandStart + 1;
            if (bandW <= MAX_LINE_THICK) {
              for (let bi = bandStart; bi <= i; bi++) {
                const x = vLineCols[bi];
                for (let y = ry0; y < ry1; y++) {
                  const p = y * W + x;
                  if (erased[p] && cloneD[p * 4] !== 0) { // not already filled by horizontal
                    cloneD[p * 4] = 0; cloneD[p * 4 + 1] = 0; cloneD[p * 4 + 2] = 0; cloneD[p * 4 + 3] = 255;
                    filled++;
                  }
                }
              }
            }
            i++;
          }
        }

        // --- Diagonal lines (45° and -45°) ---
        // Scan along diagonal paths through the ROI
        for (const diagDir of [1, -1]) { // 1 = top-left→bottom-right, -1 = bottom-left→top-right
          const diagHits = []; // [diagIndex, ...]
          // Enumerate diagonals that cross the ROI
          // Each diagonal is identified by: x - diagDir*y = constant (for dir=1)
          // or x + y = constant (for dir=-1)
          const diagSet = new Map(); // diagKey → array of {x,y}
          for (let y = ry0; y < ry1; y++) {
            for (let x = rx0; x < rx1; x++) {
              if (!erased[y * W + x]) continue;
              const key = diagDir === 1 ? (x - y) : (x + y);
              if (!diagSet.has(key)) diagSet.set(key, []);
              diagSet.get(key).push({ x, y });
            }
          }

          const hitKeys = [];
          for (const [key, pixels] of diagSet) {
            if (pixels.length < 2) continue;
            // Sort by x
            pixels.sort((a, b) => a.x - b.x);
            const first = pixels[0], last = pixels[pixels.length - 1];
            // Look before first
            let foundA = false;
            for (let s = 1; s <= STUB_LOOK; s++) {
              const nx = first.x - s, ny = first.y - diagDir * s;
              if (isStruct(nx, ny)) { foundA = true; break; }
            }
            // Look after last
            let foundB = false;
            for (let s = 1; s <= STUB_LOOK; s++) {
              const nx = last.x + s, ny = last.y + diagDir * s;
              if (isStruct(nx, ny)) { foundB = true; break; }
            }
            if (foundA && foundB) hitKeys.push(key);
          }

          // Group adjacent diagonals and filter by thickness
          hitKeys.sort((a, b) => a - b);
          let di = 0;
          while (di < hitKeys.length) {
            let bStart = di;
            while (di + 1 < hitKeys.length && hitKeys[di + 1] === hitKeys[di] + 1) di++;
            const bW = di - bStart + 1;
            if (bW <= MAX_LINE_THICK) {
              for (let bdi = bStart; bdi <= di; bdi++) {
                const pixels = diagSet.get(hitKeys[bdi]);
                if (!pixels) continue;
                for (const { x, y } of pixels) {
                  const p = y * W + x;
                  if (erased[p] && cloneD[p * 4] !== 0) {
                    cloneD[p * 4] = 0; cloneD[p * 4 + 1] = 0; cloneD[p * 4 + 2] = 0; cloneD[p * 4 + 3] = 255;
                    filled++;
                  }
                }
              }
            }
            di++;
          }
        }

        // Apply the result (text removed + gaps filled)
        const resultImgData = new ImageData(cloneData, W, H);
        ctx.putImageData(resultImgData, 0, 0);

        currentDataUrl = editCanvas.toDataURL('image/png');
        commitCurrentToPageList();
        refreshUndoRedoButtons();
        cropSelection = null;
        clearMarks();
        setStatus(`Text removal done: ${mods} text pixels removed, ${filled} line pixels reconstructed.`, 'success');
      } catch (e) {
        console.error('[PDF Image] Remove Text failed:', e);
        setStatus('Remove text error: ' + (e && (e.message || e) ? (e.message || e) : 'Unknown'), 'error');
      } finally {
        btnRemoveText.innerHTML = prevHtml;
        btnRemoveText.disabled = false;
        btnRemoveText.dataset.busy = '0';
      }
    }

    if (btnRemoveText && !btnRemoveText.dataset.bound) {
      btnRemoveText.dataset.bound = '1';
      btnRemoveText.addEventListener('click', (ev) => {
        ev.preventDefault();
        runRemoveText();
      });
    }

    // ── Remove Hatching (diagonal shading lines) ───────────────────────
    // Per-pixel directional filter: for each ink pixel, probe along 4 directions
    // (horizontal, vertical, diagonal-up /, diagonal-down \).
    // If the pixel lies on a thin diagonal stroke (many neighbours along a diagonal,
    // few perpendicular to it), classify as hatching and erase.
    function removeHatchingFromImageData(d, w, h, rect, exclude) {
      let rx0 = 0, ry0 = 0, rx1 = w, ry1 = h;
      if (rect && Number.isFinite(rect.x0) && Number.isFinite(rect.y0) && Number.isFinite(rect.w) && Number.isFinite(rect.h)) {
        rx0 = Math.max(0, Math.min(w, Math.floor(rect.x0)));
        ry0 = Math.max(0, Math.min(h, Math.floor(rect.y0)));
        rx1 = Math.max(rx0, Math.min(w, Math.floor(rect.x0 + rect.w)));
        ry1 = Math.max(ry0, Math.min(h, Math.floor(rect.y0 + rect.h)));
      }
      if (rx1 - rx0 < 4 || ry1 - ry0 < 4) return 0;

      const rw = rx1 - rx0;
      const rh = ry1 - ry0;
      if (rw * rh > 40_000_000) { console.warn('[RemoveHatching] ROI too large'); return 0; }

      const inkThreshold = 200;
      const probeLen = 8; // check ±8 pixels in each direction
      const minDiagRun = 5; // need at least this many diagonal neighbours
      const maxOrthogonalRun = 3; // perpendicular run must be thin

      // Build ink bitmap for fast lookup
      const ink = new Uint8Array(rw * rh);
      for (let y = 0; y < rh; y++) {
        const gy = ry0 + y;
        for (let x = 0; x < rw; x++) {
          const gx = rx0 + x;
          const i = (gy * w + gx) * 4;
          const a = d[i + 3];
          if (a < 50) continue;
          const lum = d[i] * 0.299 + d[i + 1] * 0.587 + d[i + 2] * 0.114;
          if (lum < inkThreshold) ink[y * rw + x] = 1;
        }
      }

      // Probe function: count consecutive ink pixels from (x,y) in direction (dx,dy)
      function probe(x, y, dx, dy) {
        let cnt = 0;
        for (let i = 1; i <= probeLen; i++) {
          const nx = x + dx * i, ny = y + dy * i;
          if (nx < 0 || nx >= rw || ny < 0 || ny >= rh) break;
          if (!ink[ny * rw + nx]) break;
          cnt++;
        }
        return cnt;
      }

      // Measure perpendicular thickness at a point for a given diagonal direction
      function perpThickness(x, y, diagDx, diagDy) {
        // perpendicular to (diagDx, diagDy) is (-diagDy, diagDx)
        const px = -diagDy, py = diagDx;
        let cnt = 1; // self
        for (let i = 1; i <= 4; i++) {
          const nx = x + px * i, ny = y + py * i;
          if (nx < 0 || nx >= rw || ny < 0 || ny >= rh) break;
          if (!ink[ny * rw + nx]) break;
          cnt++;
        }
        for (let i = 1; i <= 4; i++) {
          const nx = x - px * i, ny = y - py * i;
          if (nx < 0 || nx >= rw || ny < 0 || ny >= rh) break;
          if (!ink[ny * rw + nx]) break;
          cnt++;
        }
        return cnt;
      }

      // Mark hatching pixels
      const toRemove = new Uint8Array(rw * rh);
      for (let y = 0; y < rh; y++) {
        for (let x = 0; x < rw; x++) {
          if (!ink[y * rw + x]) continue;

          // Probe 4 directions: horizontal, vertical, diag-up /, diag-down \
          const hRun = 1 + probe(x, y, 1, 0) + probe(x, y, -1, 0);
          const vRun = 1 + probe(x, y, 0, 1) + probe(x, y, 0, -1);
          const d1Run = 1 + probe(x, y, 1, -1) + probe(x, y, -1, 1); // /
          const d2Run = 1 + probe(x, y, 1, 1) + probe(x, y, -1, -1); // \

          // Check if this pixel is part of a diagonal stroke
          let isDiag = false;
          if (d1Run >= minDiagRun && d1Run > hRun && d1Run > vRun) {
            const thick = perpThickness(x, y, 1, -1);
            if (thick <= maxOrthogonalRun) isDiag = true;
          }
          if (!isDiag && d2Run >= minDiagRun && d2Run > hRun && d2Run > vRun) {
            const thick = perpThickness(x, y, 1, 1);
            if (thick <= maxOrthogonalRun) isDiag = true;
          }

          if (isDiag) toRemove[y * rw + x] = 1;
        }
      }

      // Erase marked pixels
      let removed = 0;
      for (let y = 0; y < rh; y++) {
        const gy = ry0 + y;
        for (let x = 0; x < rw; x++) {
          if (!toRemove[y * rw + x]) continue;
          const gx = rx0 + x;
          if (exclude && exclude.data) {
            const ep = (y * exclude.w + x) * 4;
            if (exclude.data[ep + 3] > 0) continue;
          }
          const i = (gy * w + gx) * 4;
          d[i] = 255; d[i + 1] = 255; d[i + 2] = 255; d[i + 3] = 255;
          removed++;
        }
      }
      return removed;
    }

    async function runRemoveHatching() {
      if (!btnRemoveHatching || !editCanvas) return;
      if (btnRemoveHatching.dataset.busy === '1') return;

      // Require crop selection (like Remove Text / Thin Lines)
      const roi = (cropSelection && cropSelection.w > 5 && cropSelection.h > 5)
        ? { x0: Math.floor(cropSelection.x0), y0: Math.floor(cropSelection.y0), w: Math.floor(cropSelection.w), h: Math.floor(cropSelection.h) }
        : null;
      if (!roi) {
        setStatus('Select an area first: click Crop, drag a rectangle around the hatching, then click Remove Hatching.', 'warning');
        return;
      }

      btnRemoveHatching.dataset.busy = '1';
      btnRemoveHatching.disabled = true;
      const prevHtml = btnRemoveHatching.innerHTML;
      btnRemoveHatching.innerHTML = '<i class="fa-solid fa-circle-notch fa-spin text-[10px]"></i> Removing hatching…';

      try {
        const baseForUndo = currentDataUrl || editCanvas.toDataURL('image/png');
        pushUndoState(baseForUndo);

        setStatus('Removing diagonal hatching in selected area…', 'info');

        const ctx = editCanvas.getContext('2d', { willReadFrequently: true });
        const imageData = ctx.getImageData(0, 0, editCanvas.width, editCanvas.height);

        // Build protect mask
        let exclude = null;
        try {
          const exCtx = protectMaskCanvas.getContext('2d', { willReadFrequently: true });
          const exImg = exCtx.getImageData(roi.x0, roi.y0, roi.w, roi.h);
          const exd = exImg.data;
          let has = false;
          for (let i = 3; i < exd.length; i += 4) { if (exd[i] > 0) { has = true; break; } }
          if (has) exclude = { data: exd, w: roi.w, h: roi.h };
        } catch { }

        const mods = removeHatchingFromImageData(imageData.data, editCanvas.width, editCanvas.height, roi, exclude);
        ctx.putImageData(imageData, 0, 0);

        currentDataUrl = editCanvas.toDataURL('image/png');
        commitCurrentToPageList();
        refreshUndoRedoButtons();
        cropSelection = null;
        clearMarks();
        setStatus(`Hatching removal done: ${mods} pixels removed in selected area.`, 'success');
      } catch (e) {
        console.error('[PDF Image] Remove Hatching failed:', e);
        setStatus('Remove hatching error: ' + (e && (e.message || e) ? (e.message || e) : 'Unknown'), 'error');
      } finally {
        btnRemoveHatching.innerHTML = prevHtml;
        btnRemoveHatching.disabled = false;
        btnRemoveHatching.dataset.busy = '0';
      }
    }

    if (btnRemoveHatching && !btnRemoveHatching.dataset.bound) {
      btnRemoveHatching.dataset.bound = '1';
      btnRemoveHatching.addEventListener('click', (ev) => {
        ev.preventDefault();
        runRemoveHatching();
      });
    }

    // ── Remove Arrows / Leader Lines ────────────────────────────────────
    // Uses connected-component analysis to find thin elongated components
    // that are NOT aligned with wall directions (0°/90°).
    // Arrow/leader lines: thin, moderate length, often angled.
    function removeArrowsFromImageData(d, w, h, rect, exclude) {
      let rx0 = 0, ry0 = 0, rx1 = w, ry1 = h;
      if (rect && Number.isFinite(rect.x0) && Number.isFinite(rect.y0) && Number.isFinite(rect.w) && Number.isFinite(rect.h)) {
        rx0 = Math.max(0, Math.min(w, Math.floor(rect.x0)));
        ry0 = Math.max(0, Math.min(h, Math.floor(rect.y0)));
        rx1 = Math.max(rx0, Math.min(w, Math.floor(rect.x0 + rect.w)));
        ry1 = Math.max(ry0, Math.min(h, Math.floor(rect.y0 + rect.h)));
      }
      if (rx1 - rx0 < 4 || ry1 - ry0 < 4) return 0;

      const rw = rx1 - rx0;
      const rh = ry1 - ry0;
      if (rw * rh > 40_000_000) { console.warn('[RemoveArrows] ROI too large'); return 0; }

      const inkThreshold = 200;
      const N = rw * rh;
      const ink = new Uint8Array(N);
      const parent = new Int32Array(N);
      parent.fill(-1);

      function find(a) {
        while (parent[a] >= 0) { parent[a] = parent[parent[a]] >= 0 ? parent[parent[a]] : parent[a]; a = parent[a]; }
        return a;
      }
      function unite(a, b) {
        a = find(a); b = find(b);
        if (a === b) return;
        if (parent[a] > parent[b]) { const t = a; a = b; b = t; }
        parent[a] += parent[b];
        parent[b] = a;
      }

      for (let y = 0; y < rh; y++) {
        const gy = ry0 + y;
        for (let x = 0; x < rw; x++) {
          const gx = rx0 + x;
          const p = y * rw + x;
          const i = (gy * w + gx) * 4;
          const a = d[i + 3];
          if (a < 50) continue;
          const lum = d[i] * 0.299 + d[i + 1] * 0.587 + d[i + 2] * 0.114;
          if (lum >= inkThreshold) continue;
          ink[p] = 1;
          parent[p] = -1;
          if (x > 0 && ink[p - 1]) unite(p, p - 1);
          if (y > 0 && ink[p - rw]) unite(p, p - rw);
        }
      }

      // Gather component stats with covariance for orientation
      const compStats = new Map();
      for (let y = 0; y < rh; y++) {
        for (let x = 0; x < rw; x++) {
          const p = y * rw + x;
          if (!ink[p]) continue;
          const root = find(p);
          let s = compStats.get(root);
          if (!s) {
            s = { minX: x, minY: y, maxX: x, maxY: y, count: 0, sumX: 0, sumY: 0, sumXX: 0, sumYY: 0, sumXY: 0 };
            compStats.set(root, s);
          }
          if (x < s.minX) s.minX = x;
          if (y < s.minY) s.minY = y;
          if (x > s.maxX) s.maxX = x;
          if (y > s.maxY) s.maxY = y;
          s.count++;
          s.sumX += x; s.sumY += y;
          s.sumXX += x * x; s.sumYY += y * y; s.sumXY += x * y;
        }
      }

      const roiMinDim = Math.min(rw, rh);
      // Arrow/leader line characteristics:
      // - Thin: perpendicular width typically 1-4px
      // - Moderate length: longer than text but shorter than walls
      // - Often angled (not purely horizontal/vertical)
      const maxArrowThickness = Math.max(6, Math.round(roiMinDim * 0.008));
      const minArrowLength = Math.max(15, Math.round(roiMinDim * 0.02));
      const maxArrowLength = Math.round(roiMinDim * 0.5);

      const arrowRoots = new Set();
      for (const [root, s] of compStats) {
        const bw = s.maxX - s.minX + 1;
        const bh = s.maxY - s.minY + 1;
        const aspect = bw > bh ? bw / bh : bh / bw;
        const diagLen = Math.sqrt(bw * bw + bh * bh);
        const fillRatio = s.count / (bw * bh);

        // Skip tiny noise
        if (s.count < 8) continue;
        // Skip very large components (walls, building outline)
        if (diagLen > maxArrowLength) continue;
        // Must be at least moderately long
        if (diagLen < minArrowLength) continue;

        // Compute orientation via PCA
        const mx = s.sumX / s.count;
        const my = s.sumY / s.count;
        const cxx = s.sumXX / s.count - mx * mx;
        const cyy = s.sumYY / s.count - my * my;
        const cxy = s.sumXY / s.count - mx * my;
        const angle = 0.5 * Math.atan2(2 * cxy, cxx - cyy); // radians
        const angleDeg = Math.abs(angle) * 180 / Math.PI;

        // Compute perpendicular width estimate:
        // eigenvalues: half-trace ± sqrt(quarter-trace² + cxy²)
        const halfTr = (cxx + cyy) / 2;
        const det = cxx * cyy - cxy * cxy;
        const disc = Math.max(0, halfTr * halfTr - det);
        const sqrtDisc = Math.sqrt(disc);
        const lam1 = halfTr + sqrtDisc; // larger eigenvalue (along principal axis)
        const lam2 = Math.max(0, halfTr - sqrtDisc); // smaller eigenvalue (perpendicular)
        const perpWidth = 2 * Math.sqrt(lam2) * 2; // approximate full-width

        // Arrow criteria:
        // 1) Thin (perpendicular width small)
        const isThin = perpWidth <= maxArrowThickness || (aspect >= 3 && fillRatio < 0.35);
        // 2) Elongated
        const isElongated = aspect >= 2.5;
        // 3) Not purely horizontal/vertical wall — angle between 10° and 80° from horizontal
        //    (or the component is very thin + elongated even if h/v — still an arrow)
        const isAngled = (angleDeg > 10 && angleDeg < 80);
        const isVeryThinLine = perpWidth <= 4 && aspect >= 5;

        // Include arrowheads: small triangular blobs near the end of a thin line
        // These are small components with moderate fill that aren't text
        const isArrowHead = s.count < 200 && diagLen < minArrowLength * 2
          && fillRatio > 0.2 && fillRatio < 0.7 && aspect < 3;

        if ((isThin && isElongated && (isAngled || isVeryThinLine)) || isArrowHead) {
          arrowRoots.add(root);
        }
      }

      let removed = 0;
      for (let y = 0; y < rh; y++) {
        const gy = ry0 + y;
        for (let x = 0; x < rw; x++) {
          const p = y * rw + x;
          if (!ink[p]) continue;
          const root = find(p);
          if (!arrowRoots.has(root)) continue;
          const gx = rx0 + x;
          if (exclude && exclude.data) {
            const ep = (y * exclude.w + x) * 4;
            if (exclude.data[ep + 3] > 0) continue;
          }
          const i = (gy * w + gx) * 4;
          d[i] = 255; d[i + 1] = 255; d[i + 2] = 255; d[i + 3] = 255;
          removed++;
        }
      }
      return removed;
    }

    async function runRemoveArrows() {
      if (!btnRemoveArrows || !editCanvas) return;
      if (btnRemoveArrows.dataset.busy === '1') return;

      // Require crop selection (like Remove Text / Thin Lines)
      const roi = (cropSelection && cropSelection.w > 5 && cropSelection.h > 5)
        ? { x0: Math.floor(cropSelection.x0), y0: Math.floor(cropSelection.y0), w: Math.floor(cropSelection.w), h: Math.floor(cropSelection.h) }
        : null;
      if (!roi) {
        setStatus('Select an area first: click Crop, drag a rectangle around the arrows, then click Remove Arrows.', 'warning');
        return;
      }

      btnRemoveArrows.dataset.busy = '1';
      btnRemoveArrows.disabled = true;
