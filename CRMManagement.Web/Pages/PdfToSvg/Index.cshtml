    const selected = svg.querySelectorAll('.fp-selected');
    if (selected.length === 0) { cgAlert('No items selected. Click on walls, doors or equipment to select them first.'); return; }
    if (!await cgConfirm(`Delete ${selected.length} selected object(s)?`)) return;

    // If this SVG isn't backed by analysis data (e.g. traced from raster), just delete from DOM.
    if (!lastAnalysis) {
      selected.forEach(el => el.remove());
      fpUpdateSelectionInfo();
      return;
    }

    const fpPageIdx = parseInt(svg.getAttribute('data-fp-page-idx'));
    const fpPage = (lastAnalysis.floorPlan && fpPageIdx >= 0 && fpPageIdx < lastAnalysis.floorPlan.length)
      ? lastAnalysis.floorPlan[fpPageIdx] : null;

    const itemIdxs = [], wallIdxs = [], doorIdxs = [];
    selected.forEach(g => {
      if (g.hasAttribute('data-fp-item-idx')) itemIdxs.push(parseInt(g.getAttribute('data-fp-item-idx')));
      if (g.hasAttribute('data-fp-wall-idx')) wallIdxs.push(parseInt(g.getAttribute('data-fp-wall-idx')));
      if (g.hasAttribute('data-fp-door-idx')) doorIdxs.push(parseInt(g.getAttribute('data-fp-door-idx')));
    });

    if (lastAnalysis.items) {
      itemIdxs.sort((a,b) => b - a).forEach(i => {
        if (i >= 0 && i < lastAnalysis.items.length) lastAnalysis.items.splice(i, 1);
      });
    }
    if (fpPage) {
      wallIdxs.sort((a,b) => b - a).forEach(i => {
        if (i >= 0 && i < fpPage.walls.length) fpPage.walls.splice(i, 1);
      });
      doorIdxs.sort((a,b) => b - a).forEach(i => {
        if (i >= 0 && i < fpPage.doors.length) fpPage.doors.splice(i, 1);
      });
    }

    selected.forEach(g => g.remove());
    fpUpdateSelectionInfo();
  };

  window.fpGroupSelected = function(svgId) {
    const svg = document.getElementById(svgId);
    if (!svg) return;

    const selected = Array.from(svg.querySelectorAll('.fp-selected'));
    if (!selected.length) {
      cgAlert('No items selected. Select lines/walls first, then click Group Selected.');
      return;
    }

    const segs = [];
    const strokeWidths = [];

    function parseNum(v) {
      const n = parseFloat(v);
      return Number.isFinite(n) ? n : null;
    }

    function addSegment(x1, y1, x2, y2, sw) {
      if (![x1, y1, x2, y2].every(Number.isFinite)) return;
      const dx = x2 - x1, dy = y2 - y1;
      if ((dx * dx + dy * dy) < 1e-4) return;
      segs.push({ x1, y1, x2, y2 });
      if (Number.isFinite(sw) && sw > 0) strokeWidths.push(sw);
    }

    function isHiddenLine(line) {
      try {
        const op = parseNum(line.getAttribute('stroke-opacity'));
        const stroke = (line.getAttribute('stroke') || '').trim().toLowerCase();
        if (line.getAttribute('data-pdf-hit') === '1') return true;
        if (stroke === 'transparent' || stroke === 'none') return true;
        if (op !== null && op < 0.02) return true;
      } catch { }
      return false;
    }

    function collectFromLine(line, allowHidden = false) {
      if (!line) return;
      if (!allowHidden && isHiddenLine(line)) return;
      const x1 = parseNum(line.getAttribute('x1'));
      const y1 = parseNum(line.getAttribute('y1'));
      const x2 = parseNum(line.getAttribute('x2'));
      const y2 = parseNum(line.getAttribute('y2'));
      const sw = parseNum(line.getAttribute('stroke-width'));
      addSegment(x1, y1, x2, y2, sw);
    }

    function collectFromPoints(pointsAttr, closeShape = false, sw = null) {
      if (!pointsAttr) return;
      const pts = String(pointsAttr).trim().split(/\s+/)
        .map(p => p.split(',').map(Number))
        .filter(p => p.length >= 2 && Number.isFinite(p[0]) && Number.isFinite(p[1]));
      if (pts.length < 2) return;
      for (let i = 0; i < pts.length - 1; i++) {
        addSegment(pts[i][0], pts[i][1], pts[i + 1][0], pts[i + 1][1], sw);
      }
      if (closeShape) {
        addSegment(pts[pts.length - 1][0], pts[pts.length - 1][1], pts[0][0], pts[0][1], sw);
      }
    }

    for (const el of selected) {
      const tag = String(el.tagName || '').toLowerCase();

      if (tag === 'line') {
        collectFromLine(el, false);
        continue;
      }

      if (tag === 'polyline' || tag === 'polygon') {
        const sw = parseNum(el.getAttribute('stroke-width'));
        collectFromPoints(el.getAttribute('points'), tag === 'polygon', sw);
        continue;
      }

      if (tag === 'rect') {
        const x = parseNum(el.getAttribute('x')) ?? 0;
        const y = parseNum(el.getAttribute('y')) ?? 0;
        const w = parseNum(el.getAttribute('width')) ?? 0;
        const h = parseNum(el.getAttribute('height')) ?? 0;
        const sw = parseNum(el.getAttribute('stroke-width'));
        if (w > 0 && h > 0) {
          addSegment(x, y, x + w, y, sw);
          addSegment(x + w, y, x + w, y + h, sw);
          addSegment(x + w, y + h, x, y + h, sw);
          addSegment(x, y + h, x, y, sw);
        }
        continue;
      }

      const lines = Array.from(el.querySelectorAll('line'));
      let addedBefore = segs.length;
      for (const ln of lines) collectFromLine(ln, false);

      // Fallback: for marked-wall groups that only have hidden hit-lines.
      if (addedBefore === segs.length && el.hasAttribute && el.hasAttribute('data-fp-wall-idx') && lines.length) {
        collectFromLine(lines[0], true);
      }

      // Also support grouped polyline/polygon descendants.
      const polys = Array.from(el.querySelectorAll('polyline,polygon'));
      for (const p of polys) {
        const sw = parseNum(p.getAttribute('stroke-width'));
        collectFromPoints(p.getAttribute('points'), String(p.tagName || '').toLowerCase() === 'polygon', sw);
      }
    }

    if (!segs.length) {
      cgAlert('Could not extract line segments from selected items. Select walls/line objects and try again.');
      return;
    }

    const defaultStroke = 2.5;
    let strokeW = defaultStroke;
    if (strokeWidths.length) {
      strokeWidths.sort((a, b) => a - b);
      strokeW = strokeWidths[Math.floor(strokeWidths.length / 2)] || defaultStroke;
    }
    strokeW = Math.max(1.5, Math.min(8, strokeW));

    const SNAP = 8;
    const pts = [];
    segs.forEach((s, i) => {
      pts.push({ si: i, end: 1, x: s.x1, y: s.y1 });
      pts.push({ si: i, end: 2, x: s.x2, y: s.y2 });
    });

    const visited = new Set();
    for (let i = 0; i < pts.length; i++) {
      if (visited.has(i)) continue;
      const cluster = [i];
      visited.add(i);
      let changed = true;
      while (changed) {
        changed = false;
        for (let j = 0; j < pts.length; j++) {
          if (visited.has(j)) continue;
          for (const ci of cluster) {
            const dx = pts[ci].x - pts[j].x;
            const dy = pts[ci].y - pts[j].y;
            if (Math.sqrt(dx * dx + dy * dy) <= SNAP) {
              cluster.push(j);
              visited.add(j);
              changed = true;
              break;
            }
          }
        }
      }
      if (cluster.length < 2) continue;
      let sx = 0, sy = 0;
      for (const ci of cluster) { sx += pts[ci].x; sy += pts[ci].y; }
      const ax = sx / cluster.length;
      const ay = sy / cluster.length;
      for (const ci of cluster) {
        const s = segs[pts[ci].si];
        if (pts[ci].end === 1) { s.x1 = ax; s.y1 = ay; }
        else { s.x2 = ax; s.y2 = ay; }
      }
    }

    const ptKey = (x, y) => `${x.toFixed(1)},${y.toFixed(1)}`;
    const adj = new Map();
    for (let i = 0; i < segs.length; i++) {
      const s = segs[i];
      const k1 = ptKey(s.x1, s.y1);
      const k2 = ptKey(s.x2, s.y2);
      if (!adj.has(k1)) adj.set(k1, []);
      if (!adj.has(k2)) adj.set(k2, []);
      adj.get(k1).push({ si: i, other: k2 });
      adj.get(k2).push({ si: i, other: k1 });
    }

    const used = new Set();
    const chains = [];
    function trace(startKey) {
      const chain = [];
      const [sx, sy] = startKey.split(',').map(Number);
      chain.push({ x: sx, y: sy });
      let cur = startKey;
      let found = true;
      while (found) {
        found = false;
        const edges = adj.get(cur) || [];
        for (const e of edges) {
          if (used.has(e.si)) continue;
          used.add(e.si);
          const [nx, ny] = e.other.split(',').map(Number);
          chain.push({ x: nx, y: ny });
          cur = e.other;
          found = true;
          break;
        }
      }
      return chain;
    }

    const oddKeys = [];
    adj.forEach((edges, key) => { if ((edges.length % 2) !== 0) oddKeys.push(key); });
    const starts = oddKeys.length ? oddKeys : Array.from(adj.keys());
    for (const sk of starts) {
      if (used.size === segs.length) break;
      const edges = adj.get(sk) || [];
      if (edges.every(e => used.has(e.si))) continue;
      chains.push(trace(sk));
    }
    for (let i = 0; i < segs.length; i++) {
      if (used.has(i)) continue;
      used.add(i);
      chains.push([
        { x: segs[i].x1, y: segs[i].y1 },
        { x: segs[i].x2, y: segs[i].y2 }
      ]);
    }

    const grouped = document.createElementNS('http://www.w3.org/2000/svg', 'g');
    grouped.setAttribute('data-fp-selectable', '1');
    grouped.setAttribute('data-fp-grouped', '1');

    for (const chain of chains) {
      if (!chain || chain.length < 2) continue;
      const pointsStr = chain.map(p => `${p.x.toFixed(1)},${p.y.toFixed(1)}`).join(' ');
      const first = chain[0], last = chain[chain.length - 1];
      const closeDist = Math.sqrt((first.x - last.x) ** 2 + (first.y - last.y) ** 2);
      const isClosed = closeDist < SNAP;

      const node = document.createElementNS('http://www.w3.org/2000/svg', isClosed ? 'polygon' : 'polyline');
      node.setAttribute('points', pointsStr);
      node.setAttribute('fill', 'none');
      node.setAttribute('stroke', '#1e293b');
      node.setAttribute('stroke-width', strokeW.toFixed(1));
      node.setAttribute('stroke-linejoin', 'round');
      node.setAttribute('stroke-linecap', 'round');
      node.setAttribute('pointer-events', 'stroke');
      grouped.appendChild(node);
    }

    if (!grouped.childNodes.length) {
      cgAlert('Grouping failed: no valid output chains were built.');
      return;
    }

    const parent = selected[0].parentNode || svg;
    selected.forEach(el => {
      try { el.remove(); } catch { }
    });
    parent.appendChild(grouped);

    try { fpAttachSvgHandlers(); } catch { }
    try { _fpMarkSelected(grouped, true); } catch { }

    setStatus(`Grouped ${selected.length} selected element(s) into ${grouped.childNodes.length} clean shape(s).`, 'success');
  };

  // ── Mark Walls mode: click wall to cycle small●(thin) → big●(thick) → remove ──
  const _fpMarkWallsMode = {}; // svgId -> true/false
  const _fpWallMarks = {};     // svgId -> Map<wallIdx, 'thin'|'thick'>
  const _fpMarkHistory = {};   // svgId -> [{wallIdx, prevType}] undo stack
  const _fpGlobalWallMarks = {}; // pageNo -> Map<wallIdx, 'thin'|'thick'> (shared between PDF Preview + Floor Plan)
  const _fpGlobalHistory = [];   // [{pageNo, wallIdx, prevType}] cross-view undo stack

  function _fpGetPageNumberFromSvg(svg) {
    if (!svg) return null;
    const pn = svg.getAttribute('data-fp-page-number');
    if (pn !== null && pn !== undefined && pn !== '') {
      const v = parseInt(pn);
      return Number.isFinite(v) ? v : null;
    }
    // Fallback: floor plan uses data-fp-page-idx, map back to lastAnalysis.floorPlan[].page
    const pidxRaw = svg.getAttribute('data-fp-page-idx');
    if (pidxRaw && lastAnalysis && Array.isArray(lastAnalysis.floorPlan)) {
      const pidx = parseInt(pidxRaw);
      if (Number.isFinite(pidx) && pidx >= 0 && pidx < lastAnalysis.floorPlan.length) {
        const fp = lastAnalysis.floorPlan[pidx];
        if (fp && fp.page !== undefined && fp.page !== null) {
          const v = parseInt(fp.page);
          return Number.isFinite(v) ? v : null;
        }
      }
    }
    return null;
  }

  function _fpEnsureGlobalPageMap(pageNo) {
    if (!_fpGlobalWallMarks[pageNo]) _fpGlobalWallMarks[pageNo] = new Map();
    return _fpGlobalWallMarks[pageNo];
  }

  function _fpSetGlobalMark(pageNo, wallIdx, typeOrNull) {
    if (pageNo === null || pageNo === undefined) return;
    const m = _fpEnsureGlobalPageMap(pageNo);
    if (!typeOrNull) m.delete(wallIdx);
    else m.set(wallIdx, typeOrNull);
  }

  function _fpApplyGlobalMarksToSvg(svg) {
    const pageNo = _fpGetPageNumberFromSvg(svg);
    if (pageNo === null || pageNo === undefined) return;
    const global = _fpGlobalWallMarks[pageNo];
    if (!global || global.size === 0) return;
    global.forEach((type, wallIdx) => {
      const g = svg.querySelector(`g[data-fp-wall-idx="${wallIdx}"]`);
      if (g) _fpAddWallMark(svg, g, wallIdx, type);
    });
  }

  function _fpSyncMarkAcrossSvgs(pageNo, wallIdx, typeOrNull, originSvgId) {
    document.querySelectorAll(`svg[data-fp-page-number="${pageNo}"]`).forEach(s => {
      if (originSvgId && s.id === originSvgId) return;
      const g = s.querySelector(`g[data-fp-wall-idx="${wallIdx}"]`);
      if (!g) return;
      if (!_fpWallMarks[s.id]) _fpWallMarks[s.id] = new Map();
      if (!typeOrNull) {
        _fpRemoveWallMark(g);
        _fpWallMarks[s.id].delete(wallIdx);
      } else {
        _fpAddWallMark(s, g, wallIdx, typeOrNull);
      }
    });
  }

  window._fpApplyGlobalMarksToAllFloorSvgs = function() {
    document.querySelectorAll('svg[id^="fpSvg_"]').forEach(svg => _fpApplyGlobalMarksToSvg(svg));
  };

  window.fpToggleMarkWalls = function(svgId, btnId) {
    _fpMarkWallsMode[svgId] = !_fpMarkWallsMode[svgId];
    const btn = document.getElementById(btnId);
    if (btn) {
      if (_fpMarkWallsMode[svgId]) {
        btn.style.background = '#f59e0b';
        btn.style.color = '#fff';
      } else {
        btn.style.background = '';
        btn.style.color = '';
      }
    }
    // Update cursor on walls
    const svg = document.getElementById(svgId);
    if (svg) {
      svg.querySelectorAll('g[data-fp-wall-idx]').forEach(g => {
        g.style.cursor = _fpMarkWallsMode[svgId] ? 'crosshair' : 'pointer';
      });
    }
  };

  function _fpGetWallCenter(g) {
    const line = g.querySelector('line');
    if (!line) return null;
    const x1 = parseFloat(line.getAttribute('x1'));
    const y1 = parseFloat(line.getAttribute('y1'));
    const x2 = parseFloat(line.getAttribute('x2'));
    const y2 = parseFloat(line.getAttribute('y2'));
    return { x: (x1 + x2) / 2, y: (y1 + y2) / 2 };
  }

  function _fpAddWallMark(svg, g, wallIdx, type) {
    // Remove old mark if any
    _fpRemoveWallMark(g);
    const center = _fpGetWallCenter(g);
    if (!center) return;
    const r = type === 'thick' ? 10 : 5;
    const fill = type === 'thick' ? '#f97316' : '#22c55e';
    const strokeCol = type === 'thick' ? '#ea580c' : '#16a34a';
    const mark = document.createElementNS('http://www.w3.org/2000/svg', 'circle');
    mark.classList.add('fp-wall-mark');
    mark.setAttribute('cx', center.x);
    mark.setAttribute('cy', center.y);
    mark.setAttribute('r', r);
    mark.setAttribute('fill', fill);
    mark.setAttribute('fill-opacity', '0.7');
    mark.setAttribute('stroke', strokeCol);
    mark.setAttribute('stroke-width', '2');
    mark.setAttribute('pointer-events', 'none');
    g.appendChild(mark);
    // Store mark data
    const svgId = svg.id;
    if (!_fpWallMarks[svgId]) _fpWallMarks[svgId] = new Map();
    _fpWallMarks[svgId].set(wallIdx, type);

    // Update global marks (page-scoped) so marking in PDF Preview transfers to Floor Plan
    const pageNo = _fpGetPageNumberFromSvg(svg);
    if (pageNo !== null && pageNo !== undefined) {
      _fpSetGlobalMark(pageNo, wallIdx, type);
    }
  }

  function _fpRemoveWallMark(g) {
    g.querySelectorAll('.fp-wall-mark').forEach(m => m.remove());
  }

  function _fpHandleWallMarkClick(svg, g) {
    const wallIdx = parseInt(g.getAttribute('data-fp-wall-idx'));
    const svgId = svg.id;
    if (!_fpWallMarks[svgId]) _fpWallMarks[svgId] = new Map();
    if (!_fpMarkHistory[svgId]) _fpMarkHistory[svgId] = [];
    const cur = _fpWallMarks[svgId].get(wallIdx) || null;
    // Push previous state to undo stack
    _fpMarkHistory[svgId].push({ wallIdx, prevType: cur });

    const pageNo = _fpGetPageNumberFromSvg(svg);
    if (pageNo !== null && pageNo !== undefined) {
      _fpGlobalHistory.push({ pageNo, wallIdx, prevType: cur });
    }

    if (!cur) {
      _fpAddWallMark(svg, g, wallIdx, 'thin');
      if (pageNo !== null && pageNo !== undefined) {
        _fpSyncMarkAcrossSvgs(pageNo, wallIdx, 'thin', svgId);
      }
    } else if (cur === 'thin') {
      _fpAddWallMark(svg, g, wallIdx, 'thick');
      if (pageNo !== null && pageNo !== undefined) {
        _fpSyncMarkAcrossSvgs(pageNo, wallIdx, 'thick', svgId);
      }
    } else {
      _fpRemoveWallMark(g);
      _fpWallMarks[svgId].delete(wallIdx);
      if (pageNo !== null && pageNo !== undefined) {
        _fpSetGlobalMark(pageNo, wallIdx, null);
        _fpSyncMarkAcrossSvgs(pageNo, wallIdx, null, svgId);
      }
    }
  }

  window.fpUndoGlobal = function() {
    if (_fpGlobalHistory.length === 0) {
      setStatus('Nothing to undo.', 'info');
      return;
    }
    const entry = _fpGlobalHistory.pop();
    const { pageNo, wallIdx, prevType } = entry;
    _fpSetGlobalMark(pageNo, wallIdx, prevType);
    _fpSyncMarkAcrossSvgs(pageNo, wallIdx, prevType, null);
  };

  window.fpUndoMark = function(svgId) {
    const svg = document.getElementById(svgId);
    if (!svg) return;
    if (!_fpMarkHistory[svgId] || _fpMarkHistory[svgId].length === 0) {
      setStatus('Nothing to undo.', 'info');
      return;
    }
    const entry = _fpMarkHistory[svgId].pop();
    const g = svg.querySelector(`g[data-fp-wall-idx="${entry.wallIdx}"]`);
    if (!g) return;
    const pageNo = _fpGetPageNumberFromSvg(svg);
    if (!entry.prevType) {
      // Was unmarked before → remove mark now
      _fpRemoveWallMark(g);
      if (_fpWallMarks[svgId]) _fpWallMarks[svgId].delete(entry.wallIdx);
      if (pageNo !== null && pageNo !== undefined) {
        _fpSetGlobalMark(pageNo, entry.wallIdx, null);
        _fpSyncMarkAcrossSvgs(pageNo, entry.wallIdx, null, svgId);
      }
    } else {
      // Restore previous mark type
      _fpAddWallMark(svg, g, entry.wallIdx, entry.prevType);
      if (pageNo !== null && pageNo !== undefined) {
        _fpSyncMarkAcrossSvgs(pageNo, entry.wallIdx, entry.prevType, svgId);
      }
    }
  };

  // ── PDF Preview wall overlay (vector hit targets over the PNG preview) ──
  window.pdfBuildWallOverlay = function(analysis) {
    if (!analysis || !Array.isArray(analysis.floorPlan)) {
      console.log('pdfBuildWallOverlay: no floorPlan array');
      return;
    }
    if (!pdfPages) {
      console.log('pdfBuildWallOverlay: no pdfPages element');
      return;
    }

    // Remove any existing overlay SVGs
    document.querySelectorAll('svg[id^="pdfSvg_"]').forEach(s => s.remove());

    let builtCount = 0;
    for (const fp of analysis.floorPlan) {
      if (!fp || fp.page == null || !Array.isArray(fp.walls) || fp.walls.length === 0) {
        console.log('pdfBuildWallOverlay skipping fp:', fp);
        continue;
      }

      let host = document.getElementById(`pdfOverlayHost_${fp.page - 1}`);
      if (!host) host = document.getElementById(`pdfOverlayHost_${fp.page}`);
      if (!host) {
        console.log('pdfBuildWallOverlay host not found for page:', fp.page);
        continue;
      }
      builtCount++;

      let svgW = fp.width, svgH = fp.height;
      if (fp.rotation === 90 || fp.rotation === 270) { svgW = fp.height; svgH = fp.width; }

      const svg = document.createElementNS('http://www.w3.org/2000/svg', 'svg');
      svg.setAttribute('id', `pdfSvg_${fp.page}`);
      svg.setAttribute('data-fp-page-number', String(fp.page));
      svg.setAttribute('viewBox', `0 0 ${svgW} ${svgH}`);
      svg.setAttribute('xmlns', 'http://www.w3.org/2000/svg');
      svg.style.width = '100%';
      svg.style.height = '100%';
      svg.style.display = 'block';

      // Respect current preview mark mode (if user toggled it before overlay exists)
      const markOn = !!window._pdfMarkWallsOn;
      _fpMarkWallsMode[svg.id] = markOn;

      const txPt = (px, py) => {
        switch (fp.rotation % 360) {
          case 90:  return [py, px];
          case 180: return [fp.width - px, py];
          case 270: return [fp.height - py, fp.width - px];
          default:  return [px, fp.height - py];
        }
      };

      const frag = document.createDocumentFragment();
      for (let wi = 0; wi < fp.walls.length; wi++) {
        const w = fp.walls[wi];
        const [x1,y1] = txPt(w[0], w[1]);
        const [x2,y2] = txPt(w[2], w[3]);
        const g = document.createElementNS('http://www.w3.org/2000/svg', 'g');
        g.setAttribute('data-fp-wall-idx', String(wi));

        // Hit line (first <line> so _fpGetWallCenter works)
        const hit = document.createElementNS('http://www.w3.org/2000/svg', 'line');
        hit.setAttribute('x1', x1.toFixed(1));
        hit.setAttribute('y1', y1.toFixed(1));
        hit.setAttribute('x2', x2.toFixed(1));
        hit.setAttribute('y2', y2.toFixed(1));
        hit.setAttribute('data-pdf-hit', '1');
        // Use an almost-invisible stroke (NOT 'transparent') so pointer-events are reliable across browsers.
        // When mark mode is ON we make it slightly visible to confirm alignment.
        hit.setAttribute('stroke', markOn ? '#0ea5e9' : '#000');
        hit.setAttribute('stroke-opacity', markOn ? '0.14' : '0.001');
        hit.setAttribute('stroke-width', markOn ? '18' : '18');
        hit.setAttribute('stroke-linecap', 'round');
        hit.setAttribute('pointer-events', 'stroke');
        g.appendChild(hit);

        g.style.cursor = markOn ? 'crosshair' : 'default';

        frag.appendChild(g);
      }
      svg.appendChild(frag);

      host.innerHTML = '';
      host.appendChild(svg);
    }

    console.log(`pdfBuildWallOverlay finished. Built ${builtCount} overlays.`);
    window.pdfAttachWallMarkHandlers();
  };

  window.pdfAttachWallMarkHandlers = function() {
    document.querySelectorAll('svg[id^="pdfSvg_"]').forEach(svg => {
      if (svg.getAttribute('data-wall-mark-bound') === '1') return;
      svg.setAttribute('data-wall-mark-bound', '1');

      // Apply marks already made in Floor Plan
      _fpApplyGlobalMarksToSvg(svg);

      svg.querySelectorAll('g[data-fp-wall-idx]').forEach(g => {
        const hit = g.querySelector('line');
        const target = hit || g;
        target.addEventListener('click', (e) => {
          e.stopPropagation();
          if (!_fpMarkWallsMode[svg.id]) return;
          _fpHandleWallMarkClick(svg, g);
        });
      });
    });
  };

  window.pdfToggleMarkWalls = function() {
    const svgs = Array.from(document.querySelectorAll('svg[id^="pdfSvg_"]'));
    const curOn = svgs.some(s => !!_fpMarkWallsMode[s.id]);
    const nextOn = !curOn;
    window._pdfMarkWallsOn = nextOn;
    svgs.forEach(svg => {
      _fpMarkWallsMode[svg.id] = nextOn;
      svg.querySelectorAll('g[data-fp-wall-idx]').forEach(g => {
        g.style.cursor = nextOn ? 'crosshair' : 'default';
        const hit = g.querySelector('line[data-pdf-hit]');
        if (hit) {
          hit.setAttribute('stroke', nextOn ? '#0ea5e9' : '#000');
          hit.setAttribute('stroke-opacity', nextOn ? '0.14' : '0.001');
        }
      });
    });
    const wallCount = svgs.reduce((acc, s) => acc + (s.querySelectorAll('g[data-fp-wall-idx]').length || 0), 0);
    setStatus(`PDF Mark Walls ${nextOn ? 'ON' : 'OFF'} — overlay: ${svgs.length} page(s), ${wallCount} wall hit-lines.`, 'info');
  };

  if (btnPdfUndo) btnPdfUndo.addEventListener('click', () => window.fpUndoGlobal());

  // ── Clean SVG: local JS — snap endpoints & show building envelope (walls only) ──
  window.fpCleanSvg = async function(svgId, opts) {
    const options = opts || {};
    const mode = String(options.mode || 'clean').toLowerCase(); // clean | group
    const askDownload = options.askDownload !== false;
    const svg = document.getElementById(svgId);
    if (!svg) return;
    const marks = _fpWallMarks[svgId];
    if (!marks || marks.size === 0) {
      setStatus('No walls marked. Use "Mark Walls" first: click on walls to mark thin (●) or thick (●●).', 'error');
      return;
    }

    // Collect marked wall data
    const walls = [];
    marks.forEach((type, idx) => {
      const g = svg.querySelector(`g[data-fp-wall-idx="${idx}"]`);
      if (!g) return;
      const line = g.querySelector('line');
      if (!line) return;
      walls.push({
        idx, type,
        x1: parseFloat(line.getAttribute('x1')),
        y1: parseFloat(line.getAttribute('y1')),
        x2: parseFloat(line.getAttribute('x2')),
        y2: parseFloat(line.getAttribute('y2'))
      });
    });

    if (walls.length === 0) {
      setStatus('No valid wall marks found.', 'error');
      return;
    }

    // Capture before image for AI training
    let _cleanBeforeImg = null;
    try { _cleanBeforeImg = window._svgToDataUrl ? await window._svgToDataUrl(svg, 1024) : null; } catch {}

    const vb = svg.getAttribute('viewBox');
    const SNAP = 8; // snap threshold in SVG units

    // ── Snap nearby endpoints together ──
    const pts = [];
    walls.forEach((w, i) => {
      pts.push({ wi: i, end: '1', x: w.x1, y: w.y1 });
      pts.push({ wi: i, end: '2', x: w.x2, y: w.y2 });
    });

    // Iterative cluster-based snapping
    const visited = new Set();
    for (let i = 0; i < pts.length; i++) {
      if (visited.has(i)) continue;
      const cluster = [i];
      visited.add(i);
      // Grow cluster: check all pts against any cluster member
      let changed = true;
      while (changed) {
        changed = false;
        for (let j = 0; j < pts.length; j++) {
          if (visited.has(j)) continue;
          for (const ci of cluster) {
            const dx = pts[ci].x - pts[j].x;
            const dy = pts[ci].y - pts[j].y;
            if (Math.sqrt(dx * dx + dy * dy) <= SNAP) {
              cluster.push(j);
              visited.add(j);
              changed = true;
              break;
            }
          }
        }
      }
      if (cluster.length < 2) continue;
      let sx = 0, sy = 0;
      for (const ci of cluster) { sx += pts[ci].x; sy += pts[ci].y; }
      const ax = sx / cluster.length;
      const ay = sy / cluster.length;
      for (const ci of cluster) {
        const w = walls[pts[ci].wi];
        if (pts[ci].end === '1') { w.x1 = ax; w.y1 = ay; }
        else { w.x2 = ax; w.y2 = ay; }
      }
    }

    // ── Try to order walls into a connected envelope path ──
    // Build adjacency: for each unique point, list connected wall indices
    const ptKey = (x, y) => `${x.toFixed(1)},${y.toFixed(1)}`;
    const adjMap = new Map(); // ptKey -> [{wallIdx, otherPtKey}]
    for (let i = 0; i < walls.length; i++) {
      const w = walls[i];
      const k1 = ptKey(w.x1, w.y1);
      const k2 = ptKey(w.x2, w.y2);
      if (!adjMap.has(k1)) adjMap.set(k1, []);
      if (!adjMap.has(k2)) adjMap.set(k2, []);
      adjMap.get(k1).push({ wi: i, other: k2 });
      adjMap.get(k2).push({ wi: i, other: k1 });
    }

    // Try to find a continuous path (Euler-path-like traversal)
    const usedWalls = new Set();
    const chains = []; // each chain is an ordered array of points [{x,y}]

    function traceChain(startKey) {
      const chain = [];
      const [sx, sy] = startKey.split(',').map(Number);
      chain.push({ x: sx, y: sy });
      let curKey = startKey;
      let found = true;
      while (found) {
        found = false;
        const edges = adjMap.get(curKey) || [];
        for (const e of edges) {
          if (usedWalls.has(e.wi)) continue;
          usedWalls.add(e.wi);
          const [nx, ny] = e.other.split(',').map(Number);
          chain.push({ x: nx, y: ny });
          curKey = e.other;
          found = true;
          break;
        }
      }
      return chain;
    }

    // Start from vertices with odd degree (endpoints), or any vertex
    const degreeMap = new Map();
    adjMap.forEach((edges, key) => degreeMap.set(key, edges.length));
    const oddKeys = [...degreeMap.entries()].filter(([k,d]) => d % 2 !== 0).map(([k]) => k);
    const startKeys = oddKeys.length > 0 ? oddKeys : [...adjMap.keys()];

    for (const sk of startKeys) {
      if (usedWalls.size === walls.length) break;
      // Check if this vertex still has unused edges
      const edges = adjMap.get(sk) || [];
      if (edges.every(e => usedWalls.has(e.wi))) continue;
      chains.push(traceChain(sk));
    }
    // Pick up any remaining walls not in chains
    for (let i = 0; i < walls.length; i++) {
      if (usedWalls.has(i)) continue;
      usedWalls.add(i);
      chains.push([
        { x: walls[i].x1, y: walls[i].y1 },
        { x: walls[i].x2, y: walls[i].y2 }
      ]);
    }

    const thinCount = walls.filter(w => w.type === 'thin').length;
    const thickCount = walls.filter(w => w.type === 'thick').length;

    // Determine dominant wall type for stroke width
    const mainStroke = thickCount >= thinCount ? 4 : 2.5;

    // ── Build clean SVG — envelope only, no dots, no doors ──
    let cleanInner = '';

    // Draw chains as connected polylines for cleaner envelope look
    for (const chain of chains) {
      if (chain.length < 2) continue;
      const pointsStr = chain.map(p => `${p.x.toFixed(1)},${p.y.toFixed(1)}`).join(' ');
      // Check if chain is closed (first ≈ last)
      const first = chain[0], last = chain[chain.length - 1];
      const closeDist = Math.sqrt((first.x - last.x) ** 2 + (first.y - last.y) ** 2);
      const isClosed = closeDist < SNAP;

      if (isClosed) {
        cleanInner += `<polygon points="${pointsStr}" fill="none" stroke="#1e293b" stroke-width="${mainStroke}" stroke-linejoin="round"/>`;
      } else {
        cleanInner += `<polyline points="${pointsStr}" fill="none" stroke="#1e293b" stroke-width="${mainStroke}" stroke-linejoin="round" stroke-linecap="round"/>`;
      }
    }

    // Also keep individual wall groups with transparent hit-targets for re-marking
    for (let i = 0; i < walls.length; i++) {
      const w = walls[i];
      cleanInner += `<g data-fp-wall-idx="${w.idx}">`;
      cleanInner += `<line x1="${w.x1.toFixed(1)}" y1="${w.y1.toFixed(1)}" x2="${w.x2.toFixed(1)}" y2="${w.y2.toFixed(1)}" stroke="transparent" stroke-width="12" stroke-linecap="round" pointer-events="stroke"/>`;
      cleanInner += `</g>`;
    }

    // Update the map in-place
    svg.innerHTML = cleanInner;
    svg.setAttribute('viewBox', vb);
    svg.style.background = '#ffffff';

    // Re-attach click events
    fpAttachSvgHandlers();

    // Rebuild marks map
    _fpWallMarks[svgId] = new Map();
    for (const w of walls) _fpWallMarks[svgId].set(w.idx, w.type);
    _fpMarkHistory[svgId] = [];

    // Track that this SVG has been cleaned (for save/load persistence)
    if (!window._fpCleanedSvgs) window._fpCleanedSvgs = {};
    window._fpCleanedSvgs[svgId] = { mode };

    if (mode === 'group') {
      setStatus(`Grouped marked walls: ${walls.length} segments merged into ${chains.length} shape chain(s).`, 'success');
    } else {
      setStatus(`Building envelope: ${walls.length} walls in ${chains.length} chain(s). No dots, no doors.`, 'success');
    }

    // ── Log wall cleaning as AI training data ──
    try {
      const _cleanAfterImg = window._svgToDataUrl ? await window._svgToDataUrl(svg, 1024) : null;
      const wallData = walls.map(w => ({
        idx: w.idx, type: w.type,
        x1: Math.round(w.x1), y1: Math.round(w.y1),
        x2: Math.round(w.x2), y2: Math.round(w.y2)
      }));
      const vbParts = (vb || '').split(/[\s,]+/).map(Number);
      const resultJson = JSON.stringify({
        mode: 'wall-clean',
        cleanMode: mode,
        wallCount: walls.length,
        chainCount: chains.length,
        thinWalls: walls.filter(w => w.type === 'thin').length,
        thickWalls: walls.filter(w => w.type === 'thick').length,
        viewBox: { x: vbParts[0] || 0, y: vbParts[1] || 0, w: vbParts[2] || 0, h: vbParts[3] || 0 },
        walls: wallData,
        chains: chains.map(c => c.map(p => ({ x: Math.round(p.x), y: Math.round(p.y) })))
      });

      const description = mode === 'group'
        ? `Group walls: ${walls.length} segments → ${chains.length} chains`
        : `Clean SVG: ${walls.length} walls → ${chains.length} envelope chains (no doors/dots)`;

      await logAiInteraction(
        description,
        'wall-clean',
        'wall-clean',
        true,
        description,
        resultJson,
        0, 0, 0, null,
        _cleanBeforeImg, _cleanAfterImg
      );

      // Save as training example
      const [beforeSmall, afterSmall] = await Promise.all([
        _downscaleForLog(_cleanBeforeImg, 512),
        _downscaleForLog(_cleanAfterImg, 512)
      ]);
      await saveAiExample(
        'clean-drawing',
        ['ניקוי', 'clean', 'wall-clean', 'envelope', 'קירות', 'walls', mode === 'group' ? 'group' : 'clean'],
        description,
        'wall-clean',
        description,
        resultJson,
        beforeSmall, afterSmall,
        1
      );
      console.log('[WallClean] AI training data saved');
    } catch (e) { console.warn('[WallClean] AI training log failed:', e); }

    // Offer download
    let doDownload = false;
    if (askDownload) {
      doDownload = await cgConfirm(
        `Building envelope created.\n\n${walls.length} walls, ${chains.length} chain(s).\n\nOK = Download clean SVG\nCancel = No download`
      );
    }

    if (doDownload) {
      let exportSvg = `<svg xmlns="http://www.w3.org/2000/svg" viewBox="${vb}" style="background:#ffffff">`;
      for (const chain of chains) {
        if (chain.length < 2) continue;
        const pointsStr = chain.map(p => `${p.x.toFixed(1)},${p.y.toFixed(1)}`).join(' ');
        const first = chain[0], last = chain[chain.length - 1];
        const closeDist = Math.sqrt((first.x - last.x) ** 2 + (first.y - last.y) ** 2);
        if (closeDist < SNAP) {
          exportSvg += `<polygon points="${pointsStr}" fill="none" stroke="#1e293b" stroke-width="${mainStroke}" stroke-linejoin="round"/>`;
        } else {
          exportSvg += `<polyline points="${pointsStr}" fill="none" stroke="#1e293b" stroke-width="${mainStroke}" stroke-linejoin="round" stroke-linecap="round"/>`;
        }
      }
      exportSvg += `</svg>`;

      const blob = new Blob([exportSvg], { type: 'image/svg+xml;charset=utf-8' });
      const url = URL.createObjectURL(blob);
      const a = document.createElement('a');
      a.href = url;
      const fn = (lastAnalysis && lastAnalysis.fileName) || 'floorplan';
      a.download = `${fn.replace(/\.[^.]+$/, '')}_clean.svg`;
      document.body.appendChild(a); a.click(); a.remove();
      setTimeout(() => URL.revokeObjectURL(url), 2500);
    }
  };

