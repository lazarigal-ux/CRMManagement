  function fpNormalizeGroupName(raw) {
    const s = String(raw || '').trim();
    if (!s) return '';
    return s.replace(/\s+/g, '_').replace(/[^\w\-]/g, '').toUpperCase();
  }

  function fpSuggestedGroupName() {
    try {
      if (_opTypeEl && _opTypeEl.value) return fpNormalizeGroupName(_opTypeEl.value);
    } catch { }
    try {
      const fromCompare = String(_compareOpName || '').replace(/[^A-Za-z0-9_\- ]/g, ' ').trim();
      if (fromCompare) return fpNormalizeGroupName(fromCompare.split(/\s+/).slice(0, 2).join('_'));
    } catch { }
    return fpActiveGroupName || 'SVG_GROUP';
  }

  function fpSetGroupStatus(msg, kind) {
    if (!fpSvgGroupStatus) return;
    fpSvgGroupStatus.textContent = String(msg || '');
    fpSvgGroupStatus.className = kind === 'warn'
      ? 'text-[11px] text-amber-300 ml-auto'
      : kind === 'ok'
        ? 'text-[11px] text-emerald-300 ml-auto'
        : kind === 'error'
          ? 'text-[11px] text-rose-300 ml-auto'
          : 'text-[11px] text-slate-400 ml-auto';
  }

  function fpRefreshGroupUi() {
    if (fpSvgGroupSelect) {
      const prev = fpSvgGroupSelect.value;
      fpSvgGroupSelect.innerHTML = '<option value="">-- Select group --</option>';
      Object.keys(fpSvgGroups).sort().forEach(name => {
