  /* ── Smart Select: filter-based selection ── */
  window.fpSmartSelect = function(svgId, mode) {
    const svg = document.getElementById(svgId);
    if (!svg) return;
    _fpSelectMode[svgId] = true;

    if (mode === 'none') {
      svg.querySelectorAll('.fp-selected').forEach(g => _fpMarkSelected(g, false));
      return;
    }
    if (mode === 'invert') {
      svg.querySelectorAll('g[data-fp-wall-idx], g[data-fp-door-idx], g[data-fp-item-idx], [data-fp-selectable="1"]').forEach(g => {
        _fpMarkSelected(g, !g.classList.contains('fp-selected'));
      });
      return;
    }

    // Build line metadata for wall-groups
    const tolDeg = 15;
    // Determine SVG size for adaptive thresholds
    let svgSize = 1000;
    const vb = svg.getAttribute('viewBox');
    if (vb) { const p = vb.split(/[\s,]+/).map(Number); svgSize = Math.max(p[2]||1000, p[3]||1000); }
    else { svgSize = Math.max(svg.clientWidth||1000, svg.clientHeight||1000); }
    const shortThresh = svgSize * 0.06;
    const longThresh  = svgSize * 0.08;
    const CELL = Math.max(15, svgSize * 0.025);

    const wallData = [];
    const grid = {};
    svg.querySelectorAll('g[data-fp-wall-idx]').forEach(g => {
      const line = g.querySelector('line:not([pointer-events="stroke"])');
      if (!line) return;
      const x1 = +line.getAttribute('x1'), y1 = +line.getAttribute('y1');
      const x2 = +line.getAttribute('x2'), y2 = +line.getAttribute('y2');
      const dx = x2 - x1, dy = y2 - y1;
      const len = Math.sqrt(dx * dx + dy * dy);
      const mx = (x1 + x2) / 2, my = (y1 + y2) / 2;
      const angle = Math.abs(Math.atan2(dy, dx) * 180 / Math.PI);
      const nearH = angle < tolDeg || angle > (180 - tolDeg);
      const nearV = Math.abs(angle - 90) < tolDeg;
      const gx = Math.floor(mx / CELL), gy = Math.floor(my / CELL);
      const w = { g, len, diagonal: !nearH && !nearV, short: len < shortThresh, gx, gy };
      wallData.push(w);
      const key = gx + ',' + gy;
      if (!grid[key]) grid[key] = [];
      grid[key].push(wallData.length - 1);
    });

    function countNbrs(w) {
      let n = 0;
      for (let ddx = -1; ddx <= 1; ddx++)
        for (let ddy = -1; ddy <= 1; ddy++) {
          const c = grid[(w.gx + ddx) + ',' + (w.gy + ddy)];
          if (c) n += c.length;
        }
      return n - 1;
    }

    let count = 0;
    if (mode === 'diagonals') {
      // Select all diagonal wall-lines (not near H/V)
      wallData.forEach(w => {
        if (w.diagonal) { _fpMarkSelected(w.g, true); count++; }
      });
    } else if (mode === 'short') {
      // Select all short wall-lines
      wallData.forEach(w => {
        if (w.short) { _fpMarkSelected(w.g, true); count++; }
      });
    } else if (mode === 'hatching') {
      // Select lines in dense clusters (hatching fill)
      const DENSITY = 5;
      wallData.forEach(w => {
        if (w.len >= longThresh) return;  // skip long structural lines
        const nbrs = countNbrs(w);
        if (nbrs >= DENSITY) { _fpMarkSelected(w.g, true); count++; }
      });
    } else if (mode === 'diagHatch') {
      // Select diagonal lines in dense clusters only
      const DENSITY = 4;
      wallData.forEach(w => {
        if (!w.diagonal) return;
        if (w.len >= longThresh) return;
        const nbrs = countNbrs(w);
        if (nbrs >= DENSITY) { _fpMarkSelected(w.g, true); count++; }
      });
    }
    console.log(`Smart Select [${mode}]: ${count} elements selected`);
  };
  window.fpDeleteSelected = async function(svgId) {
    const svg = document.getElementById(svgId);
