  // ── Count Similar / Select Similar helpers ──
  function _fpGetVisualSignature(el) {
    const isG = String(el.tagName || '').toLowerCase() === 'g';
    let prim = isG
      ? el.querySelector('line, path, polyline, polygon, rect, circle, ellipse, text')
      : el;
    if (!prim) return null;

    // Skip hidden hit-area elements in groups
    if (isG) {
      const candidates = el.querySelectorAll('line, path, polyline, polygon, rect, circle, ellipse, text');
      for (const c of candidates) {
        if (c.getAttribute('stroke') === 'transparent' || c.getAttribute('pointer-events') === 'stroke') continue;
        prim = c;
        break;
      }
    }

    const tag = String(prim.tagName || '').toLowerCase();
    const stroke = (prim.getAttribute('stroke') || '').toLowerCase();
    const fill = (prim.getAttribute('fill') || '').toLowerCase();
    const sw = parseFloat(prim.getAttribute('stroke-width') || '1') || 1;

    // Type classification
    let kind = 'element';
    if (el.hasAttribute('data-fp-wall-idx')) kind = 'wall';
    else if (el.hasAttribute('data-fp-door-idx')) kind = 'door';
    else if (el.hasAttribute('data-fp-item-idx')) kind = 'item';

    // Approximate size from bounding box
    let bboxW = 0, bboxH = 0;
    try {
      const bb = prim.getBBox();
      bboxW = bb.width;
      bboxH = bb.height;
    } catch { }

    // Size bucket (round to nearest 10 to group similar sizes)
    const sizeBucket = Math.round(Math.max(bboxW, bboxH) / 10) * 10;

    return { tag, stroke, fill, sw: Math.round(sw * 2) / 2, kind, sizeBucket, bboxW, bboxH };
  }

  function _fpSignatureKey(sig) {
    if (!sig) return '';
    return `${sig.kind}|${sig.tag}|${sig.stroke}|${sig.fill}|${sig.sw}|${sig.sizeBucket}`;
  }

  function _fpFindSimilar(svg, selectedEls) {
    // Build signature(s) from selected elements
    const selectedSigs = new Set();
    for (const el of selectedEls) {
      const sig = _fpGetVisualSignature(el);
      if (sig) selectedSigs.add(_fpSignatureKey(sig));
    }
    if (!selectedSigs.size) return { matches: [], details: [] };

    // Scan all selectable elements
    const allEls = svg.querySelectorAll('g[data-fp-item-idx], g[data-fp-wall-idx], g[data-fp-door-idx], [data-fp-selectable="1"]');
    const matches = [];
    const detailMap = {};

    for (const el of allEls) {
      const sig = _fpGetVisualSignature(el);
      if (!sig) continue;
      const key = _fpSignatureKey(sig);
      if (selectedSigs.has(key)) {
        matches.push(el);
        if (!detailMap[key]) detailMap[key] = { sig, count: 0 };
        detailMap[key].count++;
      }
    }

    const details = Object.values(detailMap).map(d => {
      const s = d.sig;
      let desc = `${s.kind} (${s.tag})`;
      if (s.stroke && s.stroke !== 'none' && s.stroke !== 'transparent') desc += ` stroke:${s.stroke}`;
      if (s.fill && s.fill !== 'none' && s.fill !== 'transparent') desc += ` fill:${s.fill}`;
      if (s.sizeBucket > 0) desc += ` ~${s.sizeBucket}px`;
      return `${d.count}× ${desc}`;
    });

    return { matches, details };
  }

  window.fpCountSimilar = function() {
    const svg = document.querySelector('svg[id^="fpSvg_"]');
    if (!svg) return;
    const selected = Array.from(svg.querySelectorAll('.fp-selected'));
    if (!selected.length) { cgAlert('Select one or more objects first, then click Count Similar.'); return; }

    const { matches, details } = _fpFindSimilar(svg, selected);
    const resultsEl = document.getElementById('fpSimilarResults');
    const textEl = document.getElementById('fpSimilarText');
    const detailsEl = document.getElementById('fpSimilarDetails');
    if (!resultsEl || !textEl) return;

    textEl.innerHTML = `<i class="fa-solid fa-calculator mr-1"></i> Found <strong>${matches.length}</strong> similar object(s) on the SVG (${selected.length} selected as reference)`;
    if (detailsEl) detailsEl.textContent = details.join('  •  ');
    resultsEl.classList.remove('hidden');
  };

  window.fpSelectSimilar = function() {
    const svg = document.querySelector('svg[id^="fpSvg_"]');
    if (!svg) return;
    const selected = Array.from(svg.querySelectorAll('.fp-selected'));
    if (!selected.length) { cgAlert('Select one or more objects first, then click Select Similar.'); return; }

    const { matches } = _fpFindSimilar(svg, selected);
    _fpSelectMode[svg.id] = true;
    for (const el of matches) {
      if (!el.classList.contains('fp-selected')) _fpMarkSelected(el, true);
    }
  };

  // ── Area-select mode state & helpers ──
  // off -> select -> delete -> cleanup -> off
  const _fpAreaMode = {}; // svgId -> 'off' | 'select' | 'delete' | 'cleanup'
  const _fpAreaShape = {}; // svgId -> 'rect' | 'square' | 'circle' | 'triangle'
  const _fpDragState = {};

