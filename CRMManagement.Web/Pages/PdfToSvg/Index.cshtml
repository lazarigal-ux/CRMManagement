    if (!Number.isFinite(sw) || sw <= 0) return;

    selected.forEach(g => {
      const isG = String(g.tagName || '').toLowerCase() === 'g';
      const targets = isG
        ? g.querySelectorAll('line, path, polyline, polygon, rect, circle, ellipse')
        : [g];

      targets.forEach(el => {
