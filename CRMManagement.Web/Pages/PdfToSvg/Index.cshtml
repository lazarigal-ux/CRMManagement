  function _fpMarkSelected(g, select) {
    // Support both analysis-generated <g> wrappers AND raw SVG primitives (paths/lines)
    const isDirectPrimitive = !!(g && g.tagName && String(g.tagName).toLowerCase() !== 'g');
    const strokeTarget = isDirectPrimitive
      ? g
      : (g.querySelector ? g.querySelector('line, path, polyline, polygon, rect, circle, ellipse, text') : null);

    if (select) {
      g.classList.add('fp-selected');
      if (g.hasAttribute('data-fp-item-idx')) {
        const c = g.querySelector('circle:not(.fp-sel-ring)');
        if (c) {
          const ring = document.createElementNS('http://www.w3.org/2000/svg','circle');
          ring.setAttribute('cx', c.getAttribute('cx'));
          ring.setAttribute('cy', c.getAttribute('cy'));
          ring.setAttribute('r', '13');
          ring.setAttribute('fill','none');
          ring.setAttribute('stroke','#0ea5e9');
          ring.setAttribute('stroke-width','2.5');
          ring.setAttribute('stroke-dasharray','4,2');
          ring.classList.add('fp-sel-ring');
          g.insertBefore(ring, g.firstChild);
        }
      } else {
        if (strokeTarget && strokeTarget.getAttribute) {
          g.setAttribute('data-orig-stroke', strokeTarget.getAttribute('stroke') || '');
          const sw = strokeTarget.getAttribute('stroke-width');
          g.setAttribute('data-orig-stroke-width', sw === null ? '' : sw);

          strokeTarget.setAttribute('stroke', '#0ea5e9');
          if (sw === null || sw === '' || sw === '0' || sw === '0.0') {
            strokeTarget.setAttribute('stroke-width', '2');
          }
        }
      }
    } else {
      g.classList.remove('fp-selected');
      const ring = g.querySelector('.fp-sel-ring');
      if (ring) ring.remove();
      const orig = g.getAttribute('data-orig-stroke');
      if (orig !== null) {
        if (strokeTarget && strokeTarget.getAttribute) {
          strokeTarget.setAttribute('stroke', orig);
          const origSw = g.getAttribute('data-orig-stroke-width');
          if (origSw !== null) {
            if (origSw === '') strokeTarget.removeAttribute('stroke-width');
            else strokeTarget.setAttribute('stroke-width', origSw);
          }
        }
        g.removeAttribute('data-orig-stroke');
        g.removeAttribute('data-orig-stroke-width');
      }
    }
    // Debounce selection info update
    clearTimeout(_fpSelInfoTimer);
    _fpSelInfoTimer = setTimeout(fpUpdateSelectionInfo, 30);
  }
  let _fpSelInfoTimer = 0;

  // ── Selection info bar: count & color operations ──
  function fpUpdateSelectionInfo() {
    const bar = document.getElementById('fpSelectionBar');
    const countEl = document.getElementById('fpSelCount');
    const breakdownEl = document.getElementById('fpSelBreakdown');
    const totalEl = document.getElementById('fpTotalCount');
    if (!bar) return;

    const svg = document.querySelector('svg[id^="fpSvg_"]');
    if (!svg) { bar.classList.add('hidden'); return; }

    const allItems = svg.querySelectorAll('g[data-fp-item-idx], g[data-fp-wall-idx], g[data-fp-door-idx], [data-fp-selectable="1"]');
    const selected = svg.querySelectorAll('.fp-selected');
    const selCount = selected.length;
    const totalCount = allItems.length;

    if (totalCount === 0) { bar.classList.add('hidden'); return; }
    bar.classList.remove('hidden');

    if (countEl) countEl.textContent = selCount;
    if (totalEl) totalEl.textContent = totalCount;

    if (breakdownEl) {
      if (selCount === 0) {
        breakdownEl.textContent = '';
      } else {
        const walls = svg.querySelectorAll('.fp-selected[data-fp-wall-idx]').length;
        const doors = svg.querySelectorAll('.fp-selected[data-fp-door-idx]').length;
        const items = svg.querySelectorAll('.fp-selected[data-fp-item-idx]').length;
        const prims = svg.querySelectorAll('.fp-selected[data-fp-selectable="1"]').length;
        const parts = [];
        if (walls) parts.push(`${walls} wall${walls > 1 ? 's' : ''}`);
        if (doors) parts.push(`${doors} door${doors > 1 ? 's' : ''}`);
        if (items) parts.push(`${items} item${items > 1 ? 's' : ''}`);
        if (prims) parts.push(`${prims} element${prims > 1 ? 's' : ''}`);
        breakdownEl.textContent = parts.join(', ');
      }
    }
  }

