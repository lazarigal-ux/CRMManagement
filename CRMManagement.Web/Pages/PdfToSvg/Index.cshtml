        return `data:image/png;base64,${b64}`;
      }

      // ── 3. Gemini / Ollama: use vision AI to interpret free-form instructions ──
      console.log(`[EditImage] Using ${p} vision AI to interpret instructions`);
      _lastEditMode = 'ai-vision';
      _lastEditProvider = p;
      if (_lastEditTiming) { _lastEditTiming.mode = 'ai-vision'; _lastEditTiming.provider = p; }
      return await editImageViaVision(dataUrl, instructions, p);
    }

    /**
     * Downscale a data-URL image so its longest side is at most maxDim pixels.
     * Returns a PNG data-URL. If the image is already small enough, returns it unchanged.
     */
    function downscaleDataUrl(dataUrl, maxDim = 2048, mimeType = 'image/png', quality) {
      return new Promise((resolve) => {
        const img = new Image();
        img.onload = () => {
          const w = img.naturalWidth, h = img.naturalHeight;
          if (w <= maxDim && h <= maxDim) { resolve(dataUrl); return; }
          const scale = maxDim / Math.max(w, h);
          const nw = Math.round(w * scale), nh = Math.round(h * scale);
          const c = document.createElement('canvas');
          c.width = nw; c.height = nh;
          const ctx = c.getContext('2d');
          ctx.fillStyle = '#ffffff';
          ctx.fillRect(0, 0, nw, nh);
          ctx.drawImage(img, 0, 0, nw, nh);
          console.log(`[downscaleDataUrl] ${w}x${h} → ${nw}x${nh} (maxDim=${maxDim})`);
          resolve(c.toDataURL(mimeType, quality));
        };
        img.onerror = () => resolve(dataUrl);
        img.src = dataUrl;
      });
    }

    function estimateDataUrlBytes(dataUrl) {
      try {
        const b64 = String(dataUrl || '').split(',')[1] || '';
        const len = b64.length;
        const padding = b64.endsWith('==') ? 2 : (b64.endsWith('=') ? 1 : 0);
        return Math.max(0, Math.floor((len * 3) / 4) - padding);
      } catch {
        return 0;
      }
    }

    async function rasterizeDataUrl(dataUrl, maxDim, mimeType, quality) {
      return new Promise((resolve) => {
        const img = new Image();
        img.onload = () => {
          const w = img.naturalWidth || 1;
          const h = img.naturalHeight || 1;
          const scale = Math.min(1, maxDim / Math.max(w, h));
          const nw = Math.max(1, Math.round(w * scale));
          const nh = Math.max(1, Math.round(h * scale));
          const c = document.createElement('canvas');
          c.width = nw;
          c.height = nh;
          const ctx = c.getContext('2d');
          ctx.fillStyle = '#ffffff';
          ctx.fillRect(0, 0, nw, nh);
          ctx.drawImage(img, 0, 0, nw, nh);
          resolve(c.toDataURL(mimeType, quality));
        };
        img.onerror = () => resolve(dataUrl);
        img.src = dataUrl;
      });
    }

    async function limitImageForAi(dataUrl, options = {}) {
      const maxDim = Math.max(256, options.maxDim || 2048);
      const maxBytes = Math.max(128 * 1024, options.maxBytes || (4.75 * 1024 * 1024));
      if (!dataUrl) return dataUrl;

      let current = await downscaleDataUrl(dataUrl, maxDim);
      let bytes = estimateDataUrlBytes(current);
      if (bytes <= maxBytes) return current;

      console.warn(`[limitImageForAi] image too large after PNG downscale: ${bytes} bytes > ${maxBytes}. Trying JPEG compression.`);

      const jpegQualities = [0.92, 0.85, 0.78, 0.7, 0.6];
      const dimensionFactors = [1, 0.9, 0.8, 0.7, 0.6, 0.5];
      let best = current;
      let bestBytes = bytes;

      for (const dimFactor of dimensionFactors) {
        const targetDim = Math.max(256, Math.round(maxDim * dimFactor));
        for (const q of jpegQualities) {
          const candidate = await rasterizeDataUrl(current, targetDim, 'image/jpeg', q);
          const candidateBytes = estimateDataUrlBytes(candidate);
          if (candidateBytes < bestBytes) {
            best = candidate;
            bestBytes = candidateBytes;
          }
          if (candidateBytes <= maxBytes) {
            console.log(`[limitImageForAi] compressed image to ${candidateBytes} bytes (dim=${targetDim}, q=${q})`);
            return candidate;
          }
        }
      }

      console.warn(`[limitImageForAi] could not reach target ${maxBytes} bytes; using best effort ${bestBytes} bytes`);
      return best;
    }

    /**
     * Send the image + editing instructions to a vision-capable model (Gemini/Ollama).
