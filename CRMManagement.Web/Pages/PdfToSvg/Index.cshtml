          setEditLog(
            `<span class="p2s-muted-text">Engine:</span> <span class="text-amber-300 font-semibold">${escapeHtml(pLabel)}</span>` +
            `<span class="p2s-sep mx-2">|</span>` +
            `<span class="p2s-muted-text">Mode:</span> <span class="p2s-text">AI vision + pixel ops</span>` +
            `<span class="p2s-sep mx-2">|</span>` +
            `<span class="p2s-muted-text">Ops:</span> <span class="p2s-text">${escapeHtml(opsDesc)}</span>` +
            (summary ? `<span class="p2s-sep mx-2">|</span><span class="p2s-muted-text">AI:</span> <span class="p2s-text">${escapeHtml(summary)}</span>` : '') +
            (timing
              ? ((typeof timing.netMs === 'number' ? `<span class="p2s-sep mx-2">|</span><span class="p2s-muted-text">Net:</span> <span class="p2s-text">${timing.netMs}ms</span>` : '') +
                 (typeof timing.readMs === 'number' ? `<span class="p2s-sep mx-2">|</span><span class="p2s-muted-text">Read:</span> <span class="p2s-text">${timing.readMs}ms</span>` : '') +
                 (typeof timing.parseMs === 'number' ? `<span class="p2s-sep mx-2">|</span><span class="p2s-muted-text">Parse:</span> <span class="p2s-text">${timing.parseMs}ms</span>` : '') +
                 (typeof timing.applyMs === 'number' ? `<span class="p2s-sep mx-2">|</span><span class="p2s-muted-text">Apply:</span> <span class="p2s-text">${timing.applyMs}ms</span>` : ''))
              : '') +
            `<span class="p2s-sep mx-2">|</span>` +
            `<span class="p2s-muted-text">Time:</span> <span class="p2s-text">${ms}ms</span>`
          );
        } else if (mode === 'ai-image-edit') {
          // OpenAI direct image editing
          setEditLog(
            `<span class="p2s-muted-text">Engine:</span> <span class="p2s-text font-semibold">OpenAI</span>` +
            `<span class="p2s-sep mx-2">|</span>` +
            `<span class="p2s-muted-text">Mode:</span> <span class="p2s-text">AI image edit (/images/edit)</span>` +
            (timing
              ? ((typeof timing.netMs === 'number' ? `<span class="p2s-sep mx-2">|</span><span class="p2s-muted-text">Net:</span> <span class="p2s-text">${timing.netMs}ms</span>` : '') +
                 (typeof timing.readMs === 'number' ? `<span class="p2s-sep mx-2">|</span><span class="p2s-muted-text">Read:</span> <span class="p2s-text">${timing.readMs}ms</span>` : '') +
                 (typeof timing.parseMs === 'number' ? `<span class="p2s-sep mx-2">|</span><span class="p2s-muted-text">Parse:</span> <span class="p2s-text">${timing.parseMs}ms</span>` : ''))
              : '') +
            `<span class="p2s-sep mx-2">|</span>` +
            `<span class="p2s-muted-text">Time:</span> <span class="p2s-text">${ms}ms</span>`
          );
        } else {
          setEditLog(
            `<span class="p2s-muted-text">Engine:</span> <span class="p2s-text font-semibold">${escapeHtml(providerLabel)}</span>` +
            `<span class="p2s-sep mx-2">|</span>` +
            `<span class="p2s-muted-text">Time:</span> <span class="p2s-text">${ms}ms</span>`
          );
        }

        if (mode !== 'selection-count') {
          // Show "Done" + feedback buttons
          const fbId = 'aiFb_' + Date.now();
          if (statusEl) {
            statusEl.innerHTML = `<span class="text-emerald-300">Done</span>
              <span class="inline-flex items-center gap-1 ml-3">
                <span class="text-slate-500 text-[10px]">Rate:</span>
                <button type="button" onclick="window._aiFeedback(1,'${fbId}')" class="w-6 h-6 rounded border border-green-500/40 bg-green-900/20 hover:bg-green-900/40 text-green-300 text-[10px] transition inline-flex items-center justify-center" title="Good result — save for training"><i class="fa-solid fa-thumbs-up"></i></button>
                <button type="button" onclick="window._aiFeedback(-1,'${fbId}')" class="w-6 h-6 rounded border border-red-500/40 bg-red-900/20 hover:bg-red-900/40 text-red-300 text-[10px] transition inline-flex items-center justify-center" title="Bad result"><i class="fa-solid fa-thumbs-down"></i></button>
                <span id="${fbId}"></span>
              </span>`;
          }
        }
      } catch (e) {
        const msg = (e && e.message) ? e.message : String(e);
        setEditLog(
          `<span class="text-rose-300 font-semibold">Failed</span>` +
          `<span class="p2s-sep mx-2">|</span>` +
          `<span class="p2s-muted-text">Engine:</span> <span class="p2s-text">${escapeHtml(providerLabel)}</span>` +
          `<span class="p2s-sep mx-2">|</span>` +
          `<span class="p2s-muted-text">Error:</span> <span class="p2s-text">${escapeHtml(msg)}</span>`
        );
        setAiDebugLog({
          mode: isCountRequest ? 'selection-count' : (_lastEditMode || 'unknown'),
          requestSummary: `Provider: ${providerLabel}`,
