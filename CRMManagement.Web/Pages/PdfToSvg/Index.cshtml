  function buildFewShotPrompt(examples) {
    if (!examples || (!examples.dbExamples?.length && !examples.fileExamples?.length)) return '';
    const parts = ['\n\n--- Reference examples from past successful results ---'];

    // File-based examples (with systemPrompt and example instruction/result)
    if (examples.fileExamples?.length) {
      for (const ex of examples.fileExamples) {
        parts.push(`\n[Category: ${ex.Category}]`);
        if (ex.ExampleInstruction) parts.push(`User asked: "${ex.ExampleInstruction}"`);
        if (ex.ExampleResult) parts.push(`Good result: ${ex.ExampleResult}`);
      }
    }

    // DB examples (rated positively by users)
    if (examples.dbExamples?.length) {
      for (const ex of examples.dbExamples) {
        parts.push(`\n[Past result — Category: ${ex.category}, Rating: ${ex.rating > 0 ? 'good' : 'ok'}]`);
        parts.push(`Instruction: "${ex.instruction}"`);
        if (ex.resultText) parts.push(`Result: ${ex.resultText}`);
        if (ex.resultJson) parts.push(`Result JSON: ${ex.resultJson}`);
      }
    }

    parts.push('\n--- End of examples. Now handle the current request: ---\n');
    return parts.join('\n');
  }

