  function deriveDefaultReportName() {
    const fromAnalysis = (lastAnalysis && lastAnalysis.fileName) ? String(lastAnalysis.fileName) : '';
    const fromFile = (pdfInput && pdfInput.files && pdfInput.files[0]) ? String(pdfInput.files[0].name || '') : '';
    const raw = (fromAnalysis || fromFile || '').trim();
    if (!raw) return '';
    return raw.replace(/\.[^.]+$/, '');
