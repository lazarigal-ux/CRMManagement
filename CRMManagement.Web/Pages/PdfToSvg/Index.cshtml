        const t1 = (typeof performance !== 'undefined' && performance.now) ? performance.now() : Date.now();
        const ms = Math.max(0, Math.round(t1 - t0));

        // Build log based on actual execution mode (not just provider label)
        const mode = _lastEditMode || 'unknown';
        const opsDesc = _lastAiOps
            ? (_lastAiOps.operations || []).map(o => `${o.type}${o.color ? '(' + o.color + ')' : ''}`).join(', ')
            : '?';
        const summary = _lastAiOps && _lastAiOps.summary ? _lastAiOps.summary : '';
        const timing = _lastEditTiming || null;

        if (mode === 'selection-count') {
          const cr = window._lastCountResult || {};
          updateCountEditLog(cr);
        } else if (mode === 'direct') {
          // Pre-defined ops applied directly (no AI). Happens only when Provider=local.
          setEditLog(
            `<span class="p2s-muted-text">Execution:</span> <span class="text-emerald-300 font-semibold">Direct (local)</span>` +
            `<span class="p2s-sep mx-2">|</span>` +
            `<span class="p2s-muted-text">Provider:</span> <span class="p2s-text">${escapeHtml(providerLabel)}</span>` +
            `<span class="p2s-sep mx-2">|</span>` +
