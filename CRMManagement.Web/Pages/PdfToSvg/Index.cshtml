    // ── Select Region mode ──
    function clearSelectRegion() {
      selectRegionSelection = null;
      selectRegionStart = null;
      selectRegionPreviewLastPt = null;
      selectRegionRafPending = false;
      if (selectionPanel) selectionPanel.classList.add('hidden');
      if (selectionThumb) selectionThumb.src = '';
      setInstructionPlaceholder(false);
      // Clear overlay drawn for selection
      if (markCanvas && !cropMode) {
        const vctx = markCanvas.getContext('2d', { willReadFrequently: true });
        vctx.clearRect(0, 0, markCanvas.width, markCanvas.height);
      }
    }

    function drawSelectRegionOverlay(x0, y0, w, h) {
      if (!markCanvas) return;
      const vctx = markCanvas.getContext('2d', { willReadFrequently: true });
      const cw = markCanvas.width, ch = markCanvas.height;
      vctx.clearRect(0, 0, cw, ch);

      // Dim everything outside
      vctx.fillStyle = 'rgba(0, 0, 0, 0.40)';
      vctx.fillRect(0, 0, cw, y0);
      vctx.fillRect(0, y0, x0, h);
      vctx.fillRect(x0 + w, y0, cw - x0 - w, h);
      vctx.fillRect(0, y0 + h, cw, ch - y0 - h);

      // Amber selection border
      vctx.strokeStyle = '#f59e0b';
      vctx.lineWidth = Math.max(2, Math.round(Math.min(cw, ch) / 400));
      vctx.setLineDash([6, 4]);
      vctx.strokeRect(x0, y0, w, h);
      vctx.setLineDash([]);

      vctx.strokeStyle = 'rgba(255,255,255,0.5)';
      vctx.lineWidth = 1;
      vctx.strokeRect(x0 + 1, y0 + 1, w - 2, h - 2);

      // Dimensions label
      const lbl = `${Math.round(w)} × ${Math.round(h)}`;
      vctx.font = `bold ${Math.max(12, Math.round(Math.min(cw, ch) / 60))}px sans-serif`;
      vctx.textAlign = 'center';
      const lblY = y0 > 24 ? y0 - 6 : y0 + h + 18;
      vctx.fillStyle = 'rgba(0,0,0,0.6)';
      const tm = vctx.measureText(lbl);
      vctx.fillRect(x0 + w / 2 - tm.width / 2 - 4, lblY - 13, tm.width + 8, 18);
      vctx.fillStyle = '#f59e0b';
      vctx.fillText(lbl, x0 + w / 2, lblY);
    }

    function commitSelectRegion(a, b) {
      if (!markCanvas) return null;
      const x0 = Math.floor(Math.max(0, Math.min(a.x, b.x)));
      const y0 = Math.floor(Math.max(0, Math.min(a.y, b.y)));
      const x1 = Math.ceil(Math.min(markCanvas.width, Math.max(a.x, b.x)));
      const y1 = Math.ceil(Math.min(markCanvas.height, Math.max(a.y, b.y)));
      const w = Math.max(0, x1 - x0);
      const h = Math.max(0, y1 - y0);
      if (w < 10 || h < 10) return null;
      drawSelectRegionOverlay(x0, y0, w, h);
      return { x0, y0, w, h };
    }

    function getSelectionContentBounds(sel) {
      if (!sel || !editCanvas) return null;
      const tmp = document.createElement('canvas');
      tmp.width = sel.w;
      tmp.height = sel.h;
      const tctx = tmp.getContext('2d', { willReadFrequently: true });
      if (!tctx) return null;
      tctx.drawImage(editCanvas, sel.x0, sel.y0, sel.w, sel.h, 0, 0, sel.w, sel.h);

      try {
        const img = tctx.getImageData(0, 0, tmp.width, tmp.height);
        const data = img.data;
        let minX = tmp.width, minY = tmp.height, maxX = -1, maxY = -1;
        for (let y = 0; y < tmp.height; y++) {
          for (let x = 0; x < tmp.width; x++) {
            const i = (y * tmp.width + x) * 4;
            const a = data[i + 3];
            const r = data[i], g = data[i + 1], b = data[i + 2];
            const isContent = a > 20 && (r < 245 || g < 245 || b < 245);
            if (!isContent) continue;
            if (x < minX) minX = x;
            if (y < minY) minY = y;
            if (x > maxX) maxX = x;
            if (y > maxY) maxY = y;
          }
        }

        if (maxX >= minX && maxY >= minY) {
          const pad = 4;
          minX = Math.max(0, minX - pad);
          minY = Math.max(0, minY - pad);
          maxX = Math.min(tmp.width - 1, maxX + pad);
          maxY = Math.min(tmp.height - 1, maxY + pad);
          return {
            x0: minX,
            y0: minY,
            w: maxX - minX + 1,
            h: maxY - minY + 1
          };
        }
      } catch { }

      return {
        x0: 0,
        y0: 0,
        w: sel.w,
        h: sel.h
      };
    }

    function getSelectionDataUrl(sel, localBounds) {
      if (!sel || !editCanvas) return null;
      const bounds = localBounds && localBounds.w > 0 && localBounds.h > 0
        ? localBounds
        : { x0: 0, y0: 0, w: sel.w, h: sel.h };
      const tmp = document.createElement('canvas');
      tmp.width = bounds.w;
      tmp.height = bounds.h;
      const tctx = tmp.getContext('2d');
      if (!tctx) return null;
      tctx.drawImage(editCanvas, sel.x0 + bounds.x0, sel.y0 + bounds.y0, bounds.w, bounds.h, 0, 0, bounds.w, bounds.h);
      return tmp.toDataURL('image/png');
    }

    function getSelectionPreviewDataUrl(sel) {
      const bounds = getSelectionContentBounds(sel);
      return getSelectionDataUrl(sel, bounds);
    }

    function getSelectionEditPayload(sel) {
      if (!sel) return null;
      const bounds = getSelectionContentBounds(sel) || { x0: 0, y0: 0, w: sel.w, h: sel.h };
      const dataUrl = getSelectionDataUrl(sel, bounds);
      if (!dataUrl) return null;
      return {
        dataUrl,
        bounds,
        absolute: {
          x0: sel.x0 + bounds.x0,
          y0: sel.y0 + bounds.y0,
          w: bounds.w,
          h: bounds.h
        }
      };
    }

    async function composeEditedSelectionIntoBase(baseDataUrl, absoluteBounds, editedRegionDataUrl) {
      return await new Promise((resolve, reject) => {
        const baseImg = new Image();
        const regionImg = new Image();
        let ready = 0;

        function onReady() {
          ready++;
          if (ready < 2) return;
          try {
            const out = document.createElement('canvas');
            out.width = baseImg.naturalWidth;
            out.height = baseImg.naturalHeight;
            const octx = out.getContext('2d');
            if (!octx) {
              reject(new Error('Failed to initialize output canvas.'));
              return;
            }
            octx.fillStyle = '#ffffff';
            octx.fillRect(0, 0, out.width, out.height);
            octx.drawImage(baseImg, 0, 0);
            octx.drawImage(regionImg, absoluteBounds.x0, absoluteBounds.y0, absoluteBounds.w, absoluteBounds.h);
            resolve(out.toDataURL('image/png'));
          } catch (err) {
            reject(err);
          }
        }

        baseImg.onload = onReady;
        regionImg.onload = onReady;
        baseImg.onerror = () => reject(new Error('Failed to load base image for selected object edit.'));
        regionImg.onerror = () => reject(new Error('Failed to load edited selected object image.'));
        baseImg.src = baseDataUrl;
        regionImg.src = editedRegionDataUrl;
      });
    }

    async function applyEditsToSelectedObject(baseDataUrl, sel, instructions, provider) {
      const payload = getSelectionEditPayload(sel);
      if (!payload) throw new Error('Failed to capture the selected object.');
      const editedRegion = await editImageByAiProvider(payload.dataUrl, instructions, provider);
      return await composeEditedSelectionIntoBase(baseDataUrl, payload.absolute, editedRegion);
    }

    function showSelectionPanel(sel) {
      if (!sel || !selectionPanel) return;
      const regionUrl = getSelectionPreviewDataUrl(sel);
      if (!regionUrl) return;
      if (selectionThumb) selectionThumb.src = regionUrl;
      if (selectionDims) selectionDims.textContent = `${sel.w} × ${sel.h} px`;
      setInstructionPlaceholder(true);
      selectionPanel.classList.remove('hidden');
    }

    if (btnSelectRegion) {
      btnSelectRegion.onclick = () => {
        // Turn off crop mode if active
        if (cropMode) {
          cropMode = false;
          isDrawing = false;
          btnCrop.classList.remove('ring-2', 'ring-violet-300/50');
          setStatusMsg('');
        }

        selectRegionMode = !selectRegionMode;
        if (!selectRegionMode) {
          isDrawing = false;
          selectRegionStart = null;
          selectRegionPreviewLastPt = null;
          selectRegionRafPending = false;
          // Don't clear selection (keep panel visible)
        }
        if (markCanvas) {
          markCanvas.style.pointerEvents = selectRegionMode ? 'auto' : 'none';
          markCanvas.style.cursor = selectRegionMode ? 'crosshair' : '';
        }
        if (canvasWrap) canvasWrap.style.cursor = selectRegionMode ? 'crosshair' : '';
        btnSelectRegion.classList.toggle('ring-2', selectRegionMode);
        btnSelectRegion.classList.toggle('ring-amber-300/50', selectRegionMode);
        setStatusMsg(selectRegionMode ? 'Select Object: drag around one object, then ask how many similar objects exist on the main drawing' : '');
      };
    }

    if (btnClearSelection) {
      btnClearSelection.onclick = () => {
        clearSelectRegion();
        setStatusMsg('Selection cleared');
      };
    }

    setInstructionPlaceholder(false);

    refreshUndoRedoButtons();

    // Expose minimal state for Save/Load.
    window._pdfImageGetState = function () {
      return {
        selectedIdx: selectedIdx,
        instructions: instrEl ? (instrEl.value || '') : ''
      };
    };
    window._pdfImageFlushCurrentToPages = function () {
      commitCurrentToPageList();
      return lastPdfPages;
    };

    // Export the raster exactly as represented by the Image Editor for vectorization.
    // - If crop selection exists: export only the selected region (without permanently cropping the editor).
    // - If there are removal marks in the mask: apply them to the exported bitmap (without mutating the editor).
    window._pdfImageExportForVectorize = async function () {
      if (!editCanvas || !editCanvas.width || !editCanvas.height) {
        console.warn('[BuildFP] export: no editCanvas or zero size');
        return null;
      }

      try { commitCurrentToPageList(); } catch { }

      const useCrop = !!(cropSelection && cropSelection.w > 5 && cropSelection.h > 5);
      const sx = useCrop ? Math.max(0, Math.floor(cropSelection.x0)) : 0;
      const sy = useCrop ? Math.max(0, Math.floor(cropSelection.y0)) : 0;
      const sw = useCrop ? Math.min(editCanvas.width - sx, Math.floor(cropSelection.w)) : editCanvas.width;
      const sh = useCrop ? Math.min(editCanvas.height - sy, Math.floor(cropSelection.h)) : editCanvas.height;

      console.group('%c[BuildFP] Export Image Data', 'color:#0af;font-weight:bold');
      console.log('editCanvas actual pixels:', editCanvas.width, 'x', editCanvas.height);
      console.log('editCanvas CSS display size:', editCanvas.style.width, 'x', editCanvas.style.height);
      console.log('markCanvas actual pixels:', markCanvas.width, 'x', markCanvas.height);
      console.log('maskCanvas actual pixels:', maskCanvas.width, 'x', maskCanvas.height);
      console.log('zoom:', zoom);
      console.log('cropSelection:', cropSelection ? JSON.stringify(cropSelection) : 'null');
      console.log('useCrop:', useCrop, '| source rect: sx=', sx, 'sy=', sy, 'sw=', sw, 'sh=', sh);
      console.log('export image size (what goes to server):', sw, 'x', sh);
      console.log('aspect ratio of export:', (sw / sh).toFixed(4));
      console.groupEnd();

      if (sw <= 1 || sh <= 1) { console.warn('[BuildFP] export: region too small'); return null; }

      const outCanvas = document.createElement('canvas');
      outCanvas.width = sw;
      outCanvas.height = sh;
      const octx = outCanvas.getContext('2d', { willReadFrequently: true });
      octx.fillStyle = '#ffffff';
      octx.fillRect(0, 0, sw, sh);
      octx.drawImage(editCanvas, sx, sy, sw, sh, 0, 0, sw, sh);

      let hasMask = false;
      try {
        const mctx = maskCanvas.getContext('2d', { willReadFrequently: true });
        const mImg = mctx.getImageData(sx, sy, sw, sh);
        const md = mImg.data;
        for (let i = 3; i < md.length; i += 4) {
          if (md[i] > 0) { hasMask = true; break; }
        }

        if (hasMask) {
          const outImg = octx.getImageData(0, 0, sw, sh);
          const od = outImg.data;
          for (let i = 0; i < od.length; i += 4) {
            if (md[i + 3] > 0) {
              od[i] = 255; od[i + 1] = 255; od[i + 2] = 255; od[i + 3] = 255;
            }
          }
          octx.putImageData(outImg, 0, 0);
        }
      } catch { }

      const blob = await new Promise(resolve => {
        try { outCanvas.toBlob(resolve, 'image/png'); } catch { resolve(null); }
      });
      if (!blob) { console.warn('[BuildFP] export: toBlob returned null'); return null; }

      console.group('%c[BuildFP] Export Result', 'color:#0f0;font-weight:bold');
      console.log('output image:', sw, 'x', sh, '| blob size:', blob.size, 'bytes');
      console.log('usedCrop:', useCrop, '| usedMarks:', hasMask);
      console.log('aspect ratio:', (sw / sh).toFixed(4));
      console.groupEnd();
      return { blob, width: sw, height: sh, usedCrop: useCrop, usedMarks: hasMask };
    };

    if (brushSlider) {
      if (!brushSlider.value) brushSlider.value = '14';
      brushSizePx = parseInt(brushSlider.value || '0', 10) || 0;
      if (brushLabel) brushLabel.textContent = String(brushSizePx);
      brushSlider.addEventListener('input', () => {
        brushSizePx = parseInt(brushSlider.value || '0', 10) || 0;
        if (brushLabel) brushLabel.textContent = String(brushSizePx);
      });
    }

    // Bind crop events on canvasWrap (regular div, always receives events)
    // instead of markCanvas (canvas element, depends on pointer-events CSS).
    // This is more robust, especially in iframe contexts.
    if (canvasWrap && markCanvas) {
      markCanvas.style.pointerEvents = 'none';

      // Remove old crop listeners if present, to avoid stale-closure duplicates.
      if (canvasWrap._cropMousedown) canvasWrap.removeEventListener('mousedown', canvasWrap._cropMousedown);
      if (canvasWrap._cropMousemove) canvasWrap.removeEventListener('mousemove', canvasWrap._cropMousemove);
      if (window._cropMouseup) window.removeEventListener('mouseup', window._cropMouseup);

      canvasWrap._cropMousedown = function (ev) {
        // ── Select Region mode ──
        if (selectRegionMode) {
          ev.preventDefault();
          ev.stopPropagation();
          const pt = canvasPointFromEvent(ev);
          selectRegionStart = pt;
          selectRegionPreviewLastPt = pt;
          selectRegionRafPending = false;
          isDrawing = true;
          return;
        }
        if (!cropMode) return;
        ev.preventDefault();
        ev.stopPropagation();
        const pt = canvasPointFromEvent(ev);

        // Check if clicking on a resize handle of an existing selection
        if (cropSelection) {
          const handle = hitTestCropHandle(pt);
          if (handle) {
            cropResizeHandle = handle;
            isDrawing = true;
            console.log('[Crop] resize handle:', handle);
            return;
          }
        }

        // Start new selection
        cropResizeHandle = null;
        isDrawing = true;
        cropStart = pt;
        cropPreviewLastPt = pt;
        cropPreviewRafPending = false;
        console.log('[Crop] mousedown start:', JSON.stringify(cropStart), 'canvas:', markCanvas.width, 'x', markCanvas.height);
      };

      canvasWrap._cropMousemove = function (ev) {
        // ── Select Region mode ──
        if (selectRegionMode && isDrawing && selectRegionStart) {
          ev.preventDefault();
          const pt = canvasPointFromEvent(ev);
          selectRegionPreviewLastPt = pt;
          if (selectRegionRafPending) return;
          selectRegionRafPending = true;
          window.requestAnimationFrame(() => {
            selectRegionRafPending = false;
            if (!selectRegionMode || !selectRegionStart || !selectRegionPreviewLastPt) return;
            const x0 = Math.min(selectRegionStart.x, selectRegionPreviewLastPt.x);
            const y0 = Math.min(selectRegionStart.y, selectRegionPreviewLastPt.y);
            const w = Math.max(1, Math.abs(selectRegionPreviewLastPt.x - selectRegionStart.x));
            const h = Math.max(1, Math.abs(selectRegionPreviewLastPt.y - selectRegionStart.y));
            drawSelectRegionOverlay(x0, y0, w, h);
          });
          return;
        }
        if (!cropMode) return;

        // Update cursor based on handle hover
        if (!isDrawing && cropSelection) {
          const pt = canvasPointFromEvent(ev);
          const handle = hitTestCropHandle(pt);
          const cursorMap = { tl: 'nwse-resize', br: 'nwse-resize', tr: 'nesw-resize', bl: 'nesw-resize', tm: 'ns-resize', bm: 'ns-resize', ml: 'ew-resize', mr: 'ew-resize' };
          canvasWrap.style.cursor = handle ? cursorMap[handle] : 'crosshair';
        }

        if (!isDrawing) return;
        ev.preventDefault();
        const pt = canvasPointFromEvent(ev);

        // Handle resize
        if (cropResizeHandle && cropSelection) {
          if (cropPreviewRafPending) return;
          cropPreviewRafPending = true;
          window.requestAnimationFrame(() => {
            cropPreviewRafPending = false;
            resizeCropByHandle(cropResizeHandle, canvasPointFromEvent(ev));
          });
          return;
        }

        // Handle new selection drawing
        if (!cropStart) return;
        cropPreviewLastPt = pt;
        if (cropPreviewRafPending) return;
        cropPreviewRafPending = true;
        window.requestAnimationFrame(() => {
          cropPreviewRafPending = false;
          if (!cropMode || !cropStart || !cropPreviewLastPt) return;
          drawCropPreview(cropStart, cropPreviewLastPt);
        });
      };

      window._cropMouseup = function (ev) {
        // ── Select Region mode ──
        if (selectRegionMode && isDrawing && selectRegionStart) {
          const pt = canvasPointFromEvent(ev);
          selectRegionSelection = commitSelectRegion(selectRegionStart, pt);
          selectRegionStart = null;
          isDrawing = false;
          selectRegionPreviewLastPt = null;
          selectRegionRafPending = false;
          if (selectRegionSelection) {
            showSelectionPanel(selectRegionSelection);
            setStatusMsg(`Object selected: ${selectRegionSelection.w} × ${selectRegionSelection.h} — ask how many similar objects exist and press Apply`);
            // Auto-turn off select mode after successful selection
            selectRegionMode = false;
            if (markCanvas) { markCanvas.style.pointerEvents = 'none'; markCanvas.style.cursor = ''; }
            if (canvasWrap) canvasWrap.style.cursor = '';
            if (btnSelectRegion) { btnSelectRegion.classList.remove('ring-2', 'ring-amber-300/50'); }
            if (instrEl) instrEl.focus();
          } else {
            setStatusMsg('Selection too small — try again');
          }
          return;
        }
        if (!cropMode || !isDrawing) return;

        // Finish resize
        if (cropResizeHandle) {
          const pt = canvasPointFromEvent(ev);
          resizeCropByHandle(cropResizeHandle, pt);
          cropResizeHandle = null;
          isDrawing = false;
          console.log('[Crop] resize done:', cropSelection ? JSON.stringify(cropSelection) : 'null');
          setStatusMsg(cropSelection ? `Crop: ${cropSelection.w} × ${cropSelection.h} — click Apply Crop` : 'Crop too small');
          return;
        }

        // Finish new selection
        if (!cropStart) { isDrawing = false; return; }
        const pt = canvasPointFromEvent(ev);
        console.log('[Crop] mouseup end:', JSON.stringify(pt));
        cropSelection = commitCropRect(cropStart, pt);
        cropStart = null;
        isDrawing = false;
        cropPreviewSnapshot = null;
        cropPreviewLastPt = null;
        cropPreviewRafPending = false;
        cropResizeHandle = null;
        console.log('[Crop] selection:', cropSelection ? JSON.stringify(cropSelection) : 'null (too small)');
        setStatusMsg(cropSelection ? `Crop: ${cropSelection.w} × ${cropSelection.h} — click Apply Crop` : 'Crop too small');
      };

      canvasWrap.addEventListener('mousedown', canvasWrap._cropMousedown);
      canvasWrap.addEventListener('mousemove', canvasWrap._cropMousemove);
      window.addEventListener('mouseup', window._cropMouseup);
      console.log('[Crop] Event listeners bound on canvasWrap (clean re-registration)');
    } else {
      console.warn('[Crop] canvasWrap or markCanvas element NOT found');
    }
  }

  // ── Image editing (client-side, instruction-driven) ──
  // Currently supported:
  // - remove red lines / remove red / הסר קווים אדומים / הסר אדום
  // - remove thin lines / remove thin / הסר קווים דקים / קווים דקים
  async function editImageByInstructions(dataUrl, instructions) {
    const instr = (instructions || '').toLowerCase();
    const removeRed = instr.includes('remove red') || instr.includes('red') || instr.includes('אדום') || instr.includes('להוריד אדום') || instr.includes('הסר אדום') || instr.includes('הסר קווים אדומים');
    const removeThin = instr.includes('remove thin') || instr.includes('thin lines') || instr.includes('הסר קווים דקים') || instr.includes('קווים דקים');
    if (!removeRed && !removeThin) return dataUrl;

    return new Promise((resolve) => {
      const img = new Image();
      img.onload = () => {
        const canvas = document.createElement('canvas');
        canvas.width = img.naturalWidth;
        canvas.height = img.naturalHeight;
        const ctx = canvas.getContext('2d', { willReadFrequently: true });
        ctx.drawImage(img, 0, 0);

        const imageData = ctx.getImageData(0, 0, canvas.width, canvas.height);
        const d = imageData.data;

        const w = canvas.width;
        const h = canvas.height;

        function idxOf(x, y) { return (y * w + x) * 4; }

        // Pass 1: remove red-ish pixels
        if (removeRed) {
          for (let i = 0; i < d.length; i += 4) {
            const r = d[i], g = d[i + 1], b = d[i + 2];
            // Heuristic for "red-ish" pixels (covers anti-aliased reds too)
            const isRed = r > 120 && r > g * 1.25 && r > b * 1.25 && (g + b) < r * 1.4;
            if (isRed) {
              d[i] = 255; d[i + 1] = 255; d[i + 2] = 255;
            }
          }
        }

        // Pass 2: remove thin dark lines (neighbor-count based)
        if (removeThin) {
          const darkThreshold = 185;      // higher = more aggressive
          const neighborMax = 3;          // <=3 neighbors treated as thin
          const passes = 2;

          const mask = new Uint8Array(w * h);
          for (let y = 0; y < h; y++) {
            for (let x = 0; x < w; x++) {
              const i = idxOf(x, y);
              const r = d[i], g = d[i + 1], b = d[i + 2];
              // luminance-ish
              const lum = (r * 0.299 + g * 0.587 + b * 0.114);
              mask[y * w + x] = lum < darkThreshold ? 1 : 0;
            }
          }

          let cur = mask;
          for (let pass = 0; pass < passes; pass++) {
            const next = new Uint8Array(cur);
            for (let y = 1; y < h - 1; y++) {
              for (let x = 1; x < w - 1; x++) {
                const p = y * w + x;
                if (cur[p] === 0) continue;
                let n = 0;
                // 8-neighborhood count
                n += cur[p - w - 1]; n += cur[p - w]; n += cur[p - w + 1];
                n += cur[p - 1];                 n += cur[p + 1];
                n += cur[p + w - 1]; n += cur[p + w]; n += cur[p + w + 1];
                if (n <= neighborMax) next[p] = 0;
              }
            }
            cur = next;
          }

          // Apply: pixels that were dark but became cleared are "thin" → paint white
          for (let y = 0; y < h; y++) {
            for (let x = 0; x < w; x++) {
              const p = y * w + x;
              if (mask[p] === 1 && cur[p] === 0) {
                const i = idxOf(x, y);
                d[i] = 255; d[i + 1] = 255; d[i + 2] = 255;
              }
            }
          }
        }

        ctx.putImageData(imageData, 0, 0);
        resolve(canvas.toDataURL('image/png'));
      };
      img.onerror = () => resolve(dataUrl);
      img.src = dataUrl;
    });
  }

  // ── Processing overlay helpers ──
  const _procOverlay = document.getElementById('p2sProcessingOverlay');
  const _procText    = document.getElementById('p2sProcessingText');
  const _procSub     = document.getElementById('p2sProcessingSub');
  function showProcessing(msg, sub) {
    if (_procText) _procText.textContent = msg || 'Processing PDF…';
    if (_procSub)  _procSub.textContent  = sub || '';
    if (_procOverlay) _procOverlay.classList.add('active');
  }
  function hideProcessing() {
    if (_procOverlay) _procOverlay.classList.remove('active');
  }
  function updateProcessing(msg, sub) {
    if (_procText && msg) _procText.textContent = msg;
    if (_procSub  && sub !== undefined) _procSub.textContent = sub;
  }

  // ── New Build PDF Image button (in tabPdfImage) ──
  const btnBuildPdfImage = document.getElementById('btnBuildPdfImage');
  if (btnBuildPdfImage) {
    btnBuildPdfImage.addEventListener('click', function() {
      // Sync DPI from new input to original hidden one
      const newDpi = document.getElementById('pdfImageBuildDpi');
      const origDpi = document.getElementById('pdfPreviewDpi');
      if (newDpi && origDpi) origDpi.value = newDpi.value;
      // Trigger the original analyze button
      if (btnAnalyze) btnAnalyze.click();
    });
  }

  // ── Analyze ──
  btnAnalyze.addEventListener('click', async function () {
    const f = pdfInput.files && pdfInput.files[0];
    if (!f) { setStatus('Select a PDF first.', 'error'); return; }

    btnAnalyze.disabled = true;
    if (btnBuildPdfImage) btnBuildPdfImage.disabled = true;
    const analyzeIcon = document.getElementById('analyzeIcon');
    const analyzeText = document.getElementById('analyzeText');
    const analyzeSpinner = document.getElementById('analyzeSpinner');
    if (analyzeIcon) analyzeIcon.classList.add('opacity-0');
    if (analyzeText) analyzeText.add ? analyzeText.classList.add('opacity-0') : null;
    if (analyzeSpinner) analyzeSpinner.classList.remove('opacity-0');
    showProcessing('Rasterizing PDF…', 'Converting PDF pages to high-resolution images');
    setStatus('Analyzing floor plan…');

    try {
      const fd = new FormData();
      fd.append('pdf', f, f.name);

      const qs = new URLSearchParams();
      qs.set('includeCrops', 'true');

      const provider = document.getElementById('provider');
      qs.set('provider', provider ? provider.value : 'openai');

      if (detectedLayers.length && selectedVisibleLayerIndices.size !== detectedLayers.length) {
        qs.set('visibleLayers', Array.from(selectedVisibleLayerIndices.values()).sort((a,b)=>a-b).join(','));
      }

      // Keep preview consistent
      await renderPdfPreview(f, qs.get('visibleLayers') || '', getSelectedPdfPreviewDpi());

      updateProcessing('Analyzing floor plan…', 'Detecting equipment, walls and doors');

      const resp = await fetch(`${ANALYZE_ENDPOINT}?${qs.toString()}`, { method: 'POST', body: fd, headers: { 'X-Client-Id': 'admin' } });
      const text = await resp.text();
      if (!resp.ok) { setStatus(`Analysis failed (${resp.status}). ${text}`, 'error'); return; }

      const analysis = safeJsonParse(text, null);
      if (!analysis) { setStatus('Invalid JSON response.', 'error'); return; }

      updateProcessing('Building PDF Image…', 'Almost done');

      // Requirement: Analyze must NOT update Floor Plan/SVG (even first time).
      // Cache the analysis and let the user explicitly apply it from the PDF Image tab.
      pendingAnalysis = analysis;
      setStatus(`Done — ${analysis.totalHits || 0} hits, ${analysis.uniqueIds || 0} unique IDs (Floor Plan not updated)`, 'success');
      switchTab('tabPdfImage');
    } catch (e) {
      setStatus('Analysis failed: ' + (e && e.message ? e.message : String(e)), 'error');
    } finally {
      hideProcessing();
      btnAnalyze.disabled = false;
      if (btnBuildPdfImage) btnBuildPdfImage.disabled = false;
      if (analyzeIcon) analyzeIcon.classList.remove('opacity-0');
      if (analyzeText) analyzeText.classList.remove('opacity-0');
      if (analyzeSpinner) analyzeSpinner.classList.add('opacity-0');
    }
  });

})();
</script>
}
