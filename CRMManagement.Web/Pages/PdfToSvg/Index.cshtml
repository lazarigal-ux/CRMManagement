      } catch (e) {
        console.error('[PDF Image] Remove Arrows failed:', e);
        setStatus('Remove arrows error: ' + (e && (e.message || e) ? (e.message || e) : 'Unknown'), 'error');
      } finally {
        btnRemoveArrows.innerHTML = prevHtml;
        btnRemoveArrows.disabled = false;
        btnRemoveArrows.dataset.busy = '0';
      }
    }

    if (btnRemoveHatching && !btnRemoveHatching.dataset.bound) {
      btnRemoveHatching.dataset.bound = '1';
      btnRemoveHatching.addEventListener('click', (ev) => {
        ev.preventDefault();
        runRemoveHatching();
      });
    }

    if (btnRemoveArrows && !btnRemoveArrows.dataset.bound) {
      btnRemoveArrows.dataset.bound = '1';
      btnRemoveArrows.addEventListener('click', (ev) => {
        ev.preventDefault();
        runRemoveArrows();
      });
    }

    async function doUndo() {
      if (undoStack.length === 0) return;
      if (currentDataUrl) redoStack.push(currentDataUrl);
      const prev = undoStack.pop();
      currentDataUrl = prev;
      await drawDataUrlToCanvas(currentDataUrl);
      commitCurrentToPageList();
      refreshUndoRedoButtons();
      setStatusMsg('Undo');
    }

    async function doRedo() {
      if (redoStack.length === 0) return;
      if (currentDataUrl) {
        undoStack.push(currentDataUrl);
        if (undoStack.length > maxUndo) undoStack.shift();
      }
      const next = redoStack.pop();
      currentDataUrl = next;
      await drawDataUrlToCanvas(currentDataUrl);
      commitCurrentToPageList();
      refreshUndoRedoButtons();
      setStatusMsg('Redo');
    }

    function canvasPointFromEvent(ev) {
      const rect = markCanvas.getBoundingClientRect();
      const scaleX = markCanvas.width / Math.max(1, rect.width);
      const scaleY = markCanvas.height / Math.max(1, rect.height);
      let x = (ev.clientX - rect.left) * scaleX;
      let y = (ev.clientY - rect.top) * scaleY;
      // Clamp to canvas bounds.
      x = Math.max(0, Math.min(markCanvas.width, x));
      y = Math.max(0, Math.min(markCanvas.height, y));
      return { x, y };
    }

    function getBrushSize() {
      if (brushSizePx && brushSizePx > 0) return brushSizePx;
      return Math.max(8, Math.round(markCanvas.width / 220));
    }

    function drawMarkLine(a, b) {
      if (!markCanvas) return;
      const brush = getBrushSize();

      const vctx = markCanvas.getContext('2d', { willReadFrequently: true });
      vctx.lineCap = 'round';
      vctx.lineJoin = 'round';
      vctx.strokeStyle = 'rgba(239, 68, 68, 0.35)';
      vctx.lineWidth = brush;
      vctx.beginPath();
      vctx.moveTo(a.x, a.y);
      vctx.lineTo(b.x, b.y);
      vctx.stroke();

      const xctx = maskCanvas.getContext('2d', { willReadFrequently: true });
      xctx.lineCap = 'round';
      xctx.lineJoin = 'round';
      xctx.strokeStyle = 'rgba(255,255,255,1)';
      xctx.lineWidth = brush;
      xctx.beginPath();
      xctx.moveTo(a.x, a.y);
      xctx.lineTo(b.x, b.y);
      xctx.stroke();
    }

    function drawExcludeLine(a, b) {
      if (!protectCanvas) return;
      const brush = getBrushSize();

      const vctx = protectCanvas.getContext('2d', { willReadFrequently: true });
      vctx.lineCap = 'round';
      vctx.lineJoin = 'round';
      vctx.strokeStyle = 'rgba(16, 185, 129, 0.28)';
      vctx.lineWidth = brush;
      vctx.beginPath();
      vctx.moveTo(a.x, a.y);
      vctx.lineTo(b.x, b.y);
      vctx.stroke();

      const xctx = protectMaskCanvas.getContext('2d', { willReadFrequently: true });
      xctx.lineCap = 'round';
      xctx.lineJoin = 'round';
      xctx.strokeStyle = 'rgba(255,255,255,1)';
      xctx.lineWidth = brush;
      xctx.beginPath();
      xctx.moveTo(a.x, a.y);
      xctx.lineTo(b.x, b.y);
      xctx.stroke();
    }

    function drawMarkRect(a, b) {
      if (!markCanvas) return;
      const brush = getBrushSize();
      const x0 = Math.min(a.x, b.x);
      const y0 = Math.min(a.y, b.y);
      const x1 = Math.max(a.x, b.x);
      const y1 = Math.max(a.y, b.y);
      const w = Math.max(1, x1 - x0);
      const h = Math.max(1, y1 - y0);

      // Visual overlay: semi-transparent fill
      const vctx = markCanvas.getContext('2d', { willReadFrequently: true });
      vctx.fillStyle = 'rgba(239, 68, 68, 0.25)';
      vctx.fillRect(x0, y0, w, h);
      vctx.strokeStyle = 'rgba(239, 68, 68, 0.55)';
      vctx.lineWidth = Math.max(2, Math.round(brush / 4));
      vctx.strokeRect(x0, y0, w, h);

      // Mask: solid alpha
      const xctx = maskCanvas.getContext('2d', { willReadFrequently: true });
      xctx.fillStyle = 'rgba(255,255,255,1)';
      xctx.fillRect(x0, y0, w, h);
    }

    function drawRectPreview(a, b) {
      if (!markCanvas || !rectPreviewSnapshot) return;
      const vctx = markCanvas.getContext('2d', { willReadFrequently: true });

      // restore overlay snapshot, then draw preview on top
      vctx.putImageData(rectPreviewSnapshot, 0, 0);

      const brush = getBrushSize();
      const x0 = Math.min(a.x, b.x);
      const y0 = Math.min(a.y, b.y);
      const x1 = Math.max(a.x, b.x);
      const y1 = Math.max(a.y, b.y);
      const w = Math.max(1, x1 - x0);
      const h = Math.max(1, y1 - y0);

      vctx.fillStyle = 'rgba(239, 68, 68, 0.18)';
      vctx.fillRect(x0, y0, w, h);
      vctx.strokeStyle = 'rgba(239, 68, 68, 0.65)';
      vctx.lineWidth = Math.max(2, Math.round(brush / 4));
      vctx.strokeRect(x0, y0, w, h);
    }

    // ── Enhanced crop visual: dimmed overlay + bright border + resize handles ──
    const CROP_HANDLE_SIZE = 10; // px in canvas coords

    function drawCropOverlay(x0, y0, w, h) {
      if (!markCanvas) return;
      const vctx = markCanvas.getContext('2d', { willReadFrequently: true });
      const cw = markCanvas.width, ch = markCanvas.height;
      vctx.clearRect(0, 0, cw, ch);

      // Dim everything outside the selection
      vctx.fillStyle = 'rgba(0, 0, 0, 0.45)';
      vctx.fillRect(0, 0, cw, y0);                          // top
      vctx.fillRect(0, y0, x0, h);                           // left
      vctx.fillRect(x0 + w, y0, cw - x0 - w, h);            // right
      vctx.fillRect(0, y0 + h, cw, ch - y0 - h);            // bottom

      // Bright selection border (cyan, animated dashes)
      vctx.strokeStyle = '#00e5ff';
      vctx.lineWidth = Math.max(2, Math.round(Math.min(cw, ch) / 400));
      vctx.setLineDash([8, 5]);
      vctx.strokeRect(x0, y0, w, h);
      vctx.setLineDash([]);

      // Second solid inner border
      vctx.strokeStyle = 'rgba(255,255,255,0.6)';
      vctx.lineWidth = 1;
      vctx.strokeRect(x0 + 1, y0 + 1, w - 2, h - 2);

      // Rule-of-thirds grid lines
      vctx.strokeStyle = 'rgba(255,255,255,0.18)';
      vctx.lineWidth = 1;
      for (let i = 1; i <= 2; i++) {
        const gx = x0 + (w / 3) * i;
        const gy = y0 + (h / 3) * i;
        vctx.beginPath(); vctx.moveTo(gx, y0); vctx.lineTo(gx, y0 + h); vctx.stroke();
        vctx.beginPath(); vctx.moveTo(x0, gy); vctx.lineTo(x0 + w, gy); vctx.stroke();
      }

      // Draw 8 resize handles (corners + edge midpoints)
      const hs = Math.max(CROP_HANDLE_SIZE, Math.round(Math.min(cw, ch) / 120));
      const handles = getCropHandles(x0, y0, w, h, hs);
      vctx.fillStyle = '#00e5ff';
      vctx.strokeStyle = '#ffffff';
      vctx.lineWidth = 1.5;
      for (const r of handles) {
        vctx.fillRect(r.rx, r.ry, r.rw, r.rh);
        vctx.strokeRect(r.rx, r.ry, r.rw, r.rh);
      }

      // Dimensions label
      const lbl = `${Math.round(w)} × ${Math.round(h)}`;
      vctx.font = `bold ${Math.max(12, Math.round(Math.min(cw, ch) / 60))}px sans-serif`;
      vctx.textAlign = 'center';
      const lblY = y0 > 24 ? y0 - 6 : y0 + h + 18;
      vctx.fillStyle = 'rgba(0,0,0,0.6)';
      const tm = vctx.measureText(lbl);
      vctx.fillRect(x0 + w / 2 - tm.width / 2 - 4, lblY - 13, tm.width + 8, 18);
      vctx.fillStyle = '#00e5ff';
      vctx.fillText(lbl, x0 + w / 2, lblY);
    }

    function getCropHandles(x0, y0, w, h, hs) {
      const half = hs / 2;
      return [
        { id: 'tl', rx: x0 - half,         ry: y0 - half,         rw: hs, rh: hs },
        { id: 'tr', rx: x0 + w - half,      ry: y0 - half,         rw: hs, rh: hs },
        { id: 'bl', rx: x0 - half,          ry: y0 + h - half,     rw: hs, rh: hs },
        { id: 'br', rx: x0 + w - half,      ry: y0 + h - half,     rw: hs, rh: hs },
        { id: 'tm', rx: x0 + w / 2 - half,  ry: y0 - half,         rw: hs, rh: hs },
        { id: 'bm', rx: x0 + w / 2 - half,  ry: y0 + h - half,     rw: hs, rh: hs },
        { id: 'ml', rx: x0 - half,          ry: y0 + h / 2 - half, rw: hs, rh: hs },
        { id: 'mr', rx: x0 + w - half,      ry: y0 + h / 2 - half, rw: hs, rh: hs },
      ];
    }

    function hitTestCropHandle(pt) {
      if (!cropSelection) return null;
      const { x0, y0, w, h } = cropSelection;
      const hs = Math.max(CROP_HANDLE_SIZE, Math.round(Math.min(markCanvas.width, markCanvas.height) / 120));
      const margin = hs * 1.2; // generous hit area
      const handles = getCropHandles(x0, y0, w, h, hs);
      for (const r of handles) {
        if (pt.x >= r.rx - margin / 2 && pt.x <= r.rx + r.rw + margin / 2 &&
            pt.y >= r.ry - margin / 2 && pt.y <= r.ry + r.rh + margin / 2) {
          return r.id;
        }
      }
      return null;
    }

    function resizeCropByHandle(handleId, pt) {
      if (!cropSelection) return;
      let { x0, y0, w, h } = cropSelection;
      let x1 = x0 + w, y1 = y0 + h;
      const minSz = 10;

      switch (handleId) {
        case 'tl': x0 = Math.min(pt.x, x1 - minSz); y0 = Math.min(pt.y, y1 - minSz); break;
        case 'tr': x1 = Math.max(pt.x, x0 + minSz); y0 = Math.min(pt.y, y1 - minSz); break;
        case 'bl': x0 = Math.min(pt.x, x1 - minSz); y1 = Math.max(pt.y, y0 + minSz); break;
        case 'br': x1 = Math.max(pt.x, x0 + minSz); y1 = Math.max(pt.y, y0 + minSz); break;
        case 'tm': y0 = Math.min(pt.y, y1 - minSz); break;
        case 'bm': y1 = Math.max(pt.y, y0 + minSz); break;
        case 'ml': x0 = Math.min(pt.x, x1 - minSz); break;
        case 'mr': x1 = Math.max(pt.x, x0 + minSz); break;
      }

      // Clamp to canvas
      x0 = Math.max(0, x0); y0 = Math.max(0, y0);
      x1 = Math.min(markCanvas.width, x1); y1 = Math.min(markCanvas.height, y1);

      cropSelection = { x0: Math.floor(x0), y0: Math.floor(y0), w: Math.floor(x1 - x0), h: Math.floor(y1 - y0) };
      drawCropOverlay(cropSelection.x0, cropSelection.y0, cropSelection.w, cropSelection.h);
    }

    function drawCropPreview(a, b) {
      const x0 = Math.min(a.x, b.x);
      const y0 = Math.min(a.y, b.y);
      const x1 = Math.max(a.x, b.x);
      const y1 = Math.max(a.y, b.y);
      const w = Math.max(1, x1 - x0);
      const h = Math.max(1, y1 - y0);
      drawCropOverlay(x0, y0, w, h);
    }

    function commitCropRect(a, b) {
      if (!markCanvas) return null;
      const x0 = Math.floor(Math.max(0, Math.min(a.x, b.x)));
      const y0 = Math.floor(Math.max(0, Math.min(a.y, b.y)));
      const x1 = Math.ceil(Math.min(markCanvas.width, Math.max(a.x, b.x)));
      const y1 = Math.ceil(Math.min(markCanvas.height, Math.max(a.y, b.y)));
      const w = Math.max(0, x1 - x0);
      const h = Math.max(0, y1 - y0);
      if (w < 5 || h < 5) return null;

      drawCropOverlay(x0, y0, w, h);
      return { x0, y0, w, h };
    }

    async function applyMarks() {
      if (!editCanvas) return;
      pushUndoState(currentDataUrl);
      const ctx = editCanvas.getContext('2d', { willReadFrequently: true });
      const base = ctx.getImageData(0, 0, editCanvas.width, editCanvas.height);
      const maskCtx = maskCanvas.getContext('2d', { willReadFrequently: true });
      const mask = maskCtx.getImageData(0, 0, maskCanvas.width, maskCanvas.height);

      const bd = base.data;
      const md = mask.data;
      let changed = 0;
      for (let i = 0; i < bd.length; i += 4) {
        const alpha = md[i + 3];
        if (alpha > 0) {
          bd[i] = 255; bd[i + 1] = 255; bd[i + 2] = 255;
          changed++;
        }
      }
      ctx.putImageData(base, 0, 0);
      clearMarks();
      currentDataUrl = editCanvas.toDataURL('image/png');
      commitCurrentToPageList();
      setStatusMsg(changed > 0 ? 'Marks applied' : 'No marks');
    }

    async function removeThinLinesInMarkedArea(dynamicErosionRadius = null) {
      if (!editCanvas) return;
      const maskCtx = maskCanvas.getContext('2d', { willReadFrequently: true });
      const mask = maskCtx.getImageData(0, 0, maskCanvas.width, maskCanvas.height);
      const md = mask.data;
      let hasMask = false;
      for (let i = 3; i < md.length; i += 4) {
        if (md[i] > 0) { hasMask = true; break; }
      }

      const useCropRect = (!hasMask && cropSelection && cropSelection.w > 0 && cropSelection.h > 0);
      if (!hasMask && !useCropRect) {
        setStatusMsg('No marked area — use Rect Remove or Crop first');
        return;
      }

      pushUndoState(currentDataUrl);
      setStatusMsg('Removing thin lines (morphological)…');

      // Allow UI to update before heavy computation
      await new Promise(r => setTimeout(r, 50));

      const ctx = editCanvas.getContext('2d', { willReadFrequently: true });
      const img = ctx.getImageData(0, 0, editCanvas.width, editCanvas.height);
      const d = img.data;
      const w = editCanvas.width;
      const h = editCanvas.height;

      function getMaskBounds() {
        if (!hasMask) return null;
        let minX = w, minY = h, maxX = -1, maxY = -1;
        for (let y = 0; y < h; y++) {
          let rowHas = false;
          const rowStart = y * w * 4;
          for (let x = 0; x < w; x++) {
            const a = md[rowStart + x * 4 + 3];
            if (a > 0) {
              rowHas = true;
              if (x < minX) minX = x;
              if (x > maxX) maxX = x;
            }
          }
          if (rowHas) {
            if (y < minY) minY = y;
            if (y > maxY) maxY = y;
          }
        }
        if (maxX < 0 || maxY < 0) return null;
        // Expand 1px margin
        minX = Math.max(0, minX - 1);
        minY = Math.max(0, minY - 1);
        maxX = Math.min(w - 1, maxX + 1);
        maxY = Math.min(h - 1, maxY + 1);
        return { x0: minX, y0: minY, x1: maxX + 1, y1: maxY + 1 };
      }

      // ── Region bounds ──
      const mb = (!useCropRect && hasMask) ? getMaskBounds() : null;
      const rX0 = useCropRect ? Math.max(0, Math.floor(cropSelection.x0)) : (mb ? mb.x0 : 0);
      const rY0 = useCropRect ? Math.max(0, Math.floor(cropSelection.y0)) : (mb ? mb.y0 : 0);
      const rX1 = useCropRect ? Math.min(w, Math.ceil(cropSelection.x0 + cropSelection.w)) : (mb ? mb.x1 : w);
      const rY1 = useCropRect ? Math.min(h, Math.ceil(cropSelection.y0 + cropSelection.h)) : (mb ? mb.y1 : h);

      console.log(`[ThinLines] Region bounds: X(${rX0}-${rX1}), Y(${rY0}-${rY1}), useCropRect: ${useCropRect}, hasMask: ${hasMask}`);

      function inRegion(x, y, idx) {
        if (useCropRect) return (x >= rX0 && x < rX1 && y >= rY0 && y < rY1);
        return md[idx * 4 + 3] > 0;
      }

      // ── 1. Build ink mask (non-white pixels in region) ──
      // inkThreshold: pixels with ALL channels >= this are "white" (background)
      const inkThreshold = 240;
      const ink = new Uint8Array(w * h);  // 1 = ink pixel
      let initialInkCount = 0;
      for (let y = rY0; y < rY1; y++) {
        for (let x = rX0; x < rX1; x++) {
          const idx = y * w + x;
          if (!inRegion(x, y, idx)) continue;
          const i = idx * 4;
          const r = d[i], g = d[i + 1], b = d[i + 2];
          // Not white => ink
          if (r < inkThreshold || g < inkThreshold || b < inkThreshold) {
            ink[idx] = 1;
            initialInkCount++;
          }
        }
      }
      console.log(`[ThinLines] Step 1: Found ${initialInkCount} ink pixels in region (threshold < ${inkThreshold})`);

      // ── 2. Morphological opening: erode N times, then dilate N times ──
      // Thin lines (width <= 2*erosionRadius) disappear after erosion
      // and do NOT come back after dilation. Thick walls survive both.
      const erosionRadius = dynamicErosionRadius !== null ? dynamicErosionRadius : 8;
      console.log(`[ThinLines] Using erosion radius: ${erosionRadius}`);

      let current = ink.slice();
      let next = new Uint8Array(w * h);

      // Erode: a pixel survives only if ALL neighbors in the kernel are also ink
      for (let step = 0; step < erosionRadius; step++) {
        next.fill(0);
        let survivedErosion = 0;
        for (let y = rY0; y < rY1; y++) {
          for (let x = rX0; x < rX1; x++) {
            const idx = y * w + x;
            if (!current[idx]) continue;
            let allSet = true;
            for (let dy = -1; dy <= 1 && allSet; dy++) {
              for (let dx = -1; dx <= 1 && allSet; dx++) {
                const nx = x + dx, ny = y + dy;
                if (nx < 0 || nx >= w || ny < 0 || ny >= h) { allSet = false; break; }
                if (!current[ny * w + nx]) allSet = false;
              }
            }
            if (allSet) {
              next[idx] = 1;
              survivedErosion++;
            }
          }
        }
        console.log(`[ThinLines] Erosion step ${step + 1}: ${survivedErosion} pixels survived`);
        [current, next] = [next, current];
      }

      // Dilate: a pixel is set if ANY neighbor in the kernel is set
      for (let step = 0; step < erosionRadius; step++) {
        next.fill(0);
        // Copy current first
        for (let i = 0; i < current.length; i++) next[i] = current[i];
        let afterDilation = 0;
        for (let y = rY0; y < rY1; y++) {
          for (let x = rX0; x < rX1; x++) {
            const idx = y * w + x;
            if (!current[idx]) continue;
            for (let dy = -1; dy <= 1; dy++) {
              for (let dx = -1; dx <= 1; dx++) {
                const nx = x + dx, ny = y + dy;
                if (nx < 0 || nx >= w || ny < 0 || ny >= h) continue;
                next[ny * w + nx] = 1;
              }
            }
          }
        }
        for (let i = 0; i < next.length; i++) {
          if (next[i]) afterDilation++;
        }
        console.log(`[ThinLines] Dilation step ${step + 1}: ${afterDilation} pixels after dilation`);
        [current, next] = [next, current];
      }

      // ── 3. Whiten pixels that were ink but did NOT survive opening ──
      let changed = 0;
      for (let y = rY0; y < rY1; y++) {
        for (let x = rX0; x < rX1; x++) {
          const idx = y * w + x;
          if (!inRegion(x, y, idx)) continue;
          if (ink[idx] === 1 && current[idx] === 0) {
            const i = idx * 4;
            d[i] = 255; d[i + 1] = 255; d[i + 2] = 255;
            changed++;
          }
        }
      }
      console.log(`[ThinLines] Step 3: Whitened ${changed} pixels that were identified as thin lines`);

      ctx.putImageData(img, 0, 0);
      clearMarks();
      currentDataUrl = editCanvas.toDataURL('image/png');
      commitCurrentToPageList();
      setStatusMsg(changed > 0 ? `Removed ${changed.toLocaleString()} thin-line pixels` : 'No thin lines detected');
    }

    // Distance-transform based removal: removes ink pixels whose local thickness (distance to background)
    // is <= distanceThreshold, even if connected to thick walls.
    async function removeThinLinesByDistanceInMarkedArea(distanceThreshold) {
      if (!editCanvas) return;
      const maskCtx = maskCanvas.getContext('2d', { willReadFrequently: true });
      const mask = maskCtx.getImageData(0, 0, maskCanvas.width, maskCanvas.height);
      const md = mask.data;
      let hasMask = false;
      for (let i = 3; i < md.length; i += 4) {
        if (md[i] > 0) { hasMask = true; break; }
      }

      const useCropRect = (!hasMask && cropSelection && cropSelection.w > 0 && cropSelection.h > 0);
      if (!hasMask && !useCropRect) {
        setStatusMsg('No marked area — use Rect Remove or Crop first');
        return;
      }

      const distT = Math.max(1, Math.min(32, Math.floor(distanceThreshold || 1)));
      pushUndoState(currentDataUrl);
      setStatusMsg('Removing thin lines (distance)…');
      await new Promise(r => setTimeout(r, 50));

      const ctx = editCanvas.getContext('2d', { willReadFrequently: true });
      const img = ctx.getImageData(0, 0, editCanvas.width, editCanvas.height);
      const d = img.data;
      const w = editCanvas.width;
      const h = editCanvas.height;

      function getMaskBounds() {
        if (!hasMask) return null;
        let minX = w, minY = h, maxX = -1, maxY = -1;
        for (let y = 0; y < h; y++) {
          let rowHas = false;
          const rowStart = y * w * 4;
          for (let x = 0; x < w; x++) {
            const a = md[rowStart + x * 4 + 3];
            if (a > 0) {
              rowHas = true;
              if (x < minX) minX = x;
              if (x > maxX) maxX = x;
            }
          }
          if (rowHas) {
            if (y < minY) minY = y;
            if (y > maxY) maxY = y;
          }
        }
        if (maxX < 0 || maxY < 0) return null;
        minX = Math.max(0, minX - 1);
        minY = Math.max(0, minY - 1);
        maxX = Math.min(w - 1, maxX + 1);
        maxY = Math.min(h - 1, maxY + 1);
        return { x0: minX, y0: minY, x1: maxX + 1, y1: maxY + 1 };
      }

      const mb = (!useCropRect && hasMask) ? getMaskBounds() : null;
      const rX0 = useCropRect ? Math.max(0, Math.floor(cropSelection.x0)) : (mb ? mb.x0 : 0);
      const rY0 = useCropRect ? Math.max(0, Math.floor(cropSelection.y0)) : (mb ? mb.y0 : 0);
      const rX1 = useCropRect ? Math.min(w, Math.ceil(cropSelection.x0 + cropSelection.w)) : (mb ? mb.x1 : w);
      const rY1 = useCropRect ? Math.min(h, Math.ceil(cropSelection.y0 + cropSelection.h)) : (mb ? mb.y1 : h);

      console.log(`[ThinDist] Region bounds: X(${rX0}-${rX1}), Y(${rY0}-${rY1}), useCropRect: ${useCropRect}, hasMask: ${hasMask}, distT: ${distT}`);

      function inRegion(x, y, idx) {
        if (useCropRect) return (x >= rX0 && x < rX1 && y >= rY0 && y < rY1);
        return md[idx * 4 + 3] > 0;
      }

      // Slightly higher threshold to treat anti-aliased light-gray pixels as ink
      // so they get removed together with the sampled thin lines.
      const inkThreshold = 248;
      const bw = (rX1 - rX0);
      const bh = (rY1 - rY0);
      if (bw <= 0 || bh <= 0) {
        setStatusMsg('Invalid region');
        return;
      }

      const INF = 65535;
      const ink = new Uint8Array(bw * bh);
      const dist = new Uint16Array(bw * bh);
      let inkCount = 0;
      for (let y = 0; y < bh; y++) {
        for (let x = 0; x < bw; x++) {
          const gx = rX0 + x;
          const gy = rY0 + y;
          const gidx = gy * w + gx;
          if (!inRegion(gx, gy, gidx)) {
            dist[y * bw + x] = 0;
            continue;
          }
          const i = gidx * 4;
          const r = d[i], g = d[i + 1], b = d[i + 2];
          const isInkPx = (r < inkThreshold || g < inkThreshold || b < inkThreshold);
          if (isInkPx) {
            ink[y * bw + x] = 1;
            dist[y * bw + x] = INF;
            inkCount++;
          } else {
            dist[y * bw + x] = 0;
          }
        }
      }
      console.log(`[ThinDist] Ink pixels in region: ${inkCount}`);

      // 2-pass distance transform for chessboard (Chebyshev) distance.
      // First pass: top-left -> bottom-right
      for (let y = 0; y < bh; y++) {
        for (let x = 0; x < bw; x++) {
          const idx = y * bw + x;
          if (dist[idx] === 0) continue;
          let best = dist[idx];
          if (x > 0) best = Math.min(best, dist[idx - 1] + 1);
          if (y > 0) best = Math.min(best, dist[idx - bw] + 1);
          if (x > 0 && y > 0) best = Math.min(best, dist[idx - bw - 1] + 1);
          if (x + 1 < bw && y > 0) best = Math.min(best, dist[idx - bw + 1] + 1);
          dist[idx] = best;
        }
      }
      // Second pass: bottom-right -> top-left
      for (let y = bh - 1; y >= 0; y--) {
        for (let x = bw - 1; x >= 0; x--) {
          const idx = y * bw + x;
          if (dist[idx] === 0) continue;
          let best = dist[idx];
          if (x + 1 < bw) best = Math.min(best, dist[idx + 1] + 1);
          if (y + 1 < bh) best = Math.min(best, dist[idx + bw] + 1);
          if (x + 1 < bw && y + 1 < bh) best = Math.min(best, dist[idx + bw + 1] + 1);
          if (x > 0 && y + 1 < bh) best = Math.min(best, dist[idx + bw - 1] + 1);
          dist[idx] = best;
        }
      }

      // Remove all ink pixels whose distance-to-background is <= distT
      let changed = 0;
      for (let y = 0; y < bh; y++) {
        for (let x = 0; x < bw; x++) {
          const aidx = y * bw + x;
          if (!ink[aidx]) continue;
          if (dist[aidx] <= distT) {
            const gx = rX0 + x;
            const gy = rY0 + y;
            const gidx = gy * w + gx;
            if (!inRegion(gx, gy, gidx)) continue;
            const i = gidx * 4;
            d[i] = 255; d[i + 1] = 255; d[i + 2] = 255;
            changed++;
          }
        }
      }
      console.log(`[ThinDist] Whitened ${changed} pixels with dist<=${distT}`);

      ctx.putImageData(img, 0, 0);
      clearMarks();
      currentDataUrl = editCanvas.toDataURL('image/png');
      commitCurrentToPageList();
      setStatusMsg(changed > 0 ? `Removed ${changed.toLocaleString()} thin-line pixels` : 'No thin lines detected');
    }

    async function applyCrop() {
      if (!editCanvas || !cropSelection) {
        setStatusMsg('No crop selected');
        return;
      }

      compareCaptureBefore();

      // Ensure undo works even if the page hasn't been committed yet.
      try {
        const baseForUndo = currentDataUrl || editCanvas.toDataURL('image/png');
        pushUndoState(baseForUndo);
      } catch {
        pushUndoState(currentDataUrl);
      }
      const { x0, y0, w, h } = cropSelection;

      console.group('%c[Crop] Apply', 'color:#ff6');
      console.log('cropSelection rect:', JSON.stringify({ x0, y0, w, h }));
      console.log('editCanvas BEFORE crop:', { canvasW: editCanvas.width, canvasH: editCanvas.height });
      console.log('markCanvas BEFORE crop:', { canvasW: markCanvas.width, canvasH: markCanvas.height });
      console.log('zoom:', zoom, '| CSS display size:', editCanvas.style.width, 'x', editCanvas.style.height);
      console.log('aspect ratio source:', (editCanvas.width / editCanvas.height).toFixed(4));
      console.log('aspect ratio crop:', (w / h).toFixed(4));
      console.groupEnd();

      const tmp = document.createElement('canvas');
      tmp.width = w;
      tmp.height = h;
      const tctx = tmp.getContext('2d', { willReadFrequently: true });
      tctx.fillStyle = '#ffffff';
      tctx.fillRect(0, 0, w, h);
      tctx.drawImage(editCanvas, x0, y0, w, h, 0, 0, w, h);

      // Resize main canvases to cropped size
      editCanvas.width = w;
      editCanvas.height = h;
      markCanvas.width = w;
      markCanvas.height = h;
      maskCanvas.width = w;
      maskCanvas.height = h;
      if (protectCanvas) {
        protectCanvas.width = w;
        protectCanvas.height = h;
      }
      protectMaskCanvas.width = w;
      protectMaskCanvas.height = h;
      clearExclude();

      const ctx = editCanvas.getContext('2d', { willReadFrequently: true });
      ctx.drawImage(tmp, 0, 0);

      // IMPORTANT: update CSS sizing / wrap sizing after canvas resize
      applyZoom();
      ensurePdfImageViewportHeight();
      try { if (canvasViewport) { canvasViewport.scrollTop = 0; canvasViewport.scrollLeft = 0; } } catch { }

      clearMarks();
      clearCropSelection();
      // Reset crop mode after applying
      cropMode = false;
      if (markCanvas) {
        const hasCountMarkers = typeof _countState !== 'undefined' && _countState.matches && _countState.matches.length > 0;
        markCanvas.style.pointerEvents = hasCountMarkers ? 'auto' : 'none';
        markCanvas.style.cursor = hasCountMarkers ? 'pointer' : '';
      }
      if (canvasWrap) canvasWrap.style.cursor = '';
      if (btnCrop) { btnCrop.classList.remove('ring-2', 'ring-violet-300/50'); }
      currentDataUrl = editCanvas.toDataURL('image/png');
      commitCurrentToPageList();
      compareCaptureAfterAndShow();

      console.group('%c[Crop] AFTER Apply', 'color:#0f0');
      console.log('editCanvas AFTER crop:', { canvasW: editCanvas.width, canvasH: editCanvas.height });
      console.log('markCanvas AFTER crop:', { canvasW: markCanvas.width, canvasH: markCanvas.height });
      console.log('maskCanvas AFTER crop:', { canvasW: maskCanvas.width, canvasH: maskCanvas.height });
      console.log('zoom:', zoom, '| CSS display size:', editCanvas.style.width, 'x', editCanvas.style.height);
      console.log('aspect ratio after crop:', (editCanvas.width / editCanvas.height).toFixed(4));
      console.log('cropSelection now:', cropSelection);
      console.log('dataURL length:', currentDataUrl ? currentDataUrl.length : 0);
      console.groupEnd();

      setStatusMsg('Cropped');
    }

    async function setSelectedPage(idx) {
      // Before switching pages, persist current page edits.
      commitCurrentToPageList();

      selectedIdx = Math.max(0, Math.min(lastPdfPages.length - 1, idx));
      currentDataUrl = lastPdfPages[selectedIdx];
      undoStack.length = 0;
      redoStack.length = 0;
      refreshUndoRedoButtons();
      clearExclude();
      await drawDataUrlToCanvas(currentDataUrl);
      commitCurrentToPageList();
      setStatusMsg('');
    }

    card.classList.remove('hidden');
    const buildBar = document.getElementById('pdfImageBuildBar');
    if (buildBar) buildBar.classList.add('hidden');
    if (switchToPdfImageTab) switchTab('tabPdfImage');

    // Make the framed editor fill the remaining screen height.
    ensurePdfImageViewportHeight();

    // Initialize selection
    if (instrEl && restoreState && typeof restoreState.instructions === 'string') {
      instrEl.value = restoreState.instructions;
    }
    setSelectedPage(Math.max(0, Math.min(lastPdfPages.length - 1, initialPageIndex || 0)));

    // ── Apply edits based on instructions ──
    function setApplyBusy(isBusy) {
      if (btnApply) btnApply.disabled = !!isBusy;
      if (btnApplyIcon) btnApplyIcon.classList.toggle('opacity-0', !!isBusy);
      if (btnApplySpinner) btnApplySpinner.classList.toggle('opacity-0', !isBusy);
    }

    function setEditLog(html) {
      if (!editLogEl) return;
      editLogEl.innerHTML = html || '';
    }

    let _lastAiDebug = null;
    let aiDebugExpanded = false;

    async function copyTextToClipboard(text) {
      const value = String(text || '');
      if (!value) return false;
      try {
        if (navigator.clipboard && typeof navigator.clipboard.writeText === 'function') {
          await navigator.clipboard.writeText(value);
          return true;
        }
      } catch {
        // fall through to textarea fallback
      }

      const ta = document.createElement('textarea');
      ta.value = value;
      ta.setAttribute('readonly', '');
      ta.style.position = 'fixed';
      ta.style.left = '-9999px';
      ta.style.top = '0';
      document.body.appendChild(ta);
      ta.select();
      ta.setSelectionRange(0, ta.value.length);
      let ok = false;
      try {
        ok = document.execCommand('copy');
      } catch {
        ok = false;
      } finally {
        document.body.removeChild(ta);
      }
      return ok;
    }

    function setAiDebugExpanded(next) {
      aiDebugExpanded = !!next;
      if (aiDebugLogWrapEl) aiDebugLogWrapEl.classList.toggle('hidden', !aiDebugExpanded);
      if (aiDebugToggleIconEl) {
        aiDebugToggleIconEl.classList.toggle('fa-chevron-down', !aiDebugExpanded);
        aiDebugToggleIconEl.classList.toggle('fa-chevron-up', aiDebugExpanded);
      }
    }

    function buildAiDebugCopyText(debug) {
      if (!debug) return '';
      const sections = [];
      const addSection = (title, body, isJson) => {
        if (body === undefined || body === null || body === '') return;
        const text = typeof body === 'string' ? body : (isJson ? formatJsonForDebug(body) : String(body));
        if (!text) return;
        sections.push(`${title}\n${text}`);
      };

      addSection('Mode', debug.mode || '', false);
      addSection('Request Summary', debug.requestSummary || '', false);
      addSection('Prompt Sent', debug.promptSent || '', false);
      addSection('Payload Sent', debug.payloadSent, true);
      addSection('AI Understanding', debug.aiUnderstanding, true);
      addSection('Response Received', debug.responseReceived || '', false);
      addSection('Parsed Response', debug.parsedResponse, true);

      return sections.join('\n\n');
    }

    if (btnToggleAiDebugEl && !btnToggleAiDebugEl.dataset.bound) {
      btnToggleAiDebugEl.dataset.bound = '1';
      btnToggleAiDebugEl.addEventListener('click', () => {
        if (!_lastAiDebug) return;
        setAiDebugExpanded(!aiDebugExpanded);
      });
    }

    if (btnCopyAiDebugEl && !btnCopyAiDebugEl.dataset.bound) {
      btnCopyAiDebugEl.dataset.bound = '1';
      btnCopyAiDebugEl.addEventListener('click', async () => {
        const text = buildAiDebugCopyText(_lastAiDebug);
        if (!text) {
          setStatusMsg('No AI log available to copy yet.');
          return;
        }

        const copied = await copyTextToClipboard(text);
        setStatusMsg(copied ? 'AI log copied to clipboard.' : 'Could not copy AI log.');
      });
    }

    setAiDebugExpanded(false);

    function truncateForLog(value, maxLen = 4000) {
      const text = String(value || '');
