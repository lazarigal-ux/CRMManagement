@page
@model CRMManagement.Web.Pages.PdfToSvg.IndexModel
@{
    ViewData["Title"] = "PDF to SVG";
}

<style>
[data-page="pdf-to-svg"] {
  max-width: 1580px;
  margin-inline: auto;
}
[data-page="pdf-to-svg"] .p2s-shell {
  border: 1px solid rgba(71, 85, 105, .52);
  border-radius: 1.5rem;
  background: linear-gradient(180deg, rgba(71, 85, 105, .88) 0%, rgba(51, 65, 85, .92) 100%);
  box-shadow: 0 10px 28px rgba(2, 6, 23, .32), 0 0 0 1px rgba(255,255,255,.03) inset;
  overflow: clip;
}
[data-page="pdf-to-svg"] .p2s-header {
  padding: 1rem 1.25rem .85rem;
  border-bottom: 1px solid rgba(255,255,255,.04);
}
[data-page="pdf-to-svg"] .p2s-headline {
  display: inline-flex;
  align-items: center;
  gap: .65rem;
  font-size: 1.05rem;
  font-weight: 700;
  letter-spacing: -.01em;
  color: #e5e7eb;
}
[data-page="pdf-to-svg"] .p2s-subtitle {
  margin-top: .35rem;
  color: #cbd5e1;
  font-size: .95rem;
}
[data-page="pdf-to-svg"] .p2s-toolbar-card {
  margin: 1.1rem 1rem .9rem;
  padding: 1rem;
  border: 1px solid rgba(148, 163, 184, .28);
  border-radius: 1rem;
  background: rgba(71, 85, 105, .7);
  box-shadow: inset 0 1px 0 rgba(255,255,255,.05), 0 4px 12px rgba(2, 6, 23, .18);
}
[data-page="pdf-to-svg"] .p2s-tab {
  background: rgba(30, 41, 59, .4);
  border-color: rgba(255,255,255,.04);
  color: #cbd5e1;
  border-radius: 0;
  padding-inline: 1rem;
  min-height: 2.35rem;
}
[data-page="pdf-to-svg"] .p2s-tab:hover {
  color: #f8fafc;
  background: rgba(51, 65, 85, .68);
}
[data-page="pdf-to-svg"] .p2s-tab.active {
  background: rgba(51, 65, 85, .82);
  border-color: rgba(148, 163, 184, .2);
  color: #fff;
  box-shadow: inset 0 1px 0 rgba(255,255,255,.05);
}
[data-page="pdf-to-svg"] .p2s-tab-bar {
  display: flex;
  align-items: center;
  gap: 0;
  padding: 0 1rem;
  border-bottom: 1px solid rgba(148, 163, 184, .16);
  position: sticky;
  top: 0;
  z-index: 40;
  background: linear-gradient(180deg, rgba(71, 85, 105, .98) 0%, rgba(51, 65, 85, .98) 100%);
  backdrop-filter: blur(6px);
}
[data-page="pdf-to-svg"] .p2s-preview-toolbar-sticky {
  position: sticky;
  top: 2.35rem;
  z-index: 39;
  background: rgba(51, 65, 85, .97);
  backdrop-filter: blur(6px);
  border-radius: 1rem 1rem 0 0;
  margin: 0 -1px;
}
[data-page="pdf-to-svg"] .p2s-empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: .5rem;
  min-height: 14.5rem;
  border: 0;
  border-radius: 1rem;
  color: #94a3b8;
  background: transparent;
  text-align: center;
}
[data-page="pdf-to-svg"] .p2s-empty-state i {
  font-size: 2.25rem;
  color: #94a3b8;
  opacity: .95;
}
[data-page="pdf-to-svg"] .p2s-empty-state-title {
  color: #cbd5e1;
  font-size: 1.05rem;
  font-weight: 700;
}
[data-page="pdf-to-svg"] .p2s-empty-state-subtitle {
  color: #94a3b8;
  font-size: .95rem;
}
.pdf-loader-overlay {
  position: absolute;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(15, 23, 42, .55);
  border-radius: 1rem;
  z-index: 30;
}
.pdf-loader-hidden {
  opacity: 0;
  pointer-events: none;
}
#pdfImageCanvasViewport {
  background: #1e293b;
}
#pdfImageCanvasStage {
  background: #1e293b;
}
#pdfImageCanvasWrap {
  background: #fff;
}
#btnPdfImageMarkRemove,
#btnPdfImageRectRemove,
#btnPdfImageExcludeMode,
#btnPdfImageClearExclude,
#btnPdfImageClearMarks,
#btnPdfImageApplyMarks,
#btnPdfImageThinInMarks,
#btnPdfImageRemoveText,
#btnPdfImageRemoveHatching,
#btnPdfImageRemoveArrows,
#pdfImagePageCount,
#pdfImageEditSelectedLabel,
#btnDownloadAllImages,
#pdfImagePages {
  display: none !important;
}

/* ── Full-page processing overlay ── */
.p2s-processing-overlay {
  position: fixed;
  inset: 0;
  z-index: 9000;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 1.5rem;
  background: rgba(15, 23, 42, .82);
  backdrop-filter: blur(8px);
  opacity: 0;
  pointer-events: none;
  transition: opacity .35s ease;
}
.p2s-processing-overlay.active {
  opacity: 1;
  pointer-events: auto;
}
.p2s-processing-spinner {
  width: 64px; height: 64px;
  border: 4px solid rgba(148,163,184,.25);
  border-top-color: #38bdf8;
  border-radius: 50%;
  animation: p2sSpin 0.8s linear infinite;
}
@@keyframes p2sSpin { to { transform: rotate(360deg); } }
.p2s-processing-text {
  color: #e2e8f0;
  font-size: 1.1rem;
  font-weight: 600;
  letter-spacing: .02em;
}
.p2s-processing-sub {
  color: #94a3b8;
  font-size: .85rem;
}
.p2s-processing-bar {
  width: 280px; height: 6px;
  border-radius: 3px;
  background: rgba(148,163,184,.2);
  overflow: hidden;
}
.p2s-processing-bar-fill {
  height: 100%;
  border-radius: 3px;
  background: linear-gradient(90deg, #38bdf8 0%, #818cf8 50%, #38bdf8 100%);
  background-size: 200% 100%;
  animation: p2sBarSlide 1.5s ease-in-out infinite;
  width: 100%;
}
@@keyframes p2sBarSlide { 0%{background-position:200% 0} 100%{background-position:-200% 0} }
</style>

  <section class="w-full px-2 md:px-4 mt-3 md:mt-5 relative" data-page="pdf-to-svg">

    <div id="toastContainer" class="fixed top-20 right-4 z-[9999] flex flex-col gap-2 pointer-events-none" style="max-width:420px;"></div>

    <!-- Full-page processing overlay -->
    <div id="p2sProcessingOverlay" class="p2s-processing-overlay">
      <div class="p2s-processing-spinner"></div>
      <div id="p2sProcessingText" class="p2s-processing-text">Processing PDF…</div>
      <div id="p2sProcessingSub" class="p2s-processing-sub">Rasterizing pages and analyzing floor plan</div>
      <div class="p2s-processing-bar"><div class="p2s-processing-bar-fill"></div></div>
    </div>

    <div class="p2s-shell">
      <div class="p2s-header">
        <h2 class="p2s-headline">
          <i class="fa-solid fa-vector-square text-brand text-sm"></i>
          <span>PDF TO SVG</span>
          <span class="ml-3 inline-flex items-center rounded-full border border-amber-400/70 bg-amber-500/20 px-3 py-1 text-[11px] font-black tracking-wide text-amber-200 shadow-[0_0_0_1px_rgba(251,191,36,.18)]">LIVE AWS BUILD • 2026-04-18 09:33 UTC</span>
        </h2>
        <div class="p2s-subtitle">
          Upload a PDF, preview layers, extract walls &amp; doors, adjust drawing scale, and export a clean SVG floor plan.
        </div>
      </div>

    <div class="p2s-toolbar-card">
      <div class="space-y-4">
        <div class="flex flex-wrap items-end gap-3">
          <div class="min-w-[180px]">
            <div class="text-xs text-slate-300 mb-1 font-semibold uppercase tracking-wider">
              <i class="fa-solid fa-file-pdf text-xs me-1"></i> PDF
            </div>
            <input id="pdfInput" type="file" accept="application/pdf"
                   class="w-full rounded-lg border border-slate-500/60 bg-slate-800/40 px-3 py-2 text-sm text-slate-100 focus:border-brand focus:ring-brand focus:ring-1" />
          </div>

          <div>
            <div class="text-xs text-slate-300 mb-1 font-semibold uppercase tracking-wider">
              <i class="fa-solid fa-plug text-xs me-1"></i> Provider
            </div>
            <select id="provider"
                    class="w-64 h-10 rounded-lg border border-slate-500/60 bg-slate-800/40 px-3 py-2.5 text-sm text-slate-100 focus:border-brand focus:ring-brand focus:ring-1">
              <option value="openai">ONLINE (OpenAI)</option>
              <option value="gemini">ONLINE (Google Gemini)</option>
              <option value="claude">ONLINE (Claude)</option>
              <option value="ollama" selected>OFFLINE (Ollama vision model)</option>
            </select>
          </div>

          <div class="w-72">
            <div class="text-xs text-slate-300 mb-1 font-semibold uppercase tracking-wider">
              <i class="fa-solid fa-diagram-project text-xs me-1"></i> Project
            </div>
            <select id="fireProjectSelect"
                    class="w-full h-10 rounded-lg border border-slate-500/60 bg-slate-800/40 px-3 py-2.5 text-sm text-slate-100 focus:border-brand focus:ring-brand focus:ring-1">
              <option value="">Loading…</option>
            </select>
          </div>

          <div class="w-96">
            <div class="text-xs text-slate-300 mb-1 font-semibold uppercase tracking-wider">
              <i class="fa-solid fa-pen-to-square text-xs me-1"></i> Report Name
            </div>
            <input id="fireReportName" type="text"
                   class="w-full h-10 rounded-lg border border-slate-500/60 bg-slate-800/40 px-3 py-2.5 text-sm text-slate-100 focus:border-brand focus:ring-brand focus:ring-1"
                   placeholder="e.g. Floorplan - Building A" />
          </div>

          <button id="btnSaveDb" type="button"
                  class="inline-flex items-center gap-1 rounded-lg border border-emerald-500/60 bg-emerald-900/30 hover:bg-emerald-900/50 text-emerald-300 px-3 py-1.5 text-xs transition whitespace-nowrap"
                  title="Save all data to database">
            <i class="fa-solid fa-floppy-disk"></i> Save
          </button>

          <button id="btnLoadDb" type="button"
                  class="inline-flex items-center gap-1 rounded-lg border border-blue-500/60 bg-blue-900/30 hover:bg-blue-900/50 text-blue-300 px-3 py-1.5 text-xs transition whitespace-nowrap"
                  title="Load data from database">
            <i class="fa-solid fa-folder-open"></i> Load
          </button>

          <button id="btnExportSvg" type="button"
                  class="hidden inline-flex items-center gap-1 rounded-lg border border-emerald-500/60 bg-emerald-900/30 hover:bg-emerald-900/50 text-emerald-300 px-3 py-1.5 text-xs transition whitespace-nowrap">
            <i class="fa-solid fa-file-code"></i> Export SVG
          </button>
          <button id="btnExportJson" type="button"
                  class="hidden inline-flex items-center gap-1 rounded-lg border border-slate-500/60 bg-slate-800/40 hover:bg-slate-800/60 text-slate-100 px-3 py-1.5 text-xs transition whitespace-nowrap">
            <i class="fa-solid fa-file-arrow-down"></i> Export JSON
          </button>
        </div>
      </div>
    </div>

    <div class="flex items-center gap-1 border-b border-slate-600/50 p2s-tab-bar">
      <button type="button" data-tab="tabPdfImage"
              class="tab-btn inline-flex items-center gap-1.5 text-sm font-semibold border border-b-0 p2s-tab active transition">
        <i class="fa-solid fa-image text-xs"></i> PDF Image
      </button>
      <button type="button" data-tab="tabFloorPlan"
              class="tab-btn inline-flex items-center gap-1.5 text-sm font-semibold border border-b-0 border-transparent p2s-tab transition">
        <i class="fa-solid fa-map text-xs"></i> Floor Plan
      </button>
      <button type="button" data-tab="tabScale"
              class="tab-btn inline-flex items-center gap-1.5 text-sm font-semibold border border-b-0 border-transparent p2s-tab transition">
        <i class="fa-solid fa-ruler-combined text-xs"></i> Drawing Scale
      </button>
      <button type="button" data-tab="tab3d"
              class="tab-btn inline-flex items-center gap-1.5 text-sm font-semibold border border-b-0 border-transparent p2s-tab transition">
        <i class="fa-solid fa-cube text-xs"></i> 3D
      </button>
    </div>

    <div id="tabPreview" class="tab-panel hidden flex flex-col gap-5 px-3 pb-4 pt-0" style="display:none !important;">
      <div class="p2s-empty-state">
        <i class="fa-solid fa-file-pdf"></i>
        <div class="p2s-empty-state-title">PDF</div>
        <div class="p2s-empty-state-subtitle">Upload a PDF file and click <strong>Analyze</strong> to see the preview here.</div>
      </div>

      <div id="layerCard" class="hidden rounded-2xl border border-amber-500/40 bg-slate-700/80 text-slate-100 shadow-[0_6px_24px_-10px_rgba(2,6,23,.25)]">
        <button type="button" id="layerToggleBtn" class="w-full flex items-center gap-2 px-4 py-3 border-b border-amber-400/30 cursor-pointer hover:bg-slate-600/30 transition">
          <i class="fa-solid fa-layer-group text-amber-300 text-sm"></i>
          <h3 class="text-sm font-semibold uppercase tracking-wider text-slate-300">PDF Layers (OCG)</h3>
          <span id="layerCount" class="ml-auto inline-flex items-center gap-1 rounded-full bg-amber-500/15 border border-amber-400/30 px-3 py-0.5 text-xs font-semibold text-amber-200">0</span>
          <i id="layerToggleIcon" class="fa-solid fa-chevron-down text-slate-400 text-xs transition-transform duration-300 ml-2"></i>
        </button>
        <div id="layerBody" class="hidden px-4 py-4 space-y-3">
          <div class="text-xs text-slate-400">
            This PDF contains <span id="layerCountText" class="font-semibold text-slate-200">0</span> layer(s). Uncheck layers you want to exclude from the conversion.
          </div>
          <div class="rounded-xl border border-slate-600/40 bg-slate-900/40 p-3 max-h-72 overflow-auto">
            <div id="layerList" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-x-6 gap-y-2"></div>
          </div>
        </div>
      </div>

      <div id="pdfPreviewCard" class="hidden rounded-2xl border border-slate-600/50 bg-slate-700/80 text-slate-100 shadow-[0_6px_24px_-10px_rgba(2,6,23,.25)]">
        <div class="flex flex-wrap items-center gap-2 px-4 py-3 border-b border-slate-600/40 p2s-preview-toolbar-sticky">
          <i class="fa-solid fa-file-lines text-brand text-sm"></i>
          <h3 class="text-sm font-semibold uppercase tracking-wider text-slate-300">PDF Preview</h3>
          <div class="ml-auto flex flex-wrap items-center gap-2">
            <button type="button" id="btnPdfUndo" class="inline-flex items-center gap-1 rounded-lg border border-slate-500/60 bg-slate-800/40 hover:bg-slate-800/60 text-slate-300 px-3 py-1.5 text-xs transition" title="Undo last wall mark (across Preview + Floor Plan)">
              <i class="fa-solid fa-rotate-left"></i> Undo
            </button>
            <span class="w-px h-5 bg-slate-500/50 mx-1"></span>
            <button type="button" id="btnPdfZoomIn" class="inline-flex items-center gap-1 rounded-lg border border-slate-500/60 bg-slate-800/40 hover:bg-slate-800/60 text-slate-300 px-3 py-1.5 text-xs transition" title="Zoom In">
              <i class="fa-solid fa-magnifying-glass-plus"></i> Zoom In
            </button>
            <button type="button" id="btnPdfZoomOut" class="inline-flex items-center gap-1 rounded-lg border border-slate-500/60 bg-slate-800/40 hover:bg-slate-800/60 text-slate-300 px-3 py-1.5 text-xs transition" title="Zoom Out">
              <i class="fa-solid fa-magnifying-glass-minus"></i> Zoom Out
            </button>
            <button type="button" id="btnPdfZoomFit" class="inline-flex items-center gap-1 rounded-lg border border-slate-500/60 bg-slate-800/40 hover:bg-slate-800/60 text-slate-300 px-3 py-1.5 text-xs transition" title="Fit to viewport">
              <i class="fa-solid fa-expand"></i> Fit
            </button>
            <span id="pdfZoomLabel" class="text-xs text-slate-400 min-w-[3rem] text-center">100%</span>

            <button type="button" id="btnPreviewCropMode" class="inline-flex items-center gap-1 rounded-lg border border-violet-500/60 bg-violet-900/30 hover:bg-violet-900/50 text-violet-300 px-3 py-1.5 text-xs transition">
              <i class="fa-solid fa-crop-simple text-[10px]"></i> Crop
            </button>
            <button type="button" id="btnPreviewApplyCrop" class="inline-flex items-center gap-1 rounded-lg border border-emerald-500/60 bg-emerald-900/20 hover:bg-emerald-900/40 text-emerald-300 px-3 py-1.5 text-xs transition">
              <i class="fa-solid fa-check text-[10px]"></i> Apply Crop
            </button>
            <span id="previewCropStatus" class="text-[11px] text-slate-400 min-w-[8rem]"></span>

            <div class="ml-3 flex items-center gap-2" title="PDF rasterization resolution">
              <div class="text-[11px] text-slate-400 whitespace-nowrap">DPI</div>
              <input id="pdfPreviewDpi" type="number" min="50" max="1200" step="10" value="600"
                     class="w-20 rounded-md border border-slate-500/50 px-2 py-1 text-sm text-slate-100 outline-none focus:border-sky-400 focus:ring-2 focus:ring-sky-400/40"
                     style="background-color:#1e293b;" />
            </div>

            <button id="btnAnalyze" type="button"
                    class="ml-3 group inline-flex items-center gap-1.5 rounded-lg border border-sky-500/30 bg-sky-600 hover:bg-sky-500 text-white font-extrabold px-4 py-2 text-xs transition duration-200 active:scale-95 disabled:opacity-70 disabled:cursor-not-allowed relative overflow-hidden whitespace-nowrap ring-1 ring-sky-600/30 focus:ring-2 focus:ring-sky-500/70">
              <i id="analyzeIcon" class="fa-solid fa-magnifying-glass-chart text-[12px] transition-transform duration-300 motion-safe:animate-pulse group-hover:scale-110"></i>
              <span id="analyzeText">Build PDF Image</span>
              <i class="fa-solid fa-arrow-right text-[11px] opacity-70 transition-transform duration-200 group-hover:translate-x-0.5"></i>
              <i id="analyzeSpinner" class="fa-solid fa-circle-notch fa-spin absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 opacity-0 transition-opacity duration-300"></i>
            </button>
          </div>
        </div>
        <div class="px-4 py-4 relative">
          <div id="pdfLoadingSpinner" class="pdf-loader-overlay pdf-loader-hidden" aria-hidden="true">
            <i class="fa-solid fa-circle-notch fa-spin text-white text-2xl"></i>
          </div>
          <div id="pdfViewport" class="w-full max-h-[60vh] overflow-auto rounded-xl bg-white">
            <div id="pdfInner" class="inline-block origin-top-left">
              <div id="pdfPages" class="space-y-4 p-3"></div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div id="tabPdfImage" class="tab-panel flex flex-col gap-5 px-3 pb-4 pt-0">
      <!-- Build PDF Image controls (shown before image is generated) -->
      <div id="pdfImageBuildBar" class="flex flex-wrap items-center gap-3 px-4 py-3 mt-2 rounded-2xl border border-slate-600/50 bg-slate-700/80 text-slate-100">
        <i class="fa-solid fa-image text-brand text-sm"></i>
        <span class="text-sm font-semibold uppercase tracking-wider text-slate-300">PDF Image</span>
        <span class="text-xs text-slate-400">Upload a PDF above, then click Build to generate the image.</span>
        <div class="ml-auto flex flex-wrap items-center gap-2">
          <div class="flex items-center gap-2" title="PDF rasterization resolution">
            <div class="text-[11px] text-slate-400 whitespace-nowrap">DPI</div>
            <input id="pdfImageBuildDpi" type="number" min="50" max="1200" step="10" value="600"
                   class="w-20 rounded-md border border-slate-500/50 px-2 py-1 text-sm text-slate-100 outline-none focus:border-sky-400 focus:ring-2 focus:ring-sky-400/40"
                   style="background-color:#1e293b;" />
          </div>
          <button id="btnBuildPdfImage" type="button"
                  class="group inline-flex items-center gap-1.5 rounded-lg border border-sky-500/30 bg-sky-600 hover:bg-sky-500 text-white font-extrabold px-4 py-2 text-xs transition duration-200 active:scale-95 disabled:opacity-70 disabled:cursor-not-allowed relative overflow-hidden whitespace-nowrap ring-1 ring-sky-600/30 focus:ring-2 focus:ring-sky-500/70">
            <i id="buildPdfImageIcon" class="fa-solid fa-magnifying-glass-chart text-[12px] transition-transform duration-300 motion-safe:animate-pulse group-hover:scale-110"></i>
            <span id="buildPdfImageText">Build PDF Image</span>
            <i class="fa-solid fa-arrow-right text-[11px] opacity-70 transition-transform duration-200 group-hover:translate-x-0.5"></i>
            <i id="buildPdfImageSpinner" class="fa-solid fa-circle-notch fa-spin absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 opacity-0 transition-opacity duration-300"></i>
          </button>
        </div>
      </div>
      <div id="pdfImageCard" class="hidden rounded-2xl border border-slate-600/50 bg-slate-700/80 text-slate-100 shadow-[0_6px_24px_-10px_rgba(2,6,23,.25)]">
        <div class="px-4 py-2">
          <div class="rounded-xl border border-slate-600/40" style="background-color:#1e293b;">
            <div class="px-3 py-2 border-b border-slate-600/40 overflow-x-hidden" style="overflow-y:visible;">
              <div class="flex flex-wrap items-center gap-2 min-w-0">
                <div class="flex items-center gap-2 min-w-0">
                  <i class="fa-solid fa-wand-magic-sparkles text-violet-300 text-xs"></i>
                  <div class="text-[11px] text-slate-300 font-semibold whitespace-nowrap">Image Editor</div>
                </div>

                <span class="w-px h-5 bg-slate-600/40 mx-1"></span>

                <div class="flex flex-wrap items-center gap-2">
                  <button type="button" id="btnPdfImageUndo"
                          class="inline-flex items-center gap-1 rounded-lg border border-amber-500/60 bg-amber-900/20 hover:bg-amber-900/40 text-amber-300 px-3 py-1.5 text-xs transition">
                    <i class="fa-solid fa-rotate-left text-[10px]"></i> Undo
                  </button>
                  <button type="button" id="btnPdfImageRedo"
                          class="inline-flex items-center gap-1 rounded-lg border border-amber-500/60 bg-amber-900/20 hover:bg-amber-900/40 text-amber-300 px-3 py-1.5 text-xs transition">
                    <i class="fa-solid fa-rotate-right text-[10px]"></i> Redo
                  </button>
                </div>

                <span class="w-px h-5 bg-slate-600/40 mx-1"></span>

                <div class="flex flex-wrap items-center gap-2">
                  <button type="button" id="btnPdfImageZoomOut"
                          class="inline-flex items-center gap-1 rounded-lg border border-slate-500/60 bg-slate-900/30 hover:bg-slate-900/50 text-slate-300 px-3 py-1.5 text-xs transition">
                    <i class="fa-solid fa-magnifying-glass-minus text-[10px]"></i>
                  </button>
                  <div id="pdfImageZoomLabel" class="text-[11px] text-slate-400 w-12 text-center">100%</div>
