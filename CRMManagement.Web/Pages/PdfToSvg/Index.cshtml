        btn.style.color = '#fff';
        label = 'Area Cleanup';
        title = `Area Cleanup: drag ${_fpShapeLabel(shape)} to clear selection marks in area`;
      }
      btn.title = title;
      const shapeIcon = shape === 'circle' ? '●' : shape === 'triangle' ? '▲' : shape === 'square' ? '■' : '▬';
      if (mode === 'off') {
