        const cur = _compareZoom <= 0 ? Math.round(fitScale * 100) : _compareZoom;
        const delta = e.deltaY < 0 ? 15 : -15;
        const next = Math.max(10, Math.min(cur + delta, 500));
        _compareSetZoom(next);
      }, { passive: false });

      // Drag-to-pan
      let _cmpDrag = false, _cmpDragX = 0, _cmpDragY = 0;
      _compareScroller.addEventListener('mousedown', (e) => {
        if (e.button !== 0) return;
        _cmpDrag = true; _cmpDragX = e.clientX; _cmpDragY = e.clientY;
        _compareScroller.style.cursor = 'grabbing';
      });
      window.addEventListener('mousemove', (e) => {
        if (!_cmpDrag) return;
        _compareScroller.scrollLeft -= (e.clientX - _cmpDragX);
        _compareScroller.scrollTop  -= (e.clientY - _cmpDragY);
        _cmpDragX = e.clientX; _cmpDragY = e.clientY;
      });
      window.addEventListener('mouseup', () => {
        if (_cmpDrag) { _cmpDrag = false; if (_compareScroller) _compareScroller.style.cursor = 'grab'; }
