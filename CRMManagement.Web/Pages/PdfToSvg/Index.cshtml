        pushUndoState(baseForUndo);

        setStatus('Removing arrows/leaders in selected area…', 'info');

        const ctx = editCanvas.getContext('2d', { willReadFrequently: true });
        const imageData = ctx.getImageData(0, 0, editCanvas.width, editCanvas.height);

        // Build protect mask
        let exclude = null;
        try {
          const exCtx = protectMaskCanvas.getContext('2d', { willReadFrequently: true });
          const exImg = exCtx.getImageData(roi.x0, roi.y0, roi.w, roi.h);
          const exd = exImg.data;
          let has = false;
          for (let i = 3; i < exd.length; i += 4) { if (exd[i] > 0) { has = true; break; } }
          if (has) exclude = { data: exd, w: roi.w, h: roi.h };
        } catch { }

        const mods = removeArrowsFromImageData(imageData.data, editCanvas.width, editCanvas.height, roi, exclude);
        ctx.putImageData(imageData, 0, 0);

        currentDataUrl = editCanvas.toDataURL('image/png');
