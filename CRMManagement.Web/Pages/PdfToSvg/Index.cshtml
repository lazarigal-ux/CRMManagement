        opt.textContent = name + (name === fpActiveGroupName ? ' • active' : '');
        fpSvgGroupSelect.appendChild(opt);
      });
      fpSvgGroupSelect.value = fpSvgGroups[prev] ? prev : (fpActiveGroupName && fpSvgGroups[fpActiveGroupName] ? fpActiveGroupName : '');
    }
    if (fpSvgGroupName && !fpSvgGroupName.value && fpActiveGroupName) fpSvgGroupName.value = fpActiveGroupName;
  }

  function fpGetCurrentRenderedSvgPayload() {
    try {
      const svg = fpContainer ? fpContainer.querySelector('svg') : null;
      if (!svg) return null;
      const vb = String(svg.getAttribute('viewBox') || '').trim();
      let coordW = 0, coordH = 0;
      const m = vb.match(/(-?\d*\.?\d+)\s+(-?\d*\.?\d+)\s+(-?\d*\.?\d+)\s+(-?\d*\.?\d+)/);
      if (m) {
        coordW = parseFloat(m[3]) || 0;
        coordH = parseFloat(m[4]) || 0;
      }
      return {
        svgText: new XMLSerializer().serializeToString(svg),
        coordW,
        coordH
      };
    } catch {
      return null;
    }
  }

  function fpSaveSvgGroup(name, payload) {
    if (!name || !payload || !payload.svgText) return false;
    fpSvgGroups[name] = {
      name,
      svgText: payload.svgText,
      coordW: payload.coordW || 0,
      coordH: payload.coordH || 0,
      updatedAt: new Date().toISOString()
    };
    fpActiveGroupName = name;
    fpRefreshGroupUi();
    return true;
  }

  function fpResolveSelectedGroupName() {
    return fpNormalizeGroupName((fpSvgGroupSelect && fpSvgGroupSelect.value) || (fpSvgGroupName && fpSvgGroupName.value) || fpActiveGroupName);
