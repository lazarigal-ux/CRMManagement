  window.fpApplyColor = function(color, mode) {
    const svg = document.querySelector('svg[id^="fpSvg_"]');
    if (!svg) return;
    const selected = svg.querySelectorAll('.fp-selected');
    if (!selected.length) { cgAlert('No items selected.'); return; }

    selected.forEach(g => {
      const isG = String(g.tagName || '').toLowerCase() === 'g';
      const targets = isG
        ? g.querySelectorAll('line, path, polyline, polygon, rect, circle, ellipse')
        : [g];

      targets.forEach(el => {
        // Skip invisible hit-area elements
        if (el.getAttribute('pointer-events') === 'stroke' && el.getAttribute('stroke') === 'transparent') return;

        if (mode === 'stroke') {
          el.setAttribute('stroke', color);
          // Update saved orig-stroke so deselect keeps new color
          if (g.hasAttribute('data-orig-stroke')) g.setAttribute('data-orig-stroke', color);
        } else if (mode === 'fill') {
          el.setAttribute('fill', color);
        }
      });
    });

    // Close picker
    const menu = document.getElementById('fpColorPickerMenu');
    if (menu) menu.classList.add('hidden');
