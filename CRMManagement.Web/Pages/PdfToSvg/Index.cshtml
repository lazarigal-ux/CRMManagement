  function _fpSetZoomAnchored(svg, wrap, nextZoom, anchorClientX, anchorClientY) {
    if (!svg) return;
    const cur = _fpZoomLevels[svg.id] || 1;
    const next = _fpClamp(nextZoom, 0.2, 8);
    if (!wrap || !(wrap instanceof HTMLElement)) {
      _fpZoomLevels[svg.id] = next;
      svg.style.width = (next * 100) + '%';
      svg.style.height = 'auto';
      const lblFallback = _fpZoomLabelForSvg(svg.id);
      if (lblFallback) lblFallback.textContent = Math.round(next * 100) + '%';
      return;
    }

    const vpRect = wrap.getBoundingClientRect();
    const mx = anchorClientX - vpRect.left;
    const my = anchorClientY - vpRect.top;

    // World coords (unscaled) under the cursor before zoom.
    const worldX = (wrap.scrollLeft + mx) / Math.max(0.0001, cur);
    const worldY = (wrap.scrollTop + my) / Math.max(0.0001, cur);

    _fpZoomLevels[svg.id] = next;
    // Scale via width only (height follows viewBox aspect ratio).
    // Preserves aspect ratio and avoids distortion/"tiny centered" content.
    svg.style.width = (next * 100) + '%';
    svg.style.height = 'auto';

    const lbl = _fpZoomLabelForSvg(svg.id);
    if (lbl) lbl.textContent = Math.round(next * 100) + '%';

    // Restore scroll so the same world point stays under the cursor (synchronous).
    wrap.scrollLeft = Math.max(0, worldX * next - mx);
    wrap.scrollTop = Math.max(0, worldY * next - my);
  }
  window.fpZoom = function(svgId, wrapId, lblId, delta) {
    const svg = document.getElementById(svgId);
    if (!svg) return;
    const cur = _fpZoomLevels[svgId] || 1;
    const next = _fpClamp(cur + delta, 0.2, 8);
    const wrap = wrapId ? document.getElementById(wrapId) : (svg.parentElement || null);
    // Anchor zoom to viewport center for toolbar buttons.
    if (wrap && wrap.getBoundingClientRect) {
      const r = wrap.getBoundingClientRect();
      _fpSetZoomAnchored(svg, wrap, next, r.left + r.width / 2, r.top + r.height / 2);
    } else {
      _fpSetZoomAnchored(svg, null, next, 0, 0);
    }
  };
  window.fpZoomFit = function(svgId, wrapId, lblId) {
    const svg = document.getElementById(svgId);
    if (!svg) return;
    const wrap = wrapId ? document.getElementById(wrapId) : (svg.parentElement || null);

    if (!wrap || !(wrap instanceof HTMLElement)) {
      _fpSetZoomAnchored(svg, null, 1, 0, 0);
      const lbl = document.getElementById(lblId);
      if (lbl) lbl.textContent = '100%';
      return;
    }

    // Update wrapper height first (fit should use the visible viewport).
    try { _fpResizeWrapHeight(wrap); } catch { }

    const pad = 24;
    const vw = Math.max(50, (wrap.clientWidth || 0) - pad);
    const vh = Math.max(50, (wrap.clientHeight || 0) - pad);

    let vbW = 0, vbH = 0;
    try {
      if (svg.viewBox && svg.viewBox.baseVal) {
        vbW = svg.viewBox.baseVal.width;
        vbH = svg.viewBox.baseVal.height;
      }
    } catch { }
    if (!vbW || !vbH) {
      try {
        const bb = svg.getBBox();
        if (bb && bb.width > 0 && bb.height > 0) {
          vbW = bb.width;
          vbH = bb.height;
        }
      } catch { }
    }

    const aspect = (vbW > 0 && vbH > 0) ? (vbH / vbW) : 1;
    const wrapW = Math.max(1, wrap.clientWidth || 1);

    // At zoom=1 => svg width equals wrap width. Height is wrapW * aspect.
    const maxByWidth = vw / wrapW;
    const baseHAt1 = wrapW * aspect;
    const maxByHeight = baseHAt1 > 0 ? (vh / baseHAt1) : 1;
    const next = _fpClamp(Math.min(maxByWidth, maxByHeight), 0.2, 8);

    const r = wrap.getBoundingClientRect();
    _fpSetZoomAnchored(svg, wrap, next, r.left + r.width / 2, r.top + r.height / 2);
  };

