  @section Scripts {
  <script>
  (function () {
    'use strict';

    // ── Tab switching ──
    const tabBtns   = document.querySelectorAll('.tab-btn');
    const tabPanels = document.querySelectorAll('.tab-panel');

    function refreshEmptyState(panel) {
      if (!panel) return;
      const placeholder = panel.querySelector('.p2s-empty-state');
      if (!placeholder) return;
      const hasContent = Array.from(panel.children).some(
        el => el !== placeholder && !el.classList.contains('pdf-loader-overlay') && !el.classList.contains('hidden') && el.offsetHeight > 0
      );
      placeholder.classList.toggle('hidden', hasContent);
    }

    const emptyObs = new MutationObserver(() => {
      tabPanels.forEach(p => refreshEmptyState(p));
    });
    tabPanels.forEach(p => {
      emptyObs.observe(p, { attributes: true, attributeFilter: ['class'], subtree: true, childList: true });
    });

    function switchTab(tabId) {
      // Preview tab removed – redirect to PDF Image
      if (tabId === 'tabPreview') tabId = 'tabPdfImage';
      tabPanels.forEach(p => p.classList.toggle('hidden', p.id !== tabId));
      tabBtns.forEach(b => {
        const active = b.getAttribute('data-tab') === tabId;
        b.className = active
          ? 'tab-btn inline-flex items-center gap-1.5 px-4 py-2 text-sm font-semibold border border-b-0 p2s-tab active transition'
          : 'tab-btn inline-flex items-center gap-1.5 px-4 py-2 text-sm font-semibold border border-b-0 border-transparent p2s-tab transition';
      });

      const activePanel = document.getElementById(tabId);
      if (activePanel) setTimeout(() => refreshEmptyState(activePanel), 0);

      if (tabId === 'tabPdfImage') {
        try {
          const pending = window._pendingPdfImageRestore || null;
          window._pendingPdfImageRestore = null;
          if (pending) {
            showPdfImageTab({ switchToTab: false, initialPageIndex: pending.initialPageIndex || 0, restoreState: pending.restoreState || null });
          } else {
            showPdfImageTab({ switchToTab: false });
          }
        } catch (e) { console.error('[switchTab] showPdfImageTab error:', e); }
      }

      if (tabId === 'tabPreview') {
        try { if (lastAnalysis && window.pdfBuildWallOverlay) window.pdfBuildWallOverlay(lastAnalysis); } catch { }
      }
    }
    tabBtns.forEach(b => b.addEventListener('click', () => switchTab(b.getAttribute('data-tab'))));

  // ── API endpoints (point to the main LDataBrain app, NOT crm PathBase) ──
  const ANALYZE_ENDPOINT  = '/fire/pdf/equipment/analyze';
  const LAYERS_ENDPOINT   = '/fire/pdf/layers/detect';
  const PREVIEW_ENDPOINT  = '/fire/pdf/preview/render';
  const FLOORPLAN_VECTORIZE_ENDPOINT = '/fire/floorplan/vectorize';
  const IMAGE_EDIT_ENDPOINT = '/images/edit';
  const PDFIMG_CONTROLNET_CLEAN_ENDPOINT = '/fire/pdfimg/controlnet/clean';
  const PDFIMG_CONTROLNET_STYLES_ENDPOINT = '/fire/pdfimg/controlnet/styles';
  const REPORT_SAVE_ENDPOINT = '/fire/report/save';
