    async function _compareLoadToCanvas(dataUrl) {
      if (!dataUrl) return;
      pushUndoState(currentDataUrl || (editCanvas ? editCanvas.toDataURL('image/png') : null));
      currentDataUrl = dataUrl;
      await drawDataUrlToCanvas(dataUrl);
