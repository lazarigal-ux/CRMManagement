        (attachCount > 0 ? `<span class="p2s-sep mx-2">|</span><span class="p2s-muted-text">Files:</span> <span class="text-emerald-300">${attachCount}</span>` : '') +
        ` <i class="fa-solid fa-circle-notch fa-spin p2s-muted ml-2"></i>`
      );

      const t0 = (typeof performance !== 'undefined' && performance.now) ? performance.now() : Date.now();
      try {
        const base = currentDataUrl || src;
