    const _btnCompareZoomFit = document.getElementById('btnCompareZoomFit');
    const _btnCompareZoom100 = document.getElementById('btnCompareZoom100');

    /** Compute the "fit" scale — fits the BEFORE rect into the container */
    function _compareFitScale() {
      const refW = _compareBeforeW || _compareAfterW || 1;
      const refH = _compareBeforeH || _compareAfterH || 1;
      const container = _compareScroller || (_compareImg ? _compareImg.parentElement : null);
      const availW = container ? (container.clientWidth - 16) : 800;
      const availH = Math.round(window.innerHeight * 0.78);
      return Math.min(availW / refW, availH / refH, 1);
    }

    /**
     * Display both Original and Result at the SAME visual size.
     * Uses the shared _compareZoom level so both images are always
     * shown at an identical scale.
     */
    function _compareUpdateView() {
      if (!_compareImg) return;
      const showOriginal = _compareToggle && _compareToggle.checked;
      _compareImg.src = showOriginal ? _compareBeforeDataUrl : _compareAfterDataUrl;
      if (_compareLabel) _compareLabel.textContent = showOriginal ? 'Original ◀' : 'Result ✓';

      // Show the operation name badge
      if (_compareOpNameEl) _compareOpNameEl.textContent = _compareOpName || '';

      // Reference = BEFORE dimensions
      const refW = _compareBeforeW || _compareAfterW || 1;
      const refH = _compareBeforeH || _compareAfterH || 1;

      // Determine effective scale
      const fitScale = _compareFitScale();
      let effectiveScale;
      if (_compareZoom <= 0) {
        effectiveScale = fitScale;  // fit mode
      } else {
        effectiveScale = _compareZoom / 100;  // explicit percentage
      }

      const dispW = Math.round(refW * effectiveScale);
      const dispH = Math.round(refH * effectiveScale);

      _compareImg.style.width      = dispW + 'px';
      _compareImg.style.height     = dispH + 'px';
      _compareImg.style.objectFit  = 'contain';
      _compareImg.style.background = '#ffffff';
      _compareImg.style.maxWidth   = 'none';  // allow zoom beyond container

      // Badge
      const pct = Math.round(effectiveScale * 100);
      if (_compareZoomBadge) {
        _compareZoomBadge.textContent = _compareZoom <= 0 ? `Fit (${pct}%)` : `${pct}%`;
      }
    }

    function _compareSetZoom(newZoom) {
      _compareZoom = newZoom;
      _compareUpdateView();
    }

    // Zoom In (+25%)
    if (_btnCompareZoomIn) _btnCompareZoomIn.addEventListener('click', () => {
      const fitScale = _compareFitScale();
      const cur = _compareZoom <= 0 ? Math.round(fitScale * 100) : _compareZoom;
      _compareSetZoom(Math.min(cur + 25, 500));
    });
    // Zoom Out (-25%)
    if (_btnCompareZoomOut) _btnCompareZoomOut.addEventListener('click', () => {
      const fitScale = _compareFitScale();
      const cur = _compareZoom <= 0 ? Math.round(fitScale * 100) : _compareZoom;
      _compareSetZoom(Math.max(cur - 25, 10));
    });
    // Fit
    if (_btnCompareZoomFit) _btnCompareZoomFit.addEventListener('click', () => {
      _compareSetZoom(0);
    });
    // 100%
    if (_btnCompareZoom100) _btnCompareZoom100.addEventListener('click', () => {
      _compareSetZoom(100);
    });

