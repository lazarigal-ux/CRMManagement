        if (markCanvas) {
          const hasCountMarkers = typeof _countState !== 'undefined' && _countState.matches && _countState.matches.length > 0;
          markCanvas.style.pointerEvents = (cropMode || hasCountMarkers) ? 'auto' : 'none';
          markCanvas.style.cursor = cropMode ? 'crosshair' : (hasCountMarkers ? 'pointer' : '');
