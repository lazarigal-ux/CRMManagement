    // Hebrew + English keyword matching for category detection
    if (instr.includes('גלאי') || instr.includes('detector') || instr.includes('ספיר') || instr.includes('ספור') || instr.includes('count') || instr.includes('כמה')) {
      category = 'count-detectors';
      tags = ['ספירה', 'גלאים', 'count', 'detectors'];
    } else if (instr.includes('קיר') || instr.includes('wall') || instr.includes('להשאיר') || instr.includes('keep')) {
      category = 'keep-walls';
      tags = ['קירות', 'walls', 'keep', 'להשאיר'];
    } else if (instr.includes('עבה') || instr.includes('thick') || instr.includes('עובי')) {
      category = 'thicken-walls';
      tags = ['עיבוי', 'thicken', 'walls', 'קירות'];
    } else if (instr.includes('נקה') || instr.includes('clean') || instr.includes('הסר') || instr.includes('remove')) {
      category = 'clean-drawing';
      tags = ['ניקוי', 'clean', 'remove', 'הסרה'];
    } else if (instr.includes('אדריכל') || instr.includes('architect') || instr.includes('עיצוב') || instr.includes('design')) {
      category = 'style-drawing';
      tags = ['אדריכלי', 'עיצוב', 'architectural', 'style'];
    } else if (_isAnalysisRequest(_lastAiResult.instruction)) {
