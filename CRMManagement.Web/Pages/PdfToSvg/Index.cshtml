  function _fpViewportH() {
    try {
      return Math.max(0, (document.documentElement && document.documentElement.clientHeight) || 0, window.innerHeight || 0);
    } catch {
      return 0;
    }
  }
  function _fpResizeWrapHeight(wrap) {
    if (!wrap || !(wrap instanceof HTMLElement)) return false;
    const viewportH = _fpViewportH();
    const rect = wrap.getBoundingClientRect();
    if (!viewportH || (rect.height === 0 && rect.top === 0)) return false;
    const bottomGapPx = 4;
    const minHeightPx = 520;
