    function _isAnalysisRequest(instructions) {
      if (!instructions) return false;
      const t = instructions.toLowerCase();
      // Hebrew analysis keywords
      const heAnalysis = ['ספירה', 'ספור', 'כמה', 'מספר', 'זיהוי', 'זהה', 'תאר', 'מדוד', 'ניתוח', 'נתח',
        'מצא', 'חפש', 'בדוק', 'רשימה', 'פרט', 'סמן', 'הראה', 'היכן', 'איפה', 'גלאים', 'גלאי'];
      // English analysis keywords
      const enAnalysis = ['count', 'how many', 'identify', 'detect', 'find', 'describe',
        'measure', 'analyze', 'analysis', 'list', 'locate', 'where', 'what is', 'what are',
        'show me', 'number of', 'check', 'inspect', 'report', 'detector', 'detectors'];
      for (const kw of heAnalysis) { if (t.includes(kw)) return true; }
      for (const kw of enAnalysis) { if (t.includes(kw)) return true; }
      return false;
    }

