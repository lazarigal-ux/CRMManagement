    // Track whether the PDF Image editor is currently in "Fit" mode.
    // When true, we re-fit on window resize.
    let pdfImageIsFitView = false;

    function resizePdfImageViewportHeight() {
      if (!canvasViewport) return false;

      // Compute based on visible viewport height (use documentElement for better cross-browser behavior).
      const viewportH = Math.max(0, (document.documentElement && document.documentElement.clientHeight) || 0, window.innerHeight || 0);
      const rect = canvasViewport.getBoundingClientRect();

      // If we are still hidden/not laid out, rect.top can be 0 and sizes can be stale.
      if (!viewportH || rect.height === 0 && rect.top === 0) return false;

      // Fill the remaining viewport height under the toolbar (do not exceed the window).
      const bottomGapPx = 0;
      const minHeightPx = 520;
      const available = Math.floor(viewportH - rect.top - bottomGapPx);
      const nextH = Math.max(minHeightPx, available);
      canvasViewport.style.height = `${nextH}px`;
      return true;
    }

    function ensurePdfImageViewportHeight() {
      if (!canvasViewport) return;
      let tries = 0;
      const tick = () => {
        tries++;
        const ok = resizePdfImageViewportHeight();
        // Retry while the tab is still transitioning into visibility/layout.
        if ((!ok || canvasViewport.clientHeight < 300) && tries < 12) {
          setTimeout(tick, 40);
        }
      };
      tick();
    }

