    function commitCurrentToPageList() {
      try {
        if (!Array.isArray(lastPdfPages) || !lastPdfPages.length) return;
        if (!Number.isFinite(selectedIdx) || selectedIdx < 0 || selectedIdx >= lastPdfPages.length) return;
        if (!currentDataUrl) return;
        if (lastPdfPages[selectedIdx] !== currentDataUrl) {
          lastPdfPages[selectedIdx] = currentDataUrl;
