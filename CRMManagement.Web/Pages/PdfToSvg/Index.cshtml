  // ── Preview Crop state ──
  let previewCropMode = false;
  let previewCropStart = null;
  let previewCropSelection = null;   // {pageIdx, x0, y0, w, h} in natural-image coords
  let previewCropSnapshot = null;
  let previewCropLastPt = null;
  let previewCropRafPending = false;
  let previewCropPageIdx = null;

  let currentReportId = null;

  // ── Helpers ──
  function safeJsonParse(s, fb) { try { return JSON.parse(s); } catch { return fb; } }
  function nowMs() {
    return (typeof performance !== 'undefined' && performance.now) ? performance.now() : Date.now();
  }
  function escapeHtml(s) {
    return String(s ?? '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;').replace(/'/g,'&#39;');
  }

  function getSelectedPdfPreviewDpi() {
    // Keep in sync with backend constraint: 50..1200.
    const raw = (pdfPreviewDpiEl && typeof pdfPreviewDpiEl.value !== 'undefined') ? String(pdfPreviewDpiEl.value || '').trim() : '';
    const n = parseInt(raw, 10);
    if (!Number.isFinite(n)) return 600;
