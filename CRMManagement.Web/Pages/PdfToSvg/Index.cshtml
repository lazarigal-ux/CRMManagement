    async function ensureClipartStylesLoaded() {
      if (!clipartStyleEl) return;
      if (clipartStyleEl.dataset.loaded === '1') return;
      clipartStyleEl.dataset.loaded = '1';

      const prevVal = clipartStyleEl.value;
      try {
        const resp = await fetch(PDFIMG_CONTROLNET_STYLES_ENDPOINT, { method: 'GET' });
        if (!resp.ok) throw new Error('HTTP ' + resp.status);
        const items = await resp.json();
        if (!Array.isArray(items) || items.length === 0) return;

        // Replace options with server-provided list.
        clipartStyleEl.innerHTML = '';
        for (const it of items) {
          if (!it || !it.id) continue;
          const opt = document.createElement('option');
          opt.value = String(it.id);
          opt.textContent = String(it.label || it.id);
          if (it.description) opt.title = String(it.description);
          clipartStyleEl.appendChild(opt);
        }

        // Preserve previous selection if it still exists.
        if (prevVal) {
          const exists = Array.from(clipartStyleEl.options).some(o => o.value === prevVal);
          if (exists) clipartStyleEl.value = prevVal;
        }
      } catch {
        // Fallback to existing hardcoded options (already in markup).
      }
    }

