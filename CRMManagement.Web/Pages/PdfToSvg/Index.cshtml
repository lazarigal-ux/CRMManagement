    // ══════════════════════════════════════════════════════════════════════
    // ██  TEMPLATE MATCHING  —  client-side NCC with learning feedback  ██
    // ══════════════════════════════════════════════════════════════════════

    /** Shared state for the count-with-learning feature */
    const _countState = {
      matches: [],          // Array of { x, y, score, state:'pending'|'accepted'|'rejected', idx }
      mainDataUrl: null,    // Full drawing data-URL
      templateDataUrl: null,// Original selected object data-URL
      sel: null,            // Selection bounds { x0, y0, w, h }
      // Cached grayscale data for re-scan
      mainGray: null,
      mainW: 0,
      mainH: 0,
      origW: 0,
      origH: 0,
      scale: 1
    };

    /**
     * Convert data-URL image to { gray: Float32Array, w, h } scaled to fit maxDim.
     * Returns a Promise.
     */
    function imageToGray(dataUrl, maxDim) {
      return new Promise((resolve) => {
        const img = new Image();
        img.onload = () => {
          const scale = Math.min(1, maxDim / Math.max(img.width, img.height));
          const w = Math.round(img.width * scale);
          const h = Math.round(img.height * scale);
          const cvs = document.createElement('canvas');
          cvs.width = w; cvs.height = h;
          const ctx = cvs.getContext('2d', { willReadFrequently: true });
          ctx.drawImage(img, 0, 0, w, h);
          const data = ctx.getImageData(0, 0, w, h).data;
          const gray = new Float32Array(w * h);
          for (let i = 0; i < gray.length; i++) {
            const off = i * 4;
            gray[i] = 0.299 * data[off] + 0.587 * data[off + 1] + 0.114 * data[off + 2];
          }
          resolve({ gray, w, h, origW: img.width, origH: img.height, scale });
        };
        img.onerror = () => resolve(null);
        img.src = dataUrl;
      });
    }

    /**
     * Compute mean & stddev of a grayscale buffer region.
     */
    function regionStats(gray, imgW, x0, y0, tw, th) {
      let sum = 0, sumSq = 0;
      const n = tw * th;
      for (let ty = 0; ty < th; ty++) {
        const rowOff = (y0 + ty) * imgW + x0;
        for (let tx = 0; tx < tw; tx++) {
          const v = gray[rowOff + tx];
          sum += v;
          sumSq += v * v;
        }
      }
      const mean = sum / n;
      const variance = sumSq / n - mean * mean;
      return { mean, stdDev: Math.sqrt(Math.max(0, variance)), n };
    }

    /**
     * Compute NCC between a pre-normalized template and a region in mainGray.
     */
    function computeNCC(mainGray, imgW, x0, y0, tw, th, tplNorm) {
      const stats = regionStats(mainGray, imgW, x0, y0, tw, th);
      if (stats.stdDev < 2) return -1;
      let cross = 0;
      for (let ty = 0; ty < th; ty++) {
        const rowOff = (y0 + ty) * imgW + x0;
        for (let tx = 0; tx < tw; tx++) {
          cross += ((mainGray[rowOff + tx] - stats.mean) / stats.stdDev) * tplNorm[ty * tw + tx];
        }
      }
      return cross / stats.n;
    }

    /**
     * Pre-normalize a grayscale template patch.
     */
    function preNormalizeTemplate(gray, w, h) {
      const n = w * h;
      let sum = 0;
      for (let i = 0; i < n; i++) sum += gray[i];
      const mean = sum / n;
      let varSum = 0;
      for (let i = 0; i < n; i++) varSum += (gray[i] - mean) * (gray[i] - mean);
      const stdDev = Math.sqrt(varSum / n);
      if (stdDev < 2) return null;
      const norm = new Float32Array(n);
      for (let i = 0; i < n; i++) norm[i] = (gray[i] - mean) / stdDev;
      return norm;
    }

    /**
     * Extract a grayscale patch from mainGray at pixel position (cx, cy) in ORIGINAL image coords.
     * Returns { gray, w, h } in scaled coords, or null.
     */
    function extractScaledPatch(mainGray, mainW, mainH, scale, cx, cy, origPatchW, origPatchH) {
      const tw = Math.max(5, Math.round(origPatchW * scale));
      const th = Math.max(5, Math.round(origPatchH * scale));
      const x0 = Math.round(cx * scale - tw / 2);
      const y0 = Math.round(cy * scale - th / 2);
      if (x0 < 0 || y0 < 0 || x0 + tw > mainW || y0 + th > mainH) return null;
      const gray = new Float32Array(tw * th);
      for (let ty = 0; ty < th; ty++) {
        const srcOff = (y0 + ty) * mainW + x0;
        const dstOff = ty * tw;
        for (let tx = 0; tx < tw; tx++) gray[dstOff + tx] = mainGray[srcOff + tx];
      }
      return { gray, w: tw, h: th };
    }

    /**
     * Core template matching.
     * Positive templates: array of { norm, tw, th } — at least one.
     * Negative templates: array of { norm, tw, th } — can be empty.
     * Returns array of { x, y, score } in ORIGINAL image coords.
     */
    function runTemplateMatching(mainGray, mainW, mainH, scale, positiveTemplates, negativeTemplates, options) {
      const opts = Object.assign({
        matchThreshold: 0.50,
        negativeThreshold: 0.65,
        minDistanceFactor: 0.7,
        maxMatches: 300,
        origPatchW: 50,
        origPatchH: 50
      }, options || {});

      const t0 = performance.now();
      const primary = positiveTemplates[0];
      const tw = primary.tw;
      const th = primary.th;
      const STEP = Math.max(1, Math.floor(Math.min(tw, th) / 5));
      const endY = mainH - th;
      const endX = mainW - tw;
      const rawMatches = [];

      // Phase 1: Coarse scan with primary template
      for (let y = 0; y <= endY; y += STEP) {
        for (let x = 0; x <= endX; x += STEP) {
          const ncc = computeNCC(mainGray, mainW, x, y, tw, th, primary.norm);
          if (ncc >= opts.matchThreshold) {
            rawMatches.push({ sx: x, sy: y, score: ncc });
          }
        }
      }

      // Phase 2: Sub-pixel refinement
      const refined = [];
      for (const m of rawMatches) {
        let bestScore = m.score, bestX = m.sx, bestY = m.sy;
        for (let dy = -STEP; dy <= STEP; dy++) {
          for (let dx = -STEP; dx <= STEP; dx++) {
            const rx = m.sx + dx, ry = m.sy + dy;
            if (rx < 0 || ry < 0 || rx + tw > mainW || ry + th > mainH) continue;
            const ncc = computeNCC(mainGray, mainW, rx, ry, tw, th, primary.norm);
            if (ncc > bestScore) { bestScore = ncc; bestX = rx; bestY = ry; }
          }
        }

        // Phase 3: Multi-template scoring — average NCC across all positive templates
        let avgScore = bestScore;
        if (positiveTemplates.length > 1) {
          let totalScore = bestScore;
          for (let t = 1; t < positiveTemplates.length; t++) {
            const tpl = positiveTemplates[t];
            // Resize patch area to this template's size
            const cx = bestX + tw / 2, cy = bestY + th / 2;
            const ax = Math.round(cx - tpl.tw / 2), ay = Math.round(cy - tpl.th / 2);
            if (ax < 0 || ay < 0 || ax + tpl.tw > mainW || ay + tpl.th > mainH) {
              totalScore += bestScore * 0.5; // Partial credit for edge cases
              continue;
            }
            totalScore += computeNCC(mainGray, mainW, ax, ay, tpl.tw, tpl.th, tpl.norm);
          }
          avgScore = totalScore / positiveTemplates.length;
        }

        // Phase 4: Negative template filtering
        let isNegative = false;
        if (negativeTemplates.length > 0) {
          const cx = bestX + tw / 2, cy = bestY + th / 2;
          for (const neg of negativeTemplates) {
            const ax = Math.round(cx - neg.tw / 2), ay = Math.round(cy - neg.th / 2);
            if (ax < 0 || ay < 0 || ax + neg.tw > mainW || ay + neg.th > mainH) continue;
            const negScore = computeNCC(mainGray, mainW, ax, ay, neg.tw, neg.th, neg.norm);
            if (negScore >= opts.negativeThreshold) { isNegative = true; break; }
          }
        }

        if (!isNegative && avgScore >= opts.matchThreshold) {
          refined.push({
            x: (bestX + tw / 2) / scale,
            y: (bestY + th / 2) / scale,
            score: avgScore
          });
        }
      }

      // Phase 5: Non-maximum suppression
      refined.sort((a, b) => b.score - a.score);
      const minDist = Math.max(opts.origPatchW, opts.origPatchH) * opts.minDistanceFactor;
      const filtered = [];
      for (const m of refined) {
        if (filtered.length >= opts.maxMatches) break;
        let tooClose = false;
        for (const f of filtered) {
          const dx = m.x - f.x, dy = m.y - f.y;
          if (Math.sqrt(dx * dx + dy * dy) < minDist) { tooClose = true; break; }
        }
        if (!tooClose) filtered.push(m);
      }

      const t1 = performance.now();
      console.log(`[TemplateMatch] ${filtered.length} matches (${rawMatches.length} raw, ${positiveTemplates.length} pos tpl, ${negativeTemplates.length} neg tpl) in ${Math.round(t1 - t0)}ms`);
      return filtered;
    }

    /**
     * Initial template matching from a single template data-URL.
     */
    async function findTemplateMatches(mainDataUrl, templateDataUrl, options) {
      const opts = Object.assign({ maxMainDim: 2000, matchThreshold: 0.50, minDistanceFactor: 0.7, maxMatches: 300 }, options || {});

      const mainData = await imageToGray(mainDataUrl, opts.maxMainDim);
      const tplData = await imageToGray(templateDataUrl, opts.maxMainDim);
      if (!mainData || !tplData) return [];

      // Cache main data for re-scan
      _countState.mainGray = mainData.gray;
      _countState.mainW = mainData.w;
      _countState.mainH = mainData.h;
      _countState.origW = mainData.origW;
      _countState.origH = mainData.origH;
      _countState.scale = mainData.scale;

      const tplNorm = preNormalizeTemplate(tplData.gray, tplData.w, tplData.h);
      if (!tplNorm) return [];

      const positives = [{ norm: tplNorm, tw: tplData.w, th: tplData.h }];
      return runTemplateMatching(mainData.gray, mainData.w, mainData.h, mainData.scale, positives, [], {
        matchThreshold: opts.matchThreshold,
        minDistanceFactor: opts.minDistanceFactor,
        maxMatches: opts.maxMatches,
        origPatchW: tplData.origW,
        origPatchH: tplData.origH
      });
    }

    /**
     * Re-scan using learning: accepted matches become extra positive templates,
     * rejected matches become negative templates.
     */
    async function rescanWithLearning() {
      if (!_countState.mainGray || !_countState.templateDataUrl) {
        setStatusMsg('No previous scan to learn from');
        return;
      }

      const accepted = _countState.matches.filter(m => m.state === 'accepted');
      const rejected = _countState.matches.filter(m => m.state === 'rejected');

      if (accepted.length === 0 && rejected.length === 0) {
        setStatusMsg('Click markers to mark ✓ (correct) or ✗ (wrong), then Re-scan');
        return;
      }

      setStatusMsg(`Re-scanning with ${accepted.length} positive + ${rejected.length} negative examples…`);
      setApplyBusy(true);

      try {
        const { mainGray, mainW, mainH, scale, sel, templateDataUrl } = _countState;
        const selW = sel ? sel.w : 50;
        const selH = sel ? sel.h : 50;

        // Build primary template
        const tplData = await imageToGray(templateDataUrl, _countState.scale < 1 ? Math.round(1 / _countState.scale * 2000) : 2000);
        const tplNorm = tplData ? preNormalizeTemplate(tplData.gray, tplData.w, tplData.h) : null;
        if (!tplNorm) { setStatusMsg('Template error'); setApplyBusy(false); return; }

        const positives = [{ norm: tplNorm, tw: tplData.w, th: tplData.h }];
        const negatives = [];

        // Add accepted patches as positive templates
        for (const m of accepted) {
          const patch = extractScaledPatch(mainGray, mainW, mainH, scale, m.x, m.y, selW, selH);
          if (patch) {
            const norm = preNormalizeTemplate(patch.gray, patch.w, patch.h);
            if (norm) positives.push({ norm, tw: patch.w, th: patch.h });
          }
        }

        // Add rejected patches as negative templates
        for (const m of rejected) {
          const patch = extractScaledPatch(mainGray, mainW, mainH, scale, m.x, m.y, selW, selH);
          if (patch) {
            const norm = preNormalizeTemplate(patch.gray, patch.w, patch.h);
            if (norm) negatives.push({ norm, tw: patch.w, th: patch.h });
          }
        }

        // Compute an adaptive threshold: lower it slightly if we have positive examples
        const threshold = positives.length > 2 ? 0.45 : 0.50;

        const matches = runTemplateMatching(mainGray, mainW, mainH, scale, positives, negatives, {
          matchThreshold: threshold,
          negativeThreshold: 0.60,
          minDistanceFactor: 0.7,
          maxMatches: 300,
          origPatchW: selW,
          origPatchH: selH
        });

        // Update state
        _countState.matches = matches.map((m, i) => ({ ...m, state: 'pending', idx: i }));
        window._lastCountResult = {
          total: matches.length,
          matches: _countState.matches,
          description: `Re-scan: ${matches.length} matches (${positives.length} pos, ${negatives.length} neg templates)`
        };

        drawCountMarkers(_countState.matches, _countState.sel);

        const cr = window._lastCountResult;
        updateCountEditLog(cr);
        setStatusMsg(`Re-scan: ${matches.length} matches found (learned from ${accepted.length}✓ ${rejected.length}✗)`);

        // Auto-log the re-scan interaction for training pipeline
        _logCountInteraction(
          `Re-scan: ${matches.length} matches (${positives.length} pos tpl, ${negatives.length} neg tpl, learned ${accepted.length}✓ ${rejected.length}✗)`,
          _countState.matches,
          true
        );
      } catch (e) {
        console.error('[Rescan] Error:', e);
        setStatusMsg('Re-scan failed: ' + (e.message || e));
      } finally {
        setApplyBusy(false);
      }
    }

    /** Expose for inline onclick */
    window._rescanWithLearning = rescanWithLearning;

    // ────────────────────────────────────────────────────
    // Save counting results as YOLO training data
    // ────────────────────────────────────────────────────
    async function saveCountTrainingData() {
      const matches = _countState.matches;
      if (!matches || !matches.length) {
        setStatusMsg('No count data to save');
        return;
      }

      const accepted = matches.filter(m => m.state === 'accepted');
      const rejected = matches.filter(m => m.state === 'rejected');
      // If no explicit accepts, use all non-rejected (pending + accepted)
      const positiveMatches = accepted.length > 0
        ? accepted
        : matches.filter(m => m.state !== 'rejected');

      if (positiveMatches.length === 0) {
        setStatusMsg('No accepted matches to save as training data');
        return;
      }

      setStatusMsg(`Saving ${positiveMatches.length} matches as YOLO training data…`);
      setApplyBusy(true);

      try {
        const mainImg = _countState.mainDataUrl;
        const templateImg = _countState.templateDataUrl;
        const sel = _countState.sel;
        const imgW = _countState.origW || _countState.mainW;
        const imgH = _countState.origH || _countState.mainH;
        const selW = sel ? sel.w : 40;
        const selH = sel ? sel.h : 40;

        // Build YOLO-format annotations (class center_x center_y width height — all 0-1 normalized)
        const yoloAnnotations = positiveMatches.map(m => ({
          classId: 0,
          cx: Math.min(1, Math.max(0, m.x / imgW)),
          cy: Math.min(1, Math.max(0, m.y / imgH)),
          w:  Math.min(1, selW / imgW),
          h:  Math.min(1, selH / imgH),
          score: Math.round(m.score * 1000) / 1000
        }));

        // Build YOLO .txt format lines for reference
        const yoloTxt = yoloAnnotations
          .map(a => `${a.classId} ${a.cx.toFixed(6)} ${a.cy.toFixed(6)} ${a.w.toFixed(6)} ${a.h.toFixed(6)}`)
          .join('\n');

        const resultJson = JSON.stringify({
          mode: 'object-count',
          format: 'yolo-v8',
          imageWidth: imgW,
          imageHeight: imgH,
          templateWidth: selW,
          templateHeight: selH,
          totalScanned: matches.length,
          acceptedCount: positiveMatches.length,
          rejectedCount: rejected.length,
          annotations: yoloAnnotations,
          yoloTxt: yoloTxt,
          rawMatches: positiveMatches.map(m => ({
            x: Math.round(m.x), y: Math.round(m.y),
            score: Math.round(m.score * 1000) / 1000,
            state: m.state
          }))
        });

        // Downscale images for storage (higher res for YOLO training)
        const [drawingImg, tplImg] = await Promise.all([
          _downscaleForLog(mainImg, 1280),
          _downscaleForLog(templateImg, 256)
        ]);

        // 1. Log as AI Interaction with mode = 'object-count'
        const logId = await logAiInteraction(
          `YOLO training: ${positiveMatches.length} objects (${rejected.length} rejected)`,
          'template-matching',
          'object-count',
          true,
          `${positiveMatches.length} objects detected and confirmed`,
          resultJson,
          0, 0, 0, null,
          drawingImg, tplImg
        );

        // 2. Save as AI Example with category 'count-objects' for YOLO/Ollama learning
        const exampleId = await saveAiExample(
          'count-objects',
          ['counting', 'ספירה', 'yolo', 'object-detection', 'training', 'bounding-box'],
          `Count: ${positiveMatches.length} objects on ${_aiSessionFileName || 'drawing'}`,
          'template-matching',
          `${positiveMatches.length} objects with YOLO annotations`,
          resultJson,
          drawingImg,
          tplImg,
          1
        );

        // 3. Mark log feedback as "perfect" (user explicitly saved training data)
        if (logId) {
          try { await fetch(`${AI_LOG_ENDPOINT}/${logId}/feedback?feedback=2`, { method: 'POST' }); } catch {}
        }

        setStatusMsg(`✓ Saved ${positiveMatches.length} detections as YOLO training data (log #${logId || '?'}, example #${exampleId || '?'})`);
        console.log('[CountTraining] Saved YOLO data:', { logId, exampleId, annotations: yoloAnnotations.length, yoloTxt });

      } catch (e) {
        console.error('[CountTraining] Error:', e);
        setStatusMsg('Failed to save training data: ' + (e.message || e));
      } finally {
        setApplyBusy(false);
      }
    }
    window._saveCountTrainingData = saveCountTrainingData;

    // ────────────────────────────────────────────────────
    // Auto-log count interaction (called after count/re-scan)
    // ────────────────────────────────────────────────────
    async function _logCountInteraction(description, matches, isRescan) {
      try {
        const sel = _countState.sel;
        const imgW = _countState.origW || _countState.mainW;
        const imgH = _countState.origH || _countState.mainH;
        const selW = sel ? sel.w : 40;
        const selH = sel ? sel.h : 40;
        const accepted = matches.filter(m => m.state === 'accepted');
        const rejected = matches.filter(m => m.state === 'rejected');
        const pending  = matches.filter(m => m.state === 'pending');

        const resultJson = JSON.stringify({
          mode: isRescan ? 'object-count-rescan' : 'object-count',
          imageWidth: imgW,
          imageHeight: imgH,
          templateWidth: selW,
          templateHeight: selH,
          totalMatches: matches.length,
          acceptedCount: accepted.length,
          rejectedCount: rejected.length,
          pendingCount: pending.length,
          matches: matches.map(m => ({
            x: Math.round(m.x), y: Math.round(m.y),
            score: Math.round(m.score * 1000) / 1000,
            state: m.state
          }))
        });

        const [drawingImg, tplImg] = await Promise.all([
          _downscaleForLog(_countState.mainDataUrl, 512),
          _downscaleForLog(_countState.templateDataUrl, 256)
        ]);

        await logAiInteraction(
          description,
          'template-matching',
          isRescan ? 'object-count-rescan' : 'object-count',
          true,
          `${matches.length} matches (${accepted.length}✓ ${rejected.length}✗ ${pending.length}?)`,
          resultJson,
          0, 0, 0, null,
          drawingImg, tplImg
        );
      } catch (e) { console.warn('[CountLog] logging failed:', e); }
    }

    /** Update the edit log bar for count mode */
    function updateCountEditLog(cr) {
      if (!cr) return;
      const markerCount = (cr.matches || []).length;
      const accepted = (cr.matches || []).filter(m => m.state === 'accepted').length;
      const rejected = (cr.matches || []).filter(m => m.state === 'rejected').length;
      const pending = markerCount - accepted - rejected;
      const aiCountInfo = cr.aiCount ? ` (AI: ${cr.aiCount})` : '';

      setEditLog(
        `<span class="p2s-muted-text">Count:</span> <span class="text-emerald-300 font-bold text-base">${cr.total || '?'}</span>${aiCountInfo}` +
        `<span class="p2s-sep mx-2">|</span>` +
        (accepted > 0 ? `<span class="text-green-400">✓${accepted}</span> ` : '') +
        (rejected > 0 ? `<span class="text-red-400">✗${rejected}</span> ` : '') +
        (pending > 0 ? `<span class="text-amber-300">?${pending}</span>` : '') +
        `<span class="p2s-sep mx-2">|</span>` +
        `<span class="p2s-muted-text text-[10px]">Click markers to verify, then:</span>` +
        `<button type="button" onclick="window._rescanWithLearning()" class="ml-2 inline-flex items-center gap-1 px-2.5 py-1 rounded border border-violet-500/60 bg-violet-900/30 hover:bg-violet-900/50 text-[11px] text-violet-200 font-semibold transition"><i class="fa-solid fa-rotate text-[9px]"></i> Re-scan with Learning</button>` +
        `<button type="button" onclick="window._saveCountTrainingData()" class="ml-1 inline-flex items-center gap-1 px-2 py-1 rounded border border-emerald-500/60 bg-emerald-900/30 hover:bg-emerald-900/50 text-[10px] text-emerald-200 font-semibold transition" title="Save accepted markers as YOLO training data"><i class="fa-solid fa-database text-[8px]"></i> Save YOLO</button>` +
        `<button type="button" onclick="if(typeof clearMarks==='function')clearMarks();window._lastCountResult=null;_countState.matches=[];" class="ml-1 inline-flex items-center gap-1 px-2 py-1 rounded border border-slate-600 bg-slate-800 hover:bg-slate-700 text-[10px] text-slate-300 transition"><i class="fa-solid fa-xmark text-[8px]"></i> Clear</button>`
      );
    }
    window._updateCountEditLog = updateCountEditLog;

    async function analyzeSelectedObjectCountOnMainImage(baseDataUrl, sel, instructions, provider) {
      const payload = getSelectionEditPayload(sel);
      if (!payload) throw new Error('Failed to capture the selected object.');

      // Store for re-scan
      _countState.sel = sel;
      _countState.templateDataUrl = payload.dataUrl;
      _countState.mainDataUrl = currentDataUrl || baseDataUrl;

      // ── Run client-side template matching ──
      setStatusMsg('Scanning drawing for matching objects…');
      const templateMatches = await findTemplateMatches(_countState.mainDataUrl, payload.dataUrl, {
        maxMainDim: 2000,
        matchThreshold: 0.50,
        minDistanceFactor: 0.7
      });

      // Store with state tracking
      _countState.matches = templateMatches.map((m, i) => ({ ...m, state: 'pending', idx: i }));

      console.log(`[CountObjects] Template matching found ${templateMatches.length} matches`);

      // ── Also run Claude for description ──
      const fullImage = await downscaleDataUrl(baseDataUrl, 4096);
      const selectedImage = await downscaleDataUrl(payload.dataUrl, 512);
      const effectiveProvider = 'claude';
      const userPrompt = String(instructions || '').trim();

      const analysisPrompt = [
        'You are an expert at analyzing architectural/engineering drawings.',
        'Image 1: FULL drawing. Image 2: ONE target symbol from that drawing.',
        'Count how many instances of the target symbol appear in Image 1.',
        '- Scan entire drawing, count every match (rotated/mirrored/scaled).',
        '- First line: the exact number. Second line: brief description.',
        '- Reply in same language as user.',
        userPrompt ? `\nUser: ${userPrompt}` : ''
      ].filter(Boolean).join('\n');

      // Fetch examples for debug log
      const countExamples = await fetchMatchingExamples(analysisPrompt, 'count-objects', true);
      const countAllExamples = await fetchAllExamples('count-objects', 50, true);

      setAiDebugLog({
        mode: 'selection-count',
        requestSummary: `Local template matches: ${templateMatches.length}\nMatched examples: ${(countExamples.dbExamples?.length || 0)} DB + ${(countExamples.fileExamples?.length || 0)} file`,
        promptSent: analysisPrompt,
        payloadSent: { provider: effectiveProvider, localMatches: templateMatches.length },
        matchedExamples: countExamples,
        allExamples: countAllExamples
      });

      let aiCount = 0, aiDescription = '';
      try {
        const resp = await fetch(CHAT_RESPOND_ENDPOINT, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'X-Client-Id': 'admin' },
          body: JSON.stringify({ clientId: 'admin', provider: effectiveProvider, input: analysisPrompt, imageBase64: [fullImage, selectedImage] })
        });
        const rawText = await resp.text();
        if (resp.ok) {
          const answerText = extractTextFromAiResponseText(rawText);
          const numMatch = String(answerText).match(/(\d+)/);
          aiCount = numMatch ? parseInt(numMatch[1], 10) : 0;
          aiDescription = String(answerText).replace(/^\d+\s*\n?/, '').trim();
          setAiDebugLog({
            mode: 'selection-count',
            requestSummary: `Local: ${templateMatches.length}, AI: ${aiCount}\nMatched examples: ${(countExamples.dbExamples?.length || 0)} DB + ${(countExamples.fileExamples?.length || 0)} file`,
            promptSent: analysisPrompt,
            responseReceived: rawText,
            parsedResponse: answerText,
            matchedExamples: countExamples,
            allExamples: countAllExamples
          });
        }
      } catch (e) { console.warn('[CountObjects] AI error:', e); }

      const localCount = templateMatches.length;
      window._lastCountResult = {
        total: localCount,
        aiCount,
        localCount,
        matches: _countState.matches,
        description: aiDescription || `Found ${localCount} matching objects`
      };

      drawCountMarkers(_countState.matches, sel);

      // Auto-log the initial count interaction for training pipeline
      _logCountInteraction(
        `Initial count: ${localCount} matches (AI: ${aiCount}) — ${aiDescription || 'no description'}`,
        _countState.matches,
        false
      );

      _lastEditMode = 'selection-count';
      _lastEditProvider = effectiveProvider;
      return `${localCount} ${aiDescription}`.trim();
    }

    /**
     * Draw numbered circle markers. Color-coded by state:
     * pending = amber, accepted = green, rejected = red (dimmed + strikethrough).
     * Clicking on a marker cycles its state.
     */
    function drawCountMarkers(matches, sel) {
      if (!markCanvas || !matches || !matches.length) return;
      // Enable pointer-events so users can click markers to accept/reject
      markCanvas.style.pointerEvents = 'auto';
      markCanvas.style.cursor = 'pointer';
      const vctx = markCanvas.getContext('2d', { willReadFrequently: true });
      const cw = markCanvas.width, ch = markCanvas.height;
      vctx.clearRect(0, 0, cw, ch);

      const selW = sel ? sel.w : 40;
      const selH = sel ? sel.h : 40;
      const markerRadius = Math.max(8, Math.round(Math.max(selW, selH) * 0.55));
      const fontSize = Math.max(9, Math.round(markerRadius * 0.7));
      const lineWidth = Math.max(1.5, markerRadius / 10);

      const colors = {
        pending:  { stroke: '#f59e0b', fill: 'rgba(245,158,11,0.15)', text: '#f59e0b', label: 'rgba(30,30,30,0.85)' },
        accepted: { stroke: '#22c55e', fill: 'rgba(34,197,94,0.20)', text: '#22c55e', label: 'rgba(20,50,20,0.90)' },
        rejected: { stroke: '#ef4444', fill: 'rgba(239,68,68,0.10)', text: '#ef4444', label: 'rgba(50,20,20,0.85)' }
      };

      for (let i = 0; i < matches.length; i++) {
        const m = matches[i];
        const px = m.x, py = m.y;
        const c = colors[m.state || 'pending'];
        const isRejected = m.state === 'rejected';

        // Semi-transparent fill
        vctx.beginPath();
        vctx.arc(px, py, markerRadius, 0, Math.PI * 2);
        vctx.fillStyle = c.fill;
        vctx.fill();

        // Circle border
        vctx.beginPath();
        vctx.arc(px, py, markerRadius, 0, Math.PI * 2);
        vctx.strokeStyle = c.stroke;
        vctx.lineWidth = lineWidth;
        if (isRejected) { vctx.setLineDash([4, 4]); }
        vctx.stroke();
        vctx.setLineDash([]);

        // Inner crosshair
        const crossLen = markerRadius * 0.5;
        vctx.strokeStyle = c.stroke;
        vctx.globalAlpha = isRejected ? 0.4 : 0.8;
        vctx.lineWidth = Math.max(1, lineWidth * 0.6);
        vctx.beginPath(); vctx.moveTo(px - crossLen, py); vctx.lineTo(px + crossLen, py); vctx.stroke();
        vctx.beginPath(); vctx.moveTo(px, py - crossLen); vctx.lineTo(px, py + crossLen); vctx.stroke();
        vctx.globalAlpha = 1;

        // Strikethrough for rejected
        if (isRejected) {
          vctx.strokeStyle = '#ef4444';
          vctx.lineWidth = 2;
          vctx.beginPath();
          vctx.moveTo(px - markerRadius, py - markerRadius);
          vctx.lineTo(px + markerRadius, py + markerRadius);
          vctx.stroke();
        }

        // Number label
        const label = String(i + 1);
        vctx.font = `bold ${fontSize}px sans-serif`;
        vctx.textAlign = 'center';
        vctx.textBaseline = 'bottom';
        const tm = vctx.measureText(label);
        const bgW = Math.max(tm.width + 6, fontSize + 2);
        const bgH = fontSize + 4;
        const labelX = px, labelY = py - markerRadius - 3;

        vctx.fillStyle = c.label;
        vctx.beginPath();
        vctx.roundRect(labelX - bgW / 2, labelY - bgH, bgW, bgH, 3);
        vctx.fill();
        vctx.fillStyle = c.text;
        vctx.fillText(label, labelX, labelY - 2);

        // State icon
        if (m.state === 'accepted') {
          vctx.font = `bold ${Math.round(fontSize * 0.9)}px sans-serif`;
          vctx.fillStyle = '#22c55e';
          vctx.textAlign = 'center';
          vctx.textBaseline = 'middle';
          vctx.fillText('✓', px, py);
        } else if (m.state === 'rejected') {
          vctx.font = `bold ${Math.round(fontSize * 0.9)}px sans-serif`;
          vctx.fillStyle = '#ef4444';
          vctx.textAlign = 'center';
          vctx.textBaseline = 'middle';
          vctx.fillText('✗', px, py);
        }
      }

      // Total badge at top-right
      const accepted = matches.filter(m => m.state === 'accepted').length;
      const rejected = matches.filter(m => m.state === 'rejected').length;
      const pending = matches.length - accepted - rejected;

      const badgeFontSize = Math.max(14, Math.round(Math.min(cw, ch) / 55));
      const totalText = `Total: ${matches.length - rejected}` + (rejected > 0 ? ` (${rejected} rejected)` : '');
      vctx.font = `bold ${badgeFontSize}px sans-serif`;
      vctx.textAlign = 'right';
      vctx.textBaseline = 'top';
      const ttm = vctx.measureText(totalText);
      const badgeX = cw - 10, badgeY = 10;
      const badgeW = ttm.width + 20, badgeH = badgeFontSize + 14;

      vctx.fillStyle = 'rgba(0,0,0,0.85)';
      vctx.beginPath(); vctx.roundRect(badgeX - badgeW, badgeY, badgeW, badgeH, 6); vctx.fill();
      vctx.strokeStyle = '#f59e0b';
      vctx.lineWidth = 2;
      vctx.beginPath(); vctx.roundRect(badgeX - badgeW, badgeY, badgeW, badgeH, 6); vctx.stroke();
      vctx.fillStyle = '#fbbf24';
      vctx.fillText(totalText, badgeX - 8, badgeY + 7);

      // Instructions hint
      const hintText = 'Click marker: ✓/✗ → Re-scan with Learning';
      vctx.font = `${Math.max(11, Math.round(badgeFontSize * 0.75))}px sans-serif`;
      const htm = vctx.measureText(hintText);
      const hintY = badgeY + badgeH + 6;
      vctx.fillStyle = 'rgba(0,0,0,0.7)';
      vctx.beginPath(); vctx.roundRect(badgeX - htm.width - 16, hintY, htm.width + 16, badgeFontSize + 4, 4); vctx.fill();
      vctx.fillStyle = '#94a3b8';
      vctx.textAlign = 'right';
      vctx.fillText(hintText, badgeX - 8, hintY + Math.round(badgeFontSize * 0.85));
    }

    /**
     * Handle clicks on the markCanvas to toggle marker states.
     */
    function handleCountMarkerClick(e) {
      if (!_countState.matches.length) return;
      if (!markCanvas) return;
      // Don't intercept clicks when crop or select-region mode is active
      if (cropMode || selectRegionMode) return;

      // Get click coordinates in canvas pixel space
      const rect = markCanvas.getBoundingClientRect();
      const scaleX = markCanvas.width / rect.width;
      const scaleY = markCanvas.height / rect.height;
      const cx = (e.clientX - rect.left) * scaleX;
      const cy = (e.clientY - rect.top) * scaleY;

      const selW = _countState.sel ? _countState.sel.w : 40;
      const selH = _countState.sel ? _countState.sel.h : 40;
      const hitRadius = Math.max(20, Math.max(selW, selH) * 0.7);

      // Find closest marker within hit radius
      let closestIdx = -1, closestDist = Infinity;
      for (let i = 0; i < _countState.matches.length; i++) {
        const m = _countState.matches[i];
        const dx = m.x - cx, dy = m.y - cy;
        const d = Math.sqrt(dx * dx + dy * dy);
        if (d < hitRadius && d < closestDist) {
          closestDist = d;
          closestIdx = i;
        }
      }

      if (closestIdx === -1) return;
      e.preventDefault();
      e.stopPropagation();

      // Cycle state: pending → accepted → rejected → pending
      const m = _countState.matches[closestIdx];
      if (m.state === 'pending') m.state = 'accepted';
      else if (m.state === 'accepted') m.state = 'rejected';
      else m.state = 'pending';

      console.log(`[CountMarker] Marker ${closestIdx + 1} → ${m.state} (score=${m.score.toFixed(3)})`);

      // Redraw and update log
      drawCountMarkers(_countState.matches, _countState.sel);

      // Update the stored result
      const cr = window._lastCountResult;
      if (cr) {
        cr.matches = _countState.matches;
        cr.total = _countState.matches.filter(m => m.state !== 'rejected').length;
        updateCountEditLog(cr);
      }
    }

    // Attach click handler to markCanvas — only fires when we have count markers
    if (markCanvas) {
      markCanvas.addEventListener('click', (e) => {
        if (_countState.matches.length > 0) handleCountMarkerClick(e);
      }, true); // Use capture to get it before other handlers
    }

    function extractTextFromAiResponseText(rawText) {
      let answerText = String(rawText || '').trim();
      try {
        const parsed = JSON.parse(rawText);
        if (parsed && parsed.choices && parsed.choices[0] && parsed.choices[0].message && parsed.choices[0].message.content) {
          return String(parsed.choices[0].message.content || '').trim();
        }
        if (parsed && parsed.content) {
          return String(parsed.content || '').trim();
        }
        if (parsed && parsed.message && parsed.message.content) {
          return String(parsed.message.content || '').trim();
        }
        if (parsed && Array.isArray(parsed.output)) {
          const parts = [];
          for (const item of parsed.output) {
            if (!item || item.type !== 'message' || !Array.isArray(item.content)) continue;
            for (const part of item.content) {
              if (!part) continue;
              if (typeof part.text === 'string' && part.text.trim()) parts.push(part.text.trim());
              else if (typeof part.output_text === 'string' && part.output_text.trim()) parts.push(part.output_text.trim());
            }
          }
          if (parts.length) return parts.join('\n').trim();
        }
      } catch { }
      return answerText;
    }

    function escapeHtml(s) {
      return (s || '').replace(/[&<>"']/g, (ch) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[ch]));
    }

    function extractProviderErrorMessage(rawText, fallbackMessage) {
      const fallback = fallbackMessage || 'Request failed.';
      try {
        const parsed = JSON.parse(rawText);
        if (parsed && parsed.error && parsed.error.message) return String(parsed.error.message);
        if (parsed && parsed.detail) {
          try {
            const detailParsed = JSON.parse(parsed.detail);
            if (detailParsed && detailParsed.error && detailParsed.error.message) return String(detailParsed.error.message);
          } catch { }
          return String(parsed.detail);
        }
        if (parsed && parsed.message) return String(parsed.message);
      } catch { }
      return String(rawText || fallback);
    }

    function getLocalEditSummary(instructions) {
      const instr = (instructions || '').toLowerCase();
      const removeRed = instr.includes('remove red') || instr.includes('red') || instr.includes('אדום') || instr.includes('להוריד אדום') || instr.includes('הסר אדום') || instr.includes('הסר קווים אדומים');
      const removeThin = instr.includes('remove thin') || instr.includes('thin lines') || instr.includes('הסר קווים דקים') || instr.includes('קווים דקים');
      const actions = [];
      if (removeRed) actions.push('remove red-ish pixels');
      if (removeThin) actions.push('remove thin dark lines');
      return actions;
    }

    /**
     * Parse predefined operations from the multi-select instruction string.
     * Returns array of operation objects if matched, or null if free-form text.
     */
    function parseDirectOps(instructions) {
      const m = (instructions || '').match(/^Apply exactly these operations:\s*(.+)$/i);
      if (!m) return null;
      const opNames = m[1].split(/\s*,\s*/).map(s => s.trim()).filter(Boolean);
      if (!opNames.length) return null;
      const ops = [];
      for (const raw of opNames) {
        // Handle ops like "removeColor red", "keepColor gray"
        const parts = raw.split(/\s+/);
        const type = parts[0];
        const color = parts[1] || undefined;
        const op = { type };
        if (color) op.color = color;
        ops.push(op);
      }
      return ops;
    }

