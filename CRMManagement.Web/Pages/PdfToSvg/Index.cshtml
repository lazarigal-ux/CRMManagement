  async function loadFireProjects() {
    if (!fireProjectSelect) return;
    try {
      fireProjectSelect.innerHTML = '<option value="">Loading…</option>';
      const resp = await fetch(PROJECT_LIST_ENDPOINT, {
        method: 'GET',
        headers: { 'X-Client-Id': 'admin' }
      });
      if (!resp.ok) throw new Error(`HTTP ${resp.status}`);
      const text = await resp.text();
      if (!text || !text.trim()) throw new Error('Empty response');
      const result = JSON.parse(text);
      if (!result || !result.ok) {
        const msg = (result && result.error) ? result.error : 'Failed to load projects';
        throw new Error(msg);
      }

      const projects = Array.isArray(result.projects) ? result.projects : [];
      let html = '<option value="">Select project…</option>';
      for (const p of projects) {
        const id = (p && typeof p.id !== 'undefined') ? String(p.id) : '';
        const name = (p && typeof p.name !== 'undefined') ? String(p.name) : '';
        if (!id) continue;
        html += `<option value="${escapeHtml(id)}">${escapeHtml(name || ('#' + id))}</option>`;
      }
      fireProjectSelect.innerHTML = html;
    } catch (e) {
      fireProjectSelect.innerHTML = '<option value="">(no projects)</option>';
    }
  }
  const _toastContainer = document.getElementById('toastContainer');
  let _activeToast = null;
  function setStatus(msg, type) {
    if (!_toastContainer || !msg) return;
    // Remove previous in-progress toast when a new one arrives
    if (_activeToast) { _activeToast.remove(); _activeToast = null; }

    const tone = type === 'error'
      ? { border: 'rgba(251,113,133,.55)', bg: 'rgba(225,29,72,.90)' }
      : type === 'success'
        ? { border: 'rgba(52,211,153,.55)', bg: 'rgba(5,150,105,.90)' }
        : { border: 'rgba(251,146,60,.60)', bg: 'rgba(234,88,12,.92)' };
    const icon = type === 'error'
      ? 'fa-solid fa-circle-xmark'
      : type === 'success'
        ? 'fa-solid fa-circle-check'
        : 'fa-solid fa-circle-info';

    const toast = document.createElement('div');
    toast.className = 'pointer-events-auto rounded-xl border text-white shadow-[0_8px_30px_rgba(2,6,23,.35)] transition-all duration-500 opacity-0 translate-x-4';
    toast.style.borderColor = tone.border;
    toast.style.backgroundColor = tone.bg;
    toast.innerHTML = `<div class="flex items-start gap-3 px-4 py-3">
      <i class="${icon} mt-0.5"></i>
      <div class="text-sm">${msg}</div>
      <button type="button" class="ml-auto text-white/80 hover:text-white" onclick="this.closest('[class*=rounded-xl]').remove()">
        <i class="fa-solid fa-xmark"></i>
      </button>
    </div>`;
    _toastContainer.appendChild(toast);
    _activeToast = toast;

    // Animate in
    requestAnimationFrame(() => { toast.classList.remove('opacity-0','translate-x-4'); toast.classList.add('opacity-100','translate-x-0'); });

    // Auto-dismiss for success/error
    const delay = type === 'error' ? 6000 : type === 'success' ? 4000 : 0;
    if (delay > 0) {
      setTimeout(() => {
        toast.classList.add('opacity-0','translate-x-4');
        toast.classList.remove('opacity-100','translate-x-0');
        setTimeout(() => { toast.remove(); if (_activeToast === toast) _activeToast = null; }, 500);
      }, delay);
    }
  }

  // Project dropdown initialization
  try { loadFireProjects(); } catch { }

  function getCorpFromId(id) {
    const s = String(id ?? '').trim();
    if (!s) return '';
    const dash = s.indexOf('-');
    return (dash > 0 ? s.slice(0, dash) : s).trim().toUpperCase();
  }

  // ── PDF zoom ──
  function setPdfZoom(z) {
    pdfZoom = Math.max(0.1, Math.min(6, z));
    if (pdfInner) pdfInner.style.transform = `scale(${pdfZoom})`;
    if (pdfZoomLabel) pdfZoomLabel.textContent = Math.round(pdfZoom * 100) + '%';
  }
  if (btnPdfZoomIn)  btnPdfZoomIn.addEventListener('click', () => setPdfZoom(pdfZoom + 0.1));
  if (btnPdfZoomOut) btnPdfZoomOut.addEventListener('click', () => setPdfZoom(pdfZoom - 0.1));
  if (btnPdfZoomFit) btnPdfZoomFit.addEventListener('click', () => {
    if (!pdfViewport) return;
    const firstImg = pdfPages ? pdfPages.querySelector('img') : null;
    if (!firstImg) return;
    const imgW = firstImg.naturalWidth || firstImg.getBoundingClientRect().width || 1;
    const viewportW = pdfViewport.clientWidth || 1;
    setPdfZoom(Math.max(0.1, Math.min(6, (viewportW - 24) / imgW)));
  });

  // ── Preview Crop ──
  const btnPreviewCrop      = document.getElementById('btnPreviewCropMode');
  const btnPreviewApplyCrop = document.getElementById('btnPreviewApplyCrop');
  const previewCropStatusEl = document.getElementById('previewCropStatus');

  function setPreviewCropStatus(msg) {
    if (previewCropStatusEl) previewCropStatusEl.textContent = msg || '';
  }

  function clearPreviewCropSelection() {
    previewCropSelection = null;
    previewCropStart = null;
    previewCropSnapshot = null;
    previewCropLastPt = null;
    previewCropRafPending = false;
    previewCropPageIdx = null;
    // Clear all crop canvases
    if (pdfPages) {
      pdfPages.querySelectorAll('canvas.pdfPreviewCropCanvas').forEach(c => {
        const ctx = c.getContext('2d');
        ctx.clearRect(0, 0, c.width, c.height);
      });
    }
    setPreviewCropStatus('');
  }

  function setPreviewCropInteractivity(enabled) {
    if (!pdfPages) return;
    pdfPages.querySelectorAll('canvas.pdfPreviewCropCanvas').forEach(c => {
      c.style.pointerEvents = enabled ? 'auto' : 'none';
      c.style.cursor = enabled ? 'crosshair' : '';
      c.style.zIndex = enabled ? '999' : '40';
      c.style.touchAction = 'none';
      c.style.background = enabled ? 'rgba(139, 92, 246, 0.01)' : 'transparent';
      if (c.width < 2 || c.height < 2) {
        const sibImg = c.parentElement ? c.parentElement.querySelector('img') : null;
        if (sibImg && sibImg.naturalWidth > 0) {
          c.width = sibImg.naturalWidth;
          c.height = sibImg.naturalHeight;
        }
      }
      // Attach / detach mousedown handler for crop drag
      if (c._previewCropMousedown) {
        c.removeEventListener('mousedown', c._previewCropMousedown);
        c._previewCropMousedown = null;
      }
      if (enabled) {
        c._previewCropMousedown = (ev) => beginPreviewCrop(c, ev);
        c.addEventListener('mousedown', c._previewCropMousedown);
      }
    });
    pdfPages.querySelectorAll('[id^="pdfOverlayHost_"]').forEach(h => {
      h.style.display = enabled ? 'none' : '';
      h.style.pointerEvents = enabled ? 'none' : '';
    });
  }

  function previewCropCanvasPointFromEvent(ev, canvas) {
    const rect = canvas.getBoundingClientRect();
    const scaleX = canvas.width / rect.width;
    const scaleY = canvas.height / rect.height;
    return {
      x: (ev.clientX - rect.left) * scaleX,
      y: (ev.clientY - rect.top) * scaleY
    };
  }

  function drawPreviewCropRect(canvas, a, b, snapshot) {
    if (!canvas) return;
    const ctx = canvas.getContext('2d');
    if (snapshot) ctx.putImageData(snapshot, 0, 0);
    else ctx.clearRect(0, 0, canvas.width, canvas.height);
    const x0 = Math.min(a.x, b.x), y0 = Math.min(a.y, b.y);
    const w = Math.max(1, Math.abs(b.x - a.x)), h = Math.max(1, Math.abs(b.y - a.y));
    ctx.fillStyle = 'rgba(139, 92, 246, 0.12)';
    ctx.fillRect(x0, y0, w, h);
    ctx.strokeStyle = 'rgba(139, 92, 246, 0.80)';
    ctx.lineWidth = 2;
    ctx.setLineDash([6, 3]);
    ctx.strokeRect(x0, y0, w, h);
    ctx.setLineDash([]);
  }

  function commitPreviewCropRect(canvas, a, b, pageIdx) {
    if (!canvas) return null;
    const x0 = Math.floor(Math.max(0, Math.min(a.x, b.x)));
    const y0 = Math.floor(Math.max(0, Math.min(a.y, b.y)));
    const x1 = Math.ceil(Math.min(canvas.width, Math.max(a.x, b.x)));
    const y1 = Math.ceil(Math.min(canvas.height, Math.max(a.y, b.y)));
    const w = Math.max(0, x1 - x0), h = Math.max(0, y1 - y0);
    if (w < 5 || h < 5) return null;
    const ctx = canvas.getContext('2d');
    ctx.clearRect(0, 0, canvas.width, canvas.height);
    ctx.fillStyle = 'rgba(139, 92, 246, 0.12)';
    ctx.fillRect(x0, y0, w, h);
    ctx.strokeStyle = 'rgba(139, 92, 246, 0.85)';
    ctx.lineWidth = 2;
    ctx.setLineDash([6, 3]);
    ctx.strokeRect(x0, y0, w, h);
    ctx.setLineDash([]);
    return { pageIdx, x0, y0, w, h };
  }

  function beginPreviewCrop(canvas, ev) {
    if (!previewCropMode || !canvas) return;
    ev.preventDefault();
    ev.stopPropagation();
    const pageIdx = parseInt(canvas.dataset.pageIdx || '-1', 10);
    if (!Number.isFinite(pageIdx) || pageIdx < 0) return;
    clearPreviewCropSelection();
    previewCropPageIdx = pageIdx;
    previewCropStart = previewCropCanvasPointFromEvent(ev, canvas);
    const ctx = canvas.getContext('2d');
    previewCropSnapshot = ctx.getImageData(0, 0, canvas.width, canvas.height);
    previewCropLastPt = previewCropStart;
  }

  function handlePreviewCropWindowMove(ev) {
    if (!previewCropMode || previewCropStart === null || previewCropPageIdx === null || !pdfPages) return;
    const canvas = pdfPages.querySelector(`canvas.pdfPreviewCropCanvas[data-page-idx="${previewCropPageIdx}"]`);
    if (!canvas) return;
    previewCropLastPt = previewCropCanvasPointFromEvent(ev, canvas);
    if (previewCropRafPending) return;
    previewCropRafPending = true;
    window.requestAnimationFrame(() => {
      previewCropRafPending = false;
      if (!previewCropMode || !previewCropStart || !previewCropLastPt) return;
      drawPreviewCropRect(canvas, previewCropStart, previewCropLastPt, previewCropSnapshot);
    });
  }

  function handlePreviewCropWindowUp(ev) {
    if (!previewCropMode || previewCropStart === null || previewCropPageIdx === null || !pdfPages) return;
    const canvas = pdfPages.querySelector(`canvas.pdfPreviewCropCanvas[data-page-idx="${previewCropPageIdx}"]`);
    if (!canvas) return;
    const pt = previewCropCanvasPointFromEvent(ev, canvas);
    previewCropSelection = commitPreviewCropRect(canvas, previewCropStart, pt, previewCropPageIdx);
    previewCropStart = null;
    previewCropSnapshot = null;
    previewCropLastPt = null;
    previewCropRafPending = false;
    setPreviewCropStatus(previewCropSelection ? 'Crop selected — click Apply Crop' : 'Crop too small');
  }

  async function loadPreviewCropImage(src) {
    return await new Promise((resolve, reject) => {
      const img = new Image();
      img.onload = () => resolve(img);
      img.onerror = reject;
      img.src = src;
    });
  }

  // Toggle crop mode on/off
  if (btnPreviewCrop) {
    btnPreviewCrop.addEventListener('click', () => {
      previewCropMode = !previewCropMode;
      btnPreviewCrop.classList.toggle('ring-2', previewCropMode);
      btnPreviewCrop.classList.toggle('ring-violet-300/50', previewCropMode);
      setPreviewCropInteractivity(previewCropMode);
      if (!previewCropMode) {
        clearPreviewCropSelection();
        setPreviewCropStatus('');
      } else {
        setPreviewCropStatus('Drag to select crop area');
      }
    });
  }

  window.addEventListener('mousemove', handlePreviewCropWindowMove);
  window.addEventListener('mouseup', handlePreviewCropWindowUp);

  // Apply the crop
  if (btnPreviewApplyCrop) {
    btnPreviewApplyCrop.addEventListener('click', async () => {
      if (!previewCropSelection || !lastPdfPages.length) {
        setPreviewCropStatus('No crop selected');
        return;
      }
      const { x0, y0, w, h } = previewCropSelection;
      const newPages = [];
      for (let i = 0; i < lastPdfPages.length; i++) {
        const src = lastPdfPages[i];
        const currentPreviewImg = pdfPages ? pdfPages.querySelector(`div:nth-child(${i + 1}) > img`) : null;
        const tmpImg = (currentPreviewImg && currentPreviewImg.naturalWidth > 0)
          ? currentPreviewImg
          : await loadPreviewCropImage(src);

        const tmpCanvas = document.createElement('canvas');
        // Crop dimensions come from the page that was selected;
        // For pages of the same size, use the same crop.
        // For safety, clamp to the image natural size.
        const natW = tmpImg.naturalWidth || tmpImg.width || w;
        const natH = tmpImg.naturalHeight || tmpImg.height || h;
        const cx0 = Math.min(x0, natW);
        const cy0 = Math.min(y0, natH);
        const cw = Math.min(w, natW - cx0);
        const ch = Math.min(h, natH - cy0);
        if (cw < 1 || ch < 1) { newPages.push(src); continue; }

        tmpCanvas.width = cw;
        tmpCanvas.height = ch;
        const tctx = tmpCanvas.getContext('2d');
        tctx.fillStyle = '#ffffff';
        tctx.fillRect(0, 0, cw, ch);
        tctx.drawImage(tmpImg, cx0, cy0, cw, ch, 0, 0, cw, ch);
        newPages.push(tmpCanvas.toDataURL('image/png'));
      }
      // Re-render with cropped pages
      previewCropMode = false;
      if (btnPreviewCrop) {
        btnPreviewCrop.classList.remove('ring-2', 'ring-violet-300/50');
      }
      setPreviewCropInteractivity(false);
      renderPdfPreviewFromPages(newPages);
      setPreviewCropStatus('Crop applied');
    });
  }

  // ── Layer detection ──
  function clearLayers() {
    detectedLayers = [];
    selectedVisibleLayerIndices = new Set();
    if (layerList) layerList.innerHTML = '';
    if (layerCount) layerCount.textContent = '0';
    if (layerCountText) layerCountText.textContent = '0';
    if (layerCard) layerCard.classList.add('hidden');
  }

  function renderLayers(layers) {
    clearLayers();
    detectedLayers = Array.isArray(layers) ? layers : [];
    if (!detectedLayers.length) return;

    for (const l of detectedLayers) {
      if (l && typeof l.index === 'number') selectedVisibleLayerIndices.add(l.index);
    }
    if (layerCount) layerCount.textContent = String(detectedLayers.length);
    if (layerCountText) layerCountText.textContent = String(detectedLayers.length);
    if (layerList) {
      layerList.innerHTML = '';
      for (const l of detectedLayers) {
        const label = document.createElement('label');
        label.className = 'flex items-start gap-2 cursor-pointer select-none text-sm p2s-text hover:opacity-90 transition';
        const cb = document.createElement('input');
        cb.type = 'checkbox'; cb.checked = true; cb.value = String(l.index);
        cb.className = 'mt-0.5 w-4 h-4 shrink-0 rounded p2s-chk text-amber-500 focus:ring-amber-500 focus:ring-offset-0';
        cb.addEventListener('change', () => {
          const idx = parseInt(cb.value, 10);
          if (Number.isFinite(idx)) { cb.checked ? selectedVisibleLayerIndices.add(idx) : selectedVisibleLayerIndices.delete(idx); }
        });
        const span = document.createElement('span');
        span.className = 'min-w-0 break-words leading-snug'; span.dir = 'auto';
        span.textContent = l.name || `Layer ${l.index + 1}`;
        label.appendChild(cb); label.appendChild(span);
        layerList.appendChild(label);
      }
    }
    if (layerCard) layerCard.classList.remove('hidden');
  }

  async function detectLayersForPdf(file) {
    clearLayers();
    if (!file) return;
    try {
      const fd = new FormData(); fd.append('pdf', file, file.name);
      const resp = await fetch(LAYERS_ENDPOINT, { method: 'POST', body: fd, headers: { 'X-Client-Id': 'admin' } });
      if (!resp.ok) return;
      renderLayers(safeJsonParse(await resp.text(), []));
    } catch { /* ignore */ }
  }

  // ── PDF preview ──
  function clearPdfPreview() {
    if (pdfPages) pdfPages.innerHTML = '';
    if (pdfPreviewCard) pdfPreviewCard.classList.add('hidden');
    setPdfZoom(1);
  }

  async function renderPdfPreview(file, visibleLayersCsv, targetDpi) {
    clearPdfPreview();
    if (!file) return;
    const spinner = document.getElementById('pdfLoadingSpinner');
    const emptyState = document.querySelector('#tabPreview > .p2s-empty-state');
    if (emptyState) emptyState.classList.add('hidden');
    if (spinner) { spinner.classList.remove('pdf-loader-hidden'); spinner.setAttribute('aria-hidden','false'); }
    try {
      const fd = new FormData(); fd.append('pdf', file, file.name);
      const qs = new URLSearchParams();
      // Default: fast preview.
      // If targetDpi is provided (e.g., 300), render a higher-res raster like a "print screen".
      if (Number.isFinite(targetDpi) && targetDpi > 0) qs.set('dpi', String(Math.round(targetDpi)));
      else qs.set('maxDim', '1600');
      if (visibleLayersCsv) qs.set('visibleLayers', visibleLayersCsv);
      const resp = await fetch(`${PREVIEW_ENDPOINT}?${qs.toString()}`, { method: 'POST', body: fd, headers: { 'X-Client-Id': 'admin' } });
      const text = await resp.text();
      if (!resp.ok) return;
      const payload = safeJsonParse(text, null);
      if (!payload || !payload.pages) return;
      lastPdfPages = Array.isArray(payload.pages) ? payload.pages : [];

      // ── Drawing Scale: store PDF original dimensions ──
      if (Array.isArray(payload.pageDims) && payload.pageDims.length > 0) {
        const md = (payload && typeof payload.maxDimUsed === 'number') ? payload.maxDimUsed : 1600;
        updatePdfScaleData(payload.pageDims[0], md);
      }

      pdfPages.innerHTML = '';
      previewCropSelection = null;
      let pageIndex = 0;
      for (const src of (Array.isArray(payload.pages) ? payload.pages : [])) {
        const wrap = document.createElement('div');
        wrap.className = 'relative w-full';

        const img = document.createElement('img');
        img.src = src;
        img.alt = 'PDF page';
        img.className = 'block max-w-none w-full';

        const overlayHost = document.createElement('div');
        overlayHost.id = `pdfOverlayHost_${pageIndex}`;
        overlayHost.className = 'absolute inset-0';

        // Crop overlay canvas
        const cropCanvas = document.createElement('canvas');
        cropCanvas.className = 'pdfPreviewCropCanvas absolute inset-0 block';
        cropCanvas.dataset.pageIdx = String(pageIndex);
        cropCanvas.style.width = '100%';
        cropCanvas.style.height = '100%';
        cropCanvas.style.pointerEvents = 'none';
        cropCanvas.style.zIndex = '40';
        const _setCropDim2 = () => {
          if (img.naturalWidth > 0) { cropCanvas.width = img.naturalWidth; cropCanvas.height = img.naturalHeight; }
        };
        img.addEventListener('load', _setCropDim2);
        if (img.complete) _setCropDim2();

        wrap.appendChild(img);
        wrap.appendChild(overlayHost);
        wrap.appendChild(cropCanvas);
        pdfPages.appendChild(wrap);
        pageIndex++;
      }
      if (pdfPreviewCard) pdfPreviewCard.classList.toggle('hidden', !payload.pages.length);
      setPdfZoom(1);

      if (lastAnalysis && window.pdfBuildWallOverlay) {
        window.pdfBuildWallOverlay(lastAnalysis);
      }
    } catch { /* ignore */ } finally {
      if (spinner) { spinner.classList.add('pdf-loader-hidden'); spinner.setAttribute('aria-hidden','true'); }
    }
  }

  // ── On file select: detect layers + preview ──
  pdfInput.addEventListener('change', async () => {
    const f = pdfInput.files && pdfInput.files[0];
    if (!f) return;
    // Start new AI session for this PDF
    _aiNewSession();
    _aiSessionFileName = f.name || '';
    try { _aiSessionDpi = parseInt(document.getElementById('pdfImageBuildDpi')?.value) || 0; } catch { _aiSessionDpi = 0; }
    detectLayersForPdf(f);
    showProcessing('Rasterizing PDF…', 'Converting PDF pages to high-resolution images');
    try {
      // Use the user-selected DPI from the start so the initial image is high-res
      await renderPdfPreview(f, '', getSelectedPdfPreviewDpi());
      // After preview is ready, populate the PDF Image tab immediately
      try { showPdfImageTab({ switchToTab: false }); } catch (_e) { /* ignore */ }
    } finally {
      hideProcessing();
    }
    // Reset sections
    scaleSection.classList.add('hidden');
    floorPlanSection.classList.add('hidden');
    btnExportSvg.classList.add('hidden');
    btnExportJson.classList.add('hidden');
    lastAnalysis = null;
    currentReportId = null;
    ensureReportNameDefaultIfEmpty();
  });

  // ── Scale recalculation ──
  document.getElementById('btnRecalcScale')?.addEventListener('click', () => {
    const avgRadiusPt = parseFloat(scaleRatioInput.dataset.avgRadiusPt || '0');
    const doorWidthCm = parseFloat(doorWidthInput.value) || 70;
    if (avgRadiusPt > 0) {
      const ptToCm = 0.03528;
      const doorOnPaperCm = avgRadiusPt * ptToCm;
      const rawScale = doorWidthCm / doorOnPaperCm;
      const niceScales = [10,20,25,50,75,100,125,150,200,250,300,400,500,750,1000];
      let best = niceScales[0];
      for (const n of niceScales) { if (Math.abs(n - rawScale) < Math.abs(best - rawScale)) best = n; }
      const deviation = rawScale > 0 ? Math.abs(best - rawScale) / rawScale * 100 : 100;
      const finalScale = deviation <= 20 ? best : Math.round(rawScale);
      scaleRatioInput.value = finalScale;
      scaleStatusMsg.textContent = `Recalculated with door = ${doorWidthCm} cm → 1:${finalScale}`;
      // Re-render floor plan with new scale
      if (lastAnalysis) renderFloorPlan(lastAnalysis);
    } else {
      scaleStatusMsg.textContent = 'No arc data available. Enter scale manually.';
    }
  });

  // ── Render Drawing Scale section ──
  function renderScale(analysis) {
    const si = analysis.scaleInfo;
    if (si && si.doorCount > 0) {
      scaleRatioInput.value = Math.round(si.scaleRatio);
      doorWidthInput.value = si.referenceDoorWidthCm || 70;
      doorCountBadge.textContent = `${si.doorCount} door arc${si.doorCount > 1 ? 's' : ''} detected`;
      scaleStatusMsg.textContent = `Avg radius: ${si.avgRadiusPt} pt · Detected scale: ${si.scaleLabel}`;
      scaleRatioInput.dataset.avgRadiusPt = si.avgRadiusPt;
    } else {
      scaleRatioInput.value = '';
      doorCountBadge.textContent = 'No doors detected';
      scaleStatusMsg.textContent = 'Enter scale manually or adjust door width and re-analyze.';
      scaleRatioInput.dataset.avgRadiusPt = '';
    }
    scaleSection.classList.remove('hidden');
  }

  // ── Drawing Scale: Two data arrays (PDF Original + SVG) ──
  const scaleDualSection = document.getElementById('scaleDualSection');
  const scalePdfInfoEl = document.getElementById('scalePdfInfo');
  const scaleSvgInfoEl = document.getElementById('scaleSvgInfo');
  const scaleDualHeight = document.getElementById('scaleDualHeight');
  let scalePdfData = null;
  let scaleSvgData = null;

  function getScaleHeightM() { return parseFloat(scaleDualHeight?.value) || 3; }

  // Sync scaleDualHeight ↔ heightInput (in scaleSection)
  if (scaleDualHeight) {
    scaleDualHeight.addEventListener('input', () => {
      const h = getScaleHeightM();
      if (heightInput) heightInput.value = h;
      refreshScalePanels(h);
      console.log('[DrawingScale] Height manually updated to', h, 'm');
    });
  }

  function refreshScalePanels(h) {
    if (scalePdfData) {
      scalePdfData.heightM = h;
      if (scalePdfInfoEl) {
        scalePdfInfoEl.innerHTML =
          makeScaleRow('Raster Image', `${scalePdfData.rasterW} × ${scalePdfData.rasterH}`, 'px') +
          makeScaleRow('Raw (docnet)', `${scalePdfData.rawW} × ${scalePdfData.rawH}`, 'px') +
          makeScaleRow('maxDim Cap', scalePdfData.maxDim, 'px') +
          makeScaleRow('Scale Factor X', scalePdfData.scaleX, '') +
          makeScaleRow('Scale Factor Y', scalePdfData.scaleY, '') +
          makeScaleRow('Aspect Ratio', scalePdfData.aspectRatio, '') +
          makeScaleRow('Height', h, 'm');
      }
    }
    if (scaleSvgData) {
      scaleSvgData.heightM = h;
      if (scaleSvgInfoEl) {
        scaleSvgInfoEl.innerHTML =
          makeScaleRow('Source Image Sent', `${scaleSvgData.sourceW} × ${scaleSvgData.sourceH}`, 'px') +
          makeScaleRow('SVG Original Size', `${scaleSvgData.svgOrigW} × ${scaleSvgData.svgOrigH}`, '') +
          makeScaleRow('SVG viewBox (orig)', scaleSvgData.svgOrigVB, '') +
          makeScaleRow('SVG Patched Size', `${scaleSvgData.svgPatchedW} × ${scaleSvgData.svgPatchedH}`, '') +
          makeScaleRow('SVG viewBox (patched)', scaleSvgData.svgPatchedVB, '') +
          makeScaleRow('Text', scaleSvgData.textCount ?? '?', '') +
          makeScaleRow('Paths', scaleSvgData.pathCount, '') +
          makeScaleRow('Lines', scaleSvgData.lineCount ?? '?', '') +
          makeScaleRow('SVG Size', (scaleSvgData.svgBytes / 1024).toFixed(1), 'KB') +
          makeScaleRow('Aspect (source)', scaleSvgData.arSource, '') +
          makeScaleRow('Aspect (SVG orig)', scaleSvgData.arOrig, '') +
          makeScaleRow('Aspect (SVG patched)', scaleSvgData.arPatched, '') +
          makeScaleRow('PDF→SVG Scale X', scaleSvgData.pdfToSvgScaleX, '') +
          makeScaleRow('PDF→SVG Scale Y', scaleSvgData.pdfToSvgScaleY, '') +
          makeScaleRow('Height', h, 'm');
      }
    }
  }

  function makeScaleRow(label, value, unit) {
    return `<div class="flex justify-between p2s-toolbar border-b py-0.5"><span class="p2s-muted">${label}</span><span class="font-mono p2s-text">${value}${unit ? ' <span class=\'p2s-muted-text text-[10px]\'>' + unit + '</span>' : ''}</span></div>`;
  }

  function getSvgObjectCounts(svgNode) {
    if (!svgNode || String(svgNode.tagName || '').toLowerCase() !== 'svg') {
      return { textCount: 0, pathCount: 0, lineCount: 0 };
    }
    return {
      textCount: svgNode.querySelectorAll('text').length,
      pathCount: svgNode.querySelectorAll('path').length,
      lineCount: svgNode.querySelectorAll('line').length,
    };
  }

  function syncCurrentSvgCountsPanel(svgNode) {
    if (!svgNode) return;
    const counts = getSvgObjectCounts(svgNode);
    const vb = svgNode.getAttribute('viewBox') || '?';
    const w = svgNode.getAttribute('width') || '?';
    const h = svgNode.getAttribute('height') || '?';
    let bytes = 0;
    try { bytes = new XMLSerializer().serializeToString(svgNode).length; } catch { bytes = 0; }

    if (fpSvgCountBadge) {
      fpSvgCountBadge.textContent = `SVG: Text ${counts.textCount} | Path ${counts.pathCount} | Line ${counts.lineCount}`;
    }

    if (scaleSvgData) {
      scaleSvgData.textCount = counts.textCount;
      scaleSvgData.pathCount = counts.pathCount;
      scaleSvgData.lineCount = counts.lineCount;
      refreshScalePanels(getScaleHeightM());
      return;
    }

    if (scaleSvgInfoEl) {
      scaleSvgInfoEl.innerHTML =
        makeScaleRow('SVG Size', `${w} × ${h}`, '') +
        makeScaleRow('SVG viewBox', vb, '') +
        makeScaleRow('Text', counts.textCount, '') +
        makeScaleRow('Paths', counts.pathCount, '') +
        makeScaleRow('Lines', counts.lineCount, '') +
        makeScaleRow('SVG Size', (bytes / 1024).toFixed(1), 'KB');
    }
    if (scaleDualSection) scaleDualSection.classList.remove('hidden');
  }

  // Called when PDF pages are rendered — stores the "PDF Original" scale data.
  // pageDim: { rawWidth, rawHeight, pixelWidth, pixelHeight } from backend
  // maxDim: maxDim parameter used for render
  function updatePdfScaleData(pageDim, maxDim) {
    if (!pageDim) return;
    const rw = pageDim.pixelWidth, rh = pageDim.pixelHeight;
    const raw = pageDim.rawWidth, rawH = pageDim.rawHeight;
    const scaleX = raw > 0 ? (rw / raw).toFixed(4) : '?';
    const scaleY = rawH > 0 ? (rh / rawH).toFixed(4) : '?';
    const ar = rh > 0 ? (rw / rh).toFixed(4) : '?';
    const heightM = getScaleHeightM();

    scalePdfData = {
      rasterW: rw, rasterH: rh,
      rawW: raw, rawH: rawH,
      maxDim: maxDim,
      scaleX: scaleX, scaleY: scaleY,
      aspectRatio: ar,
      heightM: heightM
    };

    if (scalePdfInfoEl) {
      scalePdfInfoEl.innerHTML =
        makeScaleRow('Raster Image', `${rw} × ${rh}`, 'px') +
        makeScaleRow('Raw (docnet)', `${raw} × ${rawH}`, 'px') +
        makeScaleRow('maxDim Cap', maxDim, 'px') +
        makeScaleRow('Scale Factor X', scaleX, '') +
        makeScaleRow('Scale Factor Y', scaleY, '') +
        makeScaleRow('Aspect Ratio', ar, '') +
        makeScaleRow('Height', heightM, 'm');
    }
    if (scaleDualSection) scaleDualSection.classList.remove('hidden');

    console.group('%c[DrawingScale] PDF Original Data', 'color:#38bdf8;font-weight:bold');
    console.log('raster:', rw, '×', rh, '| raw:', raw, '×', rawH);
    console.log('scaleX:', scaleX, '| scaleY:', scaleY, '| aspect:', ar, '| maxDim:', maxDim, '| height:', heightM, 'm');
    console.groupEnd();
  }

  // Called after SVG is built from Floor Plan — stores the "SVG" scale data.
  // info: { svgOrigW, svgOrigH, svgOrigVB, svgPatchedW, svgPatchedH, svgPatchedVB, textCount, pathCount, lineCount, svgBytes, sourceW, sourceH }
  function updateSvgScaleData(info) {
    if (!info) return;
    const arOrig = info.svgOrigH > 0 ? (info.svgOrigW / info.svgOrigH).toFixed(4) : '?';
    const arPatched = info.svgPatchedH > 0 ? (info.svgPatchedW / info.svgPatchedH).toFixed(4) : '?';
    const arSource = info.sourceH > 0 ? (info.sourceW / info.sourceH).toFixed(4) : '?';

    // If we have the PDF data too, compute the relationship
    let pdfToSvgScaleX = '?', pdfToSvgScaleY = '?';
    if (scalePdfData && scalePdfData.rasterW > 0 && info.sourceW > 0) {
      pdfToSvgScaleX = (info.svgOrigW / scalePdfData.rasterW).toFixed(4);
      pdfToSvgScaleY = (info.svgOrigH / scalePdfData.rasterH).toFixed(4);
    }

    const heightM = getScaleHeightM();

    scaleSvgData = {
      svgOrigW: info.svgOrigW, svgOrigH: info.svgOrigH, svgOrigVB: info.svgOrigVB,
      svgPatchedW: info.svgPatchedW, svgPatchedH: info.svgPatchedH, svgPatchedVB: info.svgPatchedVB,
      textCount: info.textCount ?? 0, pathCount: info.pathCount ?? 0, lineCount: info.lineCount ?? 0, svgBytes: info.svgBytes,
      sourceW: info.sourceW, sourceH: info.sourceH,
      arOrig: arOrig, arPatched: arPatched, arSource: arSource,
      pdfToSvgScaleX: pdfToSvgScaleX, pdfToSvgScaleY: pdfToSvgScaleY,
      heightM: heightM
    };

    if (scaleSvgInfoEl) {
      scaleSvgInfoEl.innerHTML =
        makeScaleRow('Source Image Sent', `${info.sourceW} × ${info.sourceH}`, 'px') +
        makeScaleRow('SVG Original Size', `${info.svgOrigW} × ${info.svgOrigH}`, '') +
        makeScaleRow('SVG viewBox (orig)', info.svgOrigVB, '') +
        makeScaleRow('SVG Patched Size', `${info.svgPatchedW} × ${info.svgPatchedH}`, '') +
        makeScaleRow('SVG viewBox (patched)', info.svgPatchedVB, '') +
        makeScaleRow('Text', info.textCount ?? 0, '') +
        makeScaleRow('Paths', info.pathCount, '') +
        makeScaleRow('Lines', info.lineCount ?? 0, '') +
        makeScaleRow('SVG Size', (info.svgBytes / 1024).toFixed(1), 'KB') +
        makeScaleRow('Aspect (source)', arSource, '') +
        makeScaleRow('Aspect (SVG orig)', arOrig, '') +
        makeScaleRow('Aspect (SVG patched)', arPatched, '') +
        makeScaleRow('PDF→SVG Scale X', pdfToSvgScaleX, '') +
        makeScaleRow('PDF→SVG Scale Y', pdfToSvgScaleY, '') +
        makeScaleRow('Height', heightM, 'm');
    }
    if (scaleDualSection) scaleDualSection.classList.remove('hidden');

    console.group('%c[DrawingScale] SVG Data', 'color:#34d399;font-weight:bold');
    console.log('source sent:', info.sourceW, '×', info.sourceH, '| aspect:', arSource);
    console.log('SVG orig:', info.svgOrigW, '×', info.svgOrigH, '| aspect:', arOrig, '| viewBox:', info.svgOrigVB);
    console.log('SVG patched:', info.svgPatchedW, '×', info.svgPatchedH, '| aspect:', arPatched, '| viewBox:', info.svgPatchedVB);
    console.log('text:', info.textCount ?? 0, '| paths:', info.pathCount, '| lines:', info.lineCount ?? 0, '| bytes:', info.svgBytes);
    console.log('PDF→SVG scale:', pdfToSvgScaleX, '×', pdfToSvgScaleY);
    console.groupEnd();
  }

  // ── Euclidean distance in real metres ──
  function realDistM(a, b, scaleRatio) {
    if (a.page !== b.page) return Infinity;
    if (a.x !== undefined && b.x !== undefined && a.y !== undefined && b.y !== undefined) {
      const dx = Math.abs(a.x - b.x), dy = Math.abs(a.y - b.y);
      const ptToCm = 0.03528;
      return (Math.sqrt(dx*dx + dy*dy) * ptToCm * scaleRatio) / 100;
    }
    return null;
  }

  // ── Device colour map ──
  const DEVICE_COLORS = {
    smokeDetector:'#16a34a', heatDetector:'#ea580c', manualCallPoint:'#dc2626',
    controlPanel:'#9333ea', bellAlarm:'#ca8a04', hornSounder:'#db2777',
    strobeLight:'#0891b2', beamDetector:'#6366f1'
  };
  function getDeviceColor(t) {
    if (!t) return '#0284c7';
    return DEVICE_COLORS[t.charAt(0).toLowerCase()+t.slice(1)] || '#0284c7';
  }

  // ── Render Floor Plan SVG ──
  function renderFloorPlan(analysis) {
    fpContainer.innerHTML = '';
    const items = analysis.items || [];
    const floorPlan = analysis.floorPlan || [];
    if (!floorPlan.length) { floorPlanSection.classList.add('hidden'); return; }

    const scaleRatio = parseFloat(scaleRatioInput.value) || 0;
    let fpIdx = 0;

    for (const fp of floorPlan) {
      const pgItems = items.filter(i => i.page === fp.page);
      if (fp.walls.length === 0 && fp.doors.length === 0 && pgItems.length === 0) continue;

      let svgW = fp.width, svgH = fp.height;
      if (fp.rotation === 90 || fp.rotation === 270) { svgW = fp.height; svgH = fp.width; }

      const svgId = `fpSvg_${fpIdx}`;
      const wrapId = `fpWrap_${fpIdx}`;
      const lblId = `fpZoomLbl_${fpIdx}`;
      fpIdx++;

      // Zoom + selection toolbar (placed in the static fpToolbar, only for first page)
      if (fpIdx === 1) {
        const selBtnId = `fpSelBtn_0`;
        const areaBtnId = `fpAreaBtn_0`;
        const shapeRowId = `fpShapeRow_0`;
        fpToolbar.innerHTML = `
          <button type="button" onclick="fpZoom('${svgId}','${wrapId}','${lblId}',0.15)" class="inline-flex items-center gap-1 rounded-lg p2s-btn border px-3 py-1.5 text-xs transition" title="Zoom In"><i class="fa-solid fa-magnifying-glass-plus"></i> Zoom In</button>
          <button type="button" onclick="fpZoom('${svgId}','${wrapId}','${lblId}',-0.15)" class="inline-flex items-center gap-1 rounded-lg p2s-btn border px-3 py-1.5 text-xs transition" title="Zoom Out"><i class="fa-solid fa-magnifying-glass-minus"></i> Zoom Out</button>
          <button type="button" onclick="fpZoomFit('${svgId}','${wrapId}','${lblId}')" class="inline-flex items-center gap-1 rounded-lg p2s-btn border px-3 py-1.5 text-xs transition" title="Fit"><i class="fa-solid fa-expand"></i> Fit</button>
          <span id="${lblId}" class="text-xs p2s-muted min-w-[3rem] text-center">100%</span>
          <span class="w-px h-5 p2s-divider mx-1"></span>
          <button type="button" id="${selBtnId}" onclick="fpToggleSelect('${svgId}','${selBtnId}')" class="inline-flex items-center gap-1 rounded-lg p2s-btn border px-3 py-1.5 text-xs transition" title="Toggle selection mode"><i class="fa-solid fa-arrow-pointer"></i> Select</button>
          <button type="button" onclick="fpSelectAll('${svgId}')" class="inline-flex items-center gap-1 rounded-lg p2s-btn border px-3 py-1.5 text-xs transition" title="Select all items"><i class="fa-solid fa-object-group"></i> Select All</button>
          <button type="button" id="${areaBtnId}" onclick="fpToggleAreaSelect('${svgId}','${areaBtnId}')" class="inline-flex items-center gap-1 rounded-lg border border-cyan-500/60 bg-cyan-900/30 hover:bg-cyan-900/50 text-cyan-300 px-3 py-1.5 text-xs transition" title="Click to cycle: Select / Delete / Cleanup / Off"><i class="fa-solid fa-vector-square"></i> Area Select</button>
          <button type="button" onclick="fpDeleteSelected('${svgId}')" class="inline-flex items-center gap-1 rounded-lg border border-red-500/60 bg-red-900/30 hover:bg-red-900/50 text-red-300 px-3 py-1.5 text-xs transition" title="Delete selected items"><i class="fa-solid fa-trash"></i> Delete Selected</button>
          <button type="button" onclick="fpGroupSelected('${svgId}')" class="inline-flex items-center gap-1 rounded-lg border border-cyan-500/60 bg-cyan-900/30 hover:bg-cyan-900/50 text-cyan-300 px-3 py-1.5 text-xs transition" title="Group selected line segments into clean polylines/polygons"><i class="fa-solid fa-object-group"></i> Group Selected</button>
          <span class="w-px h-5 p2s-divider mx-1"></span>
          <div style="position:relative;display:inline-block" id="fpSmartSelWrap_0">
            <button type="button" onclick="fpToggleSmartSel('fpSmartSelWrap_0')" class="inline-flex items-center gap-1 rounded-lg border border-orange-500/60 bg-orange-900/30 hover:bg-orange-900/50 text-orange-300 px-3 py-1.5 text-xs transition" title="Smart auto-select by criteria"><i class="fa-solid fa-wand-magic-sparkles"></i> Smart Select <i class="fa-solid fa-caret-down text-[8px] ml-0.5"></i></button>
            <ul style="display:none;position:absolute;left:0;top:calc(100% + 4px);z-index:80;min-width:220px;max-height:300px;overflow-y:auto;background:#1e293b;border:1px solid #475569;border-radius:8px;padding:4px 0;box-shadow:0 8px 24px rgba(0,0,0,.5)" id="fpSmartSelMenu_0">
              <li onclick="fpSmartSelect('${svgId}','diagonals');fpToggleSmartSel('fpSmartSelWrap_0')" class="px-3 py-2 text-xs p2s-dropdown-item cursor-pointer transition"><i class="fa-solid fa-slash text-[9px] mr-2 p2s-muted"></i>Select diagonal lines</li>
              <li onclick="fpSmartSelect('${svgId}','short');fpToggleSmartSel('fpSmartSelWrap_0')" class="px-3 py-2 text-xs p2s-dropdown-item cursor-pointer transition"><i class="fa-solid fa-minus text-[9px] mr-2 p2s-muted"></i>Select short lines</li>
              <li onclick="fpSmartSelect('${svgId}','hatching');fpToggleSmartSel('fpSmartSelWrap_0')" class="px-3 py-2 text-xs p2s-dropdown-item cursor-pointer transition"><i class="fa-solid fa-grip-lines text-[9px] mr-2 p2s-muted"></i>Select hatching (dense clusters)</li>
              <li onclick="fpSmartSelect('${svgId}','diagHatch');fpToggleSmartSel('fpSmartSelWrap_0')" class="px-3 py-2 text-xs p2s-dropdown-item cursor-pointer transition"><i class="fa-solid fa-border-none text-[9px] mr-2 p2s-muted"></i>Select diagonal hatching only</li>
              <li style="border-top:1px solid #334155;margin:2px 0"></li>
              <li onclick="fpSmartSelect('${svgId}','invert');fpToggleSmartSel('fpSmartSelWrap_0')" class="px-3 py-2 text-xs p2s-dropdown-item cursor-pointer transition"><i class="fa-solid fa-arrows-rotate text-[9px] mr-2 p2s-muted"></i>Invert selection</li>
              <li onclick="fpSmartSelect('${svgId}','none');fpToggleSmartSel('fpSmartSelWrap_0')" class="px-3 py-2 text-xs p2s-dropdown-item cursor-pointer transition"><i class="fa-solid fa-xmark text-[9px] mr-2 p2s-muted"></i>Deselect all</li>
            </ul>
          </div>
          <span class="w-px h-5 p2s-divider mx-1"></span>
          <button type="button" id="fpMarkWallsBtn" onclick="fpToggleMarkWalls('${svgId}','fpMarkWallsBtn')" class="inline-flex items-center gap-1 rounded-lg border border-amber-500/60 bg-amber-900/30 hover:bg-amber-900/50 text-amber-300 px-3 py-1.5 text-xs transition" title="Click on walls to mark: 1st click = thin wall (small ●), 2nd = thick wall (big ●), 3rd = remove"><i class="fa-solid fa-circle-dot"></i> Mark Walls</button>
          <button type="button" id="fpUndoMarkBtn" onclick="fpUndoMark('${svgId}')" class="inline-flex items-center gap-1 rounded-lg p2s-btn border px-3 py-1.5 text-xs transition" title="Undo last wall mark"><i class="fa-solid fa-rotate-left"></i> Undo</button>
          <button type="button" id="fpCleanSvgBtn" onclick="fpCleanSvg('${svgId}')" class="inline-flex items-center gap-1 rounded-lg border border-emerald-500/60 bg-emerald-900/30 hover:bg-emerald-900/50 text-emerald-300 px-3 py-1.5 text-xs transition" title="Build clean wall envelope from marked walls"><i class="fa-solid fa-broom"></i> Clean SVG</button>
          <button type="button" id="fpGroupWallsBtn" onclick="fpGroupMarkedWalls('${svgId}')" class="inline-flex items-center gap-1 rounded-lg border border-cyan-500/60 bg-cyan-900/30 hover:bg-cyan-900/50 text-cyan-300 px-3 py-1.5 text-xs transition" title="Merge marked wall segments into grouped clean shapes (polyline/polygon)"><i class="fa-solid fa-object-group"></i> Group Marked Walls</button>
        `;

        // Shape picker row
        const shapeRow = document.createElement('div');
        shapeRow.id = shapeRowId;
        shapeRow.className = 'flex items-center gap-1 mb-2';
        shapeRow.style.display = 'none';
      shapeRow.innerHTML = `
        <span class="text-[10px] p2s-muted mr-1">Shape:</span>
        <button type="button" data-shape="rect" onclick="fpSetAreaShape('${svgId}','rect','${shapeRowId}','${areaBtnId}')" class="fpShapeBtn inline-flex items-center justify-center w-7 h-7 rounded border border-cyan-500/60 bg-cyan-900/40 text-cyan-200 text-xs transition hover:bg-cyan-800/60" title="Rectangle">▬</button>
        <button type="button" data-shape="square" onclick="fpSetAreaShape('${svgId}','square','${shapeRowId}','${areaBtnId}')" class="fpShapeBtn inline-flex items-center justify-center w-7 h-7 rounded p2s-btn border text-xs transition" title="Square">■</button>
        <button type="button" data-shape="circle" onclick="fpSetAreaShape('${svgId}','circle','${shapeRowId}','${areaBtnId}')" class="fpShapeBtn inline-flex items-center justify-center w-7 h-7 rounded p2s-btn border text-xs transition" title="Circle">●</button>
        <button type="button" data-shape="triangle" onclick="fpSetAreaShape('${svgId}','triangle','${shapeRowId}','${areaBtnId}')" class="fpShapeBtn inline-flex items-center justify-center w-7 h-7 rounded p2s-btn border text-xs transition" title="Triangle">▲</button>
      `;
        fpToolbar.appendChild(shapeRow);
      }

      // SVG wrapper
      const wrapDiv = document.createElement('div');
      wrapDiv.id = wrapId;
      // Set a solid baseline height (e.g. 70vh) to ensure large SVGs have a scrollable window.
      // And set position: relative so pan-scroll bounds work correctly.
      wrapDiv.style.cssText = 'position:relative;overflow:auto;height:320px;margin-bottom:12px;border-radius:8px;border:1px solid #cbd5e1;background:#fff;';

      // Transform helper
      const txPt = (px, py) => {
        switch (fp.rotation % 360) {
          case 90:  return [py, px];
          case 180: return [fp.width - px, py];
          case 270: return [fp.height - py, fp.width - px];
          default:  return [px, fp.height - py];
        }
      };

      let svgHtml = '';

      // Walls (wrapped in <g> for selection)
      for (let wi = 0; wi < fp.walls.length; wi++) {
        const w = fp.walls[wi];
        const [x1,y1] = txPt(w[0],w[1]);
        const [x2,y2] = txPt(w[2],w[3]);
        svgHtml += `<g data-fp-wall-idx="${wi}"><line x1="${x1.toFixed(1)}" y1="${y1.toFixed(1)}" x2="${x2.toFixed(1)}" y2="${y2.toFixed(1)}" stroke="#1e293b" stroke-width="3" stroke-linecap="round"/>`;
        svgHtml += `<line x1="${x1.toFixed(1)}" y1="${y1.toFixed(1)}" x2="${x2.toFixed(1)}" y2="${y2.toFixed(1)}" stroke="transparent" stroke-width="12" stroke-linecap="round" pointer-events="stroke"/></g>`;
      }

      // Doors (wrapped in <g> for selection)
      for (let di = 0; di < fp.doors.length; di++) {
        const d = fp.doors[di];
        const [cx,cy] = txPt(d[0],d[1]);
        const r = d[2];
        let startDeg = d[3], sweepDeg = d[4];
        if (fp.rotation === 0) { startDeg = -startDeg; sweepDeg = -sweepDeg; }
        const startRad = startDeg * Math.PI / 180;
        const endRad = (startDeg + sweepDeg) * Math.PI / 180;
        const sx = cx + r*Math.cos(startRad), sy = cy + r*Math.sin(startRad);
        const ex = cx + r*Math.cos(endRad),   ey = cy + r*Math.sin(endRad);
        const largeArc = Math.abs(sweepDeg) > 180 ? 1 : 0;
        const sweepFlag = sweepDeg > 0 ? 1 : 0;
        svgHtml += `<g data-fp-door-idx="${di}"><path d="M${sx.toFixed(1)},${sy.toFixed(1)} A${r.toFixed(1)},${r.toFixed(1)} 0 ${largeArc} ${sweepFlag} ${ex.toFixed(1)},${ey.toFixed(1)}" fill="none" stroke="#2563eb" stroke-width="2.5" stroke-dasharray="6,4"/>`;
        svgHtml += `<path d="M${sx.toFixed(1)},${sy.toFixed(1)} A${r.toFixed(1)},${r.toFixed(1)} 0 ${largeArc} ${sweepFlag} ${ex.toFixed(1)},${ey.toFixed(1)}" fill="none" stroke="transparent" stroke-width="12" pointer-events="stroke"/></g>`;
      }

      // Equipment markers removed – floor plan shows only walls, doors & passages

      // Spacing arrows removed – no equipment on floor plan

      // Arrow defs
      svgHtml += `<defs>`;
      svgHtml += `<marker id="ah-ok" markerWidth="10" markerHeight="7" refX="9" refY="3.5" orient="auto"><polygon points="0 0,10 3.5,0 7" fill="#16a34a"/></marker>`;
      svgHtml += `<marker id="ah-fail" markerWidth="10" markerHeight="7" refX="9" refY="3.5" orient="auto"><polygon points="0 0,10 3.5,0 7" fill="#dc2626"/></marker>`;
      svgHtml += `</defs>`;

      // Ensure the inner SVG scales correctly
      let svgWStr = svgW;
      let svgHStr = svgH;
      // If the SVG comes with very large dimensions, we do not want it to cut off natively.
      wrapDiv.innerHTML = `<svg id="${svgId}" data-fp-page-idx="${floorPlan.indexOf(fp)}" data-fp-page-number="${fp.page}" viewBox="0 0 ${svgW} ${svgH}" style="width:100%;height:auto;min-height:100%;background:#ffffff;display:block;" xmlns="http://www.w3.org/2000/svg">${svgHtml}</svg>`;
      fpContainer.appendChild(wrapDiv);
    }

    try {
      const svgForStats = fpContainer ? fpContainer.querySelector('svg') : null;
      if (svgForStats) syncCurrentSvgCountsPanel(svgForStats);
    } catch { }

    // item count badge removed
    floorPlanSection.classList.remove('hidden');
    // Attach selection / area-select event handlers
    fpAttachSvgHandlers();

    // If user marked walls on the PDF Preview overlay, show them here too.
    if (window._fpApplyGlobalMarksToAllFloorSvgs) {
      window._fpApplyGlobalMarksToAllFloorSvgs();
    }

    // Initial view: fill remaining window height + Fit.
    try {
      requestAnimationFrame(() => {
        try { if (window.fpEnsureWrapHeights) window.fpEnsureWrapHeights(); } catch { }
        try {
          const svg0 = fpContainer ? fpContainer.querySelector('svg[id^="fpSvg_"]') : null;
          const wrap0 = svg0 ? (svg0.parentElement || null) : null;
          if (svg0 && wrap0 && window.fpZoomFit) window.fpZoomFit(svg0.id, wrap0.id, '');
        } catch { }
      });
    } catch { }
  }

  // ── Render Floor Plan from raw SVG (vectorized from edited raster) ──
  // coordW / coordH = the ORIGINAL SVG coordinate space (vtracer output dimensions,
  // typically 2× source).  Used as a safety-net viewBox if the text-based patching
  // didn't manage to inject one.
  function _renderFloorPlanSvgTextNow(svgText, coordW, coordH, options) {
    fpContainer.innerHTML = '';

    let svgNode = null;
    try {
      const parsed = new DOMParser().parseFromString(String(svgText || ''), 'image/svg+xml');
      svgNode = parsed && parsed.documentElement ? parsed.documentElement : null;
    } catch {
      svgNode = null;
    }

    if (!svgNode || String(svgNode.tagName || '').toLowerCase() !== 'svg') {
      setStatus('Invalid SVG response from vectorizer.', 'error');
      return;
    }

    const svgId = 'fpSvg_0';
    const wrapId = 'fpWrap_0';
    const lblId = 'fpZoomLbl_0';

    // Use the existing toolbar (selection/zoom/area tools); some analysis-specific tools may be no-ops.
    const selBtnId = 'fpSelBtn_0';
    const areaBtnId = 'fpAreaBtn_0';
    const shapeRowId = 'fpShapeRow_0';
    fpToolbar.innerHTML = `
      <button type="button" onclick="fpZoom('${svgId}','${wrapId}','${lblId}',0.15)" class="inline-flex items-center gap-1 rounded-lg p2s-btn border px-3 py-1.5 text-xs transition" title="Zoom In"><i class="fa-solid fa-magnifying-glass-plus"></i> Zoom In</button>
      <button type="button" onclick="fpZoom('${svgId}','${wrapId}','${lblId}',-0.15)" class="inline-flex items-center gap-1 rounded-lg p2s-btn border px-3 py-1.5 text-xs transition" title="Zoom Out"><i class="fa-solid fa-magnifying-glass-minus"></i> Zoom Out</button>
      <button type="button" onclick="fpZoomFit('${svgId}','${wrapId}','${lblId}')" class="inline-flex items-center gap-1 rounded-lg p2s-btn border px-3 py-1.5 text-xs transition" title="Fit"><i class="fa-solid fa-expand"></i> Fit</button>
      <span id="${lblId}" class="text-xs p2s-muted min-w-[3rem] text-center">100%</span>
      <span class="w-px h-5 p2s-divider mx-1"></span>
      <button type="button" id="${selBtnId}" onclick="fpToggleSelect('${svgId}','${selBtnId}')" class="inline-flex items-center gap-1 rounded-lg p2s-btn border px-3 py-1.5 text-xs transition" title="Toggle selection mode"><i class="fa-solid fa-arrow-pointer"></i> Select</button>
      <button type="button" onclick="fpSelectAll('${svgId}')" class="inline-flex items-center gap-1 rounded-lg p2s-btn border px-3 py-1.5 text-xs transition" title="Select all items"><i class="fa-solid fa-object-group"></i> Select All</button>
      <button type="button" id="${areaBtnId}" onclick="fpToggleAreaSelect('${svgId}','${areaBtnId}')" class="inline-flex items-center gap-1 rounded-lg border border-cyan-500/60 bg-cyan-900/30 hover:bg-cyan-900/50 text-cyan-300 px-3 py-1.5 text-xs transition" title="Click to cycle: Select / Delete / Cleanup / Off"><i class="fa-solid fa-vector-square"></i> Area Select</button>
      <button type="button" onclick="fpDeleteSelected('${svgId}')" class="inline-flex items-center gap-1 rounded-lg border border-red-500/60 bg-red-900/30 hover:bg-red-900/50 text-red-300 px-3 py-1.5 text-xs transition" title="Delete selected items"><i class="fa-solid fa-trash"></i> Delete Selected</button>
      <button type="button" onclick="fpGroupSelected('${svgId}')" class="inline-flex items-center gap-1 rounded-lg border border-cyan-500/60 bg-cyan-900/30 hover:bg-cyan-900/50 text-cyan-300 px-3 py-1.5 text-xs transition" title="Group selected line segments into clean polylines/polygons"><i class="fa-solid fa-object-group"></i> Group Selected</button>
    `;

    // Create wrapper
    const wrapDiv = document.createElement('div');
    wrapDiv.id = wrapId;
    // Set a solid baseline height (e.g. 70vh) to ensure large SVGs have a scrollable window.
    wrapDiv.style.cssText = 'position:relative;overflow:auto;height:320px;margin-bottom:12px;border-radius:8px;border:1px solid #cbd5e1;background:#fff;';

    // Import into current document
    const imported = document.importNode(svgNode, true);
    imported.id = svgId;
    imported.setAttribute('data-fp-page-idx', '0');
    imported.setAttribute('data-fp-page-number', '1');
    imported.setAttribute('xmlns', 'http://www.w3.org/2000/svg');
    imported.style.width = '100%';
    imported.style.height = 'auto';
    imported.style.minHeight = '100%';
    imported.style.background = '#ffffff';
    imported.style.display = 'block';

    // Force a stable viewBox from actual content bounds.
    // This fixes cases where SVG coordinates are offset (non-zero x/y), which can
    // otherwise produce blank bands and clipping even with correct width/height.
    const tempDiv = document.createElement('div');
    tempDiv.style.cssText = 'position:absolute;left:-99999px;top:-99999px;width:0;height:0;overflow:hidden;';
    tempDiv.appendChild(imported.cloneNode(true));
    document.body.appendChild(tempDiv);

    let bbX = NaN, bbY = NaN, bbW = NaN, bbH = NaN;
    try {
      const svgClone = tempDiv.querySelector('svg');
      if (svgClone) {
        const bb = svgClone.getBBox();
        if (bb && bb.width > 0 && bb.height > 0) {
          bbX = bb.x;
          bbY = bb.y;
          bbW = bb.width;
          bbH = bb.height;
        }
      }
    } catch { }
    tempDiv.remove();

    if (Number.isFinite(bbX) && Number.isFinite(bbY) && Number.isFinite(bbW) && Number.isFinite(bbH) && bbW > 0 && bbH > 0) {
      const vb = `${Math.floor(bbX)} ${Math.floor(bbY)} ${Math.ceil(bbW)} ${Math.ceil(bbH)}`;
      imported.setAttribute('viewBox', vb);
      console.log('[renderFPSvg] viewBox FORCED from getBBox:', vb);
    } else if (Number.isFinite(coordW) && Number.isFinite(coordH) && coordW > 0 && coordH > 0) {
      imported.setAttribute('viewBox', `0 0 ${coordW} ${coordH}`);
      console.warn('[renderFPSvg] getBBox unavailable; fallback viewBox from coordW/H:', coordW, coordH);
    } else if (!imported.getAttribute('viewBox')) {
      const wAttr = imported.getAttribute('width');
      const hAttr = imported.getAttribute('height');
      const w = wAttr ? parseFloat(String(wAttr).replace(/[^0-9.\-]/g, '')) : NaN;
      const h = hAttr ? parseFloat(String(hAttr).replace(/[^0-9.\-]/g, '')) : NaN;
      if (Number.isFinite(w) && Number.isFinite(h) && w > 0 && h > 0) {
        imported.setAttribute('viewBox', `0 0 ${w} ${h}`);
      } else {
        imported.setAttribute('viewBox', '0 0 1000 1000');
      }
      console.warn('[renderFPSvg] getBBox+coord fallback; using attribute/default viewBox:', imported.getAttribute('viewBox'));
    }
    console.log('[renderFPSvg] FINAL viewBox on SVG node:', imported.getAttribute('viewBox'));

    // Cache the latest Floor Plan SVG for the 3D tab.
    try {
      window._fpCurrentSvgNode = imported;
      window._fpCurrentSvgText = new XMLSerializer().serializeToString(imported);
    } catch { }

    // A new SVG is ready; auto-build 3D next time the user opens the 3D tab.
    try { fp3dPendingRebuild = true; } catch { }

    wrapDiv.appendChild(imported);
    fpContainer.appendChild(wrapDiv);

    try { syncCurrentSvgCountsPanel(imported); } catch { }

    if (options && options.groupName) {
      fpActiveGroupName = options.groupName;
      if (fpSvgGroupName) fpSvgGroupName.value = options.groupName;
      fpRefreshGroupUi();
      fpSetGroupStatus(`Loaded group ${options.groupName}`, 'ok');
    }

    floorPlanSection.classList.remove('hidden');
    btnExportSvg.classList.remove('hidden');
    // JSON export only makes sense for analysis-based data.
    btnExportJson.classList.toggle('hidden', !lastAnalysis);
    fpAttachSvgHandlers();
    switchTab('tabFloorPlan');

    // Initial view: fill remaining window height + Fit.
    try {
      requestAnimationFrame(() => {
        try { if (window.fpEnsureWrapHeights) window.fpEnsureWrapHeights(); } catch { }
        try { if (window.fpZoomFit) window.fpZoomFit(svgId, wrapId, lblId); } catch { }
      });
    } catch { }
  }

  function renderFloorPlanSvgText(svgText, coordW, coordH) {
    fpPendingVectorized = {
      svgText: String(svgText || ''),
      coordW: Number(coordW) || 0,
      coordH: Number(coordH) || 0,
      suggestedName: fpSuggestedGroupName(),
      updatedAt: new Date().toISOString()
    };
    if (fpSvgGroupName && !String(fpSvgGroupName.value || '').trim()) {
      fpSvgGroupName.value = fpPendingVectorized.suggestedName || '';
    }
    floorPlanSection.classList.remove('hidden');
    switchTab('tabFloorPlan');
    fpRefreshGroupUi();
    fpSetGroupStatus(`Pending SVG ready${fpPendingVectorized.suggestedName ? ` for ${fpPendingVectorized.suggestedName}` : ''}. Use Add Group or Update Group manually.`, 'warn');
  }

  // ── 3D: SVG → extruded mesh (client-side) ──
  function fp3dSetStatus(msg, kind) {
    if (!fp3dStatus) return;
    fp3dStatus.textContent = String(msg || '');
    fp3dStatus.className = kind === 'error'
      ? 'text-[11px] text-rose-300'
      : (kind === 'ok' ? 'text-[11px] text-emerald-300' : 'text-[11px] p2s-muted');
  }

  function getFloorPlanSvgTextFor3d() {
    const cached = window._fpCurrentSvgText;
    if (cached && typeof cached === 'string' && cached.includes('<svg')) return cached;
    try {
      const svg = fpContainer ? fpContainer.querySelector('svg') : null;
      if (!svg) return '';
      return new XMLSerializer().serializeToString(svg);
    } catch {
      return '';
    }
  }

  function updateFp3dSvgInfo() {
    if (!fp3dSvgInfo) return;
    try {
      const svg = fpContainer ? fpContainer.querySelector('svg') : null;
      if (!svg) { fp3dSvgInfo.textContent = 'No Floor Plan SVG yet.'; return; }
      const vb = svg.getAttribute('viewBox') || '';
      const w = svg.getAttribute('width') || '';
      const h = svg.getAttribute('height') || '';
      const counts = getSvgObjectCounts(svg);
      fp3dSvgInfo.textContent = `SVG: ${w || '?'}×${h || '?'} | viewBox: ${vb || '?'} | text: ${counts.textCount} | path: ${counts.pathCount} | line: ${counts.lineCount}`;
    } catch {
      fp3dSvgInfo.textContent = '';
    }
  }

  function getFp3dPlanMaxUnits() {
    // Prefer actual SVG viewBox units.
    try {
      const svg = fpContainer ? fpContainer.querySelector('svg') : null;
      if (svg) {
        const vb = String(svg.getAttribute('viewBox') || '').trim();
        const m = vb.match(/(-?\d*\.?\d+)\s+(-?\d*\.?\d+)\s+(-?\d*\.?\d+)\s+(-?\d*\.?\d+)/);
        if (m) {
          const w = parseFloat(m[3]);
          const h = parseFloat(m[4]);
          if (Number.isFinite(w) && Number.isFinite(h) && w > 0 && h > 0) return Math.max(w, h);
        }
        const wAttr = parseFloat(String(svg.getAttribute('width') || '').replace(/[^0-9.\-]/g, ''));
        const hAttr = parseFloat(String(svg.getAttribute('height') || '').replace(/[^0-9.\-]/g, ''));
        if (Number.isFinite(wAttr) && Number.isFinite(hAttr) && wAttr > 0 && hAttr > 0) return Math.max(wAttr, hAttr);
      }
    } catch { }

    // Fallback to captured scale info.
    try {
      const w = (scaleSvgData && (scaleSvgData.svgOrigW || scaleSvgData.svgPatchedW)) ? parseFloat(scaleSvgData.svgOrigW || scaleSvgData.svgPatchedW) : NaN;
      const h = (scaleSvgData && (scaleSvgData.svgOrigH || scaleSvgData.svgPatchedH)) ? parseFloat(scaleSvgData.svgOrigH || scaleSvgData.svgPatchedH) : NaN;
      if (Number.isFinite(w) && Number.isFinite(h) && w > 0 && h > 0) return Math.max(w, h);
    } catch { }

    return 1000;
  }

  const fp3dState = {
    libs: null,
    renderer: null,
    scene: null,
    camera: null,
    controls: null,
    root: null,
    animId: 0,
    ro: null,
  };

  let fp3dPendingRebuild = false;

  async function ensureFp3dLibs() {
    if (fp3dState.libs) return fp3dState.libs;
    console.groupCollapsed('%c[3D] Loading libraries', 'color:#38bdf8;font-weight:bold');
    console.time('[3D] libs import');
    try {
      // Use a CDN that rewrites bare module specifiers used by three/examples (e.g. import from 'three').
      // unpkg serves the raw files, which causes: "Failed to resolve module specifier 'three'".
      const THREE = await import('https://esm.sh/three@0.160.0');
      const { OrbitControls } = await import('https://esm.sh/three@0.160.0/examples/jsm/controls/OrbitControls.js');
      const { SVGLoader } = await import('https://esm.sh/three@0.160.0/examples/jsm/loaders/SVGLoader.js');
      fp3dState.libs = { THREE, OrbitControls, SVGLoader };
      console.log('three:', THREE.REVISION || '(unknown)');
      console.log('OrbitControls:', typeof OrbitControls);
      console.log('SVGLoader:', typeof SVGLoader);
      return fp3dState.libs;
    } catch (e) {
      console.error('[3D] libs import failed:', e);
      throw e;
    } finally {
      console.timeEnd('[3D] libs import');
      console.groupEnd();
    }
  }

  function fp3dDisposeObject3D(obj) {
    if (!obj) return;
    try {
      obj.traverse((child) => {
        if (child && child.geometry) {
          try { child.geometry.dispose(); } catch { }
        }
        if (child && child.material) {
          const mats = Array.isArray(child.material) ? child.material : [child.material];
          for (const m of mats) {
            try { m.dispose(); } catch { }
          }
        }
      });
    } catch { }
  }

  async function ensureFp3dScene() {
    if (fp3dState.renderer && fp3dState.scene && fp3dState.camera) return;
    if (!fp3dViewport) return;

    const { THREE, OrbitControls } = await ensureFp3dLibs();

    fp3dViewport.innerHTML = '';

    const scene = new THREE.Scene();

    const camera = new THREE.PerspectiveCamera(45, 1, 0.1, 20000);
    camera.position.set(0, -600, 600);

    const renderer = new THREE.WebGLRenderer({ antialias: true, alpha: true });
    renderer.setPixelRatio(Math.min(2, window.devicePixelRatio || 1));
    renderer.setClearAlpha(0);
    renderer.shadowMap.enabled = false;
    fp3dViewport.appendChild(renderer.domElement);

    const controls = new OrbitControls(camera, renderer.domElement);
    controls.enableDamping = true;
    controls.dampingFactor = 0.08;
    controls.target.set(0, 0, 0);
    controls.update();

    const amb = new THREE.AmbientLight(0xffffff, 0.55);
    scene.add(amb);
    const dir = new THREE.DirectionalLight(0xffffff, 0.85);
    dir.position.set(600, -600, 1200);
    scene.add(dir);

    fp3dState.scene = scene;
    fp3dState.camera = camera;
    fp3dState.renderer = renderer;
    fp3dState.controls = controls;

    const resize = () => {
      try {
        const rect = fp3dViewport.getBoundingClientRect();
        const w = Math.max(1, Math.floor(rect.width));
        const h = Math.max(1, Math.floor(rect.height));
        console.debug('[3D] viewport size:', w, 'x', h);
        camera.aspect = w / h;
        camera.updateProjectionMatrix();
        renderer.setSize(w, h, false);
      } catch { }
    };
    resize();

    try {
      fp3dState.ro = new ResizeObserver(() => resize());
      fp3dState.ro.observe(fp3dViewport);
    } catch { }

    const loop = () => {
      fp3dState.animId = requestAnimationFrame(loop);
      try { controls.update(); } catch { }
      try { renderer.render(scene, camera); } catch { }
    };
    loop();
  }

  async function buildFp3dFromCurrentSvg() {
    console.groupCollapsed('%c[3D] Build start', 'color:#a78bfa;font-weight:bold');
    console.time('[3D] build total');

    updateFp3dSvgInfo();
    const svgText = getFloorPlanSvgTextFor3d();
    if (!svgText) {
      console.warn('[3D] No SVG text found');
      fp3dSetStatus('No Floor Plan SVG available. Build the Floor Plan first.', 'error');
      console.timeEnd('[3D] build total');
      console.groupEnd();
      return;
    }

    const heightM = Math.max(0.1, parseFloat(String(fp3dHeight && fp3dHeight.value ? fp3dHeight.value : '3')) || 3);
    const planMaxUnits = getFp3dPlanMaxUnits();
    // Convert meters → SVG units so height is visually meaningful.
    // Heuristic: 1m ≈ (max(viewBox) / 80) units.
    const unitsPerMeter = Math.max(1, planMaxUnits / 80);
    const depthUnits = Math.max(1, heightM * unitsPerMeter);

    console.log('[3D] height(m):', heightM);
    console.log('[3D] planMaxUnits:', planMaxUnits, '| unitsPerMeter:', unitsPerMeter.toFixed(3), '| depthUnits:', depthUnits.toFixed(2));
    console.log('[3D] svg chars:', svgText.length);
    console.log('[3D] svg head:', svgText.slice(0, 120));

    fp3dSetStatus('Building 3D…', '');
    try {
      await ensureFp3dScene();
    } catch (e) {
      console.error('[3D] ensure scene failed:', e);
      fp3dSetStatus(`3D scene init failed: ${e && e.message ? e.message : e}`, 'error');
      console.timeEnd('[3D] build total');
      console.groupEnd();
      throw e;
    }

    let libs = null;
    try {
      libs = await ensureFp3dLibs();
    } catch (e) {
      fp3dSetStatus(`3D library load failed: ${e && e.message ? e.message : e}`, 'error');
      console.timeEnd('[3D] build total');
      console.groupEnd();
      throw e;
    }
    const { THREE, SVGLoader } = libs;
    if (!fp3dState.scene) return;

    // Clear previous model
    if (fp3dState.root) {
      try { fp3dState.scene.remove(fp3dState.root); } catch { }
      fp3dDisposeObject3D(fp3dState.root);
      fp3dState.root = null;
    }

    let parsed = null;
    console.time('[3D] SVG parse');
    try {
      const loader = new SVGLoader();
      parsed = loader.parse(svgText);
    } catch (e) {
      console.error('[3D] SVG parse failed:', e);
      parsed = null;
    } finally {
      console.timeEnd('[3D] SVG parse');
    }
    if (!parsed || !Array.isArray(parsed.paths) || parsed.paths.length === 0) {
      fp3dSetStatus('Failed to parse SVG into shapes for 3D.', 'error');
      console.warn('[3D] Parsed paths:', parsed && parsed.paths ? parsed.paths.length : '(none)');
      console.timeEnd('[3D] build total');
      console.groupEnd();
      return;
    }

    console.log('[3D] parsed paths:', parsed.paths.length);

    const group = new THREE.Group();
    const extrudeSettings = { depth: depthUnits, bevelEnabled: false, curveSegments: 2, steps: 1 };
    let meshCount = 0;
    let shapeCount = 0;
    let fillPathCount = 0;
    console.time('[3D] shapes+extrude');

    for (const p of parsed.paths) {
      const style = (p && p.userData && p.userData.style) ? p.userData.style : {};
      const fill = (style.fill || '').trim();
      if (!fill || fill.toLowerCase() === 'none') continue;
      fillPathCount++;

      let color = null;
      try { color = new THREE.Color(fill); } catch { color = null; }
      if (!color) continue;
      // Ignore near-white fills (common background rectangles)
      if (color.r > 0.95 && color.g > 0.95 && color.b > 0.95) continue;

      const opacity = Math.max(0, Math.min(1, parseFloat(String(style.fillOpacity || '1')) || 1));
      const material = new THREE.MeshStandardMaterial({
        color,
        roughness: 0.95,
        metalness: 0.0,
        transparent: opacity < 1,
        opacity
      });

      let shapes = [];
      try { shapes = SVGLoader.createShapes(p); } catch { shapes = []; }
      shapeCount += shapes.length;
      for (const s of shapes) {
        try {
          const geom = new THREE.ExtrudeGeometry(s, extrudeSettings);
          const mesh = new THREE.Mesh(geom, material);
          group.add(mesh);
          meshCount++;
        } catch { }
      }
    }

    console.timeEnd('[3D] shapes+extrude');
    console.log('[3D] fill paths used:', fillPathCount);
    console.log('[3D] shapes created:', shapeCount);
    console.log('[3D] meshes created:', meshCount);

    if (meshCount === 0) {
      fp3dSetStatus('SVG parsed, but no filled shapes were found to extrude. (Try a different SVG / ensure it has filled paths.)', 'error');
      console.timeEnd('[3D] build total');
      console.groupEnd();
      return;
    }

    // SVG Y axis is downward; flip to make it look natural in 3D
    group.scale.y *= -1;

    // Center + fit
    const box = new THREE.Box3().setFromObject(group);
    const size = new THREE.Vector3();
    const center = new THREE.Vector3();
    box.getSize(size);
    box.getCenter(center);
    group.position.x -= center.x;
    group.position.y -= center.y;
    group.position.z -= depthUnits / 2;

    fp3dState.scene.add(group);
    fp3dState.root = group;

    // Fit camera distance
    const maxDim = Math.max(size.x, size.y, size.z);
    const dist = Math.max(200, maxDim * 1.1);
    try {
      fp3dState.camera.position.set(0, -dist, dist);
      fp3dState.controls.target.set(0, 0, 0);
      fp3dState.controls.update();
    } catch { }

    fp3dSetStatus(`3D ready. Height: ${heightM} m (depth: ${depthUnits.toFixed(1)} units). Shapes: ${meshCount}.`, 'ok');

    console.timeEnd('[3D] build total');
    console.groupEnd();
  }

