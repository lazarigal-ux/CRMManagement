  function fpExportGroup(name) {
    const entry = name ? fpSvgGroups[name] : null;
    if (!entry || !entry.svgText) { fpSetGroupStatus('No group SVG to export', 'error'); return; }
    const blob = new Blob([entry.svgText], { type: 'image/svg+xml;charset=utf-8' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    const fn = (lastAnalysis && lastAnalysis.fileName)
      || ((pdfInput && pdfInput.files && pdfInput.files[0]) ? (pdfInput.files[0].name || 'floorplan') : 'floorplan');
    a.download = `${fn.replace(/\.[^.]+$/, '')}_${name}.svg`;
    document.body.appendChild(a); a.click(); a.remove();
    setTimeout(() => URL.revokeObjectURL(url), 2500);
    fpSetGroupStatus(`Exported group ${name}`, 'ok');
  }

  function applyAnalysisToFloorPlan(analysis) {
    if (!analysis) return;
    lastAnalysis = analysis;
    pendingAnalysis = null;
    try {
      renderScale(analysis);
      renderFloorPlan(analysis);
