@page
@model CRMManagement.Web.Pages.Auth.ExternalLoginModel
@{
    ViewData["Title"] = "External Login";
    ViewData["ForceHideSidebar"] = true;
}

<section class="w-full mt-10 px-4">
    <div class="mx-auto max-w-md rounded-2xl border border-slate-600/50 bg-slate-700/80 text-slate-100 overflow-hidden shadow-[0_6px_24px_-10px_rgba(2,6,23,.25)]">
        <div class="px-6 py-5 border-b border-slate-600/40">
            <h1 class="text-xl font-semibold tracking-tight">External Login</h1>
            <p class="mt-1 text-sm text-slate-300">Redirecting to the external identity provider.</p>
        </div>
        <div class="px-6 py-5 text-sm text-slate-300">Redirecting...</div>
    </div>
</section>
