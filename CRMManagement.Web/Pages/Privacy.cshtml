@page
@model PrivacyModel
@{
    ViewData["Title"] = "Privacy Policy";
}
<section class="w-full mt-10 px-4">
    <div class="mx-auto max-w-4xl rounded-2xl border border-slate-600/50 bg-slate-700/80 text-slate-100 overflow-hidden shadow-[0_6px_24px_-10px_rgba(2,6,23,.25)]">
        <div class="px-6 py-5 border-b border-slate-600/40">
            <h1 class="text-2xl font-semibold tracking-tight">@ViewData["Title"]</h1>
            <p class="mt-2 text-sm text-slate-300">Privacy and data handling information for the CRMManagement module.</p>
        </div>
        <div class="px-6 py-5 text-sm text-slate-300 space-y-3">
            <p>This page can be used to document how the application handles user data, authentication details, and operational telemetry.</p>
            <p>Update it when formal privacy language is available.</p>
        </div>
    </div>
</section>
