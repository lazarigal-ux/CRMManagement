@page "{id:guid}"
@model CRMManagement.Web.Pages.Products.DetailsModel
@{ ViewData["Title"] = "Product Details"; }

@if (Model.Item is null)
{
    <div class="p-4 text-slate-300">Not found.</div>
}
else
{
    var p = Model.Item;
    <section class="p-4 space-y-4">
        <div class="flex items-center justify-between">
            <h1 class="text-2xl font-semibold text-slate-100">@p.Name</h1>
            <a asp-page="/Products/Upsert" asp-route-id="@p.Id" class="px-4 py-2 rounded-xl bg-blue-600 hover:bg-blue-500 text-white text-sm">Edit</a>
        </div>
        <div class="rounded-2xl border border-slate-700/50 bg-slate-800/40 p-6 grid grid-cols-1 md:grid-cols-2 gap-4 text-sm text-slate-200">
            <div><span class="text-slate-400">SKU:</span> @p.Sku</div>
            <div><span class="text-slate-400">Family:</span> @p.Family</div>
            <div><span class="text-slate-400">Price:</span> @p.StandardPrice.ToString("N2")</div>
            <div><span class="text-slate-400">Cost:</span> @p.Cost</div>
            <div><span class="text-slate-400">Unit:</span> @p.Unit</div>
            <div><span class="text-slate-400">Active:</span> @p.IsActive</div>
            <div class="md:col-span-2"><span class="text-slate-400">Description:</span> @p.Description</div>
        </div>
        <partial name="_CustomFields" model='(EntityType: "Product", EntityId: Model.Item!.Id)' />
</section>
}
