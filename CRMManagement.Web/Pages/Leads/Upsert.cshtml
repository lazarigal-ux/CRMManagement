@page "{id:guid?}"
@model CRMManagement.Web.Pages.Leads.UpsertModel
@{
    var isNew = Model.Input.Id is null;
    ViewData["Title"] = isNew ? "New Lead" : "Edit Lead";
}

<style>
    /* ── Form inputs ── */
    .cred-form-input {
        background: light-dark(#ffffff, rgba(15,23,42,.4));
        border-color: light-dark(#aab7b8, rgba(100,116,139,.5));
        color: light-dark(#16191f, #f1f5f9);
    }
    .cred-form-input::placeholder {
        color: light-dark(#687078, rgba(148,163,184,.65));
    }
    .cred-form-input:focus {
        outline: none;
        border-color: #0ea5e9;
        box-shadow: 0 0 0 2px rgba(14,165,233,.25);
    }
    .cred-form-label {
        color: light-dark(#545b64, #94a3b8);
    }

    /* ── comm-section-title ── */
    .comm-section-title {
        display: flex; align-items: center; gap: .5rem;
        font-size: .8125rem; line-height: 1.25rem; font-weight: 600;
        text-transform: uppercase; letter-spacing: .08em;
        color: light-dark(#16191f, rgb(203 213 225));
    }
    .comm-section-title i { color: light-dark(#0073bb, rgb(59 130 246)); font-size: .875rem; }

    /* ── vm-action-btn ── */
    .vm-action-btn {
        border-color: light-dark(#c5ccd3, rgba(71,85,105,.5));
        color: light-dark(#16191f, #f1f5f9);
    }

    /* ══ GRAY theme ══ */
    html[data-theme="gray"] .cred-form-card,
    html.dark .cred-form-card {
        background: rgb(51,65,85) !important;
        border-color: rgba(71,85,105,.55) !important;
        box-shadow: 0 2px 8px rgba(0,0,0,.35) !important;
    }
    html[data-theme="gray"] .cred-form-input,
    html.dark .cred-form-input {
        background: rgba(15,23,42,.4) !important;
        border-color: rgba(100,116,139,.5) !important;
    }
    html[data-theme="gray"] .vm-action-btn,
    html.dark .vm-action-btn {
        border-color: rgba(100,116,139,.6) !important;
        color: #f1f5f9 !important;
    }

    /* ══ BLACK theme ══ */
    html[data-theme="black"] .cred-form-card {
        background: rgb(22,22,22) !important;
        border-color: rgba(255,255,255,.08) !important;
        box-shadow: 0 2px 12px rgba(0,0,0,.6) !important;
    }
    html[data-theme="black"] .cred-form-input {
        background: rgba(0,0,0,.4) !important;
        border-color: rgba(255,255,255,.10) !important;
    }
    html[data-theme="black"] .vm-action-btn {
        border-color: rgba(255,255,255,.12) !important;
        color: #f1f5f9 !important;
    }

    /* ══ LIGHT theme ══ */
    html[data-theme="light"] .cred-form-card {
        background: #ffffff !important;
        border-color: #d5dbdb !important;
        box-shadow: 0 1px 4px rgba(0,0,0,.1) !important;
    }
    html[data-theme="light"] .cred-form-input {
        background: #ffffff !important;
        border-color: #aab7b8 !important;
        color: #16191f !important;
    }
    html[data-theme="light"] .cred-form-label {
        color: #545b64 !important;
    }

    /* ── Responsive ── */
    @@media (max-width: 767px) {
        #lead-form-root .grid {
            grid-template-columns: 1fr !important;
            gap: 0.65rem !important;
        }
        #lead-form-root .grid > [style*="grid-column"] {
            grid-column: auto !important;
        }
        #lead-form-root .cred-form-card .px-4.flex {
            flex-direction: column !important;
            align-items: stretch !important;
        }
        #lead-form-root .cred-form-card .px-4.flex > div:last-child {
            display: flex !important;
            flex-wrap: wrap !important;
            gap: 0.4rem !important;
        }
        #lead-form-root .cred-form-card .px-4.flex > div:last-child > * {
            flex: 1 1 auto;
            justify-content: center;
            min-width: 0;
            text-align: center;
        }
    }
</style>

<section id="lead-form-root" class="w-full" style="padding-left:0; padding-right:0; padding-bottom:2rem; margin-top:0.5rem;">

    <div class="cred-form-card w-full rounded-2xl border overflow-hidden">

        <form method="post">
        <input type="hidden" asp-for="Input.Id" />

        <div class="flex flex-col gap-2 py-2">

            <!-- Card header -->
            <div class="px-4 flex flex-col md:flex-row md:items-start md:justify-between gap-3">
                <div>
                    <h2 class="comm-section-title">
                        <i class="fa-solid fa-user-plus"></i>
                        <span>@ViewData["Title"]</span>
                    </h2>
                    <div class="text-sm mt-0.5" style="color:light-dark(#545b64, #94a3b8)">@(isNew ? "Create a new lead with contact and business details." : "Edit lead details and contact information.")</div>
                </div>
                <div class="flex flex-wrap items-center gap-2 shrink-0">
                    <button type="submit"
                            class="inline-flex items-center gap-2 rounded-full bg-sky-600 hover:bg-sky-500 px-3 py-1.5 text-sm text-white transition font-medium">
                        <i class="fas fa-save text-xs"></i> Save
                    </button>
                    <a asp-page="/Leads/Index"
                       class="vm-action-btn inline-flex items-center gap-2 rounded-full border px-3 py-1.5 text-sm hover:opacity-80 transition"
                       title="Back to leads">
                        <i class="fa-solid fa-arrow-left text-xs"></i>
                        <span>Back</span>
                    </a>
                </div>
            </div>

            <!-- Divider -->
            <div class="border-t" style="border-color:light-dark(#d5dbdb, rgba(255,255,255,.08)) !important;"></div>

            <!-- Card body -->
            <div class="px-4 py-3">
                <div asp-validation-summary="ModelOnly" class="text-red-400 text-sm mb-2"></div>

                <!-- 2-column grid -->
                <div class="grid" style="grid-template-columns:repeat(2, minmax(0, 1fr)); gap:.75rem;">

                    <!-- First Name -->
                    <div class="space-y-1.5">
                        <label asp-for="Input.FirstName" class="cred-form-label block text-sm font-medium">
                            <span class="inline-flex items-center gap-2">
                                <i class="fa-solid fa-user text-xs"></i>
                                <span>First Name</span>
                                <span class="text-red-500">*</span>
                            </span>
                        </label>
                        <input asp-for="Input.FirstName" required placeholder="John"
                               class="cred-form-input w-full rounded-lg border px-3 py-2 text-sm" />
                        <span asp-validation-for="Input.FirstName" class="text-red-400 text-xs"></span>
                    </div>

                    <!-- Last Name -->
                    <div class="space-y-1.5">
                        <label asp-for="Input.LastName" class="cred-form-label block text-sm font-medium">
                            <span class="inline-flex items-center gap-2">
                                <i class="fa-solid fa-user text-xs"></i>
                                <span>Last Name</span>
                                <span class="text-red-500">*</span>
                            </span>
                        </label>
                        <input asp-for="Input.LastName" required placeholder="Doe"
                               class="cred-form-input w-full rounded-lg border px-3 py-2 text-sm" />
                        <span asp-validation-for="Input.LastName" class="text-red-400 text-xs"></span>
                    </div>

                    <!-- Company -->
                    <div class="space-y-1.5">
                        <label asp-for="Input.Company" class="cred-form-label block text-sm font-medium">
                            <span class="inline-flex items-center gap-2">
                                <i class="fa-solid fa-building text-xs"></i>
                                <span>Company</span>
                            </span>
                        </label>
                        <input asp-for="Input.Company" placeholder="Acme Corp"
                               class="cred-form-input w-full rounded-lg border px-3 py-2 text-sm" />
                    </div>

                    <!-- Title -->
                    <div class="space-y-1.5">
                        <label asp-for="Input.Title" class="cred-form-label block text-sm font-medium">
                            <span class="inline-flex items-center gap-2">
                                <i class="fa-solid fa-briefcase text-xs"></i>
                                <span>Title</span>
                            </span>
                        </label>
                        <input asp-for="Input.Title" placeholder="CTO"
                               class="cred-form-input w-full rounded-lg border px-3 py-2 text-sm" />
                    </div>

                    <!-- Email -->
                    <div class="space-y-1.5">
                        <label asp-for="Input.Email" class="cred-form-label block text-sm font-medium">
                            <span class="inline-flex items-center gap-2">
                                <i class="fa-solid fa-envelope text-xs"></i>
                                <span>Email</span>
                            </span>
                        </label>
                        <input asp-for="Input.Email" type="email" placeholder="john@@example.com"
                               class="cred-form-input w-full rounded-lg border px-3 py-2 text-sm" />
                    </div>

                    <!-- Phone -->
                    <div class="space-y-1.5">
                        <label asp-for="Input.Phone" class="cred-form-label block text-sm font-medium">
                            <span class="inline-flex items-center gap-2">
                                <i class="fa-solid fa-phone text-xs"></i>
                                <span>Phone</span>
                            </span>
                        </label>
                        <input asp-for="Input.Phone" type="tel" placeholder="+1 555-123-4567"
                               class="cred-form-input w-full rounded-lg border px-3 py-2 text-sm" />
                    </div>

                    <!-- Source -->
                    <div class="space-y-1.5">
                        <label asp-for="Input.Source" class="cred-form-label block text-sm font-medium">
                            <span class="inline-flex items-center gap-2">
                                <i class="fa-solid fa-bullhorn text-xs"></i>
                                <span>Source</span>
                            </span>
                        </label>
                        <input asp-for="Input.Source" placeholder="Website, Referral, LinkedIn…"
                               class="cred-form-input w-full rounded-lg border px-3 py-2 text-sm" />
                    </div>

                    <!-- Status -->
                    <div class="space-y-1.5">
                        <label asp-for="Input.Status" class="cred-form-label block text-sm font-medium">
                            <span class="inline-flex items-center gap-2">
                                <i class="fa-solid fa-circle-info text-xs"></i>
                                <span>Status</span>
                            </span>
                        </label>
                        <select asp-for="Input.Status"
                                class="cred-form-input w-full rounded-lg border px-3 py-2 text-sm">
                            <option value="New">New</option>
                            <option value="Contacted">Contacted</option>
                            <option value="Qualified">Qualified</option>
                            <option value="Won">Won</option>
                            <option value="Lost">Lost</option>
                        </select>
                    </div>

                    <!-- Rating -->
                    <div class="space-y-1.5">
                        <label asp-for="Input.Rating" class="cred-form-label block text-sm font-medium">
                            <span class="inline-flex items-center gap-2">
                                <i class="fa-solid fa-star text-xs"></i>
                                <span>Rating</span>
                            </span>
                        </label>
                        <select asp-for="Input.Rating"
                                class="cred-form-input w-full rounded-lg border px-3 py-2 text-sm">
                            <option value="">— Select —</option>
                            <option value="Hot">Hot</option>
                            <option value="Warm">Warm</option>
                            <option value="Cold">Cold</option>
                        </select>
                    </div>

                    <!-- Score -->
                    <div class="space-y-1.5">
                        <label asp-for="Input.Score" class="cred-form-label block text-sm font-medium">
                            <span class="inline-flex items-center gap-2">
                                <i class="fa-solid fa-chart-line text-xs"></i>
                                <span>Score</span>
                            </span>
                        </label>
                        <input asp-for="Input.Score" type="number" min="0" max="100" placeholder="0"
                               class="cred-form-input w-full rounded-lg border px-3 py-2 text-sm" />
                    </div>

                    <!-- Industry -->
                    <div class="space-y-1.5">
                        <label asp-for="Input.Industry" class="cred-form-label block text-sm font-medium">
                            <span class="inline-flex items-center gap-2">
                                <i class="fa-solid fa-industry text-xs"></i>
                                <span>Industry</span>
                            </span>
                        </label>
                        <input asp-for="Input.Industry" placeholder="Technology, Healthcare…"
                               class="cred-form-input w-full rounded-lg border px-3 py-2 text-sm" />
                    </div>

                    <!-- Website -->
                    <div class="space-y-1.5">
                        <label asp-for="Input.Website" class="cred-form-label block text-sm font-medium">
                            <span class="inline-flex items-center gap-2">
                                <i class="fa-solid fa-globe text-xs"></i>
                                <span>Website</span>
                            </span>
                        </label>
                        <input asp-for="Input.Website" type="url" placeholder="https://example.com"
                               class="cred-form-input w-full rounded-lg border px-3 py-2 text-sm" />
                    </div>

                    <!-- Mobile -->
                    <div class="space-y-1.5">
                        <label asp-for="Input.Mobile" class="cred-form-label block text-sm font-medium">
                            <span class="inline-flex items-center gap-2"><i class="fa-solid fa-mobile-screen text-xs"></i><span>Mobile</span></span>
                        </label>
                        <input asp-for="Input.Mobile" type="tel" placeholder="+1 555-987-6543"
                               class="cred-form-input w-full rounded-lg border px-3 py-2 text-sm" />
                    </div>

                    <!-- Annual Revenue -->
                    <div class="space-y-1.5">
                        <label asp-for="Input.AnnualRevenue" class="cred-form-label block text-sm font-medium">
                            <span class="inline-flex items-center gap-2"><i class="fa-solid fa-sack-dollar text-xs"></i><span>Annual Revenue</span></span>
                        </label>
                        <input asp-for="Input.AnnualRevenue" type="number" step="0.01" placeholder="0.00"
                               class="cred-form-input w-full rounded-lg border px-3 py-2 text-sm" />
                    </div>

                    <!-- Number of Employees -->
                    <div class="space-y-1.5">
                        <label asp-for="Input.NoOfEmployees" class="cred-form-label block text-sm font-medium">
                            <span class="inline-flex items-center gap-2"><i class="fa-solid fa-users text-xs"></i><span>No. of Employees</span></span>
                        </label>
                        <input asp-for="Input.NoOfEmployees" type="number" min="0" placeholder="0"
                               class="cred-form-input w-full rounded-lg border px-3 py-2 text-sm" />
                    </div>

                    <!-- Street -->
                    <div class="space-y-1.5">
                        <label asp-for="Input.Street" class="cred-form-label block text-sm font-medium">
                            <span class="inline-flex items-center gap-2"><i class="fa-solid fa-road text-xs"></i><span>Street</span></span>
                        </label>
                        <input asp-for="Input.Street" placeholder="123 Main St"
                               class="cred-form-input w-full rounded-lg border px-3 py-2 text-sm" />
                    </div>

                    <!-- City -->
                    <div class="space-y-1.5">
                        <label asp-for="Input.City" class="cred-form-label block text-sm font-medium">
                            <span class="inline-flex items-center gap-2"><i class="fa-solid fa-city text-xs"></i><span>City</span></span>
                        </label>
                        <input asp-for="Input.City" placeholder="Springfield"
                               class="cred-form-input w-full rounded-lg border px-3 py-2 text-sm" />
                    </div>

                    <!-- State -->
                    <div class="space-y-1.5">
                        <label asp-for="Input.State" class="cred-form-label block text-sm font-medium">
                            <span class="inline-flex items-center gap-2"><i class="fa-solid fa-map-location-dot text-xs"></i><span>State / Province</span></span>
                        </label>
                        <input asp-for="Input.State" placeholder="IL"
                               class="cred-form-input w-full rounded-lg border px-3 py-2 text-sm" />
                    </div>

                    <!-- Zip Code -->
                    <div class="space-y-1.5">
                        <label asp-for="Input.ZipCode" class="cred-form-label block text-sm font-medium">
                            <span class="inline-flex items-center gap-2"><i class="fa-solid fa-mailbox text-xs"></i><span>Zip / Postal Code</span></span>
                        </label>
                        <input asp-for="Input.ZipCode" placeholder="62701"
                               class="cred-form-input w-full rounded-lg border px-3 py-2 text-sm" />
                    </div>

                    <!-- Country -->
                    <div class="space-y-1.5">
                        <label asp-for="Input.Country" class="cred-form-label block text-sm font-medium">
                            <span class="inline-flex items-center gap-2"><i class="fa-solid fa-flag text-xs"></i><span>Country</span></span>
                        </label>
                        <input asp-for="Input.Country" placeholder="USA"
                               class="cred-form-input w-full rounded-lg border px-3 py-2 text-sm" />
                    </div>

                    <!-- Description (full width) -->
                    <div class="space-y-1.5" style="grid-column: 1 / -1;">
                        <label asp-for="Input.Description" class="cred-form-label block text-sm font-medium">
                            <span class="inline-flex items-center gap-2">
                                <i class="fa-solid fa-align-left text-xs"></i>
                                <span>Description</span>
                            </span>
                        </label>
                        <textarea asp-for="Input.Description" rows="3" placeholder="Additional notes about this lead…"
                                  class="cred-form-input w-full rounded-lg border px-3 py-2 text-sm"></textarea>
                    </div>

                </div>
            </div>

        </div>
        </form>

    </div>
</section>
