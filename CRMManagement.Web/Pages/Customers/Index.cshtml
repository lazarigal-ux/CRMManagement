@page
@model CRMManagement.Web.Pages.Customers.IndexModel
@{
    ViewData["Title"] = "Customers";

    var isActiveOnly = string.Equals(Model.Scope, "active",   StringComparison.OrdinalIgnoreCase);
    var isInactive   = string.Equals(Model.Scope, "inactive", StringComparison.OrdinalIgnoreCase);
    var isAll        = !isActiveOnly && !isInactive;
}

<style>
    :root{--svc-header-row-height:42px}
    /* utility shims (CRM prebuilt Tailwind may omit these) */
    .tracking-wide{letter-spacing:.025em}
    .tracking-wider{letter-spacing:.05em}
    #svcCustTable{border-collapse:collapse;width:100%;table-layout:auto}
    #svcCustTable th,#svcCustTable td{border-right:1px solid rgba(148,163,184,.2)!important;padding-left:.4rem;padding-right:.4rem}
    #svcCustTable th:last-child,#svcCustTable td:last-child{border-right:none!important}
    #svcCustTable tbody td{border-bottom:1px solid rgba(148,163,184,.25)!important}
    #svcCustTable thead th{border-bottom:1px solid rgba(148,163,184,.35)!important}
    #svcCustTable thead tr:first-child th{position:sticky;top:0;z-index:24;backdrop-filter:blur(10px);-webkit-backdrop-filter:blur(10px)}
    #svcCustTable thead .svc-filter-row th{position:sticky;top:var(--svc-header-row-height);z-index:23}
    #svcCustTable .svc-actions-col{min-width:8rem;width:8rem}
    #svcCustTable td{font-size:11px;padding-top:.3rem;padding-bottom:.3rem}
    #svcCustTable thead th{font-size:10px;padding-top:.4rem;padding-bottom:.4rem}
    #svcCustTable .svc-col-name,
    #svcCustTable .svc-col-type,
    #svcCustTable .svc-col-address,
    #svcCustTable .svc-col-email,
    #svcCustTable .svc-col-payment{max-width:14rem;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}

    .svc-table-wrap{border-radius:0 0 1rem 1rem;overflow-x:auto;overflow-y:hidden;scrollbar-gutter:stable both-edges}
    .svc-table-wrap::-webkit-scrollbar{height:10px}
    .svc-table-wrap::-webkit-scrollbar-thumb{background:rgba(148,163,184,.45);border-radius:9999px}

    html[data-theme="gray"]  .svc-table-card{background:rgb(51,65,85)!important;border-color:rgba(148,163,184,.45)!important;box-shadow:0 6px 24px -4px rgba(0,0,0,.55),0 0 0 1px rgba(255,255,255,.07)!important}
    html[data-theme="black"] .svc-table-card{background:rgb(22,22,22)!important;border-color:rgba(255,255,255,.08)!important;box-shadow:0 2px 12px rgba(0,0,0,.6)!important}
    html[data-theme="black"] .svc-table-card .svc-toolbar{border-bottom-color:rgba(255,255,255,.06)!important}
    html[data-theme="black"] .svc-table-card .svc-toolbar-btn{border-color:rgba(255,255,255,.12)!important}
    html[data-theme="black"] .svc-table-card thead tr:first-child{background:rgba(255,255,255,.04)!important}
    html[data-theme="black"] .svc-table-card .svc-filter-row{background:rgba(255,255,255,.02)!important}
    html[data-theme="black"] .svc-table-card .svc-col-filter{background:rgba(0,0,0,.4)!important;border-color:rgba(255,255,255,.10)!important}
    html[data-theme="black"] .svc-table-card tbody tr:hover{background:rgba(255,255,255,.06)!important}

    html[data-theme="light"] .svc-table-card{background:#ffffff!important;border-color:#d5dbdb!important;box-shadow:0 1px 4px rgba(0,0,0,.08)!important;color:#16191f!important}
    html[data-theme="light"] .svc-table-card .svc-toolbar{border-bottom-color:#e5e7eb!important}
    html[data-theme="light"] .svc-table-card thead tr:first-child{background:#f7f8f8!important;color:#16191f!important}
    html[data-theme="light"] .svc-table-card .svc-filter-row{background:#f7f8f8!important}
    html[data-theme="light"] .svc-table-card .svc-col-filter{background:#ffffff!important;border-color:#aab7b8!important;color:#16191f!important}
    html[data-theme="light"] .svc-table-card tbody tr{color:#16191f!important}
    html[data-theme="light"] .svc-table-card tbody tr:hover{background:rgba(0,0,0,.03)!important}

    .svc-toolbar-btn{display:inline-flex;align-items:center;gap:.4rem;transition:opacity 150ms}
    .svc-toolbar-btn:hover{opacity:.8}

    #svc-cust-colvis-menu label{display:flex;align-items:center;gap:.5rem;padding:.35rem .5rem;border-radius:.375rem;cursor:pointer;transition:background 120ms}
    #svc-cust-colvis-menu label:hover{background:light-dark(rgba(0,0,0,.05),rgba(255,255,255,.08))}

    .svc-ctx-menu{position:fixed;z-index:9999;min-width:13rem;padding:.35rem 0;border-radius:.65rem;border:1px solid light-dark(#d5dbdb,rgba(71,85,105,.6));background:light-dark(#ffffff,rgba(30,41,59,.97));color:light-dark(#16191f,#f1f5f9);box-shadow:0 12px 32px -4px rgba(0,0,0,.35),0 0 0 1px rgba(255,255,255,.04);backdrop-filter:blur(12px);-webkit-backdrop-filter:blur(12px);font-size:13px;line-height:1;display:none}
    .svc-ctx-menu.open{display:block}
    .svc-ctx-menu-item{display:flex;align-items:center;gap:.6rem;padding:.5rem .85rem;cursor:pointer;transition:background 100ms;white-space:nowrap;border:none;background:none;width:100%;color:inherit;font-size:inherit;text-align:left}
    .svc-ctx-menu-item:hover{background:light-dark(rgba(0,0,0,.05),rgba(255,255,255,.08))}
    .svc-ctx-menu-item i{width:1rem;text-align:center;font-size:12px}
    .svc-ctx-sep{height:1px;margin:.3rem .6rem;background:light-dark(#e5e7eb,rgba(71,85,105,.45))}

    .svc-tab-active{background:var(--color-brand,#3b82f6)!important;color:#fff!important;font-weight:600}

    .svc-actions-inline{display:inline-flex;gap:.4rem;flex-wrap:nowrap;justify-content:center;min-width:8.5rem}
    .svc-action-btn{padding:.3rem .6rem!important;min-width:3.4rem;justify-content:center;white-space:nowrap}

    @@media(max-width:640px){
        .svc-toolbar{flex-wrap:wrap;padding:.5rem .75rem;gap:.4rem}
        .svc-toolbar .min-w-0{width:100%}
        .svc-toolbar .ml-auto{width:100%;flex-wrap:wrap;gap:.3rem;justify-content:flex-start}
        .svc-toolbar .ml-auto button>span,.svc-toolbar .ml-auto a>span{display:none}
        .svc-toolbar h3{font-size:.7rem}
        #svcCustTable th,#svcCustTable td{padding-left:.35rem;padding-right:.35rem;font-size:10px}
        .svc-col-filter{min-width:3rem;font-size:10px;padding:.15rem .3rem}
        .svc-cust-desktop-table{display:none!important}
        .svc-cust-mobile-cards{display:block!important}
        #svcCustFilterBar{flex-direction:column;align-items:stretch;gap:.5rem}
        #svcCustFilterBar > div{width:100%}
        #svcCustFilterBar input[type="text"]{min-width:0!important;width:100%}
    }
    @@media(min-width:641px){
        .svc-cust-mobile-cards{display:none!important}
    }

    .svc-cust-mobile-card{
        background:light-dark(#ffffff,rgba(30,41,59,.55));
        border-color:light-dark(#d5dbdb,rgba(71,85,105,.5));
        color:light-dark(#16191f,#f1f5f9);
    }
    html[data-theme="black"] .svc-cust-mobile-card{
        background:rgba(0,0,0,.25)!important;
        border-color:rgba(255,255,255,.08)!important;
    }
    .svc-cust-mobile-card-label{
        color:light-dark(#687078,#94a3b8);
        font-size:10px;font-weight:600;text-transform:uppercase;letter-spacing:.05em;
    }
    .svc-cust-mobile-card-value{font-size:13px}

    .svc-pager{display:flex;align-items:center;justify-content:space-between;gap:.75rem;padding:.75rem 1rem;border-top:1px solid light-dark(#d5dbdb,rgba(71,85,105,.4));background:light-dark(#f7f8f8,rgba(30,41,59,.38))}
    .svc-pager-summary{font-size:11px;color:light-dark(#687078,#94a3b8)}
    .svc-pager-controls{display:flex;align-items:center;gap:.35rem;flex-wrap:wrap;justify-content:flex-end}
    .svc-pager-btn{min-width:2rem;height:2rem;display:inline-flex;align-items:center;justify-content:center;border-radius:9999px;border:1px solid light-dark(#aab7b8,rgba(100,116,139,.45));background:light-dark(#ffffff,rgba(255,255,255,.03));color:light-dark(#16191f,#e2e8f0);font-size:11px;font-weight:600;padding:0 .7rem;transition:opacity 140ms}
    .svc-pager-btn:hover:not(:disabled){opacity:.86}
    .svc-pager-btn:disabled{opacity:.45;cursor:not-allowed}
    .svc-pager-btn.is-active{background:light-dark(#eaf4fc,rgba(56,189,248,.14));border-color:light-dark(#89bde0,rgba(56,189,248,.28));color:light-dark(#0073bb,#7dd3fc)}

    html[dir="rtl"] [data-page="crm-customers"] .text-left{text-align:right!important}
    html[dir="rtl"] [data-page="crm-customers"] .svc-ctx-menu-item{text-align:right}
    html[dir="rtl"] [data-page="crm-customers"] .svc-toolbar .ml-auto{margin-left:0!important;margin-right:auto!important}
    html[dir="rtl"] [data-page="crm-customers"] #svc-cust-colvis-menu{right:auto!important;left:0!important}
</style>

<div id="svcCustCtxMenu" class="svc-ctx-menu">
    <button type="button" class="svc-ctx-menu-item" data-action="sort-asc"><i class="fa-solid fa-arrow-down-a-z"></i><span>Sort A &#x2192; Z</span></button>
    <button type="button" class="svc-ctx-menu-item" data-action="sort-desc"><i class="fa-solid fa-arrow-down-z-a"></i><span>Sort Z &#x2192; A</span></button>
    <div class="svc-ctx-sep"></div>
    <button type="button" class="svc-ctx-menu-item" data-action="hide"><i class="fa-solid fa-eye-slash"></i><span>Hide column</span></button>
    <div class="svc-ctx-sep"></div>
    <button type="button" class="svc-ctx-menu-item" data-action="move-left"><i class="fa-solid fa-arrow-left"></i><span>Move column left</span></button>
    <button type="button" class="svc-ctx-menu-item" data-action="move-right"><i class="fa-solid fa-arrow-right"></i><span>Move column right</span></button>
    <div class="svc-ctx-sep"></div>
    <button type="button" class="svc-ctx-menu-item" data-action="clear-filter"><i class="fa-solid fa-filter-circle-xmark"></i><span>Clear filter</span></button>
</div>

<section class="w-full max-w-full overflow-x-hidden" style="margin-top:12px;padding-inline:8px;padding-bottom:2rem;box-sizing:border-box;" data-page="crm-customers">

    <div class="w-full rounded-2xl border svc-table-card" style="overflow:visible;background:light-dark(#ffffff,rgb(51,65,85));border-color:light-dark(#d5dbdb,rgba(71,85,105,.5));box-shadow:light-dark(0 1px 4px rgba(0,0,0,.1),0 2px 8px rgba(0,0,0,.35));color:light-dark(#16191f,#f1f5f9)">

        @* ─── Toolbar ─── *@
        <div class="flex items-center gap-2 px-4 py-3 svc-toolbar" style="border-bottom:1px solid light-dark(#d5dbdb,rgba(71,85,105,.4))">
            <i class="fa-solid fa-address-book text-sm" style="color:light-dark(#0073bb,#60a5fa)"></i>
            <div class="min-w-0">
                <h3 class="text-sm font-semibold uppercase tracking-wider" style="color:light-dark(#545b64,#cbd5e1)">Customers</h3>
                <div class="mt-0.5 text-xs" style="color:light-dark(#687078,#94a3b8)">L Control customer directory.</div>
            </div>
            <div class="ml-auto flex items-center justify-end gap-2 flex-nowrap">
                <a asp-page="/Customers/Upsert"
                   class="inline-flex shrink-0 items-center justify-center gap-2 rounded-full border ring-1 px-3 py-1.5 text-sm hover:opacity-80 transition svc-toolbar-btn" style="border-color:light-dark(#aab7b8,rgba(100,116,139,.6));ring-color:light-dark(rgba(0,0,0,.06),rgba(148,163,184,.2));color:light-dark(#16191f,#f1f5f9)" title="New customer">
                    <i class="fa-solid fa-plus text-[12px]" style="color:light-dark(#0073bb,#60a5fa)"></i><span>New</span>
                </a>
                <button id="svcCustFilterToggle" type="button" class="inline-flex shrink-0 items-center justify-center gap-2 rounded-full border ring-1 px-3 py-1.5 text-sm hover:opacity-80 transition svc-toolbar-btn" style="border-color:light-dark(#aab7b8,rgba(100,116,139,.6));ring-color:light-dark(rgba(0,0,0,.06),rgba(148,163,184,.2))" title="Show/Hide search row">
                    <i class="fa-solid fa-chevron-down text-[12px]" data-icon="down"></i>
                    <i class="fa-solid fa-chevron-up text-[12px] hidden" data-icon="up"></i>
                    <span>Filters</span>
                </button>
                <div class="relative shrink-0">
                    <button id="svc-cust-colvis-toggle" type="button" class="inline-flex items-center gap-2 rounded-full border ring-1 px-3 py-1.5 text-sm hover:opacity-80 transition svc-toolbar-btn" style="border-color:light-dark(#aab7b8,rgba(100,116,139,.6));ring-color:light-dark(rgba(0,0,0,.06),rgba(148,163,184,.2))" title="Show/Hide columns"><i class="fa-solid fa-table-columns text-[12px]"></i><span>Cols &#x25BE;</span></button>
                    <div id="svc-cust-colvis-menu" class="hidden absolute right-0 z-50 mt-2 w-52 rounded-xl border shadow-xl backdrop-blur-sm p-2 text-sm leading-tight" style="border-color:light-dark(#d5dbdb,rgba(71,85,105,.6));background:light-dark(#ffffff,rgba(30,41,59,.95));color:light-dark(#16191f,#f1f5f9)"></div>
                </div>
                <div class="flex items-center rounded-full border ring-1 overflow-hidden svc-toolbar-btn" style="border-color:light-dark(#aab7b8,rgba(100,116,139,.6));ring-color:light-dark(rgba(0,0,0,.06),rgba(148,163,184,.2))">
                    <button type="button" id="svcCustBtnExcel" class="inline-flex items-center gap-1 px-3 py-1.5 text-sm hover:opacity-80 transition" style="border-right:1px solid light-dark(#d5dbdb,rgba(100,116,139,.4));color:light-dark(#16191f,#f1f5f9)" title="Export to Excel"><i class="fa-solid fa-file-excel text-[12px] text-emerald-400"></i><span>Excel</span></button>
                    <button type="button" id="svcCustBtnPdf" class="inline-flex items-center gap-1 px-3 py-1.5 text-sm hover:opacity-80 transition" style="border-right:1px solid light-dark(#d5dbdb,rgba(100,116,139,.4));color:light-dark(#16191f,#f1f5f9)" title="Export to PDF"><i class="fa-solid fa-file-pdf text-[12px]" style="color:rgb(251 113 133)"></i><span>PDF</span></button>
                    <button type="button" id="svcCustBtnPrint" class="inline-flex items-center gap-1 px-3 py-1.5 text-sm hover:opacity-80 transition" style="color:light-dark(#16191f,#f1f5f9)" title="Print table"><i class="fa-solid fa-print text-[12px] text-sky-400"></i><span>Print</span></button>
                </div>
                <span class="inline-flex items-center gap-1 rounded-full bg-brand/15 border border-brand/30 px-3 py-0.5 text-xs font-semibold" style="color:light-dark(#0073bb,rgb(96 165 250))">
                    <i class="fa-solid fa-hashtag text-[9px]"></i>@Model.TotalCount
                </span>
            </div>
        </div>

        @* ─── Stat tiles ─── *@
        <div class="svc-stat-tiles" style="display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:.75rem;padding:.75rem 1rem;border-bottom:1px solid light-dark(#d5dbdb,rgba(71,85,105,.4));background:light-dark(#fafbfc,rgba(30,41,59,.25))">
            <div class="rounded-xl border px-3 py-2" style="background-color:light-dark(#e8eef5,rgba(255,255,255,.03));border-color:light-dark(#adb8c4,rgba(255,255,255,.06))">
                <div class="text-[10px] uppercase tracking-wide font-semibold" style="color:light-dark(#0073bb,#7dd3fc)">Total</div>
                <div class="mt-0.5 text-lg font-bold leading-tight" style="color:light-dark(#16191f,#f8fafc)">@Model.TotalCount</div>
            </div>
            <div class="rounded-xl border px-3 py-2" style="background-color:light-dark(#e8eef5,rgba(255,255,255,.03));border-color:light-dark(#adb8c4,rgba(255,255,255,.06))">
                <div class="text-[10px] uppercase tracking-wide font-semibold" style="color:light-dark(#0073bb,#7dd3fc)">L Control Service</div>
                <div class="mt-0.5 text-lg font-bold leading-tight" style="color:light-dark(#16191f,#f8fafc)">@Model.ServiceCount</div>
            </div>
            <div class="rounded-xl border px-3 py-2" style="background-color:light-dark(#e8eef5,rgba(255,255,255,.03));border-color:light-dark(#adb8c4,rgba(255,255,255,.06))">
                <div class="text-[10px] uppercase tracking-wide font-semibold" style="color:light-dark(#0073bb,#7dd3fc)">Active</div>
                <div class="mt-0.5 text-lg font-bold leading-tight" style="color:light-dark(#16191f,#f8fafc)">@Model.ActiveCount</div>
            </div>
        </div>

        @* ─── Filter bar: page-size | scope tabs | global search ─── *@
        <div id="svcCustFilterBar" class="flex items-center justify-between gap-4 px-4 py-2" style="display:none;border-bottom:1px solid light-dark(#d5dbdb,rgba(71,85,105,.4));background:light-dark(#f7f8f8,rgba(30,41,59,.5))">
            <div class="flex items-center gap-2 text-xs" style="color:light-dark(#545b64,#cbd5e1)">
                <span>Show</span>
                <select id="svcCustPageSize" class="rounded-md border px-2 py-1 text-xs outline-none focus:ring-2 focus:ring-blue-600/40" style="background:light-dark(#ffffff,rgba(15,23,42,.7));border-color:light-dark(#aab7b8,rgba(100,116,139,.5));color:light-dark(#16191f,#f1f5f9)">
                    <option value="10">10</option>
                    <option value="25">25</option>
                    <option value="50" selected>50</option>
                    <option value="100">100</option>
                    <option value="-1">All</option>
                </select>
                <span>entries</span>
            </div>
            <div class="flex items-center rounded-full border ring-1 overflow-hidden svc-toolbar-btn" style="border-color:light-dark(#aab7b8,rgba(100,116,139,.6));ring-color:light-dark(rgba(0,0,0,.06),rgba(148,163,184,.2))">
                <a asp-page="/Customers/Index" asp-route-scope="active"
                   class="inline-flex items-center px-3 py-1.5 text-xs hover:opacity-80 transition @(isActiveOnly ? "svc-tab-active" : "")" style="border-right:1px solid light-dark(#d5dbdb,rgba(100,116,139,.4));color:light-dark(#16191f,#f1f5f9)">Active</a>
                <a asp-page="/Customers/Index" asp-route-scope="all"
                   class="inline-flex items-center px-3 py-1.5 text-xs hover:opacity-80 transition @(isAll ? "svc-tab-active" : "")" style="border-right:1px solid light-dark(#d5dbdb,rgba(100,116,139,.4));color:light-dark(#16191f,#f1f5f9)">All</a>
                <a asp-page="/Customers/Index" asp-route-scope="inactive"
                   class="inline-flex items-center px-3 py-1.5 text-xs hover:opacity-80 transition @(isInactive ? "svc-tab-active" : "")" style="color:light-dark(#16191f,#f1f5f9)">Inactive</a>
            </div>
            <div class="flex items-center gap-2">
                <input id="svcCustGlobalSearch" type="text" placeholder="Search" class="rounded-md border px-3 py-1 text-xs outline-none focus:border-blue-500 focus:ring-2 focus:ring-blue-600/40" style="background:light-dark(#ffffff,rgba(15,23,42,.7));border-color:light-dark(#aab7b8,rgba(100,116,139,.5));color:light-dark(#16191f,#f1f5f9);min-width:12rem" />
            </div>
        </div>

        @{
            var colNames = new[] { "Customer No.", "Name", "Type", "City", "Address", "Status", "Opened", "Phone", "Email", "Payment Terms", "Actions" };
            var colCount = colNames.Length - 1;
        }

        @* ─── Table (desktop) ─── *@
        <div class="svc-table-wrap svc-cust-desktop-table">
            <table id="svcCustTable" class="min-w-full">
                <thead>
                    <tr style="background:light-dark(#f7f8f8,rgba(30,41,59,.8));color:light-dark(#16191f,#f1f5f9)" class="text-[11px] uppercase tracking-wide select-none">
                        <th class="px-2 py-1.5 text-left whitespace-nowrap" data-col-idx="0"><div class="flex items-start justify-between gap-2"><span class="inline-flex items-center gap-2"><i class="fa-solid fa-hashtag text-[10px]"></i><span>Customer No.</span></span><button type="button" class="svc-cust-th-btn opacity-40 hover:opacity-100 text-xs px-1 py-0.5 rounded-md border border-transparent hover:border-current/30" title="Column menu"><i class="fa-solid fa-filter text-[10px]"></i></button></div></th>
                        <th class="px-2 py-1.5 text-left whitespace-nowrap svc-col-name" data-col-idx="1"><div class="flex items-start justify-between gap-2"><span class="inline-flex items-center gap-2"><i class="fa-solid fa-user-tie text-[10px]"></i><span>Name</span></span><button type="button" class="svc-cust-th-btn opacity-40 hover:opacity-100 text-xs px-1 py-0.5 rounded-md border border-transparent hover:border-current/30" title="Column menu"><i class="fa-solid fa-filter text-[10px]"></i></button></div></th>
                        <th class="px-2 py-1.5 text-left whitespace-nowrap svc-col-type" data-col-idx="2"><div class="flex items-start justify-between gap-2"><span class="inline-flex items-center gap-2"><i class="fa-solid fa-layer-group text-[10px]"></i><span>Type</span></span><button type="button" class="svc-cust-th-btn opacity-40 hover:opacity-100 text-xs px-1 py-0.5 rounded-md border border-transparent hover:border-current/30" title="Column menu"><i class="fa-solid fa-filter text-[10px]"></i></button></div></th>
                        <th class="px-2 py-1.5 text-left whitespace-nowrap" data-col-idx="3"><div class="flex items-start justify-between gap-2"><span class="inline-flex items-center gap-2"><i class="fa-solid fa-city text-[10px]"></i><span>City</span></span><button type="button" class="svc-cust-th-btn opacity-40 hover:opacity-100 text-xs px-1 py-0.5 rounded-md border border-transparent hover:border-current/30" title="Column menu"><i class="fa-solid fa-filter text-[10px]"></i></button></div></th>
                        <th class="px-2 py-1.5 text-left whitespace-nowrap svc-col-address" data-col-idx="4"><div class="flex items-start justify-between gap-2"><span class="inline-flex items-center gap-2"><i class="fa-solid fa-location-dot text-[10px]"></i><span>Address</span></span><button type="button" class="svc-cust-th-btn opacity-40 hover:opacity-100 text-xs px-1 py-0.5 rounded-md border border-transparent hover:border-current/30" title="Column menu"><i class="fa-solid fa-filter text-[10px]"></i></button></div></th>
                        <th class="px-2 py-1.5 text-left whitespace-nowrap" data-col-idx="5"><div class="flex items-start justify-between gap-2"><span class="inline-flex items-center gap-2"><i class="fa-solid fa-circle-dot text-[10px]"></i><span>Status</span></span><button type="button" class="svc-cust-th-btn opacity-40 hover:opacity-100 text-xs px-1 py-0.5 rounded-md border border-transparent hover:border-current/30" title="Column menu"><i class="fa-solid fa-filter text-[10px]"></i></button></div></th>
                        <th class="px-2 py-1.5 text-left whitespace-nowrap" data-col-idx="6"><div class="flex items-start justify-between gap-2"><span class="inline-flex items-center gap-2"><i class="fa-solid fa-calendar-day text-[10px]"></i><span>Opened</span></span><button type="button" class="svc-cust-th-btn opacity-40 hover:opacity-100 text-xs px-1 py-0.5 rounded-md border border-transparent hover:border-current/30" title="Column menu"><i class="fa-solid fa-filter text-[10px]"></i></button></div></th>
                        <th class="px-2 py-1.5 text-left whitespace-nowrap" data-col-idx="7"><div class="flex items-start justify-between gap-2"><span class="inline-flex items-center gap-2"><i class="fa-solid fa-phone text-[10px]"></i><span>Phone</span></span><button type="button" class="svc-cust-th-btn opacity-40 hover:opacity-100 text-xs px-1 py-0.5 rounded-md border border-transparent hover:border-current/30" title="Column menu"><i class="fa-solid fa-filter text-[10px]"></i></button></div></th>
                        <th class="px-2 py-1.5 text-left whitespace-nowrap svc-col-email" data-col-idx="8"><div class="flex items-start justify-between gap-2"><span class="inline-flex items-center gap-2"><i class="fa-solid fa-envelope text-[10px]"></i><span>Email</span></span><button type="button" class="svc-cust-th-btn opacity-40 hover:opacity-100 text-xs px-1 py-0.5 rounded-md border border-transparent hover:border-current/30" title="Column menu"><i class="fa-solid fa-filter text-[10px]"></i></button></div></th>
                        <th class="px-2 py-1.5 text-left whitespace-nowrap svc-col-payment" data-col-idx="9"><div class="flex items-start justify-between gap-2"><span class="inline-flex items-center gap-2"><i class="fa-solid fa-credit-card text-[10px]"></i><span>Payment Terms</span></span><button type="button" class="svc-cust-th-btn opacity-40 hover:opacity-100 text-xs px-1 py-0.5 rounded-md border border-transparent hover:border-current/30" title="Column menu"><i class="fa-solid fa-filter text-[10px]"></i></button></div></th>
                        <th class="px-2 py-1.5 text-center whitespace-nowrap svc-actions-col" data-col-idx="10"><span class="inline-flex items-center gap-2"><i class="fa-solid fa-ellipsis text-[10px]"></i></span></th>
                    </tr>
                    <tr class="svc-filter-row text-[12px]" style="background:light-dark(#f7f8f8,rgba(30,41,59,.6));color:light-dark(#16191f,#e2e8f0);display:none">
                        @for (var i = 0; i < colCount; i++)
                        {
                            <th class="px-2 py-1.5"><input class="svc-col-filter w-full rounded-md border px-2 py-1 text-[12px] outline-none focus:border-blue-500 focus:ring-2 focus:ring-blue-600/40" style="background:light-dark(#ffffff,rgba(30,41,59,.4));border-color:light-dark(#aab7b8,rgba(100,116,139,.5));color:light-dark(#16191f,#f1f5f9)" type="text" placeholder="Search" data-col="@i" /></th>
                        }
                        <th class="px-2 py-1.5 svc-actions-col"></th>
                    </tr>
                </thead>
                <tbody>
                @if (Model.Items.Count == 0)
                {
                    <tr><td colspan="@colNames.Length" class="px-4 py-6 text-center text-xs" style="color:light-dark(#687078,#94a3b8)">No customers found.</td></tr>
                }
                else
                {
                    foreach (var c in Model.Items)
                    {
                        <tr class="hover:opacity-90 transition-colors align-top" style="border-top:1px solid light-dark(#e5e7eb,rgba(71,85,105,.5))">
                            <td class="px-2 py-1 text-[11px] font-mono whitespace-nowrap" data-full="@(c.ExternalNumber ?? "")">@(c.ExternalNumber ?? "—")</td>
                            <td class="px-2 py-1 text-[11px] font-medium svc-col-name" data-full="@(c.Name ?? "")" title="@(c.Name ?? "")">@c.Name</td>
                            <td class="px-2 py-1 text-[11px] svc-col-type" data-full="@(c.CustomerType ?? "")" title="@(c.CustomerType ?? "")">@(string.IsNullOrEmpty(c.CustomerType) ? "—" : c.CustomerType)</td>
                            <td class="px-2 py-1 text-[11px] whitespace-nowrap" data-full="@(c.City ?? "")">@(string.IsNullOrEmpty(c.City) ? "—" : c.City)</td>
                            <td class="px-2 py-1 text-[11px] svc-col-address" data-full="@(c.Address ?? "")" title="@(c.Address ?? "")">@(string.IsNullOrEmpty(c.Address) ? "—" : c.Address)</td>
                            <td class="px-2 py-1 text-[11px]" data-full="@(c.Status ?? "")">
                                @if (c.Status == "פעיל")
                                {
                                    <span class="inline-flex items-center rounded-full border px-2 py-0.5 text-[10px] font-medium" style="background:light-dark(#d1fae5,rgba(16,185,129,.1));border-color:light-dark(#6ee7b7,rgba(16,185,129,.3));color:light-dark(#065f46,#6ee7b7)">Active</span>
                                }
                                else if (c.Status == "לא פעיל")
                                {
                                    <span class="inline-flex items-center rounded-full border px-2 py-0.5 text-[10px] font-medium" style="background:light-dark(#fef3c7,rgba(234,179,8,.1));border-color:light-dark(#fde68a,rgba(234,179,8,.3));color:light-dark(#854d0e,#fde047)">Inactive</span>
                                }
                                else
                                {
                                    <span style="color:light-dark(#687078,#64748b)">—</span>
                                }
                            </td>
                            <td class="px-2 py-1 text-[11px] whitespace-nowrap" data-full="@(c.OpenedOn?.ToString("yyyy-MM-dd") ?? "")">@(c.OpenedOn?.ToString("dd/MM/yyyy") ?? "—")</td>
                            <td class="px-2 py-1 text-[11px] whitespace-nowrap" data-full="@(c.Phone ?? "")">@(string.IsNullOrEmpty(c.Phone) ? "—" : c.Phone)</td>
                            <td class="px-2 py-1 text-[11px] svc-col-email" data-full="@(c.Email ?? "")" title="@(c.Email ?? "")">@(string.IsNullOrEmpty(c.Email) ? "—" : c.Email)</td>
                            <td class="px-2 py-1 text-[11px] svc-col-payment" data-full="@(c.PaymentTermsName ?? "")" title="@(c.PaymentTermsName ?? "")">@(string.IsNullOrEmpty(c.PaymentTermsName) ? "—" : c.PaymentTermsName)</td>
                            <td class="px-2 py-1 text-[11px] text-center whitespace-nowrap svc-actions-col">
                                <div class="svc-actions-inline">
                                    <a asp-page="/Customers/Upsert" asp-route-id="@c.Id"
                                       class="inline-flex items-center gap-1 rounded-full border text-[11px] font-semibold px-2.5 py-1 hover:opacity-80 transition svc-action-btn" style="border-color:light-dark(#aab7b8,rgba(100,116,139,.4));background:light-dark(rgba(0,0,0,.03),rgba(100,116,139,.15));color:light-dark(#16191f,#e2e8f0)" title="Edit customer">
                                        <i class="fa-solid fa-pen-to-square text-[10px]"></i>
                                        <span>Edit</span>
                                    </a>
                                    <form method="post" asp-page-handler="Delete" class="inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@c.Id" />
                                        <input type="hidden" name="scope" value="@Model.Scope" />
                                        <button type="submit" onclick="return confirm('Delete customer @(c.Name?.Replace("'","\\'"))?')"
                                                class="inline-flex items-center gap-1 rounded-full border text-[11px] font-semibold px-2.5 py-1 hover:opacity-80 transition svc-action-btn" style="border-color:rgba(239,68,68,.4);background:rgba(239,68,68,.08);color:rgb(252 165 165)" title="Delete customer">
                                            <i class="fa-solid fa-trash-can text-[10px]"></i>
                                            <span>Del</span>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                }
                </tbody>
            </table>
        </div>

        <div class="svc-pager svc-cust-desktop-table">
            <div id="svcCustPagerSummary" class="svc-pager-summary">Showing 0 to 0 of 0 entries</div>
            <div class="svc-pager-controls">
                <button type="button" id="svcCustPagerPrev" class="svc-pager-btn" aria-label="Previous page">
                    <i class="fa-solid fa-chevron-left text-[10px]"></i>
                </button>
                <div id="svcCustPagerNumbers" class="svc-pager-controls"></div>
                <button type="button" id="svcCustPagerNext" class="svc-pager-btn" aria-label="Next page">
                    <i class="fa-solid fa-chevron-right text-[10px]"></i>
                </button>
            </div>
        </div>

        @* ─── Mobile cards ─── *@
        <div class="svc-cust-mobile-cards p-3 space-y-3" style="display:none">
            @foreach (var c in Model.Items)
            {
                <div class="svc-cust-mobile-card rounded-xl border p-3 space-y-2">
                    <div class="flex items-center gap-2">
                        <i class="fa-solid fa-user-tie text-xs" style="color:light-dark(#0073bb,#60a5fa)"></i>
                        <span class="text-sm font-semibold">@c.Name</span>
                        <span class="ml-auto text-[10px] font-mono" style="color:light-dark(#687078,#94a3b8)">@c.ExternalNumber</span>
                    </div>
                    <div class="grid grid-cols-2 gap-x-3 gap-y-1.5">
                        @if (!string.IsNullOrWhiteSpace(c.CustomerType))
                        {
                            <div style="grid-column:1/-1">
                                <div class="svc-cust-mobile-card-label">Type</div>
                                <div class="svc-cust-mobile-card-value">@c.CustomerType</div>
                            </div>
                        }
                        @if (!string.IsNullOrWhiteSpace(c.City))
                        {
                            <div>
                                <div class="svc-cust-mobile-card-label">City</div>
                                <div class="svc-cust-mobile-card-value">@c.City</div>
                            </div>
                        }
                        @if (c.OpenedOn.HasValue)
                        {
                            <div>
                                <div class="svc-cust-mobile-card-label">Opened</div>
                                <div class="svc-cust-mobile-card-value">@c.OpenedOn.Value.ToString("dd/MM/yyyy")</div>
                            </div>
                        }
                        @if (!string.IsNullOrWhiteSpace(c.Phone))
                        {
                            <div>
                                <div class="svc-cust-mobile-card-label">Phone</div>
                                <div class="svc-cust-mobile-card-value">@c.Phone</div>
                            </div>
                        }
                        @if (!string.IsNullOrWhiteSpace(c.Email))
                        {
                            <div style="grid-column:1/-1">
                                <div class="svc-cust-mobile-card-label">Email</div>
                                <div class="svc-cust-mobile-card-value" style="word-break:break-all">@c.Email</div>
                            </div>
                        }
                        @if (!string.IsNullOrWhiteSpace(c.PaymentTermsName))
                        {
                            <div>
                                <div class="svc-cust-mobile-card-label">Payment Terms</div>
                                <div class="svc-cust-mobile-card-value">@c.PaymentTermsName</div>
                            </div>
                        }
                    </div>
                    <div class="flex items-center justify-end gap-2 pt-1" style="border-top:1px solid light-dark(#e5e7eb,rgba(71,85,105,.3))">
                        <a asp-page="/Customers/Upsert" asp-route-id="@c.Id"
                           class="inline-flex items-center gap-1 rounded-full border text-[11px] font-semibold px-2.5 py-1 hover:opacity-80 transition" style="border-color:light-dark(#aab7b8,rgba(100,116,139,.4));background:light-dark(rgba(0,0,0,.03),rgba(100,116,139,.15));color:light-dark(#16191f,#e2e8f0)">
                            <i class="fa-solid fa-pen-to-square text-[10px]"></i> Edit
                        </a>
                        <form method="post" asp-page-handler="Delete" class="inline">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@c.Id" />
                            <input type="hidden" name="scope" value="@Model.Scope" />
                            <button type="submit" onclick="return confirm('Delete customer?')"
                                    class="inline-flex items-center gap-1 rounded-full border text-[11px] font-semibold px-2.5 py-1 hover:opacity-80 transition" style="border-color:rgba(239,68,68,.4);background:rgba(239,68,68,.08);color:rgb(252 165 165)">
                                <i class="fa-solid fa-trash-can text-[10px]"></i> Delete
                            </button>
                        </form>
                    </div>
                </div>
            }
            @if (Model.Items.Count == 0)
            {
                <div class="text-center py-6 text-sm" style="color:light-dark(#687078,#94a3b8)">No customers found.</div>
            }
        </div>

    </div>

</section>

@section Scripts {
<script>
(function(){
    var filterToggle=document.getElementById('svcCustFilterToggle');
    var filterRow=document.querySelector('.svc-filter-row');
    var filterBar=document.getElementById('svcCustFilterBar');
    var filterOpen=false;
    function syncFilterUi(){
        if(filterRow)filterRow.style.display=filterOpen?'':'none';
        if(filterBar)filterBar.style.display=filterOpen?'':'none';
        if(filterToggle){
            var dI=filterToggle.querySelector('i[data-icon="down"]');
            var uI=filterToggle.querySelector('i[data-icon="up"]');
            if(dI)dI.classList.toggle('hidden',filterOpen);
            if(uI)uI.classList.toggle('hidden',!filterOpen);
        }
    }
    syncFilterUi();
    if(filterToggle&&filterRow){filterToggle.addEventListener('click',function(){filterOpen=!filterOpen;syncFilterUi();});}
    window.addEventListener('pageshow',function(){filterOpen=false;syncFilterUi();});

    var table=document.getElementById('svcCustTable');
    var ctxMenu=document.getElementById('svcCustCtxMenu');
    var ctxColIdx=null;
    var colNames=['Customer No.','Name','Type','City','Address','Status','Opened','Phone','Email','Payment Terms','Actions'];
    var tbody=table?table.querySelector('tbody'):null;
    var filters=table?table.querySelectorAll('.svc-col-filter'):[];
    var pagerSummary=document.getElementById('svcCustPagerSummary');
    var pagerPrev=document.getElementById('svcCustPagerPrev');
    var pagerNext=document.getElementById('svcCustPagerNext');
    var pagerNumbers=document.getElementById('svcCustPagerNumbers');
    var currentPage=1;
    var colvisStorageKey='ldatabrain.crm.customers.visibleColumns';
    var pageSizeStorageKey='ldatabrain.crm.customers.pageSize';

    function getFilteredRows(){
        return tbody?Array.from(tbody.querySelectorAll('tr')).filter(function(r){return r.dataset.globalHide!=='1'&&r.dataset.colHide!=='1';}):[];
    }

    function renderPager(totalRows,limit){
        var totalPages=limit<0?1:Math.max(1,Math.ceil(totalRows/Math.max(limit,1)));
        if(currentPage>totalPages)currentPage=totalPages;
        if(currentPage<1)currentPage=1;
        var start=totalRows===0?0:(limit<0?1:((currentPage-1)*limit)+1);
        var end=totalRows===0?0:(limit<0?totalRows:Math.min(totalRows,currentPage*limit));
        if(pagerSummary)pagerSummary.textContent='Showing '+start+' to '+end+' of '+totalRows+' entries';
        if(pagerPrev)pagerPrev.disabled=currentPage<=1||totalRows===0||limit<0;
        if(pagerNext)pagerNext.disabled=currentPage>=totalPages||totalRows===0||limit<0;
        if(!pagerNumbers)return;
        pagerNumbers.innerHTML='';
        if(totalRows===0)return;
        var startPage=Math.max(1,currentPage-2);
        var endPage=Math.min(totalPages,currentPage+2);
        if(endPage-startPage<4){
            if(startPage===1)endPage=Math.min(totalPages,startPage+4);
            else if(endPage===totalPages)startPage=Math.max(1,endPage-4);
        }
        for(var p=startPage;p<=endPage;p++){
            var btn=document.createElement('button');
            btn.type='button';
            btn.className='svc-pager-btn'+(p===currentPage?' is-active':'');
            btn.textContent=String(p);
            btn.setAttribute('data-page',String(p));
            btn.addEventListener('click',function(){currentPage=parseInt(this.getAttribute('data-page')||'1',10)||1;applyPaging();});
            pagerNumbers.appendChild(btn);
        }
    }

    function openCtxMenu(el,ci){
        ctxColIdx=ci;
        ctxMenu.style.top='-9999px';ctxMenu.style.left='-9999px';
        ctxMenu.classList.add('open');
        var mr=ctxMenu.getBoundingClientRect(),mw=mr.width,mh=mr.height;
        var r=el.getBoundingClientRect();
        var top=r.bottom+4;
        var left=r.right-mw;
        if(left<8)left=8;
        if(left+mw>window.innerWidth-8)left=window.innerWidth-mw-8;
        if(top+mh>window.innerHeight-8)top=Math.max(8,r.top-mh-4);
        ctxMenu.style.top=top+'px';ctxMenu.style.left=left+'px';
    }
    function closeCtxMenu(){ctxMenu.classList.remove('open');ctxColIdx=null;}
    if(table){table.querySelectorAll('.svc-cust-th-btn').forEach(function(b){b.addEventListener('click',function(e){e.stopPropagation();var th=b.closest('th');var idx=th?parseInt(th.getAttribute('data-col-idx'),10):null;if(idx===null||isNaN(idx))return;if(ctxMenu.classList.contains('open')&&ctxColIdx===idx){closeCtxMenu();return;}openCtxMenu(b,idx);});});}
    document.addEventListener('click',function(e){if(ctxMenu&&!ctxMenu.contains(e.target))closeCtxMenu();});

    function applyColumnFilters(){if(!tbody)return;currentPage=1;tbody.querySelectorAll('tr').forEach(function(row){var cells=row.querySelectorAll('td');var vis=true;filters.forEach(function(f){var col=parseInt(f.getAttribute('data-col'),10);if(isNaN(col)||col>=cells.length)return;var val=(cells[col].getAttribute('data-full')||cells[col].textContent||'').toLowerCase();var term=f.value.toLowerCase().trim();if(term&&val.indexOf(term)===-1)vis=false;});row.dataset.colHide=vis?'':'1';});applyPaging();}
    if(filters.length&&tbody)filters.forEach(function(f){f.addEventListener('input',applyColumnFilters);});

    var globalSearch=document.getElementById('svcCustGlobalSearch');
    function applyGlobalSearch(){if(!tbody)return;currentPage=1;var term=(globalSearch?globalSearch.value:'').toLowerCase().trim();tbody.querySelectorAll('tr').forEach(function(row){if(!term){row.dataset.globalHide='';return;}var cells=row.querySelectorAll('td');var found=false;cells.forEach(function(c){var v=(c.getAttribute('data-full')||c.textContent||'').toLowerCase();if(v.indexOf(term)!==-1)found=true;});row.dataset.globalHide=found?'':'1';});applyPaging();}
    function applyVisibility(){if(!tbody)return;tbody.querySelectorAll('tr').forEach(function(row){row.style.display=(row.dataset.globalHide==='1'||row.dataset.colHide==='1'||row.dataset.pageHide==='1')?'none':'';});}

    var pageSizeSelect=document.getElementById('svcCustPageSize');
    var currentPageSize=50;
    function applyPaging(){if(!tbody)return;var visibleRows=getFilteredRows();var limit=currentPageSize<0?-1:currentPageSize;var totalRows=visibleRows.length;var totalPages=limit<0?1:Math.max(1,Math.ceil(totalRows/Math.max(limit,1)));if(currentPage>totalPages)currentPage=totalPages;if(currentPage<1)currentPage=1;visibleRows.forEach(function(r,i){if(limit<0){r.dataset.pageHide='';return;}var startIndex=(currentPage-1)*limit;var endIndex=startIndex+limit;r.dataset.pageHide=(i>=startIndex&&i<endIndex)?'':'1';});applyVisibility();renderPager(totalRows,limit);}
    if(pageSizeSelect){try{var savedPageSize=window.localStorage?window.localStorage.getItem(pageSizeStorageKey):null;if(savedPageSize&&pageSizeSelect.querySelector('option[value="'+savedPageSize+'"]'))pageSizeSelect.value=savedPageSize;}catch{}pageSizeSelect.addEventListener('change',function(){currentPageSize=parseInt(this.value,10);currentPage=1;try{if(window.localStorage)window.localStorage.setItem(pageSizeStorageKey,this.value);}catch{}applyPaging();});currentPageSize=parseInt(pageSizeSelect.value,10);}
    if(globalSearch)globalSearch.addEventListener('input',function(){applyGlobalSearch();});
    if(pagerPrev){pagerPrev.addEventListener('click',function(){if(currentPage>1){currentPage--;applyPaging();}});}
    if(pagerNext){pagerNext.addEventListener('click',function(){if(currentPageSize<0)return;currentPage++;applyPaging();});}

    function sortTable(ci,asc){if(!table)return;var tbd=table.querySelector('tbody');if(!tbd)return;var rows=Array.from(tbd.querySelectorAll('tr'));rows.sort(function(a,b){var ac=a.querySelectorAll('td'),bc=b.querySelectorAll('td');var av=(ac[ci]?(ac[ci].getAttribute('data-full')||ac[ci].textContent):'').toLowerCase().trim();var bv=(bc[ci]?(bc[ci].getAttribute('data-full')||bc[ci].textContent):'').toLowerCase().trim();var an=parseFloat(av),bn=parseFloat(bv);if(!isNaN(an)&&!isNaN(bn))return asc?an-bn:bn-an;return asc?av.localeCompare(bv):bv.localeCompare(av);});rows.forEach(function(r){tbd.appendChild(r);});applyPaging();}
    function swapColumns(a,b){table.querySelectorAll('tr').forEach(function(row){var cells=Array.from(row.querySelectorAll('th, td'));if(!cells[a]||!cells[b])return;if(a<b)row.insertBefore(cells[b],cells[a]);else row.insertBefore(cells[a],cells[b]);});}

    var colvisToggle=document.getElementById('svc-cust-colvis-toggle'),colvisMenu=document.getElementById('svc-cust-colvis-menu');
    function saveColVisibility(){if(!colvisMenu||!window.localStorage)return;var state={};colvisMenu.querySelectorAll('input[data-colvis]').forEach(function(cb){state[cb.getAttribute('data-colvis')]=cb.checked;});window.localStorage.setItem(colvisStorageKey,JSON.stringify(state));}
    function loadColVisibility(){if(!colvisMenu||!window.localStorage)return null;try{return JSON.parse(window.localStorage.getItem(colvisStorageKey)||'null');}catch{return null;}}
    function setColVisible(ci,show,skipSave){table.querySelectorAll('tr').forEach(function(row){var c=row.querySelectorAll('th, td');if(c[ci])c[ci].style.display=show?'':'none';});var cb=colvisMenu?colvisMenu.querySelector('input[data-colvis="'+ci+'"]'):null;if(cb)cb.checked=show;if(!skipSave)saveColVisibility();}

    ctxMenu.querySelectorAll('.svc-ctx-menu-item').forEach(function(item){item.addEventListener('click',function(){var action=item.getAttribute('data-action');var ci=ctxColIdx;closeCtxMenu();if(ci===null)return;switch(action){case'sort-asc':sortTable(ci,true);break;case'sort-desc':sortTable(ci,false);break;case'hide':setColVisible(ci,false);break;case'move-left':if(ci>0)swapColumns(ci-1,ci);break;case'move-right':var max=colNames.length-2;if(ci<max)swapColumns(ci,ci+1);break;case'clear-filter':var inp=table.querySelector('.svc-col-filter[data-col="'+ci+'"]');if(inp){inp.value='';applyColumnFilters();}break;}});});

    if(colvisMenu){colNames.forEach(function(name,idx){var lbl=document.createElement('label');var cb=document.createElement('input');cb.type='checkbox';cb.checked=true;cb.setAttribute('data-colvis',idx);cb.style.accentColor='#3b82f6';lbl.appendChild(cb);lbl.appendChild(document.createTextNode(' '+name));colvisMenu.appendChild(lbl);cb.addEventListener('change',function(){setColVisible(idx,cb.checked);});});var savedVisibility=loadColVisibility();if(savedVisibility){Object.keys(savedVisibility).forEach(function(key){var idx=parseInt(key,10);if(isNaN(idx))return;setColVisible(idx,!!savedVisibility[key],true);});}}
    if(colvisToggle&&colvisMenu){colvisToggle.addEventListener('click',function(e){e.stopPropagation();colvisMenu.classList.toggle('hidden');});document.addEventListener('click',function(e){if(!colvisMenu.contains(e.target)&&e.target!==colvisToggle)colvisMenu.classList.add('hidden');});}

    document.getElementById('svcCustBtnExcel')?.addEventListener('click',function(){var rows=[colNames.slice(0,-1).join(',')];(tbody?tbody.querySelectorAll('tr'):[]).forEach(function(tr){if(tr.style.display==='none')return;var cells=tr.querySelectorAll('td');var row=[];for(var i=0;i<cells.length-1;i++){var v=(cells[i].getAttribute('data-full')||cells[i].textContent||'').trim();row.push('"'+v.replace(/"/g,'""')+'"');}rows.push(row.join(','));});var blob=new Blob(['﻿'+rows.join('\n')],{type:'text/csv;charset=utf-8;'});var a=document.createElement('a');a.href=URL.createObjectURL(blob);a.download='Customers.csv';a.click();URL.revokeObjectURL(a.href);});
    function printOrPdf(){var clone=table.cloneNode(true);clone.querySelectorAll('.svc-filter-row').forEach(function(r){r.remove();});clone.querySelectorAll('tr').forEach(function(tr){if(tr.style.display==='none')tr.remove();});clone.querySelectorAll('tr').forEach(function(tr){var cells=tr.querySelectorAll('th, td');if(cells.length)cells[cells.length-1].remove();});var w=window.open('','_blank');w.document.write('<html><head><title>Customers</title><style>body{font-family:system-ui,sans-serif;padding:20px}table{border-collapse:collapse;width:100%}th,td{border:1px solid #ccc;padding:6px 10px;text-align:left;font-size:12px}th{background:#f0f0f0;font-weight:600;text-transform:uppercase}</style></head><body>');w.document.write('<h2>Customers</h2>');w.document.write(clone.outerHTML);w.document.write('</body></html>');w.document.close();setTimeout(function(){w.print();},300);}
    document.getElementById('svcCustBtnPdf')?.addEventListener('click',printOrPdf);
    document.getElementById('svcCustBtnPrint')?.addEventListener('click',printOrPdf);
    applyPaging();
})();
</script>
}
