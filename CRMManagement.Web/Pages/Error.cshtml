@page
@model ErrorModel
@{
    ViewData["Title"] = "Error";
}

<section class="w-full mt-10 px-4">
    <div class="mx-auto max-w-5xl grid grid-cols-1 lg:grid-cols-[minmax(0,1.1fr)_minmax(360px,420px)] gap-5 items-stretch">
        <div class="rounded-2xl border border-slate-600/50 bg-slate-700/80 text-slate-100 overflow-hidden shadow-[0_6px_24px_-10px_rgba(2,6,23,.25)] hidden lg:block">
            <div class="p-8 h-full flex flex-col justify-between">
                <div>
                    <div class="inline-flex items-center gap-2 rounded-full border border-slate-500/60 bg-slate-800/35 px-3 py-1 text-[11px] font-semibold uppercase tracking-[0.22em] text-slate-300">
                        <i class="fa-solid fa-triangle-exclamation text-brand"></i>
                        Error state
                    </div>
                    <h1 class="mt-6 text-3xl font-semibold tracking-tight">Something went wrong</h1>
                    <p class="mt-3 text-sm leading-relaxed text-slate-300">A request failed while rendering the workspace. Use the request identifier for troubleshooting and return to a stable entry point.</p>
                </div>
            </div>
        </div>

        <div class="rounded-2xl border border-slate-600/50 bg-slate-700/80 text-slate-100 overflow-hidden shadow-[0_6px_24px_-10px_rgba(2,6,23,.25)]">
            <div class="px-6 py-5 border-b border-slate-600/40">
                <h1 class="text-xl font-semibold tracking-tight">Error</h1>
                <p class="mt-1 text-sm text-slate-300">An error occurred while processing your request.</p>
            </div>
            <div class="px-6 py-5 space-y-4">
                @if (Model.ShowRequestId)
                {
                    <div class="rounded-xl border border-slate-500/60 bg-slate-800/35 px-4 py-3 text-sm text-slate-200">
                        <span class="font-semibold">Request ID:</span>
                        <span class="font-mono text-slate-100">@Model.RequestId</span>
                    </div>
                }

                <a asp-page="/Dashboard/Index" class="inline-flex items-center justify-center rounded-xl bg-brand px-4 py-2 text-sm font-semibold text-white hover:opacity-95">Back to dashboard</a>

                <environment include="Development">
                    <div class="rounded-xl border border-amber-300/30 bg-amber-500/10 px-4 py-3 text-sm text-amber-100 space-y-2">
                        <div class="font-semibold">Development Mode</div>
                        <p>Detailed exception information is shown only in the Development environment.</p>
                        <p>Do not enable Development in production because it can expose sensitive application details.</p>
                    </div>
                </environment>
            </div>
        </div>
    </div>
</section>
