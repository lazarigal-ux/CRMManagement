@page
@model CRMManagement.Web.Pages.Tickets.IndexModel
@{ ViewData["Title"] = "Tickets"; }

<style>
    .ml-auto{margin-left:auto}.flex-nowrap{flex-wrap:nowrap}.flex-wrap{flex-wrap:wrap}.flex-row{flex-direction:row}.items-end{align-items:flex-end}.w-9{width:2.25rem}.h-9{height:2.25rem}.gap-1{gap:.25rem}.py-1\.5{padding-top:.375rem;padding-bottom:.375rem}.min-w-\[10rem\]{min-width:10rem}.text-\[12px\]{font-size:12px}.text-\[11px\]{font-size:11px}.text-\[10px\]{font-size:10px}.text-\[9px\]{font-size:9px}.text-emerald-400{color:rgb(52 211 153)}.text-sky-400{color:rgb(56 189 248)}.bg-brand\/15{background-color:rgba(59,130,246,.15)}.border-brand\/30{border-color:rgba(59,130,246,.3)}.hover\:opacity-80:hover{opacity:.8}.backdrop-blur-sm{-webkit-backdrop-filter:blur(4px);backdrop-filter:blur(4px)}.shadow-xl{box-shadow:0 20px 25px -5px rgba(0,0,0,.1),0 8px 10px -6px rgba(0,0,0,.1)}.flex-1{flex:1 1 0%}.focus\:border-blue-500:focus{border-color:rgb(59 130 246)}.focus\:ring-blue-600:focus{--tw-ring-color:rgb(37 99 235)}.focus\:ring-1:focus{--tw-ring-offset-shadow:var(--tw-ring-inset) 0 0 0 var(--tw-ring-offset-width) var(--tw-ring-offset-color);--tw-ring-shadow:var(--tw-ring-inset) 0 0 0 calc(1px + var(--tw-ring-offset-width)) var(--tw-ring-color);box-shadow:var(--tw-ring-offset-shadow),var(--tw-ring-shadow),var(--tw-shadow,0 0 #0000)}.right-0{right:0}.mt-2{margin-top:.5rem}.w-48{width:12rem}.p-2{padding:.5rem}.leading-tight{line-height:1.25}.shrink-0{flex-shrink:0}

    #tickTable{border-collapse:collapse}
    #tickTable th,#tickTable td{border-right:1px solid rgba(148,163,184,.2)!important}
    #tickTable th:last-child,#tickTable td:last-child{border-right:none!important}
    #tickTable tbody td{border-bottom:1px solid rgba(148,163,184,.25)!important}
    #tickTable thead th{border-bottom:1px solid rgba(148,163,184,.35)!important}

    html[data-theme="gray"] .tick-table-card{background:rgb(51,65,85)!important;border-color:rgba(148,163,184,.45)!important;box-shadow:0 6px 24px -4px rgba(0,0,0,.55),0 0 0 1px rgba(255,255,255,.07)!important}
    html[data-theme="black"] .tick-table-card{background:rgb(22,22,22)!important;border-color:rgba(255,255,255,.08)!important;box-shadow:0 2px 12px rgba(0,0,0,.6)!important}
    html[data-theme="black"] .tick-table-card .tick-toolbar{border-bottom-color:rgba(255,255,255,.06)!important}
    html[data-theme="black"] .tick-table-card .tick-toolbar-btn{border-color:rgba(255,255,255,.12)!important}
    html[data-theme="black"] .tick-table-card thead tr:first-child{background:rgba(255,255,255,.04)!important}
    html[data-theme="black"] .tick-table-card .tick-filter-row{background:rgba(255,255,255,.02)!important}
    html[data-theme="black"] .tick-table-card .tick-col-filter{background:rgba(0,0,0,.4)!important;border-color:rgba(255,255,255,.10)!important}
    html[data-theme="black"] .tick-table-card tbody tr:hover{background:rgba(255,255,255,.06)!important}
    html[data-theme="black"] .tick-filters-panel{border-bottom-color:rgba(255,255,255,.06)!important}
    html[data-theme="light"] .tick-table-card{background:#ffffff!important;border-color:#d5dbdb!important;box-shadow:0 1px 4px rgba(0,0,0,.08)!important;color:#16191f!important}
    html[data-theme="light"] .tick-table-card .tick-toolbar{border-bottom-color:#e5e7eb!important}
    html[data-theme="light"] .tick-table-card thead tr:first-child{background:#f7f8f8!important;color:#16191f!important}
    html[data-theme="light"] .tick-table-card .tick-filter-row{background:#f7f8f8!important}
    html[data-theme="light"] .tick-table-card .tick-col-filter{background:#ffffff!important;border-color:#aab7b8!important;color:#16191f!important}
    html[data-theme="light"] .tick-table-card tbody tr{color:#16191f!important}
    html[data-theme="light"] .tick-table-card tbody tr:hover{background:rgba(0,0,0,.03)!important}

    .tick-action-btn{display:inline-flex;align-items:center;justify-content:center;gap:.4rem;padding:.2rem .75rem;border-radius:.5rem;font-size:.75rem;font-weight:600;line-height:1;white-space:nowrap;border:1px solid transparent;transition:transform 150ms ease,box-shadow 150ms ease,border-color 150ms ease,background 150ms ease,color 150ms ease}
    .tick-action-btn:hover{transform:translateY(-1px)}
    .tick-action-btn--primary{background:linear-gradient(135deg,rgb(59 130 246),rgb(37 99 235));color:#fff;box-shadow:0 10px 24px rgba(37,99,235,.22)}
    .tick-action-btn--secondary{border-color:light-dark(#aab7b8,rgba(71,85,105,.9));background:light-dark(#ffffff,rgba(30,41,59,.6));color:light-dark(#16191f,rgb(226 232 240));box-shadow:inset 0 1px 0 light-dark(rgba(0,0,0,.04),rgba(148,163,184,.08))}
    .tick-action-btn--secondary:hover{border-color:light-dark(rgba(0,115,187,.45),rgba(96,165,250,.45));background:light-dark(#f7f8f8,rgba(30,41,59,.88));color:light-dark(#16191f,rgb(248 250 252))}

    .tick-badge{display:inline-flex;align-items:center;gap:.35rem;padding:.15rem .6rem;border-radius:9999px;font-size:10px;font-weight:600;border:1px solid transparent;white-space:nowrap}
    .tick-badge--open{background:rgba(56,189,248,.10);border-color:rgba(56,189,248,.25);color:rgb(56 189 248)}
    .tick-badge--inprogress{background:rgba(251,191,36,.10);border-color:rgba(251,191,36,.25);color:rgb(251 191 36)}
    .tick-badge--resolved{background:rgba(52,211,153,.10);border-color:rgba(52,211,153,.25);color:rgb(52 211 153)}
    .tick-badge--closed{background:rgba(148,163,184,.10);border-color:rgba(148,163,184,.25);color:rgb(148 163 184)}
    .tick-badge--default{background:rgba(148,163,184,.10);border-color:rgba(148,163,184,.25);color:rgb(148 163 184)}
    .tick-badge--high{background:rgba(251,113,133,.10);border-color:rgba(251,113,133,.25);color:rgb(251 113 133)}
    .tick-badge--medium{background:rgba(251,191,36,.10);border-color:rgba(251,191,36,.25);color:rgb(251 191 36)}
    .tick-badge--low{background:rgba(56,189,248,.10);border-color:rgba(56,189,248,.25);color:rgb(56 189 248)}
    .tick-badge--critical{background:rgba(239,68,68,.10);border-color:rgba(239,68,68,.25);color:rgb(239 68 68)}

    .tick-ctx-menu{position:fixed;z-index:9999;min-width:13rem;padding:.35rem 0;border-radius:.65rem;border:1px solid light-dark(#d5dbdb,rgba(71,85,105,.6));background:light-dark(#ffffff,rgba(30,41,59,.97));color:light-dark(#16191f,#f1f5f9);box-shadow:0 12px 32px -4px rgba(0,0,0,.35),0 0 0 1px rgba(255,255,255,.04);backdrop-filter:blur(12px);-webkit-backdrop-filter:blur(12px);font-size:13px;line-height:1;display:none}
    .tick-ctx-menu.open{display:block}
    .tick-ctx-menu-item{display:flex;align-items:center;gap:.6rem;padding:.5rem .85rem;cursor:pointer;transition:background 100ms;white-space:nowrap;border:none;background:none;width:100%;color:inherit;font-size:inherit;text-align:left}
    .tick-ctx-menu-item:hover{background:light-dark(rgba(0,0,0,.05),rgba(255,255,255,.08))}
    .tick-ctx-menu-item i{width:1rem;text-align:center;font-size:12px}
    .tick-ctx-menu-item--danger{color:rgb(239 68 68)}
    .tick-ctx-menu-item--danger:hover{background:rgba(239,68,68,.08)}
    .tick-ctx-sep{height:1px;margin:.3rem .6rem;background:light-dark(#e5e7eb,rgba(71,85,105,.45))}
    html[data-theme="black"] .tick-ctx-menu{background:rgba(17,17,17,.97)!important;border-color:rgba(255,255,255,.08)!important}
    html[data-theme="light"] .tick-ctx-menu{background:#ffffff!important;border-color:#d5dbdb!important;color:#16191f!important}

    #tick-colvis-menu label{display:flex;align-items:center;gap:.5rem;padding:.35rem .5rem;border-radius:.375rem;cursor:pointer;transition:background 120ms}
    #tick-colvis-menu label:hover{background:light-dark(rgba(0,0,0,.05),rgba(255,255,255,.08))}
    html[data-theme="black"] #tick-colvis-menu{background:rgba(17,17,17,.97)!important;border-color:rgba(255,255,255,.08)!important}

    @@media(max-width:640px){
        .tick-toolbar{flex-wrap:wrap;padding:.5rem .75rem;gap:.4rem}
        .tick-toolbar .ml-auto{flex-wrap:wrap;gap:.3rem}
        .tick-toolbar .ml-auto button>span,.tick-toolbar .ml-auto a>span{display:none}
        .tick-toolbar h3{font-size:.7rem}
        #tickTable th,#tickTable td{padding-left:.35rem;padding-right:.35rem;font-size:10px}
        .tick-col-filter{min-width:3rem;font-size:10px;padding:.15rem .3rem}
        .tick-filters-panel{padding:.5rem .75rem}
        .tick-filters-panel .flex-1{min-width:6rem!important}
    }
</style>

<div id="tickCtxMenu" class="tick-ctx-menu">
    <button type="button" class="tick-ctx-menu-item" data-action="sort-asc"><i class="fa-solid fa-arrow-down-a-z"></i><span>Sort A &#x2192; Z</span></button>
    <button type="button" class="tick-ctx-menu-item" data-action="sort-desc"><i class="fa-solid fa-arrow-down-z-a"></i><span>Sort Z &#x2192; A</span></button>
    <div class="tick-ctx-sep"></div>
    <button type="button" class="tick-ctx-menu-item" data-action="hide"><i class="fa-solid fa-eye-slash"></i><span>Hide column</span></button>
    <div class="tick-ctx-sep"></div>
    <button type="button" class="tick-ctx-menu-item" data-action="move-left"><i class="fa-solid fa-arrow-left"></i><span>Move column left</span></button>
    <button type="button" class="tick-ctx-menu-item" data-action="move-right"><i class="fa-solid fa-arrow-right"></i><span>Move column right</span></button>
    <div class="tick-ctx-sep"></div>
    <button type="button" class="tick-ctx-menu-item" data-action="clear-filter"><i class="fa-solid fa-filter-circle-xmark"></i><span>Clear filter</span></button>
    <button type="button" class="tick-ctx-menu-item tick-ctx-menu-item--danger" data-action="remove"><i class="fa-solid fa-trash-can"></i><span>Remove column</span></button>
</div>

<section class="w-full mt-2" style="padding-left:0;" data-page="crm-tickets">
    <div class="w-full rounded-2xl border overflow-hidden tick-table-card"
         style="background:light-dark(#ffffff,rgb(51,65,85));border-color:light-dark(#d5dbdb,rgba(71,85,105,.5));box-shadow:light-dark(0 1px 4px rgba(0,0,0,.1),0 2px 8px rgba(0,0,0,.35));color:light-dark(#16191f,#f1f5f9)">

        <div class="flex items-center gap-2 px-4 py-3 tick-toolbar" style="border-bottom:1px solid light-dark(#d5dbdb,rgba(71,85,105,.4))">
            <i class="fa-solid fa-ticket text-sm" style="color:light-dark(#0073bb,#60a5fa)"></i>
            <h3 class="text-sm font-semibold uppercase tracking-wider" style="color:light-dark(#545b64,#cbd5e1)">Tickets</h3>
            <div class="ml-auto flex items-center justify-end gap-2 flex-nowrap">
                <button id="tickTopbarToggle" type="button" class="inline-flex shrink-0 items-center justify-center w-9 h-9 rounded-full border ring-1 hover:opacity-80 transition tick-toolbar-btn" style="border-color:light-dark(#aab7b8,rgba(100,116,139,.6));ring-color:light-dark(rgba(0,0,0,.06),rgba(148,163,184,.2))" title="Show/Hide filters"><i class="fa-solid fa-filter text-[12px]"></i></button>
                <div class="relative shrink-0">
                    <button id="tick-colvis-toggle" type="button" class="inline-flex items-center gap-2 rounded-full border ring-1 px-3 py-1.5 text-sm hover:opacity-80 transition tick-toolbar-btn" style="border-color:light-dark(#aab7b8,rgba(100,116,139,.6));ring-color:light-dark(rgba(0,0,0,.06),rgba(148,163,184,.2))" title="Show/Hide columns"><i class="fa-solid fa-table-columns text-[12px]"></i><span>Cols &#x25BE;</span></button>
                    <div id="tick-colvis-menu" class="hidden absolute right-0 z-50 mt-2 w-48 rounded-xl border shadow-xl backdrop-blur-sm p-2 text-sm leading-tight" style="border-color:light-dark(#d5dbdb,rgba(71,85,105,.6));background:light-dark(#ffffff,rgba(30,41,59,.95));color:light-dark(#16191f,#f1f5f9)"></div>
                </div>
                <div class="flex items-center rounded-full border ring-1 overflow-hidden tick-toolbar-btn" style="border-color:light-dark(#aab7b8,rgba(100,116,139,.6));ring-color:light-dark(rgba(0,0,0,.06),rgba(148,163,184,.2))">
                    <button type="button" id="tickBtnExcel" class="inline-flex items-center gap-1 px-3 py-1.5 text-sm hover:opacity-80 transition" style="border-right:1px solid light-dark(#d5dbdb,rgba(100,116,139,.4));color:light-dark(#16191f,#f1f5f9)" title="Export to Excel"><i class="fa-solid fa-file-excel text-[12px] text-emerald-400"></i><span>Excel</span></button>
                    <button type="button" id="tickBtnPdf" class="inline-flex items-center gap-1 px-3 py-1.5 text-sm hover:opacity-80 transition" style="border-right:1px solid light-dark(#d5dbdb,rgba(100,116,139,.4));color:light-dark(#16191f,#f1f5f9)" title="Export to PDF"><i class="fa-solid fa-file-pdf text-[12px]" style="color:rgb(251 113 133)"></i><span>PDF</span></button>
                    <button type="button" id="tickBtnPrint" class="inline-flex items-center gap-1 px-3 py-1.5 text-sm hover:opacity-80 transition" style="color:light-dark(#16191f,#f1f5f9)" title="Print table"><i class="fa-solid fa-print text-[12px] text-sky-400"></i><span>Print</span></button>
                </div>
                <a asp-page="/Tickets/Upsert" class="inline-flex items-center gap-2 rounded-full border ring-1 px-3 py-1.5 text-sm hover:opacity-80 transition tick-toolbar-btn" style="border-color:light-dark(#aab7b8,rgba(100,116,139,.6));ring-color:light-dark(rgba(0,0,0,.06),rgba(148,163,184,.2))" title="Add new ticket"><i class="fa-solid fa-plus text-[12px] text-emerald-400"></i><span>New</span></a>
                <span class="inline-flex items-center gap-1 rounded-full bg-brand/15 border border-brand/30 px-3 py-0.5 text-xs font-semibold" style="color:light-dark(#0073bb,rgb(96 165 250))"><i class="fa-solid fa-hashtag text-[9px]"></i>@Model.Items.Count</span>
            </div>
        </div>

        <div id="tickFilters" class="tick-filters-panel px-4 py-3 hidden" style="border-bottom:1px solid light-dark(#d5dbdb,rgba(71,85,105,.4))">
            <form method="get" class="flex flex-row flex-wrap items-end gap-3">
                <div class="flex-1 min-w-[10rem]">
                    <label class="block text-xs mb-1" style="color:light-dark(#545b64,#94a3b8)" for="status">Status</label>
                    <input id="status" name="status" value="@Model.Status" class="w-full rounded-lg border px-3 py-1.5 text-sm focus:border-blue-500 focus:ring-blue-600 focus:ring-1" style="background:light-dark(#ffffff,rgba(30,41,59,.4));border-color:light-dark(#aab7b8,rgba(100,116,139,.5));color:light-dark(#16191f,#f1f5f9)" placeholder="open / in progress / resolved …" />
                </div>
                <div class="flex-1 min-w-[10rem]">
                    <label class="block text-xs mb-1" style="color:light-dark(#545b64,#94a3b8)" for="priority">Priority</label>
                    <input id="priority" name="priority" value="@Model.Priority" class="w-full rounded-lg border px-3 py-1.5 text-sm focus:border-blue-500 focus:ring-blue-600 focus:ring-1" style="background:light-dark(#ffffff,rgba(30,41,59,.4));border-color:light-dark(#aab7b8,rgba(100,116,139,.5));color:light-dark(#16191f,#f1f5f9)" placeholder="low / medium / high / critical" />
                </div>
                <div class="flex-1 min-w-[10rem]">
                    <label class="block text-xs mb-1" style="color:light-dark(#545b64,#94a3b8)" for="ownerUserId">Owner</label>
                    <input id="ownerUserId" name="ownerUserId" value="@Model.OwnerUserId" class="w-full rounded-lg border px-3 py-1.5 text-sm focus:border-blue-500 focus:ring-blue-600 focus:ring-1" style="background:light-dark(#ffffff,rgba(30,41,59,.4));border-color:light-dark(#aab7b8,rgba(100,116,139,.5));color:light-dark(#16191f,#f1f5f9)" placeholder="owner id" />
                </div>
                <div class="flex items-end gap-3">
                    <button type="submit" class="tick-action-btn tick-action-btn--primary"><i class="fa-solid fa-magnifying-glass text-[11px]"></i><span>Search</span></button>
                    <a class="tick-action-btn tick-action-btn--secondary" asp-page="/Tickets/Index"><i class="fa-solid fa-rotate-left text-[11px]"></i><span>Reset</span></a>
                </div>
            </form>
        </div>

        <div class="overflow-x-auto">
            <table id="tickTable" data-cm-table="tickets" class="min-w-full">
                <thead>
                    <tr style="background:light-dark(#f7f8f8,rgba(30,41,59,.8));color:light-dark(#16191f,#f1f5f9)" class="text-[11px] uppercase tracking-wide select-none">
                        <th class="px-3 py-3 text-left align-top whitespace-nowrap" data-col-idx="0"><div class="flex items-start justify-between gap-2"><span class="inline-flex items-center gap-2"><i class="fa-solid fa-hashtag text-[10px]"></i><span>Number</span></span><button type="button" class="tick-th-btn opacity-40 hover:opacity-100 text-xs px-1 py-0.5 rounded-md border border-transparent hover:border-current/30" title="Column filter"><i class="fa-solid fa-filter text-[10px]"></i></button></div></th>
                        <th class="px-3 py-3 text-left align-top whitespace-nowrap" data-col-idx="1"><div class="flex items-start justify-between gap-2"><span class="inline-flex items-center gap-2"><i class="fa-solid fa-pen text-[10px]"></i><span>Subject</span></span><button type="button" class="tick-th-btn opacity-40 hover:opacity-100 text-xs px-1 py-0.5 rounded-md border border-transparent hover:border-current/30" title="Column filter"><i class="fa-solid fa-filter text-[10px]"></i></button></div></th>
                        <th class="px-3 py-3 text-left align-top whitespace-nowrap" data-col-idx="2"><div class="flex items-start justify-between gap-2"><span class="inline-flex items-center gap-2"><i class="fa-solid fa-circle-info text-[10px]"></i><span>Status</span></span><button type="button" class="tick-th-btn opacity-40 hover:opacity-100 text-xs px-1 py-0.5 rounded-md border border-transparent hover:border-current/30" title="Column filter"><i class="fa-solid fa-filter text-[10px]"></i></button></div></th>
                        <th class="px-3 py-3 text-left align-top whitespace-nowrap" data-col-idx="3"><div class="flex items-start justify-between gap-2"><span class="inline-flex items-center gap-2"><i class="fa-solid fa-flag text-[10px]"></i><span>Priority</span></span><button type="button" class="tick-th-btn opacity-40 hover:opacity-100 text-xs px-1 py-0.5 rounded-md border border-transparent hover:border-current/30" title="Column filter"><i class="fa-solid fa-filter text-[10px]"></i></button></div></th>
                        <th class="px-3 py-3 text-left align-top whitespace-nowrap" data-col-idx="4"><div class="flex items-start justify-between gap-2"><span class="inline-flex items-center gap-2"><i class="fa-solid fa-calendar text-[10px]"></i><span>Opened</span></span><button type="button" class="tick-th-btn opacity-40 hover:opacity-100 text-xs px-1 py-0.5 rounded-md border border-transparent hover:border-current/30" title="Column filter"><i class="fa-solid fa-filter text-[10px]"></i></button></div></th>
                        @* Extra Zoho fields — default-hidden, surfaced via the "Columns" picker *@
                        <th class="px-3 py-3 text-left align-top whitespace-nowrap" data-col-idx="5"  data-cm-default-hide="1">Account</th>
                        <th class="px-3 py-3 text-left align-top whitespace-nowrap" data-col-idx="6"  data-cm-default-hide="1">Contact</th>
                        <th class="px-3 py-3 text-left align-top whitespace-nowrap" data-col-idx="7"  data-cm-default-hide="1">Channel</th>
                        <th class="px-3 py-3 text-left align-top whitespace-nowrap" data-col-idx="8"  data-cm-default-hide="1">Reported By</th>
                        <th class="px-3 py-3 text-left align-top whitespace-nowrap" data-col-idx="9"  data-cm-default-hide="1">Description</th>
                        <th class="px-3 py-3 text-left align-top whitespace-nowrap" data-col-idx="10" data-cm-default-hide="1">Owner</th>
                        <th class="px-3 py-3 text-left align-top whitespace-nowrap" data-col-idx="11" data-cm-default-hide="1">Resolved At</th>
                        <th class="px-3 py-3 text-left align-top whitespace-nowrap" data-col-idx="12" data-cm-default-hide="1">Closed At</th>
                        <th class="px-3 py-3 text-left align-top whitespace-nowrap" data-col-idx="13" data-cm-default-hide="1">Created (Zoho)</th>
                        <th class="px-3 py-3 text-left align-top whitespace-nowrap" data-col-idx="14" data-cm-default-hide="1">Modified (Zoho)</th>
                        <th class="px-3 py-3 text-center align-top whitespace-nowrap" style="width:4.5rem;"><span class="inline-flex items-center gap-2"><i class="fa-solid fa-ellipsis text-[10px]"></i></span></th>
                    </tr>
                    <tr class="tick-filter-row text-[12px]" style="background:light-dark(#f7f8f8,rgba(30,41,59,.6));color:light-dark(#16191f,#e2e8f0)">
                        @for(var i=0;i<5;i++){<th class="px-3 py-2"><input class="tick-col-filter w-full rounded-md border px-2 py-1 text-[12px] outline-none focus:border-blue-500 focus:ring-2 focus:ring-blue-600/40" style="background:light-dark(#ffffff,rgba(30,41,59,.4));border-color:light-dark(#aab7b8,rgba(100,116,139,.5));color:light-dark(#16191f,#f1f5f9)" type="text" placeholder="Search" data-col="@i" /></th>}
                        @for(var i=5;i<=14;i++){<th class="px-3 py-2"></th>}
                        <th class="px-3 py-2"></th>
                    </tr>
                </thead>
                <tbody>
                @if(Model.Items.Count>0){
                    @foreach(var t in Model.Items){
                        var statusLower=t.Status?.ToLowerInvariant()??"";
                        var statusClass=statusLower switch{
                            "open"=>"tick-badge--open",
                            "in progress" or "inprogress"=>"tick-badge--inprogress",
                            "resolved"=>"tick-badge--resolved",
                            "closed"=>"tick-badge--closed",
                            _=>"tick-badge--default"
                        };
                        var prioLower=t.Priority?.ToLowerInvariant()??"";
                        var prioClass=prioLower switch{
                            "high"=>"tick-badge--high",
                            "medium"=>"tick-badge--medium",
                            "low"=>"tick-badge--low",
                            "critical"=>"tick-badge--critical",
                            _=>"tick-badge--default"
                        };
                        <tr class="hover:opacity-90 transition-colors align-top" style="border-top:1px solid light-dark(#e5e7eb,rgba(71,85,105,.5))">
                            <td class="px-3 py-3 text-xs whitespace-nowrap" data-full="@t.TicketNumber"><span class="font-medium">@t.TicketNumber</span></td>
                            <td class="px-3 py-3 text-xs whitespace-nowrap" data-full="@t.Subject">@t.Subject</td>
                            <td class="px-3 py-3 text-xs whitespace-nowrap" data-full="@t.Status"><span class="tick-badge @statusClass">@t.Status</span></td>
                            <td class="px-3 py-3 text-xs whitespace-nowrap" data-full="@t.Priority"><span class="tick-badge @prioClass">@t.Priority</span></td>
                            <td class="px-3 py-3 text-xs whitespace-nowrap" data-full="@t.OpenedAt.ToString("yyyy-MM-dd")">@t.OpenedAt.ToString("yyyy-MM-dd")</td>
                            @{
                                var tickDesc     = string.IsNullOrWhiteSpace(t.Description) ? "-" : (t.Description!.Length > 80 ? t.Description.Substring(0, 80) + "…" : t.Description);
                                var tickResolved = t.ResolvedAt?.ToString("yyyy-MM-dd HH:mm") ?? "-";
                                var tickClosed   = t.ClosedAt?.ToString("yyyy-MM-dd HH:mm") ?? "-";
                                var tickZCreated = t.ZohoCreatedTime?.ToString("yyyy-MM-dd HH:mm") ?? "-";
                                var tickZMod     = t.ZohoModifiedTime?.ToString("yyyy-MM-dd HH:mm") ?? "-";
                            }
                            <td class="px-3 py-3 text-xs whitespace-nowrap" data-full="@(t.AccountName ?? "-")">@(t.AccountName ?? "-")</td>
                            <td class="px-3 py-3 text-xs whitespace-nowrap" data-full="@(t.ContactName ?? "-")">@(t.ContactName ?? "-")</td>
                            <td class="px-3 py-3 text-xs whitespace-nowrap" data-full="@(t.Channel ?? "-")">@(t.Channel ?? "-")</td>
                            <td class="px-3 py-3 text-xs whitespace-nowrap" data-full="@(t.ReportedBy ?? "-")">@(t.ReportedBy ?? "-")</td>
                            <td class="px-3 py-3 text-xs" data-full="@(t.Description ?? "")" title="@(t.Description ?? "")">@tickDesc</td>
                            <td class="px-3 py-3 text-xs whitespace-nowrap" data-full="@(t.OwnerName ?? "-")">@(t.OwnerName ?? "-")</td>
                            <td class="px-3 py-3 text-xs whitespace-nowrap" data-full="@tickResolved">@tickResolved</td>
                            <td class="px-3 py-3 text-xs whitespace-nowrap" data-full="@tickClosed">@tickClosed</td>
                            <td class="px-3 py-3 text-xs whitespace-nowrap" data-full="@tickZCreated">@tickZCreated</td>
                            <td class="px-3 py-3 text-xs whitespace-nowrap" data-full="@tickZMod">@tickZMod</td>
                            <td class="px-3 py-3 text-xs text-center whitespace-nowrap">
                                <a class="inline-flex items-center gap-1 rounded-full border px-2.5 py-1 text-[10px] font-medium hover:opacity-80 transition" style="border-color:light-dark(#aab7b8,rgba(100,116,139,.5));color:light-dark(#0073bb,#60a5fa)" asp-page="/Tickets/Details" asp-route-id="@t.Id"><i class="fa-solid fa-arrow-up-right-from-square text-[9px]"></i>Details</a>
                            </td>
                        </tr>
                    }
                }
                </tbody>
            </table>
        </div>
        @if(Model.Items.Count==0){<div class="px-4 py-8 text-center" style="color:light-dark(#545b64,#94a3b8);border-top:1px solid light-dark(#d5dbdb,rgba(71,85,105,.4))">No tickets found.</div>}
    </div>
</section>

@section Scripts{
<script>
(function(){
    var btn=document.getElementById('tickTopbarToggle'),panel=document.getElementById('tickFilters'),filtersOpen=false;
    function setFiltersOpen(o){filtersOpen=!!o;if(panel)panel.classList.toggle('hidden',!filtersOpen);}
    var hasActive=@((!string.IsNullOrWhiteSpace(Model.Status)||!string.IsNullOrWhiteSpace(Model.Priority)||Model.OwnerUserId!=null).ToString().ToLowerInvariant());
    setFiltersOpen(hasActive);
    if(btn)btn.addEventListener('click',function(){setFiltersOpen(!filtersOpen);});

    var table=document.getElementById('tickTable');
    var ctxMenu=document.getElementById('tickCtxMenu');
    var ctxColIdx=null;
    function openCtxMenu(btnEl,colIdx){ctxColIdx=colIdx;ctxMenu.style.top='-9999px';ctxMenu.style.left='-9999px';ctxMenu.classList.add('open');var mr=ctxMenu.getBoundingClientRect(),mw=mr.width,mh=mr.height;var r=btnEl.getBoundingClientRect();var top=r.bottom+4,left=r.right-mw-40;if(left<8)left=8;if(left+mw>window.innerWidth-8)left=window.innerWidth-mw-8;if(top+mh>window.innerHeight-8)top=Math.max(8,r.top-mh-4);ctxMenu.style.top=top+'px';ctxMenu.style.left=left+'px';}
    function closeCtxMenu(){ctxMenu.classList.remove('open');ctxColIdx=null;}
    if(table){table.querySelectorAll('.tick-th-btn').forEach(function(thBtn){thBtn.addEventListener('click',function(e){e.stopPropagation();var th=thBtn.closest('th');var idx=th?parseInt(th.getAttribute('data-col-idx'),10):null;if(idx===null||isNaN(idx))return;if(ctxMenu.classList.contains('open')&&ctxColIdx===idx){closeCtxMenu();return;}openCtxMenu(thBtn,idx);});});}
    document.addEventListener('click',function(e){if(ctxMenu&&!ctxMenu.contains(e.target))closeCtxMenu();});

    var colNames=['Number','Subject','Status','Priority','Opened','Actions'];
    var filterRow=table?table.querySelector('.tick-filter-row'):null;
    var tbody=table?table.querySelector('tbody'):null;
    var filters=table?table.querySelectorAll('.tick-col-filter'):[];
    function applyColumnFilters(){if(!tbody)return;tbody.querySelectorAll('tr').forEach(function(row){var cells=row.querySelectorAll('td');var visible=true;filters.forEach(function(f){var col=parseInt(f.getAttribute('data-col'),10);if(isNaN(col)||col>=cells.length)return;var val=(cells[col].getAttribute('data-full')||cells[col].textContent||'').toLowerCase();var term=f.value.toLowerCase().trim();if(term&&val.indexOf(term)===-1)visible=false;});row.style.display=visible?'':'none';});}
    if(filters.length&&tbody){filters.forEach(function(input){input.addEventListener('input',applyColumnFilters);});}

    function sortTable(ci,asc){if(!table)return;var tbd=table.querySelector('tbody');if(!tbd)return;var rows=Array.from(tbd.querySelectorAll('tr'));rows.sort(function(a,b){var ac=a.querySelectorAll('td'),bc=b.querySelectorAll('td');var av=(ac[ci]?(ac[ci].getAttribute('data-full')||ac[ci].textContent):'').toLowerCase().trim();var bv=(bc[ci]?(bc[ci].getAttribute('data-full')||bc[ci].textContent):'').toLowerCase().trim();var an=parseFloat(av),bn=parseFloat(bv);if(!isNaN(an)&&!isNaN(bn))return asc?an-bn:bn-an;return asc?av.localeCompare(bv):bv.localeCompare(av);});rows.forEach(function(r){tbd.appendChild(r);});}
    function swapColumns(a,b){table.querySelectorAll('tr').forEach(function(row){var cells=Array.from(row.querySelectorAll('th, td'));if(!cells[a]||!cells[b])return;if(a<b)row.insertBefore(cells[b],cells[a]);else row.insertBefore(cells[a],cells[b]);});}
    function setColVisible(ci,show){table.querySelectorAll('tr').forEach(function(row){var c=row.querySelectorAll('th, td');if(c[ci])c[ci].style.display=show?'':'none';});var cb=colvisMenu?colvisMenu.querySelector('input[data-colvis="'+ci+'"]'):null;if(cb)cb.checked=show;}

    ctxMenu.querySelectorAll('.tick-ctx-menu-item').forEach(function(item){item.addEventListener('click',function(){var action=item.getAttribute('data-action');var ci=ctxColIdx;closeCtxMenu();if(ci===null)return;switch(action){case'sort-asc':sortTable(ci,true);break;case'sort-desc':sortTable(ci,false);break;case'hide':setColVisible(ci,false);break;case'move-left':if(ci>0)swapColumns(ci-1,ci);break;case'move-right':var max=colNames.length-2;if(ci<max)swapColumns(ci,ci+1);break;case'clear-filter':var inp=table.querySelector('.tick-col-filter[data-col="'+ci+'"]');if(inp){inp.value='';applyColumnFilters();}break;case'remove':setColVisible(ci,false);break;}});});

    var colvisToggle=document.getElementById('tick-colvis-toggle');
    var colvisMenu=document.getElementById('tick-colvis-menu');
    if(colvisMenu){colNames.forEach(function(name,idx){var lbl=document.createElement('label');var cb=document.createElement('input');cb.type='checkbox';cb.checked=true;cb.setAttribute('data-colvis',idx);cb.style.accentColor='#3b82f6';lbl.appendChild(cb);lbl.appendChild(document.createTextNode(' '+name));colvisMenu.appendChild(lbl);cb.addEventListener('change',function(){var show=cb.checked;table.querySelectorAll('tr').forEach(function(row){var cells=row.querySelectorAll('th, td');if(cells[idx])cells[idx].style.display=show?'':'none';});});});}
    if(colvisToggle&&colvisMenu){colvisToggle.addEventListener('click',function(e){e.stopPropagation();colvisMenu.classList.toggle('hidden');});document.addEventListener('click',function(e){if(!colvisMenu.contains(e.target)&&e.target!==colvisToggle)colvisMenu.classList.add('hidden');});}

    document.getElementById('tickBtnExcel')?.addEventListener('click',function(){var rows=[colNames.slice(0,-1).join(',')];(tbody?tbody.querySelectorAll('tr'):[]).forEach(function(tr){if(tr.style.display==='none')return;var cells=tr.querySelectorAll('td');var row=[];for(var i=0;i<cells.length-1;i++){var v=(cells[i].getAttribute('data-full')||cells[i].textContent||'').trim();row.push('"'+v.replace(/"/g,'""')+'"');}rows.push(row.join(','));});var blob=new Blob(['\uFEFF'+rows.join('\n')],{type:'text/csv;charset=utf-8;'});var a=document.createElement('a');a.href=URL.createObjectURL(blob);a.download='Tickets.csv';a.click();URL.revokeObjectURL(a.href);});
    function printOrPdf(isPdf){var clone=table.cloneNode(true);clone.querySelectorAll('.tick-filter-row').forEach(function(r){r.remove();});clone.querySelectorAll('tr').forEach(function(tr){if(tr.style.display==='none')tr.remove();});clone.querySelectorAll('tr').forEach(function(tr){var cells=tr.querySelectorAll('th, td');if(cells.length)cells[cells.length-1].remove();});var w=window.open('','_blank');w.document.write('<html><head><title>Tickets</title><style>body{font-family:system-ui,sans-serif;padding:20px}table{border-collapse:collapse;width:100%}th,td{border:1px solid #ccc;padding:6px 10px;text-align:left;font-size:12px}th{background:#f0f0f0;font-weight:600;text-transform:uppercase}</style></head><body>');w.document.write('<h2>Tickets</h2>');w.document.write(clone.outerHTML);w.document.write('</body></html>');w.document.close();setTimeout(function(){w.print();},300);}
    document.getElementById('tickBtnPdf')?.addEventListener('click',function(){printOrPdf(true);});
    document.getElementById('tickBtnPrint')?.addEventListener('click',function(){printOrPdf(false);});
})();
</script>
}
