@page "{id:guid}"
@model CRMManagement.Web.Pages.Tickets.DetailsModel
@{ ViewData["Title"] = "Ticket Details"; }

@if (Model.Item is null)
{
    <div class="p-4 text-slate-300">Not found.</div>
}
else
{
    var t = Model.Item;
    <section class="p-4 space-y-4">
        <div class="flex items-center justify-between">
            <h1 class="text-2xl font-semibold text-slate-100">@t.TicketNumber - @t.Subject</h1>
            <div class="flex gap-2">
                <a asp-page="/Tickets/Upsert" asp-route-id="@t.Id" class="px-4 py-2 rounded-xl bg-blue-600 hover:bg-blue-500 text-white text-sm">Edit</a>
                @if (t.ClosedAt is null)
                {
                    <form method="post" asp-page-handler="Close" asp-route-id="@t.Id">
                        <button class="px-4 py-2 rounded-xl bg-red-600 hover:bg-red-500 text-white text-sm">Close</button>
                    </form>
                }
            </div>
        </div>
        <div class="rounded-2xl border border-slate-700/50 bg-slate-800/40 p-6 grid grid-cols-1 md:grid-cols-2 gap-4 text-sm text-slate-200">
            <div><span class="text-slate-400">Status:</span> @t.Status</div>
            <div><span class="text-slate-400">Priority:</span> @t.Priority</div>
            <div><span class="text-slate-400">Type:</span> @t.Type</div>
            <div><span class="text-slate-400">Channel:</span> @t.Channel</div>
            <div><span class="text-slate-400">Opened:</span> @t.OpenedAt.ToString("yyyy-MM-dd HH:mm")</div>
            <div><span class="text-slate-400">Resolved:</span> @t.ResolvedAt</div>
            <div><span class="text-slate-400">Closed:</span> @t.ClosedAt</div>
            <div><span class="text-slate-400">Account:</span> @t.AccountId</div>
            <div class="md:col-span-2"><span class="text-slate-400">Description:</span> @t.Description</div>
        </div>
    </section>
}
