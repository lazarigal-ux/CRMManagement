@page
@model CRMManagement.Web.Pages.Auth.DeniedModel
@{
    ViewData["Title"] = "Access denied";
    ViewData["ForceHideSidebar"] = true;
}

<section class="w-full mt-10 px-4">
    <div class="mx-auto max-w-5xl grid grid-cols-1 lg:grid-cols-[minmax(0,1.1fr)_minmax(360px,420px)] gap-5 items-stretch">
        <div class="rounded-2xl border border-slate-600/50 bg-slate-700/80 text-slate-100 overflow-hidden shadow-[0_6px_24px_-10px_rgba(2,6,23,.25)] hidden lg:block">
            <div class="p-8 h-full flex flex-col justify-between">
                <div>
                    <div class="inline-flex items-center gap-2 rounded-full border border-slate-500/60 bg-slate-800/35 px-3 py-1 text-[11px] font-semibold uppercase tracking-[0.22em] text-slate-300">
                        <i class="fa-solid fa-lock text-brand"></i>
                        Authorization
                    </div>
                    <h1 class="mt-6 text-3xl font-semibold tracking-tight">This area is restricted</h1>
                    <p class="mt-3 text-sm leading-relaxed text-slate-300">The page follows the same shared shell but access is blocked for the current identity or role.</p>
                </div>
            </div>
        </div>

        <div class="rounded-2xl border border-slate-600/50 bg-slate-700/80 text-slate-100 overflow-hidden shadow-[0_6px_24px_-10px_rgba(2,6,23,.25)]">
            <div class="px-6 py-5 border-b border-slate-600/40">
                <h1 class="text-xl font-semibold tracking-tight">Access denied</h1>
                <p class="mt-1 text-sm text-slate-300">You don’t have permission to view this page.</p>
            </div>
            <div class="px-6 py-5">
                <a asp-page="/Home/Index" class="inline-flex items-center justify-center rounded-xl bg-brand px-4 py-2 text-sm font-semibold text-white hover:opacity-95">
                    Go to home
                </a>
            </div>
        </div>
    </div>
</section>
