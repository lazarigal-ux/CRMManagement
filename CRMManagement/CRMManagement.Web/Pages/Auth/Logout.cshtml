@page
@model CRMManagement.Web.Pages.Auth.LogoutModel
@{
    ViewData["Title"] = "Logout";
    ViewData["ForceHideSidebar"] = true;
}

<section class="w-full mt-10 px-4">
    <div class="mx-auto max-w-5xl grid grid-cols-1 lg:grid-cols-[minmax(0,1.1fr)_minmax(360px,420px)] gap-5 items-stretch">
        <div class="rounded-2xl border border-slate-600/50 bg-slate-700/80 text-slate-100 overflow-hidden shadow-[0_6px_24px_-10px_rgba(2,6,23,.25)] hidden lg:block">
            <div class="p-8 h-full flex flex-col justify-between">
                <div>
                    <div class="inline-flex items-center gap-2 rounded-full border border-slate-500/60 bg-slate-800/35 px-3 py-1 text-[11px] font-semibold uppercase tracking-[0.22em] text-slate-300">
                        <i class="fa-solid fa-arrow-right-from-bracket text-brand"></i>
                        Session
                    </div>
                    <h1 class="mt-6 text-3xl font-semibold tracking-tight">Sign out from the workspace</h1>
                    <p class="mt-3 text-sm leading-relaxed text-slate-300">Confirm the session action in the same shared card language used throughout the restyled module.</p>
                </div>
            </div>
        </div>

        <div class="mx-auto w-full max-w-md rounded-2xl border border-slate-600/50 bg-slate-700/80 text-slate-100 overflow-hidden shadow-[0_6px_24px_-10px_rgba(2,6,23,.25)]">
            <div class="px-6 py-5 border-b border-slate-600/40">
                <h1 class="text-xl font-semibold tracking-tight">Sign out</h1>
                <p class="mt-1 text-sm text-slate-300">Confirm you want to sign out.</p>
            </div>
            <div class="px-6 py-5">
                <form method="post" class="flex items-center justify-end gap-2">
                    @Html.AntiForgeryToken()
                    <a href="/" class="inline-flex items-center justify-center rounded-xl border border-slate-500/60 bg-transparent px-4 py-2 text-sm text-slate-100 hover:bg-slate-600">Cancel</a>
                    <button type="submit" class="inline-flex items-center justify-center rounded-xl bg-brand px-4 py-2 text-sm font-semibold text-white hover:opacity-95">Sign out</button>
                </form>
            </div>
        </div>
    </div>
</section>
