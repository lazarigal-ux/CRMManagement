@page "/Admin"
@model CRMManagement.Web.Pages.Admin.IndexModel
@{ ViewData["Title"] = "Settings"; }

<style>
    .stg-shell {
        max-width: 1200px;
        margin: 0 auto;
    }
    .stg-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
        gap: 1rem;
    }
    .stg-card {
        border-radius: 1rem;
        border: 1px solid light-dark(#d5dbdb, rgba(71,85,105,.5));
        background: light-dark(#ffffff, rgb(51,65,85));
        box-shadow: light-dark(0 1px 4px rgba(0,0,0,.08), 0 2px 8px rgba(0,0,0,.35));
        padding: 1.1rem 1.25rem 1rem;
        display: flex;
        flex-direction: column;
        gap: .55rem;
    }
    .stg-card h3 {
        display: flex; align-items: center; gap: .55rem;
        font-size: .8rem;
        font-weight: 700;
        letter-spacing: .14em;
        text-transform: uppercase;
        color: light-dark(#0073bb, #7dd3fc);
        padding-bottom: .55rem;
        border-bottom: 1px solid light-dark(#e5e7eb, rgba(255,255,255,.08));
    }
    .stg-card h3 i { font-size: .9rem; }
    .stg-link {
        display: block;
        padding: .35rem .55rem;
        border-radius: .5rem;
        color: light-dark(#16191f, #e2e8f0);
        text-decoration: none;
        transition: background .12s, color .12s;
    }
    .stg-link:hover {
        background: light-dark(#f2f3f3, rgba(255,255,255,.06));
        color: light-dark(#0073bb, #93c5fd);
    }
    .stg-link .stg-link-title {
        display: flex; align-items: center; gap: .55rem;
        font-size: .85rem; font-weight: 600;
    }
    .stg-link .stg-link-title i { width: 1rem; text-align: center; color: light-dark(#545b64, #94a3b8); }
    .stg-link .stg-link-desc {
        margin: .15rem 0 0 1.55rem;
        font-size: .72rem;
        color: light-dark(#687078, #94a3b8);
        line-height: 1.35;
    }
    .stg-search {
        width: 100%; max-width: 380px;
        padding: .5rem .85rem;
        border-radius: 999px;
        border: 1px solid light-dark(#aab7b8, rgba(100,116,139,.55));
        background: light-dark(#ffffff, rgba(30,41,59,.5));
        color: light-dark(#16191f, #f1f5f9);
        font-size: .85rem;
        outline: none;
    }
    .stg-search:focus { border-color: #3b82f6; box-shadow: 0 0 0 3px rgba(59,130,246,.18); }

    html[data-theme="black"] .stg-card { background: rgb(22,22,22); border-color: rgba(255,255,255,.08); }
    html[data-theme="black"] .stg-link:hover { background: rgba(255,255,255,.05); }
</style>

<section class="w-full mt-2 stg-shell" data-page="crm-settings">

    <header class="flex flex-wrap items-center gap-3 mb-4 px-1">
        <i class="fa-solid fa-gears text-xl" style="color:light-dark(#0073bb,#60a5fa)"></i>
        <div class="min-w-0">
            <h1 class="text-xl font-semibold" style="color:light-dark(#16191f,#f1f5f9)">Settings</h1>
            <div class="text-xs mt-0.5" style="color:light-dark(#687078,#94a3b8)">
                Configure pipelines, tags, users, AI tooling, and integrations.
            </div>
        </div>
        <input id="stgSearch" type="search" placeholder="Search settings..." class="stg-search ml-auto" autocomplete="off" />
    </header>

    <div id="stgGrid" class="stg-grid">
        @foreach (var cat in Model.Categories)
        {
            <div class="stg-card" data-stg-card>
                <h3>
                    <i class="fa-solid @cat.Icon"></i>
                    <span>@cat.Title</span>
                </h3>
                @foreach (var link in cat.Links)
                {
                    var href = !string.IsNullOrEmpty(link.Href) ? link.Href : Url.Page(link.Page);
                    <a class="stg-link" data-stg-item data-search="@($"{cat.Title} {link.Label} {link.Description}".ToLowerInvariant())" href="@href">
                        <div class="stg-link-title"><i class="fa-solid @link.Icon"></i><span>@link.Label</span></div>
                        <div class="stg-link-desc">@link.Description</div>
                    </a>
                }
            </div>
        }
    </div>
</section>

@section Scripts {
    <script>
        (function () {
            var input = document.getElementById('stgSearch');
            if (!input) return;
            var items = Array.prototype.slice.call(document.querySelectorAll('[data-stg-item]'));
            var cards = Array.prototype.slice.call(document.querySelectorAll('[data-stg-card]'));
            input.addEventListener('input', function () {
                var q = (input.value || '').trim().toLowerCase();
                items.forEach(function (el) {
                    var hit = !q || (el.getAttribute('data-search') || '').indexOf(q) !== -1;
                    el.style.display = hit ? '' : 'none';
                });
                cards.forEach(function (card) {
                    var visible = card.querySelectorAll('[data-stg-item]:not([style*="display: none"])').length > 0;
                    card.style.display = visible ? '' : 'none';
                });
            });
        })();
    </script>
}
