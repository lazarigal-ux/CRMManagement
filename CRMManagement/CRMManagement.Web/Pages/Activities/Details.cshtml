@page "{id:guid}"
@model CRMManagement.Web.Pages.Activities.DetailsModel
@{ ViewData["Title"] = "Activity Details"; }

@if (Model.Item is null)
{
    <div class="p-4 text-slate-300">Not found.</div>
}
else
{
    var a = Model.Item;
    <section class="p-4 space-y-4">
        <div class="flex items-center justify-between">
            <h1 class="text-2xl font-semibold text-slate-100">@a.Subject</h1>
            <div class="flex gap-2">
                <a asp-page="/Activities/Upsert" asp-route-id="@a.Id" class="px-4 py-2 rounded-xl bg-blue-600 hover:bg-blue-500 text-white text-sm">Edit</a>
                @if (a.CompletedAt is null)
                {
                    <form method="post" asp-page-handler="Complete" asp-route-id="@a.Id">
                        <button class="px-4 py-2 rounded-xl bg-emerald-600 hover:bg-emerald-500 text-white text-sm">Complete</button>
                    </form>
                }
            </div>
        </div>
        <div class="rounded-2xl border border-slate-700/50 bg-slate-800/40 p-6 grid grid-cols-1 md:grid-cols-2 gap-4 text-sm text-slate-200">
            <div><span class="text-slate-400">Type:</span> @a.Type</div>
            <div><span class="text-slate-400">Status:</span> @a.Status</div>
            <div><span class="text-slate-400">Priority:</span> @a.Priority</div>
            <div><span class="text-slate-400">Due:</span> @(a.DueDate?.ToString("yyyy-MM-dd") ?? "-")</div>
            <div><span class="text-slate-400">Start:</span> @a.StartAt</div>
            <div><span class="text-slate-400">End:</span> @a.EndAt</div>
            <div><span class="text-slate-400">Related:</span> @a.RelatedType / @a.RelatedId</div>
            <div><span class="text-slate-400">Location:</span> @a.Location</div>
            <div class="md:col-span-2"><span class="text-slate-400">Description:</span> @a.Description</div>
        </div>
        <partial name="_CustomFields" model='(EntityType: "Activity", EntityId: Model.Item!.Id)' />
</section>
}
