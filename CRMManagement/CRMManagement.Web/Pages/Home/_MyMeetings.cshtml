@model IReadOnlyList<CRMManagement.Application.DTOs.MeetingListItemDto>
<div class="crm-dash-panel space-y-3">
    <div class="flex items-center justify-between gap-3">
        <div>
            <h3>My Meetings</h3>
            <div class="mt-1 text-xs" style="color:light-dark(#687078, #94a3b8)">Upcoming meetings and events on your calendar.</div>
        </div>
        <i class="fa-solid fa-calendar-day text-sm" style="color:light-dark(#0073bb, #60a5fa)"></i>
    </div>
    @if (Model.Count == 0)
    {
        <div class="text-sm" style="color:light-dark(#687078, #94a3b8)">No upcoming meetings.</div>
    }
    else
    {
        <div class="overflow-x-auto">
            <table data-cm-table="home-meetings" class="crm-dash-table min-w-full text-sm">
                <thead style="background-color:light-dark(#dde3ea, rgba(0,0,0,.15))">
                    <tr style="color:light-dark(#545b64, #94a3b8)">
                        <th class="px-3 py-2 text-left text-xs font-semibold uppercase tracking-wider" data-col-idx="0">Title</th>
                        <th class="px-3 py-2 text-left text-xs font-semibold uppercase tracking-wider" data-col-idx="1">From</th>
                        <th class="px-3 py-2 text-left text-xs font-semibold uppercase tracking-wider" data-col-idx="2">To</th>
                        <th class="px-3 py-2 text-left text-xs font-semibold uppercase tracking-wider" data-col-idx="3">Account</th>
                        @* Extra Zoho fields — default-hidden, surfaced via the "Columns" picker *@
                        <th class="px-3 py-2 text-left text-xs font-semibold uppercase tracking-wider" data-col-idx="4" data-cm-default-hide="1">Status</th>
                        <th class="px-3 py-2 text-left text-xs font-semibold uppercase tracking-wider" data-col-idx="5" data-cm-default-hide="1">Location</th>
                        <th class="px-3 py-2 text-left text-xs font-semibold uppercase tracking-wider" data-col-idx="6" data-cm-default-hide="1">Related To</th>
                        <th class="px-3 py-2 text-left text-xs font-semibold uppercase tracking-wider" data-col-idx="7" data-cm-default-hide="1">Owner</th>
                        <th class="px-3 py-2 text-left text-xs font-semibold uppercase tracking-wider" data-col-idx="8" data-cm-default-hide="1">Description</th>
                        <th class="px-3 py-2 text-left text-xs font-semibold uppercase tracking-wider" data-col-idx="9" data-cm-default-hide="1">Created (Zoho)</th>
                        <th class="px-3 py-2 text-left text-xs font-semibold uppercase tracking-wider" data-col-idx="10" data-cm-default-hide="1">Modified (Zoho)</th>
                    </tr>
                </thead>
                <tbody class="divide-y" style="border-color:light-dark(#d5dbdb, rgba(255,255,255,.06))">
                    @foreach (var m in Model)
                    {
                        var meetDesc     = string.IsNullOrWhiteSpace(m.Description) ? "-" : (m.Description!.Length > 80 ? m.Description.Substring(0, 80) + "…" : m.Description);
                        var meetZCreated = m.ZohoCreatedTime?.ToString("yyyy-MM-dd HH:mm") ?? "-";
                        var meetZMod     = m.ZohoModifiedTime?.ToString("yyyy-MM-dd HH:mm") ?? "-";
                        <tr>
                            <td data-label="Title" class="px-3 py-2" style="color:light-dark(#16191f, #f1f5f9)">@m.Subject</td>
                            <td data-label="From" class="px-3 py-2 whitespace-nowrap" style="color:light-dark(#687078, #94a3b8)">@(m.StartAt?.ToString("yyyy-MM-dd HH:mm") ?? "-")</td>
                            <td data-label="To" class="px-3 py-2 whitespace-nowrap" style="color:light-dark(#687078, #94a3b8)">@(m.EndAt?.ToString("yyyy-MM-dd HH:mm") ?? "-")</td>
                            <td data-label="Account" class="px-3 py-2" style="color:light-dark(#545b64, #cbd5e1)">@(m.AccountName ?? "-")</td>
                            <td data-label="Status" class="px-3 py-2" style="color:light-dark(#545b64, #cbd5e1)">@m.Status</td>
                            <td data-label="Location" class="px-3 py-2" style="color:light-dark(#545b64, #cbd5e1)">@(m.Location ?? "-")</td>
                            <td data-label="Related To" class="px-3 py-2" style="color:light-dark(#545b64, #cbd5e1)">@(m.RelatedType ?? "-")</td>
                            <td data-label="Owner" class="px-3 py-2" style="color:light-dark(#545b64, #cbd5e1)">@(m.OwnerName ?? "-")</td>
                            <td data-label="Description" class="px-3 py-2" style="color:light-dark(#545b64, #cbd5e1)" title="@(m.Description ?? "")">@meetDesc</td>
                            <td data-label="Created (Zoho)" class="px-3 py-2 whitespace-nowrap" style="color:light-dark(#545b64, #cbd5e1)">@meetZCreated</td>
                            <td data-label="Modified (Zoho)" class="px-3 py-2 whitespace-nowrap" style="color:light-dark(#545b64, #cbd5e1)">@meetZMod</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
