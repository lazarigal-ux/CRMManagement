@page
@model CRMManagement.Web.Pages.PurchaseOrders.IndexModel
@{ ViewData["Title"] = "Purchase Orders"; }

<section class="p-4 space-y-4 text-slate-200">
    <div class="flex items-center justify-between">
        <div>
            <h1 class="text-2xl font-semibold text-slate-100">Purchase Orders</h1>
            <p class="text-xs text-slate-400 mt-1">Outbound orders to vendors. Synced from Zoho's <code class="text-sky-300">Purchase_Orders</code> module.</p>
        </div>
        <a asp-page="/PurchaseOrders/Upsert" class="inline-flex items-center gap-2 px-3 py-1.5 rounded-xl bg-emerald-600 hover:bg-emerald-500 text-white text-sm">
            <i class="fa-solid fa-plus text-xs"></i> New
        </a>
    </div>

    <form method="get" class="rounded-2xl border border-slate-700/50 bg-slate-800/40 p-3 flex flex-wrap items-end gap-3">
        <div class="flex-1 min-w-[12rem]">
            <label class="block text-xs text-slate-400 mb-1">Search</label>
            <input name="Search" value="@Model.Search" placeholder="PO number / subject"
                   class="w-full rounded-lg bg-slate-900/60 border border-slate-700/60 px-3 py-1.5 text-sm" />
        </div>
        <div class="min-w-[10rem]">
            <label class="block text-xs text-slate-400 mb-1">Status</label>
            <input name="Status" value="@Model.Status" placeholder="Draft / Approved / …"
                   class="w-full rounded-lg bg-slate-900/60 border border-slate-700/60 px-3 py-1.5 text-sm" />
        </div>
        <button type="submit" class="px-3 py-1.5 rounded-xl bg-sky-600 hover:bg-sky-500 text-white text-sm">Search</button>
        <a asp-page="/PurchaseOrders/Index" class="px-3 py-1.5 rounded-xl bg-slate-700 hover:bg-slate-600 text-slate-200 text-sm">Reset</a>
    </form>

    <div class="rounded-2xl border border-slate-700/50 bg-slate-800/40 overflow-hidden">
        <table data-cm-table="purchase-orders" class="min-w-full text-sm">
            <thead class="text-xs text-slate-400 uppercase bg-slate-900/40">
                <tr>
                    <th class="text-left px-3 py-2">PO #</th>
                    <th class="text-left px-3 py-2">Subject</th>
                    <th class="text-left px-3 py-2">Status</th>
                    <th class="text-right px-3 py-2">Total</th>
                    <th class="text-left px-3 py-2">PO Date</th>
                    <th class="text-left px-3 py-2">Due Date</th>
                    @* Extra Zoho fields — default-hidden, surfaced via the "Columns" picker *@
                    <th class="text-left px-3 py-2"  data-cm-default-hide="1">Vendor</th>
                    <th class="text-left px-3 py-2"  data-cm-default-hide="1">Requisition #</th>
                    <th class="text-left px-3 py-2"  data-cm-default-hide="1">Carrier</th>
                    <th class="text-right px-3 py-2" data-cm-default-hide="1">Subtotal</th>
                    <th class="text-right px-3 py-2" data-cm-default-hide="1">Discount</th>
                    <th class="text-right px-3 py-2" data-cm-default-hide="1">Tax</th>
                    <th class="text-right px-3 py-2" data-cm-default-hide="1">Adjustment</th>
                    <th class="text-left px-3 py-2"  data-cm-default-hide="1">Description</th>
                    <th class="text-left px-3 py-2"  data-cm-default-hide="1">Owner</th>
                    <th class="text-left px-3 py-2"  data-cm-default-hide="1">Created (Zoho)</th>
                    <th class="text-left px-3 py-2"  data-cm-default-hide="1">Modified (Zoho)</th>
                    <th class="px-3 py-2"></th>
                </tr>
            </thead>
            <tbody class="divide-y divide-slate-700/40">
                @if (Model.Items.Count == 0)
                {
                    <tr><td colspan="18" class="px-3 py-6 text-center text-slate-400">No purchase orders found.</td></tr>
                }
                @foreach (var p in Model.Items)
                {
                    var poSubtotal   = p.Subtotal.HasValue ? p.Subtotal.Value.ToString("N2") : "—";
                    var poDiscount   = p.Discount.HasValue ? p.Discount.Value.ToString("N2") : "—";
                    var poTax        = p.Tax.HasValue ? p.Tax.Value.ToString("N2") : "—";
                    var poAdjustment = p.AdjustmentAmount.HasValue ? p.AdjustmentAmount.Value.ToString("N2") : "—";
                    var poDesc       = string.IsNullOrWhiteSpace(p.Description) ? "—" : (p.Description!.Length > 80 ? p.Description.Substring(0, 80) + "…" : p.Description);
                    var poZCreated   = p.ZohoCreatedTime?.ToString("yyyy-MM-dd HH:mm") ?? "—";
                    var poZMod       = p.ZohoModifiedTime?.ToString("yyyy-MM-dd HH:mm") ?? "—";
                    <tr class="hover:bg-slate-700/30">
                        <td class="px-3 py-2 font-mono text-slate-100">@p.PoNumber</td>
                        <td class="px-3 py-2">@p.Subject</td>
                        <td class="px-3 py-2"><span class="px-2 py-0.5 rounded-full text-xs bg-slate-700/40 text-slate-200 border border-slate-600/40">@p.Status</span></td>
                        <td class="px-3 py-2 text-right font-mono">@p.Total.ToString("N2") @p.Currency</td>
                        <td class="px-3 py-2 text-slate-300">@(p.PoDate?.ToString("yyyy-MM-dd") ?? "—")</td>
                        <td class="px-3 py-2 text-slate-300">@(p.DueDate?.ToString("yyyy-MM-dd") ?? "—")</td>
                        <td class="px-3 py-2 text-slate-300">@(p.VendorName ?? "—")</td>
                        <td class="px-3 py-2 text-slate-300">@(p.RequisitionNo ?? "—")</td>
                        <td class="px-3 py-2 text-slate-300">@(p.CarrierName ?? "—")</td>
                        <td class="px-3 py-2 text-right text-slate-300 whitespace-nowrap">@poSubtotal</td>
                        <td class="px-3 py-2 text-right text-slate-300 whitespace-nowrap">@poDiscount</td>
                        <td class="px-3 py-2 text-right text-slate-300 whitespace-nowrap">@poTax</td>
                        <td class="px-3 py-2 text-right text-slate-300 whitespace-nowrap">@poAdjustment</td>
                        <td class="px-3 py-2 text-slate-300" title="@(p.Description ?? "")">@poDesc</td>
                        <td class="px-3 py-2 text-slate-300">@(p.OwnerName ?? "—")</td>
                        <td class="px-3 py-2 text-slate-400 whitespace-nowrap">@poZCreated</td>
                        <td class="px-3 py-2 text-slate-400 whitespace-nowrap">@poZMod</td>
                        <td class="px-3 py-2 text-right">
                            <a asp-page="/PurchaseOrders/Details" asp-route-id="@p.Id" class="text-xs text-sky-300 hover:underline">Details</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</section>
